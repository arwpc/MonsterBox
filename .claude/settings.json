{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "Bash(npm test)",
      "Bash(npm run test:*)",
      "Bash(npm run verify:*)",
      "Bash(npm run gate)",
      "Bash(npm run validate:*)",
      "Bash(npm run audit:*)",
      "Bash(npm run check)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(node --check:*)",
      "Bash(node scripts/:*)",
      "Bash(python3 -m py_compile:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "mcp__playwright__*"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -d node_modules ] || npm install --no-audit --no-fund",
            "timeout": 600,
            "statusMessage": "Ensuring npm dependencies are installed…"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["playwright"],
  "mcpServers": {
    "playwright": {
      "type": "sse",
      "url": "http://localhost:8931/sse"
    }
  }
}
