{
    "folders": [
        {
            "name": "MonsterBox",
            "path": "."
        }
    ],
    "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
            "bash": {
                "path": "/bin/bash",
                "args": ["-l"]
            }
        },
        "files.watcherExclude": {
            "**/node_modules/**": true,
            "**/.git/objects/**": true,
            "**/.git/subtree-cache/**": true,
            "**/dist/**": true,
            "**/build/**": true,
            "**/.taskmaster/**": true,
            "**/logs/**": true,
            "**/data/backups/**": true
        },
        "search.exclude": {
            "**/node_modules": true,
            "**/dist": true,
            "**/build": true,
            "**/.git": true,
            "**/.taskmaster": true,
            "**/logs": true,
            "**/data/backups": true
        },
        "files.exclude": {
            "**/.git": true,
            "**/node_modules": true,
            "**/dist": true
        },
        "files.associations": {
            "*.ejs": "html",
            "*.json": "jsonc"
        },
        "emmet.includeLanguages": {
            "ejs": "html"
        },
        "typescript.preferences.includePackageJsonAutoImports": "auto",
        "javascript.preferences.includePackageJsonAutoImports": "auto",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.eslint": true
        },
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.detectIndentation": true,
        "eslint.workingDirectories": [
            "."
        ],
        "eslint.validate": [
            "javascript",
            "javascriptreact",
            "typescript",
            "typescriptreact"
        ],
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.formatting.provider": "black",
        "git.ignoreLimitWarning": true,
        "git.autofetch": true,
        "git.confirmSync": false,
        "extensions.autoUpdate": false,
        "extensions.autoCheckUpdates": false,
        "telemetry.telemetryLevel": "off",
        "workbench.colorTheme": "Default Dark+",
        "workbench.iconTheme": "vs-seti",
        "explorer.confirmDelete": false,
        "explorer.confirmDragAndDrop": false,
        "debug.console.fontSize": 12,
        "terminal.integrated.fontSize": 12,
        "editor.fontSize": 13,
        "editor.lineHeight": 1.4,
        "editor.minimap.enabled": true,
        "editor.minimap.maxColumn": 120,
        "editor.rulers": [80, 120],
        "editor.wordWrap": "on",
        "editor.wordWrapColumn": 120,
        "breadcrumbs.enabled": true,
        "outline.showVariables": false,
        "outline.showFunctions": true,
        "outline.showClasses": true,
        "outline.showModules": true
    },
    "extensions": {
        "recommendations": [
            "ms-vscode.vscode-json",
            "ms-python.python",
            "ms-vscode.vscode-eslint",
            "bradlc.vscode-tailwindcss",
            "ms-vscode.vscode-typescript-next",
            "formulahendry.auto-rename-tag",
            "christian-kohler.path-intellisense",
            "ms-vscode.vscode-html-css-support",
            "ms-vscode.remote-ssh",
            "ms-vscode.remote-ssh-edit",
            "ms-vscode-remote.remote-ssh-explorer",
            "ms-vscode.hexeditor",
            "redhat.vscode-yaml",
            "ms-vscode.vscode-markdown",
            "yzhang.markdown-all-in-one",
            "davidanson.vscode-markdownlint",
            "ms-vscode.vscode-github-pullrequest",
            "github.vscode-github-actions",
            "ms-vscode.vscode-docker"
        ]
    },
    "tasks": {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "Start MonsterBox",
                "type": "shell",
                "command": "npm",
                "args": ["start"],
                "group": {
                    "kind": "build",
                    "isDefault": true
                },
                "presentation": {
                    "echo": true,
                    "reveal": "always",
                    "focus": false,
                    "panel": "shared",
                    "showReuseMessage": true,
                    "clear": false
                },
                "problemMatcher": []
            },
            {
                "label": "Test MonsterBox",
                "type": "shell",
                "command": "npm",
                "args": ["test"],
                "group": "test",
                "presentation": {
                    "echo": true,
                    "reveal": "always",
                    "focus": false,
                    "panel": "shared",
                    "showReuseMessage": true,
                    "clear": false
                },
                "problemMatcher": []
            },
            {
                "label": "Install Dependencies",
                "type": "shell",
                "command": "npm",
                "args": ["install"],
                "group": "build",
                "presentation": {
                    "echo": true,
                    "reveal": "always",
                    "focus": false,
                    "panel": "shared",
                    "showReuseMessage": true,
                    "clear": false
                },
                "problemMatcher": []
            },
            {
                "label": "Hardware Test",
                "type": "shell",
                "command": "npm",
                "args": ["run", "test:hardware"],
                "group": "test",
                "presentation": {
                    "echo": true,
                    "reveal": "always",
                    "focus": false,
                    "panel": "shared",
                    "showReuseMessage": true,
                    "clear": false
                },
                "problemMatcher": []
            },
            {
                "label": "Check Hardware Services",
                "type": "shell",
                "command": "bash",
                "args": ["-c", "netstat -tlnp | grep -E ':(8765|8766|877[0-9])'"],
                "group": "test",
                "presentation": {
                    "echo": true,
                    "reveal": "always",
                    "focus": false,
                    "panel": "shared",
                    "showReuseMessage": true,
                    "clear": false
                },
                "problemMatcher": []
            },
            {
                "label": "View System Logs",
                "type": "shell",
                "command": "sudo",
                "args": ["journalctl", "-u", "monsterbox", "-f", "--no-pager"],
                "group": "test",
                "presentation": {
                    "echo": true,
                    "reveal": "always",
                    "focus": false,
                    "panel": "shared",
                    "showReuseMessage": true,
                    "clear": false
                },
                "problemMatcher": []
            },
            {
                "label": "Deploy MonsterBox",
                "type": "shell",
                "command": "bash",
                "args": ["-c", "git pull origin main && npm install && npm run build && sudo systemctl restart monsterbox"],
                "group": "build",
                "presentation": {
                    "echo": true,
                    "reveal": "always",
                    "focus": false,
                    "panel": "shared",
                    "showReuseMessage": true,
                    "clear": false
                },
                "problemMatcher": []
            },
            {
                "label": "TaskMaster Status",
                "type": "shell",
                "command": "bash",
                "args": ["-c", "ANTHROPIC_API_KEY=\"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\" node node_modules/task-master-ai/bin/task-master.js list"],
                "group": "test",
                "presentation": {
                    "echo": true,
                    "reveal": "always",
                    "focus": false,
                    "panel": "shared",
                    "showReuseMessage": true,
                    "clear": false
                },
                "problemMatcher": []
            }
        ]
    },
    "launch": {
        "version": "0.2.0",
        "configurations": [
            {
                "name": "Launch MonsterBox",
                "type": "node",
                "request": "launch",
                "program": "${workspaceFolder}/app.js",
                "env": {
                    "NODE_ENV": "development"
                },
                "console": "integratedTerminal",
                "internalConsoleOptions": "neverOpen"
            },
            {
                "name": "Debug Tests",
                "type": "node",
                "request": "launch",
                "program": "${workspaceFolder}/node_modules/.bin/mocha",
                "args": [
                    "--timeout",
                    "10000",
                    "tests/**/*.test.js"
                ],
                "env": {
                    "NODE_ENV": "test"
                },
                "console": "integratedTerminal",
                "internalConsoleOptions": "neverOpen"
            },
            {
                "name": "Debug Hardware Tests",
                "type": "node",
                "request": "launch",
                "program": "${workspaceFolder}/node_modules/.bin/mocha",
                "args": [
                    "--timeout",
                    "30000",
                    "tests/hardware/**/*.test.js"
                ],
                "env": {
                    "NODE_ENV": "test"
                },
                "console": "integratedTerminal",
                "internalConsoleOptions": "neverOpen"
            }
        ]
    }
}
