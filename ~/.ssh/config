# Global settings for all RPI devices
Host rpi* orlok coffin pumpkinhead skulltalker
    User remote
    IdentityFile ~/.ssh/id_ed25519
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    ServerAliveInterval 60
    ServerAliveCountMax 3

# MonsterBox Animatronics
Host orlok
    HostName 192.168.8.120
    User remote
    Port 22

Host coffin
    HostName 192.168.8.140
    User remote
    Port 22

Host skulltalker
    HostName 192.168.8.130
    User remote
    Port 22

Host pumpkinhead
    HostName 192.168.1.101
    User remote
    Port 22
    # Note: Currently offline according to config

# Alternative/backup IPs (if needed)
Host pumpkinhead-alt
    HostName 192.168.8.200
    User remote
    Port 22

# Legacy RPI numbering (keeping your original entries)
Host rpi1
    HostName 192.168.1.101
    User pi

Host rpi2
    HostName 192.168.1.102
    User pi

# Generic RPI pattern matching
Host rpi-*
    User pi
    IdentityFile ~/.ssh/id_ed25519
