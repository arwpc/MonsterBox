  {
    "id": "1758764520000",
    "name": "Nema17 Stepper Motor",
    "description": "Precision stepper motor, 200 steps/revolution (1.8° per step), ideal for animatronics positioning",
    "defaults": {
      "stepsPerRevolution": 200,
      "stepAngle": 1.8,
