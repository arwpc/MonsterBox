  {
    "id": "3",
    "name": "GoBilda 2000 Series Dual-Mode (New Spec)",
    "manufacturer": "GoBilda",
    "defaults": {
      "servoType": "continuous",
      "controllerType": "pca9685",
      "neutralPulse": 1500,
      "minPulse": 900,
      "maxPulse": 2100,
      "positionalMinPulse": 500,
      "positionalMaxPulse": 2500,
      "rotationRangeDeg": 1800
    },
    "meta": {
      "notes": "New unified model for GoBilda 2000 series 5-turn dual-mode servo. Default mode: Continuous (900–2100µs active, 1500µs neutral, CW with increasing PWM). Positional/Feedback mode supported (500–2500µs maps to 0–1800°). Specs: 64g, 300:1, 25T spline, 4.8–7.4V, 0.17–0.25s/60°, 17.2–25.2 kg·cm, stall 2–3A, deadband 4µs, 5-turn max in positional mode.",
      "controlType": [
        "PWM"
      ]
    }
  },
