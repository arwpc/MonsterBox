[
  {
    "id": "default_wiper_motor_bts7960",
    "name": "Default Wiper Motor (BTS7960)",
    "manufacturer": "Generic",
    "description": "12V DC wiper motor driven by BTS7960 dual H-bridge (Left/Right Enable + shared PWM)",
    "defaults": {
      "motorType": "dc",
      "driver": "BTS7960",
      "nominalVoltage": 12,
      "maxDutyPct": 100,
      "maxDuration": 10000,
      "recommendedPwmFrequencyHz": 1000,
      "notes": "Use leftEnablePin/rightEnablePin for direction; only one enable HIGH at a time with shared PWM."
    },
    "controlsSchema": {
      "controlType": [
        "DUAL_ENABLE_PWM"
      ],
      "inputs": [
        {
          "name": "leftEnablePin",
          "type": "number"
        },
        {
          "name": "rightEnablePin",
          "type": "number"
        },
        {
          "name": "pwmPin",
          "type": "number"
        },
        {
          "name": "speed",
          "type": "number",
          "optional": true
        },
        {
          "name": "duration",
          "type": "number",
          "optional": true
        }
      ]
    },
    "meta": {
      "stallCurrentA": 20,
      "typicalCurrentA": 5,
      "polarity": "Swap enable pins to reverse",
      "driverNotes": "BTS7960 requires both EN pins high only for some boards; here we use one side enabled at a time."
    }
  },
  {
    "id": "motor_stepperonline_nema17_59ncm",
    "name": "STEPPERONLINE Nema 17 Stepper (59Ncm, 2A, 48mm, 4-lead)",
    "manufacturer": "STEPPERONLINE",
    "description": "NEMA 17 stepper motor, 59Ncm (84 oz-in) holding torque, 1.8° step, 2A/phase, 4-lead",
    "defaults": {
      "motorType": "stepper",
      "stepsPerRevolution": 200,
      "stepAngleDeg": 1.8,
      "ratedCurrentA": 2,
      "phaseResistanceOhm": 1.4,
      "phaseInductancemH": 3,
      "holdingTorqueNcm": 59,
      "holdingTorqueOzIn": 84,
      "recommendedDriver": [
        "A4988",
        "DRV8825",
        "TMC2208",
        "TMC2209"
      ],
      "recommendedMicrostepping": 16
    },
    "controlsSchema": {
      "requiresDriver": true,
      "controlType": [
        "STEP_DIR"
      ],
      "inputs": [
        {
          "name": "stepPin",
          "type": "number"
        },
        {
          "name": "dirPin",
          "type": "number"
        },
        {
          "name": "enablePin",
          "type": "number",
          "optional": true
        }
      ]
    },
    "meta": {
      "voltage": "Use driver current limiting; supply 12-24V typical",
      "shaft": "5mm D-shaft",
      "bodyLengthMm": 48,
      "wires": 4
    }
  },
