[
  {
    "id": "motor_jeep_wagoneer_wiper",
    "name": "Jeep Wagoneer Wiper Motor",
    "manufacturer": "OEM",
    "description": "12V DC wiper motor from Jeep Wagoneer, high torque for animatronic jaw/head movement",
    "defaults": {
      "motorType": "dc",
      "voltage": 12,
      "maxDutyPct": 100,
      "recommendedDriver": [
        "MDD10A",
        "BTS7960",
        "L298N"
      ]
    },
    "controlsSchema": {
      "requiresDriver": true,
      "controlType": [
        "DIR_PWM",
        "DUAL_PWM"
      ],
      "inputs": [
        {
          "name": "directionPin",
          "type": "number",
          "description": "GPIO pin for direction control (MDD10A)"
        },
        {
          "name": "pwmPin",
          "type": "number",
          "description": "GPIO pin for PWM speed control (MDD10A)"
        },
        {
          "name": "rpwmPin",
          "type": "number",
          "optional": true,
          "description": "Right PWM pin (BTS7960)"
        },
        {
          "name": "lpwmPin",
          "type": "number",
          "optional": true,
          "description": "Left PWM pin (BTS7960)"
        },
        {
          "name": "renPin",
          "type": "number",
          "optional": true,
          "description": "Right Enable pin (BTS7960)"
        },
        {
          "name": "lenPin",
          "type": "number",
          "optional": true,
          "description": "Left Enable pin (BTS7960)"
        }
      ]
    },
    "meta": {
      "voltage": "12V DC",
      "source": "Jeep Wagoneer wiper motor",
      "notes": "High torque DC motor suitable for animatronic jaw and head movements. Can be driven by MDD10A (Cytron) or BTS7960 motor drivers.",
      "amazonASIN": "B00WSN98DC (for MDD10A driver)"
    }
  },
  {
    "id": "motor_stepperonline_nema17_59ncm",
    "name": "STEPPERONLINE Nema 17 Stepper (59Ncm, 2A, 48mm, 4-lead)",
    "manufacturer": "STEPPERONLINE",
    "description": "NEMA 17 stepper motor, 59Ncm (84 oz-in) holding torque, 1.8° step, 2A/phase, 4-lead",
    "defaults": {
      "motorType": "stepper",
      "stepsPerRevolution": 200,
      "stepAngleDeg": 1.8,
      "ratedCurrentA": 2,
      "phaseResistanceOhm": 1.4,
      "phaseInductancemH": 3,
      "holdingTorqueNcm": 59,
      "holdingTorqueOzIn": 84,
      "recommendedDriver": [
        "A4988",
        "DRV8825",
        "TMC2208",
        "TMC2209"
      ],
      "recommendedMicrostepping": 16
    },
    "controlsSchema": {
      "requiresDriver": true,
      "controlType": [
        "STEP_DIR"
      ],
      "inputs": [
        {
          "name": "stepPin",
          "type": "number"
        },
        {
          "name": "dirPin",
          "type": "number"
        },
        {
          "name": "enablePin",
          "type": "number",
          "optional": true
        }
      ]
    },
    "meta": {
      "voltage": "Use driver current limiting; supply 12-24V typical",
      "shaft": "5mm D-shaft",
      "bodyLengthMm": 48,
      "wires": 4
    }
  },
