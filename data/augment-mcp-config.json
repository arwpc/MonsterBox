{
  "mcpServers": {
    "task-master-ai": {
      "command": "npx",
      "args": ["-y", "--package=task-master-ai", "task-master-ai"],
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}",
        "XAI_API_KEY": "${XAI_API_KEY}",
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
        "MISTRAL_API_KEY": "${MISTRAL_API_KEY}",
        "AZURE_OPENAI_API_KEY": "${AZURE_OPENAI_API_KEY}",
        "OLLAMA_API_KEY": "${OLLAMA_API_KEY}",
        "AUGMENT_ENFORCE_REMOTE": "true",
        "AUGMENT_PREVENT_POWERSHELL": "true",
        "AUGMENT_SSH_MONITORING": "true"
      }
    },
    "monsterbox-log-collector": {
      "command": "node",
      "args": ["mcp-servers/log-collector-server.js"],
      "cwd": "C:/Users/arwpe/CodeBase/MonsterBox-1",
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "ORLOK_SSH_USER": "${ORLOK_SSH_USER}",
        "ORLOK_SSH_PASSWORD": "${ORLOK_SSH_PASSWORD}",
        "COFFIN_SSH_USER": "${COFFIN_SSH_USER}",
        "COFFIN_SSH_PASSWORD": "${COFFIN_SSH_PASSWORD}",
        "RPI_SSH_USER": "${RPI_SSH_USER}",
        "RPI_SSH_PASSWORD": "${RPI_SSH_PASSWORD}",
        "AUGMENT_ENFORCE_REMOTE": "true",
        "AUGMENT_SSH_MONITORING": "true"
      }
    },
    "monsterbox-remote-enforcer": {
      "command": "node",
      "args": ["services/augment/augmentMCPIntegration.js"],
      "cwd": "C:/Users/arwpe/CodeBase/MonsterBox-1",
      "env": {
        "NODE_ENV": "production",
        "LOG_LEVEL": "info",
        "AUGMENT_ENFORCE_REMOTE": "true",
        "AUGMENT_PREVENT_POWERSHELL": "true",
        "AUGMENT_SSH_MONITORING": "true",
        "AUGMENT_STRICT_MODE": "true"
      }
    }
  },
  "remoteExecutionEnforcement": {
    "enabled": true,
    "strictMode": true,
    "preventPowerShellFallback": true,
    "sshConnectionMonitoring": true,
    "emergencyShutdownEnabled": true,
    "allowedRemoteHosts": ["orlok", "coffin", "skulltalker", "pumpkinhead", "192.168.8.120", "192.168.8.130", "192.168.8.140", "192.168.1.101"]
  }
}
