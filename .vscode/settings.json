{
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        "./tests",
        "-p",
        "*_test.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true,

    // Remote SSH Configuration for MonsterBox RPI Systems
    "remote.SSH.configFile": "C:\\Users\\arwpe\\.ssh\\config",
    "remote.SSH.showLoginTerminal": true,
    "remote.SSH.remotePlatform": {
        "orlok": "linux",
        "coffin": "linux",
        "skulltalker": "linux",
        "pumpkinhead": "linux",
        "192.168.8.120": "linux",
        "192.168.8.130": "linux",
        "192.168.8.140": "linux",
        "192.168.1.101": "linux"
    },
    "remote.SSH.enableDynamicForwarding": false,
    "remote.SSH.connectTimeout": 15,
    "remote.SSH.useLocalServer": false,

    // PowerShell Fallback Prevention - CRITICAL SECURITY SETTINGS
    "remote.SSH.enableRemoteCommand": true,
    "remote.SSH.enableX11Forwarding": false,
    "remote.SSH.enableAgentForwarding": false,
    "remote.SSH.lockfilesInTmp": true,
    "remote.SSH.maxReconnectionAttempts": 3,
    "remote.SSH.suppressWindowsSshWarning": true,
    "remote.SSH.path": "ssh",
    "remote.SSH.defaultExtensions": [],

    // Force remote execution - prevent local fallback
    "remote.SSH.remoteServerListenOnSocket": true,
    "remote.SSH.serverPickPortsFromRange": {
        "22000": 22999
    },

    // Terminal configuration for remote connections
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.profiles.linux": {
        "bash": {
            "path": "/bin/bash",
            "args": ["-l"]
        }
    },

    // Windows PowerShell restrictions - PREVENT LOCAL EXECUTION
    "terminal.integrated.defaultProfile.windows": null,
    "terminal.integrated.profiles.windows": {},
    "powershell.powerShellDefaultVersion": "PowerShell",
    "powershell.enableReferencesCodeLens": false,
    "powershell.integratedConsole.suppressStartupBanner": true,

    // Augment MCP Configuration - Force Remote Execution
    "augment.enforceRemoteExecution": true,
    "augment.preventLocalPowerShell": true,
    "augment.sshConnectionMonitoring": true,
    "augment.remoteExecutionValidation": true,

    // Development Environment Restrictions
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/*/**": true,
        "**/.hg/store/**": true
    },

    // Security and Monitoring
    "security.workspace.trust.enabled": true,
    "security.workspace.trust.startupPrompt": "always",
    "workbench.enableExperiments": false,
    "telemetry.telemetryLevel": "off"
}