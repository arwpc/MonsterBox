{
  // --- Copilot Agent: fully autonomous ---
  "chat.tools.global.autoApprove": true,
  // Terminal auto-approve engine + no interactive hangs
  "chat.tools.terminal.enableAutoApprove": true,
  "chat.tools.terminal.autoReplyToPrompts": true,
  // (Optional but useful) Make sure Copilot Chat uses bash in terminals
  "chat.tools.terminal.terminalProfile.linux": "bash",
  // --- Terminal allow/deny map (strictly controls prompts in the terminal) ---
  "chat.tools.terminal.autoApprove": {
    // Core and filesystem (approve)
    "cd": true,
    "pwd": true,
    "echo": true,
    "true": true,
    "false": true,
    "printf": true,
    "ls": true,
    "cat": true,
    "head": true,
    "tail": true,
    "grep": true,
    "sed": true,
    "awk": true,
    "find": true,
    "sort": true,
    "uniq": true,
    "cut": true,
    "paste": true,
    "wc": true,
    "stat": true,
    "file": true,
    "readlink": true,
    "realpath": true,
    "basename": true,
    "dirname": true,
    "df": true,
    "du": true,
    "tree": true,
    // Processes / OS
    "whoami": true,
    "uname": true,
    "id": true,
    "date": true,
    "uptime": true,
    "ps": true,
    "top": true,
    "vmstat": true,
    "free": true,
    "lscpu": true,
    "lsusb": true,
    "lsmod": true,
    "dmesg": true,
    "journalctl": true,
    "systemctl": true,
    // Networking and transfers
    "ip": true,
    "ss": true,
    "netstat": true,
    "ping": true,
    "traceroute": true,
    "nslookup": true,
    "dig": true,
    "hostnamectl": true,
    "nmcli": true,
    "curl": true,
    "wget": true,
    "ssh": true,
    "scp": true,
    "rsync": true,
    "ssh-keygen": true,
    "ssh-copy-id": true,
    // Package/build/dev
    "sudo": true,
    "apt": true,
    "apt-get": true,
    "dpkg": true,
    "/^apt(-get)?\\s+(update|install|upgrade|remove|autoremove|dist-upgrade)\\b/": true,
    "python3": true,
    "pip": true,
    "pip3": true,
    "/^pip3?\\s+.+/": true,
    "node": true,
    "npm": true,
    "npx": true,
    "/^npm\\s+(i|install|ci|run|test|start|stop|rebuild)\\b/": true,
    "make": true,
    "cmake": true,
    "gcc": true,
    "g++": true,
    "docker": true,
    "/^docker(\\s+compose)?\\s+.*$/": true,
    // Git (allow broadly, but block branch deletion by name)
    "git": true,
    "/^git\\s+(clone|pull|fetch|checkout|status|log|diff|add|commit|push|merge|rebase|tag|stash|cherry-pick)\\b/": true,
    "/^git\\s+branch\\b.*-(d|D|m|M|-delete|-force)\\b/": false,
    // Approve common pipelines (entire command line)
    "/^\\s*(ls|cat)\\b[^\\n]*\\|\\s*grep\\b[^\\n]*$/is": true,
    "/^\\s*grep\\b[^|\\n]*\\|\\s*wc\\b\\s*-l\\b[^\\n]*$/is": true,
    "/^\\s*du\\b[^\\n]*\\|\\s*sort\\b[^\\n]*$/is": true,
    "/^\\s*journalctl\\b[^\\n]*\\|\\s*grep\\b[^\\n]*$/is": true,
    "/^\\s*find\\b(?![^\\n]*-(delete|exec|execdir|ok|okdir|fprint|fprintf|fls)\\b)[^\\n]*\\|\\s*grep\\b[^\\n]*$/is": true,
    // Approve chains using && or ; (entire line)
    "/^(?:(?!`|\\$\\(|\\{)[^\\n])+((\\s*(?:&&|;)\\s*)(?:(?!`|\\$\\(|\\{)[^\\n])+)+\\s*)$/is": true,
    // SSH one-liners (user@host ... then quoted chain)
    "/^\\s*ssh\\s+\\S+@\\S+\\b[^\\n]*$/is": true,
    "/^\\s*scp\\s+.+/is": true,
    "/^\\s*rsync\\s+.+/is": true,
    // systemctl mutations and reboots
    "/^\\s*systemctl\\s+(start|stop|restart|reload|enable|disable|daemon-reload)\\b[^\\n]*$/i": true,
    "/^\\s*(sudo\\s+)?reboot\\b.*$/i": true,
    "/^\\s*(sudo\\s+)?shutdown\\b.*$/i": true,
    // Minimal destructive hard-blocks to prevent fat-finger disasters
    "/^\\s*rm\\s+-rf\\s+([/\\\\]|~)\\s*$/i": false,
    "/^\\s*rm\\s+-rf\\s+\\.$/i": false,
    "/^\\s*mkfs(\\.|\\b)/i": false,
    "/^\\s*dd\\b.*\\bof=\\s*\\/dev\\//i": false,
    "/^\\s*tune2fs\\b/i": false,
    "/^\\s*fsck\\b/i": false
  },
  "chat.agent.maxRequests": 100,

  // --- Claude Code Integration ---
  "claude.autoReadClaudeMd": true,
  "claude.enableInlineEdit": true,
  "claude.confirmBeforeExecutingCommands": false,
  "claude.maxContextTokens": 200000,
  "claude.preferredModel": "claude-sonnet-4-5",
  "claude.showDiffView": true,
  "claude.enableAutoMemory": true,
  "claude.memoryPath": "${workspaceFolder}/.claude/memory",
  "claude-code-usage.showInActivityBar": true,
  "claude-code-usage.enabled": true,

  // --- Performance optimization for RPI4B ---
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.vscode-server/**": true,
    "**/.claude/**": true,
    "**/data/audio-library/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/data/audio-library/**": true
  },
  "git.autofetch": false,
  "git.autorefresh": false,
  "git.detectSubmodules": false,

  // --- Editor optimizations ---
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "selection",
  "editor.formatOnSave": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,

  // --- Python settings for hardware wrappers ---
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.defaultInterpreterPath": "/usr/bin/python3",

  // --- Node.js settings ---
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.suggest.autoImports": true,
  "eslint.enable": true,

  // --- Terminal settings ---
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.scrollback": 10000,

  // --- Workspace state restoration ---
  "workbench.startupEditor": "none",
  "window.restoreWindows": "all",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,

  // --- Auto-launch configurations ---
  "task.autoDetect": "on",
  "npm.autoDetect": "on"
}