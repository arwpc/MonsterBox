{
  // --- Copilot Agent: fully autonomous ---
  "chat.tools.global.autoApprove": true,
  "chat.tools.terminal.enableAutoApprove": true,
  "chat.tools.terminal.autoReplyToPrompts": true,
  "chat.tools.terminal.terminalProfile.linux": "bash",
  "chat.tools.terminal.autoApprove": {
    // Core filesystem (approve)
    "cd": true,
    "pwd": true,
    "echo": true,
    "true": true,
    "false": true,
    "printf": true,
    "ls": true,
    "cat": true,
    "head": true,
    "tail": true,
    "grep": true,
    "sed": true,
    "awk": true,
    "find": true,
    "sort": true,
    "uniq": true,
    "cut": true,
    "paste": true,
    "wc": true,
    "stat": true,
    "file": true,
    "readlink": true,
    "realpath": true,
    "basename": true,
    "dirname": true,
    "df": true,
    "du": true,
    "tree": true,
    "jq": true,
    // Processes / OS
    "whoami": true,
    "uname": true,
    "id": true,
    "date": true,
    "uptime": true,
    "ps": true,
    "top": true,
    "vmstat": true,
    "free": true,
    "lscpu": true,
    "lsusb": true,
    "lsmod": true,
    "dmesg": true,
    "journalctl": true,
    "systemctl": true,
    // Networking
    "ip": true,
    "ss": true,
    "netstat": true,
    "ping": true,
    "traceroute": true,
    "nslookup": true,
    "dig": true,
    "hostnamectl": true,
    "nmcli": true,
    "curl": true,
    "wget": true,
    "ssh": true,
    "scp": true,
    "rsync": true,
    "ssh-keygen": true,
    "ssh-copy-id": true,
    // Package/build/dev
    "sudo": true,
    "apt": true,
    "apt-get": true,
    "dpkg": true,
    "/^apt(-get)?\\s+(update|install|upgrade|remove|autoremove|dist-upgrade)\\b/": true,
    "python3": true,
    "pip": true,
    "pip3": true,
    "/^pip3?\\s+.+/": true,
    "node": true,
    "npm": true,
    "npx": true,
    "mocha": true,
    "playwright": true,
    "/^npm\\s+(i|install|ci|run|test|start|stop|rebuild)\\b/": true,
    "make": true,
    // Git (allow broadly, block destructive operations)
    "git": true,
    "/^git\\s+(clone|pull|fetch|checkout|status|log|diff|add|commit|push|merge|rebase|tag|stash|cherry-pick)\\b/": true,
    "/^git\\s+branch\\b.*-(d|D|m|M|-delete|-force)\\b/": false,
    // Common pipelines
    "/^\\s*(ls|cat)\\b[^\\n]*\\|\\s*grep\\b[^\\n]*$/is": true,
    "/^\\s*grep\\b[^|\\n]*\\|\\s*wc\\b\\s*-l\\b[^\\n]*$/is": true,
    "/^\\s*du\\b[^\\n]*\\|\\s*sort\\b[^\\n]*$/is": true,
    "/^\\s*journalctl\\b[^\\n]*\\|\\s*grep\\b[^\\n]*$/is": true,
    // systemctl mutations
    "/^\\s*systemctl\\s+(start|stop|restart|reload|enable|disable|daemon-reload)\\b[^\\n]*$/i": true,
    // Destructive hard-blocks
    "/^\\s*rm\\s+-rf\\s+([/\\\\]|~)\\s*$/i": false,
    "/^\\s*rm\\s+-rf\\s+\\.$/i": false,
    "/^\\s*mkfs(\\.|\\b)/i": false,
    "/^\\s*dd\\b.*\\bof=\\s*\\/dev\\//i": false,
    "/^\\s*tune2fs\\b/i": false,
    "/^\\s*fsck\\b/i": false
  },
  "chat.agent.maxRequests": 100,

  // --- Claude Code Integration ---
  "claude.autoReadClaudeMd": true,
  "claude.enableInlineEdit": true,
  "claude.confirmBeforeExecutingCommands": false,
  "claude.maxContextTokens": 200000,
  "claude.preferredModel": "claude-opus-4-6",
  "claude.showDiffView": true,
  "claude.enableAutoMemory": true,
  "claude.memoryPath": "${workspaceFolder}/.claude/memory",
  "claude-code-usage.showInActivityBar": true,
  "claude-code-usage.enabled": true,

  // --- Performance optimization for RPI4B (SD card wear + CPU) ---
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.vscode-server/**": true,
    "**/.windsurf-server/**": true,
    "**/.copilot/**": true,
    "**/.claude/**": true,
    "**/data/audio-library/**": true,
    "**/data/*/audio/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.git": true,
    "**/.claude": true,
    "**/.vscode-server": true,
    "**/.windsurf-server": true,
    "**/data/audio-library/**": true,
    "**/data/*/audio/**": true
  },
  "search.followSymlinks": false,
  "search.smartCase": true,
  "git.autofetch": false,
  "git.autorefresh": false,
  "git.detectSubmodules": false,

  // --- Editor: consistency and quality ---
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "selection",
  "editor.formatOnSave": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.linkedEditing": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // --- ESLint: run on save to reduce CPU load ---
  "eslint.enable": true,
  "eslint.run": "onSave",

  // --- Python settings for hardware wrappers ---
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.defaultInterpreterPath": "/usr/bin/python3",

  // --- Node.js / JavaScript ---
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.suggest.autoImports": true,
  "js/ts.implicitProjectConfig.module": "ESNext",

  // --- Terminal settings ---
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.gpuAcceleration": "off",

  // --- Workspace state ---
  "workbench.startupEditor": "none",
  "window.restoreWindows": "all",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 2000,

  // --- Task detection ---
  "task.autoDetect": "on",
  "npm.autoDetect": "on"
}
