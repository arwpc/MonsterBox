{
  // --- your existing prefs ---
  "editor.inlineSuggest.enabled": true,
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "workbench.editor.enablePreview": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.formatOnSave": true,
  // --- Copilot Agent, full auto ---
  "chat.agent.enabled": true,
  "chat.agent.maxRequests": 999999,
  "github.copilot.chat.agent.autoFix": true,
  "chat.tools.global.autoApprove": true,
  "chat.tools.terminal.autoReplyToPrompts": true,
  "chat.tools.shell.autoApprove": true,
  "chat.tools.codeExecution.autoApprove": true,
  "github.copilot.chat.runCommand.enabled": true,
  "github.copilot.chat.executeCommand.enabled": true,
  "github.copilot.chat.executeCommands": "always",
  "github.copilot.chat.terminalAutoExecution": "enabled",
  "github.copilot.chat.requireApproval": false,
  "github.copilot.chat.terminalChatLocation": "terminal",
  "terminal.integrated.confirmBeforeExecutingCommands": false,
  // --- Workspace trust & prompts (reduce nags) ---
  "security.workspace.trust.enabled": false,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  // --- Search/Watch hygiene (big media & build dirs) ---
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/coverage": true,
    "**/.cache": true,
    "**/.playwright": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/coverage": true,
    "**/.cache": true,
    "**/.playwright": true,
    "**/*.mp4": true,
    "**/*.mov": true,
    "**/*.mkv": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.playwright/**": true,
    "**/coverage/**": true,
    "**/*.mp4": true,
    "**/*.mov": true,
    "**/*.mkv": true,
    "/home/remote/media/video/**": true
  },
  // --- Node/JS/TS quality of life ---
  "npm.autoDetect": "on",
  "npm.scriptExplorerAction": "run",
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.tsserver.maxTsServerMemory": 4096,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "eslint.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "json"
  ],
  // If you use Prettier, uncomment the next two lines:
  // "editor.defaultFormatter": "esbenp.prettier-vscode",
  // "[javascript]": { "editor.formatOnSave": true },
  // --- Testing (Mocha & Playwright) ---
  "testing.automaticallyOpenPeekView": "never",
  "mochaExplorer.files": "test/**/*.spec.js",
  "mochaExplorer.env": {
    "NODE_ENV": "test"
  },
  "mochaExplorer.timeout": 20000,
  "playwright.reuseBrowser": true, // faster local e2e
  "playwright.trace": "on-first-retry", // useful but not noisy
  // --- Git (fewer interruptions, safer defaults) ---
  "git.autofetch": true,
  "git.pruneOnFetch": true,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  // --- Remote-SSH (Pi hosts) ---
  "remote.SSH.remotePlatform": {
    "orlok": "linux",
    "coffin": "linux",
    "skulltalker": "linux",
    "groundbreaker": "linux",
    "pumpkinhead": "linux",
    "goblin-one": "linux",
    "goblin-two": "linux",
    "goblin-three": "linux"
  },
  "remote.SSH.useLocalServer": true,
  // --- Python wrappers (used by your hardware scripts) ---
  "python.defaultInterpreterPath": "/usr/bin/python3",
  "python.analysis.typeCheckingMode": "basic",
  // --- Markdown/docs ergonomics ---
  "markdown.validate.enabled": true,
  "markdown.preview.doubleClickToSwitchToEditor": false,
  // --- Misc editor ergonomics ---
  "editor.stickyScroll.enabled": true,
  "workbench.startupEditor": "none",
  "extensions.ignoreRecommendations": true,
  // --- (optional) Telemetry on home lab machines ---
  "telemetry.telemetryLevel": "off",
  "chat.tools.terminal.autoApprove": {
    
    "cd": true,
    "echo": true,
    "ls": true,
    "pwd": true,
    "cat": true,
    "head": true,
    "tail": true,
    "findstr": true,
    "wc": true,
    "tr": true,
    "cut": true,
    "cmp": true,
    "which": true,
    "basename": true,
    "dirname": true,
    "realpath": true,
    "readlink": true,
    "stat": true,
    "file": true,
    "du": true,
    "df": true,
    "sleep": true,
    "grep": true,
    "git status": true,
    "git log": true,
    "git show": true,
    "git diff": true,
    "git grep": true,
    "git branch": true,
    "/^git branch\\b.*-(d|D|m|M|-delete|-force)\\b/": false,
    "Get-ChildItem": true,
    "Get-Content": true,
    "Get-Date": true,
    "Get-Random": true,
    "Get-Location": true,
    "Write-Host": true,
    "Write-Output": true,
    "Split-Path": true,
    "Join-Path": true,
    "Start-Sleep": true,
    "Where-Object": true,
    "/^Select-[a-z0-9]/i": true,
    "/^Measure-[a-z0-9]/i": true,
    "/^Compare-[a-z0-9]/i": true,
    "/^Format-[a-z0-9]/i": true,
    "/^Sort-[a-z0-9]/i": true,
    "column": true,
    "/^column\\b.*-c\\s+[0-9]{4,}/": false,
    "date": true,
    "/^date\\b.*(-s|--set)\\b/": false,
    "find": true,
    "/^find\\b.*-(delete|exec|execdir|fprint|fprintf|fls|ok|okdir)\\b/": false,
    "sort": true,
    "/^sort\\b.*-(o|S)\\b/": false,
    "tree": true,
    "/^tree\\b.*-o\\b/": false,
    "/\\(.+\\)/s": {
      "approve": false,
      "matchCommandLine": true
    },
    "/\\{.+\\}/s": {
      "approve": false,
      "matchCommandLine": true
    },
    "/`.+`/s": {
      "approve": false,
      "matchCommandLine": true
    },
    "rm": false,
    "rmdir": false,
    "del": false,
    "Remove-Item": false,
    "ri": false,
    "rd": false,
    "erase": false,
    "dd": false,
    "kill": false,
    "ps": false,
    "top": false,
    "Stop-Process": false,
    "spps": false,
    "taskkill": false,
    "taskkill.exe": false,
    "curl": false,
    "wget": false,
    "Invoke-RestMethod": false,
    "Invoke-WebRequest": false,
    "irm": false,
    "iwr": false,
    "chmod": false,
    "chown": false,
    "Set-ItemProperty": false,
    "sp": false,
    "Set-Acl": false,
    "jq": false,
    "xargs": false,
    "eval": false,
    "Invoke-Expression": false,
    "iex": false
  }
}