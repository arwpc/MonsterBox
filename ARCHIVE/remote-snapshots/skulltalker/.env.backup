# =============================================================================
# MCP CONFIGURATION (For Remote Agents - MCP System)
# =============================================================================
MCP_SERVER_PORT=3001
MCP_LOG_BUFFER_SIZE=1000
MCP_RECONNECT_INTERVAL=5000
FLUENT_BIT_LOG_PATH=/var/log/monsterbox
FLUENT_BIT_OUTPUT_PATH=./log/aggregated
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_RECIPIENTS=admin@monsterbox.local

# =============================================================================
# TESTING CONFIGURATION (For Remote Agents - Testing System)
