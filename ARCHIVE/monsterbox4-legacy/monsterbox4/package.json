{
  "name": "monsterbox4",
  "version": "4.0.0",
  "description": "MonsterBox 4.0 - Single Node Animatronic Control System with Poses",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha tests/**/*.test.js --timeout 10000",
    "test:unit": "mocha --recursive tests/unit --reporter spec",
    "test:e2e": "playwright test",
    "test:ui": "playwright test",
    "test:ui-headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run test:ui",
    "verify": "npm run test:unit && npm run test:e2e"
  },
  "keywords": [
    "animatronic",
    "raspberry-pi",
    "servo",
    "poses",
    "hardware-control"
  ],
  "author": "MonsterBox Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.5",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "multer": "^2.0.2",
    "wrtc": "^0.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "node-pre-gyp": "^0.17.0",
    "nodemon": "^3.0.1",
    "playwright": "^1.55.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "tar": "^6.2.1"
  }
}