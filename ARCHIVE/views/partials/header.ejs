<%
// Simple header partial for MonsterBox
// Basic header with MonsterBox branding
%>

<style>
/* Simple Header Styles */
.simple-header {
    background: #000000;
    border-bottom: 2px solid #00ff00;
    padding: 15px 20px;
    margin: -20px -20px 20px -20px;
    text-align: center;
}

.simple-header h1 {
    font-family: 'Creepster', cursive;
    font-size: 2.5em;
    margin: 0;
    color: #00ff00;
    text-shadow: 0 0 10px #00ff00;
}

.simple-header .subtitle {
    color: #00ff88;
    font-size: 1.1em;
    margin: 5px 0 0 0;
    opacity: 0.8;
}

@media (max-width: 768px) {
    .simple-header {
        padding: 10px 15px;
        margin: -20px -20px 15px -20px;
    }
    
    .simple-header h1 {
        font-size: 1.8em;
    }
    
    .simple-header .subtitle {
        font-size: 1em;
    }
}
</style>

<header class="simple-header">
    <h1>🎭 MONSTERBOX</h1>
    <p class="subtitle">Animatronic Control System</p>
</header>
