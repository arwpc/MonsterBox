<%# Protocol Utils Partial - Include this in pages that need HTTPS/WSS support %>
<script src="/js/protocol-utils.js"></script>
<script>
    // Initialize protocol utils when DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
        if (window.protocolUtils) {
            console.log('🔗 Protocol Utils initialized for page:', window.location.pathname);
            
            // Log connection info in development
            if (window.location.hostname === 'localhost' || window.location.hostname.includes('192.168')) {
                window.protocolUtils.logConnectionInfo();
            }
        }
    });
</script>
