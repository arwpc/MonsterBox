<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MonsterBox</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>
<body>
  <%- include('../components/universal-header') %>
  <div class="container">
    <div class="header">
      <h1><%= title %></h1>
      <p class="subtitle">Configure speaker settings</p>
    </div>

    <form action="<%= action %>" method="POST" class="form">
      <% if (part.id) { %>
        <input type="hidden" name="id" value="<%= part.id %>">
      <% } %>
      <input type="hidden" name="type" value="speaker">

      <div class="form-section">
        <h3>📝 Basic Information</h3>

        <div class="form-group">
          <label for="characterId">Character:</label>
          <select id="characterId" name="characterId" required>
            <option value="">Select a character...</option>
            <% characters.forEach(char => { %>
              <option value="<%= char.id %>" <%= (part.characterId && part.characterId == char.id) || (character && character.id == char.id) ? 'selected' : '' %>>
                <%= char.char_name || char.name %>
              </option>
            <% }); %>
          </select>
          <small>Select which character this speaker belongs to</small>
        </div>

        <div class="form-group">
          <label for="name">Speaker Name:</label>
          <input type="text" id="name" name="name" value="<%= part.name || '' %>" required>
        </div>

        <div class="form-group">
          <label for="description">Description:</label>
          <textarea id="description" name="description" rows="3"><%= part.description || '' %></textarea>
        </div>
      </div>

      <div class="form-section">
        <h3>🔊 Speaker Configuration</h3>
      <div class="form-group">
        <label for="outputDevice">Output Device:</label>
        <select id="outputDevice" name="outputDevice">
          <option value="default" <%= (part.outputDevice||'default')==='default' ? 'selected' : '' %>>Loading devices...</option>
        </select>
        <button type="button" class="button small-btn" onclick="discoverOutputs()">🔄 Refresh Devices</button>
        <small>Select ALSA output (USB dongle is recommended and consistent across bots)</small>
      </div>
      <div class="form-group">
        <label for="volume">Volume (%):</label>
        <input type="number" id="volume" name="volume" min="0" max="100" value="<%= part.volume || 80 %>">
      </div>
    </div>

      <div class="form-actions">
        <button type="submit" class="button primary-btn">💾 Save Speaker</button>
        <a href="/parts" class="button secondary-btn">↩️ Back to Parts</a>
        <button type="button" id="configureTTS" class="button">🔊 Configure TTS</button>
      </div>
    </form>

  <div class="form-section">
    <h3>🧪 Live Output Test</h3>
    <div class="button-group">
      <button type="button" class="button" onclick="playTestTone()">▶️ Play Test Tone</button>
      <button type="button" class="button secondary-btn" onclick="setVolume()">🔊 Apply Volume</button>
      <button type="button" class="button" onclick="playTestToneWithVU()">📊 Play with VU Meter</button>
    </div>
    <pre id="speakerTestOutput"></pre>
  </div>

  <div class="form-section">
    <h3>📊 Live Audio Level Monitor</h3>
    <div class="audio-level-container">
      <div class="level-bar-container">
        <div class="level-bar" id="speakerLevelBar"></div>
      </div>
      <div class="level-text" id="speakerLevelText">0%</div>
    </div>
    <div class="button-group">
      <button type="button" class="button" id="vuMeterBtn" onclick="toggleVUMeter()">🎵 Start VU Meter</button>
    </div>
    <small>VU meter shows real-time audio levels during test tone playback</small>
  </div>

  <script>
    async function discoverOutputs() {
      try {
        console.log('🔍 Discovering audio output devices...');
        const res = await axios.get('/parts/api/speaker/devices');
        const sel = document.getElementById('outputDevice');
        const currentValue = '<%= part.outputDevice || "" %>';

        // Clear existing options
        sel.innerHTML = '<option value="default">System Default Audio</option>';

        if (res.data.success && Array.isArray(res.data.devices)) {
          console.log(`Found ${res.data.devices.length} audio devices:`, res.data.devices);

          res.data.devices.forEach(dev => {
            // Skip the default option if it's already added
            if (dev.id === 'default') return;

            const opt = document.createElement('option');
            opt.value = dev.id;
            opt.textContent = dev.name;
            opt.title = dev.description; // Add tooltip with full description

            // Select the current device if it matches
            if (dev.id === currentValue) {
              opt.selected = true;
            }

            sel.appendChild(opt);
          });

          // If no device was selected and we have a current value, try to select it
          if (currentValue && currentValue !== 'default' && !sel.querySelector(`option[value="${currentValue}"]`)) {
            // Add the current device as an option even if not discovered (might be offline)
            const opt = document.createElement('option');
            opt.value = currentValue;
            opt.textContent = `${currentValue} (offline?)`;
            opt.selected = true;
            sel.appendChild(opt);
          }

          console.log(`✅ Loaded ${res.data.devices.length} audio output devices`);
        } else {
          console.warn('No devices returned or API call failed');
        }
      } catch (e) {
        console.error('❌ Discover outputs failed:', e);
        const sel = document.getElementById('outputDevice');
        sel.innerHTML = '<option value="default">System Default Audio (discovery failed)</option>';
      }
    }

    async function playTestTone() {
      const out = document.getElementById('speakerTestOutput');
      out.textContent = 'Playing test tone...';
      try {
        const deviceId = document.getElementById('outputDevice').value;
        const res = await axios.post('/parts/api/speaker/test', { deviceId });
        out.textContent = res.data.success ? '✅ Test tone played successfully' : ('❌ ' + (res.data.error || 'Failed'));
      } catch (e) {
        out.textContent = '❌ ' + e.message;
      }
    }

    async function setVolume() {
      const out = document.getElementById('speakerTestOutput');
      try {
        const volume = parseInt(document.getElementById('volume').value || '80', 10);
        const res = await axios.post('/parts/api/speaker/volume', { volume });
        out.textContent = res.data.success ? `✅ Volume set to ${volume}%` : ('❌ ' + (res.data.error || 'Failed'));
      } catch (e) {
        out.textContent = '❌ ' + e.message;
      }
    }

    // VU Meter functionality
    let audioContext = null;
    let analyser = null;
    let vuMeterActive = false;
    let vuAnimationFrame = null;

    async function playTestToneWithVU() {
      await playTestTone();
      if (!vuMeterActive) {
        await startVUMeter();
      }
    }

    async function toggleVUMeter() {
      if (vuMeterActive) {
        stopVUMeter();
      } else {
        await startVUMeter();
      }
    }

    async function startVUMeter() {
      try {
        if (!audioContext) {
          audioContext = new (window.AudioContext || window.webkitAudioContext)();
        }

        if (audioContext.state === 'suspended') {
          await audioContext.resume();
        }

        // Create a test tone oscillator for VU meter demonstration
        const oscillator = audioContext.createOscillator();
        const gainNode = audioContext.createGain();
        analyser = audioContext.createAnalyser();

        oscillator.connect(gainNode);
        gainNode.connect(analyser);
        analyser.connect(audioContext.destination);

        oscillator.frequency.setValueAtTime(440, audioContext.currentTime);
        gainNode.gain.setValueAtTime(0.1, audioContext.currentTime);

        analyser.fftSize = 256;

        oscillator.start();

        // Stop the oscillator after 3 seconds
        setTimeout(() => {
          oscillator.stop();
        }, 3000);

        vuMeterActive = true;
        document.getElementById('vuMeterBtn').textContent = '⏹️ Stop VU Meter';
        updateVUMeter();

      } catch (error) {
        console.error('Error starting VU meter:', error);
        document.getElementById('speakerTestOutput').textContent = '❌ VU Meter error: ' + error.message;
      }
    }

    function stopVUMeter() {
      vuMeterActive = false;
      if (vuAnimationFrame) {
        cancelAnimationFrame(vuAnimationFrame);
        vuAnimationFrame = null;
      }
      document.getElementById('vuMeterBtn').textContent = '🎵 Start VU Meter';
      document.getElementById('speakerLevelBar').style.width = '0%';
      document.getElementById('speakerLevelText').textContent = '0%';
    }

    function updateVUMeter() {
      if (!vuMeterActive || !analyser) return;

      const bufferLength = analyser.frequencyBinCount;
      const dataArray = new Uint8Array(bufferLength);
      analyser.getByteFrequencyData(dataArray);

      // Calculate average level
      let sum = 0;
      for (let i = 0; i < bufferLength; i++) {
        sum += dataArray[i];
      }
      const average = sum / bufferLength;
      const percentage = Math.round((average / 255) * 100);

      // Update UI
      document.getElementById('speakerLevelBar').style.width = percentage + '%';
      document.getElementById('speakerLevelText').textContent = percentage + '%';

      // Color coding
      const levelBar = document.getElementById('speakerLevelBar');
      if (percentage > 80) {
        levelBar.style.backgroundColor = '#ff0040';
      } else if (percentage > 60) {
        levelBar.style.backgroundColor = '#ffff00';
      } else {
        levelBar.style.backgroundColor = '#00ff00';
      }

      vuAnimationFrame = requestAnimationFrame(updateVUMeter);
    }

    // Configure TTS button functionality
    document.getElementById('configureTTS').addEventListener('click', function() {
      const characterId = document.getElementById('characterId').value;
      if (characterId) {
        window.location.href = `/ai-management/tts?characterId=${characterId}`;
      } else {
        alert('Please select a character first');
      }
    });

    // Auto-discover on load
    discoverOutputs();

    // Set character ID from universal header on page load
    document.addEventListener('DOMContentLoaded', function() {
      // Get character ID from universal header
      const currentCharacterId = sessionStorage.getItem('selectedCharacterId') ||
                                localStorage.getItem('selectedCharacterId');

      const characterSelect = document.getElementById('characterId');
      if (currentCharacterId && characterSelect && !characterSelect.value) {
        characterSelect.value = currentCharacterId;
        console.log('🎭 Set character ID from universal header:', currentCharacterId);
      }
    });
  </script>

  <style>
    .form-section { background: rgba(0,0,0,0.3); border: 1px solid rgba(0,255,0,0.3); border-radius: 8px; padding: 20px; margin: 20px 0; }
    .form-group { margin-bottom: 15px; }
    .form-group label { display:block; color:#00ff00; font-weight:bold; margin-bottom:6px; }
    .form-group input, .form-group select, .form-group textarea { width:100%; padding:8px; background:rgba(0,0,0,0.5); border:1px solid rgba(0,255,0,0.5); border-radius:4px; color:#fff; }
    .form-actions { display:flex; gap:10px; margin-top: 20px; }

    /* VU Meter Styles */
    .audio-level-container {
      display: flex;
      align-items: center;
      gap: 15px;
      margin: 15px 0;
    }

    .level-bar-container {
      flex: 1;
      height: 30px;
      background: rgba(0,0,0,0.5);
      border: 1px solid rgba(0,255,0,0.3);
      border-radius: 15px;
      overflow: hidden;
      position: relative;
    }

    .level-bar {
      height: 100%;
      width: 0%;
      background: #00ff00;
      transition: width 0.1s ease;
      border-radius: 15px;
      box-shadow: 0 0 10px rgba(0,255,0,0.5);
    }

    .level-text {
      min-width: 50px;
      color: #00ff00;
      font-weight: bold;
      text-align: center;
      font-family: 'Courier New', monospace;
      text-shadow: 0 0 5px rgba(0,255,0,0.5);
    }

    .button-group {
      display: flex;
      gap: 10px;
      margin: 10px 0;
    }
  </style>
  </div>
</body>
</html>

