<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>
<body>
    <%- include('components/universal-header') %>
    <h1><%= title %></h1>
    <form action="<%= action %>?characterId=<%= character.id %>" method="POST">
        <% if (part.id) { %>
            <input type="hidden" name="id" value="<%= part.id %>">
        <% } %>
        <input type="hidden" name="characterId" value="<%= character.id %>">
        <div>
            <label for="name">Part Name:</label>
            <input type="text" id="name" name="name" value="<%= part.name || '' %>" required>
        </div>
        <div>
            <label for="type">Type:</label>
            <select id="type" name="type" required onchange="toggleInputs()">
                <option value="motor" <%= part.type === 'motor' ? 'selected' : '' %>>Motor</option>
                <option value="light" <%= part.type === 'light' ? 'selected' : '' %>>Light</option>
                <option value="led" <%= part.type === 'led' ? 'selected' : '' %>>LED</option>
                <option value="servo" <%= part.type === 'servo' ? 'selected' : '' %>>Servo</option>
                <option value="sensor" <%= part.type === 'sensor' ? 'selected' : '' %>>Sensor</option>
                <option value="linear-actuator" <%= part.type === 'linear-actuator' ? 'selected' : '' %>>Linear Actuator</option>
                <option value="microphone" <%= part.type === 'microphone' ? 'selected' : '' %>>Microphone</option>
            </select>
        </div>
        <div>
            <label for="characterId">Character:</label>
            <select id="characterId" name="characterId" required <% if (part.type !== 'microphone') { %>disabled<% } %>>
                <% if (part.type === 'microphone') { %>
                    <% characters.forEach(function(char) { %>
                        <option value="<%= char.id %>" <%= char.id === character.id ? 'selected' : '' %>><%= char.char_name %></option>
                    <% }); %>
                <% } else { %>
                    <option value="<%= character.id %>" selected><%= character.char_name %></option>
                <% } %>
            </select>
            <% if (part.type === 'microphone') { %>
                <small>Select which character this microphone will be assigned to</small>
            <% } %>
        </div>
        <div id="motorInputs" style="display: none;">
            <div>
                <label for="directionPin">Direction Pin:</label>
                <input type="number" id="directionPin" name="directionPin" value="<%= part.directionPin || '' %>">
            </div>
            <div>
                <label for="pwmPin">PWM Pin:</label>
                <input type="number" id="pwmPin" name="pwmPin" value="<%= part.pwmPin || '' %>">
            </div>
        </div>
        <div id="singlePinInputs" style="display: none;">
            <div>
                <label for="gpioPin">GPIO Pin:</label>
                <input type="number" id="gpioPin" name="gpioPin" value="<%= part.gpioPin || '' %>">
            </div>
        </div>
        <div id="sensorInputs" style="display: none;">
            <div>
                <label for="sensorType">Sensor Type:</label>
                <select id="sensorType" name="sensorType">
                    <option value="motion" <%= part.sensorType === 'motion' ? 'selected' : '' %>>Motion</option>
                    <option value="sound" <%= part.sensorType === 'sound' ? 'selected' : '' %>>Sound</option>
                </select>
            </div>
            <div>
                <label for="gpioPin">GPIO Pin:</label>
                <input type="number" id="gpioPin" name="gpioPin" value="<%= part.gpioPin || '' %>">
            </div>
        </div>
        <div id="ledInputs" style="display: none;">
            <div>
                <label for="gpioPin">GPIO Pin:</label>
                <input type="number" id="gpioPin" name="gpioPin" value="<%= part.gpioPin || '' %>" min="0" max="40">
            </div>
            <div>
                <label for="duration">Duration (ms):</label>
                <input type="number" id="duration" name="duration" value="<%= part.duration || '' %>" min="0">
            </div>
        </div>
        <div id="servoInputs" style="display: none;">
            <div>
                <label for="gpioPin">GPIO Pin:</label>
                <input type="number" id="gpioPin" name="gpioPin" value="<%= part.gpioPin || '' %>">
            </div>
            <div>
                <label for="pwmFrequency">PWM Frequency (Hz):</label>
                <input type="number" id="pwmFrequency" name="pwmFrequency" value="<%= part.pwmFrequency || '' %>">
            </div>
            <div>
                <label for="dutyCycle">Duty Cycle (%):</label>
                <input type="number" id="dutyCycle" name="dutyCycle" value="<%= part.dutyCycle || '' %>" min="0" max="100">
            </div>
        </div>
        <div id="microphoneInputs" style="display: none;">
            <!-- Basic Configuration -->
            <div class="microphone-section">
                <h4>🎤 Basic Configuration</h4>
                <div class="form-grid">
                    <div>
                        <label for="deviceId">Device ID:</label>
                        <select id="deviceId" name="deviceId">
                            <option value="default" <%= (part.deviceId || 'default') === 'default' ? 'selected' : '' %>>Default Device</option>
                            <!-- Device options will be populated by JavaScript -->
                        </select>
                        <button type="button" id="detectDevicesBtn" class="btn-small">🔍 Detect Devices</button>
                        <small>Audio device identifier</small>
                    </div>
                    <div>
                        <label for="sampleRate">Sample Rate (Hz):</label>
                        <select id="sampleRate" name="sampleRate">
                            <option value="8000" <%= part.sampleRate === 8000 ? 'selected' : '' %>>8000</option>
                            <option value="16000" <%= part.sampleRate === 16000 || !part.sampleRate ? 'selected' : '' %>>16000</option>
                            <option value="22050" <%= part.sampleRate === 22050 ? 'selected' : '' %>>22050</option>
                            <option value="44100" <%= part.sampleRate === 44100 ? 'selected' : '' %>>44100</option>
                            <option value="48000" <%= part.sampleRate === 48000 ? 'selected' : '' %>>48000</option>
                        </select>
                    </div>
                    <div>
                        <label for="channels">Channels:</label>
                        <select id="channels" name="channels">
                            <option value="1" <%= part.channels === 1 || !part.channels ? 'selected' : '' %>>1 (Mono)</option>
                            <option value="2" <%= part.channels === 2 ? 'selected' : '' %>>2 (Stereo)</option>
                        </select>
                    </div>
                    <div>
                        <label for="sensitivity">Sensitivity:</label>
                        <input type="range" id="sensitivity" name="sensitivity" min="0.1" max="3.0" step="0.1" value="<%= part.sensitivity || 1.0 %>">
                        <span id="sensitivityValue"><%= part.sensitivity || 1.0 %></span>
                        <small>Microphone input sensitivity (0.1 - 3.0)</small>
                    </div>
                </div>
            </div>

            <!-- Audio Processing -->
            <div class="microphone-section">
                <h4>🔧 Audio Processing</h4>
                <div class="checkbox-grid">
                    <div>
                        <label>
                            <input type="checkbox" id="echoCancellation" name="echoCancellation" <%= part.echoCancellation !== false ? 'checked' : '' %>>
                            Echo Cancellation
                        </label>
                        <small>Reduces echo and feedback</small>
                    </div>
                    <div>
                        <label>
                            <input type="checkbox" id="noiseSuppression" name="noiseSuppression" <%= part.noiseSuppression !== false ? 'checked' : '' %>>
                            Noise Suppression
                        </label>
                        <small>Filters background noise</small>
                    </div>
                    <div>
                        <label>
                            <input type="checkbox" id="autoGainControl" name="autoGainControl" <%= part.autoGainControl !== false ? 'checked' : '' %>>
                            Auto Gain Control
                        </label>
                        <small>Automatically adjusts volume levels</small>
                    </div>
                    <div>
                        <label>
                            <input type="checkbox" id="voiceActivation" name="voiceActivation" <%= part.voiceActivation ? 'checked' : '' %>>
                            Voice Activation Detection
                        </label>
                        <small>Only record when voice is detected</small>
                    </div>
                </div>
                <div id="voiceActivationThresholdDiv" style="display: <%= part.voiceActivation ? 'block' : 'none' %>;">
                    <label for="voiceActivationThreshold">Voice Activation Threshold:</label>
                    <input type="range" id="voiceActivationThreshold" name="voiceActivationThreshold" min="0.01" max="1.0" step="0.01" value="<%= part.voiceActivationThreshold || 0.1 %>">
                    <span id="thresholdValue"><%= part.voiceActivationThreshold || 0.1 %></span>
                    <small>Threshold for voice activation (0.01 - 1.0)</small>
                </div>
            </div>
        </div>
        <button type="submit">Save Part</button>
    </form>

    <!-- Microphone Management Section (only visible for microphone parts) -->
    <div id="microphoneManagement" style="display: none;">
        <div class="management-tabs">
            <div class="tab-navigation">
                <button class="tab-button active" data-tab="test">🧪 Test</button>
                <button class="tab-button" data-tab="monitor">👁️ Monitor</button>
                <button class="tab-button" data-tab="stt">🎙️ STT Integration</button>
            </div>

            <!-- Test Tab -->
            <div id="test-tab" class="tab-content active">
                <div class="test-section">
                    <h4>🧪 Microphone Testing</h4>
                    <div class="test-controls">
                        <button type="button" id="testMicrophoneBtn" class="btn primary">🎤 Test Microphone</button>
                        <button type="button" id="testAudioLevelsBtn" class="btn secondary">📊 Test Audio Levels</button>
                        <button type="button" id="testSTTBtn" class="btn secondary">🎙️ Test STT</button>
                    </div>
                    <div id="testResults" class="test-results">
                        <h5>Test Results</h5>
                        <div id="testStatus">Not tested yet</div>
                        <pre id="testOutput"></pre>
                    </div>
                </div>
            </div>

            <!-- Monitor Tab -->
            <div id="monitor-tab" class="tab-content">
                <div class="monitor-section">
                    <h4>👁️ Live Monitoring</h4>
                    <div class="monitor-controls">
                        <button type="button" id="startMonitoringBtn" class="btn primary">▶️ Start Monitoring</button>
                        <button type="button" id="stopMonitoringBtn" class="btn secondary">⏹️ Stop Monitoring</button>
                    </div>
                    <div class="audio-level-container">
                        <div class="audio-level-meter">
                            <div class="level-bar" id="audioLevelBar"></div>
                        </div>
                        <div class="audio-level-percentage" id="audioLevelPercentage">0%</div>
                    </div>
                    <div id="monitoringData" class="monitoring-data">
                        <div class="metric">
                            <span class="metric-label">Peak Level:</span>
                            <span class="metric-value" id="peakLevel">0 dB</span>
                        </div>
                        <div class="metric">
                            <span class="metric-label">Average Level:</span>
                            <span class="metric-value" id="avgLevel">0 dB</span>
                        </div>
                        <div class="metric">
                            <span class="metric-label">Noise Floor:</span>
                            <span class="metric-value" id="noiseFloor">-∞ dB</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STT Integration Tab -->
            <div id="stt-tab" class="tab-content">
                <div class="stt-section">
                    <h4>🎙️ Speech-to-Text Integration</h4>
                    <div class="stt-status">
                        <div class="status-indicator">
                            <span class="indicator-dot" id="sttStatusDot"></span>
                            <span id="sttStatusText">STT Service Status: Checking...</span>
                        </div>
                    </div>
                    <div class="stt-controls">
                        <button type="button" id="testSTTIntegrationBtn" class="btn primary">🎙️ Test STT Integration</button>
                        <button type="button" id="configureSTTBtn" class="btn secondary">⚙️ Configure STT</button>
                    </div>
                    <div id="sttResults" class="stt-results">
                        <h5>STT Test Results</h5>
                        <div id="transcriptionOutput"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Standard Test Area (for non-microphone parts) -->
    <div id="standardTestArea">
        <button type="button" id="testPartButton" onclick="testPart()">Test Part</button>
        <div id="testArea">
            <h2>Test Results</h2>
            <p id="testStatus">Not tested yet</p>
            <pre id="testOutput"></pre>
        </div>
    </div>

    <a href="/parts" class="button">Back to Parts</a>

    <script>
        const characterId = '<%= character.id %>';
        const partId = '<%= part.id %>';

        function toggleInputs() {
            const type = document.getElementById('type').value;
            const isMicrophone = type === 'microphone';

            // Toggle input sections
            document.getElementById('motorInputs').style.display = ['motor', 'linear-actuator'].includes(type) ? 'block' : 'none';
            document.getElementById('singlePinInputs').style.display = ['light'].includes(type) ? 'block' : 'none';
            document.getElementById('sensorInputs').style.display = type === 'sensor' ? 'block' : 'none';
            document.getElementById('ledInputs').style.display = type === 'led' ? 'block' : 'none';
            document.getElementById('servoInputs').style.display = type === 'servo' ? 'block' : 'none';
            document.getElementById('microphoneInputs').style.display = isMicrophone ? 'block' : 'none';

            // Toggle character selection (enable for microphones)
            const characterSelect = document.getElementById('characterId');
            characterSelect.disabled = !isMicrophone;

            // Toggle management sections
            document.getElementById('microphoneManagement').style.display = isMicrophone ? 'block' : 'none';
            document.getElementById('standardTestArea').style.display = isMicrophone ? 'none' : 'block';
        }

        // Call toggleInputs on page load to set initial state
        toggleInputs();

        // Microphone-specific JavaScript
        document.addEventListener('DOMContentLoaded', function() {
            // Update sensitivity value display
            const sensitivitySlider = document.getElementById('sensitivity');
            const sensitivityValue = document.getElementById('sensitivityValue');
            if (sensitivitySlider && sensitivityValue) {
                sensitivitySlider.addEventListener('input', function() {
                    sensitivityValue.textContent = this.value;
                });
            }

            // Update threshold value display
            const thresholdSlider = document.getElementById('voiceActivationThreshold');
            const thresholdValue = document.getElementById('thresholdValue');
            if (thresholdSlider && thresholdValue) {
                thresholdSlider.addEventListener('input', function() {
                    thresholdValue.textContent = this.value;
                });
            }

            // Toggle voice activation threshold visibility
            const voiceActivationCheckbox = document.getElementById('voiceActivation');
            const thresholdDiv = document.getElementById('voiceActivationThresholdDiv');
            if (voiceActivationCheckbox && thresholdDiv) {
                voiceActivationCheckbox.addEventListener('change', function() {
                    thresholdDiv.style.display = this.checked ? 'block' : 'none';
                });
            }

            // Initialize microphone management features
            initializeMicrophoneManagement();
        });

        // Initialize microphone management functionality
        function initializeMicrophoneManagement() {
            // Tab switching
            const tabButtons = document.querySelectorAll('.tab-button');
            const tabContents = document.querySelectorAll('.tab-content');

            tabButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const targetTab = this.getAttribute('data-tab');

                    // Update active states
                    tabButtons.forEach(btn => btn.classList.remove('active'));
                    tabContents.forEach(content => content.classList.remove('active'));

                    this.classList.add('active');
                    document.getElementById(targetTab + '-tab').classList.add('active');
                });
            });

            // Device detection
            const detectDevicesBtn = document.getElementById('detectDevicesBtn');
            if (detectDevicesBtn) {
                detectDevicesBtn.addEventListener('click', detectAudioDevices);
            }

            // Test buttons
            const testMicrophoneBtn = document.getElementById('testMicrophoneBtn');
            if (testMicrophoneBtn) {
                testMicrophoneBtn.addEventListener('click', testMicrophone);
            }

            const testAudioLevelsBtn = document.getElementById('testAudioLevelsBtn');
            if (testAudioLevelsBtn) {
                testAudioLevelsBtn.addEventListener('click', testAudioLevels);
            }

            const testSTTBtn = document.getElementById('testSTTBtn');
            if (testSTTBtn) {
                testSTTBtn.addEventListener('click', testSTTIntegration);
            }

            // Monitoring buttons
            const startMonitoringBtn = document.getElementById('startMonitoringBtn');
            if (startMonitoringBtn) {
                startMonitoringBtn.addEventListener('click', startMonitoring);
            }

            const stopMonitoringBtn = document.getElementById('stopMonitoringBtn');
            if (stopMonitoringBtn) {
                stopMonitoringBtn.addEventListener('click', stopMonitoring);
            }

            // STT Integration buttons
            const testSTTIntegrationBtn = document.getElementById('testSTTIntegrationBtn');
            if (testSTTIntegrationBtn) {
                testSTTIntegrationBtn.addEventListener('click', testSTTIntegration);
            }

            const configureSTTBtn = document.getElementById('configureSTTBtn');
            if (configureSTTBtn) {
                configureSTTBtn.addEventListener('click', configureSTT);
            }

            // Initialize device detection on page load
            if (document.getElementById('type').value === 'microphone') {
                detectAudioDevices();
                // STT config moved to separate forms under /ai-management/stt
                checkSTTStatus();
            }
        }

        // Microphone Management Functions
        async function detectAudioDevices() {
            try {
                const response = await axios.get('/parts/api/microphone/devices');
                const deviceSelect = document.getElementById('deviceId');

                // Clear existing options except default
                deviceSelect.innerHTML = '<option value="default">Default Device</option>';

                if (response.data.success && response.data.devices) {
                    response.data.devices.forEach(device => {
                        const option = document.createElement('option');
                        option.value = device.id;
                        option.textContent = `${device.name} (${device.id})`;
                        deviceSelect.appendChild(option);
                    });
                }
            } catch (error) {
                console.error('Error detecting audio devices:', error);
                // non-fatal; keep UI responsive
            }
        }

        async function testMicrophone() {
            const testStatus = document.getElementById('testStatus');
            const testOutput = document.getElementById('testOutput');

            testStatus.textContent = 'Testing microphone...';
            testOutput.textContent = '';

            try {
                const microphoneConfig = {
                    deviceId: document.getElementById('deviceId').value,
                    sampleRate: parseInt(document.getElementById('sampleRate').value),
                    channels: parseInt(document.getElementById('channels').value),
                    sensitivity: parseFloat(document.getElementById('sensitivity').value)
                };

                const response = await axios.post('/parts/api/microphone/test', {
                    config: microphoneConfig,
                    duration: 5
                });

                if (response.data.success) {
                    testStatus.textContent = 'Microphone test completed successfully';
                    testOutput.textContent = JSON.stringify(response.data.results, null, 2);
                } else {
                    testStatus.textContent = 'Microphone test failed';
                    testOutput.textContent = response.data.error || 'Unknown error';
                }
            } catch (error) {
                console.error('Error testing microphone:', error);
                testStatus.textContent = 'Error testing microphone';
                testOutput.textContent = error.message;
            }
        }

        async function testAudioLevels() {
            const testStatus = document.getElementById('testStatus');
            testStatus.textContent = 'Testing audio levels...';

            try {
                const response = await axios.post('/parts/api/microphone/test-levels', {
                    microphoneId: partId || 'default',
                    duration: 10
                });

                if (response.data.success) {
                    testStatus.textContent = 'Audio level test completed';
                    updateAudioLevelDisplay(response.data.levels);
                } else {
                    testStatus.textContent = 'Audio level test failed';
                }
            } catch (error) {
                console.error('Error testing audio levels:', error);
                testStatus.textContent = 'Error testing audio levels';
            }
        }

        async function startMonitoring() {
            if (!partId) {
                showNotification('Please save the microphone first before starting monitoring', 'error');
                return;
            }

            try {
                const response = await axios.post(`/parts/api/microphone/${partId}/start-monitoring`);

                if (response.data.success) {
                    showNotification('Monitoring started', 'success');
                    // Start real-time updates
                    startAudioLevelUpdates();
                } else {
                    showNotification('Failed to start monitoring', 'error');
                }
            } catch (error) {
                console.error('Error starting monitoring:', error);
                showNotification('Error starting monitoring', 'error');
            }
        }

        async function stopMonitoring() {
            if (!partId) {
                showNotification('Please save the microphone first before stopping monitoring', 'error');
                return;
            }

            try {
                const response = await axios.post(`/parts/api/microphone/${partId}/stop-monitoring`);

                if (response.data.success) {
                    showNotification('Monitoring stopped', 'success');
                    stopAudioLevelUpdates();
                } else {
                    showNotification('Failed to stop monitoring', 'error');
                }
            } catch (error) {
                console.error('Error stopping monitoring:', error);
                showNotification('Error stopping monitoring', 'error');
            }
        }

        async function testSTTIntegration() {
            const sttResults = document.getElementById('transcriptionOutput');
            sttResults.innerHTML = '<div class="loading">Testing STT integration...</div>';

            try {
                const response = await axios.post('/parts/api/microphone/test-stt', {
                    microphoneId: partId || 'default',
                    characterId: characterId,
                    duration: 10
                });

                if (response.data.success) {
                    sttResults.innerHTML = `
                        <div class="stt-result success">
                            <h6>STT Test Successful</h6>
                            <p><strong>Transcription:</strong> ${response.data.transcription}</p>
                            <p><strong>Confidence:</strong> ${response.data.confidence}%</p>
                            <p><strong>Language:</strong> ${response.data.language}</p>
                        </div>
                    `;
                } else {
                    sttResults.innerHTML = `
                        <div class="stt-result error">
                            <h6>STT Test Failed</h6>
                            <p>${response.data.error}</p>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error testing STT integration:', error);
                sttResults.innerHTML = `
                    <div class="stt-result error">
                        <h6>STT Test Error</h6>
                        <p>${error.message}</p>
                    </div>
                `;
            }
        }

        async function configureSTT() {
            // STT configuration consolidated under AI Management -> STT
            window.open(`/ai-management/stt?characterId=${characterId}`, '_blank');
        }

        async function checkSTTStatus() {
            try {
                const response = await axios.get('/parts/api/microphone/stt-status');
                const statusDot = document.getElementById('sttStatusDot');
                const statusText = document.getElementById('sttStatusText');

                if (response.data.success && response.data.status === 'active') {
                    statusDot.className = 'indicator-dot active';
                    statusText.textContent = 'STT Service Status: Active';
                } else {
                    statusDot.className = 'indicator-dot inactive';
                    statusText.textContent = 'STT Service Status: Inactive';
                }
            } catch (error) {
                console.error('Error checking STT status:', error);
                const statusDot = document.getElementById('sttStatusDot');
                const statusText = document.getElementById('sttStatusText');
                statusDot.className = 'indicator-dot error';
                statusText.textContent = 'STT Service Status: Error';
            }
        }

        function updateAudioLevelDisplay(levels) {
            const levelBar = document.getElementById('audioLevelBar');
            const levelPercentage = document.getElementById('audioLevelPercentage');
            const peakLevel = document.getElementById('peakLevel');
            const avgLevel = document.getElementById('avgLevel');
            const noiseFloor = document.getElementById('noiseFloor');

            if (levels) {
                const percentage = Math.min(100, Math.max(0, levels.current || 0));
                levelBar.style.width = percentage + '%';
                levelPercentage.textContent = percentage.toFixed(1) + '%';

                if (peakLevel) peakLevel.textContent = (levels.peak || 0).toFixed(1) + ' dB';
                if (avgLevel) avgLevel.textContent = (levels.average || 0).toFixed(1) + ' dB';
                if (noiseFloor) noiseFloor.textContent = (levels.noiseFloor || -60).toFixed(1) + ' dB';
            }
        }

        let audioLevelInterval;
        function startAudioLevelUpdates() {
            if (!partId) {
                console.warn('Cannot start audio level updates: microphone not saved yet');
                return;
            }

            audioLevelInterval = setInterval(async () => {
                try {
                    const response = await axios.get(`/parts/api/microphone/${partId}/levels`);
                    if (response.data.success) {
                        updateAudioLevelDisplay(response.data.levels);
                    }
                } catch (error) {
                    console.error('Error getting audio levels:', error);
                }
            }, 100); // Update every 100ms
        }

        function stopAudioLevelUpdates() {
            if (audioLevelInterval) {
                clearInterval(audioLevelInterval);
                audioLevelInterval = null;
            }
        }

        function showNotification(message, type = 'info') {
            // Simple notification system
            const notification = document.createElement('div');
            notification.className = `notification ${type}`;
            notification.textContent = message;
            notification.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                padding: 10px 20px;
                border-radius: 5px;
                color: white;
                z-index: 1000;
                background-color: ${type === 'success' ? '#4CAF50' : type === 'error' ? '#f44336' : '#2196F3'};
            `;

            document.body.appendChild(notification);

            setTimeout(() => {
                document.body.removeChild(notification);
            }, 3000);
        }

        function testPart() {
            const type = document.getElementById('type').value;
            const testStatus = document.getElementById('testStatus');
            const testOutput = document.getElementById('testOutput');
            testStatus.textContent = 'Testing...';
            testOutput.textContent = '';

            let script = '';
            let args = [];

            switch (type) {
                case 'motor':
                case 'linear-actuator':
                    script = 'motor_control.py';
                    args = ['forward', '50', '1000', document.getElementById('directionPin').value, document.getElementById('pwmPin').value];
                    break;
                case 'light':
                case 'led':
                    script = 'light_control.py';
                    args = ['on', '1000', document.getElementById('gpioPin').value];
                    if (type === 'led') {
                        args.push('50'); // brightness
                    }
                    break;
                case 'servo':
                    script = 'servo_control.py';
                    args = ['90', '50', '1000', document.getElementById('gpioPin').value];
                    break;
                case 'sensor':
                    script = 'sensor_control.py';
                    args = [document.getElementById('gpioPin').value, '5'];
                    break;
                case 'microphone':
                    script = 'microphone_test.py';
                    args = [
                        document.getElementById('deviceId').value,
                        document.getElementById('sampleRate').value,
                        document.getElementById('channels').value,
                        '5' // test duration in seconds
                    ];
                    break;
                default:
                    testStatus.textContent = 'Error: Unknown part type';
                    return;
            }

            axios.post('/execute-python-script', { script, args })
                .then(function (response) {
                    console.log('Test response:', response.data);
                    if (response.data.success) {
                        testStatus.textContent = 'Test completed successfully';
                        testOutput.textContent = JSON.stringify(response.data, null, 2);
                    } else {
                        testStatus.textContent = 'Test failed';
                        testOutput.textContent = JSON.stringify(response.data, null, 2);
                    }
                })
                .catch(function (error) {
                    console.error('Error testing part:', error);
                    testStatus.textContent = 'Error testing part';
                    if (error.response) {
                        testOutput.textContent = `Status: ${error.response.status}\nData: ${JSON.stringify(error.response.data, null, 2)}`;
                    } else if (error.request) {
                        testOutput.textContent = 'No response received from server';
                    } else {
                        testOutput.textContent = `Error: ${error.message}`;
                    }
                });
        }
    </script>

