<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1 class="landing-title">🦷 Jaw Animation</h1>
    <p class="subtitle">Amplitude-only jaw animation powered by ElevenLabs audio. Per-character settings.</p>

    <div class="form-group">
      <label for="characterId">Character</label>
      <select id="characterId" onchange="onCharacterChange(this.value)">
        <option value="">Choose a character...</option>
        <% (characters || []).forEach(function(c){ %>
          <option value="<%= c.id %>" <%= (String(c.id)===String(characterId)) ? 'selected' : '' %>><%= c.char_name || c.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="servoPartId">Jaw Servo</label>
      <select id="servoPartId">
        <option value="">Select a servo...</option>
        <% (servos || []).forEach(function(s){ %>
          <option value="<%= s.id %>" <%= (config && s.id===config.servoPartId) ? 'selected' : '' %>><%= s.name || ('Servo '+s.id) %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" id="enabled" <%= (config && config.enabled) ? 'checked' : '' %>>
        Enabled
      </label>
    </div>

    <div class="form-group">
      <label>Min Angle (deg)</label>
      <input type="number" id="minAngle" min="0" max="180" value="<%= config ? config.minAngle : 60 %>">
    </div>

    <div class="form-group">
      <label>Max Angle (deg)</label>
      <input type="number" id="maxAngle" min="0" max="180" value="<%= config ? config.maxAngle : 120 %>">
    </div>

    <div class="form-group">
      <label>Smoothing (0-0.99)</label>
      <input type="number" id="smoothing" step="0.01" min="0" max="0.99" value="<%= config ? config.smoothing : 0.6 %>">
    </div>

    <div class="form-group">
      <label>Sensitivity (0.1-5.0)</label>
      <input type="number" id="sensitivity" step="0.1" min="0.1" max="5.0" value="<%= config ? config.sensitivity : 1.0 %>">
    </div>

    <div class="button-group">
      <button class="button" onclick="saveConfig()">Save</button>
      <a class="button secondary-btn" href="/super-powers">Back</a>
    </div>

    <div class="status-section">
      <h3 class="font-creepster">🎧 Live Level</h3>
      <div id="levelBar" style="height: 20px; background:#222; border:1px solid #28a745;">
        <div id="levelFill" style="height:100%; width:0%; background:#28a745;"></div>
      </div>
      <div id="lastTranscript" style="margin-top:8px; color:#ccc; font-size:14px;"></div>
    </div>
  </div>

  <script>
    const characterId = <%- characterId ? JSON.stringify(String(characterId)) : 'null' %>;

    function onCharacterChange(id){
      const url = new URL(window.location.href);
      if(id){ url.searchParams.set('characterId', id); }
      else { url.searchParams.delete('characterId'); }
      window.location.href = url.toString();
    }

    async function saveConfig(){
      const cid = document.getElementById('characterId').value;
      if(!cid){ return alert('Select a character'); }
      const body = {
        enabled: document.getElementById('enabled').checked,
        servoPartId: document.getElementById('servoPartId').value || null,
        minAngle: parseFloat(document.getElementById('minAngle').value),
        maxAngle: parseFloat(document.getElementById('maxAngle').value),
        smoothing: parseFloat(document.getElementById('smoothing').value),
        sensitivity: parseFloat(document.getElementById('sensitivity').value)
      };
      const res = await fetch('/api/super-powers/jaw-animation/'+cid, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)});
      const json = await res.json();
      if(json.success){ alert('Saved'); }
      else { alert('Save failed'); }
    }

    // Live level: subscribe to ElevenLabs client WS if available via test chat conventions
    let ws;
    function connectLive(){
      try{
        ws = new WebSocket('ws://'+window.location.hostname+':8671'); // Fixed: service runs on 8671
        ws.onopen = ()=>{ /* no auth required for just showcasing level visuals if available */ };
        ws.onmessage = (ev)=>{
          try{
            const msg = JSON.parse(ev.data);
            if(msg.type==='audio' && msg.format==='base64'){
              // crude amplitude estimate on client for bar
              const len = (msg.audioData||'').length;
              const approxAmp = Math.min(1, Math.sqrt(len/20000));
              document.getElementById('levelFill').style.width = (approxAmp*100).toFixed(0)+'%';
            } else if(msg.type==='transcript'){
              document.getElementById('lastTranscript').textContent = (msg.role==='assistant'?'AI: ':'You: ')+msg.text;
            }
          }catch(e){}
        };
      }catch(e){}
    }
    connectLive();
  </script>
</body>
</html>

