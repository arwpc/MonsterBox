<script>
  try { if (navigator.webdriver) window.MB_TEST_MODE = true; } catch (e) { }
</script>

<style>
  .conv-grid-panel {
    height: 100%;
  }
  .conv-panel-body {
    max-height: 350px;
    overflow-y: auto;
  }
  .conv-hardware-list {
    max-height: 400px;
    overflow-y: auto;
  }
  .conv-audio-list {
    max-height: 250px;
    overflow-y: auto;
  }
  .conv-chat-log {
    height: 250px;
    overflow-y: auto;
    background: #111;
    border-radius: 5px;
    padding: 10px;
  }
  .conv-part-control {
    border-bottom: 1px solid #333;
    padding: 10px 0;
  }
  .conv-part-control:last-child {
    border-bottom: none;
  }
</style>

<div class="container-fluid">
  <!-- Page Header -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0"><i class="bi bi-broadcast"></i> Conversation Control</h1>
    <div class="d-flex align-items-center gap-2">
      <a class="btn btn-outline-secondary btn-sm" href="/ai-settings/stt"><i class="bi bi-sliders"></i> STT Config</a>
      <a class="btn btn-outline-secondary btn-sm" href="/ai-settings/tts"><i class="bi bi-volume-up"></i> TTS Config</a>
    </div>
  </div>

  <!-- Main Grid Layout: 3 columns on large screens, stacks on mobile -->
  <div class="row g-3">
    
    <!-- Column 1: Character Selection, Live Audio (STT), Make Say -->
    <div class="col-lg-4">
      
      <!-- Character Selection -->
      <div class="card mb-3" id="character-selection-card">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-person-badge"></i> Character Selection</h6>
        </div>
        <div class="card-body">
          <select id="character-select" class="form-select form-select-sm" data-testid="character-selector">
            <option value="">Loading characters...</option>
          </select>
          <div id="character-select-status" class="form-text text-muted mt-2 small"></div>
        </div>
      </div>

      <!-- Live Audio (STT) -->
      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="bi bi-mic"></i> Live Audio (STT)</h6>
          <a href="/ai-settings/stt" class="btn btn-sm btn-outline-secondary" title="STT Configuration">
            <i class="bi bi-gear"></i>
          </a>
        </div>
        <div class="card-body">
          <div id="micStatus" class="small text-muted mb-2">Configure VAD and input device</div>
          <div class="progress" style="height: 10px;">
            <div id="audioLevel" class="progress-bar bg-success" style="width: 5%"></div>
          </div>
          <div class="mt-2 d-flex gap-2 flex-wrap">
            <button id="micStart" class="btn btn-success btn-sm"><i class="bi bi-mic-fill"></i> Start</button>
            <button id="micStop" class="btn btn-outline-danger btn-sm"><i class="bi bi-mic-mute"></i> Stop</button>
            <button id="listenInBtn" class="btn btn-outline-info btn-sm"><i class="bi bi-headphones"></i> Listen In</button>
          </div>
          <div class="mt-2">
            <label class="form-label small text-muted">Transcription</label>
            <div id="transcript" class="border rounded p-2 small" style="min-height: 60px; max-height: 100px; overflow-y: auto; background: #1a1a1a;">
              <span class="text-muted">Transcription will appear here...</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Make Character Say -->
      <div class="card mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-send"></i> Make <span id="charName">Character</span> Say</h6>
        </div>
        <div class="card-body">
          <div class="mb-2">
            <label for="convSpeakerSelect" class="form-label small text-muted">Speaker</label>
            <select id="convSpeakerSelect" class="form-select form-select-sm">
              <option value="">Loading...</option>
            </select>
          </div>
          <div class="input-group input-group-sm">
            <input id="sayInput" type="text" class="form-control" placeholder="Type something spooky...">
            <button id="sayBtn" class="btn btn-primary"><i class="bi bi-send"></i> Speak</button>
          </div>
          <div id="sayStatus" class="mt-2 small"></div>
        </div>
      </div>

      <!-- Ask AI -->
      <div class="card mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-robot"></i> Ask AI</h6>
        </div>
        <div class="card-body">
          <div class="input-group input-group-sm">
            <input id="askInput" type="text" class="form-control" placeholder="Ask a question...">
            <button id="askBtn" class="btn btn-success"><i class="bi bi-chat-dots"></i> Ask</button>
          </div>
          <div id="askStatus" class="mt-2 small"></div>
        </div>
      </div>

      <!-- Audio Files -->
      <div class="card mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-music-note-list"></i> Audio Files</h6>
        </div>
        <div class="card-body">
          <select id="audioFileSelect" class="form-select form-select-sm mb-2">
            <option value="">Select audio file...</option>
          </select>
          <div class="d-flex gap-2 mb-2">
            <button id="audioPlayBtn" class="btn btn-success btn-sm flex-fill"><i class="bi bi-play-fill"></i> Play</button>
            <button id="audioStopBtn" class="btn btn-danger btn-sm flex-fill"><i class="bi bi-stop-fill"></i> Stop</button>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="audioLoopToggle">
            <label class="form-check-label small" for="audioLoopToggle">Loop continuously</label>
          </div>
          <div id="audioStatus" class="mt-2 small"></div>
        </div>
      </div>

    </div>

    <!-- Column 2: AI On, Hardware Control, Monster Features -->
    <div class="col-lg-4">
      
      <!-- AI On (Autonomous Mode) -->
      <div class="card mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-robot"></i> AI On (Autonomous)</h6>
        </div>
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="aiOnToggle">
              <label class="form-check-label fw-bold" for="aiOnToggle">AI On</label>
            </div>
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="aiMicToggle" checked>
              <label class="form-check-label small" for="aiMicToggle">Use Microphone</label>
            </div>
          </div>
          <small class="text-muted d-block mb-2">When ON with mic: responds to speech via STT. Without mic: generates comments automatically.</small>
          
          <div id="aiChatLog" class="conv-chat-log mb-2">
            <div class="text-muted small">AI chat log will appear here...</div>
          </div>
          
          <div id="aiOnStatus" class="small text-info"></div>
        </div>
      </div>

      <!-- Hardware Control -->
      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="bi bi-gear"></i> Hardware Control</h6>
          <span class="badge bg-secondary" id="hardwareCount">0 parts</span>
        </div>
        <div class="card-body p-0">
          <div id="hardwareList" class="conv-hardware-list p-2">
            <div class="text-muted text-center py-3 small">Select a character to see hardware parts</div>
          </div>
        </div>
      </div>

      <!-- Monster Features -->
      <div class="card mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-lightning-charge"></i> Monster Features</h6>
        </div>
        <div class="card-body">
          <!-- Jaw Animation -->
          <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
            <div>
              <div class="form-check form-switch mb-1">
                <input class="form-check-input" type="checkbox" id="jawToggle">
                <label class="form-check-label fw-bold" for="jawToggle">Jaw Animation</label>
              </div>
              <small class="text-muted">Sync jaw with speech audio</small>
            </div>
            <a href="/setup/super-powers" class="btn btn-sm btn-outline-secondary">
              <i class="bi bi-gear"></i>
            </a>
          </div>

          <!-- Parrot Mode -->
          <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
            <div>
              <div class="form-check form-switch mb-1">
                <input class="form-check-input" type="checkbox" id="parrotToggle">
                <label class="form-check-label fw-bold" for="parrotToggle">Parrot Mode</label>
              </div>
              <small class="text-muted">Repeat detected speech</small>
            </div>
            <a href="/setup/super-powers" class="btn btn-sm btn-outline-secondary">
              <i class="bi bi-gear"></i>
            </a>
          </div>

          <!-- Head Tracking -->
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <div class="form-check form-switch mb-1">
                <input class="form-check-input" type="checkbox" id="headTrackToggle">
                <label class="form-check-label fw-bold" for="headTrackToggle">Head Tracking</label>
              </div>
              <small class="text-muted">Track visitor movement</small>
            </div>
            <a href="/setup/super-powers" class="btn btn-sm btn-outline-secondary">
              <i class="bi bi-gear"></i>
            </a>
          </div>
        </div>
      </div>

    </div>

    <!-- Column 3: Scenes, Webcam -->
    <div class="col-lg-4">
      
      <!-- Scenes -->
      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="bi bi-film"></i> Scenes</h6>
          <a href="/scenes" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-gear"></i>
          </a>
        </div>
        <div class="card-body conv-panel-body">
          <div id="scenesContainer">
            <div class="text-center text-muted py-3">
              <div class="spinner-border spinner-border-sm"></div>
              <p class="mt-2 mb-0 small">Loading scenes...</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Webcam -->
      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h6 class="mb-0"><i class="bi bi-camera-video"></i> Webcam</h6>
          <small class="text-muted" id="webcamHint"></small>
        </div>
        <div class="card-body text-center">
          <img id="webcamImg" src="" alt="Webcam Stream" class="img-fluid rounded border" style="max-height: 400px; max-width: 100%; background: #000;">
          <div id="webcamStatus" class="text-muted mt-2 small">Finding webcam...</div>
        </div>
      </div>

    </div>

  </div>
</div>

<script src="/js/mic-panel.js"></script>
<script src="/js/websocket-chat.js"></script>

<script>
  (function () {
    const ui = {
      levelBar: null,
      transcript: null,
      sayBtn: null,
      sayInput: null,
      sayStatus: null,
      askBtn: null,
      askInput: null,
      askStatus: null,
      speakerSelect: null,
      jawToggle: null,
      headTrackToggle: null,
      parrotToggle: null,
      listenInBtn: null,
      aiOnToggle: null,
      aiMicToggle: null,
      aiChatLog: null,
      aiOnStatus: null,
      characterSelect: null,
      characterSelectStatus: null,
      audioFileSelect: null,
      audioPlayBtn: null,
      audioStopBtn: null,
      audioLoopToggle: null,
      audioStatus: null,
      hardwareList: null,
      hardwareCount: null,
    };
    
    let characters = [];
    let currentCharacterId = null;
    let isSwitchingCharacter = false;
    let speakers = [];
    let selectedSpeakerPartId = null;
    let listenInAudio = null;
    let aiOnInterval = null;
    let aiWebSocket = null;
    let currentParts = [];
    let currentAudioFiles = [];

    // Parrot Mode
    var parrotEnabled = false;
    var lastParrotAt = 0;
    function parrotSay(text) {
      var t = (text || '').trim(); 
      if (!t) return;
      var now = Date.now(); 
      if (now - lastParrotAt < 800) return; 
      lastParrotAt = now;
      ui.sayStatus.innerHTML = '<span class="text-info">Parrot: "' + t.replace(/</g, '&lt;').slice(0, 140) + '"</span>';
      fetch('/conversation/api/say', { 
        method: 'POST', 
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify({ text: t, speakerPartId: selectedSpeakerPartId || undefined }) 
      })
      .then(r => r.json())
      .then(j => {
        if (j && j.success) { 
          ui.sayStatus.innerHTML = '<span class="text-success">Parrot spoke</span>'; 
        } else { 
          ui.sayStatus.innerHTML = '<span class="text-danger">Parrot failed</span>'; 
        }
      })
      .catch(() => ui.sayStatus.innerHTML = '<span class="text-danger">Parrot error</span>');
    }
    try { window.__parrotSay = parrotSay; } catch (e) { }

    function $(id) { return document.getElementById(id); }

    async function init() {
      // Bind UI elements
      ui.levelBar = $('audioLevel');
      ui.transcript = $('transcript');
      ui.sayBtn = $('sayBtn');
      ui.sayInput = $('sayInput');
      ui.sayStatus = $('sayStatus');
      ui.askBtn = $('askBtn');
      ui.askInput = $('askInput');
      ui.askStatus = $('askStatus');
      ui.speakerSelect = $('convSpeakerSelect');
      ui.jawToggle = $('jawToggle');
      ui.headTrackToggle = $('headTrackToggle');
      ui.parrotToggle = $('parrotToggle');
      ui.listenInBtn = $('listenInBtn');
      ui.aiOnToggle = $('aiOnToggle');
      ui.aiMicToggle = $('aiMicToggle');
      ui.aiChatLog = $('aiChatLog');
      ui.aiOnStatus = $('aiOnStatus');
      ui.characterSelect = $('character-select');
      ui.characterSelectStatus = $('character-select-status');
      ui.audioFileSelect = $('audioFileSelect');
      ui.audioPlayBtn = $('audioPlayBtn');
      ui.audioStopBtn = $('audioStopBtn');
      ui.audioLoopToggle = $('audioLoopToggle');
      ui.audioStatus = $('audioStatus');
      ui.hardwareList = $('hardwareList');
      ui.hardwareCount = $('hardwareCount');
      
      currentCharacterId = getCurrentCharacterIdFromLabel();
      
      setCharName();
      bindEvents();
      await loadCharacters();
      await loadSpeakers();
      
      // Initialize microphone panel
      try { 
        MicPanel.init({ 
          levelBarId: 'audioLevel', 
          startBtnId: 'micStart', 
          stopBtnId: 'micStop', 
          statusId: 'micStatus', 
          transcriptId: 'transcript', 
          jawToggleId: 'jawToggle', 
          enableStt: true 
        }); 
      } catch (_) { }

      await loadWebcam();
      await loadJawSettings();
      await loadHeadTrackStatus();
      await loadScenes();
      await loadAudioFiles();
      await loadHardwareParts();
    }

    function setCharName() {
      const label = document.querySelector('#charLabel');
      const nameEl = $('charName');
      if (label && nameEl) nameEl.textContent = label.textContent || 'Character';
    }

    function getCurrentCharacterIdFromLabel() {
      const label = document.querySelector('#charLabel');
      if (!label) return null;
      const idAttr = label.getAttribute('data-char-id');
      const parsed = parseInt(idAttr, 10);
      return Number.isFinite(parsed) ? parsed : null;
    }

    async function loadCharacters() {
      if (!ui.characterSelect) return;
      ui.characterSelect.disabled = true;
      ui.characterSelectStatus.textContent = 'Loading...';
      
      try {
        const r = await fetch('/setup/characters/api/characters');
        const j = await r.json();
        if (j && j.success && Array.isArray(j.characters)) {
          characters = j.characters;
          renderCharacterOptions();
        } else {
          throw new Error('Invalid response');
        }
      } catch (error) {
        console.error('Failed to load characters:', error);
        ui.characterSelectStatus.textContent = 'Failed to load characters.';
      }
    }

    function renderCharacterOptions() {
      if (!ui.characterSelect) return;
      ui.characterSelect.innerHTML = '';
      
      if (!characters.length) {
        ui.characterSelect.appendChild(new Option('No characters available', ''));
        ui.characterSelect.disabled = true;
        ui.characterSelectStatus.textContent = 'No characters configured.';
        return;
      }
      
      characters.forEach(char => {
        const opt = new Option(char.name || ('Character ' + char.id), String(char.id));
        ui.characterSelect.appendChild(opt);
      });
      
      const match = characters.find(c => Number(c.id) === Number(currentCharacterId));
      if (match) {
        ui.characterSelect.value = String(match.id);
      } else {
        currentCharacterId = characters[0].id;
        ui.characterSelect.value = String(currentCharacterId);
      }
      
      ui.characterSelect.disabled = false;
      ui.characterSelectStatus.textContent = 'Active character';
    }

    async function handleCharacterChange() {
      if (!ui.characterSelect || isSwitchingCharacter) return;
      const selected = parseInt(ui.characterSelect.value, 10);
      if (!Number.isFinite(selected) || selected === currentCharacterId) return;
      
      isSwitchingCharacter = true;
      ui.characterSelect.disabled = true;
      ui.characterSelectStatus.textContent = 'Switching...';
      
      try {
        const resp = await fetch('/setup/characters/api/select', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: selected })
        });
        const payload = await resp.json().catch(() => ({}));
        
        if (resp.ok && payload && payload.success) {
          currentCharacterId = selected;
          await refreshPageState();
          ui.characterSelectStatus.textContent = 'Character updated.';
        } else {
          throw new Error(payload && payload.error ? payload.error : 'Unknown error');
        }
      } catch (error) {
        console.error('Character switch failed:', error);
        ui.characterSelectStatus.textContent = 'Failed to switch.';
        if (ui.characterSelect && currentCharacterId !== null) {
          ui.characterSelect.value = String(currentCharacterId);
        }
      } finally {
        ui.characterSelect.disabled = false;
        isSwitchingCharacter = false;
      }
    }

    async function refreshPageState() {
      setCharName();
      await loadSpeakers();
      await loadWebcam();
      await loadJawSettings();
      await loadHeadTrackStatus();
      await loadScenes();
      await loadAudioFiles();
      await loadHardwareParts();
    }

    function bindEvents() {
      ui.sayBtn.addEventListener('click', sendSay);
      ui.sayInput.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); sendSay(); } });
      
      ui.askBtn.addEventListener('click', askAIQuestion);
      ui.askInput.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); askAIQuestion(); } });
      
      ui.jawToggle && ui.jawToggle.addEventListener('change', saveJawSettings);
      ui.headTrackToggle && ui.headTrackToggle.addEventListener('change', saveHeadTrackSettings);
      ui.listenInBtn && ui.listenInBtn.addEventListener('click', toggleListenIn);
      ui.aiOnToggle && ui.aiOnToggle.addEventListener('change', toggleAiOn);
      ui.characterSelect && ui.characterSelect.addEventListener('change', handleCharacterChange);
      
      ui.parrotToggle && ui.parrotToggle.addEventListener('change', function () {
        parrotEnabled = !!ui.parrotToggle.checked;
        try { window.__setParrotEnabled = v => { parrotEnabled = !!v; }; } catch (e) { }
        if (window.MB_TEST_MODE && parrotEnabled) {
          setTimeout(() => { 
            try { if (typeof window.__parrotSay === 'function') { window.__parrotSay('test'); } } 
            catch (e) { } 
          }, 2500);
        }
      });
      
      document.addEventListener('micpanel:user_transcript', ev => { 
        if (parrotEnabled && ev && ev.detail && ev.detail.text) { 
          try { if (typeof window.__parrotSay === 'function') { window.__parrotSay(ev.detail.text); } } 
          catch (e) { } 
        } 
      });
      
      // Audio controls
      ui.audioPlayBtn && ui.audioPlayBtn.addEventListener('click', playAudioFile);
      ui.audioStopBtn && ui.audioStopBtn.addEventListener('click', stopAudioFile);
    }

    async function loadSpeakers() {
      try {
        const r = await fetch('/conversation/api/speakers');
        const j = await r.json();
        if (j && j.success) { 
          speakers = j.speakers || []; 
          renderSpeakerSelect(); 
        } else { 
          renderSpeakerSelect([]); 
        }
      } catch { 
        renderSpeakerSelect([]); 
      }
    }

    function renderSpeakerSelect() {
      const sel = ui.speakerSelect; 
      sel.innerHTML = '';
      
      if (!speakers.length) { 
        sel.appendChild(new Option('Default System Output', '')); 
        sel.disabled = true; 
        return; 
      }
      
      speakers.forEach(sp => { 
        const label = (sp.name || ('Speaker ' + sp.id)) + (sp.characterId ? (' (Char ' + sp.characterId + ')') : ''); 
        const opt = new Option(label, sp.id); 
        sel.appendChild(opt); 
      });
      
      selectedSpeakerPartId = speakers[0].id; 
      sel.value = String(selectedSpeakerPartId); 
      sel.disabled = false;
      sel.addEventListener('change', e => { selectedSpeakerPartId = e.target.value || null; });
    }

    async function loadWebcam() {
      const img = $('webcamImg'); 
      const status = $('webcamStatus'); 
      const hint = $('webcamHint');
      
      try {
        const r = await fetch('/conversation/api/webcam-stream-url'); 
        const j = await r.json();
        
        if (j && j.success && j.url) { 
          try { 
            img.setAttribute('decoding', 'sync'); 
            img.setAttribute('loading', 'eager'); 
          } catch (_) { } 
          img.src = j.url + '?_=' + Date.now(); 
          status.textContent = 'Streaming'; 
          hint.textContent = j.url; 
        } else { 
          status.textContent = 'No webcam configured'; 
        }
      } catch { 
        status.textContent = 'Failed to locate webcam'; 
      }
    }

    async function loadHeadTrackStatus() {
      try {
        const r = await fetch('/conversation/api/head-tracking-status');
        const j = await r.json();
        if (j && j.success && ui.headTrackToggle) { 
          ui.headTrackToggle.checked = !!(j.headTracking && j.headTracking.enabled); 
        }
      } catch { }
    }

    async function saveHeadTrackSettings() {
      try {
        await fetch('/conversation/api/head-tracking', { 
          method: 'POST', 
          headers: { 'Content-Type': 'application/json' }, 
          body: JSON.stringify({ enabled: !!(ui.headTrackToggle && ui.headTrackToggle.checked) }) 
        });
      } catch { }
    }

    async function loadJawSettings() {
      try { 
        const r = await fetch('/conversation/api/jaw-settings'); 
        const j = await r.json(); 
        if (j && j.success) { 
          ui.jawToggle.checked = !!j.enabled; 
        } 
      } catch { }
    }

    async function saveJawSettings() {
      try { 
        await fetch('/conversation/api/jaw-settings', { 
          method: 'POST', 
          headers: { 'Content-Type': 'application/json' }, 
          body: JSON.stringify({ enabled: ui.jawToggle.checked }) 
        }); 
      } catch { }
    }

    async function sendSay() {
      const text = (ui.sayInput.value || '').trim(); 
      if (!text) { 
        ui.sayStatus.innerHTML = '<span class="text-warning">Enter text</span>'; 
        return; 
      }
      
      ui.sayBtn.disabled = true; 
      ui.sayBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Speaking...';
      
      try {
        const r = await fetch('/conversation/api/say', { 
          method: 'POST', 
          headers: { 'Content-Type': 'application/json' }, 
          body: JSON.stringify({ text, speakerPartId: selectedSpeakerPartId || undefined }) 
        });
        const j = await r.json();
        
        if (j && j.success) { 
          ui.sayStatus.innerHTML = '<span class="text-success">Done</span>'; 
        } else { 
          ui.sayStatus.innerHTML = '<span class="text-danger">Failed: ' + ((j && j.error) || '') + '</span>'; 
        }
      } catch (e) { 
        ui.sayStatus.innerHTML = '<span class="text-danger">Error: ' + (e && e.message ? e.message : e) + '</span>'; 
      } finally { 
        ui.sayBtn.disabled = false; 
        ui.sayBtn.innerHTML = '<i class="bi bi-send"></i> Speak'; 
      }
    }

    async function askAIQuestion() {
      const question = (ui.askInput.value || '').trim();
      if (!question) {
        ui.askStatus.innerHTML = '<span class="text-warning">Enter a question</span>';
        return;
      }
      
      ui.askBtn.disabled = true;
      ui.askBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Asking...';
      ui.askStatus.innerHTML = '<span class="text-info">Asking AI...</span>';
      
      try {
        const r = await fetch('/api/elevenlabs/generate-and-play', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: question, characterId: currentCharacterId })
        });
        const j = await r.json();
        
        if (j && j.success) {
          ui.askStatus.innerHTML = '<span class="text-success">AI responded</span>';
          ui.askInput.value = '';
        } else {
          ui.askStatus.innerHTML = '<span class="text-danger">Failed: ' + (j.error || 'Unknown error') + '</span>';
        }
      } catch (e) {
        ui.askStatus.innerHTML = '<span class="text-danger">Error: ' + e.message + '</span>';
      } finally {
        ui.askBtn.disabled = false;
        ui.askBtn.innerHTML = '<i class="bi bi-chat-dots"></i> Ask';
      }
    }

    function toggleListenIn() {
      if (listenInAudio) {
        listenInAudio.pause();
        listenInAudio = null;
        ui.listenInBtn.innerHTML = '<i class="bi bi-headphones"></i> Listen In';
        ui.listenInBtn.classList.remove('active');
      } else {
        fetch('/conversation/api/listen-in-url')
          .then(r => r.json())
          .then(j => {
            if (j && j.success && j.url) {
              listenInAudio = new Audio(j.url);
              listenInAudio.play();
              ui.listenInBtn.innerHTML = '<i class="bi bi-stop-circle"></i> Stop Listening';
              ui.listenInBtn.classList.add('active');
            } else {
              alert('No microphone configured');
            }
          })
          .catch(e => alert('Failed to start Listen In: ' + e.message));
      }
    }

    async function toggleAiOn() {
      const enabled = ui.aiOnToggle.checked;
      const useMic = ui.aiMicToggle.checked;
      
      if (enabled) {
        startAiOn(useMic);
      } else {
        stopAiOn();
      }
    }

    function startAiOn(useMic) {
      ui.aiOnStatus.innerHTML = '<span class="text-success">AI On - ' + (useMic ? 'Listening for speech' : 'Auto-generating') + '</span>';
      logAiChat('System', 'AI autonomous mode started (' + (useMic ? 'with microphone' : 'auto-generation') + ')');
      
      // TODO: Implement full AI On logic with WebSocket connection
      // For now, just show status
    }

    function stopAiOn() {
      ui.aiOnStatus.innerHTML = '';
      logAiChat('System', 'AI autonomous mode stopped');
    }

    function logAiChat(sender, message) {
      const log = ui.aiChatLog;
      if (!log) return;
      
      const colorClass = sender === 'System' ? 'text-warning' : sender === 'You' ? 'text-info' : 'text-success';
      const msg = document.createElement('div');
      msg.className = 'mb-2 ' + colorClass + ' small';
      msg.innerHTML = '<strong>' + sender + ':</strong> ' + message;
      log.appendChild(msg);
      log.scrollTop = log.scrollHeight;
    }

    async function loadScenes() {
      const container = $('scenesContainer');
      
      try {
        const r = await fetch('/scenes/api/');
        const j = await r.json();
        
        if (j && j.success && j.scenes && j.scenes.length > 0) {
          container.innerHTML = j.scenes.map(scene => `
            <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
              <div>
                <strong class="small">${scene.name}</strong>
                <div class="text-muted" style="font-size: 0.75rem;">${scene.description || 'No description'}</div>
              </div>
              <button class="btn btn-sm btn-primary" onclick="playScene(${scene.id})">
                <i class="bi bi-play"></i>
              </button>
            </div>
          `).join('');
        } else {
          container.innerHTML = '<div class="text-center text-muted py-2 small"><i class="bi bi-film"></i><p class="mt-2 mb-0">No scenes</p></div>';
        }
      } catch {
        container.innerHTML = '<div class="text-center text-danger py-2 small">Failed to load</div>';
      }
    }

    window.playScene = async function (sceneId) {
      try {
        const r = await fetch(`/scenes/api/${sceneId}/play`, { method: 'POST' });
        const j = await r.json();
        if (j && j.success) {
          console.log('Scene playing:', sceneId);
        } else {
          alert('Failed to play scene: ' + (j.error || 'Unknown error'));
        }
      } catch (e) {
        alert('Error playing scene: ' + e.message);
      }
    };

    async function loadAudioFiles() {
      if (!currentCharacterId) return;
      
      try {
        const r = await fetch(`/audio-library/api/library?characterId=${currentCharacterId}`);
        const j = await r.json();
        
        if (j && j.success && j.files && j.files.length > 0) {
          currentAudioFiles = j.files;
          renderAudioFiles();
        } else {
          ui.audioFileSelect.innerHTML = '<option value="">No audio files</option>';
          ui.audioFileSelect.disabled = true;
        }
      } catch (e) {
        console.error('Failed to load audio files:', e);
        ui.audioFileSelect.innerHTML = '<option value="">Error loading</option>';
        ui.audioFileSelect.disabled = true;
      }
    }

    function renderAudioFiles() {
      ui.audioFileSelect.innerHTML = '<option value="">Select audio file...</option>';
      
      currentAudioFiles.forEach(file => {
        const opt = new Option(file.title || file.filename, file.id);
        opt.setAttribute('data-filename', file.filename);
        ui.audioFileSelect.appendChild(opt);
      });
      
      ui.audioFileSelect.disabled = false;
    }

    async function playAudioFile() {
      const audioId = ui.audioFileSelect.value;
      if (!audioId) {
        ui.audioStatus.innerHTML = '<span class="text-warning">Select an audio file</span>';
        return;
      }
      
      const loop = ui.audioLoopToggle.checked;
      const selectedOption = ui.audioFileSelect.options[ui.audioFileSelect.selectedIndex];
      const filename = selectedOption.getAttribute('data-filename');
      const title = selectedOption.text;
      
      ui.audioPlayBtn.disabled = true;
      ui.audioStatus.innerHTML = '<span class="text-info">Playing...</span>';
      
      try {
        const r = await fetch(`/api/orchestration/animatronic/${currentCharacterId}/play-audio`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ audioId, loop, filename, audioTitle: title })
        });
        const j = await r.json();
        
        if (j && j.success) {
          ui.audioStatus.innerHTML = '<span class="text-success">Playing' + (loop ? ' (loop)' : '') + '</span>';
        } else {
          ui.audioStatus.innerHTML = '<span class="text-danger">Failed: ' + (j.error || 'Unknown') + '</span>';
        }
      } catch (e) {
        ui.audioStatus.innerHTML = '<span class="text-danger">Error: ' + e.message + '</span>';
      } finally {
        ui.audioPlayBtn.disabled = false;
      }
    }

    async function stopAudioFile() {
      if (!currentCharacterId) return;
      
      ui.audioStopBtn.disabled = true;
      ui.audioStatus.innerHTML = '<span class="text-info">Stopping...</span>';
      
      try {
        const r = await fetch(`/api/orchestration/animatronic/${currentCharacterId}/stop-audio`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const j = await r.json();
        
        if (j && j.success) {
          ui.audioStatus.innerHTML = '<span class="text-success">Stopped</span>';
          setTimeout(() => { ui.audioStatus.innerHTML = ''; }, 2000);
        } else {
          ui.audioStatus.innerHTML = '<span class="text-danger">Failed to stop</span>';
        }
      } catch (e) {
        ui.audioStatus.innerHTML = '<span class="text-danger">Error: ' + e.message + '</span>';
      } finally {
        ui.audioStopBtn.disabled = false;
      }
    }

    async function loadHardwareParts() {
      if (!currentCharacterId) return;
      
      try {
        const r = await fetch(`/api/parts?characterId=${currentCharacterId}`);
        const j = await r.json();
        
        if (j && j.success && j.parts && j.parts.length > 0) {
          currentParts = j.parts;
          renderHardwareParts();
        } else {
          ui.hardwareList.innerHTML = '<div class="text-muted text-center py-3 small">No hardware parts configured</div>';
          ui.hardwareCount.textContent = '0 parts';
        }
      } catch (e) {
        console.error('Failed to load hardware parts:', e);
        ui.hardwareList.innerHTML = '<div class="text-danger text-center py-3 small">Error loading parts</div>';
      }
    }

    function renderHardwareParts() {
      ui.hardwareList.innerHTML = '';
      ui.hardwareCount.textContent = currentParts.length + ' parts';
      
      currentParts.forEach(part => {
        const partDiv = document.createElement('div');
        partDiv.className = 'conv-part-control';
        partDiv.innerHTML = renderPartControl(part);
        ui.hardwareList.appendChild(partDiv);
      });
      
      // Bind control events
      bindHardwareControls();
    }

    function renderPartControl(part) {
      const type = part.type.toLowerCase();
      
      // Common header for all parts
      let html = `<div class="d-flex justify-content-between align-items-center mb-2">
        <strong class="small">${part.name}</strong>
        <span class="badge bg-secondary" style="font-size: 0.65rem;">${part.type}</span>
      </div>`;
      
      // Type-specific controls
      if (type === 'servo') {
        const isCont = part.config && part.config.servoType === 'continuous';
        if (isCont) {
          html += `<div class="d-flex gap-1">
            <button class="btn btn-sm btn-outline-primary" data-part="${part.id}" data-action="ccw">CCW</button>
            <button class="btn btn-sm btn-danger" data-part="${part.id}" data-action="stop">Stop</button>
            <button class="btn btn-sm btn-outline-primary" data-part="${part.id}" data-action="cw">CW</button>
          </div>`;
        } else {
          html += `<div class="input-group input-group-sm">
            <input type="range" class="form-range" min="0" max="180" value="90" id="servo-${part.id}" style="max-width:100px;">
            <input type="number" class="form-control" min="0" max="180" value="90" id="servo-num-${part.id}" style="max-width:60px;">
            <button class="btn btn-success" data-part="${part.id}" data-action="move">Move</button>
          </div>`;
        }
      } else if (type === 'linear_actuator') {
        html += `<div class="d-flex gap-1">
          <button class="btn btn-sm btn-primary" data-part="${part.id}" data-action="extend">Extend</button>
          <button class="btn btn-sm btn-danger" data-part="${part.id}" data-action="stop">Stop</button>
          <button class="btn btn-sm btn-primary" data-part="${part.id}" data-action="retract">Retract</button>
        </div>`;
      } else if (type === 'motor') {
        html += `<div class="d-flex gap-1">
          <select class="form-select form-select-sm" id="motor-dir-${part.id}" style="max-width:90px;">
            <option value="forward">Forward</option>
            <option value="reverse">Reverse</option>
          </select>
          <button class="btn btn-sm btn-success" data-part="${part.id}" data-action="run">Run</button>
          <button class="btn btn-sm btn-danger" data-part="${part.id}" data-action="stop">Stop</button>
        </div>`;
      } else if (type === 'stepper') {
        html += `<div class="input-group input-group-sm">
          <select class="form-select" id="stepper-dir-${part.id}" style="max-width:70px;">
            <option value="cw">CW</option>
            <option value="ccw">CCW</option>
          </select>
          <input type="number" class="form-control" value="200" id="stepper-steps-${part.id}" style="max-width:70px;">
          <button class="btn btn-success" data-part="${part.id}" data-action="move">Move</button>
        </div>`;
      } else if (type === 'light') {
        html += `<button class="btn btn-sm btn-warning w-100" data-part="${part.id}" data-action="toggle">Toggle Light</button>`;
      } else if (type === 'led') {
        html += `<div class="input-group input-group-sm">
          <input type="range" class="form-range" min="0" max="100" value="50" id="led-${part.id}">
          <button class="btn btn-success" data-part="${part.id}" data-action="set">Set</button>
        </div>`;
      } else if (type === 'speaker') {
        html += `<button class="btn btn-sm btn-success w-100" data-part="${part.id}" data-action="test">Test Speaker</button>`;
      } else if (type === 'microphone') {
        html += `<div class="d-flex gap-1">
          <div class="progress flex-fill" style="height:24px;"><div id="mic-vu-${part.id}" class="progress-bar" style="width:0%"></div></div>
          <button class="btn btn-sm btn-info" data-part="${part.id}" data-action="poll">Poll</button>
        </div>`;
      } else if (type === 'webcam') {
        html += `<button class="btn btn-sm btn-info w-100" data-part="${part.id}" data-action="snapshot">Capture Snapshot</button>`;
      } else if (type === 'motion_sensor') {
        html += `<div class="d-flex gap-1">
          <button class="btn btn-sm btn-info flex-fill" data-part="${part.id}" data-action="read">Read</button>
          <button class="btn btn-sm btn-primary flex-fill" data-part="${part.id}" data-action="detect">Detect</button>
        </div>`;
      } else if (type === 'head_tracking') {
        html += `<button class="btn btn-sm btn-info w-100" data-part="${part.id}" data-action="position">Get Position</button>`;
      } else {
        html += `<button class="btn btn-sm btn-secondary w-100" data-part="${part.id}" data-action="test">Test</button>`;
      }
      
      html += `<div class="mt-1 small text-info" id="status-${part.id}"></div>`;
      
      return html;
    }

    function bindHardwareControls() {
      // Bind all hardware control buttons
      ui.hardwareList.querySelectorAll('button[data-part]').forEach(btn => {
        btn.addEventListener('click', async () => {
          const partId = btn.getAttribute('data-part');
          const action = btn.getAttribute('data-action');
          await executeHardwareAction(partId, action);
        });
      });
      
      // Bind servo sliders
      ui.hardwareList.querySelectorAll('input[type="range"][id^="servo-"]').forEach(range => {
        const partId = range.id.split('-')[1];
        const numInput = $(`servo-num-${partId}`);
        if (numInput) {
          range.addEventListener('input', () => { numInput.value = range.value; });
          numInput.addEventListener('input', () => { range.value = numInput.value; });
        }
      });
    }

    async function executeHardwareAction(partId, action) {
      const part = currentParts.find(p => String(p.id) === String(partId));
      if (!part) return;
      
      const statusEl = $(`status-${partId}`);
      if (statusEl) statusEl.textContent = 'Processing...';
      
      try {
        const type = part.type.toLowerCase();
        let endpoint = `/api/parts/${partId}/test`;
        let body = {};
        
        // Build request based on type and action
        if (type === 'servo') {
          if (action === 'move') {
            const angle = parseInt($(`servo-num-${partId}`).value || '90', 10);
            const p = angle / 180.0;
            endpoint = `/api/calibration/${partId}/goto`;
            body = { p };
          } else if (action === 'cw' || action === 'ccw' || action === 'stop') {
            let delta = action === 'cw' ? 0.1 : action === 'ccw' ? -0.1 : 0;
            endpoint = `/api/calibration/${partId}/nudge`;
            body = { delta, speedPct: 35, durationMs: 300 };
          }
        } else if (type === 'linear_actuator') {
          if (action === 'extend') {
            endpoint = `/api/calibration/${partId}/nudge`;
            body = { delta: 0.1, speedPct: 50, durationMs: 500 };
          } else if (action === 'retract') {
            endpoint = `/api/calibration/${partId}/nudge`;
            body = { delta: -0.1, speedPct: 50, durationMs: 500 };
          } else if (action === 'stop') {
            endpoint = `/setup/calibration/api/linear_actuator/${partId}/stop`;
          }
        } else if (type === 'motor') {
          if (action === 'run') {
            const dir = $(`motor-dir-${partId}`).value;
            body = { action: 'control', params: { direction: dir, speed: 50, duration: 15000 } };
          } else if (action === 'stop') {
            body = { action: 'stop', params: {} };
          }
        } else if (type === 'stepper') {
          if (action === 'move') {
            const dir = $(`stepper-dir-${partId}`).value;
            const steps = parseInt($(`stepper-steps-${partId}`).value || '200', 10);
            body = { action: 'moveSteps', params: { direction: dir, steps, stepDelayUs: 800 } };
          }
        } else if (type === 'light') {
          body = { action: 'toggle' };
        } else if (type === 'led') {
          const brightness = parseInt($(`led-${partId}`).value || '50', 10);
          body = { action: 'setBrightness', params: { brightness } };
        } else if (type === 'speaker') {
          // Test speaker with TTS
          const r = await fetch('/api/elevenlabs/generate-and-play', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text: 'Speaker test', characterId: currentCharacterId })
          });
          const j = await r.json();
          if (statusEl) statusEl.textContent = j.success ? 'Done' : 'Failed';
          return;
        } else if (type === 'microphone') {
          const deviceId = (part.config && part.config.deviceId) || 'default';
          const r = await fetch(`/setup/audio/api/audio-levels?deviceId=${deviceId}&deviceType=input`);
          const j = await r.json();
          const level = j.success ? Math.round(j.level * 100) : 0;
          const vu = $(`mic-vu-${partId}`);
          if (vu) vu.style.width = level + '%';
          if (statusEl) statusEl.textContent = `Level: ${level}`;
          return;
        } else if (type === 'webcam') {
          body = { action: 'capture' };
        } else if (type === 'motion_sensor') {
          if (action === 'detect') {
            body = { action: 'detectMotion', params: { duration: 10 } };
          }
        } else if (type === 'head_tracking') {
          body = { action: 'getPosition' };
        } else {
          body = {};
        }
        
        const r = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const j = await r.json();
        
        if (statusEl) {
          statusEl.textContent = j.success !== false ? 'Done' : ('Failed: ' + (j.error || 'Unknown'));
          setTimeout(() => { statusEl.textContent = ''; }, 2000);
        }
      } catch (e) {
        if (statusEl) statusEl.textContent = 'Error: ' + e.message;
      }
    }

    document.addEventListener('DOMContentLoaded', init);
    window.__conv = { loadSpeakers, loadWebcam, loadScenes, loadAudioFiles, loadHardwareParts };
  })();
</script>
