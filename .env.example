# API Keys (Required to enable respective provider)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Required: Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Optional: Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional, for OpenAI/OpenRouter models. Format: sk-proj-...
GOOGLE_API_KEY="your_google_api_key_here"             # Optional, for Google Gemini models.
MISTRAL_API_KEY="your_mistral_key_here"               # Optional, for Mistral AI models.
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional, for xAI AI models.
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional, for Azure OpenAI models (requires endpoint in .taskmaster/config.json).
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: For remote Ollama servers that require authentication.

# ElevenLabs API Configuration
ELEVENLABS_API_KEY="your_elevenlabs_api_key_here"     # Required: Format: sk_...
ELEVENLABS_BASE_URL="https://api.elevenlabs.io/v1"    # ElevenLabs API base URL

# MonsterBox Audio Configuration
AUDIO_SAMPLE_RATE=44100
AUDIO_CHANNELS=1
AUDIO_FORMAT=wav

# WebSocket Configuration
WEBSOCKET_TIMEOUT=30000
WEBSOCKET_RECONNECT_ATTEMPTS=3

# Security / Operations
# Optional: if set, the destructive /api/system endpoints (reboot, shutdown,
# restart-service, optimize) require this value in an `x-mb-admin-token` header.
# If unset, those endpoints still reject cross-origin (CSRF) browser requests but
# remain available to the same-origin operator UI and on-box callers.
MB_ADMIN_TOKEN=""
# Recommended: inter-node (MonsterNet) SSH control password. Set per node and
# rotate — the previous literal was committed to git history. Prefer key-based auth.
MONSTERBOX_SSH_PASSWORD=""
# Optional: shared secret for mDNS node discovery. When set (identically on every
# node), only peers advertising a matching token hash are trusted, so a rogue LAN
# device can't inject itself into the roster. Unset = trust any MonsterBox on the LAN.
MB_NODE_TOKEN=""