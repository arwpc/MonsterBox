# MonsterBox Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=production
SESSION_SECRET=skulltalker-session-secret-2025

# API Keys
ANTHROPIC_API_KEY=sk-ant-api03-dummy-key-for-testing
OPENAI_API_KEY=sk-openai-dummy-key-for-testing
GOOGLE_API_KEY=AIza-google-dummy-key-for-testing
REPLICA_API_KEY=dummy-replica-key-for-testing
PERPLEXITY_API_KEY=pplx-dummy-key-for-testing
MISTRAL_API_KEY=dummy-mistral-key-for-testing
XAI_API_KEY=dummy-xai-key-for-testing
AZURE_OPENAI_API_KEY=dummy-azure-key-for-testing
OLLAMA_API_KEY=dummy-ollama-key-for-testing

# Hardware Configuration
HARDWARE_ENABLED=true
GPIO_ENABLED=true
I2C_ENABLED=true
AUDIO_ENABLED=true
VIDEO_ENABLED=true

# Skulltalker-specific settings
ANIMATRONIC_ID=skulltalker
ANIMATRONIC_IP=192.168.8.130
MCP_ENABLED=true
MCP_SERVER_PORT=3001
