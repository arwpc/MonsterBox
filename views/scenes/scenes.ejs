<div class="container-fluid py-4">
  <!-- Cache buster: v2.0 - 2025-10-17 -->
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-film"></i> Scenes</h1>
        <a href="/scenes/edit/new" class="btn btn-success"><i class="bi bi-plus-circle"></i> Create New Scene</a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="card mb-3">
        <div class="card-header"><i class="bi bi-list-ul"></i> Scenes</div>
        <div class="card-body">
          <div id="scenesStatus" class="mb-2"></div>
          <div id="scenesList" class="list-group"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    function setHtml(id, html) { var el = document.getElementById(id); if (el) el.innerHTML = html; }
    function alertBox(type, text) { return '<div class="alert alert-' + type + ' py-2 mb-2">' + text + '</div>'; }
    async function loadScenes() {
      setHtml('scenesStatus', '');
      try {
        var r = await fetch('/scenes/api'); var j = await r.json();
        if (!j.success) { setHtml('scenesStatus', alertBox('danger', j.error || 'Failed to load scenes')); return; }
        var list = document.getElementById('scenesList');
        if (!j.scenes || j.scenes.length === 0) { list.innerHTML = '<div class="text-muted">No scenes yet</div>'; return; }
        var html = '';
        for (var i = 0; i < j.scenes.length; i++) {
          var s = j.scenes[i];
          var stepCount = (s.steps && s.steps.length) || 0;
          html += '<div class="list-group-item">';
          html += '<div class="d-flex justify-content-between align-items-center mb-2">';
          html += '<div>';
          html += '<i class="bi bi-film"></i> <strong>' + (s.name || ('Scene ' + s.id)) + '</strong> ';
          html += '<span class="badge bg-secondary">' + stepCount + ' step' + (stepCount !== 1 ? 's' : '') + '</span>';
          html += '</div>';
          html += '<div class="btn-group btn-group-sm">';
          html += '<button class="btn btn-outline-primary" onclick="window.editScene(' + s.id + ')"><i class="bi bi-pencil"></i> Edit</button>';
          html += '<button class="btn btn-outline-success" onclick="window.playScene(' + s.id + ')"><i class="bi bi-play-fill"></i> Play</button>';
          html += '<button class="btn btn-outline-danger" onclick="window.deleteScene(' + s.id + ')"><i class="bi bi-trash"></i></button>';
          html += '</div>';
          html += '</div>';
          if (stepCount > 0) {
            html += '<div class="text-muted small">';
            html += '<i class="bi bi-list-ol"></i> Steps: ';
            var stepTypes = [];
            for (var k = 0; k < Math.min(s.steps.length, 5); k++) {
              stepTypes.push(s.steps[k].type);
            }
            html += stepTypes.join(', ');
            if (s.steps.length > 5) html += ', ...';
            html += '</div>';
          }
          html += '</div>';
        }
        list.innerHTML = html;
      } catch (e) { setHtml('scenesStatus', alertBox('danger', 'Error: ' + (e.message || e))); }
    }
    window.playScene = async function (id) {
      setHtml('scenesStatus', alertBox('info', 'Playing scene #' + id + '...'));
      try {
        var r = await fetch('/scenes/api/' + id + '/play', { method: 'POST' }); var j = await r.json();
        if (j.success) setHtml('scenesStatus', alertBox('success', 'Played scene #' + id + ' (' + j.steps + ' steps)'));
        else setHtml('scenesStatus', alertBox('danger', 'Failed: ' + (j.error || 'Unknown error')));
      } catch (e) { setHtml('scenesStatus', alertBox('danger', 'Error: ' + (e.message || e))); }
    };
    window.editScene = function (id) {
      window.location.href = '/scenes/edit/' + id;
    };
    window.deleteScene = async function (id) {
      if (!confirm('Delete scene #' + id + '?')) return;
      try {
        var r = await fetch('/scenes/api/' + id, { method: 'DELETE' }); var j = await r.json();
        if (j.success) { loadScenes(); }
        else setHtml('scenesStatus', alertBox('danger', 'Delete failed: ' + (j.error || 'Unknown')));
      } catch (e) { setHtml('scenesStatus', alertBox('danger', 'Error: ' + (e.message || e))); }
    };
    loadScenes();
  })();
</script>