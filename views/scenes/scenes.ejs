<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-film"></i> Scenes</h1>
        <span class="badge bg-secondary">MVP</span>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-6">
      <div class="card mb-3">
        <div class="card-header"><i class="bi bi-plus-circle"></i> Create Scene</div>
        <div class="card-body">
          <div id="createStatus" class="mb-2"></div>
          <div class="input-group">
            <input id="sceneName" type="text" class="form-control" placeholder="Scene name">
            <button id="createScene" class="btn btn-primary">Create</button>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card mb-3">
        <div class="card-header"><i class="bi bi-list-ul"></i> Scenes</div>
        <div class="card-body">
          <div id="scenesStatus" class="mb-2"></div>
          <div id="scenesList" class="list-group small"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    function setHtml(id, html) { var el = document.getElementById(id); if (el) el.innerHTML = html; }
    function alertBox(type, text) { return '<div class="alert alert-' + type + ' py-2 mb-2">' + text + '</div>'; }
    async function loadScenes() {
      setHtml('scenesStatus', '');
      try {
        var r = await fetch('/scenes/api'); var j = await r.json();
        if (!j.success) { setHtml('scenesStatus', alertBox('danger', j.error || 'Failed to load scenes')); return; }
        var list = document.getElementById('scenesList');
        if (!j.scenes || j.scenes.length === 0) { list.innerHTML = '<div class="text-muted">No scenes yet</div>'; return; }
        var html = '';
        for (var i = 0; i < j.scenes.length; i++) {
          var s = j.scenes[i];
          html += '<div class="list-group-item d-flex justify-content-between align-items-center">';
          html += '<div><i class="bi bi-film"></i> <strong>' + (s.name || ('Scene ' + s.id)) + '</strong> <span class="text-muted">(#' + s.id + ')</span></div>';
          html += '<div class="btn-group btn-group-sm">';
          html += '<button class="btn btn-outline-success" onclick="window.playScene(' + s.id + ')"><i class="bi bi-play-fill"></i> Play</button>';
          html += '<button class="btn btn-outline-danger" onclick="window.deleteScene(' + s.id + ')"><i class="bi bi-trash"></i></button>';
          html += '</div></div>';
        }
        list.innerHTML = html;
      } catch (e) { setHtml('scenesStatus', alertBox('danger', 'Error: ' + (e.message || e))); }
    }
    window.playScene = async function (id) {
      setHtml('scenesStatus', alertBox('info', 'Playing scene #' + id + '...'));
      try {
        var r = await fetch('/scenes/api/' + id + '/play', { method: 'POST' }); var j = await r.json();
        if (j.success) setHtml('scenesStatus', alertBox('success', 'Played scene #' + id + ' (' + j.steps + ' steps)'));
        else setHtml('scenesStatus', alertBox('danger', 'Failed: ' + (j.error || 'Unknown error')));
      } catch (e) { setHtml('scenesStatus', alertBox('danger', 'Error: ' + (e.message || e))); }
    };
    window.deleteScene = async function (id) {
      if (!confirm('Delete scene #' + id + '?')) return;
      try {
        var r = await fetch('/scenes/api/' + id, { method: 'DELETE' }); var j = await r.json();
        if (j.success) { loadScenes(); }
        else setHtml('scenesStatus', alertBox('danger', 'Delete failed: ' + (j.error || 'Unknown')));
      } catch (e) { setHtml('scenesStatus', alertBox('danger', 'Error: ' + (e.message || e))); }
    };
    document.getElementById('createScene').addEventListener('click', async function () {
      var name = document.getElementById('sceneName').value.trim();
      if (!name) { setHtml('createStatus', alertBox('warning', 'Enter a name')); return; }
      setHtml('createStatus', '');
      try {
        var r = await fetch('/scenes/api', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name, steps: [] }) }); var j = await r.json();
        if (j.success) { document.getElementById('sceneName').value = ''; loadScenes(); setHtml('createStatus', alertBox('success', 'Created scene #' + j.scene.id)); }
        else setHtml('createStatus', alertBox('danger', 'Create failed: ' + (j.error || 'Unknown')));
      } catch (e) { setHtml('createStatus', alertBox('danger', 'Error: ' + (e.message || e))); }
    });
    loadScenes();
  })();
</script>