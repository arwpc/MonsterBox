  function attachStepFormHandlers() {
    document.querySelectorAll('.sf-input').forEach(function(input) {
      input.addEventListener('change', function() {
        var idx = parseInt(this.getAttribute('data-idx'), 10);
        var field = this.getAttribute('data-field');
        var val = this.value;
        if (this.type === 'checkbox') val = this.checked;
        else if (this.type === 'number') val = parseFloat(val);
        else if (field === 'usePreset') val = (val === 'true');
        if (currentSteps[idx]) {
          currentSteps[idx][field] = val;
          // Re-render if mode changed
          if (field === 'usePreset' || field === 'partId') renderTimeline();
        }
      });
    });
  }

  function collectStepData() {
    document.querySelectorAll('.sf-input').forEach(function(input) {
      var idx = parseInt(input.getAttribute('data-idx'), 10);
      var field = input.getAttribute('data-field');
      if (isNaN(idx) || !field || !currentSteps[idx]) return;
      var val = input.value;
      if (input.type === 'checkbox') val = input.checked;
      else if (input.type === 'number') val = parseFloat(val);
      else if (field === 'usePreset') val = (val === 'true');
      currentSteps[idx][field] = val;
    });
  }

  // ============ ADD STEP ============
  function addStep(type, partId) {
    var step = { type: type };
    if (partId) step.partId = String(partId);

    // Defaults
    switch (type) {
      case 'servo': step.angle = 90; step.duration = 1000; break;
      case 'motor': step.direction = 'forward'; step.speed = 50; step.duration = 1000; break;
      case 'linear-actuator': step.direction = 'extend'; step.speed = 75; step.duration = 3000; break;
      case 'light': step.state = 'on'; step.brightness = 100; break;
      case 'wait': step.duration = 1000; break;
      case 'sensor': step.timeout = 5000; step.waitForMotion = true; break;
      case 'audio': step.volume = 80; break;
      case 'sayThis': step.text = ''; break;
      case 'askAI': step.question = ''; break;
      case 'goblin-video': step.volume = 80; break;
      case 'jaw-animation': step.action = 'enable'; break;
      case 'head-tracking': step.action = 'start'; break;
    }

    collectStepData();
    currentSteps.push(step);
    expandedStepIndex = currentSteps.length - 1;
    renderTimeline();
  }

