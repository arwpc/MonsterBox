  // ============ QUEUE ============
  function loadQueue() {
    apiGet('/scenes/api/queue').then(function(j) {
      if (!j.success) return;
      var status = j.status || {};
      var items = status.items || [];

      // Status
      if (status.running) {
        var msg = '<span class="badge bg-success">Running</span>';
        if (status.nowPlaying) msg += ' ' + escHtml(status.nowPlaying.name);
        setHtml('queueStatus', msg);
      } else {
        setHtml('queueStatus', '');
      }

      // Items
      if (items.length === 0) {
        hide('queueList');
        show('emptyQueue');
        return;
      }
      show('queueList');
      hide('emptyQueue');

      var html = '';
      items.forEach(function(it, i) {
        html += '<div class="list-group-item list-group-item-action queue-item py-1 px-2" draggable="true" data-queue-idx="' + i + '">';
        html += '<div class="d-flex justify-content-between align-items-center">';
        html += '<span style="font-size:0.8rem;"><i class="bi bi-grip-vertical"></i> ' + escHtml(it.name) + '</span>';
        html += '<button class="btn btn-sm btn-outline-danger p-0 px-1 queue-remove-btn" data-idx="' + i + '" style="font-size:0.7rem;"><i class="bi bi-x"></i></button>';
        html += '</div></div>';
      });
      setHtml('queueList', html);

      // Remove buttons
      document.querySelectorAll('.queue-remove-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          removeFromQueue(parseInt(btn.getAttribute('data-idx'), 10));
        });
      });

      // Sortable for queue
      if (window.Sortable) {
        new Sortable($('queueList'), {
          animation: 150,
          onEnd: function(evt) {
            apiPost('/scenes/api/queue/reorder', { fromIndex: evt.oldIndex, toIndex: evt.newIndex }).then(function() { loadQueue(); });
          }
        });
      }
    });
  }

  function addToQueue(sceneId) {
    apiPost('/scenes/api/queue/enqueue', { sceneId: parseInt(sceneId, 10) }).then(function(j) {
      if (j.success) { loadQueue(); setStatus('Added to queue'); }
    });
  }

  function removeFromQueue(idx) {
    apiGet('/scenes/api/queue').then(function(j) {
      if (!j.success) return;
      var items = j.status.items || [];
      return apiPost('/scenes/api/queue/clear', {}).then(function() {
        var promises = [];
        items.forEach(function(it, i) {
          if (i !== idx) promises.push(apiPost('/scenes/api/queue/enqueue', { sceneId: it.id }));
        });
        return Promise.all(promises);
      }).then(function() { loadQueue(); });
    });
  }

  // ============ MODE TOGGLES ============
  function toggleJawAnimation(enabled) {
    jawEnabled = enabled;
    renderTimeline();
    if (studioCharacterId) {
      apiGet('/setup/jaw-animation/api/jaw-animation/' + studioCharacterId).then(function(j) {
        if (j && j.success && j.config) {
          var cfg = j.config;
          cfg.enabled = enabled;
          apiPost('/setup/jaw-animation/api/jaw-animation/' + studioCharacterId, cfg).then(function(r) {
            if (r && r.success) {
              setStatus(enabled ? 'Jaw animation enabled (saved)' : 'Jaw animation disabled (saved)');
            }
          });
        }
      });
    } else {
      setStatus(enabled ? 'Jaw animation enabled' : 'Jaw animation disabled');
    }
  }

  function toggleHeadTracking(enabled) {
    headTrackEnabled = enabled;
    if (enabled) {
      show('headTrackIndicator');
    } else {
      hide('headTrackIndicator');
    }
    // Persist via scene step execution (start/stop head tracking)
    if (studioCharacterId) {
      apiPost('/scenes/api/test-step', {
        type: 'head-tracking',
        action: enabled ? 'start' : 'stop'
      }).then(function(r) {
        setStatus(enabled ? 'Head tracking started (saved)' : 'Head tracking stopped (saved)');
      });
    } else {
      setStatus(enabled ? 'Head tracking enabled' : 'Head tracking disabled');
    }
  }

  function loadSuperpowerStates() {
    if (!studioCharacterId) return;
    apiGet('/setup/jaw-animation/api/jaw-animation/' + studioCharacterId).then(function(j) {
      if (j && j.success && j.config) {
        jawEnabled = !!j.config.enabled;
        var jawToggle = $('jawToggle');
        if (jawToggle) jawToggle.checked = jawEnabled;
        renderTimeline();
      }
    }).catch(function() {});
  }

  // ============ DRAG & DROP ============
  function setupDragDrop() {
    var zone = $('addStepZone');
    if (!zone) return;

    zone.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'copy';
      zone.classList.add('drag-over');
    });
    zone.addEventListener('dragleave', function() {
      zone.classList.remove('drag-over');
    });
    zone.addEventListener('drop', function(e) {
      e.preventDefault();
      zone.classList.remove('drag-over');
      var data = e.dataTransfer.getData('text/plain') || '';
      handleDrop(data);
    });

    // Queue drop zone
    var queueList = $('queueList');
    var emptyQueue = $('emptyQueue');
    [queueList, emptyQueue].forEach(function(el) {
      if (!el) return;
      el.addEventListener('dragover', function(e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'copy';
      });
      el.addEventListener('drop', function(e) {
        e.preventDefault();
        var data = e.dataTransfer.getData('text/plain') || '';
        if (data.indexOf('scene:') === 0) {
          var sceneId = data.split(':')[1];
          addToQueue(sceneId);
        }
      });
    });
  }

  function handleDrop(data) {
    if (!currentSceneId) {
      setStatus('Select or create a scene first');
      return;
    }
    if (data.indexOf('step:') === 0) {
      var parts = data.split(':');
      var type = parts[1];
      var partId = parts[2] || null;
      addStep(type, partId);
    } else if (data.indexOf('pose:') === 0) {
      var poseId = data.split(':')[1];
      addStep('pose', null);
      currentSteps[currentSteps.length - 1].poseId = parseInt(poseId, 10);
      renderTimeline();
    }
  }

  // ============ PANEL SECTION TOGGLES ============
  function setupSectionToggles() {
    document.querySelectorAll('.panel-section-header').forEach(function(header) {
      header.addEventListener('click', function() {
        var sectionId = header.getAttribute('data-toggle-section');
        if (!sectionId) return;
        var body = $(sectionId);
        if (body) body.classList.toggle('collapsed');
        var chevron = header.querySelector('.bi-chevron-down, .bi-chevron-right');
        if (chevron) {
          chevron.classList.toggle('bi-chevron-down');
          chevron.classList.toggle('bi-chevron-right');
        }
      });
    });
  }

  // ============ EVENT BINDINGS ============
  function bindEvents() {
    // Toolbar buttons
    $('btnNewScene').addEventListener('click', createNewScene);
    $('btnNewSceneCenter').addEventListener('click', createNewScene);
    $('btnSave').addEventListener('click', saveCurrentScene);
    $('btnPlay').addEventListener('click', function() {
      if (currentSceneId) playScene(currentSceneId);
    });
    $('btnStop').addEventListener('click', function() {
      apiPost('/scenes/api/queue/stop', {}).then(function() { setStatus('Stopped'); });
    });
    $('btnEmergencyStop').addEventListener('click', function() {
      apiPost('/scenes/api/queue/emergency-stop', {}).then(function() { setStatus('EMERGENCY STOP'); loadQueue(); });
    });

    // New Pose - open Pose Editor
    $('btnNewPose').addEventListener('click', function() {
      window.location.href = '/poses/editor';
    });

    // Scene search
    $('sceneSearch').addEventListener('input', renderSceneLibrary);

    // Add step zone click
    $('addStepZone').addEventListener('click', function() {
      if (!currentSceneId) { setStatus('Create a scene first'); return; }
      var modal = new bootstrap.Modal($('addStepModal'));
      modal.show();
    });

    // Duplicate scene
    $('btnDuplicateScene').addEventListener('click', function() {
      if (!currentSceneId) return;
      apiPost('/scenes/api/' + currentSceneId + '/duplicate', {}).then(function(j) {
        if (j.success && j.scene) {
          allScenes.push(j.scene);
          renderSceneLibrary();
          loadSceneIntoEditor(j.scene.id);
          setStatus('Scene duplicated');
        }
      });
    });
    $('btnDeleteCurrentScene').addEventListener('click', function() {
      if (currentSceneId) deleteScene(currentSceneId);
    });

    // Queue buttons
    $('btnQueuePlay').addEventListener('click', function() { playQueue(false); });
    $('btnQueueLoop').addEventListener('click', function() { playQueue(true); });
    $('btnQueueStop').addEventListener('click', function() {
      apiPost('/scenes/api/queue/stop', {}).then(function() { loadQueue(); setStatus('Queue stopped'); });
    });
    $('btnQueueClear').addEventListener('click', function() {
      if (!confirm('Clear queue?')) return;
      apiPost('/scenes/api/queue/clear', {}).then(function() { loadQueue(); });
    });
    $('btnQueuePause').addEventListener('click', function() {
      apiPost('/scenes/api/queue/pause', {}).then(function() { loadQueue(); setStatus('Queue paused'); });
    });
    $('btnQueueResume').addEventListener('click', function() {
      apiPost('/scenes/api/queue/resume', {}).then(function() { loadQueue(); setStatus('Queue resumed'); });
    });
    $('btnQueueSkip').addEventListener('click', function() {
      apiPost('/scenes/api/queue/skip', {}).then(function() { loadQueue(); setStatus('Skipped'); });
    });
    $('btnSaveStory').addEventListener('click', function() {
      var name = ($('storyNameInput') || {}).value;
      if (!name) { setStatus('Enter story name'); return; }
      apiGet('/scenes/api/queue').then(function(j) {
        if (!j.success) return;
        var items = j.status.items || [];
        if (items.length === 0) { setStatus('Queue is empty'); return; }
        return apiPost('/scenes/api/queue/library', {
          name: name,
          mode: 'sequential',
          scenes: items.map(function(it) { return { scene_id: it.id }; })
        });
      }).then(function(j) {
        if (j && j.success) { setStatus('Story saved'); $('storyNameInput').value = ''; }
      });
    });

    // Webcam
    $('btnStartStream').addEventListener('click', startWebcamStream);
    $('btnStopStream').addEventListener('click', stopWebcamStream);

    // Mode toggles
    $('jawToggle').addEventListener('change', function() { toggleJawAnimation(this.checked); });
    $('headTrackToggle').addEventListener('change', function() { toggleHeadTracking(this.checked); });

    // Keyboard shortcut: Ctrl+S to save
    document.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        e.preventDefault();
        if (currentSceneId) saveCurrentScene();
      }
    });
  }

  function playQueue(loop) {
    apiGet('/scenes/api/queue').then(function(j) {
      if (!j.success) return;
      var items = j.status.items || [];
      if (items.length === 0) { setStatus('Queue is empty'); return; }
      return apiPost('/scenes/api/queue/start-config', {
        mode: loop ? 'loop_queue' : 'sequential',
        scenes: items.map(function(it) { return { scene_id: it.id }; })
      });
    }).then(function(j) {
      if (j && j.success) {
        setStatus(loop ? 'Queue looping' : 'Queue playing');
        loadQueue();
      }
    });
  }

  // ============ INITIALIZATION ============
  function init() {
    bindEvents();
    setupSectionToggles();
    setupDragDrop();
    loadAllData();
    loadSuperpowerStates();

    // Refresh queue every 2 seconds
    setInterval(loadQueue, 2000);
  }

  // Start when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
