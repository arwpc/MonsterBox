<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-pencil"></i> <span id="editorTitle">Edit Scene</span></h1>
        <a href="/scenes" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Scenes</a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header"><i class="bi bi-info-circle"></i> Scene Details</div>
        <div class="card-body">
          <div id="editorStatus" class="mb-3"></div>
          <div class="mb-3">
            <label for="sceneName" class="form-label">Scene Name</label>
            <input type="text" id="sceneName" class="form-control" placeholder="Enter scene name">
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span><i class="bi bi-list-ol"></i> Steps</span>
          <button id="addStepBtn" class="btn btn-sm btn-success"><i class="bi bi-plus-circle"></i> Add Step</button>
        </div>
        <div class="card-body">
          <div id="stepsList" class="sortable-steps">
            <div class="text-muted text-center py-4">No steps yet. Click "Add Step" to begin.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-12">
      <button id="saveSceneBtn" class="btn btn-primary btn-lg"><i class="bi bi-save"></i> Save Scene</button>
      <button id="testSceneBtn" class="btn btn-outline-success btn-lg ms-2"><i class="bi bi-play-fill"></i> Test
        Scene</button>
      <a href="/scenes" class="btn btn-outline-secondary btn-lg ms-2">Cancel</a>
    </div>
  </div>
</div>

<!-- Add Step Modal -->
<div class="modal fade" id="addStepModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Step</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-6">
            <button class="btn btn-outline-primary w-100 step-type-btn" data-type="pose">
              <i class="bi bi-person-arms-up"></i><br>Pose
            </button>
          </div>
          <div class="col-md-6">
            <button class="btn btn-outline-primary w-100 step-type-btn" data-type="audio">
              <i class="bi bi-music-note-beamed"></i><br>Audio
            </button>
          </div>
          <div class="col-md-6">
            <button class="btn btn-outline-primary w-100 step-type-btn" data-type="sayThis">
              <i class="bi bi-chat-quote"></i><br>Say This (AI Voice)
            </button>
          </div>
          <div class="col-md-6">
            <button class="btn btn-outline-primary w-100 step-type-btn" data-type="servo">
              <i class="bi bi-gear"></i><br>Servo
            </button>
          </div>
          <div class="col-md-6">
            <button class="btn btn-outline-primary w-100 step-type-btn" data-type="motor">
              <i class="bi bi-arrow-repeat"></i><br>Motor
            </button>
          </div>
          <div class="col-md-6">
            <button class="btn btn-outline-primary w-100 step-type-btn" data-type="linear-actuator">
              <i class="bi bi-arrows-expand"></i><br>Linear Actuator
            </button>
          </div>
          <div class="col-md-6">
            <button class="btn btn-outline-primary w-100 step-type-btn" data-type="light">
              <i class="bi bi-lightbulb"></i><br>Light/LED
            </button>
          </div>
          <div class="col-md-6">
            <button class="btn btn-outline-primary w-100 step-type-btn" data-type="sensor">
              <i class="bi bi-radar"></i><br>Sensor (Wait for Motion)
            </button>
          </div>
          <div class="col-md-6">
            <button class="btn btn-outline-primary w-100 step-type-btn" data-type="goblin-video">
              <i class="bi bi-display"></i><br>Goblin Video
            </button>
          </div>
          <div class="col-md-6">
            <button class="btn btn-outline-primary w-100 step-type-btn" data-type="wait">
              <i class="bi bi-hourglass-split"></i><br>Wait/Pause
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .sortable-steps {
    min-height: 100px;
  }

  .step-card {
    cursor: move;
    transition: all 0.2s;
  }

  .step-card:hover {
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
  }

  .step-card.dragging {
    opacity: 0.5;
  }

  .step-type-btn {
    padding: 1.5rem;
    font-size: 1rem;
  }

  .step-type-btn:hover {
    background-color: var(--bs-primary);
    color: white;
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
  (function () {
    let sceneId = null;
    let steps = [];
    let parts = [];
    let poses = [];
    let sounds = [];
    let goblins = [];
    let addStepModal = null;

    function setHtml(id, html) {
      const el = document.getElementById(id);
      if (el) el.innerHTML = html;
    }

    function alertBox(type, text) {
      return '<div class="alert alert-' + type + ' py-2 mb-2">' + text + '</div>';
    }

    // Initialize
    async function init() {
      // Get scene ID from URL
      const pathParts = window.location.pathname.split('/');
      sceneId = pathParts[pathParts.length - 1];

      if (sceneId === 'new') {
        sceneId = null;
        document.getElementById('editorTitle').textContent = 'Create New Scene';
      }

      // Initialize modal
      addStepModal = new bootstrap.Modal(document.getElementById('addStepModal'));

      // Load resources
      await Promise.all([
        loadParts(),
        loadPoses(),
        loadSounds(),
        loadGoblins()
      ]);

      // Load scene if editing
      if (sceneId) {
        await loadScene();
      }

      // Initialize sortable
      initSortable();

      // Event listeners
      document.getElementById('addStepBtn').addEventListener('click', () => addStepModal.show());
      document.getElementById('saveSceneBtn').addEventListener('click', saveScene);
      document.getElementById('testSceneBtn').addEventListener('click', testScene);

      // Step type button listeners
      document.querySelectorAll('.step-type-btn').forEach(btn => {
        btn.addEventListener('click', function () {
          const type = this.getAttribute('data-type');
          addStep(type);
          addStepModal.hide();
        });
      });
    }

    async function loadParts() {
      try {
        const r = await fetch('/api/parts');
        const j = await r.json();
        parts = j.parts || [];
      } catch (e) {
        console.error('Failed to load parts:', e);
        parts = [];
      }
    }

    async function loadPoses() {
      try {
        const r = await fetch('/api/poses');
        const j = await r.json();
        poses = j.poses || [];
      } catch (e) {
        console.error('Failed to load poses:', e);
        poses = [];
      }
    }

    async function loadSounds() {
      try {
        const r = await fetch('/api/sounds');
        const j = await r.json();
        sounds = j.sounds || [];
      } catch (e) {
        console.error('Failed to load sounds:', e);
        sounds = [];
      }
    }

    async function loadGoblins() {
      try {
        const r = await fetch('/api/goblins');
        const j = await r.json();
        goblins = j.goblins || [];
      } catch (e) {
        console.error('Failed to load goblins:', e);
        goblins = [];
      }
    }

    async function loadScene() {
      try {
        const r = await fetch('/scenes/api/' + sceneId);
        const j = await r.json();
        if (!j.success) {
          setHtml('editorStatus', alertBox('danger', 'Failed to load scene: ' + (j.error || 'Unknown error')));
          return;
        }
        const scene = j.scene;
        if (!scene) {
          setHtml('editorStatus', alertBox('danger', 'Scene not found'));
          return;
        }
        document.getElementById('sceneName').value = scene.name || '';
        steps = scene.steps || [];
        renderSteps();
      } catch (e) {
        setHtml('editorStatus', alertBox('danger', 'Error loading scene: ' + (e.message || e)));
      }
    }

    function initSortable() {
      const el = document.getElementById('stepsList');
      new Sortable(el, {
        animation: 150,
        handle: '.step-card',
        ghostClass: 'dragging',
        onEnd: function () {
          updateStepsFromDOM();
        }
      });
    }

    function addStep(type) {
      const step = { type: type };
      steps.push(step);
      renderSteps();
    }

    function removeStep(index) {
      if (confirm('Remove this step?')) {
        steps.splice(index, 1);
        renderSteps();
      }
    }

    function duplicateStep(index) {
      const copy = JSON.parse(JSON.stringify(steps[index]));
      steps.splice(index + 1, 0, copy);
      renderSteps();
    }

    async function playStep(index) {
      const step = steps[index];
      if (!step) {
        alert('Step not found');
        return;
      }

      const btn = document.querySelector(`.btn-play-step[data-index="${index}"]`);
      const originalHtml = btn.innerHTML;

      try {
        // Disable button and show loading state
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

        // Call the test-step API
        const response = await fetch('/scenes/api/test-step', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(step)
        });

        const data = await response.json();

        if (data.success) {
          // Show success feedback
          btn.innerHTML = '<i class="bi bi-check-circle-fill"></i>';
          btn.classList.remove('btn-outline-success');
          btn.classList.add('btn-success');

          // Reset button after 2 seconds
          setTimeout(() => {
            btn.innerHTML = originalHtml;
            btn.classList.remove('btn-success');
            btn.classList.add('btn-outline-success');
            btn.disabled = false;
          }, 2000);
        } else {
          // Show error feedback
          btn.innerHTML = '<i class="bi bi-x-circle-fill"></i>';
          btn.classList.remove('btn-outline-success');
          btn.classList.add('btn-danger');
          alert('Step test failed: ' + (data.error || 'Unknown error'));

          // Reset button after 2 seconds
          setTimeout(() => {
            btn.innerHTML = originalHtml;
            btn.classList.remove('btn-danger');
            btn.classList.add('btn-outline-success');
            btn.disabled = false;
          }, 2000);
        }
      } catch (error) {
        console.error('Error testing step:', error);
        alert('Error testing step: ' + error.message);

        // Reset button
        btn.innerHTML = originalHtml;
        btn.disabled = false;
      }
    }

    function updateStepsFromDOM() {
      const newSteps = [];
      document.querySelectorAll('.step-card').forEach((card, index) => {
        const stepIndex = parseInt(card.getAttribute('data-index'));
        if (!isNaN(stepIndex) && steps[stepIndex]) {
          newSteps.push(steps[stepIndex]);
        }
      });
      steps = newSteps;
      renderSteps();
    }

    function renderSteps() {
      const container = document.getElementById('stepsList');
      if (steps.length === 0) {
        container.innerHTML = '<div class="text-muted text-center py-4">No steps yet. Click "Add Step" to begin.</div>';
        return;
      }

      let html = '';
      steps.forEach((step, index) => {
        html += renderStepCard(step, index);
      });
      container.innerHTML = html;

      // Attach event listeners
      attachStepEventListeners();
    }

    function renderStepCard(step, index) {
      const stepNum = index + 1;
      let html = '<div class="card step-card mb-3" data-index="' + index + '">';
      html += '<div class="card-header">';
      html += '<div class="d-flex justify-content-between align-items-center">';
      html += '<h6 class="mb-0"><i class="bi bi-grip-vertical"></i> Step ' + stepNum + ': ' + getStepTypeName(step.type) + '</h6>';
      html += '<div class="btn-group btn-group-sm">';
      html += '<button class="btn btn-outline-success btn-play-step" data-index="' + index + '" title="Test Step"><i class="bi bi-play-fill"></i></button>';
      html += '<button class="btn btn-outline-secondary btn-duplicate" data-index="' + index + '" title="Duplicate Step"><i class="bi bi-files"></i></button>';
      html += '<button class="btn btn-outline-danger btn-remove" data-index="' + index + '" title="Remove Step"><i class="bi bi-trash"></i></button>';
      html += '</div></div></div>';
      html += '<div class="card-body">';
      html += renderStepForm(step, index);
      html += '</div></div>';
      return html;
    }

    function getStepTypeName(type) {
      const names = {
        'pose': 'Pose',
        'audio': 'Audio',
        'sayThis': 'Say This (AI Voice)',
        'servo': 'Servo',
        'motor': 'Motor',
        'linear-actuator': 'Linear Actuator',
        'light': 'Light/LED',
        'sensor': 'Sensor',
        'goblin-video': 'Goblin Video',
        'wait': 'Wait/Pause',
        'part': 'Part Control (Legacy)'
      };
      return names[type] || type;
    }

    function renderStepForm(step, index) {
      switch (step.type) {
        case 'pose': return renderPoseForm(step, index);
        case 'audio': return renderAudioForm(step, index);
        case 'sayThis': return renderSayThisForm(step, index);
        case 'servo': return renderServoForm(step, index);
        case 'motor': return renderMotorForm(step, index);
        case 'linear-actuator': return renderLinearActuatorForm(step, index);
        case 'light': return renderLightForm(step, index);
        case 'sensor': return renderSensorForm(step, index);
        case 'goblin-video': return renderGoblinVideoForm(step, index);
        case 'wait': return renderWaitForm(step, index);
        case 'part': return renderPartForm(step, index);
        default: return '<div class="alert alert-warning mb-0"><small>Unknown step type: ' + step.type + '</small></div>';
      }
    }

    function renderPoseForm(step, index) {
      let html = '<div class="row g-3">';
      html += '<div class="col-md-12">';
      html += '<label class="form-label">Pose</label>';
      html += '<select class="form-select step-input" data-index="' + index + '" data-field="poseId">';
      html += '<option value="">Select a pose...</option>';
      poses.forEach(p => {
        const sel = (step.poseId == p.id) ? ' selected' : '';
        html += '<option value="' + p.id + '"' + sel + '>' + (p.name || 'Pose ' + p.id) + '</option>';
      });
      html += '</select></div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
      html += '<input class="form-check-input step-input" type="checkbox" data-index="' + index + '" data-field="concurrent" id="concurrent' + index + '"' + (step.concurrent ? ' checked' : '') + '>';
      html += '<label class="form-check-label" for="concurrent' + index + '">Run concurrently with next step</label>';
      html += '</div></div></div>';
      return html;
    }

    function renderAudioForm(step, index) {
      let html = '<div class="row g-3">';
      html += '<div class="col-md-8">';
      html += '<label class="form-label">Audio File</label>';
      html += '<select class="form-select step-input" data-index="' + index + '" data-field="audioId">';
      html += '<option value="">Select audio...</option>';
      sounds.forEach(s => {
        const sel = (step.audioId == s.id || step.audioId == s.filename) ? ' selected' : '';
        html += '<option value="' + (s.filename || s.id) + '"' + sel + '>' + (s.name || s.filename) + '</option>';
      });
      html += '</select></div>';
      html += '<div class="col-md-4">';
      html += '<label class="form-label">Volume (%)</label>';
      html += '<input type="number" class="form-control step-input" data-index="' + index + '" data-field="volume" value="' + (step.volume || 80) + '" min="0" max="100">';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
      html += '<input class="form-check-input step-input" type="checkbox" data-index="' + index + '" data-field="concurrent" id="concurrent' + index + '"' + (step.concurrent ? ' checked' : '') + '>';
      html += '<label class="form-check-label" for="concurrent' + index + '">Run concurrently with next step</label>';
      html += '</div></div></div>';
      return html;
    }

    function renderSayThisForm(step, index) {
      let html = '<div class="row g-3">';
      html += '<div class="col-md-12">';
      html += '<label class="form-label">Text to Speak</label>';
      html += '<textarea class="form-control step-input" data-index="' + index + '" data-field="text" rows="2" placeholder="Enter text for AI to speak...">' + (step.text || '') + '</textarea>';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<button class="btn btn-sm btn-outline-primary btn-preview-voice" data-index="' + index + '"><i class="bi bi-play-circle"></i> Preview Voice</button>';
      html += '<span class="ms-2 text-muted voice-preview-status" id="voiceStatus' + index + '"></span>';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
      html += '<input class="form-check-input step-input" type="checkbox" data-index="' + index + '" data-field="concurrent" id="concurrent' + index + '"' + (step.concurrent ? ' checked' : '') + '>';
      html += '<label class="form-check-label" for="concurrent' + index + '">Run concurrently with next step</label>';
      html += '</div></div></div>';
      return html;
    }

    function renderServoForm(step, index) {
      const servoParts = parts.filter(p => p.type === 'servo');
      let html = '<div class="row g-3">';
      html += '<div class="col-md-6">';
      html += '<label class="form-label">Servo Part</label>';
      html += '<select class="form-select step-input" data-index="' + index + '" data-field="partId">';
      html += '<option value="">Select servo...</option>';
      servoParts.forEach(p => {
        const sel = (step.partId == p.id) ? ' selected' : '';
        html += '<option value="' + p.id + '"' + sel + '>' + p.name + '</option>';
      });
      html += '</select></div>';
      html += '<div class="col-md-3">';
      html += '<label class="form-label">Angle (°)</label>';
      html += '<input type="number" class="form-control step-input" data-index="' + index + '" data-field="angle" value="' + (step.angle || 90) + '" min="0" max="180">';
      html += '</div>';
      html += '<div class="col-md-3">';
      html += '<label class="form-label">Duration (ms)</label>';
      html += '<input type="number" class="form-control step-input" data-index="' + index + '" data-field="duration" value="' + (step.duration || 1000) + '" min="0">';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
      html += '<input class="form-check-input step-input" type="checkbox" data-index="' + index + '" data-field="concurrent" id="concurrent' + index + '"' + (step.concurrent ? ' checked' : '') + '>';
      html += '<label class="form-check-label" for="concurrent' + index + '">Run concurrently with next step</label>';
      html += '</div></div></div>';
      return html;
    }

    function renderMotorForm(step, index) {
      const motorParts = parts.filter(p => p.type === 'motor');
      let html = '<div class="row g-3">';
      html += '<div class="col-md-6">';
      html += '<label class="form-label">Motor Part</label>';
      html += '<select class="form-select step-input" data-index="' + index + '" data-field="partId">';
      html += '<option value="">Select motor...</option>';
      motorParts.forEach(p => {
        const sel = (step.partId == p.id) ? ' selected' : '';
        html += '<option value="' + p.id + '"' + sel + '>' + p.name + '</option>';
      });
      html += '</select></div>';
      html += '<div class="col-md-3">';
      html += '<label class="form-label">Direction</label>';
      html += '<select class="form-select step-input" data-index="' + index + '" data-field="direction">';
      html += '<option value="forward"' + (step.direction === 'forward' ? ' selected' : '') + '>Forward</option>';
      html += '<option value="backward"' + (step.direction === 'backward' ? ' selected' : '') + '>Backward</option>';
      html += '</select></div>';
      html += '<div class="col-md-3">';
      html += '<label class="form-label">Speed (%)</label>';
      html += '<input type="number" class="form-control step-input" data-index="' + index + '" data-field="speed" value="' + (step.speed || 50) + '" min="0" max="100">';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<label class="form-label">Duration (ms)</label>';
      html += '<input type="number" class="form-control step-input" data-index="' + index + '" data-field="duration" value="' + (step.duration || 1000) + '" min="0">';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
      html += '<input class="form-check-input step-input" type="checkbox" data-index="' + index + '" data-field="concurrent" id="concurrent' + index + '"' + (step.concurrent ? ' checked' : '') + '>';
      html += '<label class="form-check-label" for="concurrent' + index + '">Run concurrently with next step</label>';
      html += '</div></div></div>';
      return html;
    }

    function renderLinearActuatorForm(step, index) {
      const actuatorParts = parts.filter(p => p.type === 'linear_actuator');
      let html = '<div class="row g-3">';
      html += '<div class="col-md-6">';
      html += '<label class="form-label">Linear Actuator Part</label>';
      html += '<select class="form-select step-input" data-index="' + index + '" data-field="partId">';
      html += '<option value="">Select actuator...</option>';
      actuatorParts.forEach(p => {
        const sel = (step.partId == p.id) ? ' selected' : '';
        html += '<option value="' + p.id + '"' + sel + '>' + p.name + '</option>';
      });
      html += '</select></div>';
      html += '<div class="col-md-3">';
      html += '<label class="form-label">Direction</label>';
      html += '<select class="form-select step-input" data-index="' + index + '" data-field="direction">';
      html += '<option value="extend"' + (step.direction === 'extend' ? ' selected' : '') + '>Extend</option>';
      html += '<option value="retract"' + (step.direction === 'retract' ? ' selected' : '') + '>Retract</option>';
      html += '</select></div>';
      html += '<div class="col-md-3">';
      html += '<label class="form-label">Speed (%)</label>';
      html += '<input type="number" class="form-control step-input" data-index="' + index + '" data-field="speed" value="' + (step.speed || 75) + '" min="0" max="100">';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<label class="form-label">Duration (ms)</label>';
      html += '<input type="number" class="form-control step-input" data-index="' + index + '" data-field="duration" value="' + (step.duration || 3000) + '" min="0">';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
      html += '<input class="form-check-input step-input" type="checkbox" data-index="' + index + '" data-field="concurrent" id="concurrent' + index + '"' + (step.concurrent ? ' checked' : '') + '>';
      html += '<label class="form-check-label" for="concurrent' + index + '">Run concurrently with next step</label>';
      html += '</div></div></div>';
      return html;
    }

    function renderLightForm(step, index) {
      const lightParts = parts.filter(p => p.type === 'light' || p.type === 'led');
      let html = '<div class="row g-3">';
      html += '<div class="col-md-6">';
      html += '<label class="form-label">Light/LED Part</label>';
      html += '<select class="form-select step-input" data-index="' + index + '" data-field="partId">';
      html += '<option value="">Select light...</option>';
      lightParts.forEach(p => {
        const sel = (step.partId == p.id) ? ' selected' : '';
        html += '<option value="' + p.id + '"' + sel + '>' + p.name + '</option>';
      });
      html += '</select></div>';
      html += '<div class="col-md-3">';
      html += '<label class="form-label">State</label>';
