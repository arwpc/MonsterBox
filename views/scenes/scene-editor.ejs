    function renderWaitForm(step, index) {
      let html = '<div class="row g-3">';
      html += '<div class="col-md-12">';
      html += '<label class="form-label">Duration (milliseconds)</label>';
      html += '<input type="number" class="form-control step-input" data-index="' + index + '" data-field="duration" value="' + (step.duration || 1000) + '" min="0">';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="alert alert-secondary py-2 mb-0"><small>' + ((step.duration || 1000) / 1000).toFixed(1) + ' seconds</small></div>';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
