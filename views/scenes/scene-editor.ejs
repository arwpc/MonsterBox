    function attachStepEventListeners() {
      // Remove step buttons
      document.querySelectorAll('.btn-remove').forEach(btn => {
        btn.addEventListener('click', function () {
          const index = parseInt(this.getAttribute('data-index'));
          removeStep(index);
        });
      });

      // Play step buttons
      document.querySelectorAll('.btn-play-step').forEach(btn => {
        btn.addEventListener('click', function () {
          const index = parseInt(this.getAttribute('data-index'));
          playStep(index);
        });
      });

      // Duplicate step buttons
      document.querySelectorAll('.btn-duplicate').forEach(btn => {
        btn.addEventListener('click', function () {
          const index = parseInt(this.getAttribute('data-index'));
          duplicateStep(index);
        });
      });

      // Step input changes
      document.querySelectorAll('.step-input').forEach(input => {
        input.addEventListener('change', function () {
          const index = parseInt(this.getAttribute('data-index'));
          const field = this.getAttribute('data-field');
          let value = this.value;

          if (this.type === 'number') {
            value = parseFloat(value);
          } else if (this.type === 'checkbox') {
            value = this.checked;
          } else if (field === 'params') {
            // Parse JSON for params field
            try {
              value = value.trim() ? JSON.parse(value) : {};
            } catch (e) {
              console.error('Invalid JSON in params field:', e);
              value = {};
            }
          }

          if (!steps[index]) steps[index] = {};
          steps[index][field] = value;
        });
      });

      // Load goblin videos when goblin is selected
      document.querySelectorAll('.goblin-selector').forEach(select => {
        select.addEventListener('change', async function () {
          const index = parseInt(this.getAttribute('data-index'));
          const goblinId = this.value;
          const videoDropdown = document.querySelector(`.video-dropdown[data-goblin-index="${index}"]`);

          if (!videoDropdown) return;

          // Clear existing options except first
          videoDropdown.innerHTML = '<option value="">Loading videos...</option>';

          if (!goblinId) {
            videoDropdown.innerHTML = '<option value="">Select goblin first</option>';
            return;
          }

          try {
            const response = await fetch(`/goblin-management/api/goblins/${goblinId}/videos`);
            const data = await response.json();

            if (data.success && data.videos) {
              videoDropdown.innerHTML = '<option value="">Select video...</option>';
              data.videos.forEach(video => {
                const option = document.createElement('option');
                option.value = video.filename;
                option.textContent = video.filename;
                // Pre-select if this was the saved value
                if (steps[index] && steps[index].videoId === video.filename) {
                  option.selected = true;
                }
                videoDropdown.appendChild(option);
              });
            } else {
              videoDropdown.innerHTML = '<option value="">No videos found</option>';
            }
          } catch (error) {
            console.error('Error loading goblin videos:', error);
            videoDropdown.innerHTML = '<option value="">Error loading videos</option>';
          }
        });

        // Trigger load if goblin is already selected (editing existing scene)
        if (select.value) {
          select.dispatchEvent(new Event('change'));
        }
      });

      // Voice preview buttons
      document.querySelectorAll('.btn-preview-voice').forEach(btn => {
        btn.addEventListener('click', async function () {
          const index = parseInt(this.getAttribute('data-index'));
          await previewVoice(index);
        });
      });
    }

    async function previewVoice(index) {
      const step = steps[index];
      const text = step.text;
      const statusEl = document.getElementById('voiceStatus' + index);

      if (!text) {
        statusEl.textContent = 'Please enter text first';
        return;
      }

      statusEl.textContent = 'Generating voice...';

      try {
        const r = await fetch('/api/tts/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: text })
        });
        const j = await r.json();

        if (j.success && j.audioUrl) {
          statusEl.textContent = 'Playing preview...';
          const audio = new Audio(j.audioUrl);
          audio.play();
          audio.onended = () => {
            statusEl.textContent = 'Preview complete';
          };
        } else {
          statusEl.textContent = 'Failed: ' + (j.error || 'Unknown error');
        }
      } catch (e) {
        statusEl.textContent = 'Error: ' + (e.message || e);
      }
    }

    async function saveScene() {
      const name = document.getElementById('sceneName').value.trim();
      if (!name) {
        setHtml('editorStatus', alertBox('warning', 'Please enter a scene name'));
        return;
      }

      setHtml('editorStatus', alertBox('info', 'Saving scene...'));

      try {
        const sceneData = { name: name, steps: steps };
        let url, method;

        if (sceneId) {
          url = '/scenes/api/' + sceneId;
          method = 'PUT';
        } else {
          url = '/scenes/api';
          method = 'POST';
        }

        const r = await fetch(url, {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(sceneData)
        });
        const j = await r.json();

        if (j.success) {
          setHtml('editorStatus', alertBox('success', 'Scene saved successfully!'));
          setTimeout(() => {
            window.location.href = '/scenes';
          }, 1000);
        } else {
          setHtml('editorStatus', alertBox('danger', 'Save failed: ' + (j.error || 'Unknown error')));
        }
      } catch (e) {
        setHtml('editorStatus', alertBox('danger', 'Error saving scene: ' + (e.message || e)));
      }
    }

    async function testScene() {
      const name = document.getElementById('sceneName').value.trim();
      if (!name) {
        setHtml('editorStatus', alertBox('warning', 'Please enter a scene name first'));
        return;
      }

      setHtml('editorStatus', alertBox('info', 'Testing scene...'));

      try {
        // Save first if editing
        if (sceneId) {
          await saveScene();
          await new Promise(r => setTimeout(r, 500));
        }

        const r = await fetch('/scenes/api/' + (sceneId || 'test') + '/play?dryRun=true', {
          method: 'POST'
        });
        const j = await r.json();

        if (j.success) {
          setHtml('editorStatus', alertBox('success', 'Test complete! Executed ' + j.steps + ' steps (dry run)'));
        } else {
          setHtml('editorStatus', alertBox('danger', 'Test failed: ' + (j.error || 'Unknown error')));
        }
      } catch (e) {
        setHtml('editorStatus', alertBox('danger', 'Error testing scene: ' + (e.message || e)));
      }
    }

    // Handle control mode change between Manual Control and Position Preset
    function handleModeChange(index, stepType) {
      const step = steps[index];
      const modeSelect = document.querySelector(`[data-index="${index}"][data-field="usePreset"]`);
      const usePreset = modeSelect.value === 'true';
      
      // Update step data
      step.usePreset = usePreset;
      if (usePreset) {
        step.presetName = '__MIN__'; // Default to Min position
      } else {
        delete step.presetName;
      }
      
      // Re-render the form
      renderSteps();
    }

    // Handle part selection change - update presets dropdown
    function handlePartChange(index, stepType) {
      const step = steps[index];
      const partSelect = document.querySelector(`[data-index="${index}"][data-field="partId"]`);
      step.partId = parseInt(partSelect.value);
      
      // If using preset mode, re-render to update preset dropdown
      if (step.usePreset) {
        renderSteps();
      }
    }

    // Expose functions to window scope for inline event handlers
    window.handleModeChange = handleModeChange;
    window.handlePartChange = handlePartChange;

    window.addEventListener('DOMContentLoaded', init);
  })();
</script>