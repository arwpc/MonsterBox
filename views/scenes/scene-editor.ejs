<div class="mb-cluster-animation container-fluid py-3">

  <header class="mb-page-header">
    <h1 class="mb-page-header-title">
      <i class="bi bi-pencil"></i> <span id="editorTitle">Edit Scene</span>
    </h1>
    <div class="mb-page-header-actions">
      <a href="/scenes" class="mb-btn mb-btn-secondary" title="Back to scenes list">
        <i class="bi bi-arrow-left"></i> Back to Scenes
      </a>
    </div>
  </header>

  <div class="mb-panel mb-panel-accent" style="margin-bottom: var(--mb-space-4);">
    <div class="mb-panel-header">
      <h2 class="mb-panel-title"><i class="bi bi-info-circle"></i> Scene Details</h2>
    </div>
    <div class="mb-panel-body">
      <div id="editorStatus" style="margin-bottom: var(--mb-space-3);"></div>
      <div class="mb-field">
        <label for="sceneName" class="mb-field-label">Scene Name</label>
        <input type="text" id="sceneName" class="mb-input" placeholder="Enter scene name" title="Scene name">
      </div>
    </div>
  </div>

  <div class="mb-panel mb-panel-accent-ai" style="margin-bottom: var(--mb-space-4);">
    <div class="mb-panel-header">
      <h2 class="mb-panel-title"><i class="bi bi-list-ol"></i> Steps</h2>
      <button id="addStepBtn" class="mb-btn mb-btn-primary mb-btn-sm" title="Add a step to the scene">
        <i class="bi bi-plus-circle"></i> Add Step
      </button>
    </div>
    <div class="mb-panel-body">
      <div id="stepsList" class="sortable-steps" style="min-height: 100px;">
        <div class="mb-empty">
          <i class="bi bi-list-ol mb-empty-icon"></i>
          <h3 class="mb-empty-title">No steps yet</h3>
          <p class="mb-empty-body">Click "Add Step" to begin building this scene.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mb-row" style="gap: var(--mb-space-2); margin-top: var(--mb-space-4);">
    <button id="saveSceneBtn" class="mb-btn mb-btn-primary mb-btn-lg" title="Save this scene">
      <i class="bi bi-save"></i> Save Scene
    </button>
    <button id="testSceneBtn" class="mb-btn mb-btn-ai mb-btn-lg" title="Test play this scene">
      <i class="bi bi-play-fill"></i> Test Scene
    </button>
    <a href="/scenes" class="mb-btn mb-btn-secondary mb-btn-lg" title="Cancel and return to scenes">Cancel</a>
  </div>
</div>

<!-- Add Step Modal -->
<div class="mb-cluster-animation modal fade" id="addStepModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Add Step</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" title="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-eyebrow" style="margin-bottom: var(--mb-space-3);">Actions</div>
        <div class="row g-3" style="margin-bottom: var(--mb-space-5);">
          <div class="col-md-6">
            <button class="mb-btn mb-btn-secondary step-action-btn" data-type="pose" title="Add a pose step" style="width:100%; padding: var(--mb-space-5); flex-direction: column;">
              <i class="bi bi-person-arms-up"></i><span>Pose</span>
            </button>
          </div>
          <div class="col-md-6">
            <button class="mb-btn mb-btn-secondary step-action-btn" data-type="audio" title="Add an audio step" style="width:100%; padding: var(--mb-space-5); flex-direction: column;">
              <i class="bi bi-music-note-beamed"></i><span>Audio</span>
            </button>
          </div>
          <div class="col-md-6">
            <button class="mb-btn mb-btn-secondary step-action-btn" data-type="sayThis" title="Add a Say This AI voice step" style="width:100%; padding: var(--mb-space-5); flex-direction: column;">
              <i class="bi bi-chat-quote"></i><span>Say This (AI Voice)</span>
            </button>
          </div>
          <div class="col-md-6">
            <button class="mb-btn mb-btn-secondary step-action-btn" data-type="askAI" title="Add an Ask AI step" style="width:100%; padding: var(--mb-space-5); flex-direction: column;">
              <i class="bi bi-question-circle"></i><span>Ask AI a Question</span>
            </button>
          </div>
          <div class="col-md-6">
            <button class="mb-btn mb-btn-secondary step-action-btn" data-type="goblin-video" title="Add a Goblin video step" style="width:100%; padding: var(--mb-space-5); flex-direction: column;">
              <i class="bi bi-display"></i><span>Goblin Video</span>
            </button>
          </div>
          <div class="col-md-6">
            <button class="mb-btn mb-btn-secondary step-action-btn" data-type="wait" title="Add a wait or pause step" style="width:100%; padding: var(--mb-space-5); flex-direction: column;">
              <i class="bi bi-hourglass-split"></i><span>Wait / Pause</span>
            </button>
          </div>
          <div class="col-md-6">
            <button class="mb-btn mb-btn-secondary step-action-btn" data-type="sensor" title="Add a sensor motion-wait step" style="width:100%; padding: var(--mb-space-5); flex-direction: column;">
              <i class="bi bi-radar"></i><span>Sensor (Wait for Motion)</span>
            </button>
          </div>
        </div>

        <div class="mb-eyebrow" style="margin-bottom: var(--mb-space-3);">Character Parts</div>
        <div id="partsStepContainer" class="row g-3">
          <div class="col-12 mb-text-muted" style="text-align:center; padding: var(--mb-space-4);">
            <i class="bi bi-hourglass-split"></i> Loading parts…
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
  (function () {
    let sceneId = null;
    let steps = [];
    let parts = [];
    let calibrationProfiles = {};
    let poses = [];
    let sounds = [];
    let goblins = [];
    let addStepModal = null;

    function setHtml(id, html) {
      const el = document.getElementById(id);
      if (el) el.innerHTML = html;
    }

    function alertBox(type, text) {
      return '<div class="alert alert-' + type + ' py-2 mb-2">' + text + '</div>';
    }

    // Initialize
    async function init() {
      // Get scene ID from URL
      const pathParts = window.location.pathname.split('/');
      sceneId = pathParts[pathParts.length - 1];

      if (sceneId === 'new') {
        sceneId = null;
        document.getElementById('editorTitle').textContent = 'Create New Scene';
      }

      // Initialize modal
      addStepModal = new bootstrap.Modal(document.getElementById('addStepModal'));

      // Load resources
      await Promise.all([
        loadParts(),
        loadCalibrationProfiles(),
        loadPoses(),
        loadSounds(),
        loadGoblins()
      ]);

      // Load scene if editing
      if (sceneId) {
        await loadScene();
      }

      // Initialize sortable
      initSortable();

      // Event listeners
      document.getElementById('addStepBtn').addEventListener('click', () => addStepModal.show());
      document.getElementById('saveSceneBtn').addEventListener('click', saveScene);
      document.getElementById('testSceneBtn').addEventListener('click', testScene);

      // Step action button listeners (for non-part steps)
      document.querySelectorAll('.step-action-btn').forEach(btn => {
        btn.addEventListener('click', function () {
          const type = this.getAttribute('data-type');
          addStep(type);
          addStepModal.hide();
        });
      });
    }

    async function loadParts() {
      try {
        const r = await fetch('/api/parts');
        const j = await r.json();
        parts = j.parts || [];
        populatePartsModal();
      } catch (e) {
        console.error('Failed to load parts:', e);
        parts = [];
        populatePartsModal();
      }
    }

    async function loadCalibrationProfiles() {
      try {
        const r = await fetch('/api/calibration/profiles');
        const j = await r.json();
        calibrationProfiles = j || {};
      } catch (e) {
        console.error('Failed to load calibration profiles:', e);
        calibrationProfiles = {};
      }
    }

    function populatePartsModal() {
      const container = document.getElementById('partsStepContainer');
      if (!container) return;

      // Filter only enabled hardware parts (exclude speakers, microphones, webcams)
      const hardwareParts = parts.filter(p =>
        p.enabled &&
        (p.type === 'servo' || p.type === 'motor' || p.type === 'linear_actuator' ||
          p.type === 'light' || p.type === 'led' || p.type === 'motion_sensor' || p.type === 'sensor')
      );

      if (hardwareParts.length === 0) {
        container.innerHTML = '<div class="col-12 text-center text-muted py-3"><i class="bi bi-info-circle"></i> No hardware parts configured for this character.</div>';
        return;
      }

      // Group parts by type
      const grouped = {
        'servo': [],
        'motor': [],
        'linear_actuator': [],
        'light': [],
        'sensor': []
      };

      hardwareParts.forEach(p => {
        const type = p.type === 'led' ? 'light' : (p.type === 'motion_sensor' ? 'sensor' : p.type);
        if (grouped[type]) {
          grouped[type].push(p);
        }
      });

      // Type metadata
      const typeInfo = {
        'servo': { icon: 'bi-gear', label: 'Servos' },
        'motor': { icon: 'bi-arrow-repeat', label: 'Motors' },
        'linear_actuator': { icon: 'bi-arrows-expand', label: 'Linear Actuators' },
        'light': { icon: 'bi-lightbulb', label: 'Lights/LEDs' },
        'sensor': { icon: 'bi-radar', label: 'Sensors' }
      };

      let html = '';
      Object.keys(grouped).forEach(type => {
        if (grouped[type].length > 0) {
          const info = typeInfo[type];
          grouped[type].forEach(part => {
            html += '<div class="col-md-6">';
            html += '<button class="btn btn-outline-success w-100 step-type-btn" title="Add ' + part.name + ' as a scene step" data-type="' + type + '" data-part-id="' + part.id + '" data-part-name="' + part.name + '">';
            html += '<i class="bi ' + info.icon + '"></i><br>';
            html += '<strong>' + part.name + '</strong>';
            html += '<br><small class="text-muted">' + info.label.slice(0, -1) + '</small>';
            html += '</button>';
            html += '</div>';
          });
        }
      });

      container.innerHTML = html;

      // Attach event listeners to new part buttons
      container.querySelectorAll('.step-type-btn').forEach(btn => {
        btn.addEventListener('click', function () {
          const type = this.getAttribute('data-type');
          const partId = this.getAttribute('data-part-id');
          addStepWithPart(type, partId);
          addStepModal.hide();
        });
      });
    }

    async function loadPoses() {
      try {
        const r = await fetch('/api/poses');
        const j = await r.json();
        poses = j.poses || [];
      } catch (e) {
        console.error('Failed to load poses:', e);
        poses = [];
      }
    }

    async function loadSounds() {
      try {
        const r = await fetch('/api/sounds');
        const j = await r.json();
        sounds = j.sounds || [];
      } catch (e) {
        console.error('Failed to load sounds:', e);
        sounds = [];
      }
    }

    async function loadGoblins() {
      try {
        const r = await fetch('/api/goblins');
        const j = await r.json();
        goblins = j.goblins || [];
      } catch (e) {
        console.error('Failed to load goblins:', e);
        goblins = [];
      }
    }

    async function loadScene() {
      try {
        const r = await fetch('/scenes/api/' + sceneId);
        const j = await r.json();
        if (!j.success) {
          setHtml('editorStatus', alertBox('danger', 'Failed to load scene: ' + (j.error || 'Unknown error')));
          return;
        }
        const scene = j.scene;
        if (!scene) {
          setHtml('editorStatus', alertBox('danger', 'Scene not found'));
          return;
        }
        document.getElementById('sceneName').value = scene.name || '';
        steps = scene.steps || [];
        renderSteps();
      } catch (e) {
        setHtml('editorStatus', alertBox('danger', 'Error loading scene: ' + (e.message || e)));
      }
    }

    function initSortable() {
      const el = document.getElementById('stepsList');
      new Sortable(el, {
        animation: 150,
        handle: '.step-card',
        ghostClass: 'dragging',
        onEnd: function () {
          updateStepsFromDOM();
        }
      });
    }

    function addStep(type) {
      const step = { type: type };
      steps.push(step);
      renderSteps();
    }

    function addStepWithPart(type, partId) {
      // Normalize type to match renderStepForm expectations (use hyphen not underscore)
      const normalizedType = type === 'linear_actuator' ? 'linear-actuator' : type;

      const step = {
        type: normalizedType,
        partId: partId
      };
      // Set sensible defaults based on type
      switch (normalizedType) {
        case 'servo':
          step.angle = 90;
          step.duration = 1000;
          break;
        case 'motor':
          step.direction = 'forward';
          step.speed = 50;
          step.duration = 1000;
          break;
        case 'linear-actuator':
          step.direction = 'extend';
          step.speed = 75;
          step.duration = 3000;
          break;
        case 'light':
          step.state = 'on';
          step.brightness = 100;
          step.duration = 0;
          break;
        case 'sensor':
          step.timeout = 5000;
          step.threshold = 500;
          break;
      }
      steps.push(step);
      renderSteps();
    }

    function removeStep(index) {
      if (confirm('Remove this step?')) {
        steps.splice(index, 1);
        renderSteps();
      }
    }

    function duplicateStep(index) {
      const copy = JSON.parse(JSON.stringify(steps[index]));
      steps.splice(index + 1, 0, copy);
      renderSteps();
    }

    async function playStep(index) {
      const step = steps[index];
      if (!step) {
        alert('Step not found');
        return;
      }

      const btn = document.querySelector(`.btn-play-step[data-index="${index}"]`);
      const originalHtml = btn.innerHTML;

      try {
        // Disable button and show loading state
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

        // Call the test-step API
        const response = await fetch('/scenes/api/test-step', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(step)
        });

        const data = await response.json();

        if (data.success) {
          // Show success feedback
          btn.innerHTML = '<i class="bi bi-check-circle-fill"></i>';
          btn.classList.remove('btn-outline-success');
          btn.classList.add('btn-success');

          // Reset button after 2 seconds
          setTimeout(() => {
            btn.innerHTML = originalHtml;
            btn.classList.remove('btn-success');
            btn.classList.add('btn-outline-success');
            btn.disabled = false;
          }, 2000);
        } else {
          // Show error feedback
          btn.innerHTML = '<i class="bi bi-x-circle-fill"></i>';
          btn.classList.remove('btn-outline-success');
          btn.classList.add('btn-danger');
          alert('Step test failed: ' + (data.error || 'Unknown error'));

          // Reset button after 2 seconds
          setTimeout(() => {
            btn.innerHTML = originalHtml;
            btn.classList.remove('btn-danger');
            btn.classList.add('btn-outline-success');
            btn.disabled = false;
          }, 2000);
        }
      } catch (error) {
        console.error('Error testing step:', error);
        alert('Error testing step: ' + error.message);

        // Reset button
        btn.innerHTML = originalHtml;
        btn.disabled = false;
      }
    }

    function updateStepsFromDOM() {
      const newSteps = [];
      document.querySelectorAll('.step-card').forEach((card, index) => {
        const stepIndex = parseInt(card.getAttribute('data-index'));
        if (!isNaN(stepIndex) && steps[stepIndex]) {
          newSteps.push(steps[stepIndex]);
        }
      });
      steps = newSteps;
      renderSteps();
    }

    function renderSteps() {
      const container = document.getElementById('stepsList');
      if (steps.length === 0) {
        container.innerHTML = '<div class="text-muted text-center py-4">No steps yet. Click "Add Step" to begin.</div>';
        return;
      }

      let html = '';
      steps.forEach((step, index) => {
        html += renderStepCard(step, index);
      });
      container.innerHTML = html;

      // Attach event listeners
      attachStepEventListeners();
    }

    function renderStepCard(step, index) {
      const stepNum = index + 1;
      let html = '<div class="card step-card mb-3" data-index="' + index + '">';
      html += '<div class="card-header">';
      html += '<div class="d-flex justify-content-between align-items-center">';
      html += '<h6 class="mb-0"><i class="bi bi-grip-vertical"></i> Step ' + stepNum + ': ' + getStepTypeName(step.type) + '</h6>';
      html += '<div class="btn-group btn-group-sm">';
      html += '<button class="btn btn-outline-success btn-play-step" data-index="' + index + '" title="Test Step"><i class="bi bi-play-fill"></i></button>';
      html += '<button class="btn btn-outline-secondary btn-duplicate" data-index="' + index + '" title="Duplicate Step"><i class="bi bi-files"></i></button>';
      html += '<button class="btn btn-outline-danger btn-remove" data-index="' + index + '" title="Remove Step"><i class="bi bi-trash"></i></button>';
      html += '</div></div></div>';
      html += '<div class="card-body">';
      html += renderStepForm(step, index);
      html += '</div></div>';
      return html;
    }

    function getStepTypeName(type) {
      const names = {
        'pose': 'Pose',
        'audio': 'Audio',
        'sayThis': 'Say This (AI Voice)',
        'askAI': 'Ask AI a Question',
        'servo': 'Servo',
        'motor': 'Motor',
        'linear-actuator': 'Linear Actuator',
        'light': 'Light/LED',
        'sensor': 'Sensor',
        'goblin-video': 'Goblin Video',
        'wait': 'Wait/Pause',
        'part': 'Part Control (Legacy)'
      };
      return names[type] || type;
    }

    function renderStepForm(step, index) {
      switch (step.type) {
        case 'pose': return renderPoseForm(step, index);
        case 'audio': return renderAudioForm(step, index);
        case 'sayThis': return renderSayThisForm(step, index);
        case 'askAI': return renderAskAIForm(step, index);
        case 'servo': return renderServoForm(step, index);
        case 'motor': return renderMotorForm(step, index);
        case 'linear-actuator': return renderLinearActuatorForm(step, index);
        case 'light': return renderLightForm(step, index);
        case 'sensor': return renderSensorForm(step, index);
        case 'goblin-video': return renderGoblinVideoForm(step, index);
        case 'wait': return renderWaitForm(step, index);
        case 'part': return renderPartForm(step, index);
        default: return '<div class="alert alert-warning mb-0"><small>Unknown step type: ' + step.type + '</small></div>';
      }
    }

    function renderPoseForm(step, index) {
      let html = '<div class="row g-3">';
      html += '<div class="col-md-12">';
      html += '<label class="form-label">Pose</label>';
      html += '<select title="Select a pose to run" class="form-select step-input" data-index="' + index + '" data-field="poseId">';
      html += '<option value="">Select a pose...</option>';
      poses.forEach(p => {
        const sel = (step.poseId == p.id) ? ' selected' : '';
        html += '<option value="' + p.id + '"' + sel + '>' + (p.name || 'Pose ' + p.id) + '</option>';
      });
      html += '</select></div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
      html += '<input title="Run this step at the same time as the next step" class="form-check-input step-input" type="checkbox" data-index="' + index + '" data-field="concurrent" id="concurrent' + index + '"' + (step.concurrent ? ' checked' : '') + '>';
      html += '<label class="form-check-label" for="concurrent' + index + '">Run concurrently with next step</label>';
      html += '</div></div></div>';
      return html;
    }

    function renderAudioForm(step, index) {
      let html = '<div class="row g-3">';
      html += '<div class="col-md-8">';
      html += '<label class="form-label">Audio File</label>';
      html += '<select title="Select an audio file to play" class="form-select step-input" data-index="' + index + '" data-field="audioId">';
      html += '<option value="">Select audio...</option>';
      sounds.forEach(s => {
        const sel = (step.audioId == s.id || step.audioId == s.filename) ? ' selected' : '';
        html += '<option value="' + (s.filename || s.id) + '"' + sel + '>' + (s.name || s.filename) + '</option>';
      });
      html += '</select></div>';
      html += '<div class="col-md-4">';
      html += '<label class="form-label">Volume (%)</label>';
      html += '<input type="number" class="form-control step-input" data-index="' + index + '" data-field="volume" value="' + (step.volume || 80) + '" min="0" max="100">';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
      html += '<input title="Run this step at the same time as the next step" class="form-check-input step-input" type="checkbox" data-index="' + index + '" data-field="concurrent" id="concurrent' + index + '"' + (step.concurrent ? ' checked' : '') + '>';
      html += '<label class="form-check-label" for="concurrent' + index + '">Run concurrently with next step</label>';
      html += '</div></div></div>';
      return html;
    }

    function renderSayThisForm(step, index) {
      let html = '<div class="row g-3">';
      html += '<div class="col-md-12">';
      html += '<label class="form-label">Text to Speak</label>';
      html += '<textarea class="form-control step-input" data-index="' + index + '" data-field="text" rows="2" placeholder="Enter text for AI to speak...">' + (step.text || '') + '</textarea>';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<button class="btn btn-sm btn-outline-primary btn-preview-voice" title="Preview this voice line" data-index="' + index + '"><i class="bi bi-play-circle"></i> Preview Voice</button>';
      html += '<span class="ms-2 text-muted voice-preview-status" id="voiceStatus' + index + '"></span>';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
      html += '<input title="Run this step at the same time as the next step" class="form-check-input step-input" type="checkbox" data-index="' + index + '" data-field="concurrent" id="concurrent' + index + '"' + (step.concurrent ? ' checked' : '') + '>';
      html += '<label class="form-check-label" for="concurrent' + index + '">Run concurrently with next step</label>';
      html += '</div></div></div>';
      return html;
    }

    function renderAskAIForm(step, index) {
      let html = '<div class="row g-3">';
      html += '<div class="col-md-12">';
      html += '<label class="form-label">Question to Ask AI</label>';
      html += '<textarea class="form-control step-input" data-index="' + index + '" data-field="question" rows="2" placeholder="Enter question for AI agent...">' + (step.question || step.text || '') + '</textarea>';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="alert alert-info mb-0"><small><i class="bi bi-info-circle"></i> The AI will respond and the response will be played through TTS.</small></div>';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<div class="form-check">';
      html += '<input title="Run this step at the same time as the next step" class="form-check-input step-input" type="checkbox" data-index="' + index + '" data-field="concurrent" id="concurrent' + index + '"' + (step.concurrent ? ' checked' : '') + '>';
      html += '<label class="form-check-label" for="concurrent' + index + '">Run concurrently with next step</label>';
      html += '</div></div></div>';
      return html;
    }

    function renderServoForm(step, index) {
      const servoParts = parts.filter(p => p.type === 'servo');
      let html = '<div class="row g-3">';
      html += '<div class="col-md-6">';
      html += '<label class="form-label">Servo Part</label>';
      html += '<select title="Select the hardware part for this step" class="form-select step-input" data-index="' + index + '" data-field="partId" onchange="handlePartChange(' + index + ', \'servo\')">';
      html += '<option value="">Select servo...</option>';
      servoParts.forEach(p => {
        const sel = (step.partId == p.id) ? ' selected' : '';
        html += '<option value="' + p.id + '"' + sel + '>' + p.name + '</option>';
      });
