    function renderPartForm(step, index) {
      // Legacy "part" step type - generic part control
      const allParts = parts;
      let html = '<div class="row g-3">';
      html += '<div class="col-md-12">';
      html += '<div class="alert alert-info py-2 mb-2"><small><i class="bi bi-info-circle"></i> Legacy part control step</small></div>';
      html += '</div>';
      html += '<div class="col-md-6">';
      html += '<label class="form-label">Part</label>';
      html += '<select class="form-select step-input" data-index="' + index + '" data-field="partId">';
      html += '<option value="">Select part...</option>';
      allParts.forEach(p => {
        const sel = (step.partId == p.id) ? ' selected' : '';
        html += '<option value="' + p.id + '"' + sel + '>' + p.name + ' (' + p.type + ')</option>';
      });
      html += '</select></div>';
      html += '<div class="col-md-6">';
      html += '<label class="form-label">Action</label>';
      html += '<input type="text" class="form-control step-input" data-index="' + index + '" data-field="action" value="' + (step.action || '') + '" placeholder="e.g., turnOn, turnOff">';
      html += '</div>';
      html += '<div class="col-md-12">';
      html += '<label class="form-label">Parameters (JSON)</label>';
      html += '<textarea class="form-control step-input font-monospace" data-index="' + index + '" data-field="params" rows="2" placeholder=\'{"duration": 500}\'>' + (step.params ? JSON.stringify(step.params) : '') + '</textarea>';
      html += '</div>';
