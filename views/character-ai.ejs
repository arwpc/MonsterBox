<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>
<body>
    <header>
        <h1 class="landing-title">🧠 <%= title %></h1>
    </header>

    <main>
        <div class="info-section">
            <h3>🎭 Character: <%= character.char_name %></h3>
            <p><%= character.char_description %></p>
            <p>Manage AI instances assigned to this character. Multiple AI instances can be assigned to provide different personalities and behaviors.</p>
        </div>

        <div class="button-group">
            <a href="/characters/<%= character.id %>/edit" class="button">✏️ Edit Character</a>
            <a href="/characters/<%= character.id %>/parts" class="button">🔧 Manage Hardware Parts</a>
            <a href="/ai-instances" class="button">🧠 Manage All AI Instances</a>
            <a href="/characters" class="button secondary-btn">Back to Characters</a>
        </div>

        <!-- Assigned AI Instances Section -->
        <div class="section-container">
            <h3>🧠 Assigned AI Instances</h3>
            <% if (assignedAIInstances.length > 0) { %>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Personality</th>
                                <th>Model</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for(let ai of assignedAIInstances) { %>
                                <tr>
                                    <td><%= ai.name %></td>
                                    <td><%= ai.type %></td>
                                    <td><%= ai.config.personality %></td>
                                    <td><%= ai.config.model %></td>
                                    <td>
                                        <% if (ai.enabled) { %>
                                            <span class="status-badge success">✅ Enabled</span>
                                        <% } else { %>
                                            <span class="status-badge error">❌ Disabled</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <button class="button secondary-btn" onclick="testAI('<%= ai.id %>')">
                                            🧪 Test
                                        </button>
                                        <button class="button danger-btn" onclick="unassignAI('<%= ai.id %>')">
                                            🗑️ Unassign
                                        </button>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p>No AI instances assigned to this character yet.</p>
                </div>
            <% } %>
        </div>

        <!-- Available AI Instances Section -->
        <div class="section-container">
            <h3>🧠 Available AI Instances</h3>
            <% if (availableAIInstances.length > 0) { %>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Personality</th>
                                <th>Model</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for(let ai of availableAIInstances) { %>
                                <tr>
                                    <td><%= ai.name %></td>
                                    <td><%= ai.type %></td>
                                    <td><%= ai.config.personality %></td>
                                    <td><%= ai.config.model %></td>
                                    <td>
                                        <% if (ai.enabled) { %>
                                            <span class="status-badge success">✅ Enabled</span>
                                        <% } else { %>
                                            <span class="status-badge error">❌ Disabled</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <button class="button secondary-btn" onclick="testAI('<%= ai.id %>')">
                                            🧪 Test
                                        </button>
                                        <button class="button primary-btn" onclick="assignAI('<%= ai.id %>')">
                                            ➕ Assign
                                        </button>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p>No unassigned AI instances available. <a href="/ai-instances/new">Create new AI instances</a> or unassign instances from other characters.</p>
                </div>
            <% } %>
        </div>
    </main>

    <script>
        function assignAI(aiInstanceId) {
            if (confirm('Assign this AI instance to <%= character.char_name %>?')) {
                $.post('/characters/<%= character.id %>/ai/assign', { aiInstanceId: aiInstanceId })
                    .done(function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert('Error: ' + response.error);
                        }
                    })
                    .fail(function() {
                        alert('Failed to assign AI instance. Please try again.');
                    });
            }
        }

        function unassignAI(aiInstanceId) {
            if (confirm('Unassign this AI instance from <%= character.char_name %>?')) {
                $.post('/characters/<%= character.id %>/ai/unassign', { aiInstanceId: aiInstanceId })
                    .done(function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert('Error: ' + response.error);
                        }
                    })
                    .fail(function() {
                        alert('Failed to unassign AI instance. Please try again.');
                    });
            }
        }

        function testAI(aiInstanceId) {
            $.post('/ai-instances/' + aiInstanceId + '/test')
                .done(function(response) {
                    if (response.success) {
                        alert('AI Test Result:\n\n' + 
                              'Response Time: ' + response.response_time + 'ms\n' +
                              'Test Message: ' + response.test_message + '\n' +
                              'Config Valid: ' + (response.config_valid ? 'Yes' : 'No') + '\n' +
                              'Voice Synthesis: ' + (response.voice_synthesis_available ? 'Available' : 'Not Available'));
                    } else {
                        alert('AI Test Failed: ' + response.error);
                    }
                })
                .fail(function() {
                    alert('Failed to test AI instance. Please try again.');
                });
        }
    </script>
</body>
</html>
