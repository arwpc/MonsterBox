<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <style>
        .pca9685-board {
            background: #1a4a6b;
            border: 2px solid #333;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
            position: relative;
            max-width: 600px;
        }

        .pca9685-title {
            text-align: center;
            color: #fff;
            font-weight: bold;
            margin-bottom: 15px;
            font-size: 14px;
        }

        .channel-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            margin-bottom: 15px;
        }

        .channel-row {
            display: contents;
        }

        .channel-button {
            padding: 8px 4px;
            text-align: center;
            background-color: #2a2a2a;
            color: #00ff00;
            border: 2px solid #444;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 11px;
            line-height: 1.2;
            min-height: 45px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .channel-button:hover {
            background-color: #004400;
            border-color: #00ff00;
        }

        .channel-button.selected {
            background-color: #006600;
            border-color: #00ff00;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
        }

        .channel-number {
            font-weight: bold;
            font-size: 12px;
        }

        .channel-position {
            font-size: 9px;
            opacity: 0.8;
        }

        .board-labels {
            display: flex;
            justify-content: space-between;
            margin-top: 10px;
            font-size: 10px;
            color: #aaa;
        }

        .channel-button.selected {
            background-color: #00ff00;
            color: #000000;
        }

        .servo-type-container {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        #testResult {
            margin-top: 10px;
            padding: 10px;
            border: 1px solid #00ff00;
            border-radius: 4px;
            display: none;
        }

        #testResult.success {
            background-color: rgba(0, 255, 0, 0.1);
            color: #00ff00;
        }

        #testResult.error {
            background-color: rgba(255, 0, 0, 0.1);
            color: #ff0000;
        }

        .test-buttons {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .test-buttons button {
            flex: 1;
        }

        .test-buttons button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Calibration Status Styles */
        .calibration-status {
            background: #2a2a2a;
            border: 1px solid #28a745;
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .status-indicator {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .status-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            display: inline-block;
        }

        .status-dot.calibrated {
            background-color: #28a745;
        }

        .status-dot.uncalibrated {
            background-color: #dc3545;
        }

        .calibrate-btn {
            background: linear-gradient(135deg, #007bff, #0056b3);
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 500;
        }

        .calibrate-btn:hover {
            background: linear-gradient(135deg, #0056b3, #004085);
        }

        .calibration-note {
            color: #6c757d;
            font-style: italic;
            margin: 0;
        }

        /* Modal Styles */
        .modal-monsterbox {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
        }

        .modal-content-monsterbox {
            background-color: #1a1a1a;
            margin: 5% auto;
            padding: 2rem;
            border: 2px solid #28a745;
            border-radius: 12px;
            width: 90%;
            max-width: 800px;
            max-height: 80vh;
            overflow-y: auto;
            position: relative;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        .modal-backdrop {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
        }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid #333;
        }

        /* Calibration Modal Styles */
        .calibration-methods {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin: 1rem 0;
        }

        .calibration-methods .button {
            padding: 1rem;
            text-align: center;
            border: 2px solid #28a745;
            background: #2a2a2a;
            color: #28a745;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .calibration-methods .button:hover {
            border-color: #28a745;
            background: #28a745;
            color: #000;
        }

        /* Rotation Control Buttons */
        .rotation-control-buttons {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 10px;
            margin-top: 10px;
        }

        .rotation-btn {
            padding: 12px 16px;
            background: #2a2a2a;
            border: 2px solid #28a745;
            color: #28a745;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 14px;
            font-weight: bold;
        }

        .rotation-btn:hover {
            background: #28a745;
            color: #000;
        }

        .rotation-btn:active {
            background: #1e7e34;
            border-color: #1e7e34;
            color: #fff;
        }

        .stop-btn {
            background: #dc3545;
            border-color: #dc3545;
            color: #fff;
        }

        .stop-btn:hover {
            background: #c82333;
            border-color: #c82333;
        }

        /* Calibration Interface Styles */
        .continuous-calibration,
        .standard-calibration,
        .extension-calibration {
            background: #2a2a2a;
            color: #28a745;
            padding: 20px;
            border-radius: 8px;
        }

        .continuous-calibration h4,
        .standard-calibration h4,
        .extension-calibration h4 {
            color: #28a745;
            margin-bottom: 15px;
        }

        .continuous-calibration p,
        .standard-calibration p,
        .extension-calibration p {
            color: #ccc;
            margin-bottom: 20px;
        }

        .servo-controls,
        .calibration-steps,
        .extension-controls {
            background: #1a1a1a;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 15px;
        }

        .control-group,
        .calibration-step {
            margin-bottom: 15px;
        }

        .control-group label,
        .calibration-step h5 {
            color: #28a745;
            display: block;
            margin-bottom: 8px;
        }

        .button-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .position-saving,
        .saved-positions {
            background: #1a1a1a;
            padding: 15px;
            border-radius: 6px;
            margin-top: 15px;
        }

        .position-saving h5 {
            color: #28a745;
            margin-bottom: 10px;
        }

        .position-buttons {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
            margin-bottom: 15px;
        }

        .custom-position {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .custom-position input {
            flex: 1;
            padding: 8px;
            background: #2a2a2a;
            border: 1px solid #28a745;
            color: #28a745;
            border-radius: 4px;
        }

        /* Calibration Recommendation Styles */
        .calibration-recommendation {
            background: #1a4d2e;
            border: 2px solid #28a745;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            color: #28a745;
        }

        .calibration-recommendation h5 {
            color: #28a745;
            margin: 0 0 10px 0;
            font-size: 1.1em;
        }

        .calibration-recommendation p {
            margin: 0;
            color: #ccc;
            font-size: 0.9em;
        }

        .recommended-btn {
            position: relative;
            border: 2px solid #28a745 !important;
            background: #1a4d2e !important;
        }

        .recommended-btn::after {
            content: "⭐ RECOMMENDED";
            position: absolute;
            top: -8px;
            right: -8px;
            background: #28a745;
            color: #000;
            font-size: 0.7em;
            padding: 2px 6px;
            border-radius: 4px;
            font-weight: bold;
        }

        /* Servo Control Styles */
        .servo-controls,
        .extension-controls {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 1rem;
            margin: 1rem 0;
        }

        .control-group {
            margin-bottom: 1rem;
        }

        .control-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .button-group {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .button-group .button {
            flex: 1;
            min-width: 100px;
            padding: 0.5rem;
            text-align: center;
        }

        /* Test Controls Enhancement */
        .test-controls {
            background: #1a1a1a;
            border: 2px solid #28a745;
            border-radius: 8px;
            padding: 1.5rem;
            margin-top: 1rem;
        }

        .test-controls h3 {
            margin-top: 0;
            color: #28a745;
            text-align: center;
            margin-bottom: 1.5rem;
        }

        .test-section {
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #333;
        }

        .test-section:last-child {
            border-bottom: none;
            margin-bottom: 0;
        }

        .test-section h4 {
            color: #28a745;
            margin-bottom: 1rem;
            font-size: 1.1rem;
        }

        .angle-control {
            margin-bottom: 1rem;
        }

        .angle-control label {
            display: block;
            margin-bottom: 0.5rem;
            color: #28a745;
            font-weight: 600;
        }

        .angle-slider {
            width: 100%;
            margin-bottom: 0.5rem;
        }

        #angleValue {
            color: #28a745;
            font-weight: bold;
            font-size: 1.1rem;
        }

        .test-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .position-buttons {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .position-btn {
            padding: 0.75rem 0.5rem;
            background: rgba(40, 167, 69, 0.1);
            border: 1px solid #28a745;
            color: #28a745;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.9rem;
            text-align: center;
        }

        .position-btn:hover {
            background: #28a745;
            color: white;
        }

        .rotation-controls {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .rotation-btn {
            padding: 0.75rem 0.5rem;
            background: rgba(40, 167, 69, 0.1);
            border: 1px solid #28a745;
            color: #28a745;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.9rem;
            text-align: center;
        }

        .rotation-btn:hover {
            background: #28a745;
            color: white;
        }

        .rotation-btn:active {
            background: #1e7e34;
        }

        .stop-btn {
            background: rgba(220, 53, 69, 0.1) !important;
            border-color: #dc3545 !important;
            color: #dc3545 !important;
        }

        .stop-btn:hover {
            background: #dc3545 !important;
            color: white !important;
        }
    </style>
</head>

<body>
    <header>
        <h1 class="landing-title">
            <%= title %>
        </h1>
    </header>

    <main>
        <form
            action="<%= action %>?returnTo=/parts?characterId=<%= character ? character.id : (part ? part.characterId : '') %>"
            method="POST" id="servoForm">
            <input type="hidden" name="type" value="servo">
            <% if (part && part.id) { %>
                <input type="hidden" name="id" value="<%= part.id %>">
                <% } %>

                    <div class="form-group">
                        <label for="name">Part Name:</label>
                        <input type="text" id="name" name="name" value="<%= part ? part.name : '' %>" required>
                    </div>

                    <div class="form-group">
                        <label for="characterId">Character:</label>
                        <select id="characterId" name="characterId" required>
                            <% characters.forEach(function(character) { %>
                                <option value="<%= character.id %>" <%=(part && part.characterId===character.id)
                                    ? 'selected' : '' %>>
                                    <%= character.char_name %>
                                </option>
                                <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="servoType">Servo Type:</label>
                        <div class="servo-type-container">
                            <select id="servoType" name="servoType" required onchange="updateServoParameters()">
                                <option value="">Select a Servo Type</option>
                                <% servoConfigs.forEach(function(servo) { %>
                                    <option value="<%= servo.name %>" data-min-pulse="<%= servo.min_pulse_width_us %>"
                                        data-max-pulse="<%= servo.max_pulse_width_us %>"
                                        data-default-angle="<%= servo.default_angle_deg %>"
                                        data-model="<%= servo.model %>" data-manufacturer="<%= servo.manufacturer %>"
                                        data-modes="<%= servo.mode.join(',') %>"
                                        data-torque="<%= servo.max_torque_kg_cm %>"
                                        data-rotation="<%= servo.rotation_range_deg %>"
                                        data-feedback="<%= servo.feedback %>" data-notes="<%= servo.notes || '' %>"
                                        <%=(part && part.servoType===servo.name) ? 'selected' : '' %>>
                                        <%= servo.name %>
                                    </option>
                                    <% }); %>
                            </select>
                            <button type="button" class="button" onclick="openCustomizeModal()">Customize</button>
                        </div>
                    </div>

                    <div id="servoInfo" class="config-section">
                        <p id="servoModel"></p>
                        <p id="servoModes"></p>
                        <p id="servoTorque"></p>
                        <p id="servoRotation"></p>
                        <p id="servoFeedback"></p>
                        <p id="servoNotes"></p>
                    </div>

                    <div class="form-group">
                        <label class="checkbox-label" for="usePCA9685">
                            <input type="checkbox" id="usePCA9685" name="usePCA9685" <%=(part && part.usePCA9685)
                                ? 'checked' : '' %> onchange="togglePCA9685()">
                            Use PCA9685
                        </label>
                    </div>

                    <div id="pca9685Fields" class="config-section" style="display: none;">
                        <div class="form-group">
                            <label for="channel">PCA9685 Channel:</label>
                            <input type="number" id="channel" name="channel" value="<%= part ? part.channel : 0 %>"
                                min="0" max="15" required>
                        </div>
                        <div class="form-group">
                            <label for="pca9685Frequency">PCA9685 Frequency (Hz):</label>
                            <input type="number" id="pca9685Frequency" name="pca9685Frequency"
                                value="<%= part && part.pca9685Settings ? part.pca9685Settings.frequency : 50 %>"
                                min="40" max="1000" required>
                        </div>
                        <div class="form-group">
                            <label for="pca9685Address">PCA9685 I2C Address:</label>
                            <input type="text" id="pca9685Address" name="pca9685Address"
                                value="<%= part && part.pca9685Settings ? part.pca9685Settings.address : '0x40' %>"
                                pattern="0x[0-9A-Fa-f]{2}" required>
                        </div>
                        <div class="form-group">
                            <label>PCA9685 Channel Position:</label>
                            <div class="pca9685-board">
                                <div class="pca9685-title">PCA9685 16-Channel PWM Driver</div>
                                <div class="channel-grid">
                                    <!-- Top Row: Channels 0-3 -->
                                    <div class="channel-button" data-channel="0">
                                        <div class="channel-number">0</div>
                                        <div class="channel-position">Left Top</div>
                                    </div>
                                    <div class="channel-button" data-channel="1">
                                        <div class="channel-number">1</div>
                                        <div class="channel-position">Left Top</div>
                                    </div>
                                    <div class="channel-button" data-channel="2">
                                        <div class="channel-number">2</div>
                                        <div class="channel-position">Left Top</div>
                                    </div>
                                    <div class="channel-button" data-channel="3">
                                        <div class="channel-number">3</div>
                                        <div class="channel-position">Left Top</div>
                                    </div>

                                    <!-- Second Row: Channels 4-7 -->
                                    <div class="channel-button" data-channel="4">
                                        <div class="channel-number">4</div>
                                        <div class="channel-position">Left Mid</div>
                                    </div>
                                    <div class="channel-button" data-channel="5">
                                        <div class="channel-number">5</div>
                                        <div class="channel-position">Left Mid</div>
                                    </div>
                                    <div class="channel-button" data-channel="6">
                                        <div class="channel-number">6</div>
                                        <div class="channel-position">Left Mid</div>
                                    </div>
                                    <div class="channel-button" data-channel="7">
                                        <div class="channel-number">7</div>
                                        <div class="channel-position">Left Mid</div>
                                    </div>

                                    <!-- Third Row: Channels 8-11 -->
                                    <div class="channel-button" data-channel="8">
                                        <div class="channel-number">8</div>
                                        <div class="channel-position">Right Mid</div>
                                    </div>
                                    <div class="channel-button" data-channel="9">
                                        <div class="channel-number">9</div>
                                        <div class="channel-position">Right Mid</div>
                                    </div>
                                    <div class="channel-button" data-channel="10">
                                        <div class="channel-number">10</div>
                                        <div class="channel-position">Right Mid</div>
                                    </div>
                                    <div class="channel-button" data-channel="11">
                                        <div class="channel-number">11</div>
                                        <div class="channel-position">Right Mid</div>
                                    </div>

                                    <!-- Bottom Row: Channels 12-15 -->
                                    <div class="channel-button" data-channel="12">
                                        <div class="channel-number">12</div>
                                        <div class="channel-position">Right Top</div>
                                    </div>
                                    <div class="channel-button" data-channel="13">
                                        <div class="channel-number">13</div>
                                        <div class="channel-position">Right Top</div>
                                    </div>
                                    <div class="channel-button" data-channel="14">
                                        <div class="channel-number">14</div>
                                        <div class="channel-position">Right Top</div>
                                    </div>
                                    <div class="channel-button" data-channel="15">
                                        <div class="channel-number">15</div>
                                        <div class="channel-position">Right Top</div>
                                    </div>
                                </div>
                                <div class="board-labels">
                                    <span>PWM Outputs</span>
                                    <span>I2C: SCL/SDA</span>
                                    <span>Power: VCC/GND</span>
                                </div>
                            </div>
                            <p style="color: #888; font-size: 12px; margin-top: 10px;">
                                💡 Click the channel that matches where your servo signal wire is connected on the
                                physical PCA9685 board.
                            </p>
                            <div style="margin-top: 15px;">
                                <button type="button" class="button secondary-btn" onclick="testSelectedChannel()"
                                    id="testChannelBtn">
                                    🔧 Test Selected Channel
                                </button>
                                <div id="channelTestResult" style="margin-top: 10px;"></div>
                            </div>
                        </div>
                    </div>

                    <div id="gpioField" class="form-group" style="display: none;">
                        <label for="pin">GPIO Pin:</label>
                        <input type="number" id="pin" name="pin" value="<%= part ? part.pin : '' %>" min="0" max="27"
                            required>
                    </div>

                    <input type="hidden" id="minPulse" name="minPulse" value="<%= part ? part.minPulse : 500 %>">
                    <input type="hidden" id="maxPulse" name="maxPulse" value="<%= part ? part.maxPulse : 2500 %>">
                    <input type="hidden" id="defaultAngle" name="defaultAngle"
                        value="<%= part ? part.defaultAngle : 90 %>">
                    <input type="hidden" id="customSettings" name="customSettings"
                        value="<%= part && part.customSettings ? JSON.stringify(part.customSettings) : '' %>">

                    <div class="button-group">
                        <button type="submit" class="button primary-btn">Save Part</button>
                    </div>
        </form>

        <!-- Customize Modal -->
        <div id="customizeModal" class="modal">
            <div class="modal-content">
                <span class="close" onclick="closeCustomizeModal()">&times;</span>
                <h2>Customize Servo Settings</h2>
                <form id="customizeForm" onsubmit="saveCustomSettings(event)">
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="customMinPulse">Min Pulse Width (μs):</label>
                            <input type="number" id="customMinPulse" name="customMinPulse" required>
                        </div>
                        <div class="form-group">
                            <label for="customMaxPulse">Max Pulse Width (μs):</label>
                            <input type="number" id="customMaxPulse" name="customMaxPulse" required>
                        </div>
                        <div class="form-group">
                            <label for="customDefaultAngle">Default Angle (degrees):</label>
                            <input type="number" id="customDefaultAngle" name="customDefaultAngle" min="0" max="180"
                                required>
                        </div>
                        <div class="form-group">
                            <label for="customRotationRange">Rotation Range (degrees):</label>
                            <input type="number" id="customRotationRange" name="customRotationRange" min="0" max="360"
                                required>
                        </div>
                    </div>
                    <div class="button-group">
                        <button type="submit" class="button primary-btn">Save Settings</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="config-section">
            <h2>Servo Control & Calibration</h2>

            <!-- Rotation Control Section -->
            <div class="form-group">
                <label>Rotation Control</label>
                <div class="rotation-control-buttons">
                    <button type="button" class="button rotation-btn"
                        onmousedown="startContinuousRotation('ccw', 'slow')" onmouseup="stopContinuousRotation()"
                        onmouseleave="stopContinuousRotation()">
                        ← Left Slow
                    </button>
                    <button type="button" class="button rotation-btn"
                        onmousedown="startContinuousRotation('ccw', 'fast')" onmouseup="stopContinuousRotation()"
                        onmouseleave="stopContinuousRotation()">
                        ←← Left Fast
                    </button>
                    <button type="button" class="button rotation-btn stop-btn" onclick="stopContinuousRotation()">
                        ⏹ STOP
                    </button>
                    <button type="button" class="button rotation-btn"
                        onmousedown="startContinuousRotation('cw', 'slow')" onmouseup="stopContinuousRotation()"
                        onmouseleave="stopContinuousRotation()">
                        Right Slow →
                    </button>
                    <button type="button" class="button rotation-btn"
                        onmousedown="startContinuousRotation('cw', 'fast')" onmouseup="stopContinuousRotation()"
                        onmouseleave="stopContinuousRotation()">
                        Right Fast →→
                    </button>
                </div>
            </div>

            <!-- Calibration Status -->
            <div id="calibrationStatus" class="calibration-status">
                <div class="status-indicator">
                    <span id="calibrationIndicator" class="status-dot uncalibrated"></span>
                    <span id="calibrationText">Not Calibrated</span>
                </div>
                <% if (part && part.id) { %>
                    <button type="button" onclick="openCalibrationModal('<%= part.id %>')" class="button calibrate-btn">
                        🎯 Calibrate Servo
                    </button>
                    <% } else { %>
                        <p class="calibration-note">Save the servo first to enable calibration</p>
                        <% } %>
            </div>

            <!-- Test Servo panel removed -->
        </div>

        <div class="button-group">
            <a href="/parts?characterId=<%= character ? character.id : (part ? part.characterId : '') %>"
                class="button secondary-btn">Back to Parts</a>
            <a href="/system-config/servos" class="button">Manage Servo Configurations</a>
        </div>
    </main>

    <!-- Servo Calibration Modal -->
    <div id="calibrationModal" class="modal-monsterbox" style="display: none;">
        <div class="modal-content-monsterbox max-w-4xl">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                <h3 class="font-bold text-lg text-primary mb-0">
                    🎯 Servo Calibration
                </h3>
                <button type="button" class="button secondary-btn" onclick="closeCalibrationModal()"
                    style="padding: 0.5rem 1rem;">
                    ✕ Close
                </button>
            </div>

            <div id="calibrationContent">
                <div class="calibration-type-selection">
                    <h4>Select Calibration Method:</h4>
                    <div id="calibrationRecommendation" class="calibration-recommendation" style="display: none;">
                        <!-- Recommendation will be inserted here -->
                    </div>
                    <div class="calibration-methods">
                        <button type="button" class="button" onclick="startContinuousCalibration()">
                            🎮 Continuous Rotation Servo
                        </button>
                        <button type="button" class="button" onclick="startStandardCalibration()">
                            📐 Standard Position Servo
                        </button>
                        <button type="button" class="button recommended-btn" onclick="startExtensionCalibration()">
                            🦴 Extension/Joint Servo
                        </button>
                    </div>
                </div>

                <div id="calibrationInterface" style="display: none;">
                    <!-- Calibration interface will be loaded here -->
                </div>
            </div>

            <div class="modal-actions">
                <button type="button" class="button secondary-btn" onclick="closeCalibrationModal()">
                    Cancel
                </button>
                <button type="button" class="button" id="saveCalibrationBtn" onclick="saveCalibration()"
                    style="display: none;">
                    💾 Save Calibration
                </button>
            </div>
        </div>
        <div class="modal-backdrop" onclick="closeCalibrationModal()"></div>
    </div>

    <script>
        let isTestingServo = false;
        const currentServoId = <%= (part && part.id) ? part.id : 'null' %>;

        // Initialize the page
        document.addEventListener('DOMContentLoaded', function () {
            console.log('Page initialized');
            togglePCA9685();
            updateServoParameters();
            initializeChannelButtons();
            updateTestAngleDisplay();
        });

        // Handle PCA9685 checkbox toggle
        function togglePCA9685() {
            console.log('Toggling PCA9685');
            const usePCA9685 = document.getElementById('usePCA9685').checked;
            const pca9685Fields = document.getElementById('pca9685Fields');
            const gpioField = document.getElementById('gpioField');

            if (usePCA9685) {
                pca9685Fields.style.display = 'block';
                gpioField.style.display = 'none';
                document.getElementById('pin').removeAttribute('required');
                document.getElementById('channel').setAttribute('required', 'required');
                document.getElementById('pca9685Frequency').setAttribute('required', 'required');
                document.getElementById('pca9685Address').setAttribute('required', 'required');
            } else {
                pca9685Fields.style.display = 'none';
                gpioField.style.display = 'block';
                document.getElementById('channel').removeAttribute('required');
                document.getElementById('pca9685Frequency').removeAttribute('required');
                document.getElementById('pca9685Address').removeAttribute('required');
                document.getElementById('pin').setAttribute('required', 'required');
            }
        }

        // Initialize channel selection buttons
        function initializeChannelButtons() {
            console.log('Initializing channel buttons');
            const channelInput = document.getElementById('channel');
            const buttons = document.querySelectorAll('.channel-button');

            // Set initial selected state
            const currentChannel = parseInt(channelInput.value);
            buttons.forEach(button => {
                const buttonChannel = parseInt(button.dataset.channel);
                if (buttonChannel === currentChannel) {
                    button.classList.add('selected');
                }
            });

            // Add click handlers
            buttons.forEach(button => {
                button.addEventListener('click', function () {
                    const channel = this.dataset.channel;
                    channelInput.value = channel;

                    // Update visual selection
                    buttons.forEach(b => b.classList.remove('selected'));
                    this.classList.add('selected');

                    // Clear previous test results
                    document.getElementById('channelTestResult').innerHTML = '';
                });
            });
        }

        // Test the selected PCA9685 channel
        async function testSelectedChannel() {
            const channelInput = document.getElementById('channel');
            const channel = parseInt(channelInput.value);
            const resultDiv = document.getElementById('channelTestResult');
            const testBtn = document.getElementById('testChannelBtn');

            if (isNaN(channel) || channel < 0 || channel > 15) {
                resultDiv.innerHTML = '<div class="error">Please select a valid channel (0-15)</div>';
                return;
            }

            testBtn.disabled = true;
            testBtn.textContent = '🔧 Testing...';
            resultDiv.innerHTML = '<div class="info">Testing channel ' + channel + ' with sweep pattern...</div>';

            try {
                // Test with a sweep pattern: center -> left -> center -> right -> center
                const testSequence = [
                    { pulse: 1500, description: 'Center position' },
                    { pulse: 1000, description: 'Left/Min position' },
                    { pulse: 1500, description: 'Center position' },
                    { pulse: 2000, description: 'Right/Max position' },
                    { pulse: 1500, description: 'Center position' }
                ];

                for (let i = 0; i < testSequence.length; i++) {
                    const test = testSequence[i];
                    resultDiv.innerHTML = `<div class="info">Step ${i + 1}/5: ${test.description} (${test.pulse}µs)</div>`;

                    // Send test pulse via WebSocket
                    const response = await fetch('/parts/servo/test-pulse', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            servo_id: currentServoId || 'test',
                            pulse_width: test.pulse,
                            channel: channel,
                            use_pca9685: true
                        })
                    });

                    if (!response.ok) {
                        throw new Error('Test request failed');
                    }

                    // Wait between pulses
                    await new Promise(resolve => setTimeout(resolve, 1000));
                }

                resultDiv.innerHTML = `
                    <div class="success">✅ Channel ${channel} test completed!</div>
                    <div style="color: #888; font-size: 12px; margin-top: 5px;">
                        Did you see servo movement? If yes, this is the correct channel.
                        If no movement, try a different channel.
                    </div>
                `;

            } catch (error) {
                console.error('Channel test error:', error);
                resultDiv.innerHTML = `<div class="error">❌ Test failed: ${error.message}</div>`;
            } finally {
                testBtn.disabled = false;
                testBtn.textContent = '🔧 Test Selected Channel';
            }
        }

        // Update servo parameters when type changes
        function updateServoParameters() {
            console.log('Updating servo parameters');
            const select = document.getElementById('servoType');
            const option = select.options[select.selectedIndex];
            const servoInfo = document.getElementById('servoInfo');

            if (option.value) {
                document.getElementById('minPulse').value = option.dataset.minPulse;
                document.getElementById('maxPulse').value = option.dataset.maxPulse;
                document.getElementById('defaultAngle').value = option.dataset.defaultAngle;

                // Update info display
                document.getElementById('servoModel').textContent = `Model: ${option.dataset.model}`;
                document.getElementById('servoModes').textContent = `Modes: ${option.dataset.modes}`;
                document.getElementById('servoTorque').textContent = `Torque: ${option.dataset.torque} kg/cm`;
                document.getElementById('servoRotation').textContent = `Rotation Range: ${option.dataset.rotation}°`;
                document.getElementById('servoFeedback').textContent = `Feedback: ${option.dataset.feedback}`;
                if (option.dataset.notes) {
                    document.getElementById('servoNotes').textContent = `Notes: ${option.dataset.notes}`;
                }

                servoInfo.style.display = 'block';
            } else {
                servoInfo.style.display = 'none';
            }
        }

        // Handle test angle slider
        function updateTestAngleDisplay() {
            const angle = document.getElementById('testAngle').value;
            document.getElementById('angleValue').textContent = angle + '°';
        }

        // Show test result with status
        function showTestResult(message, isError = false) {
            const resultDiv = document.getElementById('testResult');
            resultDiv.textContent = message;
            resultDiv.style.display = 'block';
            resultDiv.className = isError ? 'error' : 'success';
        }

        // Update button states
        function updateButtonStates(testing) {
            const testButton = document.getElementById('testButton');
            const stopButton = document.getElementById('stopButton');
            testButton.disabled = testing;
            stopButton.disabled = !testing;
            isTestingServo = testing;
        }

        // Test servo functionality
        async function testServo() {
            if (isTestingServo) return;

            console.log('Testing servo');
            updateButtonStates(true);
            const angle = document.getElementById('testAngle').value;
            const usePCA9685 = document.getElementById('usePCA9685').checked;
            const channel = document.getElementById('channel').value;
            const pin = document.getElementById('pin').value;
            const servoType = document.getElementById('servoType').value;

            const testData = {
                angle,
                usePCA9685,
                channel,
                pin,
                servoType,
                duration: '1.0'
            };

            console.log('Test data:', testData);

            try {
                const response = await makeWebSocketRequest('test_servo', {
                    angle: parseFloat(angle),
                    use_pca9685: usePCA9685,
                    channel: usePCA9685 ? parseInt(channel) : null,
                    pin: usePCA9685 ? null : parseInt(pin),
                    servo_type: servoType
                });

                if (response.status === 'success') {
                    document.getElementById('testResult').innerHTML = `<div class="success">${response.message}</div>`;
                } else {
                    document.getElementById('testResult').innerHTML = `<div class="error">${response.message}</div>`;
                }
            } catch (error) {
                console.error('Error testing servo:', error);
                document.getElementById('testResult').innerHTML = `<div class="error">Error: ${error.message}</div>`;
            } finally {
                updateButtonStates(false);
            }
        }

        // Stop servo test
        async function stopServo() {
            if (!isTestingServo) return;

            console.log('Stopping servo');
            const usePCA9685 = document.getElementById('usePCA9685').checked;
            const channel = document.getElementById('channel').value;
            const pin = document.getElementById('pin').value;
            const servoType = document.getElementById('servoType').value;

            try {
                const response = await makeWebSocketRequest('test_servo', {
                    angle: 90, // Return to neutral position
                    use_pca9685: usePCA9685,
                    channel: usePCA9685 ? parseInt(channel) : null,
                    pin: usePCA9685 ? null : parseInt(pin),
                    servo_type: servoType
                });

                if (response.status === 'success') {
                    document.getElementById('testResult').innerHTML = `<div class="success">Servo stopped</div>`;
                } else {
                    document.getElementById('testResult').innerHTML = `<div class="error">Failed to stop servo</div>`;
                }
            } catch (error) {
                console.error('Error stopping servo:', error);
                document.getElementById('testResult').innerHTML = `<div class="error">Error stopping servo</div>`;
            } finally {
                updateButtonStates(false);
            }
        }

        // Modal functionality
        function openCustomizeModal() {
            const modal = document.getElementById('customizeModal');
            const select = document.getElementById('servoType');
            const option = select.options[select.selectedIndex];

            // Pre-fill current values
            document.getElementById('customMinPulse').value = document.getElementById('minPulse').value;
            document.getElementById('customMaxPulse').value = document.getElementById('maxPulse').value;
            document.getElementById('customDefaultAngle').value = document.getElementById('defaultAngle').value;
            document.getElementById('customRotationRange').value = option.dataset.rotation || '180';

            modal.style.display = 'block';
        }

        function closeCustomizeModal() {
            document.getElementById('customizeModal').style.display = 'none';
        }

        function saveCustomSettings(event) {
            event.preventDefault();

            const customSettings = {
                minPulse: parseInt(document.getElementById('customMinPulse').value),
                maxPulse: parseInt(document.getElementById('customMaxPulse').value),
                defaultAngle: parseInt(document.getElementById('customDefaultAngle').value),
                rotationRange: parseInt(document.getElementById('customRotationRange').value)
            };

            // Update hidden inputs
            document.getElementById('minPulse').value = customSettings.minPulse;
            document.getElementById('maxPulse').value = customSettings.maxPulse;
            document.getElementById('defaultAngle').value = customSettings.defaultAngle;
            document.getElementById('customSettings').value = JSON.stringify(customSettings);

            closeCustomizeModal();
        }

        // Close modal when clicking outside
        window.onclick = function (event) {
            const customizeModal = document.getElementById('customizeModal');
            const calibrationModal = document.getElementById('calibrationModal');

            if (event.target === customizeModal) {
                closeCustomizeModal();
            }

            if (event.target === calibrationModal) {
                closeCalibrationModal();
            }
        }

        // Prevent modal from closing when clicking inside modal content
        document.addEventListener('DOMContentLoaded', function () {
            const modalContent = document.querySelector('.modal-content-monsterbox');
            if (modalContent) {
                modalContent.addEventListener('click', function (event) {
                    event.stopPropagation();
                });
            }
        });

        // Calibration Modal Functions
        function openCalibrationModal(servoId) {
            console.log('Opening calibration modal for servo:', servoId);
            const modal = document.getElementById('calibrationModal');
            modal.style.display = 'block';

            // Reset modal state
            document.querySelector('.calibration-type-selection').style.display = 'block';
            document.getElementById('calibrationInterface').style.display = 'none';
            document.getElementById('saveCalibrationBtn').style.display = 'none';

            // Store servo ID for calibration
            window.currentCalibrationServoId = servoId;

            // Show servo-specific calibration recommendation
            showCalibrationRecommendation();

            // Check calibration status
            checkCalibrationStatus(servoId);
        }

        function closeCalibrationModal() {
            document.getElementById('calibrationModal').style.display = 'none';
        }

        function showCalibrationRecommendation() {
            const servoType = document.getElementById('servoType').value;
            const recommendationDiv = document.getElementById('calibrationRecommendation');

            // Servo-specific recommendations
            const recommendations = {
                'Hooyij 40kg DS3240MG': {
                    type: 'Extension/Joint Servo',
                    reason: 'This high-torque servo is ideal for arm joints and elbow movements. Use Extension calibration for precise positioning.',
                    icon: '🦴'
                },
                'GoBilda 2000 Series': {
                    type: 'Standard Position Servo',
                    reason: 'Precision servo best suited for standard position control with accurate angle positioning.',
                    icon: '📐'
                }
            };

            const recommendation = recommendations[servoType];
            if (recommendation) {
                recommendationDiv.innerHTML = `
                    <h5>${recommendation.icon} Recommended: ${recommendation.type}</h5>
                    <p>${recommendation.reason}</p>
                `;
                recommendationDiv.style.display = 'block';
            } else {
                recommendationDiv.style.display = 'none';
            }
        }

        async function checkCalibrationStatus(servoId) {
            try {
                const response = await axios.post('/parts/servo/get-positions', {
                    servo_id: servoId
                });

                if (response.data.success) {
                    const hasCalibration = Object.keys(response.data.calibrated_positions || {}).length > 0;
                    const hasSavedPositions = Object.keys(response.data.saved_positions || {}).length > 0;

                    updateCalibrationStatus(hasCalibration || hasSavedPositions);
                }
            } catch (error) {
                console.warn('Could not check calibration status:', error);
            }
        }

        function updateCalibrationStatus(isCalibrated) {
            const indicator = document.getElementById('calibrationIndicator');
            const text = document.getElementById('calibrationText');

            if (isCalibrated) {
                indicator.className = 'status-dot calibrated';
                text.textContent = 'Calibrated';
            } else {
                indicator.className = 'status-dot uncalibrated';
                text.textContent = 'Not Calibrated';
            }
        }

        function startContinuousCalibration() {
            console.log('Starting continuous servo calibration');
            loadCalibrationInterface('continuous');
        }

        function startStandardCalibration() {
            console.log('Starting standard servo calibration');
            loadCalibrationInterface('standard');
        }

        function startExtensionCalibration() {
            console.log('Starting extension servo calibration');
            loadCalibrationInterface('extension');
        }

        function loadCalibrationInterface(type) {
            const interface = document.getElementById('calibrationInterface');
            const typeSelection = document.querySelector('.calibration-type-selection');

            typeSelection.style.display = 'none';
            interface.style.display = 'block';
            document.getElementById('saveCalibrationBtn').style.display = 'block';

            // Load appropriate calibration interface
            if (type === 'continuous') {
                interface.innerHTML = getContinuousCalibrationHTML();
            } else if (type === 'standard') {
                interface.innerHTML = getStandardCalibrationHTML();
            } else if (type === 'extension') {
                interface.innerHTML = getExtensionCalibrationHTML();
            }

            window.currentCalibrationType = type;
        }

        function getContinuousCalibrationHTML() {
            return `
                <div class="continuous-calibration">
                    <h4>🎮 Continuous Rotation Servo Calibration</h4>
                    <p>Use the controls below to manually position the servo and save key positions.</p>

                    <div class="servo-controls">
                        <div class="control-group">
                            <label>Rotation Control:</label>
                            <div class="button-group">
                                <button type="button" class="button" onmousedown="startContinuousRotation('ccw', 'slow')" onmouseup="stopContinuousRotation()">↺ Left Slow</button>
                                <button type="button" class="button" onmousedown="startContinuousRotation('ccw', 'fast')" onmouseup="stopContinuousRotation()">↺↺ Left Fast</button>
                                <button type="button" class="button" onclick="stopContinuousRotation()">⏹️ Stop</button>
                                <button type="button" class="button" onmousedown="startContinuousRotation('cw', 'slow')" onmouseup="stopContinuousRotation()">↻ Right Slow</button>
                                <button type="button" class="button" onmousedown="startContinuousRotation('cw', 'fast')" onmouseup="stopContinuousRotation()">↻↻ Right Fast</button>
                            </div>
                        </div>

                        <div class="position-saving">
                            <h5>Save Positions:</h5>
                            <div class="position-buttons">
                                <button type="button" class="button" onclick="saveCalibrationPosition('forward')">💾 Forward (0°)</button>
                                <button type="button" class="button" onclick="saveCalibrationPosition('right_90')">💾 Right (90°)</button>
                                <button type="button" class="button" onclick="saveCalibrationPosition('left_90')">💾 Left (-90°)</button>
                                <button type="button" class="button" onclick="saveCalibrationPosition('backward')">💾 Backward (180°)</button>
                            </div>

                            <div class="custom-position">
                                <input type="text" id="customPositionName" placeholder="Custom position name">
                                <button type="button" class="button" onclick="saveCustomCalibrationPosition()">💾 Save Custom</button>
                            </div>
                        </div>
                    </div>

                    <div id="calibrationPositions" class="saved-positions">
                        <!-- Saved positions will appear here -->
                    </div>
                </div>
            `;
        }

        function getStandardCalibrationHTML() {
            return `
                <div class="standard-calibration">
                    <h4>📐 Standard Servo Calibration</h4>
                    <p>Calibrate the servo's minimum, center, and maximum positions.</p>

                    <div class="calibration-steps">
                        <div class="calibration-step">
                            <h5>Step 1: Minimum Position (0°)</h5>
                            <div class="pulse-control">
                                <label>Pulse Width (µs):</label>
                                <input type="range" id="minPulseCalibration" min="300" max="1500" value="500" oninput="updatePulseDisplay('min')">
                                <span id="minPulseValue">500µs</span>
                                <button type="button" class="button" onclick="testCalibrationPulse('min')">Test</button>
                            </div>
                        </div>

                        <div class="calibration-step">
                            <h5>Step 2: Center Position (90°)</h5>
                            <div class="pulse-control">
                                <label>Pulse Width (µs):</label>
                                <input type="range" id="centerPulseCalibration" min="1000" max="2000" value="1500" oninput="updatePulseDisplay('center')">
                                <span id="centerPulseValue">1500µs</span>
                                <button type="button" class="button" onclick="testCalibrationPulse('center')">Test</button>
                            </div>
                        </div>

                        <div class="calibration-step">
                            <h5>Step 3: Maximum Position (180°)</h5>
                            <div class="pulse-control">
                                <label>Pulse Width (µs):</label>
                                <input type="range" id="maxPulseCalibration" min="1500" max="3000" value="2500" oninput="updatePulseDisplay('max')">
                                <span id="maxPulseValue">2500µs</span>
                                <button type="button" class="button" onclick="testCalibrationPulse('max')">Test</button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        function getExtensionCalibrationHTML() {
            return `
                <div class="extension-calibration">
                    <h4>🦴 Extension/Joint Servo Calibration</h4>
                    <p>Calibrate servo for slow, controlled extension and retraction movements.</p>

                    <div class="extension-controls">
                        <div class="control-group">
                            <label>Extension Control:</label>
                            <div class="button-group">
                                <button type="button" class="button" onclick="testExtensionMovement('retract', 'slow')">⬅️ Retract Slow</button>
                                <button type="button" class="button" onclick="testExtensionMovement('retract', 'fast')">⬅️⬅️ Retract Fast</button>
                                <button type="button" class="button" onclick="stopExtensionMovement()">⏹️ Stop</button>
                                <button type="button" class="button" onclick="testExtensionMovement('extend', 'slow')">➡️ Extend Slow</button>
                                <button type="button" class="button" onclick="testExtensionMovement('extend', 'fast')">➡️➡️ Extend Fast</button>
                            </div>
                        </div>

                        <div class="position-markers">
                            <h5>Mark Key Positions:</h5>
                            <div class="marker-buttons">
                                <button type="button" class="button" onclick="markExtensionPosition('fully_retracted')">📍 Fully Retracted</button>
                                <button type="button" class="button" onclick="markExtensionPosition('quarter_extended')">📍 25% Extended</button>
                                <button type="button" class="button" onclick="markExtensionPosition('half_extended')">📍 50% Extended</button>
                                <button type="button" class="button" onclick="markExtensionPosition('three_quarter_extended')">📍 75% Extended</button>
                                <button type="button" class="button" onclick="markExtensionPosition('fully_extended')">📍 Fully Extended</button>
                            </div>
                        </div>
                    </div>

                    <div id="extensionPositions" class="marked-positions">
                        <!-- Marked positions will appear here -->
                    </div>
                </div>
            `;
        }

        // Calibration control functions
        async function startContinuousRotation(direction, speed) {
            if (!window.currentCalibrationServoId) return;

            try {
                await axios.post('/parts/servo/continuous-control', {
                    servo_id: window.currentCalibrationServoId,
                    direction: direction,
                    speed: speed
                });
            } catch (error) {
                console.error('Error controlling continuous servo:', error);
            }
        }

        async function stopContinuousRotation() {
            if (!window.currentCalibrationServoId) return;

            try {
                await axios.post('/parts/servo/continuous-control', {
                    servo_id: window.currentCalibrationServoId,
                    direction: 'stop'
                });
            } catch (error) {
                console.error('Error stopping continuous servo:', error);
            }
        }

        async function saveCalibrationPosition(positionName) {
            if (!window.currentCalibrationServoId) return;

            try {
                const response = await axios.post('/parts/servo/save-position', {
                    servo_id: window.currentCalibrationServoId,
                    position_name: positionName,
                    description: `${positionName} position for servo calibration`
                });

                if (response.data.success) {
                    updateCalibrationPositionsList();
                    showCalibrationMessage(`Position '${positionName}' saved!`);
                }
            } catch (error) {
                console.error('Error saving position:', error);
                showCalibrationMessage('Error saving position', true);
            }
        }

        async function saveCustomCalibrationPosition() {
            const positionName = document.getElementById('customPositionName').value.trim();
            if (!positionName) {
                showCalibrationMessage('Please enter a position name', true);
                return;
            }

            await saveCalibrationPosition(positionName);
            document.getElementById('customPositionName').value = '';
        }

        async function testCalibrationPulse(position) {
            if (!window.currentCalibrationServoId) return;

            const pulseInput = document.getElementById(`${position}PulseCalibration`);
            const pulseWidth = parseInt(pulseInput.value);

            try {
                await axios.post('/parts/servo/test-pulse', {
                    servo_id: window.currentCalibrationServoId,
                    pulse_width: pulseWidth
                });
                showCalibrationMessage(`Testing ${position} position at ${pulseWidth}µs`);
            } catch (error) {
                console.error('Error testing pulse:', error);
                showCalibrationMessage('Error testing pulse', true);
            }
        }

        function updatePulseDisplay(position) {
            const input = document.getElementById(`${position}PulseCalibration`);
            const display = document.getElementById(`${position}PulseValue`);
            display.textContent = input.value + 'µs';
        }

        async function testExtensionMovement(action, speed) {
            if (!window.currentCalibrationServoId) return;

            try {
                await axios.post('/parts/servo/extension-control', {
                    servo_id: window.currentCalibrationServoId,
                    action: action,
                    speed: speed
                });
                showCalibrationMessage(`${action} ${speed}`);
            } catch (error) {
                console.error('Error controlling extension:', error);
                showCalibrationMessage('Error controlling extension', true);
            }
        }

        async function stopExtensionMovement() {
            if (!window.currentCalibrationServoId) return;

            try {
                await axios.post('/parts/servo/extension-control', {
                    servo_id: window.currentCalibrationServoId,
                    action: 'stop'
                });
                showCalibrationMessage('Extension stopped');
            } catch (error) {
                console.error('Error stopping extension:', error);
            }
        }

        async function markExtensionPosition(positionName) {
            await saveCalibrationPosition(positionName);
        }

        function showCalibrationMessage(message, isError = false) {
            // Create or update message display
            let messageDiv = document.getElementById('calibrationMessage');
            if (!messageDiv) {
                messageDiv = document.createElement('div');
                messageDiv.id = 'calibrationMessage';
                messageDiv.className = 'calibration-message';
                document.getElementById('calibrationInterface').appendChild(messageDiv);
            }

            messageDiv.textContent = message;
            messageDiv.className = `calibration-message ${isError ? 'error' : 'success'}`;
            messageDiv.style.display = 'block';

            // Auto-hide after 3 seconds
            setTimeout(() => {
                messageDiv.style.display = 'none';
            }, 3000);
        }

        async function updateCalibrationPositionsList() {
            if (!window.currentCalibrationServoId) return;

            try {
                const response = await axios.post('/parts/servo/get-positions', {
                    servo_id: window.currentCalibrationServoId
                });

                if (response.data.success) {
                    const positions = response.data.saved_positions || {};
                    const positionsDiv = document.getElementById('calibrationPositions');

                    if (positionsDiv && Object.keys(positions).length > 0) {
                        positionsDiv.innerHTML = '<h5>Saved Positions:</h5>' +
                            Object.keys(positions).map(name =>
                                `<div class="saved-position">${name}</div>`
                            ).join('');
                    }
                }
            } catch (error) {
                console.error('Error updating positions list:', error);
            }
        }

        async function saveCalibration() {
            showCalibrationMessage('Calibration saved successfully!');
            updateCalibrationStatus(true);

            // Close modal after short delay
            setTimeout(() => {
                closeCalibrationModal();
            }, 1500);
        }

        // Initialize calibration status on page load
        document.addEventListener('DOMContentLoaded', function () {
            if (currentServoId) {
                checkCalibrationStatus(currentServoId);
                loadSavedPositionsForTesting();
                checkServoTypeForContinuousControl();
            }
        });

        // Load saved positions for testing
        async function loadSavedPositionsForTesting() {
            if (!currentServoId) return;

            try {
                const response = await axios.post('/parts/servo/get-positions', {
                    servo_id: currentServoId.toString()
                });

                if (response.data.success) {
                    const positions = { ...response.data.saved_positions, ...response.data.calibrated_positions };
                    populatePositionButtons(positions);
                }
            } catch (error) {
                console.error('Error loading positions for testing:', error);
            }
        }

        // Populate position buttons for testing
        function populatePositionButtons(positions) {
            const container = document.getElementById('positionButtons');
            const section = document.getElementById('savedPositionsTest');

            if (!positions || Object.keys(positions).length === 0) {
                section.style.display = 'none';
                return;
            }

            container.innerHTML = '';
            section.style.display = 'block';

            Object.entries(positions).forEach(([key, position]) => {
                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'position-btn';
                button.textContent = position.description || key;
                button.onclick = () => testSavedPosition(key, position);
                container.appendChild(button);
            });
        }

        // Test a saved position - REMOVED FOR NOW

        // Check if servo supports continuous rotation
        function checkServoTypeForContinuousControl() {
            const servoTypeSelect = document.getElementById('servoType');
            const continuousSection = document.getElementById('continuousControlTest');

            if (!servoTypeSelect || !continuousSection) return;

            const selectedOption = servoTypeSelect.options[servoTypeSelect.selectedIndex];
            const isContinuous = selectedOption && selectedOption.dataset.continuous === 'true';

            continuousSection.style.display = isContinuous ? 'block' : 'none';
        }

        // Update continuous control visibility when servo type changes
        function updateServoType() {
            const select = document.getElementById('servoType');
            const option = select.options[select.selectedIndex];

            // Update pulse width fields
            document.getElementById('minPulse').value = option.dataset.minPulse;
            document.getElementById('maxPulse').value = option.dataset.maxPulse;
            document.getElementById('defaultAngle').value = option.dataset.defaultAngle;

            // Update continuous control visibility
            checkServoTypeForContinuousControl();
        }

        // Continuous rotation control
        let continuousRotationInterval = null;

        // WebSocket request function
        async function makeWebSocketRequest(type, data) {
            return new Promise((resolve, reject) => {
                const ws = new WebSocket('ws://localhost:8779');

                ws.onopen = function () {
                    ws.send(JSON.stringify({ type, ...data }));
                };

                ws.onmessage = function (event) {
                    const response = JSON.parse(event.data);
                    ws.close();
                    resolve(response);
                };

                ws.onerror = function (error) {
                    ws.close();
                    reject(error);
                };

                ws.onclose = function (event) {
                    if (event.code !== 1000) {
                        reject(new Error('WebSocket connection failed'));
                    }
                };
            });
        }

        // Update test angle display
        function updateTestAngleDisplay() {
            const slider = document.getElementById('testAngle');
            const display = document.getElementById('angleValue');
            if (slider && display) {
                display.textContent = slider.value + '°';
            }
        }

        // Continuous rotation control functions for main form
        async function startContinuousRotation(direction, speed) {
            if (!currentServoId) return;

            try {
                const response = await axios.post('/parts/servo/continuous-control', {
                    servo_id: currentServoId,
                    direction: direction,
                    speed: speed
                });

                if (response.data?.success) {
                    console.log(`Started ${direction} rotation at ${speed} speed`);
                } else {
                    console.error('Failed to start rotation:', response.data?.message);
                }
            } catch (error) {
                console.error('Error starting continuous rotation:', error);
            }
        }

        async function stopContinuousRotation() {
            if (!currentServoId) return;

            try {
                const response = await axios.post('/parts/servo/continuous-control', {
                    servo_id: currentServoId,
                    direction: 'stop'
                });

                if (response.data?.success) {
                    console.log('Rotation stopped');
                } else {
                    console.error('Failed to stop rotation');
                }
            } catch (error) {
                console.error('Error stopping rotation:', error);
            }
        }
    </script>
</body>

