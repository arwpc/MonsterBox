<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>

<body>
    <h1>
        <%= title %>
    </h1>

    <form action="<%= action %>?characterId=<%= character.id %>" method="POST">
        <% if (part.id) { %>
            <input type="hidden" name="id" value="<%= part.id %>">
            <% } %>
                <input type="hidden" name="characterId" value="<%= character.id %>">
                <input type="hidden" name="type" value="microphone">

                <div class="form-section">
                    <h3>🎤 Basic Microphone Settings</h3>

                    <div class="form-group">
                        <label for="name">Microphone Name:</label>
                        <input type="text" id="name" name="name" value="<%= part.name || '' %>" required>
                        <small>Give your microphone a descriptive name</small>
                    </div>

                    <div class="form-group">
                        <label for="description">Description:</label>
                        <textarea id="description" name="description" rows="3"><%= part.description || '' %></textarea>
                        <small>Optional description of the microphone</small>
                    </div>
                </div>

                <div class="form-section">
                    <h3>🔧 Hardware Configuration</h3>

                    <div class="form-group">
                        <label for="deviceId">Microphone Device:</label>
                        <select id="deviceId" name="deviceId">
                            <option value="default" <%=part.deviceId==='default' || !part.deviceId ? 'selected' : '' %>
                                >Default System Microphone</option>
                            <!-- Microphone devices will be populated dynamically -->
                        </select>
                        <button type="button" id="refreshDevicesButton" class="refresh-btn">🔄 Refresh Devices</button>
                        <small id="deviceIdHelp">Select your preferred microphone from the list of available
                            devices</small>
                    </div>

                    <div class="form-group">
                        <label for="sampleRate">Sample Rate (Hz):</label>
                        <select id="sampleRate" name="sampleRate">
                            <option value="8000" <%=part.sampleRate===8000 ? 'selected' : '' %>>8000 Hz</option>
                            <option value="16000" <%=part.sampleRate===16000 || !part.sampleRate ? 'selected' : '' %>
                                >16000 Hz (Recommended)</option>
                            <option value="22050" <%=part.sampleRate===22050 ? 'selected' : '' %>>22050 Hz</option>
                            <option value="44100" <%=part.sampleRate===44100 ? 'selected' : '' %>>44100 Hz</option>
                            <option value="48000" <%=part.sampleRate===48000 ? 'selected' : '' %>>48000 Hz</option>
                        </select>
                        <small>Higher sample rates provide better quality but use more resources</small>
                    </div>

                    <div class="form-group">
                        <label for="channels">Audio Channels:</label>
                        <select id="channels" name="channels">
                            <option value="1" <%=part.channels===1 || !part.channels ? 'selected' : '' %>>1 (Mono) -
                                Recommended</option>
                            <option value="2" <%=part.channels===2 ? 'selected' : '' %>>2 (Stereo)</option>
                        </select>
                        <small>Mono is recommended for speech recognition</small>
                    </div>
                </div>

                <div class="form-section">
                    <h3>🎚️ Audio Processing</h3>

                    <div class="form-group">
                        <label for="sensitivity">Sensitivity:</label>
                        <input type="range" id="sensitivity" name="sensitivity" min="0.1" max="3.0" step="0.1"
                            value="<%= part.sensitivity || 1.0 %>">
                        <span id="sensitivityValue">
                            <%= part.sensitivity || 1.0 %>
                        </span>
                        <small>Microphone input sensitivity (0.1 - 3.0)</small>
                    </div>

                    <div class="form-group checkbox-group">
                        <label>
                            <input type="checkbox" id="echoCancellation" name="echoCancellation"
                                <%=part.echoCancellation !==false ? 'checked' : '' %>>
                            Echo Cancellation
                        </label>
                        <small>Reduces echo and feedback</small>
                    </div>

                    <div class="form-group checkbox-group">
                        <label>
                            <input type="checkbox" id="noiseSuppression" name="noiseSuppression"
                                <%=part.noiseSuppression !==false ? 'checked' : '' %>>
                            Noise Suppression
                        </label>
                        <small>Reduces background noise</small>
                    </div>

                    <div class="form-group checkbox-group">
                        <label>
                            <input type="checkbox" id="autoGainControl" name="autoGainControl" <%=part.autoGainControl
                                !==false ? 'checked' : '' %>>
                            Auto Gain Control
                        </label>
                        <small>Automatically adjusts microphone gain</small>
                    </div>
                </div>

                <div class="form-section">
                    <h3>🗣️ Voice Activation</h3>

                    <div class="form-group checkbox-group">
                        <label>
                            <input type="checkbox" id="voiceActivation" name="voiceActivation" <%=part.voiceActivation
                                ? 'checked' : '' %>>
                            Voice Activation Detection
                        </label>
                        <small>Only process audio when voice is detected</small>
                    </div>

                    <div class="form-group" id="voiceActivationThresholdDiv"
                        style="display: <%= part.voiceActivation ? 'block' : 'none' %>;">
                        <label for="voiceActivationThreshold">Voice Activation Threshold:</label>
                        <input type="range" id="voiceActivationThreshold" name="voiceActivationThreshold" min="0.01"
                            max="1.0" step="0.01" value="<%= part.voiceActivationThreshold || 0.1 %>">
                        <span id="thresholdValue">
                            <%= part.voiceActivationThreshold || 0.1 %>
                        </span>
                        <small>Threshold for voice activation (0.01 - 1.0)</small>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="button primary-btn">💾 Save Microphone</button>
                    <a href="/parts?characterId=<%= character.id %>" class="button secondary-btn">↩️ Back to Parts</a>
                    <a href="/ai-management/stt?characterId=<%= character.id %>" class="button">🎙️ Configure STT</a>
                </div>
    </form>

    <!-- Microphone Management Section (only visible for existing microphones) -->
    <% if (part.id) { %>
    <div class="form-section">
        <h3>🎛️ Microphone Management</h3>
        <div class="management-tabs">
            <div class="tab-navigation">
                <button class="tab-button active" data-tab="test">🧪 Test</button>
                <button class="tab-button" data-tab="monitor">👁️ Monitor</button>
                <button class="tab-button" data-tab="stt">🎙️ STT Integration</button>
            </div>

            <!-- Test Tab -->
            <div class="tab-content active" id="test-tab">
                <div class="test-section">
                    <h4>🔊 Audio Test</h4>
                    <button type="button" class="button" onclick="testMicrophone()">🎤 Test Microphone</button>
                    <button type="button" class="button" onclick="testAudioLevels()">📊 Test Audio Levels</button>
                    <div id="testStatus" class="test-status"></div>
                    <pre id="testOutput" class="test-output"></pre>
                </div>
            </div>

            <!-- Monitor Tab -->
            <div class="tab-content" id="monitor-tab">
                <div class="monitor-section">
                    <h4>📊 Live Monitoring</h4>
                    <div class="audio-level-container">
                        <div class="level-bar-container">
                            <div class="level-bar" id="audioLevelBar"></div>
                        </div>
                        <div class="level-text" id="audioLevelText">0%</div>
                    </div>
                    <div class="button-group">
                        <button type="button" class="button" onclick="startMonitoring()">▶️ Start Monitoring</button>
                        <button type="button" class="button secondary-btn" onclick="stopMonitoring()">⏹️ Stop Monitoring</button>
                    </div>
                </div>
            </div>

            <!-- STT Integration Tab -->
            <div class="tab-content" id="stt-tab">
                <div class="stt-section">
                    <h4>🎙️ Speech-to-Text Integration</h4>
                    <button type="button" class="button" onclick="testSTTIntegration()">🧪 Test STT</button>
                    <a href="/ai-management/stt?characterId=<%= character.id %>" class="button">⚙️ Configure STT</a>
                    <div id="transcriptionOutput" class="transcription-output"></div>
                </div>
            </div>
        </div>
    </div>
    <% } else { %>
    <div class="form-section">
        <p class="info-message">💡 Save the microphone first to access monitoring and testing features.</p>
    </div>
    <% } %>

    <style>
        .form-section {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }

        .form-section h3 {
            color: #00ff00;
            margin-bottom: 15px;
            border-bottom: 1px solid rgba(0, 255, 0, 0.3);
            padding-bottom: 10px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #00ff00;
            font-weight: bold;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 8px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 0, 0.5);
            border-radius: 4px;
            color: #ffffff;
        }

        .form-group input[type="range"] {
            width: 70%;
            margin-right: 10px;
        }

        .checkbox-group label {
            display: flex;
            align-items: center;
            cursor: pointer;
        }

        .checkbox-group input[type="checkbox"] {
            width: auto;
            margin-right: 10px;
        }

        .form-group small {
            display: block;
            color: #888;
            font-size: 12px;
            margin-top: 5px;
        }

        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 30px;
        }

        .info-section {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }

        .info-section h3 {
            color: #00ff00;
            margin-bottom: 15px;
            border-bottom: 1px solid rgba(0, 255, 0, 0.3);
            padding-bottom: 10px;
        }

        .info-section p {
            color: #ffffff;
            margin-bottom: 20px;
            line-height: 1.6;
        }

        .management-link {
            text-align: center;
            margin: 20px 0;
        }

        .features-list {
            margin-top: 20px;
        }

        .features-list h4 {
            color: #00ff00;
            margin-bottom: 10px;
        }

        .features-list ul {
            list-style: none;
            padding: 0;
        }

        .features-list li {
            color: #ffffff;
            padding: 5px 0;
            border-bottom: 1px solid rgba(0, 255, 0, 0.1);
        }

        .features-list li:last-child {
            border-bottom: none;
        }

        #sensitivityValue,
        #thresholdValue {
            color: #00ff00;
            font-weight: bold;
            min-width: 40px;
            display: inline-block;
        }

        .refresh-btn {
            background: rgba(0, 255, 0, 0.2);
            border: 1px solid #00ff00;
            border-radius: 4px;
            color: #00ff00;
            padding: 5px 10px;
            margin-left: 10px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s ease;
        }

        .refresh-btn:hover {
            background: rgba(0, 255, 0, 0.4);
            transform: scale(1.05);
        }

        .refresh-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Management Tab Styles */
        .management-tabs {
            margin-top: 20px;
        }

        .tab-navigation {
            display: flex;
            border-bottom: 1px solid rgba(0, 255, 0, 0.3);
            margin-bottom: 20px;
        }

        .tab-button {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-bottom: none;
            color: #00ff00;
            padding: 10px 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-right: 5px;
        }

        .tab-button:hover {
            background: rgba(0, 255, 0, 0.1);
        }

        .tab-button.active {
            background: rgba(0, 255, 0, 0.2);
            border-bottom: 2px solid #00ff00;
        }

        .tab-content {
            display: none;
            padding: 20px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 8px;
        }

        .tab-content.active {
            display: block;
        }

        .test-section, .monitor-section, .stt-section {
            margin-bottom: 20px;
        }

        .test-status, .test-output {
            margin-top: 10px;
            padding: 10px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 4px;
            color: #ffffff;
        }

        .audio-level-container {
            display: flex;
            align-items: center;
            gap: 15px;
            margin: 15px 0;
        }

        .level-bar-container {
            flex: 1;
            height: 30px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 15px;
            overflow: hidden;
            position: relative;
        }

        .level-bar {
            height: 100%;
            width: 0%;
            background: #00ff00;
            transition: width 0.1s ease;
            border-radius: 15px;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
        }

        .level-text {
            min-width: 50px;
            color: #00ff00;
            font-weight: bold;
            text-align: center;
            font-family: 'Courier New', monospace;
            text-shadow: 0 0 5px rgba(0, 255, 0, 0.5);
        }

        .button-group {
            display: flex;
            gap: 10px;
            margin: 10px 0;
        }

        .transcription-output {
            margin-top: 15px;
            padding: 15px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 4px;
            min-height: 100px;
        }

        .stt-result {
            padding: 10px;
            border-radius: 4px;
            margin: 10px 0;
        }

        .stt-result.success {
            background: rgba(0, 255, 0, 0.2);
            border: 1px solid #00ff00;
        }

        .stt-result.error {
            background: rgba(255, 0, 64, 0.2);
            border: 1px solid #ff0040;
        }

        .info-message {
            color: #00ff00;
            text-align: center;
            padding: 20px;
            font-style: italic;
        }

    </style>

    <script>
        // Update sensitivity value display
        const sensitivitySlider = document.getElementById('sensitivity');
        const sensitivityValue = document.getElementById('sensitivityValue');
        if (sensitivitySlider && sensitivityValue) {
            sensitivitySlider.addEventListener('input', function () {
                sensitivityValue.textContent = this.value;
            });
        }

        // Update threshold value display
        const thresholdSlider = document.getElementById('voiceActivationThreshold');
        const thresholdValue = document.getElementById('thresholdValue');
        if (thresholdSlider && thresholdValue) {
            thresholdSlider.addEventListener('input', function () {
                thresholdValue.textContent = this.value;
            });
        }

        // Toggle voice activation threshold visibility
        const voiceActivationCheckbox = document.getElementById('voiceActivation');
        const thresholdDiv = document.getElementById('voiceActivationThresholdDiv');
        if (voiceActivationCheckbox && thresholdDiv) {
            voiceActivationCheckbox.addEventListener('change', function () {
                thresholdDiv.style.display = this.checked ? 'block' : 'none';
            });
        }

        // Load available microphone devices
        async function loadMicrophoneDevices() {
            const deviceSelect = document.getElementById('deviceId');
            const refreshButton = document.getElementById('refreshDevicesButton');
            const helpText = document.getElementById('deviceIdHelp');

            try {
                refreshButton.disabled = true;
                refreshButton.textContent = '🔄 Loading...';
                helpText.textContent = 'Loading available microphone devices...';

                const response = await axios.get('/parts/microphone/devices');
                const data = response.data;

                if (data.success && data.microphones) {
                    // Clear existing options except default
                    const defaultOption = deviceSelect.querySelector('option[value="default"]');
                    deviceSelect.innerHTML = '';
                    deviceSelect.appendChild(defaultOption);

                    // Add discovered microphones
                    data.microphones.forEach(mic => {
                        const option = document.createElement('option');
                        option.value = mic.index.toString();
                        option.textContent = `${mic.name} (${mic.max_input_channels} ch, ${mic.default_sample_rate}Hz)`;

                        // Check if this device was previously selected
                        const currentDeviceId = '<%= part.deviceId || "default" %>';
                        if (currentDeviceId === mic.index.toString()) {
                            option.selected = true;
                        }

                        deviceSelect.appendChild(option);
                    });

                    helpText.textContent = `Found ${data.microphones.length} microphone device(s). Select your preferred microphone.`;
                } else {
                    helpText.textContent = 'No microphone devices found or discovery failed.';
                    console.error('Microphone discovery failed:', data.error);
                }
            } catch (error) {
                console.error('Error loading microphone devices:', error);
                helpText.textContent = 'Error loading microphone devices. Using default only.';
            } finally {
                refreshButton.disabled = false;
                refreshButton.textContent = '🔄 Refresh Devices';
            }
        }

        // Refresh devices button handler
        document.getElementById('refreshDevicesButton').addEventListener('click', loadMicrophoneDevices);



        // Management functions
        const characterId = '<%= character.id %>';
        const partId = '<%= part.id || "" %>';

        // Tab switching
        function switchTab(tabName) {
            // Hide all tab contents
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });

            // Remove active class from all tab buttons
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });

            // Show selected tab content
            document.getElementById(tabName + '-tab').classList.add('active');

            // Add active class to selected tab button
            document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');
        }

        // Add event listeners for tab buttons
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.tab-button').forEach(button => {
                button.addEventListener('click', function() {
                    switchTab(this.dataset.tab);
                });
            });
        });

        async function testMicrophone() {
            const testStatus = document.getElementById('testStatus');
            const testOutput = document.getElementById('testOutput');
            testStatus.textContent = 'Testing microphone...';
            testOutput.textContent = '';

            try {
                const microphoneConfig = {
                    deviceId: document.getElementById('deviceId').value,
                    sampleRate: parseInt(document.getElementById('sampleRate').value),
                    channels: parseInt(document.getElementById('channels').value),
                    sensitivity: parseFloat(document.getElementById('sensitivity').value)
                };

                const response = await axios.post('/parts/api/microphone/test', {
                    config: microphoneConfig,
                    duration: 5
                });

                if (response.data.success) {
                    testStatus.textContent = 'Microphone test completed successfully';
                    testOutput.textContent = JSON.stringify(response.data.results, null, 2);
                } else {
                    testStatus.textContent = 'Microphone test failed';
                    testOutput.textContent = response.data.error || 'Unknown error';
                }
            } catch (error) {
                console.error('Error testing microphone:', error);
                testStatus.textContent = 'Error testing microphone';
                testOutput.textContent = error.message;
            }
        }

        async function testAudioLevels() {
            const testStatus = document.getElementById('testStatus');
            testStatus.textContent = 'Testing audio levels...';

            try {
                const response = await axios.post('/parts/api/microphone/test-levels', {
                    microphoneId: partId || 'default',
                    duration: 10
                });

                if (response.data.success) {
                    testStatus.textContent = 'Audio level test completed';
                } else {
                    testStatus.textContent = 'Audio level test failed';
                }
            } catch (error) {
                console.error('Error testing audio levels:', error);
                testStatus.textContent = 'Error testing audio levels';
            }
        }

        async function startMonitoring() {
            if (!partId) {
                showNotification('Please save the microphone first before starting monitoring', 'error');
                return;
            }

            try {
                const response = await axios.post(`/parts/api/microphone/${partId}/start-monitoring`);

                if (response.data.success) {
                    showNotification('Monitoring started', 'success');
                    startAudioLevelUpdates();
                } else {
                    showNotification('Failed to start monitoring', 'error');
                }
            } catch (error) {
                console.error('Error starting monitoring:', error);
                showNotification('Error starting monitoring', 'error');
            }
        }

        async function stopMonitoring() {
            if (!partId) {
                showNotification('Please save the microphone first before stopping monitoring', 'error');
                return;
            }

            try {
                const response = await axios.post(`/parts/api/microphone/${partId}/stop-monitoring`);

                if (response.data.success) {
                    showNotification('Monitoring stopped', 'success');
                    stopAudioLevelUpdates();
                } else {
                    showNotification('Failed to stop monitoring', 'error');
                }
            } catch (error) {
                console.error('Error stopping monitoring:', error);
                showNotification('Error stopping monitoring', 'error');
            }
        }

        async function testSTTIntegration() {
            const sttResults = document.getElementById('transcriptionOutput');
            sttResults.innerHTML = '<div class="loading">Testing STT integration...</div>';

            try {
                const response = await axios.post('/parts/api/microphone/test-stt', {
                    microphoneId: partId || 'default',
                    characterId: characterId,
                    duration: 10
                });

                if (response.data.success) {
                    sttResults.innerHTML = `
                        <div class="stt-result success">
                            <h6>STT Test Successful</h6>
                            <p><strong>Transcription:</strong> ${response.data.transcription}</p>
                            <p><strong>Confidence:</strong> ${response.data.confidence}%</p>
                            <p><strong>Language:</strong> ${response.data.language}</p>
                        </div>
                    `;
                } else {
                    sttResults.innerHTML = `
                        <div class="stt-result error">
                            <h6>STT Test Failed</h6>
                            <p>${response.data.error}</p>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error testing STT integration:', error);
                sttResults.innerHTML = `
                    <div class="stt-result error">
                        <h6>STT Test Error</h6>
                        <p>${error.message}</p>
                    </div>
                `;
            }
        }

        // Audio level monitoring
        let audioLevelInterval;
        function startAudioLevelUpdates() {
            if (!partId) {
                console.warn('Cannot start audio level updates: microphone not saved yet');
                return;
            }

            audioLevelInterval = setInterval(async () => {
                try {
                    const response = await axios.get(`/parts/api/microphone/${partId}/levels`);
                    if (response.data.success) {
                        updateAudioLevelDisplay(response.data.levels);
                    }
                } catch (error) {
                    console.error('Error getting audio levels:', error);
                }
            }, 100);
        }

        function stopAudioLevelUpdates() {
            if (audioLevelInterval) {
                clearInterval(audioLevelInterval);
                audioLevelInterval = null;
            }
        }

        function updateAudioLevelDisplay(levels) {
            const levelBar = document.getElementById('audioLevelBar');
            const levelText = document.getElementById('audioLevelText');

            if (levelBar && levelText) {
                const percentage = Math.round(levels.average * 100);
                levelBar.style.width = percentage + '%';
                levelText.textContent = percentage + '%';

                // Color coding
                if (percentage > 80) {
                    levelBar.style.backgroundColor = '#ff0040';
                } else if (percentage > 60) {
                    levelBar.style.backgroundColor = '#ffff00';
                } else {
                    levelBar.style.backgroundColor = '#00ff00';
                }
            }
        }

        function showNotification(message, type) {
            // Simple notification - could be enhanced
            const notification = document.createElement('div');
            notification.className = `notification ${type}`;
            notification.textContent = message;
            notification.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                padding: 10px 20px;
                border-radius: 4px;
                color: white;
                z-index: 1000;
                background: ${type === 'success' ? '#00ff00' : '#ff0040'};
            `;
            document.body.appendChild(notification);

            setTimeout(() => {
                document.body.removeChild(notification);
            }, 3000);
        }

        // Load devices when page loads
        document.addEventListener('DOMContentLoaded', function () {
            loadMicrophoneDevices();
        });
    </script>
</body>

</html>