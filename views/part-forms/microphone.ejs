        }

        .instruction-step {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
            align-items: flex-start;
        }

        .step-number {
            background: #00ff00;
            color: #000000;
            width: 2rem;
            height: 2rem;
            border-radius: 50%;
