            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(0, 255, 0, 0.2);
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .monitor-title {
            color: #00ff00;
            font-size: 1.1rem;
            margin: 0 0 1rem 0;
        }

