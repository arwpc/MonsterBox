            box-shadow: 0 4px 20px rgba(0, 255, 0, 0.3);
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1400px;
            margin: 0 auto;
        }

        .logo {
            color: #00ff00;
            font-size: 1.8rem;
            font-weight: bold;
            text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
            margin: 0;
        }

        .breadcrumb {
            color: #ffffff;
            font-size: 0.9rem;
            margin-top: 0.5rem;
        }

        .breadcrumb a {
            color: #00ff00;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .breadcrumb a:hover {
            text-shadow: 0 0 5px rgba(0, 255, 0, 0.8);
        }

        .separator {
            margin: 0 0.5rem;
            color: #666;
        }

        .character-info {
