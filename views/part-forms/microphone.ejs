<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - MonsterBox</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>

<body>
    <header class="main-header">
        <div class="header-content">
            <div class="logo-section">
                <h1 class="logo">MonsterBox</h1>
                <div class="breadcrumb">
                    <a href="/">🏠 Home</a>
                    <span class="separator">›</span>
                    <a href="/parts?characterId=<%= character.id %>">🔧 Parts</a>
                    <span class="separator">›</span>
                    <span class="current">🎤 <%= title %></span>
                </div>
            </div>
            <div class="character-info">
                <span class="character-name">Character: <%= character.name %></span>
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="page-header">
            <h2 class="page-title">🎤 <%= title %></h2>
            <p class="page-description">Configure, test, and monitor microphone settings for real-world use</p>
        </div>

        <!-- Main Configuration Container -->
        <div class="microphone-container">

            <!-- Left Panel: Configuration Form -->
            <div class="config-panel">
                <form id="microphoneForm" action="<%= action %>?characterId=<%= character.id %>" method="POST">
                    <% if (part.id) { %>
                        <input type="hidden" name="id" value="<%= part.id %>">
                    <% } %>
                    <input type="hidden" name="characterId" value="<%= character.id %>">
                    <input type="hidden" name="type" value="microphone">

                    <!-- Basic Information Section -->
                    <div class="config-section">
                        <h3 class="section-title">📝 Basic Information</h3>

                        <div class="form-group">
                            <label for="name" class="form-label">Microphone Name</label>
                            <input type="text" id="name" name="name" value="<%= part.name || '' %>"
                                   class="form-input" required placeholder="e.g., Main Recording Mic">
                            <div class="form-help">Give your microphone a descriptive name</div>
                        </div>

                        <div class="form-group">
                            <label for="description" class="form-label">Description</label>
                            <textarea id="description" name="description" rows="2" class="form-textarea"
                                      placeholder="Optional description for this microphone's purpose"><%= part.description || '' %></textarea>
                        </div>
                    </div>

                    <!-- Device Selection Section -->
                    <div class="config-section">
                        <h3 class="section-title">🎤 Device Selection</h3>

                        <div class="form-group">
                            <label for="deviceId" class="form-label">Audio Input Device</label>
                            <div class="device-selector">
                                <select id="deviceId" name="deviceId" class="form-select">
                                    <option value="default" <%=part.deviceId==='default' || !part.deviceId ? 'selected' : '' %>>
                                        Loading devices...
                                    </option>
                                </select>
                                <button type="button" id="refreshDevicesButton" class="refresh-btn">
                                    🔄 Refresh
                                </button>
                            </div>
                            <div class="form-help">Select your preferred microphone from available devices</div>
                        </div>
                    </div>

                    <!-- Audio Configuration Section -->
                    <div class="config-section">
                        <h3 class="section-title">🔧 Audio Configuration</h3>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="sampleRate" class="form-label">Sample Rate</label>
                                <select id="sampleRate" name="sampleRate" class="form-select">
                                    <option value="8000" <%=part.sampleRate===8000 ? 'selected' : '' %>>8000 Hz</option>
                                    <option value="16000" <%=part.sampleRate===16000 || !part.sampleRate ? 'selected' : '' %>>16000 Hz (Recommended)</option>
                                    <option value="22050" <%=part.sampleRate===22050 ? 'selected' : '' %>>22050 Hz</option>
                                    <option value="44100" <%=part.sampleRate===44100 ? 'selected' : '' %>>44100 Hz</option>
                                    <option value="48000" <%=part.sampleRate===48000 ? 'selected' : '' %>>48000 Hz</option>
                                </select>
                                <div class="form-help">Higher rates = better quality, more resources</div>
                            </div>

                            <div class="form-group">
                                <label for="channels" class="form-label">Audio Channels</label>
                                <select id="channels" name="channels" class="form-select">
                                    <option value="1" <%=part.channels===1 || !part.channels ? 'selected' : '' %>>1 (Mono) - Recommended</option>
                                    <option value="2" <%=part.channels===2 ? 'selected' : '' %>>2 (Stereo)</option>
                                </select>
                                <div class="form-help">Mono is recommended for speech recognition</div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="sensitivity" class="form-label">Sensitivity</label>
                            <div class="slider-container">
                                <input type="range" id="sensitivity" name="sensitivity" min="0.1" max="3.0" step="0.1"
                                       value="<%= part.sensitivity || 1.0 %>" class="form-slider">
                                <span id="sensitivityValue" class="slider-value"><%= part.sensitivity || 1.0 %></span>
                            </div>
                            <div class="form-help">Adjust microphone sensitivity (0.1 = quiet, 3.0 = very sensitive)</div>
                        </div>
                    </div>

                    <!-- Form Actions -->
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">💾 Save Microphone</button>
                        <a href="/parts?characterId=<%= character.id %>" class="btn btn-secondary">↩️ Back to Parts</a>
                        <a href="/ai-management/stt?characterId=<%= character.id %>" class="btn btn-accent">🎙️ Configure STT</a>
                    </div>
                </form>
            </div>

            <!-- Right Panel: Live Testing & Monitoring -->
            <div class="testing-panel">
                <div class="panel-header">
                    <h3 class="panel-title">🧪 Live Testing & Monitoring</h3>
                    <p class="panel-description">Test your microphone settings in real-time while configuring</p>
                </div>
                <!-- Audio Processing Options -->
                <div class="config-section">
                    <h3 class="section-title">🎚️ Audio Processing</h3>

                    <div class="checkbox-grid">
                        <div class="checkbox-item">
                            <label class="checkbox-label">
                                <input type="checkbox" id="echoCancellation" name="echoCancellation"
                                       <%=part.echoCancellation !==false ? 'checked' : '' %>>
                                <span class="checkmark"></span>
                                Echo Cancellation
                            </label>
                            <div class="form-help">Reduces echo and feedback</div>
                        </div>

                        <div class="checkbox-item">
                            <label class="checkbox-label">
                                <input type="checkbox" id="noiseSuppression" name="noiseSuppression"
                                       <%=part.noiseSuppression !==false ? 'checked' : '' %>>
                                <span class="checkmark"></span>
                                Noise Suppression
                            </label>
                            <div class="form-help">Reduces background noise</div>
                        </div>

                        <div class="checkbox-item">
                            <label class="checkbox-label">
                                <input type="checkbox" id="autoGainControl" name="autoGainControl"
                                       <%=part.autoGainControl !==false ? 'checked' : '' %>>
                                <span class="checkmark"></span>
                                Auto Gain Control
                            </label>
                            <div class="form-help">Automatically adjusts microphone gain</div>
                        </div>
                    </div>
                </div>

                <!-- Voice Activation Detection -->
                <div class="config-section">
                    <h3 class="section-title">🗣️ Voice Activation (VAD)</h3>

                    <div class="checkbox-item">
                        <label class="checkbox-label">
                            <input type="checkbox" id="voiceActivation" name="voiceActivation"
                                   <%=part.voiceActivation ? 'checked' : '' %>>
                            <span class="checkmark"></span>
                            Voice Activation Detection
                        </label>
                        <div class="form-help">Only process audio when voice is detected</div>
                    </div>

                    <div class="form-group" id="voiceActivationThresholdDiv"
                         style="display: <%= part.voiceActivation ? 'block' : 'none' %>;">
                        <label for="voiceActivationThreshold" class="form-label">VAD Threshold</label>
                        <div class="slider-container">
                            <input type="range" id="voiceActivationThreshold" name="voiceActivationThreshold"
                                   min="0.01" max="1.0" step="0.01" value="<%= part.voiceActivationThreshold || 0.1 %>"
                                   class="form-slider">
                            <span id="thresholdValue" class="slider-value"><%= part.voiceActivationThreshold || 0.1 %></span>
                        </div>
                        <div class="form-help">Threshold for voice activation (0.01 = very sensitive, 1.0 = less sensitive)</div>
                    </div>
                </div>

                <!-- Live Audio Level Monitor -->
                <div class="audio-monitor">
                    <h4 class="monitor-title">📊 Live Audio Levels</h4>
                    <div class="level-display">
                        <div class="level-bar-container">
                            <div class="level-bar" id="audioLevelBar"></div>
                        </div>
                        <div class="level-text" id="audioLevelText">0%</div>
                    </div>
                    <div class="monitor-controls">
                        <button type="button" class="btn btn-small" onclick="startLiveMonitoring()">▶️ Start</button>
                        <button type="button" class="btn btn-small btn-secondary" onclick="stopLiveMonitoring()">⏹️ Stop</button>
                    </div>
                </div>

                <!-- Quick Test Buttons -->
                <div class="quick-tests">
                    <h4 class="test-title">🧪 Quick Tests</h4>
                    <div class="test-buttons">
                        <button type="button" class="btn btn-test" onclick="testMicrophone()">🎤 Test Audio</button>
                        <button type="button" class="btn btn-test" onclick="testSTTIntegration()">🗣️ Test STT</button>
                        <button type="button" class="btn btn-test" onclick="testVAD()">🎯 Test VAD</button>
                    </div>
                </div>

                <!-- Test Results -->
                <div class="test-results">
                    <h4 class="results-title">📋 Test Results</h4>
                    <div id="testStatus" class="test-status">Ready to test...</div>
                    <div id="testOutput" class="test-output"></div>
                    <div id="transcriptionOutput" class="transcription-output"></div>
                </div>
            </div>
        </div>

        <!-- Instructions Panel -->
        <div class="instructions-panel">
            <h3 class="instructions-title">💡 How to Use</h3>
            <div class="instructions-content">
                <div class="instruction-step">
                    <span class="step-number">1</span>
                    <div class="step-content">
                        <strong>Configure Settings</strong>
                        <p>Select your microphone device and adjust audio settings on the left</p>
                    </div>
                </div>
                <div class="instruction-step">
                    <span class="step-number">2</span>
                    <div class="step-content">
                        <strong>Test Live Audio</strong>
                        <p>Use the live monitor to see audio levels while speaking</p>
                    </div>
                </div>
                <div class="instruction-step">
                    <span class="step-number">3</span>
                    <div class="step-content">
                        <strong>Tune Settings</strong>
                        <p>Adjust sensitivity and processing options based on test results</p>
                    </div>
                </div>
                <div class="instruction-step">
                    <span class="step-number">4</span>
                    <div class="step-content">
                        <strong>Save Configuration</strong>
                        <p>Save your settings when everything sounds good</p>
                    </div>
                </div>
            </div>
        </div>


    <style>
        /* Modern Microphone Form Styling */
