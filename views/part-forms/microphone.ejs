<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - MonsterBox</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1><%= title %></h1>
            <p class="subtitle">Configure microphone settings</p>
        </div>

        <form action="<%= action %>" method="POST" class="form">
            <% if (part.id) { %>
                <input type="hidden" name="id" value="<%= part.id %>">
            <% } %>
            <input type="hidden" name="type" value="microphone">

            <!-- Basic Information -->
            <div class="form-section">
                <h3>📝 Basic Information</h3>

                <div class="form-group">
                    <label for="characterId">Character:</label>
                    <select id="characterId" name="characterId" required>
                        <option value="">Select a character...</option>
                        <% characters.forEach(char => { %>
                            <option value="<%= char.id %>" <%= (part.characterId && part.characterId == char.id) || (character && character.id == char.id) ? 'selected' : '' %>>
                                <%= char.char_name || char.name %>
                            </option>
                        <% }); %>
                    </select>
                    <small>Select which character this microphone belongs to</small>
                </div>

                <div class="form-group">
                    <label for="name">Microphone Name:</label>
                    <input type="text" id="name" name="name" value="<%= part.name || '' %>" required
                           placeholder="e.g., Main Character Microphone">
                </div>

                <div class="form-group">
                    <label for="description">Description:</label>
                    <textarea id="description" name="description" rows="3"
                              placeholder="Optional description for this microphone"><%= part.description || '' %></textarea>
                </div>
            </div>

            <!-- Device Configuration -->
            <div class="form-section">
                <h3>🎤 Device Configuration</h3>

                <div class="form-group">
                    <label for="deviceId">Audio Input Device:</label>
                    <div class="device-selector">
                        <select id="deviceId" name="deviceId">
                            <option value="default" <%=part.deviceId==='default' || !part.deviceId ? 'selected' : '' %>>
                                Loading devices...
                            </option>
                        </select>
                        <button type="button" id="refreshInputDevices" class="button small-btn">🔄 Refresh</button>
                    </div>
                    <small>Select the microphone input device</small>
                </div>

                <div class="form-group">
                    <label for="outputDevice">Audio Output Device:</label>
                    <div class="device-selector">
                        <select id="outputDevice" name="outputDevice">
                            <option value="default" <%=(part.outputDevice||'default')==='default' ? 'selected' : '' %>>
                                Loading devices...
                            </option>
                        </select>
                        <button type="button" id="refreshOutputDevices" class="button small-btn">🔄 Refresh</button>
                    </div>
                    <small>Select the speaker output device for audio playback</small>
                </div>
            </div>

            <!-- Audio Settings -->
            <div class="form-section">
                <h3>🔧 Audio Settings</h3>

                <div class="form-row">
                    <div class="form-group">
                        <label for="sampleRate">Sample Rate:</label>
                        <select id="sampleRate" name="sampleRate">
                            <option value="8000" <%=part.sampleRate===8000 ? 'selected' : '' %>>8000 Hz</option>
                            <option value="16000" <%=part.sampleRate===16000 || !part.sampleRate ? 'selected' : '' %>>16000 Hz (Recommended)</option>
                            <option value="22050" <%=part.sampleRate===22050 ? 'selected' : '' %>>22050 Hz</option>
                            <option value="44100" <%=part.sampleRate===44100 ? 'selected' : '' %>>44100 Hz</option>
                            <option value="48000" <%=part.sampleRate===48000 ? 'selected' : '' %>>48000 Hz</option>
                        </select>
                        <small>Higher rates = better quality, more resources</small>
                    </div>

                    <div class="form-group">
                        <label for="channels">Audio Channels:</label>
                        <select id="channels" name="channels">
                            <option value="1" <%=part.channels===1 || !part.channels ? 'selected' : '' %>>1 (Mono) - Recommended</option>
                            <option value="2" <%=part.channels===2 ? 'selected' : '' %>>2 (Stereo)</option>
                        </select>
                        <small>Mono is recommended for speech recognition</small>
                    </div>
                </div>

                <div class="form-group">
                    <label for="sensitivity">Sensitivity:</label>
                    <input type="range" id="sensitivity" name="sensitivity" min="0.1" max="3.0" step="0.1"
                           value="<%= part.sensitivity || 1.0 %>" class="form-control">
                    <span id="sensitivityValue"><%= part.sensitivity || 1.0 %></span>
                    <small>Adjust microphone sensitivity (0.1 = quiet, 3.0 = very sensitive)</small>
                </div>
            </div>

            <!-- Audio Processing -->
            <div class="form-section">
                <h3>🎚️ Audio Processing</h3>

                <div class="checkbox-group">
                    <label class="checkbox-label">
                        <input type="checkbox" name="echoCancellation" <%=part.echoCancellation !== false ? 'checked' : '' %>>
                        Echo Cancellation
                    </label>
                    <small>Reduces echo and feedback</small>
                </div>

                <div class="checkbox-group">
                    <label class="checkbox-label">
                        <input type="checkbox" name="noiseSuppression" <%=part.noiseSuppression !== false ? 'checked' : '' %>>
                        Noise Suppression
                    </label>
                    <small>Reduces background noise</small>
                </div>

                <div class="checkbox-group">
                    <label class="checkbox-label">
                        <input type="checkbox" name="autoGainControl" <%=part.autoGainControl !== false ? 'checked' : '' %>>
                        Auto Gain Control
                    </label>
                    <small>Automatically adjusts microphone gain</small>
                </div>

                <div class="checkbox-group">
                    <label class="checkbox-label">
                        <input type="checkbox" id="voiceActivation" name="voiceActivation" <%=part.voiceActivation ? 'checked' : '' %>>
                        Voice Activation Detection
                    </label>
                    <small>Only process audio when voice is detected</small>
                </div>

                <div class="form-group" id="vadThresholdGroup" style="display: <%= part.voiceActivation ? 'block' : 'none' %>;">
                    <label for="voiceActivationThreshold">VAD Threshold:</label>
                    <input type="range" id="voiceActivationThreshold" name="voiceActivationThreshold"
                           min="0.01" max="1.0" step="0.01" value="<%= part.voiceActivationThreshold || 0.1 %>" class="form-control">
                    <span id="vadThresholdValue"><%= part.voiceActivationThreshold || 0.1 %></span>
                    <small>Voice detection sensitivity</small>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <button type="submit" class="button primary-btn">💾 Save Microphone</button>
                <a href="/parts" class="button secondary-btn">↩️ Back to Parts</a>
                <button type="button" id="configureSTT" class="button">🎙️ Configure STT</button>
                <button type="button" id="testMicrophone" class="button">🧪 Test Microphone</button>
            </div>
        </form>
    </div>

    <script>
        // Update slider values in real-time
        document.getElementById('sensitivity').addEventListener('input', function() {
            document.getElementById('sensitivityValue').textContent = this.value;
        });

        document.getElementById('voiceActivationThreshold').addEventListener('input', function() {
            document.getElementById('vadThresholdValue').textContent = this.value;
        });

        // Show/hide VAD threshold based on voice activation checkbox
        document.getElementById('voiceActivation').addEventListener('change', function() {
            const vadGroup = document.getElementById('vadThresholdGroup');
            vadGroup.style.display = this.checked ? 'block' : 'none';
        });

        // Load input devices
        async function loadInputDevices() {
            try {
                const response = await axios.get('/parts/api/microphone/devices');
                const deviceSelect = document.getElementById('deviceId');
                const currentValue = '<%= part.deviceId || "" %>';

                deviceSelect.innerHTML = '<option value="default">Default System Microphone</option>';

                if (response.data.success && response.data.microphones) {
                    response.data.microphones.forEach(mic => {
                        if (mic.id !== 'default') {
                            const option = document.createElement('option');
                            option.value = mic.id;
                            option.textContent = mic.name;
                            if (mic.id === currentValue) {
                                option.selected = true;
                            }
                            deviceSelect.appendChild(option);
                        }
                    });
                }
            } catch (error) {
                console.error('Error loading input devices:', error);
            }
        }

        // Load output devices
        async function loadOutputDevices() {
            try {
                const response = await axios.get('/parts/api/speaker/devices');
                const deviceSelect = document.getElementById('outputDevice');
                const currentValue = '<%= part.outputDevice || "" %>';

                deviceSelect.innerHTML = '<option value="default">Default System Speaker</option>';

                if (response.data.success && response.data.devices) {
                    response.data.devices.forEach(device => {
                        if (device.id !== 'default') {
                            const option = document.createElement('option');
                            option.value = device.id;
                            option.textContent = device.name;
                            if (device.id === currentValue) {
                                option.selected = true;
                            }
                            deviceSelect.appendChild(option);
                        }
                    });
                }
            } catch (error) {
                console.error('Error loading output devices:', error);
            }
        }

        // Event listeners for device refresh buttons
        document.getElementById('refreshInputDevices').addEventListener('click', loadInputDevices);
        document.getElementById('refreshOutputDevices').addEventListener('click', loadOutputDevices);

        // Configure STT button functionality
        document.getElementById('configureSTT').addEventListener('click', function() {
            const characterId = document.getElementById('characterId').value;
            if (characterId) {
                window.location.href = `/ai-management/stt?characterId=${characterId}`;
            } else {
                alert('Please select a character first');
            }
        });

        // Test microphone functionality
        document.getElementById('testMicrophone').addEventListener('click', async function() {
            try {
                const deviceId = document.getElementById('deviceId').value;
                const response = await axios.post('/parts/api/microphone/test', { deviceId });

                if (response.data.success) {
                    alert('✅ Microphone test successful!');
                } else {
                    alert('❌ Microphone test failed: ' + (response.data.error || 'Unknown error'));
                }
            } catch (error) {
                console.error('Error testing microphone:', error);
                alert('❌ Error testing microphone: ' + error.message);
            }
        });

        // Load devices on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadInputDevices();
            loadOutputDevices();
        });
    </script>
</body>
</html>


