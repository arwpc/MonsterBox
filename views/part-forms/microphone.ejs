            text-align: center;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(0, 255, 0, 0.2);
        }

        .panel-title {
            color: #00ff00;
            font-size: 1.5rem;
            margin: 0;
