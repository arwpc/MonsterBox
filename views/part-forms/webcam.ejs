<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/console-error-monitor.js"></script>
    <style>
        /* Modern MonsterBox Webcam Form Styling */
        body {
            background-color: #000000;
            color: #00ff00;
            font-family: 'Courier New', monospace;
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        /* Enhanced dropdown visibility */
        select {
            background-color: #001100 !important;
            color: #00ff00 !important;
            border: 1px solid #00ff00 !important;
            padding: 8px !important;
            border-radius: 4px !important;
            font-family: 'Courier New', monospace !important;
            font-size: 14px !important;
            min-height: 36px !important;
        }

        select option {
            background-color: #001100 !important;
            color: #00ff00 !important;
            padding: 8px !important;
            border: none !important;
        }

        select option:hover,
        select option:focus,
        select option:checked {
            background-color: #003300 !important;
            color: #00ff00 !important;
        }

        /* Compact controls panel styling */
        .compact-controls-panel {
            background: rgba(0, 34, 34, 0.8) !important;
            border: 1px solid #004444 !important;
            border-radius: 8px !important;
            padding: 15px !important;
            margin-top: 15px !important;
        }

        .compact-controls-panel h4 {
            margin: 0 !important;
            color: #00ff00 !important;
            font-size: 1.1em !important;
        }

        header {
            background: linear-gradient(135deg, #001100, #002200);
            border-bottom: 2px solid #00ff00;
            padding: 20px;
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.3);
        }

        header h1 {
            margin: 0;
            color: #00ff00;
            text-shadow: 0 0 10px #00ff00;
            font-size: 2.5em;
            text-align: center;
        }

        nav {
            margin-top: 15px;
            text-align: center;
        }

        nav a {
            color: #00ff00;
            text-decoration: none;
            margin: 0 15px;
            padding: 8px 16px;
            border: 1px solid #00ff00;
            border-radius: 4px;
            transition: all 0.3s ease;
        }

        nav a:hover {
            background-color: #003300;
            box-shadow: 0 0 10px #00ff00;
        }

        main {
            padding: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .webcam-preview {
            width: 100%;
            max-width: 640px;
            height: 480px;
            border: 2px solid #00ff00;
            background-color: #001100;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 20px auto;
            color: #00ff00;
            border-radius: 8px;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.2);
            position: relative;
            overflow: hidden;
        }

        .webcam-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .webcam-controls {
            display: flex;
            gap: 15px;
            margin: 20px 0;
            justify-content: center;
            flex-wrap: wrap;
        }

        .detection-status {
            padding: 15px;
            margin: 15px 0;
            border-radius: 8px;
            font-weight: bold;
            border: 2px solid;
            text-align: center;
        }

        .detection-success {
            background-color: rgba(0, 68, 0, 0.3);
            color: #00ff00;
            border-color: #00ff00;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.2);
        }

        .detection-error {
            background-color: rgba(68, 0, 0, 0.3);
            color: #ff0000;
            border-color: #ff0000;
            box-shadow: 0 0 10px rgba(255, 0, 0, 0.2);
        }

        .detection-warning {
            background-color: rgba(68, 51, 0, 0.3);
            color: #ffaa00;
            border-color: #ffaa00;
            box-shadow: 0 0 10px rgba(255, 170, 0, 0.2);
        }
        .form-section {
            background: linear-gradient(135deg, #001800, #002200);
            border: 2px solid #004400;
            border-radius: 12px;
            padding: 25px;
            margin: 25px 0;
            box-shadow: 0 0 20px rgba(0, 68, 0, 0.2);
            position: relative;
        }

        .form-section::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, #00ff00, #004400, #00ff00);
            border-radius: 12px;
            z-index: -1;
            opacity: 0.3;
        }

        .form-section h3 {
            margin-top: 0;
            color: #00ff00;
            border-bottom: 2px solid #004400;
            padding-bottom: 15px;
            font-size: 1.4em;
            text-shadow: 0 0 5px #00ff00;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #00ff00;
            font-weight: bold;
            text-shadow: 0 0 3px #00ff00;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            color: #00ff00;
            border: 2px solid #004400;
            padding: 12px;
            border-radius: 6px;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: #00ff00;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
            outline: none;
        }

        .settings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .controls-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .checkbox-controls {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .control-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 25px;
            flex-wrap: wrap;
        }

        .form-group input[type="range"] {
            width: 100%;
            margin: 10px 0;
            height: 6px;
            background: #004400;
            border-radius: 3px;
            outline: none;
        }

        .form-group input[type="range"]::-webkit-slider-thumb {
            appearance: none;
            width: 20px;
            height: 20px;
            background: #00ff00;
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
        }

        .form-group input[type="range"]::-moz-range-thumb {
            width: 20px;
            height: 20px;
            background: #00ff00;
            border-radius: 50%;
            cursor: pointer;
            border: none;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
        }

        .range-value {
            display: inline-block;
            min-width: 50px;
            text-align: center;
            font-weight: bold;
            color: #00ff00;
            background: rgba(0, 255, 0, 0.1);
            padding: 6px 12px;
            border-radius: 6px;
            margin-left: 15px;
            border: 1px solid #004400;
            text-shadow: 0 0 3px #00ff00;
        }
        .button {
            background: linear-gradient(135deg, #003300, #004400);
            color: #00ff00;
            border: 2px solid #00ff00;
            padding: 12px 24px;
            border-radius: 8px;
            cursor: pointer;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            text-align: center;
            min-width: 120px;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.2);
        }

        .button:hover {
            background: linear-gradient(135deg, #004400, #005500);
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.4);
            transform: translateY(-2px);
        }

        .button:active {
            transform: translateY(0);
        }

        .button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .primary-btn {
            background: linear-gradient(135deg, #004400, #006600);
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
        }

        .secondary-btn {
            background: linear-gradient(135deg, #002200, #003300);
            border-color: #008800;
            color: #008800;
        }

        .warning-btn {
            background: linear-gradient(135deg, #664400, #775500);
            color: #ffaa00;
            border-color: #ffaa00;
            box-shadow: 0 0 10px rgba(255, 170, 0, 0.2);
        }

        .warning-btn:hover {
            background: linear-gradient(135deg, #775500, #886600);
            box-shadow: 0 0 20px rgba(255, 170, 0, 0.4);
        }

        .success-btn {
            background: linear-gradient(135deg, #004400, #006600);
            color: #00ff00;
            border-color: #00ff00;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
        }

        .success-btn:hover {
            background: linear-gradient(135deg, #005500, #007700);
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.5);
        }

        .button-group {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 30px;
            flex-wrap: wrap;
        }

        .streaming-status {
            background: rgba(0, 68, 0, 0.2);
            border: 2px solid #004400;
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
            text-align: center;
        }

        .streaming-active {
            border-color: #00ff00;
            background: rgba(0, 255, 0, 0.1);
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.2);
        }

        .streaming-inactive {
            border-color: #666666;
            background: rgba(102, 102, 102, 0.1);
            color: #666666;
        }

        @media (max-width: 768px) {
            .settings-grid,
            .controls-grid,
            .checkbox-controls {
                grid-template-columns: 1fr;
            }

            .webcam-controls {
                flex-direction: column;
                align-items: center;
            }

            .button-group {
                flex-direction: column;
                align-items: center;
            }

            .button {
                width: 100%;
                max-width: 300px;
            }
        }
    </style>
</head>
<body>
    <header>
        <h1><%= title %></h1>
        <nav>
            <a href="/parts?characterId=<%= character ? character.id : '' %>">← Back to Parts</a>
            <a href="/characters/<%= character ? character.id : '' %>/edit">📝 Edit Character</a>
            <a href="/">🏠 Home</a>
        </nav>
    </header>

    <main>
        <form action="<%= action %>" method="POST" id="webcamForm">
            <input type="hidden" name="type" value="webcam">
            <% if (part && part.id) { %>
                <input type="hidden" name="id" value="<%= part.id %>">
            <% } %>
            
            <div class="form-group">
                <label for="name">Webcam Name:</label>
                <input type="text" id="name" name="name" value="<%= part && part.name || '' %>" required 
                       placeholder="e.g., Orlok Head Camera">
            </div>

            <div class="form-group">
                <label for="characterId">Character:</label>
                <select id="characterId" name="characterId" required>
                    <% characters.forEach(function(char) { %>
                        <option value="<%= char.id %>" <%= (part && part.characterId === char.id) || (character && character.id === char.id) ? 'selected' : '' %>>
                            <%= char.char_name %>
                        </option>
                    <% }); %>
                </select>
            </div>

            <div class="form-section">
                <h3>📹 Camera Detection & Configuration</h3>

                <!-- Streaming Status Display -->
                <div id="streamingStatus" class="streaming-status streaming-inactive">
                    <strong>🔴 Streaming Status:</strong> <span id="streamStatusText">Checking...</span><br>
                    <small>Auto-start streams are managed by the Webcam Startup Service</small>
                </div>

                <div class="webcam-controls">
                    <button type="button" id="refreshCamerasBtn" class="button secondary-btn">🔄 Refresh Camera List</button>
                    <button type="button" id="stopStreamForConfigBtn" class="button warning-btn" style="display: none;">⏸️ Stop Stream for Config</button>
                    <button type="button" id="restartStreamBtn" class="button success-btn" style="display: none;">▶️ Restart Stream</button>
                </div>

                <div id="detectionStatus" class="detection-status">
                    <span>🔍 Auto-detecting cameras...</span>
                </div>

                <div class="settings-grid">
                    <div class="form-group">
                        <label for="deviceId">Camera Device:</label>
                        <select id="deviceId" name="deviceId" required>
                            <option value="">Select a camera device...</option>
                            <% if (part && part.deviceId !== undefined) { %>
                                <option value="<%= part.deviceId %>" selected>Camera <%= part.deviceId %></option>
                            <% } %>
                        </select>
                        <small>Physical camera device identifier</small>
                    </div>

                    <div class="form-group">
                        <label for="devicePath">Device Path:</label>
                        <input type="text" id="devicePath" name="devicePath"
                               value="<%= part && part.devicePath || '' %>"
                               placeholder="/dev/video0" readonly>
                        <small>Automatically set based on selected device</small>
                    </div>
                </div>
            </div>

            <!-- Streaming & Camera Settings moved below Live Preview -->

            <!-- Camera Controls moved below Live Preview -->

            <div class="form-section">
                <h3>📺 Live Preview</h3>

                <div class="webcam-preview" id="webcamPreview">
                    <div style="text-align: center; color: #00ff00;">
                        <div style="font-size: 3em; margin-bottom: 10px;">📹</div>
                        <div>No preview available</div>
                        <small>Click "Webcam On" to start preview</small>
                    </div>
                </div>

                <!-- Compact Settings & Controls Panel -->
                <div class="compact-controls-panel" style="background: rgba(0, 34, 34, 0.8); border: 1px solid #004444; border-radius: 8px; padding: 15px; margin-top: 15px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                        <h4 style="margin: 0; color: #00ff00;">⚙️ Quick Settings & Controls</h4>
                        <div class="webcam-controls">
                            <button type="button" id="webcamToggleBtn" class="button primary-btn">📹 Webcam On</button>
                        </div>
                    </div>

                    <!-- Streaming Settings Row -->
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 15px;">
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="resolution" style="display: block; margin-bottom: 5px;">Resolution:</label>
                            <select id="resolution" name="resolution" style="width: 100%; padding: 5px; background: #001100; color: #00ff00; border: 1px solid #00ff00;">
                                <option value="640x480" <%= (part && part.resolution === '640x480') ? 'selected' : '' %>>640x480 (VGA)</option>
                                <option value="1280x720" <%= (part && part.resolution === '1280x720') || (!part) ? 'selected' : '' %>>1280x720 (HD)</option>
                                <option value="1920x1080" <%= (part && part.resolution === '1920x1080') ? 'selected' : '' %>>1920x1080 (Full HD)</option>
                                <option value="2560x1440" <%= (part && part.resolution === '2560x1440') ? 'selected' : '' %>>2560x1440 (2K)</option>
                            </select>
                        </div>

                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="fps" style="display: block; margin-bottom: 5px;">Frame Rate:</label>
                            <select id="fps" name="fps" style="width: 100%; padding: 5px; background: #001100; color: #00ff00; border: 1px solid #00ff00;">
                                <option value="15" <%= (part && part.fps === 15) ? 'selected' : '' %>>15 FPS (Low)</option>
                                <option value="30" <%= (part && part.fps === 30) || (!part) ? 'selected' : '' %>>30 FPS (Standard)</option>
                                <option value="60" <%= (part && part.fps === 60) ? 'selected' : '' %>>60 FPS (High)</option>
                            </select>
                        </div>

                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="streamQuality" style="display: block; margin-bottom: 5px;">Quality:</label>
                            <select id="streamQuality" name="streamQuality" style="width: 100%; padding: 5px; background: #001100; color: #00ff00; border: 1px solid #00ff00;">
                                <option value="50" <%= (part && part.streamQuality === 50) ? 'selected' : '' %>>50% (Low)</option>
                                <option value="75" <%= (part && part.streamQuality === 75) ? 'selected' : '' %>>75% (Balanced)</option>
                                <option value="85" <%= (part && part.streamQuality === 85) || (!part) ? 'selected' : '' %>>85% (High)</option>
                                <option value="95" <%= (part && part.streamQuality === 95) ? 'selected' : '' %>>95% (Maximum)</option>
                            </select>
                        </div>

                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="status" style="display: block; margin-bottom: 5px;">Auto-Start:</label>
                            <select id="status" name="status" style="width: 100%; padding: 5px; background: #001100; color: #00ff00; border: 1px solid #00ff00;">
                                <option value="active" <%= (part && part.status === 'active') || (!part) ? 'selected' : '' %>>✅ Active</option>
                                <option value="inactive" <%= (part && part.status === 'inactive') ? 'selected' : '' %>>❌ Inactive</option>
                            </select>
                        </div>
                    </div>

                    <!-- Camera Controls Row -->
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin-bottom: 15px;">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <label for="brightness" style="min-width: 70px; font-size: 0.9em;">Brightness:</label>
                            <input type="range" id="brightness" name="brightness" min="-64" max="64" value="<%= (part && part.cameraControls && part.cameraControls.brightness !== undefined) ? part.cameraControls.brightness : 0 %>" step="1" style="flex: 1;">
                            <span class="range-value" id="brightnessValue" style="min-width: 30px; font-size: 0.8em;"><%= (part && part.cameraControls && part.cameraControls.brightness !== undefined) ? part.cameraControls.brightness : 0 %></span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <label for="contrast" style="min-width: 70px; font-size: 0.9em;">Contrast:</label>
                            <input type="range" id="contrast" name="contrast" min="0" max="64" value="<%= (part && part.cameraControls && part.cameraControls.contrast !== undefined) ? part.cameraControls.contrast : 32 %>" step="1" style="flex: 1;">
                            <span class="range-value" id="contrastValue" style="min-width: 30px; font-size: 0.8em;"><%= (part && part.cameraControls && part.cameraControls.contrast !== undefined) ? part.cameraControls.contrast : 32 %></span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <label for="saturation" style="min-width: 70px; font-size: 0.9em;">Saturation:</label>
                            <input type="range" id="saturation" name="saturation" min="0" max="128" value="<%= (part && part.cameraControls && part.cameraControls.saturation !== undefined) ? part.cameraControls.saturation : 64 %>" step="1" style="flex: 1;">
                            <span class="range-value" id="saturationValue" style="min-width: 30px; font-size: 0.8em;"><%= (part && part.cameraControls && part.cameraControls.saturation !== undefined) ? part.cameraControls.saturation : 64 %></span>
                        </div>
                    </div>

                    <!-- Additional Controls -->
                    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <label>
                                <input type="checkbox" id="white_balance_automatic" name="white_balance_automatic" <%= (part && part.cameraControls && part.cameraControls.white_balance_automatic !== undefined) ? (part.cameraControls.white_balance_automatic ? 'checked' : '') : 'checked' %>>
                                Auto White Balance
                            </label>
                            <select id="auto_exposure" name="auto_exposure" style="padding: 3px; background: #001100; color: #00ff00; border: 1px solid #00ff00;">
                                <option value="0" <%= (part && part.cameraControls && part.cameraControls.auto_exposure === 0) ? 'selected' : '' %>>Manual Exposure</option>
                                <option value="1" <%= (part && part.cameraControls && part.cameraControls.auto_exposure === 1) ? 'selected' : '' %>>Auto Exposure</option>
                                <option value="3" <%= (part && part.cameraControls && part.cameraControls.auto_exposure === 3) || (!part || !part.cameraControls) ? 'selected' : '' %>>Aperture Priority</option>
                            </select>
                        </div>
                        <div style="display: flex; gap: 10px;">
                            <button type="button" id="resetControlsBtn" class="button secondary-btn" style="padding: 5px 10px; font-size: 0.9em;">🔄 Reset</button>
                            <button type="button" id="applyControlsBtn" class="button primary-btn" style="padding: 5px 10px; font-size: 0.9em;">✅ Apply</button>
                        </div>
                    </div>

                    <!-- Hidden fields for remaining camera controls -->
                    <div style="display: none;">
                        <input type="range" id="hue" name="hue" min="-40" max="40" value="<%= (part && part.cameraControls && part.cameraControls.hue !== undefined) ? part.cameraControls.hue : 0 %>" step="1">
                        <span class="range-value" id="hueValue"><%= (part && part.cameraControls && part.cameraControls.hue !== undefined) ? part.cameraControls.hue : 0 %></span>
                        <input type="range" id="gamma" name="gamma" min="72" max="500" value="<%= (part && part.cameraControls && part.cameraControls.gamma !== undefined) ? part.cameraControls.gamma : 100 %>" step="1">
                        <span class="range-value" id="gammaValue"><%= (part && part.cameraControls && part.cameraControls.gamma !== undefined) ? part.cameraControls.gamma : 100 %></span>
                        <input type="range" id="gain" name="gain" min="0" max="100" value="<%= (part && part.cameraControls && part.cameraControls.gain !== undefined) ? part.cameraControls.gain : 0 %>" step="1">
                        <span class="range-value" id="gainValue"><%= (part && part.cameraControls && part.cameraControls.gain !== undefined) ? part.cameraControls.gain : 0 %></span>
                        <input type="range" id="sharpness" name="sharpness" min="0" max="14" value="<%= (part && part.cameraControls && part.cameraControls.sharpness !== undefined) ? part.cameraControls.sharpness : 10 %>" step="1">
                        <span class="range-value" id="sharpnessValue"><%= (part && part.cameraControls && part.cameraControls.sharpness !== undefined) ? part.cameraControls.sharpness : 10 %></span>
                        <input type="range" id="backlight_compensation" name="backlight_compensation" min="0" max="160" value="<%= (part && part.cameraControls && part.cameraControls.backlight_compensation !== undefined) ? part.cameraControls.backlight_compensation : 80 %>" step="1">
                        <span class="range-value" id="backlight_compensationValue"><%= (part && part.cameraControls && part.cameraControls.backlight_compensation !== undefined) ? part.cameraControls.backlight_compensation : 80 %></span>
                        <input type="range" id="white_balance_temperature" name="white_balance_temperature" min="2800" max="6500" value="<%= (part && part.cameraControls && part.cameraControls.white_balance_temperature !== undefined) ? part.cameraControls.white_balance_temperature : 4600 %>" step="1">
                        <span class="range-value" id="white_balance_temperatureValue"><%= (part && part.cameraControls && part.cameraControls.white_balance_temperature !== undefined) ? part.cameraControls.white_balance_temperature : 4600 %></span>
                        <input type="range" id="exposure_time_absolute" name="exposure_time_absolute" min="1" max="5000" value="<%= (part && part.cameraControls && part.cameraControls.exposure_time_absolute !== undefined) ? part.cameraControls.exposure_time_absolute : 157 %>" step="1">
                        <span class="range-value" id="exposure_time_absoluteValue"><%= (part && part.cameraControls && part.cameraControls.exposure_time_absolute !== undefined) ? part.cameraControls.exposure_time_absolute : 157 %></span>
                        <input type="checkbox" id="exposure_dynamic_framerate" name="exposure_dynamic_framerate" <%= (part && part.cameraControls && part.cameraControls.exposure_dynamic_framerate) ? 'checked' : '' %>>
                        <select id="power_line_frequency" name="power_line_frequency">
                            <option value="0" <%= (part && part.cameraControls && part.cameraControls.power_line_frequency === 0) ? 'selected' : '' %>>Disabled</option>
                            <option value="1" <%= (part && part.cameraControls && part.cameraControls.power_line_frequency === 1) || (!part || !part.cameraControls) ? 'selected' : '' %>>50 Hz</option>
                            <option value="2" <%= (part && part.cameraControls && part.cameraControls.power_line_frequency === 2) ? 'selected' : '' %>>60 Hz</option>
                        </select>
                    </div>

                    <!-- Stream Status -->
                    <div id="streamStatus" class="streaming-status" style="display: none; margin-top: 15px; padding: 10px; background: rgba(0, 68, 68, 0.3); border-radius: 4px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
                            <div>
                                <strong>🔴 Status:</strong> <span id="streamStatusText">Unknown</span>
                            </div>
                            <div>
                                <strong>👥 Clients:</strong> <span id="streamClients">0</span>
                            </div>
                            <div>
                                <strong>🌐 URL:</strong> <code id="streamUrl" style="font-size: 0.8em;">-</code>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="button-group">
                <button type="submit" class="button primary-btn">💾 Save Webcam</button>
                <a href="/parts?characterId=<%= character ? character.id : '' %>" class="button secondary-btn">❌ Cancel</a>
            </div>
        </form>
    </main>

    <script>
        let testStream = null;
        let streamStatusInterval = null;

        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🚀 Initializing Modern Webcam Configuration');

            // Initialize camera controls
            initializeCameraControls();

            // Auto-detect cameras on page load
            detectCameras();

            // Check streaming status
            checkStreamingStatus();

            // Set up periodic status updates
            setInterval(checkStreamingStatus, 10000); // Check every 10 seconds
        });

        // Check if character has active streaming
        async function checkStreamingStatus() {
            const characterId = document.getElementById('characterId')?.value;
            if (!characterId) return;

            try {
                const response = await fetch(`/api/streaming/status/${characterId}`);
                const data = await response.json();

                const statusElement = document.getElementById('streamingStatus');
                const statusText = document.getElementById('streamStatusText');

                if (data.success && data.hasStream) {
                    statusElement.className = 'streaming-status streaming-active';
                    statusText.textContent = 'Active (Auto-started)';

                    // Show stop button for configuration
                    document.getElementById('stopStreamForConfigBtn').style.display = 'inline-block';
                    document.getElementById('restartStreamBtn').style.display = 'none';
                } else {
                    statusElement.className = 'streaming-status streaming-inactive';
                    statusText.textContent = 'Inactive';

                    // Show restart button if stream was stopped for config
                    const wasActive = statusElement.dataset.wasActive === 'true';
                    if (wasActive) {
                        document.getElementById('stopStreamForConfigBtn').style.display = 'none';
                        document.getElementById('restartStreamBtn').style.display = 'inline-block';
                    }
                }
            } catch (error) {
                console.warn('Could not check streaming status:', error);
                document.getElementById('streamStatusText').textContent = 'Unknown';
            }
        }

        // Cleanup on page unload
        window.addEventListener('beforeunload', function() {
            if (streamStatusInterval) {
                clearInterval(streamStatusInterval);
            }
        });

        // Camera detection functionality
        async function detectCameras(isRefresh = false) {
            const btn = document.getElementById('refreshCamerasBtn');
            const status = document.getElementById('detectionStatus');
            const deviceSelect = document.getElementById('deviceId');
            const devicePath = document.getElementById('devicePath');

            console.log('🔍 Starting modern camera detection...', { isRefresh });

            if (btn) {
                btn.disabled = true;
                btn.textContent = isRefresh ? '🔄 Refreshing...' : '🔍 Detecting...';
            }

            // Show modern progress indicator
            status.style.display = 'block';
            status.className = 'detection-status';
            status.innerHTML = `
                <div style="display: flex; align-items: center; gap: 12px; justify-content: center;">
                    <div style="width: 20px; height: 20px; border: 3px solid #00ff00; border-top: 3px solid transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                    <span style="font-weight: bold;">🔍 Scanning for camera devices...</span>
                </div>
                <style>
                    @keyframes spin {
                        0% { transform: rotate(0deg); }
                        100% { transform: rotate(360deg); }
                    }
                </style>
            `;

            try {
                const characterId = document.getElementById('characterId').value;
                console.log('📡 Character ID:', characterId);

                // Use the new camera list endpoint
                status.innerHTML = `
                    <div style="display: flex; align-items: center; gap: 12px; justify-content: center;">
                        <div style="width: 20px; height: 20px; border: 3px solid #00ff00; border-top: 3px solid transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                        <span style="font-weight: bold;">🌐 Detecting available cameras...</span>
                    </div>
                `;

                console.log('🔍 Using modern camera detection...');
                const response = await fetch('/camera/list');

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }

                const cameras = await response.json();
                console.log('📹 Camera detection response:', cameras);

                if (cameras && cameras.length > 0) {
                    console.log('✅ Cameras found:', cameras);
                    status.className = 'detection-status detection-success';
                    status.innerHTML = `
                        <div style="text-align: center;">
                            <div style="font-size: 1.2em; margin-bottom: 8px;">✅ Found ${cameras.length} camera(s)</div>
                            <small>Select a camera device below to configure</small>
                        </div>
                    `;

                    // Clear existing options except the first one
                    deviceSelect.innerHTML = '<option value="">Select a camera device...</option>';

                    // Add detected cameras
                    cameras.forEach(cameraGroup => {
                        if (cameraGroup.devices && cameraGroup.devices.length > 0) {
                            cameraGroup.devices.forEach(camera => {
                                console.log('📹 Adding camera option:', camera);
                                const option = document.createElement('option');
                                option.value = camera.id;

                                let cameraInfo = camera.name || `Camera ${camera.id}`;
                                if (camera.path) {
                                    cameraInfo += ` (${camera.path})`;
                                }

                                option.textContent = cameraInfo;
                                option.dataset.path = camera.path || `/dev/video${camera.id}`;
                                option.dataset.name = camera.name || `Camera ${camera.id}`;

                                deviceSelect.appendChild(option);
                            });
                        }
                    });

                    // Update device path when selection changes
                    deviceSelect.addEventListener('change', function() {
                        const selectedOption = this.options[this.selectedIndex];
                        if (selectedOption && selectedOption.dataset.path) {
                            devicePath.value = selectedOption.dataset.path;

                            // Show success message for selected camera
                            status.className = 'detection-status detection-success';
                            status.innerHTML = `
                                <div style="text-align: center;">
                                    <div style="font-size: 1.1em; margin-bottom: 5px;">✅ Camera ${this.value} selected</div>
                                    <small>Device: ${selectedOption.dataset.path}</small>
                                </div>
                            `;
                        }
                    });
                } else {
                    console.log('❌ No cameras found');
                    status.className = 'detection-status detection-warning';
                    status.innerHTML = `
                        <div style="text-align: center;">
                            <div style="font-size: 1.2em; margin-bottom: 8px;">⚠️ No cameras detected</div>
                            <small>Check camera connections or try refreshing</small>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('💥 Camera detection error:', error);
                if (window.reportWebcamError) {
                    window.reportWebcamError('camera_detection', error, {
                        characterId,
                        isRefresh,
                        useRemote: true
                    });
                }
                status.className = 'detection-status detection-error';
                status.textContent = 'Error detecting cameras: ' + error.message;
            } finally {
                if (btn) {
                    btn.disabled = false;
                    btn.textContent = '🔄 Refresh Camera List';
                }
                console.log('🏁 Camera detection completed');
            }
        }

        // Add event listener for refresh button
        document.getElementById('refreshCamerasBtn').addEventListener('click', function() {
            detectCameras(true);
        });

        // Update resolution options based on camera capabilities
        function updateResolutionOptions(resolutions) {
            const resolutionSelect = document.getElementById('resolution');
            const currentValue = resolutionSelect.value;

            // Clear existing options
            resolutionSelect.innerHTML = '';

            // Remove duplicates and sort resolutions by pixel count
            const uniqueResolutions = [...new Set(resolutions)];
            const sortedResolutions = uniqueResolutions.sort((a, b) => {
                const [aWidth, aHeight] = a.split('x').map(Number);
                const [bWidth, bHeight] = b.split('x').map(Number);
                return (bWidth * bHeight) - (aWidth * aHeight); // Sort descending by pixel count
            });

            // Add resolution options
            sortedResolutions.forEach(resolution => {
                const option = document.createElement('option');
                option.value = resolution;

                // Add descriptive labels for common resolutions
                let label = resolution;
                switch(resolution) {
                    case '1920x1080': label += ' (Full HD)'; break;
                    case '1280x720': label += ' (HD)'; break;
                    case '640x480': label += ' (VGA)'; break;
                    case '320x240': label += ' (QVGA)'; break;
                }

                option.textContent = label;

                // Select the current value if it exists, otherwise select 1280x720 or first option
                if (resolution === currentValue ||
                    (!currentValue && resolution === '1280x720') ||
                    (!currentValue && !resolutionSelect.querySelector('option[value="1280x720"]') && sortedResolutions.indexOf(resolution) === 0)) {
                    option.selected = true;
                }

                resolutionSelect.appendChild(option);
            });

            console.log(`📐 Updated resolution options: ${sortedResolutions.join(', ')}`);
        }

        // Validate remote device function
        async function validateRemoteDevice(characterId, deviceId) {
            try {
                const response = await fetch(`/api/webcam/validate-device?characterId=${characterId}&deviceId=${deviceId}`);
                const data = await response.json();

                const status = document.getElementById('detectionStatus');
                if (data.success) {
                    status.className = 'detection-status detection-success';
                    status.textContent = `✓ Device validated: ${data.message}`;
                } else {
                    status.className = 'detection-status detection-error';
                    status.textContent = `✗ Device validation failed: ${data.message}`;
                }
            } catch (error) {
                const status = document.getElementById('detectionStatus');
                status.className = 'detection-status detection-error';
                status.textContent = 'Error validating device: ' + error.message;
            }
        }

        // Update device path when device is selected
        document.getElementById('deviceId').addEventListener('change', function() {
            const devicePath = document.getElementById('devicePath');
            const status = document.getElementById('detectionStatus');

            if (this.value) {
                devicePath.value = `/dev/video${this.value}`;

                // Check if selected device is in use
                const selectedOption = this.options[this.selectedIndex];
                if (selectedOption && selectedOption.dataset.inUse === 'true') {
                    status.style.display = 'block';
                    status.className = 'detection-status detection-warning';
                    status.innerHTML = `
                        ⚠️ Camera ${this.value} is currently in use by another process.<br>
                        <small>You can still configure it, but testing may not work until the device is free.</small>
                    `;
                } else if (selectedOption && selectedOption.dataset.available === 'false') {
                    status.style.display = 'block';
                    status.className = 'detection-status detection-error';
                    status.innerHTML = `
                        ❌ Camera ${this.value} is not available.<br>
                        <small>${selectedOption.dataset.note || 'Device may be disconnected or have permission issues.'}</small>
                    `;
                } else {
                    status.style.display = 'block';
                    status.className = 'detection-status detection-success';
                    status.textContent = `✅ Camera ${this.value} is available for configuration.`;
                }
            } else {
                devicePath.value = '';
                if (status) {
                    status.style.display = 'none';
                }
            }
        });

        // Unified webcam toggle functionality
        let webcamActive = false;
        let currentStream = null;

        document.getElementById('webcamToggleBtn').addEventListener('click', async function() {
            const deviceId = document.getElementById('deviceId').value;
            const resolution = document.getElementById('resolution').value;
            const fps = document.getElementById('fps').value;
            const characterId = document.getElementById('characterId').value;

            if (!deviceId && deviceId !== '0') {
                showAlert('Please select a camera device first', 'warning');
                return;
            }

            const toggleBtn = document.getElementById('webcamToggleBtn');
            const preview = document.getElementById('webcamPreview');
            const status = document.getElementById('streamStatus');

            if (!webcamActive) {
                // Turn webcam ON
                try {
                    toggleBtn.disabled = true;
                    toggleBtn.textContent = '🔄 Starting...';

                    preview.innerHTML = `
                        <div style="text-align: center; color: #00ff00;">
                            <div style="font-size: 2em; margin-bottom: 10px;">🔄</div>
                            <div style="font-weight: bold;">Starting webcam...</div>
                            <small>Connecting to camera device ${deviceId}</small>
                        </div>
                    `;

                    const [width, height] = resolution.split('x');
                    // Use character-specific streaming endpoint
                    const streamUrl = `/api/streaming/stream/${characterId}?width=${width}&height=${height}&fps=${fps}&t=${Date.now()}`;

                    console.log('🎥 Starting webcam with character-specific URL:', streamUrl);

                    const img = document.createElement('img');
                    img.style.width = '100%';
                    img.style.height = '100%';
                    img.style.objectFit = 'cover';
                    img.style.borderRadius = '8px';

                    let loadTimeout = setTimeout(() => {
                        img.onerror();
                    }, 10000); // 10 second timeout

                    img.onload = () => {
                        clearTimeout(loadTimeout);
                        preview.innerHTML = '';
                        preview.appendChild(img);
                        console.log('✅ Webcam started successfully');

                        webcamActive = true;
                        currentStream = img;
                        toggleBtn.textContent = '📹 Webcam Off';
                        toggleBtn.disabled = false;

                        // Start stream status monitoring
                        updateStreamStatus(characterId);
                        status.style.display = 'block';
                        streamStatusInterval = setInterval(() => {
                            updateStreamStatus(characterId);
                        }, 5000);

                        showAlert('Webcam started successfully!', 'success');
                    };

                    img.onerror = () => {
                        clearTimeout(loadTimeout);
                        preview.innerHTML = `
                            <div style="text-align: center; color: #ff0000;">
                                <div style="font-size: 2em; margin-bottom: 10px;">❌</div>
                                <div style="font-weight: bold;">Webcam failed to start</div>
                                <small>Check device availability and connections</small>
                            </div>
                        `;
                        toggleBtn.textContent = '📹 Webcam On';
                        toggleBtn.disabled = false;

                        showAlert('Webcam failed to start - Check device availability', 'error');
                    };

                    img.src = streamUrl;

                } catch (error) {
                    console.error('Webcam start error:', error);
                    preview.innerHTML = `
                        <div style="text-align: center; color: #ff0000;">
                            <div style="font-size: 2em; margin-bottom: 10px;">💥</div>
                            <div style="font-weight: bold;">Error: ${error.message}</div>
                            <small>Check console for details</small>
                        </div>
                    `;
                    toggleBtn.textContent = '📹 Webcam On';
                    toggleBtn.disabled = false;

                    showAlert('Webcam error: ' + error.message, 'error');
                }
            } else {
                // Turn webcam OFF
                toggleBtn.disabled = true;
                toggleBtn.textContent = '🔄 Stopping...';

                if (currentStream) {
                    currentStream.src = '';
                    currentStream = null;
                }

                // Clear status interval
                if (streamStatusInterval) {
                    clearInterval(streamStatusInterval);
                    streamStatusInterval = null;
                }

                preview.innerHTML = `
                    <div style="text-align: center; color: #00ff00;">
                        <div style="font-size: 3em; margin-bottom: 10px;">📹</div>
                        <div>No preview available</div>
                        <small>Click "Webcam On" to start preview</small>
                    </div>
                `;

                webcamActive = false;
                toggleBtn.textContent = '📹 Webcam On';
                toggleBtn.disabled = false;
                status.style.display = 'none';

                showAlert('Webcam stopped', 'info');
            }
        });

        // Modern alert system
        function showAlert(message, type = 'info') {
            const alertDiv = document.createElement('div');
            alertDiv.className = `detection-status detection-${type === 'error' ? 'error' : type === 'warning' ? 'warning' : type === 'success' ? 'success' : 'info'}`;
            alertDiv.style.position = 'fixed';
            alertDiv.style.top = '20px';
            alertDiv.style.right = '20px';
            alertDiv.style.zIndex = '1000';
            alertDiv.style.maxWidth = '400px';
            alertDiv.style.animation = 'slideIn 0.3s ease-out';
            alertDiv.innerHTML = `
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <span>${message}</span>
                    <button onclick="this.parentElement.parentElement.remove()" style="background: none; border: none; color: inherit; cursor: pointer; font-size: 1.2em; margin-left: 10px;">×</button>
                </div>
                <style>
                    @keyframes slideIn {
                        from { transform: translateX(100%); opacity: 0; }
                        to { transform: translateX(0); opacity: 1; }
                    }
                </style>
            `;

            document.body.appendChild(alertDiv);

            // Auto-remove after 5 seconds
            setTimeout(() => {
                if (alertDiv.parentElement) {
                    alertDiv.remove();
                }
            }, 5000);
        }

        // Character selection change handler - updates preview
        document.getElementById('characterId').addEventListener('change', function() {
            const characterId = this.value;
            console.log('🎭 Character changed to:', characterId);

            // Stop current webcam if active
            if (webcamActive) {
                const toggleBtn = document.getElementById('webcamToggleBtn');
                toggleBtn.click(); // This will turn off the current webcam
            }

            // Reset preview
            const preview = document.getElementById('webcamPreview');
            preview.innerHTML = `
                <div style="text-align: center; color: #00ff00;">
                    <div style="font-size: 3em; margin-bottom: 10px;">📹</div>
                    <div>No preview available</div>
                    <small>Click "Webcam On" to start preview</small>
                </div>
            `;

            // Refresh camera detection for new character
            if (characterId) {
                setTimeout(() => {
                    detectCameras(true);
                }, 500);
            }
        });

        // Stream status update function
        async function updateStreamStatus(characterId) {
            try {
                const response = await fetch(`/api/streaming/status/${characterId}`);
                const data = await response.json();

                if (data.success) {
                    document.getElementById('streamStatusText').textContent =
                        data.hasStream ? 'Active' : 'Inactive';
                    document.getElementById('streamClients').textContent =
                        data.clientCount || 0;
                    document.getElementById('streamUrl').textContent =
                        data.hasStream ? `/api/streaming/stream/${characterId}` : '-';
                }
            } catch (error) {
                console.error('Error updating stream status:', error);
            }
        }

        // Stream control for configuration
        document.getElementById('stopStreamForConfigBtn').addEventListener('click', async function() {
            const characterId = document.getElementById('characterId').value;
            const stopBtn = this;
            const restartBtn = document.getElementById('restartStreamBtn');
            const detectBtn = document.getElementById('refreshCamerasBtn');

            try {
                stopBtn.disabled = true;
                stopBtn.textContent = '⏸️ Stopping...';

                const response = await fetch(`/api/streaming/stop/${characterId}`, {
                    method: 'POST'
                });

                const data = await response.json();

                if (data.success) {
                    stopBtn.style.display = 'none';
                    restartBtn.style.display = 'inline-block';

                    // Show success message
                    const status = document.getElementById('detectionStatus');
                    status.style.display = 'block';
                    status.className = 'detection-status detection-success';
                    status.textContent = '✅ Stream stopped. Camera is now available for configuration.';

                    // Auto-detect cameras now that stream is stopped
                    setTimeout(() => {
                        detectBtn.click();
                    }, 1000);
                } else {
                    alert('Failed to stop stream: ' + data.error);
                }
            } catch (error) {
                alert('Error stopping stream: ' + error.message);
            } finally {
                stopBtn.disabled = false;
                stopBtn.textContent = '⏸️ Stop Stream for Config';
            }
        });

        document.getElementById('restartStreamBtn').addEventListener('click', async function() {
            const characterId = document.getElementById('characterId').value;
            const restartBtn = this;
            const stopBtn = document.getElementById('stopStreamForConfigBtn');

            try {
                restartBtn.disabled = true;
                restartBtn.textContent = '▶️ Starting...';

                const response = await fetch(`/api/streaming/start/${characterId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();

                if (data.success) {
                    restartBtn.style.display = 'none';
                    stopBtn.style.display = 'inline-block';

                    // Show success message
                    const status = document.getElementById('detectionStatus');
                    status.style.display = 'block';
                    status.className = 'detection-status detection-success';
                    status.textContent = '✅ Stream restarted successfully.';
                } else {
                    alert('Failed to restart stream: ' + data.error);
                }
            } catch (error) {
                alert('Error restarting stream: ' + error.message);
            } finally {
                restartBtn.disabled = false;
                restartBtn.textContent = '▶️ Restart Stream';
            }
        });

        // Camera controls functionality
        function initializeCameraControls() {
            // Update range value displays and apply controls in real-time
            const ranges = document.querySelectorAll('input[type="range"]');
            ranges.forEach(range => {
                const valueDisplay = document.getElementById(range.id + 'Value');
                if (valueDisplay) {
                    range.addEventListener('input', function() {
                        valueDisplay.textContent = this.value;

                        // Apply control in real-time for visible controls
                        if (['brightness', 'contrast', 'saturation'].includes(this.name)) {
                            applyControlRealTime(this.name, this.value);
                        }
                    });
                }
            });

            // Add real-time updates for checkboxes and selects
            const checkboxes = document.querySelectorAll('input[type="checkbox"]');
            checkboxes.forEach(checkbox => {
                if (['white_balance_automatic'].includes(checkbox.name)) {
                    checkbox.addEventListener('change', function() {
                        applyControlRealTime(this.name, this.checked);
                    });
                }
            });

            const selects = document.querySelectorAll('select[name^="auto_"]');
            selects.forEach(select => {
                if (['auto_exposure'].includes(select.name)) {
                    select.addEventListener('change', function() {
                        applyControlRealTime(this.name, parseInt(this.value));
                    });
                }
            });

            // Real-time control application function
            async function applyControlRealTime(controlName, value) {
                const deviceId = document.getElementById('deviceId').value;
                const characterId = document.getElementById('characterId').value;

                if (!deviceId && deviceId !== '0') {
                    return; // Skip if no device selected
                }

                try {
                    const controls = {};
                    controls[controlName] = (typeof value === 'boolean') ? value : parseInt(value);

                    const response = await fetch('/api/webcam/set-controls', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            characterId: parseInt(characterId),
                            deviceId: parseInt(deviceId),
                            controls: controls
                        })
                    });

                    const data = await response.json();

                    if (!data.success) {
                        console.warn(`Failed to apply ${controlName} in real-time:`, data.message);
                    } else {
                        console.log(`✅ Applied ${controlName}=${value} in real-time`);
                    }
                } catch (error) {
                    console.warn(`Error applying ${controlName} in real-time:`, error);
                }
            }

            // Reset controls button
            document.getElementById('resetControlsBtn').addEventListener('click', function() {
                const defaults = {
                    brightness: 0,
                    contrast: 32,
                    saturation: 64,
                    hue: 0,
                    gamma: 100,
                    gain: 0,
                    sharpness: 10,
                    backlight_compensation: 80,
                    white_balance_temperature: 4600,
                    exposure_time_absolute: 157,
                    white_balance_automatic: true,
                    exposure_dynamic_framerate: false,
                    auto_exposure: 3,
                    power_line_frequency: 1
                };

                Object.keys(defaults).forEach(key => {
                    const element = document.getElementById(key);
                    if (element) {
                        if (element.type === 'checkbox') {
                            element.checked = defaults[key];
                        } else {
                            element.value = defaults[key];
                            // Update value display
                            const valueDisplay = document.getElementById(key + 'Value');
                            if (valueDisplay) {
                                valueDisplay.textContent = defaults[key];
                            }
                        }
                    }
                });

                console.log('🔄 Camera controls reset to defaults');
            });

            // Apply controls button
            document.getElementById('applyControlsBtn').addEventListener('click', async function() {
                const deviceId = document.getElementById('deviceId').value;
                const characterId = document.getElementById('characterId').value;

                if (!deviceId && deviceId !== '0') {
                    showAlert('Please select a camera device first', 'warning');
                    return;
                }

                const controls = {};
                const ranges = document.querySelectorAll('input[type="range"]');
                ranges.forEach(range => {
                    if (range.name) {
                        controls[range.name] = parseInt(range.value);
                    }
                });

                const checkboxes = document.querySelectorAll('input[type="checkbox"]');
                checkboxes.forEach(checkbox => {
                    if (checkbox.name) {
                        controls[checkbox.name] = checkbox.checked;
                    }
                });

                const selects = document.querySelectorAll('select[name^="auto_"], select[name^="power_"]');
                selects.forEach(select => {
                    if (select.name) {
                        controls[select.name] = parseInt(select.value);
                    }
                });

                console.log('📋 Applying controls:', controls);

                try {
                    this.disabled = true;
                    this.textContent = '⏳ Applying...';

                    const response = await fetch('/api/webcam/set-controls', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            characterId: parseInt(characterId),
                            deviceId: parseInt(deviceId),
                            controls: controls
                        })
                    });

                    const data = await response.json();

                    if (data.success) {
                        showAlert(`✅ Applied ${data.appliedControls?.length || 0} camera controls successfully!`, 'success');
                        console.log('✅ Camera controls applied:', data.appliedControls);

                        if (data.failedControls && data.failedControls.length > 0) {
                            console.warn('⚠️ Some controls failed:', data.failedControls);
                        }
                    } else {
                        showAlert('❌ Failed to apply controls: ' + data.message, 'error');
                        console.error('❌ Control application failed:', data);
                    }
                } catch (error) {
                    if (window.reportWebcamError) {
                        window.reportWebcamError('apply_controls', error, {
                            characterId: parseInt(characterId),
                            deviceId: parseInt(deviceId),
                            controls
                        });
                    }
                    showAlert('❌ Error applying controls: ' + error.message, 'error');
                    console.error('❌ Control application error:', error);
                } finally {
                    this.disabled = false;
                    this.textContent = '✅ Apply';
                }
            });
        }

        // Initialize page on load
        document.addEventListener('DOMContentLoaded', async function() {
            console.log('🚀 Page loaded, initializing webcam configuration...');

            const characterId = document.getElementById('characterId').value;
            const stopBtn = document.getElementById('stopStreamForConfigBtn');
            const restartBtn = document.getElementById('restartStreamBtn');

            console.log('📋 Character ID:', characterId);

            if (characterId) {
                try {
                    console.log('🔍 Checking stream status...');
                    const response = await fetch(`/api/streaming/status/${characterId}`);
                    const data = await response.json();
                    console.log('📊 Stream status:', data);

                    if (data.success && data.hasStream) {
                        stopBtn.style.display = 'inline-block';
                        restartBtn.style.display = 'none';
                        console.log('🔴 Stream is active, showing stop button');
                    } else {
                        stopBtn.style.display = 'none';
                        restartBtn.style.display = 'none';
                        console.log('⚪ No active stream');
                    }
                } catch (error) {
                    console.error('❌ Error checking stream status:', error);
                }
            }

            // Initialize camera controls
            initializeCameraControls();

            // Auto-detect cameras on page load for all cases
            console.log('⏰ Starting auto-detection in 1 second...');
            setTimeout(() => {
                console.log('🎬 Auto-detecting cameras now...');
                detectCameras(false);
            }, 1000); // Increased delay to ensure page is fully loaded
        });
    </script>
</body>
</html>
