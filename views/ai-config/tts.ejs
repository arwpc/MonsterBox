<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Text-to-Speech Configuration - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .tts-config {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .config-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .config-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        
        .config-icon {
            font-size: 2em;
            margin-right: 15px;
            color: #00ff00;
        }
        
        .character-voice-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .character-voice-card {
            background: #000800;
            border: 2px solid #00ff00;
            border-radius: 12px;
            padding: 24px;
            position: relative;
            transition: all 0.3s ease;
            min-height: 300px;
            display: flex;
            flex-direction: column;
            word-wrap: break-word;
            overflow-wrap: break-word;
        }

        .character-voice-card:hover {
            border-color: #66ff66;
            box-shadow: 0 4px 12px rgba(0, 255, 0, 0.2);
        }
        
        .character-header {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .character-avatar {
            width: 125px;
            height: 125px;
            border-radius: 50%;
            background: #001100;
            border: 2px solid #00ff00;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3em;
            margin-right: 20px;
            color: #00ff00;
            flex-shrink: 0;
            overflow: hidden;
        }

        .character-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }
        
        .character-info h4 {
            color: #00ff00;
            margin: 0 0 5px 0;
        }
        
        .character-info p {
            color: #cccccc;
            margin: 0;
            font-size: 0.9em;
        }
        
        .voice-assignment {
            margin: 20px 0;
            flex: 1;
        }

        .voice-assignment label {
            display: block;
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 12px;
            font-size: 1.1em;
        }

        .voice-preview {
            background: #001100;
            border: 2px solid #333333;
            border-radius: 8px;
            padding: 16px;
            margin: 10px 0;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            transition: all 0.3s ease;
            min-height: 80px;
        }

        .voice-preview:hover {
            border-color: #00ff00;
            background: #002200;
        }

        .voice-preview.has-voice {
            border-color: #00ff00;
        }

        .voice-preview.no-voice {
            border-color: #666666;
            border-style: dashed;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: #888888;
            font-style: italic;
        }

        .voice-info {
            flex: 1;
            margin-right: 10px;
            word-wrap: break-word;
            overflow-wrap: break-word;
            min-width: 0; /* Allow flex item to shrink below content size */
            max-width: 100%;
            overflow: hidden;
        }

        .voice-name {
            color: #00ff00;
            font-weight: bold;
            font-size: 1.1em;
            margin-bottom: 4px;
            word-wrap: break-word;
            overflow-wrap: break-word;
        }

        .voice-details {
            color: #cccccc;
            font-size: 0.9em;
            line-height: 1.4;
            word-wrap: break-word;
            overflow-wrap: break-word;
            max-width: 100%;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            display: block;
        }

        .voice-controls {
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex-shrink: 0;
            min-width: 100px;
        }

        .voice-settings-summary {
            background: #000800;
            border: 1px solid #333333;
            border-radius: 6px;
            padding: 12px;
            margin-top: 12px;
        }

        .voice-settings-summary small {
            color: #cccccc;
            font-size: 0.85em;
            line-height: 1.4;
            word-wrap: break-word;
            overflow-wrap: break-word;
        }
        
        .voice-catalog {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
            max-height: 500px;
            overflow-y: auto;
        }
        
        .catalog-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .catalog-search {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }
        
        .search-input {
            flex: 1;
            padding: 8px;
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
        }
        
        .filter-select {
            padding: 8px;
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
        }
        
        .voice-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 10px;
            max-height: 400px;
            overflow-y: auto;
            padding-right: 10px;
        }
        
        .voice-item {
            background: #001100;
            border: 1px solid #333333;
            border-radius: 5px;
            padding: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .voice-item:hover {
            border-color: #00ff00;
            background: #002200;
        }
        
        .voice-item.selected {
            border-color: #ffff00;
            background: #222200;
        }
        
        .voice-item-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 5px;
        }
        
        .voice-item-name {
            color: #ffffff;
            font-weight: bold;
            font-size: 0.9em;
        }
        
        .voice-item-badges {
            display: flex;
            gap: 3px;
        }
        
        .voice-badge {
            font-size: 0.7em;
            padding: 2px 5px;
            border-radius: 3px;
            color: #000000;
        }
        
        .badge-vip { background: #ffff00; }
        .badge-free { background: #00ff00; }
        .badge-new { background: #ff6600; }
        .badge-trending { background: #ff0066; }
        
        .voice-item-details {
            color: #cccccc;
            font-size: 0.8em;
        }
        
        .voice-settings {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .settings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }
        
        .setting-group {
            margin-bottom: 15px;
        }
        
        .setting-group label {
            display: block;
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 8px;
        }
        
        .setting-group input,
        .setting-group select {
            width: 100%;
            padding: 8px;
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
        }
        
        .setting-group input:focus,
        .setting-group select:focus {
            outline: none;
            border-color: #ffff00;
            box-shadow: 0 0 5px rgba(255, 255, 0, 0.3);
        }
        
        .range-display {
            display: flex;
            justify-content: space-between;
            font-size: 0.8em;
            color: #cccccc;
            margin-top: 5px;
        }
        
        .test-section {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .test-controls {
            display: flex;
            gap: 10px;
            align-items: center;
            margin: 15px 0;
        }
        
        .test-input {
            flex: 1;
            padding: 10px;
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
        }
        
        .audio-player {
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
            text-align: center;
        }
        
        .waveform {
            height: 60px;
            background: #000800;
            border: 1px solid #333333;
            border-radius: 5px;
            margin: 10px 0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #666666;
        }
        
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
        }

        .modal-content {
            background-color: #001100;
            margin: 5% auto;
            padding: 0;
            border: 2px solid #00ff00;
            border-radius: 10px;
            width: 90%;
            max-width: 1000px;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal-header {
            background-color: #000800;
            padding: 15px 20px;
            border-bottom: 1px solid #00ff00;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h3 {
            margin: 0;
            color: #00ff00;
        }

        .close {
            color: #ff0000;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

        .close:hover {
            color: #ff6666;
        }

        .modal-body {
            padding: 20px;
            color: #cccccc;
        }
        
        .error-message {
            background: #330000;
            border: 1px solid #ff0000;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #ff6666;
        }
        
        .success-message {
            background: #003300;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #66ff66;
        }
        
        .info-message {
            background: #000033;
            border: 1px solid #0066ff;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #6666ff;
        }

        /* Button improvements */
        .button.small-btn {
            padding: 8px 12px;
            font-size: 0.9em;
            min-width: auto;
            white-space: nowrap;
            text-align: center;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .button.small-btn i {
            margin-right: 4px;
        }

        /* Text overflow fixes */
        .character-info h4 {
            word-wrap: break-word;
            overflow-wrap: break-word;
            hyphens: auto;
        }

        .character-info p {
            word-wrap: break-word;
            overflow-wrap: break-word;
            hyphens: auto;
            line-height: 1.3;
        }

        /* Responsive improvements */
        @media (max-width: 1024px) {
            .character-voice-grid {
                grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            }
        }

        @media (max-width: 768px) {
            .character-voice-grid {
                grid-template-columns: 1fr;
            }

            .settings-grid {
                grid-template-columns: 1fr;
            }

            .voice-preview {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }

            .voice-info {
                margin-right: 0;
                margin-bottom: 10px;
            }

            .voice-controls {
                flex-direction: row;
                gap: 8px;
                width: 100%;
                justify-content: flex-start;
            }

            .button.small-btn {
                flex: 1;
                justify-content: center;
                min-width: 80px;
            }

            .character-voice-card {
                min-height: auto;
            }
        }

        @media (max-width: 480px) {
            .voice-controls {
                flex-direction: column;
                gap: 4px;
            }

            .button.small-btn {
                width: 100%;
            }
        }

        /* Loading states */
        .loading {
            opacity: 0.6;
            pointer-events: none;
        }

        .loading::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 20px;
            height: 20px;
            margin: -10px 0 0 -10px;
            border: 2px solid #00ff00;
            border-radius: 50%;
            border-top-color: transparent;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ChatterPi Integration Styles */
        .integration-notice {
            background: linear-gradient(135deg, #001100, #002200);
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin-top: 15px;
        }

        .notice-content {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .notice-content i {
            color: #00ff00;
            font-size: 1.2em;
        }

        .integration-link {
            color: #ff6600;
            text-decoration: none;
            font-weight: bold;
            margin-left: 10px;
        }

        .integration-link:hover {
            color: #ff8833;
            text-decoration: underline;
        }

        .jaw-animation-integration {
            background: #001100;
            border: 1px solid #ff6600;
            border-radius: 6px;
            padding: 12px;
            margin-top: 10px;
        }

        .integration-header {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
            font-size: 0.9em;
        }

        .jaw-status {
            margin-left: 8px;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.8em;
            font-weight: bold;
        }

        .jaw-status.connected {
            background: #004400;
            color: #00ff00;
        }

        .jaw-status.disconnected {
            background: #440000;
            color: #ff4444;
        }

        .jaw-status.checking {
            background: #444400;
            color: #ffff00;
        }

        .integration-controls {
            display: flex;
            gap: 8px;
        }

        .integration-controls .button {
            font-size: 0.8em;
            padding: 6px 12px;
        }
    </style>
</head>
<body>
    <header>
        <h1>🔊 Text-to-Speech Configuration</h1>
        <div class="breadcrumb-vertical mb-6">
            <a href="/" class="breadcrumb-item">🏠 Home</a>
            <a href="/ai-management" class="breadcrumb-item">🧠 AI Management</a>
            <span class="breadcrumb-item active">🔊 TTS Configuration</span>
        </div>
    </header>

    <main class="tts-config">
        <div class="info-section">
            <h2>🎤 TopMediaAI TTS Configuration</h2>
            <p>Configure Text-to-Speech voices for each character using the comprehensive TopMediaAI voice catalog</p>

        </div>

        <!-- Character Voice Assignments -->
        <div class="config-section">
            <div class="config-header">
                <div style="display: flex; align-items: center;">
                    <i class="fas fa-users config-icon"></i>
                    <h3>Character Voice Assignments</h3>
                </div>
                <button class="button primary-btn" onclick="saveAllVoiceAssignments()">
                    <i class="fas fa-save"></i> Save All Assignments
                </button>
            </div>

            <div class="character-voice-grid" id="characterVoiceGrid">
                <% if (characters && characters.length > 0) { %>
                    <% characters.forEach(function(character) { %>
                        <div class="character-voice-card" data-character-id="<%= character.id %>">
                            <div class="character-header">
                                <div class="character-avatar">
                                    <% if (character.image) { %>
                                        <img src="/images/characters/<%= character.image %>" alt="<%= character.char_name %>">
                                    <% } else { %>
                                        <%= character.char_name ? character.char_name.charAt(0).toUpperCase() : '?' %>
                                    <% } %>
                                </div>
                                <div class="character-info">
                                    <h4><%= character.char_name || 'Unnamed Character' %></h4>
                                    <p><%= character.char_description || 'No description' %></p>
                                </div>
                            </div>

                            <div class="voice-assignment">
                                <label><i class="fas fa-microphone"></i> Assigned Voice:</label>
                                <div class="voice-preview <%= character.voiceConfig && character.voiceConfig.speaker_id ? 'has-voice' : 'no-voice' %>" id="voicePreview_<%= character.id %>">
                                    <% if (character.voiceConfig && character.voiceConfig.speaker_id) { %>
                                        <div class="voice-info">
                                            <div class="voice-name">
                                                <i class="fas fa-user-circle" style="color: #00ff00; margin-right: 8px;"></i>
                                                <%= character.voiceConfig.metadata?.voiceName || character.voiceConfig.voiceName || 'Unknown Voice' %>
                                            </div>
                                            <div class="voice-details">
                                                <i class="fas fa-info-circle" style="color: #666; margin-right: 6px;"></i>
                                                <%= character.voiceConfig.metadata?.voiceGender || character.voiceConfig.voiceGender || 'Unknown' %> •
                                                <%= character.voiceConfig.metadata?.voiceLanguage || character.voiceConfig.voiceLanguage || 'Unknown' %>
                                            </div>
                                        </div>
                                        <div class="voice-controls">
                                            <button class="button small-btn secondary-btn" onclick="previewVoice('<%= character.id %>', '<%= character.voiceConfig.speaker_id %>')" title="Preview Voice">
                                                <i class="fas fa-play"></i> Preview
                                            </button>
                                            <button class="button small-btn primary-btn" onclick="configureVoice('<%= character.id %>')" title="Configure Voice Settings">
                                                <i class="fas fa-cog"></i> Configure
                                            </button>
                                        </div>
                                    <% } else { %>
                                        <div class="voice-info">
                                            <div class="voice-name">
                                                <i class="fas fa-exclamation-triangle" style="color: #ff6600; margin-right: 8px;"></i>
                                                No Voice Assigned
                                            </div>
                                            <div class="voice-details">
                                                <i class="fas fa-arrow-right" style="color: #666; margin-right: 6px;"></i>
                                                Click "Assign Voice" to select from 2000+ available voices
                                            </div>
                                        </div>
                                        <div class="voice-controls">
                                            <button class="button small-btn primary-btn" onclick="configureVoice('<%= character.id %>')" title="Assign a voice to this character">
                                                <i class="fas fa-plus"></i> Assign Voice
                                            </button>
                                        </div>
                                    <% } %>
                                </div>

                                <% if (character.voiceConfig && character.voiceConfig.settings) { %>
                                    <div class="voice-settings-summary">
                                        <small>
                                            <i class="fas fa-sliders-h" style="color: #00ff00; margin-right: 6px;"></i>
                                            <strong>Settings:</strong>
                                            Speed: <span style="color: #66ff66;"><%= character.voiceConfig.settings.speed || 1.0 %></span> •
                                            Pitch: <span style="color: #66ff66;"><%= character.voiceConfig.settings.pitch || 0 %></span> •
                                            Volume: <span style="color: #66ff66;"><%= character.voiceConfig.settings.volume || 0 %></span>
                                            <% if (character.voiceConfig.settings.emotion && character.voiceConfig.settings.emotion !== 'Neutral') { %>
                                                • Emotion: <span style="color: #66ff66;"><%= character.voiceConfig.settings.emotion %></span>
                                            <% } %>
                                        </small>
                                    </div>
                                <% } %>


                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="character-voice-card">
                        <div class="character-header">
                            <div class="character-info">
                                <h4>No Characters Found</h4>
                                <p>Create characters in the Characters section first</p>
                            </div>
                        </div>
                        <div class="voice-assignment">
                            <a href="/characters" class="button primary-btn">
                                <i class="fas fa-plus"></i> Create Characters
                            </a>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Global TTS Settings -->
        <div class="config-section">
            <div class="config-header">
                <div style="display: flex; align-items: center;">
                    <i class="fas fa-globe config-icon"></i>
                    <h3>Global TTS Settings</h3>
                </div>
                <button class="button primary-btn" onclick="saveGlobalTTSSettings()">
                    <i class="fas fa-save"></i> Save Global Settings
                </button>
            </div>

            <form id="globalTTSForm" class="voice-settings">
                <div class="settings-grid">
                    <div class="setting-group">
                        <label for="defaultSpeed">Default Speed</label>
                        <input type="range" id="defaultSpeed" name="defaultSpeed"
                               min="0.5" max="2.0" step="0.1"
                               value="<%= globalTTSConfig && globalTTSConfig.defaultSpeed ? globalTTSConfig.defaultSpeed : '1.0' %>"
                               oninput="updateSpeedDisplay(this.value)">
                        <div class="range-display">
                            <span>Slow (0.5)</span>
                            <span id="speedValue"><%= globalTTSConfig && globalTTSConfig.defaultSpeed ? globalTTSConfig.defaultSpeed : '1.0' %></span>
                            <span>Fast (2.0)</span>
                        </div>
                    </div>

                    <div class="setting-group">
                        <label for="defaultPitch">Default Pitch</label>
                        <input type="range" id="defaultPitch" name="defaultPitch"
                               min="-20" max="20" step="1"
                               value="<%= globalTTSConfig && globalTTSConfig.defaultPitch ? globalTTSConfig.defaultPitch : '0' %>"
                               oninput="updatePitchDisplay(this.value)">
                        <div class="range-display">
                            <span>Low (-20)</span>
                            <span id="pitchValue"><%= globalTTSConfig && globalTTSConfig.defaultPitch ? globalTTSConfig.defaultPitch : '0' %></span>
                            <span>High (+20)</span>
                        </div>
                    </div>

                    <div class="setting-group">
                        <label for="defaultVolume">Default Volume</label>
                        <input type="range" id="defaultVolume" name="defaultVolume"
                               min="-20" max="20" step="1"
                               value="<%= globalTTSConfig && globalTTSConfig.defaultVolume ? globalTTSConfig.defaultVolume : '0' %>"
                               oninput="updateVolumeDisplay(this.value)">
                        <div class="range-display">
                            <span>Quiet (-20)</span>
                            <span id="volumeValue"><%= globalTTSConfig && globalTTSConfig.defaultVolume ? globalTTSConfig.defaultVolume : '0' %></span>
                            <span>Loud (+20)</span>
                        </div>
                    </div>

                    <div class="setting-group">
                        <label for="audioFormat">Audio Format</label>
                        <select id="audioFormat" name="audioFormat">
                            <option value="mp3" <%= globalTTSConfig && globalTTSConfig.audioFormat === 'mp3' ? 'selected' : '' %>>MP3</option>
                            <option value="wav" <%= globalTTSConfig && globalTTSConfig.audioFormat === 'wav' ? 'selected' : '' %>>WAV</option>
                        </select>
                    </div>

                    <div class="setting-group">
                        <label for="sampleRate">Sample Rate</label>
                        <select id="sampleRate" name="sampleRate">
                            <option value="22050" <%= globalTTSConfig && globalTTSConfig.sampleRate === '22050' ? 'selected' : '' %>>22.05 kHz</option>
                            <option value="44100" <%= globalTTSConfig && globalTTSConfig.sampleRate === '44100' ? 'selected' : '' %>>44.1 kHz</option>
                            <option value="48000" <%= globalTTSConfig && globalTTSConfig.sampleRate === '48000' ? 'selected' : '' %>>48 kHz</option>
                        </select>
                    </div>

                    <div class="setting-group">
                        <label for="timeout">Request Timeout (ms)</label>
                        <input type="number" id="timeout" name="timeout"
                               min="5000" max="60000" step="1000"
                               value="<%= globalTTSConfig && globalTTSConfig.timeout ? globalTTSConfig.timeout : '30000' %>">
                    </div>
                </div>
            </form>
        </div>

        <!-- TTS Testing Section -->
        <div class="test-section">
            <div class="config-header">
                <div style="display: flex; align-items: center;">
                    <i class="fas fa-flask config-icon"></i>
                    <h3>TTS Testing</h3>
                </div>
            </div>

            <div class="test-controls">
                <select id="testCharacter" class="form-control">
                    <option value="">Select Character to Test</option>
                    <% if (characters && characters.length > 0) { %>
                        <% characters.forEach(function(character) { %>
                            <option value="<%= character.id %>"><%= character.char_name || 'Unnamed Character' %></option>
                        <% }); %>
                    <% } %>
                </select>
                <input type="text" id="testText" class="test-input" placeholder="Enter text to synthesize..." value="Hello, I am your monster, hear me roar!">
                <button class="button primary-btn" onclick="runTTSTest()">
                    <i class="fas fa-volume-up"></i> Generate
                </button>
            </div>

            <div class="audio-player" id="audioPlayer" style="display: none;">
                <audio controls id="testAudio" style="width: 100%;">
                    Your browser does not support the audio element.
                </audio>
                <div class="waveform" id="waveform" style="margin: 10px 0; height: 80px; background: #000800; border: 1px solid #00ff00; border-radius: 5px; position: relative;">
                    <canvas id="waveformCanvas" style="width: 100%; height: 100%; border-radius: 5px;"></canvas>
                </div>
                <div style="margin-top: 10px;">
                    <button class="button secondary-btn" onclick="testAudioIntegrity()">
                        <i class="fas fa-stethoscope"></i> Test Audio Integrity
                    </button>
                    <button class="button secondary-btn" onclick="downloadAudio()">
                        <i class="fas fa-download"></i> Download
                    </button>
                    <button class="button secondary-btn" onclick="saveToLibrary()">
                        <i class="fas fa-save"></i> Save to Sound Library
                    </button>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="button-group" style="margin-top: 30px;">
            <% if (typeof returnTo !== 'undefined' && returnTo) { %>
                <a href="<%= returnTo %>" class="button secondary-btn">
                    <i class="fas fa-arrow-left"></i> Back to Assistants
                </a>
            <% } else { %>
                <a href="/ai-management" class="button secondary-btn">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            <% } %>
            <a href="/characters" class="button">
                <i class="fas fa-users"></i> Manage Characters
            </a>
            <a href="/sounds" class="button">
                <i class="fas fa-music"></i> Sound Library
            </a>
        </div>

        <!-- Messages -->
        <div id="messageContainer"></div>
    </main>

    <!-- Voice Catalog Modal -->
    <div id="voiceCatalogModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="catalogModalTitle">TopMediaAI Voice Catalog</h3>
                <span class="close" onclick="closeCatalogModal()">&times;</span>
            </div>
            <div class="modal-body">
                <input type="hidden" id="selectedCharacterId">

                <!-- Voice Catalog -->
                <div class="voice-catalog">
                    <div class="catalog-header">
                        <h4>Available Voices</h4>
                        <span id="voiceCount">Loading...</span>
                    </div>

                    <div class="catalog-search">
                        <input type="text" id="voiceSearch" class="search-input" placeholder="Search voices..." oninput="filterVoices()">
                        <select id="genderFilter" class="filter-select" onchange="filterVoices()">
                            <option value="">All Genders</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                        </select>
                        <select id="languageFilter" class="filter-select" onchange="filterVoices()">
                            <option value="">All Languages</option>
                            <option value="English">English</option>
                            <option value="Spanish">Spanish</option>
                            <option value="French">French</option>
                            <option value="German">German</option>
                            <option value="Italian">Italian</option>
                            <option value="Portuguese">Portuguese</option>
                            <option value="Russian">Russian</option>
                            <option value="Japanese">Japanese</option>
                            <option value="Korean">Korean</option>
                            <option value="Chinese">Chinese</option>
                        </select>
                        <select id="typeFilter" class="filter-select" onchange="filterVoices()">
                            <option value="">All Types</option>
                            <option value="free">Free</option>
                            <option value="vip">VIP</option>
                            <option value="new">New</option>
                            <option value="trending">Trending</option>
                        </select>
                    </div>

                    <div class="voice-list" id="voiceList">
                        <!-- Voice items will be populated here -->
                    </div>
                </div>

                <!-- Voice Settings -->
                <div class="voice-settings">
                    <h4>Voice Settings</h4>
                    <div class="settings-grid">
                        <div class="setting-group">
                            <label for="modalSpeed">Speed</label>
                            <input type="range" id="modalSpeed" name="modalSpeed"
                                   min="0.5" max="2.0" step="0.1" value="1.0"
                                   oninput="updateModalSpeedDisplay(this.value)">
                            <div class="range-display">
                                <span>Slow (0.5)</span>
                                <span id="modalSpeedValue">1.0</span>
                                <span>Fast (2.0)</span>
                            </div>
                        </div>

                        <div class="setting-group">
                            <label for="modalPitch">Pitch</label>
                            <input type="range" id="modalPitch" name="modalPitch"
                                   min="-20" max="20" step="1" value="0"
                                   oninput="updateModalPitchDisplay(this.value)">
                            <div class="range-display">
                                <span>Low (-20)</span>
                                <span id="modalPitchValue">0</span>
                                <span>High (+20)</span>
                            </div>
                        </div>

                        <div class="setting-group">
                            <label for="modalVolume">Volume</label>
                            <input type="range" id="modalVolume" name="modalVolume"
                                   min="-20" max="20" step="1" value="0"
                                   oninput="updateModalVolumeDisplay(this.value)">
                            <div class="range-display">
                                <span>Quiet (-20)</span>
                                <span id="modalVolumeValue">0</span>
                                <span>Loud (+20)</span>
                            </div>
                        </div>

                        <div class="setting-group">
                            <label for="modalEmotion">Emotion</label>
                            <select id="modalEmotion" name="modalEmotion">
                                <option value="Neutral">Neutral</option>
                                <option value="Happy">Happy</option>
                                <option value="Sad">Sad</option>
                                <option value="Angry">Angry</option>
                                <option value="Excited">Excited</option>
                                <option value="Calm">Calm</option>
                                <option value="Fearful">Fearful</option>
                                <option value="Surprised">Surprised</option>
                            </select>
                        </div>
                    </div>

                    <!-- Preview Section -->
                    <div class="test-controls">
                        <input type="text" id="previewText" class="test-input" placeholder="Enter text to preview..." value="Hello, I am your character speaking.">
                        <button class="button secondary-btn" onclick="previewSelectedVoice()">
                            <i class="fas fa-play"></i> Preview
                        </button>
                    </div>

                    <div class="audio-player" id="modalAudioPlayer" style="display: none;">
                        <audio controls id="previewAudio" style="width: 100%;">
                            Your browser does not support the audio element.
                        </audio>
                    </div>
                </div>

                <div class="button-group">
                    <button class="button primary-btn" onclick="assignVoiceToCharacter()" id="assignVoiceBtn" disabled>
                        <i class="fas fa-check"></i> Assign Voice to Character
                    </button>
                    <button class="button secondary-btn" onclick="closeCatalogModal()">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let availableVoices = [];
        let filteredVoices = [];
        let selectedVoice = null;
        let currentAudioUrl = null;

        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            updateSpeedDisplay(document.getElementById('defaultSpeed').value);
            updatePitchDisplay(document.getElementById('defaultPitch').value);
            updateVolumeDisplay(document.getElementById('defaultVolume').value);
            loadVoiceCatalog();

            // Check if a specific character was requested for voice configuration
            const urlParams = new URLSearchParams(window.location.search);
            const characterId = urlParams.get('characterId');
            if (characterId) {
                // Auto-open voice configuration for the specified character
                setTimeout(() => configureVoice(characterId), 1000);
            }

            // Initialize jaw animation status for all characters
            initializeJawAnimationStatus();
        });

        // ChatterPi Jaw Animation Integration Functions
        async function initializeJawAnimationStatus() {
            try {
                const response = await fetch('/chatterpi/api/status');
                const result = await response.json();

                const isConnected = result.success && result.status.servo.connected;

                // Update all character jaw status displays
                const statusElements = document.querySelectorAll('[id^="jawStatus_"]');
                statusElements.forEach(element => {
                    updateJawStatus(element, isConnected);
                });
            } catch (error) {
                console.error('Failed to check jaw animation status:', error);
                // Update all status displays to show error
                const statusElements = document.querySelectorAll('[id^="jawStatus_"]');
                statusElements.forEach(element => {
                    element.textContent = 'Error';
                    element.className = 'jaw-status disconnected';
                });
            }
        }

        function updateJawStatus(element, isConnected) {
            if (isConnected) {
                element.textContent = 'Connected';
                element.className = 'jaw-status connected';
            } else {
                element.textContent = 'Disconnected';
                element.className = 'jaw-status disconnected';
            }
        }





        // Global settings display updates
        function updateSpeedDisplay(value) {
            document.getElementById('speedValue').textContent = value;
        }

        function updatePitchDisplay(value) {
            document.getElementById('pitchValue').textContent = value;
        }

        function updateVolumeDisplay(value) {
            document.getElementById('volumeValue').textContent = value;
        }

        // Modal settings display updates
        function updateModalSpeedDisplay(value) {
            document.getElementById('modalSpeedValue').textContent = value;
        }

        function updateModalPitchDisplay(value) {
            document.getElementById('modalPitchValue').textContent = value;
        }

        function updateModalVolumeDisplay(value) {
            document.getElementById('modalVolumeValue').textContent = value;
        }

        // Voice catalog functions
        async function loadVoiceCatalog() {
            try {
                const response = await fetch('/api/voice/available');
                const data = await response.json();

                if (Array.isArray(data)) {
                    availableVoices = data;
                    filteredVoices = [...availableVoices];
                    updateVoiceCount();
                    renderVoiceList();
                } else {
                    showMessage('Failed to load voice catalog', 'error');
                }
            } catch (error) {
                showMessage(`Error loading voice catalog: ${error.message}`, 'error');
            }
        }

        function updateVoiceCount() {
            document.getElementById('voiceCount').textContent = `${filteredVoices.length} voices available`;
        }

        function renderVoiceList() {
            const voiceList = document.getElementById('voiceList');
            voiceList.innerHTML = '';

            filteredVoices.forEach(voice => {
                const voiceItem = document.createElement('div');
                voiceItem.className = 'voice-item';
                voiceItem.onclick = () => selectVoice(voice);

                let badges = '';
                if (voice.isVip) badges += '<span class="voice-badge badge-vip">VIP</span>';
                if (voice.isFree) badges += '<span class="voice-badge badge-free">FREE</span>';
                if (voice.isNew) badges += '<span class="voice-badge badge-new">NEW</span>';
                if (voice.trending) badges += '<span class="voice-badge badge-trending">HOT</span>';

                voiceItem.innerHTML = `
                    <div class="voice-item-header">
                        <div class="voice-item-name">${voice.name}</div>
                        <div class="voice-item-badges">${badges}</div>
                    </div>
                    <div class="voice-item-details">
                        ${voice.gender || 'Unknown'} • ${voice.language || voice.accent || 'Unknown'}
                        ${voice.description ? '<br>' + voice.description : ''}
                    </div>
                `;

                voiceList.appendChild(voiceItem);
            });
        }

        function selectVoice(voice) {
            // Remove previous selection
            document.querySelectorAll('.voice-item').forEach(item => {
                item.classList.remove('selected');
            });

            // Add selection to clicked item
            event.currentTarget.classList.add('selected');

            selectedVoice = voice;
            document.getElementById('assignVoiceBtn').disabled = false;
        }

        function filterVoices() {
            const searchTerm = document.getElementById('voiceSearch').value.toLowerCase();
            const genderFilter = document.getElementById('genderFilter').value;
            const languageFilter = document.getElementById('languageFilter').value;
            const typeFilter = document.getElementById('typeFilter').value;

            filteredVoices = availableVoices.filter(voice => {
                const matchesSearch = !searchTerm || voice.name.toLowerCase().includes(searchTerm);
                const matchesGender = !genderFilter || voice.gender?.toLowerCase() === genderFilter;
                const matchesLanguage = !languageFilter || voice.language?.includes(languageFilter) || voice.accent?.includes(languageFilter);

                let matchesType = true;
                if (typeFilter === 'free') matchesType = voice.isFree;
                else if (typeFilter === 'vip') matchesType = voice.isVip;
                else if (typeFilter === 'new') matchesType = voice.isNew;
                else if (typeFilter === 'trending') matchesType = voice.trending;

                return matchesSearch && matchesGender && matchesLanguage && matchesType;
            });

            updateVoiceCount();
            renderVoiceList();
        }

        // Character voice configuration functions
        function configureVoice(characterId) {
            document.getElementById('selectedCharacterId').value = characterId;
            document.getElementById('catalogModalTitle').textContent = `Configure Voice for Character`;
            document.getElementById('voiceCatalogModal').style.display = 'block';
        }

        function closeCatalogModal() {
            document.getElementById('voiceCatalogModal').style.display = 'none';
            selectedVoice = null;
            document.getElementById('assignVoiceBtn').disabled = true;

            // Clear audio
            if (currentAudioUrl) {
                URL.revokeObjectURL(currentAudioUrl);
                currentAudioUrl = null;
            }
        }

        async function previewSelectedVoice() {
            if (!selectedVoice) {
                showMessage('Please select a voice first', 'error');
                return;
            }

            const text = document.getElementById('previewText').value;
            if (!text.trim()) {
                showMessage('Please enter text to preview', 'error');
                return;
            }

            try {
                showMessage('Generating preview...', 'info');

                const settings = {
                    speed: parseFloat(document.getElementById('modalSpeed').value),
                    pitch: parseInt(document.getElementById('modalPitch').value),
                    volume: parseInt(document.getElementById('modalVolume').value),
                    emotion: document.getElementById('modalEmotion').value
                };

                const response = await fetch('/api/voice/generate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        speaker_id: selectedVoice.uuid || selectedVoice.speaker_id,
                        text: text,
                        options: settings
                    })
                });

                const data = await response.json();

                if (data.success && data.url) {
                    const audio = document.getElementById('previewAudio');
                    audio.src = data.url;
                    document.getElementById('modalAudioPlayer').style.display = 'block';
                    currentAudioUrl = data.url;
                    showMessage('Preview generated successfully!', 'success');
                } else {
                    showMessage(`Preview failed: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Preview error: ${error.message}`, 'error');
            }
        }

        async function assignVoiceToCharacter() {
            if (!selectedVoice) {
                showMessage('Please select a voice first', 'error');
                return;
            }

            const characterId = document.getElementById('selectedCharacterId').value;
            if (!characterId) {
                showMessage('No character selected', 'error');
                return;
            }

            try {
                showMessage('Assigning voice to character...', 'info');

                const settings = {
                    speed: parseFloat(document.getElementById('modalSpeed').value),
                    pitch: parseInt(document.getElementById('modalPitch').value),
                    volume: parseInt(document.getElementById('modalVolume').value),
                    emotion: document.getElementById('modalEmotion').value,
                    sampleRate: 44100,
                    bitRate: 128,
                    outputFormat: 'mp3',
                    channels: 1,
                    languageCode: 'en',
                    provider: 'TopMediai'
                };

                const voiceData = {
                    characterId: parseInt(characterId),
                    voiceId: selectedVoice.uuid || selectedVoice.speaker_id,
                    settings: settings,
                    metadata: {
                        voiceName: selectedVoice.name,
                        voiceGender: selectedVoice.gender,
                        voiceLanguage: selectedVoice.language || selectedVoice.accent,
                        lastUsed: null,
                        useCount: 0,
                        favorited: false,
                        tags: [],
                        notes: ''
                    }
                };

                const response = await fetch('/api/voice/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(voiceData)
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('Voice assigned successfully!', 'success');

                    closeCatalogModal();
                    // Update the voice preview without full page reload
                    updateVoicePreview(characterId, selectedVoice, settings);
                } else {
                    showMessage(`Failed to assign voice: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error assigning voice: ${error.message}`, 'error');
            }
        }

        function updateVoicePreview(characterId, voice, settings) {
            const previewElement = document.getElementById(`voicePreview_${characterId}`);
            if (!previewElement) return;

            // Update the preview element with new voice information
            previewElement.className = 'voice-preview has-voice';
            previewElement.innerHTML = `
                <div class="voice-info">
                    <div class="voice-name">
                        <i class="fas fa-user-circle" style="color: #00ff00; margin-right: 8px;"></i>
                        ${voice.name}
                    </div>
                    <div class="voice-details">
                        <i class="fas fa-info-circle" style="color: #666; margin-right: 6px;"></i>
                        ${voice.gender || 'Unknown'} • ${voice.language || voice.accent || 'Unknown'}
                    </div>
                </div>
                <div class="voice-controls">
                    <button class="button small-btn secondary-btn" onclick="previewVoice('${characterId}', '${voice.uuid || voice.speaker_id}')" title="Preview Voice">
                        <i class="fas fa-play"></i> Preview
                    </button>
                    <button class="button small-btn primary-btn" onclick="configureVoice('${characterId}')" title="Configure Voice Settings">
                        <i class="fas fa-cog"></i> Configure
                    </button>
                </div>
            `;

            // Add or update settings summary
            let settingsSummary = previewElement.parentElement.querySelector('.voice-settings-summary');
            if (!settingsSummary) {
                settingsSummary = document.createElement('div');
                settingsSummary.className = 'voice-settings-summary';
                previewElement.parentElement.appendChild(settingsSummary);
            }

            settingsSummary.innerHTML = `
                <small>
                    <i class="fas fa-sliders-h" style="color: #00ff00; margin-right: 6px;"></i>
                    <strong>Settings:</strong>
                    Speed: <span style="color: #66ff66;">${settings.speed || 1.0}</span> •
                    Pitch: <span style="color: #66ff66;">${settings.pitch || 0}</span> •
                    Volume: <span style="color: #66ff66;">${settings.volume || 0}</span>
                    ${settings.emotion && settings.emotion !== 'Neutral' ?
                        `• Emotion: <span style="color: #66ff66;">${settings.emotion}</span>` : ''}
                </small>
            `;
        }

        async function previewVoice(characterId, speakerId) {
            try {
                showMessage('Generating voice preview...', 'info');

                const response = await fetch('/api/voice/generate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        speaker_id: speakerId,
                        text: 'Hello, I am your character speaking.',
                        characterId: characterId
                    })
                });

                const data = await response.json();

                if (data.success && data.url) {
                    const audio = new Audio(data.url);
                    audio.play();
                    showMessage('Playing voice preview', 'success');
                } else {
                    showMessage(`Preview failed: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Preview error: ${error.message}`, 'error');
            }
        }

        // Global settings functions
        async function saveGlobalTTSSettings() {
            const formData = new FormData(document.getElementById('globalTTSForm'));
            const config = Object.fromEntries(formData.entries());

            try {
                showMessage('Saving global TTS settings...', 'info');

                const response = await fetch('/ai-management/api/tts/global', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config)
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('Global TTS settings saved successfully!', 'success');
                } else {
                    showMessage(`Failed to save global settings: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error saving global settings: ${error.message}`, 'error');
            }
        }

        async function saveAllVoiceAssignments() {
            try {
                showMessage('Saving all voice assignments...', 'info');

                const response = await fetch('/ai-management/api/tts/save-all', {
                    method: 'POST'
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('All voice assignments saved successfully!', 'success');
                } else {
                    showMessage(`Failed to save assignments: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error saving assignments: ${error.message}`, 'error');
            }
        }

        // Testing functions
        async function runTTSTest() {
            const characterId = document.getElementById('testCharacter').value;
            const text = document.getElementById('testText').value;

            if (!characterId) {
                showMessage('Please select a character to test', 'error');
                return;
            }

            if (!text.trim()) {
                showMessage('Please enter text to synthesize', 'error');
                return;
            }

            try {
                showMessage('Generating speech...', 'info');

                const response = await fetch('/api/voice/generate-test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        text: text,
                        characterId: characterId
                    })
                });

                const data = await response.json();

                if (data.success && data.url) {
                    const audio = document.getElementById('testAudio');
                    audio.src = data.url;
                    document.getElementById('audioPlayer').style.display = 'block';
                    currentAudioUrl = data.url;

                    // Set up audio event listeners
                    audio.onended = () => {
                        if (animationId) {
                            cancelAnimationFrame(animationId);
                            animationId = null;
                        }
                    };

                    // Auto-play the audio
                    audio.play().then(() => {
                        showMessage('Speech generated and playing!', 'success');
                        // Initialize waveform visualization after play starts
                        initializeWaveform(data.url);
                    }).catch(error => {
                        console.log('Auto-play prevented by browser:', error);
                        showMessage('Audio generated! Click play to listen.', 'success');
                        // Still initialize waveform for manual play
                        initializeWaveform(data.url);
                    });
                } else {
                    showMessage(`Speech generation failed: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Speech generation error: ${error.message}`, 'error');
            }
        }

        // Waveform visualization
        let audioContext = null;
        let analyser = null;
        let animationId = null;

        function initializeWaveform(audioUrl) {
            const canvas = document.getElementById('waveformCanvas');
            const ctx = canvas.getContext('2d');
            const audio = document.getElementById('testAudio');

            // Set canvas size
            canvas.width = canvas.offsetWidth;
            canvas.height = canvas.offsetHeight;

            // Initialize Web Audio API
            if (!audioContext) {
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
            }

            // Create audio source and analyser
            const source = audioContext.createMediaElementSource(audio);
            analyser = audioContext.createAnalyser();
            analyser.fftSize = 256;

            source.connect(analyser);
            analyser.connect(audioContext.destination);

            // Start visualization
            visualizeWaveform(ctx, canvas);
        }

        function visualizeWaveform(ctx, canvas) {
            if (!analyser) return;

            const bufferLength = analyser.frequencyBinCount;
            const dataArray = new Uint8Array(bufferLength);

            function draw() {
                if (!analyser) return;

                analyser.getByteFrequencyData(dataArray);

                ctx.fillStyle = '#000800';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                const barWidth = (canvas.width / bufferLength) * 2.5;
                let barHeight;
                let x = 0;

                for (let i = 0; i < bufferLength; i++) {
                    barHeight = (dataArray[i] / 255) * canvas.height * 0.8;

                    // Create gradient for bars
                    const gradient = ctx.createLinearGradient(0, canvas.height - barHeight, 0, canvas.height);
                    gradient.addColorStop(0, '#00ff00');
                    gradient.addColorStop(1, '#004400');

                    ctx.fillStyle = gradient;
                    ctx.fillRect(x, canvas.height - barHeight, barWidth, barHeight);

                    x += barWidth + 1;
                }

                animationId = requestAnimationFrame(draw);
            }

            draw();
        }

        function downloadAudio() {
            if (currentAudioUrl) {
                const a = document.createElement('a');
                a.href = currentAudioUrl;
                a.download = `tts-test-${Date.now()}.mp3`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
            }
        }

        async function saveToLibrary() {
            const characterId = document.getElementById('testCharacter').value;
            const text = document.getElementById('testText').value;

            if (!characterId || !text.trim()) {
                showMessage('Please select a character and enter text', 'error');
                return;
            }

            try {
                showMessage('Saving to sound library...', 'info');

                const response = await fetch('/api/voice/generate-for-scene', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        text: text,
                        characterId: characterId
                    })
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('Audio saved to sound library successfully!', 'success');
                } else {
                    showMessage(`Failed to save to library: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error saving to library: ${error.message}`, 'error');
            }
        }

        async function testAudioIntegrity() {
            if (!currentAudioUrl) {
                showMessage('No audio file to test. Please generate speech first.', 'error');
                return;
            }

            try {
                showMessage('Testing audio file integrity...', 'info');

                const response = await fetch('/api/voice/test-audio-integrity', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        audioUrl: currentAudioUrl
                    })
                });

                const data = await response.json();

                if (data.success) {
                    if (data.valid) {
                        let message = `✅ Audio file is valid and playable!`;
                        if (data.info && data.info.streams && data.info.streams[0]) {
                            const stream = data.info.streams[0];
                            message += `\n\nDetails:`;
                            message += `\n• Codec: ${stream.codec_name || 'Unknown'}`;
                            message += `\n• Duration: ${stream.duration ? parseFloat(stream.duration).toFixed(2) + 's' : 'Unknown'}`;
                            message += `\n• Sample Rate: ${stream.sample_rate || 'Unknown'}`;
                            message += `\n• Channels: ${stream.channels || 'Unknown'}`;
                            message += `\n• Bit Rate: ${stream.bit_rate || 'Unknown'}`;
                        }
                        if (data.info && data.info.format) {
                            message += `\n• Format: ${data.info.format.format_name || 'Unknown'}`;
                            message += `\n• File Size: ${data.info.format.size ? (parseInt(data.info.format.size) / 1024).toFixed(1) + ' KB' : 'Unknown'}`;
                        }
                        showMessage(message, 'success');
                    } else {
                        let message = `❌ Audio file appears to be corrupted or invalid!`;
                        message += `\n\nError: ${data.error || 'Unknown error'}`;
                        if (data.details) {
                            message += `\n\nDetails: ${data.details}`;
                        }
                        message += `\n\n💡 Try regenerating the audio or use WAV format instead.`;
                        showMessage(message, 'error');
                    }
                } else {
                    showMessage(`Audio integrity test failed: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Audio integrity test error: ${error.message}`, 'error');
            }
        }

        async function saveToLibrary() {
            const text = document.getElementById('testText').value;
            const characterId = document.getElementById('testCharacter').value;

            if (!currentAudioUrl || !text || !characterId) {
                showMessage('No audio to save or missing information', 'error');
                return;
            }

            try {
                showMessage('Saving to sound library...', 'info');

                const response = await fetch('/api/voice/save-to-library', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        text: text,
                        characterId: characterId,
                        audioUrl: currentAudioUrl
                    })
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('Audio saved to sound library!', 'success');
                } else {
                    showMessage(`Failed to save to library: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error saving to library: ${error.message}`, 'error');
            }
        }

        // Utility functions
        function showMessage(message, type) {
            const container = document.getElementById('messageContainer');
            const messageDiv = document.createElement('div');
            messageDiv.className = `${type}-message`;
            messageDiv.innerHTML = `<i class="fas fa-${type === 'error' ? 'exclamation-triangle' : type === 'success' ? 'check-circle' : 'info-circle'}"></i> ${message}`;

            container.innerHTML = '';
            container.appendChild(messageDiv);

            setTimeout(() => {
                if (messageDiv.parentNode) {
                    messageDiv.parentNode.removeChild(messageDiv);
                }
            }, 5000);
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('voiceCatalogModal');
            if (event.target === modal) {
                closeCatalogModal();
            }
        }
    </script>
</body>
</html>
