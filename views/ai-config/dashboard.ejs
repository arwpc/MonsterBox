<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .ai-dashboard {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .ai-system-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }
        
        .ai-system-card {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            position: relative;
            overflow: hidden;
        }
        
        .ai-system-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #ff0000, #00ff00, #ff0000);
            animation: pulse 2s ease-in-out infinite;
        }
        
        .system-header {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .system-icon {
            font-size: 2em;
            margin-right: 15px;
            color: #00ff00;
        }
        
        .system-title {
            color: #00ff00;
            font-size: 1.4em;
            font-weight: bold;
        }
        
        .system-status {
            display: flex;
            align-items: center;
            margin: 10px 0;
        }
        
        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 8px;
        }
        
        .status-online { background-color: #00ff00; }
        .status-offline { background-color: #ff0000; }
        .status-warning { background-color: #ffff00; }
        
        .system-details {
            margin: 15px 0;
            font-size: 0.9em;
            color: #cccccc;
        }
        
        .system-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }
        
        .pipeline-flow {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .flow-diagram {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
            gap: 15px;
        }
        
        .flow-step {
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            text-align: center;
            min-width: 120px;
            position: relative;
        }
        
        .flow-arrow {
            color: #00ff00;
            font-size: 1.5em;
        }
        
        .flow-step.active {
            border-color: #ffff00;
            box-shadow: 0 0 10px rgba(255, 255, 0, 0.3);
        }
        
        .quick-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }
        
        .action-card {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .action-card:hover {
            border-color: #ffff00;
            transform: translateY(-2px);
        }
        
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }
        
        .metric-card {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            text-align: center;
        }
        
        .metric-value {
            font-size: 2em;
            font-weight: bold;
            color: #00ff00;
        }
        
        .metric-label {
            font-size: 0.9em;
            color: #cccccc;
            margin-top: 5px;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .error-message {
            background: #330000;
            border: 1px solid #ff0000;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #ff6666;
        }

        /* Breadcrumb Navigation Styling */
        .breadcrumb-vertical {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 12px;
          margin-bottom: 20px;
          font-size: 1.1em;
        }

        .breadcrumb-item {
          color: #00ffff;
          text-decoration: none;
          transition: all 0.3s ease;
        }

        .breadcrumb-item:hover {
          color: #ffffff;
          text-shadow: 0 0 5px #00ffff;
        }

        .breadcrumb-item.active {
          color: #00ff00;
          font-weight: bold;
        }

        .breadcrumb-item:not(.active):after {
          content: ' → ';
          color: #666666;
          margin-left: 8px;
        }
    </style>
</head>
<body>
    <%- include('../components/universal-header') %>

    <main class="ai-dashboard">
        <div class="info-section">
            <h2>🤖 ElevenLabs Conversational AI Management</h2>
            <p>Centralized configuration and monitoring for ElevenLabs Conversational AI agents with integrated voice processing</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-message">
                <i class="fas fa-exclamation-triangle"></i>
                <strong>Error:</strong> <%= error %>
            </div>
        <% } %>

        <!-- ElevenLabs Conversational AI Flow -->
        <div class="pipeline-flow">
            <h3>🤖 ElevenLabs Conversational AI Pipeline</h3>
            <div class="flow-diagram">
                <div class="flow-step <%= status && status.elevenlabs && status.elevenlabs.online ? 'active' : '' %>">
                    <i class="fas fa-microphone system-icon"></i>
                    <div>Voice Input</div>
                    <small>Real-time Audio</small>
                </div>
                <div class="flow-arrow">→</div>
                <div class="flow-step <%= status && status.elevenlabs && status.elevenlabs.online ? 'active' : '' %>">
                    <i class="fas fa-robot system-icon"></i>
                    <div>ElevenLabs Agent</div>
                    <small>Conversational AI</small>
                </div>
                <div class="flow-arrow">→</div>
                <div class="flow-step <%= status && status.elevenlabs && status.elevenlabs.online ? 'active' : '' %>">
                    <i class="fas fa-volume-up system-icon"></i>
                    <div>Voice Output</div>
                    <small>Natural Speech</small>
                </div>
            </div>
        </div>

        <!-- ElevenLabs Systems Grid -->
        <div class="ai-system-grid">
            <!-- ElevenLabs Conversational AI -->
            <div class="ai-system-card">
                <div class="system-header">
                    <i class="fas fa-robot system-icon"></i>
                    <div class="system-title">ElevenLabs Conversational AI</div>
                </div>
                <div class="system-status">
                    <div class="status-indicator <%= status && status.elevenlabs && status.elevenlabs.online ? 'status-online' : 'status-offline' %>"></div>
                    <span><%= status && status.elevenlabs ? (status.elevenlabs.online ? 'Online' : 'Offline') : 'Unknown' %></span>
                </div>
                <div class="system-details">
                    <p><strong>Provider:</strong> ElevenLabs</p>
                    <p><strong>Active Agents:</strong> <%= status && status.elevenlabs ? status.elevenlabs.activeAgents || 0 : 0 %></p>
                    <p><strong>WebSocket Port:</strong> <%= status && status.elevenlabs ? status.elevenlabs.port || '8771' : 'Not configured' %></p>
                    <p><strong>Status:</strong> <%= status && status.elevenlabs ? status.elevenlabs.status || 'Unknown' : 'Not initialized' %></p>
                </div>
                <div class="system-actions">
                    <a href="/ai-management/agents" class="button primary-btn">
                        <i class="fas fa-cog"></i> Configure
                    </a>
                    <button class="button secondary-btn" onclick="testElevenLabs()">
                        <i class="fas fa-test-tube"></i> Test
                    </button>
                </div>
            </div>

            <!-- Voice Configuration -->
            <div class="ai-system-card">
                <div class="system-header">
                    <i class="fas fa-microphone-alt system-icon"></i>
                    <div class="system-title">Voice Configuration</div>
                </div>
                <div class="system-status">
                    <div class="status-indicator <%= status && status.elevenlabs && status.elevenlabs.online ? 'status-online' : 'status-offline' %>"></div>
                    <span><%= status && status.elevenlabs ? (status.elevenlabs.online ? 'Online' : 'Offline') : 'Unknown' %></span>
                </div>
                <div class="system-details">
                    <p><strong>Provider:</strong> ElevenLabs</p>
                    <p><strong>Available Voices:</strong> <%= status && status.elevenlabs ? status.elevenlabs.voiceCount || 'Loading...' : 'Unknown' %></p>
                    <p><strong>Configured Characters:</strong> <%= status && status.elevenlabs ? status.elevenlabs.configuredCharacters || 0 : 0 %></p>
                    <p><strong>Status:</strong> <%= status && status.elevenlabs ? status.elevenlabs.status || 'Unknown' : 'Not initialized' %></p>
                </div>
                <div class="system-actions">
                    <a href="/ai-management/voices" class="button primary-btn">
                        <i class="fas fa-cog"></i> Configure
                    </a>
                    <button class="button secondary-btn" onclick="testVoices()">
                        <i class="fas fa-test-tube"></i> Test
                    </button>
                </div>
            </div>

            <!-- Microphone and STT -->
            <div class="ai-system-card">
                <div class="system-header">
                    <i class="fas fa-microphone system-icon"></i>
                    <div class="system-title">Microphone and STT</div>
                </div>
                <div class="system-status">
                    <div class="status-indicator <%= status && status.elevenlabs && status.elevenlabs.online ? 'status-online' : 'status-offline' %>"></div>
                    <span><%= status && status.elevenlabs ? (status.elevenlabs.online ? 'Online' : 'Offline') : 'Unknown' %></span>
                </div>
                <div class="system-details">
                    <p><strong>Provider:</strong> Speech-to-Text Testing</p>
                    <p><strong>Microphones:</strong> Available</p>
                    <p><strong>STT Engine:</strong> <%= status && status.elevenlabs ? (status.elevenlabs.vadEnabled ? 'Enabled' : 'Disabled') : 'Unknown' %></p>
                    <p><strong>Status:</strong> <%= status && status.elevenlabs ? status.elevenlabs.status || 'Unknown' : 'Not initialized' %></p>
                </div>
                <div class="system-actions">
                    <a href="/ai-management/microphone-stt" class="button primary-btn">
                        <i class="fas fa-cog"></i> Configure
                    </a>
                    <button class="button secondary-btn" onclick="testSTT()">
                        <i class="fas fa-test-tube"></i> Test
                    </button>
                </div>
            </div>
        </div>



        <!-- Performance Metrics -->
        <div class="section-container">
            <h3>📊 Performance Metrics (Last 24 Hours)</h3>
            <div class="metrics-grid">
                <div class="metric-card">
                    <div class="metric-value">0</div>
                    <div class="metric-label">Total Requests</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value">0ms</div>
                    <div class="metric-label">Avg Response Time</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value">100%</div>
                    <div class="metric-label">Success Rate</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value">0</div>
                    <div class="metric-label">Errors</div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="section-container">
            <h3>⚡ Quick Actions</h3>
            <div class="quick-actions">
                <div class="action-card" onclick="testFullPipeline()">
                    <i class="fas fa-play-circle" style="font-size: 2em; color: #00ff00;"></i>
                    <h4>Test Full Pipeline</h4>
                    <p>Test complete STT → AI → TTS workflow</p>
                </div>
                <div class="action-card" onclick="exportConfig()">
                    <i class="fas fa-download" style="font-size: 2em; color: #00ff00;"></i>
                    <h4>Export Configuration</h4>
                    <p>Download AI settings backup</p>
                </div>
                <div class="action-card" onclick="importConfig()">
                    <i class="fas fa-upload" style="font-size: 2em; color: #00ff00;"></i>
                    <h4>Import Configuration</h4>
                    <p>Restore AI settings from backup</p>
                </div>
                <div class="action-card" onclick="viewLogs()">
                    <i class="fas fa-file-alt" style="font-size: 2em; color: #00ff00;"></i>
                    <h4>View AI Logs</h4>
                    <p>Monitor AI system activity</p>
                </div>
            </div>
        </div>

        <!-- Enhanced Navigation -->
        <div class="section-container">
            <h3>🧭 System Navigation</h3>
            <div class="navigation-grid">
                <div class="nav-section">
                    <h4>🤖 Conversational AI</h4>
                    <div class="button-group">
                        <a href="/ai-management/agents" class="button">🤖 ElevenLabs Agents</a>
                        <a href="/ai-management/voices" class="button">🎤 Voice Configuration</a>
                        <a href="/ai-management/microphone-stt" class="button">🎤 Microphone and STT</a>
                    </div>
                </div>

                <div class="nav-section">
                    <h4>🎭 Character Control</h4>
                    <div class="button-group">
                        <a href="/characters" class="button">🎭 Characters</a>
                        <a href="/ai-management/enhanced-test-chat" class="button">🤖 Enhanced Voice Chat</a>
                    </div>
                </div>

                <div class="nav-section">
                    <h4>⚙️ System Settings</h4>
                    <div class="button-group">
                        <a href="/configuration" class="button">⚙️ Configuration</a>
                        <a href="/" class="button secondary-btn">🏠 Main Menu</a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Test functions for ElevenLabs
        function testElevenLabs() {
            showModal('Testing ElevenLabs...', '<p>Testing ElevenLabs Conversational AI system...</p>');
            fetch('/ai-management/api/test/elevenlabs', { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showModal('ElevenLabs Test Result', `<p><strong>Success!</strong></p><p>Active Agents: ${data.activeAgents}</p><p>WebSocket Status: ${data.wsStatus}</p><p>Response Time: ${data.responseTime}ms</p>`);
                    } else {
                        showModal('ElevenLabs Test Failed', `<p><strong>Error:</strong> ${data.error}</p>`);
                    }
                })
                .catch(error => {
                    showModal('ElevenLabs Test Error', `<p><strong>Error:</strong> ${error.message}</p>`);
                });
        }

        function testVoices() {
            showModal('Testing Voices...', '<p>Testing ElevenLabs voice system...</p>');
            fetch('/ai-management/api/test/voices', { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showModal('Voice Test Result', `<p><strong>Success!</strong></p><p>Available Voices: ${data.voiceCount}</p><p>Response Time: ${data.responseTime}ms</p>`);
                    } else {
                        showModal('Voice Test Failed', `<p><strong>Error:</strong> ${data.error}</p>`);
                    }
                })
                .catch(error => {
                    showModal('Voice Test Error', `<p><strong>Error:</strong> ${error.message}</p>`);
                });
        }

        function testSTT() {
            showModal('Testing STT...', '<p>Testing Speech-to-Text system...</p>');
            fetch('/ai-management/api/test/stt', { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showModal('STT Test Result', `<p><strong>Success!</strong></p><p>STT System Status: ${data.sttSystemStatus}</p><p>VAD Status: ${data.vadStatus}</p><p>Response Time: ${data.responseTime}ms</p>`);
                    } else {
                        showModal('STT Test Failed', `<p><strong>Error:</strong> ${data.error}</p>`);
                    }
                })
                .catch(error => {
                    showModal('STT Test Error', `<p><strong>Error:</strong> ${error.message}</p>`);
                });
        }

        function testFullConversation() {
            showModal('Testing Full Conversation...', '<p>Testing complete ElevenLabs conversational AI workflow...</p><div id="conversationProgress"></div>');

            const progressDiv = document.getElementById('conversationProgress');
            progressDiv.innerHTML = '<p>🤖 Starting ElevenLabs conversation test...</p>';

            fetch('/ai-management/api/test/full-conversation', { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        let html = '<h4>Conversation Test Results:</h4>';
                        html += `<p>🤖 Agent Connection: ${data.agent.success ? '✅ Success' : '❌ Failed'} (${data.agent.responseTime}ms)</p>`;
                        html += `<p>🎤 Voice Input: ${data.voiceInput.success ? '✅ Success' : '❌ Failed'} (${data.voiceInput.responseTime}ms)</p>`;
                        html += `<p>🔊 Voice Output: ${data.voiceOutput.success ? '✅ Success' : '❌ Failed'} (${data.voiceOutput.responseTime}ms)</p>`;
                        html += `<p><strong>Total Time:</strong> ${data.totalTime}ms</p>`;
                        if (data.audioUrl) {
                            html += '<button onclick="playTestAudio(\'' + data.audioUrl + '\')" class="button">🔊 Play Result</button>';
                        }
                        showModal('Conversation Test Complete', html);
                    } else {
                        showModal('Conversation Test Failed', `<p><strong>Error:</strong> ${data.error}</p>`);
                    }
                })
                .catch(error => {
                    showModal('Conversation Test Error', `<p><strong>Error:</strong> ${error.message}</p>`);
                });
        }

        function playTestAudio(url) {
            const audio = new Audio(url);
            audio.play();
        }

        function exportConfig() {
            window.location.href = '/ai-management/api/export';
        }

        function importConfig() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json';
            input.onchange = function(e) {
                const file = e.target.files[0];
                if (file) {
                    const formData = new FormData();
                    formData.append('config', file);

                    fetch('/ai-management/api/import', {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showModal('Import Successful', '<p>Configuration imported successfully. Page will reload.</p>');
                            setTimeout(() => location.reload(), 2000);
                        } else {
                            showModal('Import Failed', `<p><strong>Error:</strong> ${data.error}</p>`);
                        }
                    })
                    .catch(error => {
                        showModal('Import Error', `<p><strong>Error:</strong> ${error.message}</p>`);
                    });
                }
            };
            input.click();
        }

        function viewLogs() {
            window.open('/log-collection/dashboard', '_blank');
        }

        // Modal functions
        function showModal(title, content) {
            // Create modal if it doesn't exist
            let modal = document.getElementById('testModal');
            if (!modal) {
                modal = document.createElement('div');
                modal.id = 'testModal';
                modal.className = 'modal';
                modal.innerHTML = `
                    <div class="modal-content">
                        <div class="modal-header">
                            <h3 id="modalTitle"></h3>
                            <span class="close" onclick="closeModal()">&times;</span>
                        </div>
                        <div class="modal-body" id="modalBody"></div>
                    </div>
                `;
                document.body.appendChild(modal);
            }

            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalBody').innerHTML = content;
            modal.style.display = 'block';
        }

        function closeModal() {
            const modal = document.getElementById('testModal');
            if (modal) {
                modal.style.display = 'none';
            }
        }





        // Auto-refresh status every 30 seconds
        setInterval(() => {
            // Refresh AI management status
            fetch('/ai-management/api/status')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Update without full page reload for better UX
                        console.log('AI status updated');
                    }
                })
                .catch(error => console.log('AI status refresh failed:', error));


        }, 30000);
    </script>

    <style>
        /* Modal styles */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
        }

        .modal-content {
            background-color: #001100;
            margin: 10% auto;
            padding: 0;
            border: 2px solid #00ff00;
            border-radius: 10px;
            width: 80%;
            max-width: 600px;
        }

        .modal-header {
            background-color: #000800;
            padding: 15px 20px;
            border-bottom: 1px solid #00ff00;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h3 {
            margin: 0;
            color: #00ff00;
        }

        .close {
            color: #ff0000;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

        .close:hover {
            color: #ff6666;
        }

        .modal-body {
            padding: 20px;
            color: #cccccc;
        }

        /* Navigation Grid Styles */
        .navigation-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .nav-section {
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
        }

        .nav-section h4 {
            color: #00ff00;
            margin-bottom: 15px;
            font-size: 1.1em;
            text-shadow: 0 0 5px #00ff00;
        }

        .nav-section .button-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .nav-section .button {
            text-align: left;
            justify-content: flex-start;
            padding: 10px 15px;
            font-size: 0.9em;
        }
    </style>

    <!-- AI Management Dashboard Scripts -->
    <script>
        // Enhanced dashboard functionality
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🤖 AI Management Dashboard initialized');

            // Initialize status checks

            // Add keyboard shortcuts
            document.addEventListener('keydown', function(e) {
                if (e.ctrlKey || e.metaKey) {
                    switch(e.key) {
                        case '1':
                            e.preventDefault();
                            window.location.href = '/ai-management/stt';
                            break;
                        case '2':
                            e.preventDefault();
                            window.location.href = '/ai-management/personalities';
                            break;
                        case '3':
                            e.preventDefault();
                            window.location.href = '/ai-management/tts';
                            break;

                    }
                }
            });
        });
    </script>
</body>
</html>
