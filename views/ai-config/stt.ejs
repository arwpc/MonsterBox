<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Speech-to-Text Configuration - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .stt-config {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .config-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .config-header {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .config-icon {
            font-size: 2em;
            margin-right: 15px;
            color: #00ff00;
        }
        
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group.full-width {
            grid-column: 1 / -1;
        }
        
        .form-group label {
            display: block;
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 8px;
        }
        
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px;
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
            font-family: inherit;
        }
        
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #ffff00;
            box-shadow: 0 0 5px rgba(255, 255, 0, 0.3);
        }
        
        .form-help {
            font-size: 0.9em;
            color: #cccccc;
            margin-top: 5px;
        }
        
        .status-display {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
        }
        
        .status-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 10px 0;
        }
        
        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-left: 10px;
        }
        
        .status-online { background-color: #00ff00; }
        .status-offline { background-color: #ff0000; }
        .status-warning { background-color: #ffff00; }
        
        .test-section {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .audio-controls {
            display: flex;
            gap: 10px;
            align-items: center;
            margin: 15px 0;
        }
        
        .record-button {
            background: #ff0000;
            border: none;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            color: white;
            font-size: 1.5em;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .record-button:hover {
            background: #ff3333;
            transform: scale(1.1);
        }
        
        .record-button.recording {
            background: #ffff00;
            color: #000000;
            animation: pulse 1s infinite;
        }
        
        .audio-level {
            flex: 1;
            height: 20px;
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 10px;
            overflow: hidden;
            position: relative;
        }
        
        .audio-level-bar {
            height: 100%;
            background: linear-gradient(90deg, #00ff00, #ffff00, #ff0000);
            width: 0%;
            transition: width 0.1s ease;
        }
        
        .transcription-result {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
            min-height: 60px;
            color: #ffffff;
        }
        
        .confidence-meter {
            display: flex;
            align-items: center;
            margin: 10px 0;
        }
        
        .confidence-bar {
            flex: 1;
            height: 10px;
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 5px;
            margin: 0 10px;
            overflow: hidden;
        }
        
        .confidence-fill {
            height: 100%;
            background: linear-gradient(90deg, #ff0000, #ffff00, #00ff00);
            transition: width 0.3s ease;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .error-message {
            background: #330000;
            border: 1px solid #ff0000;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #ff6666;
        }
        
        .success-message {
            background: #003300;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #66ff66;
        }
    </style>
</head>
<body>
    <header>
        <h1>🎤 Speech-to-Text Configuration</h1>
        <nav class="breadcrumb">
            <a href="/">Home</a> &gt; 
            <a href="/ai-management">AI Management</a> &gt; 
            <span>STT Configuration</span>
        </nav>
    </header>

    <main class="stt-config">
        <div class="info-section">
            <h2>🎤 OpenAI Whisper STT Configuration</h2>
            <p>Configure Speech-to-Text settings for converting spoken audio into text streams for AI processing</p>
        </div>

        <!-- Status Display -->
        <div class="status-display">
            <h3>📊 Current Status</h3>
            <div class="status-item">
                <span>OpenAI API Connection</span>
                <div style="display: flex; align-items: center;">
                    <span id="apiStatus">Checking...</span>
                    <div class="status-indicator" id="apiIndicator"></div>
                </div>
            </div>
            <div class="status-item">
                <span>Microphone Access</span>
                <div style="display: flex; align-items: center;">
                    <span id="micStatus">Checking...</span>
                    <div class="status-indicator" id="micIndicator"></div>
                </div>
            </div>
            <div class="status-item">
                <span>Audio Processing</span>
                <div style="display: flex; align-items: center;">
                    <span id="audioStatus">Ready</span>
                    <div class="status-indicator status-online" id="audioIndicator"></div>
                </div>
            </div>
        </div>

        <!-- Configuration Form -->
        <form id="sttConfigForm" class="config-section">
            <div class="config-header">
                <i class="fas fa-cog config-icon"></i>
                <h3>Configuration Settings</h3>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label for="apiKey">OpenAI API Key</label>
                    <input type="password" id="apiKey" name="apiKey" value="<%= config && config.apiKey ? '••••••••••••' : '' %>" placeholder="sk-...">
                    <div class="form-help">Your OpenAI API key for Whisper access</div>
                </div>

                <div class="form-group">
                    <label for="model">Whisper Model</label>
                    <select id="model" name="model">
                        <option value="whisper-1" <%= config && config.model === 'whisper-1' ? 'selected' : '' %>>whisper-1 (Recommended)</option>
                    </select>
                    <div class="form-help">OpenAI Whisper model version</div>
                </div>

                <div class="form-group">
                    <label for="language">Language</label>
                    <select id="language" name="language">
                        <option value="auto" <%= config && config.language === 'auto' ? 'selected' : '' %>>Auto-detect</option>
                        <option value="en" <%= config && config.language === 'en' ? 'selected' : '' %>>English</option>
                        <option value="es" <%= config && config.language === 'es' ? 'selected' : '' %>>Spanish</option>
                        <option value="fr" <%= config && config.language === 'fr' ? 'selected' : '' %>>French</option>
                        <option value="de" <%= config && config.language === 'de' ? 'selected' : '' %>>German</option>
                        <option value="it" <%= config && config.language === 'it' ? 'selected' : '' %>>Italian</option>
                        <option value="pt" <%= config && config.language === 'pt' ? 'selected' : '' %>>Portuguese</option>
                        <option value="ru" <%= config && config.language === 'ru' ? 'selected' : '' %>>Russian</option>
                        <option value="ja" <%= config && config.language === 'ja' ? 'selected' : '' %>>Japanese</option>
                        <option value="ko" <%= config && config.language === 'ko' ? 'selected' : '' %>>Korean</option>
                        <option value="zh" <%= config && config.language === 'zh' ? 'selected' : '' %>>Chinese</option>
                    </select>
                    <div class="form-help">Primary language for speech recognition</div>
                </div>

                <div class="form-group">
                    <label for="confidenceThreshold">Confidence Threshold</label>
                    <input type="range" id="confidenceThreshold" name="confidenceThreshold" 
                           min="0.1" max="1.0" step="0.1" 
                           value="<%= config && config.confidenceThreshold ? config.confidenceThreshold : '0.7' %>"
                           oninput="updateConfidenceDisplay(this.value)">
                    <div class="form-help">
                        Minimum confidence level: <span id="confidenceValue"><%= config && config.confidenceThreshold ? config.confidenceThreshold : '0.7' %></span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="chunkDuration">Audio Chunk Duration (ms)</label>
                    <input type="number" id="chunkDuration" name="chunkDuration" 
                           min="1000" max="10000" step="500"
                           value="<%= config && config.chunkDuration ? config.chunkDuration : '2000' %>">
                    <div class="form-help">Length of audio chunks for processing</div>
                </div>

                <div class="form-group">
                    <label for="timeout">Request Timeout (ms)</label>
                    <input type="number" id="timeout" name="timeout" 
                           min="5000" max="60000" step="1000"
                           value="<%= config && config.timeout ? config.timeout : '30000' %>">
                    <div class="form-help">Maximum time to wait for API response</div>
                </div>

                <div class="form-group">
                    <label for="fallbackToSystem">Enable System Fallback</label>
                    <select id="fallbackToSystem" name="fallbackToSystem">
                        <option value="true" <%= config && config.fallbackToSystem ? 'selected' : '' %>>Enabled</option>
                        <option value="false" <%= config && !config.fallbackToSystem ? 'selected' : '' %>>Disabled</option>
                    </select>
                    <div class="form-help">Use system STT if OpenAI fails</div>
                </div>
            </div>

            <div class="button-group">
                <button type="submit" class="button primary-btn">
                    <i class="fas fa-save"></i> Save Configuration
                </button>
                <button type="button" class="button secondary-btn" onclick="testConnection()">
                    <i class="fas fa-test-tube"></i> Test Connection
                </button>
                <a href="/ai-management" class="button secondary-btn">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </form>

        <!-- Live Testing Section -->
        <div class="test-section">
            <div class="config-header">
                <i class="fas fa-microphone-alt config-icon"></i>
                <h3>Live STT Testing</h3>
            </div>

            <div class="audio-controls">
                <button type="button" class="record-button" id="recordButton" onclick="toggleRecording()">
                    <i class="fas fa-microphone"></i>
                </button>
                <div class="audio-level">
                    <div class="audio-level-bar" id="audioLevelBar"></div>
                </div>
                <span id="recordingStatus">Click to start recording</span>
            </div>

            <div class="transcription-result" id="transcriptionResult">
                <em>Transcription will appear here...</em>
            </div>

            <div class="confidence-meter">
                <span>Confidence:</span>
                <div class="confidence-bar">
                    <div class="confidence-fill" id="confidenceFill" style="width: 0%"></div>
                </div>
                <span id="confidencePercent">0%</span>
            </div>

            <div class="button-group">
                <button type="button" class="button secondary-btn" onclick="clearResults()">
                    <i class="fas fa-trash"></i> Clear Results
                </button>
                <button type="button" class="button secondary-btn" onclick="downloadAudio()" id="downloadBtn" disabled>
                    <i class="fas fa-download"></i> Download Audio
                </button>
            </div>
        </div>

        <!-- Messages -->
        <div id="messageContainer"></div>
    </main>

    <script>
        let mediaRecorder = null;
        let audioChunks = [];
        let isRecording = false;
        let audioContext = null;
        let analyser = null;
        let microphone = null;
        let animationId = null;

        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            checkStatus();
            updateConfidenceDisplay(document.getElementById('confidenceThreshold').value);
        });

        // Form submission
        document.getElementById('sttConfigForm').addEventListener('submit', function(e) {
            e.preventDefault();
            saveConfiguration();
        });

        function updateConfidenceDisplay(value) {
            document.getElementById('confidenceValue').textContent = value;
        }

        async function checkStatus() {
            try {
                // Check API status
                const apiResponse = await fetch('/ai-management/api/stt/status');
                const apiData = await apiResponse.json();

                updateStatusIndicator('apiStatus', 'apiIndicator',
                    apiData.success ? 'Connected' : 'Disconnected',
                    apiData.success ? 'online' : 'offline'
                );

                // Check microphone access
                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                    updateStatusIndicator('micStatus', 'micIndicator', 'Available', 'online');
                    stream.getTracks().forEach(track => track.stop());
                } catch (error) {
                    updateStatusIndicator('micStatus', 'micIndicator', 'Not Available', 'offline');
                }
            } catch (error) {
                console.error('Status check failed:', error);
                updateStatusIndicator('apiStatus', 'apiIndicator', 'Error', 'offline');
            }
        }

        function updateStatusIndicator(statusId, indicatorId, text, status) {
            document.getElementById(statusId).textContent = text;
            const indicator = document.getElementById(indicatorId);
            indicator.className = `status-indicator status-${status}`;
        }

        async function saveConfiguration() {
            const formData = new FormData(document.getElementById('sttConfigForm'));
            const config = Object.fromEntries(formData.entries());

            try {
                showMessage('Saving configuration...', 'info');

                const response = await fetch('/ai-management/api/stt/config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config)
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('Configuration saved successfully!', 'success');
                    checkStatus(); // Refresh status
                } else {
                    showMessage(`Failed to save configuration: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error saving configuration: ${error.message}`, 'error');
            }
        }

        async function testConnection() {
            try {
                showMessage('Testing OpenAI Whisper connection...', 'info');

                const response = await fetch('/ai-management/api/stt/test', {
                    method: 'POST'
                });

                const data = await response.json();

                if (data.success) {
                    showMessage(`Connection test successful! Response time: ${data.responseTime}ms`, 'success');
                } else {
                    showMessage(`Connection test failed: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Connection test error: ${error.message}`, 'error');
            }
        }

        async function toggleRecording() {
            if (isRecording) {
                stopRecording();
            } else {
                await startRecording();
            }
        }

        async function startRecording() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({
                    audio: {
                        echoCancellation: true,
                        noiseSuppression: true,
                        autoGainControl: true
                    }
                });

                // Set up audio context for level monitoring
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                analyser = audioContext.createAnalyser();
                microphone = audioContext.createMediaStreamSource(stream);
                microphone.connect(analyser);
                analyser.fftSize = 256;

                // Start level monitoring
                monitorAudioLevel();

                // Set up media recorder
                mediaRecorder = new MediaRecorder(stream);
                audioChunks = [];

                mediaRecorder.ondataavailable = function(event) {
                    audioChunks.push(event.data);
                };

                mediaRecorder.onstop = function() {
                    processRecording();
                };

                mediaRecorder.start();
                isRecording = true;

                // Update UI
                const recordButton = document.getElementById('recordButton');
                recordButton.classList.add('recording');
                recordButton.innerHTML = '<i class="fas fa-stop"></i>';
                document.getElementById('recordingStatus').textContent = 'Recording... Click to stop';

            } catch (error) {
                showMessage(`Failed to start recording: ${error.message}`, 'error');
            }
        }

        function stopRecording() {
            if (mediaRecorder && isRecording) {
                mediaRecorder.stop();
                isRecording = false;

                // Stop audio monitoring
                if (animationId) {
                    cancelAnimationFrame(animationId);
                }
                if (audioContext) {
                    audioContext.close();
                }

                // Update UI
                const recordButton = document.getElementById('recordButton');
                recordButton.classList.remove('recording');
                recordButton.innerHTML = '<i class="fas fa-microphone"></i>';
                document.getElementById('recordingStatus').textContent = 'Processing...';
                document.getElementById('audioLevelBar').style.width = '0%';
            }
        }

        function monitorAudioLevel() {
            const bufferLength = analyser.frequencyBinCount;
            const dataArray = new Uint8Array(bufferLength);

            function updateLevel() {
                analyser.getByteFrequencyData(dataArray);

                let sum = 0;
                for (let i = 0; i < bufferLength; i++) {
                    sum += dataArray[i];
                }
                const average = sum / bufferLength;
                const percentage = (average / 255) * 100;

                document.getElementById('audioLevelBar').style.width = percentage + '%';

                if (isRecording) {
                    animationId = requestAnimationFrame(updateLevel);
                }
            }

            updateLevel();
        }

        async function processRecording() {
            try {
                const audioBlob = new Blob(audioChunks, { type: 'audio/wav' });
                const formData = new FormData();
                formData.append('audio', audioBlob, 'recording.wav');

                showMessage('Transcribing audio...', 'info');

                const response = await fetch('/ai-management/api/stt/transcribe', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    document.getElementById('transcriptionResult').innerHTML =
                        `<strong>Transcription:</strong><br>"${data.text}"<br><br>` +
                        `<small>Provider: ${data.provider} | Response Time: ${data.responseTime}ms</small>`;

                    const confidence = data.confidence || 1.0;
                    const confidencePercent = Math.round(confidence * 100);
                    document.getElementById('confidenceFill').style.width = confidencePercent + '%';
                    document.getElementById('confidencePercent').textContent = confidencePercent + '%';

                    document.getElementById('downloadBtn').disabled = false;
                    showMessage('Transcription completed successfully!', 'success');
                } else {
                    showMessage(`Transcription failed: ${data.error}`, 'error');
                }

                document.getElementById('recordingStatus').textContent = 'Click to start recording';
            } catch (error) {
                showMessage(`Processing error: ${error.message}`, 'error');
                document.getElementById('recordingStatus').textContent = 'Click to start recording';
            }
        }

        function clearResults() {
            document.getElementById('transcriptionResult').innerHTML = '<em>Transcription will appear here...</em>';
            document.getElementById('confidenceFill').style.width = '0%';
            document.getElementById('confidencePercent').textContent = '0%';
            document.getElementById('downloadBtn').disabled = true;
            audioChunks = [];
        }

        function downloadAudio() {
            if (audioChunks.length > 0) {
                const audioBlob = new Blob(audioChunks, { type: 'audio/wav' });
                const url = URL.createObjectURL(audioBlob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `stt-test-${Date.now()}.wav`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            }
        }

        function showMessage(message, type) {
            const container = document.getElementById('messageContainer');
            const messageDiv = document.createElement('div');
            messageDiv.className = `${type}-message`;
            messageDiv.innerHTML = `<i class="fas fa-${type === 'error' ? 'exclamation-triangle' : type === 'success' ? 'check-circle' : 'info-circle'}"></i> ${message}`;

            container.innerHTML = '';
            container.appendChild(messageDiv);

            setTimeout(() => {
                if (messageDiv.parentNode) {
                    messageDiv.parentNode.removeChild(messageDiv);
                }
            }, 5000);
        }
    </script>
</body>
</html>
