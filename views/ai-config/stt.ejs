<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Speech-to-Text Configuration - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .stt-config {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .config-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .config-header {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .config-icon {
            font-size: 2em;
            margin-right: 15px;
            color: #00ff00;
        }
        
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
        }
        
        .form-group {
            margin-bottom: 35px;
            padding: 15px 15px 50px 15px; /* Much more bottom padding for help text */
            background: rgba(0, 255, 0, 0.05);
            border-radius: 8px;
            border: 1px solid rgba(0, 255, 0, 0.2);
            position: relative;
            overflow: visible;
            min-height: 110px; /* Ensure minimum height for proper spacing */
            display: block; /* Ensure block layout */
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-group label {
            display: block;
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 10px;
            font-size: 16px;
            width: 100%;
            clear: both;
        }
        
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px;
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
            font-family: inherit;
            font-size: 14px;
            display: block;
            box-sizing: border-box;
            margin-top: 5px;
        }

        .form-group select {
            background: #001100;
            color: #ffffff;
            cursor: pointer;
            position: relative;
            z-index: 10;
        }

        .form-group select:focus {
            z-index: 20;
        }

        .form-group select option {
            background: #001100;
            color: #ffffff;
            padding: 8px;
            border: none;
        }

        .form-group select option:hover,
        .form-group select option:selected {
            background: #00ff00;
            color: #000000;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #ffff00;
            box-shadow: 0 0 8px rgba(255, 255, 0, 0.5);
            background: #002200;
        }
        
        .form-help {
            font-size: 11px;
            color: #aaffaa;
            margin-top: 10px;
            margin-bottom: 0;
            font-style: italic;
            line-height: 1.3;
            position: absolute;
            bottom: 10px;
            left: 15px;
            right: 15px;
            z-index: 1;
            display: block;
        }
        
        .status-display {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
        }
        
        .status-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 10px 0;
        }
        
        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-left: 10px;
        }
        
        .status-online { background-color: #00ff00; }
        .status-offline { background-color: #ff0000; }
        .status-warning { background-color: #ffff00; }
        
        .test-section {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .audio-controls {
            display: flex;
            gap: 10px;
            align-items: center;
            margin: 15px 0;
        }
        
        .record-button {
            background: #ff0000;
            border: none;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            color: white;
            font-size: 1.5em;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .record-button:hover {
            background: #ff3333;
            transform: scale(1.1);
        }
        
        .record-button.recording {
            background: #ffff00;
            color: #000000;
            animation: pulse 1s infinite;
        }
        
        .audio-level {
            flex: 1;
            height: 20px;
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 10px;
            overflow: hidden;
            position: relative;
        }
        
        .audio-level-bar {
            height: 100%;
            background: linear-gradient(90deg, #00ff00, #ffff00, #ff0000);
            width: 0%;
            transition: width 0.1s ease;
        }
        
        .transcription-result {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
            min-height: 60px;
            color: #ffffff;
        }
        
        .confidence-meter {
            display: flex;
            align-items: center;
            margin: 10px 0;
        }
        
        .confidence-bar {
            flex: 1;
            height: 10px;
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 5px;
            margin: 0 10px;
            overflow: hidden;
        }
        
        .confidence-fill {
            height: 100%;
            background: linear-gradient(90deg, #ff0000, #ffff00, #00ff00);
            transition: width 0.3s ease;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .error-message {
            background: #330000;
            border: 1px solid #ff0000;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #ff6666;
        }
        
        .success-message {
            background: #003300;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #66ff66;
        }

        /* Audio Level Indicator Styles */
        .audio-level-section {
            margin-top: 15px;
            padding: 15px;
            background: rgba(0, 255, 0, 0.05);
            border: 1px solid rgba(0, 255, 0, 0.2);
            border-radius: 8px;
        }

        .audio-level-container {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 10px;
        }

        .audio-level-meter {
            display: flex;
            align-items: center;
            gap: 15px;
            background: rgba(0, 0, 0, 0.3);
            padding: 10px;
            border-radius: 6px;
        }

        .audio-level-bar {
            flex: 1;
            height: 20px;
            background: rgba(0, 0, 0, 0.5);
            border-radius: 10px;
            overflow: hidden;
            position: relative;
            border: 1px solid rgba(0, 255, 0, 0.3);
        }

        .audio-level-bar::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: var(--level, 0%);
            background: linear-gradient(90deg,
                #00ff00 0%,
                #88ff00 30%,
                #ffff00 60%,
                #ff8800 80%,
                #ff0000 100%);
            border-radius: 10px;
            transition: width 0.1s ease-out;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
        }

        .audio-level-bar.low::before {
            background: linear-gradient(90deg, #00ff00, #88ff00);
        }

        .audio-level-bar.medium::before {
            background: linear-gradient(90deg, #88ff00, #ffff00);
        }

        .audio-level-bar.high::before {
            background: linear-gradient(90deg, #ffff00, #ff0000);
            box-shadow: 0 0 15px rgba(255, 0, 0, 0.5);
        }

        .audio-level-text {
            min-width: 50px;
            text-align: center;
            color: #00ff00;
            font-family: monospace;
            font-weight: bold;
            font-size: 14px;
        }

        .audio-level-controls {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .btn-small {
            background: rgba(0, 255, 0, 0.1);
            border: 1px solid #00ff00;
            color: #00ff00;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s ease;
        }

        .btn-small:hover {
            background: rgba(0, 255, 0, 0.2);
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
        }

        .btn-small:active {
            background: rgba(0, 255, 0, 0.3);
        }

        .btn-small.active {
            background: #00ff00;
            color: #000000;
        }

        /* Enhanced existing audio level bar in testing section */
        .audio-controls .audio-level-bar {
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 0, 0.3);
        }

        /* ChatterPi Integration Styles */
        .integration-notice {
            background: linear-gradient(135deg, #001100, #002200);
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            position: relative;
            overflow: hidden;
        }

        .integration-notice::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 0, 0.1), transparent);
            animation: shimmer 3s infinite;
        }

        @keyframes shimmer {
            0% { left: -100%; }
            100% { left: 100%; }
        }

        .notice-content {
            display: flex;
            align-items: center;
            gap: 15px;
            position: relative;
            z-index: 1;
        }

        .notice-content i {
            color: #00ff00;
            font-size: 1.2em;
        }

        .integration-link {
            color: #ff6600;
            text-decoration: none;
            font-weight: bold;
            margin-left: 10px;
        }

        .integration-link:hover {
            color: #ff8833;
            text-decoration: underline;
        }

        .jaw-animation-integration {
            background: #001100;
            border: 1px solid #ff6600;
            border-radius: 6px;
            padding: 12px;
            margin-top: 15px;
        }

        .integration-header {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .jaw-status {
            margin-left: 8px;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: bold;
        }

        .jaw-status.connected {
            background: rgba(0, 255, 0, 0.2);
            color: #00ff00;
            border: 1px solid rgba(0, 255, 0, 0.3);
        }

        .jaw-status.disconnected {
            background: rgba(255, 0, 0, 0.2);
            color: #ff6666;
            border: 1px solid rgba(255, 0, 0, 0.3);
        }

        .integration-controls {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .small-btn {
            padding: 6px 12px;
            font-size: 12px;
            border-radius: 4px;
        }

        /* UI Layout Improvements */
        .quick-actions {
            display: flex;
            gap: 15px;
            margin: 20px 0;
            padding: 20px;
            background: rgba(0, 255, 0, 0.05);
            border: 1px solid rgba(0, 255, 0, 0.2);
            border-radius: 8px;
            flex-wrap: wrap;
        }

        .prominent-section {
            border: 2px solid #00ff00;
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.2);
            position: relative;
        }

        .prominent-section::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, #00ff00, #88ff00, #00ff00);
            border-radius: 10px;
            z-index: -1;
            opacity: 0.3;
        }

        .config-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .config-status, .test-status {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .config-indicator, .test-indicator {
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
            background: rgba(0, 255, 0, 0.1);
            border: 1px solid rgba(0, 255, 0, 0.3);
            color: #00ff00;
        }

        .config-tabs {
            display: flex;
            gap: 5px;
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(0, 255, 0, 0.2);
        }

        .tab-btn {
            background: transparent;
            border: none;
            color: #888;
            padding: 12px 20px;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .tab-btn:hover {
            color: #00ff00;
            background: rgba(0, 255, 0, 0.05);
        }

        .tab-btn.active {
            color: #00ff00;
            border-bottom-color: #00ff00;
            background: rgba(0, 255, 0, 0.1);
        }

        .config-tab {
            display: none;
        }

        .config-tab.active {
            display: block;
        }

        .slider-container {
            display: flex;
            align-items: center;
            gap: 15px;
            margin: 10px 0 35px 0; /* Extra bottom margin for help text */
        }

        .slider-container input[type="range"] {
            flex: 1;
            height: 8px;
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 5px;
            outline: none;
            cursor: pointer;
        }

        .slider-container input[type="range"]::-webkit-slider-thumb {
            appearance: none;
            width: 20px;
            height: 20px;
            background: #00ff00;
            border-radius: 50%;
            cursor: pointer;
            border: 2px solid #ffffff;
        }

        .slider-container input[type="range"]::-moz-range-thumb {
            width: 20px;
            height: 20px;
            background: #00ff00;
            border-radius: 50%;
            cursor: pointer;
            border: 2px solid #ffffff;
        }

        .slider-value {
            min-width: 50px;
            text-align: center;
            background: #00ff00;
            border: 2px solid #00ff00;
            border-radius: 5px;
            padding: 8px 12px;
            color: #000000;
            font-family: monospace;
            font-weight: bold;
            font-size: 14px;
        }





        .button-group {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin-top: 30px;
        }

        .button {
            padding: 12px 20px;
            border-radius: 6px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            border: none;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .primary-btn {
            background: #00ff00;
            color: #000000;
            font-weight: bold;
        }

        .primary-btn:hover {
            background: #88ff00;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.5);
        }

        .secondary-btn {
            background: rgba(0, 255, 0, 0.1);
            color: #00ff00;
            border: 1px solid rgba(0, 255, 0, 0.3);
        }

        .secondary-btn:hover {
            background: rgba(0, 255, 0, 0.2);
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
        }

        /* Responsive improvements */
        @media (max-width: 768px) {
            .quick-actions {
                flex-direction: column;
            }

            .config-tabs {
                flex-direction: column;
            }

            .button-group {
                flex-direction: column;
            }

            .slider-container {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>
</head>
<body>
    <header>
        <h1>🎤 Speech-to-Text Configuration</h1>
        <div class="breadcrumb-vertical mb-6">
            <a href="/" class="breadcrumb-item">🏠 Home</a>
            <a href="/ai-management" class="breadcrumb-item">🧠 AI Management</a>
            <span class="breadcrumb-item active">🎤 STT Configuration</span>
        </div>
    </header>

    <main class="stt-config">
        <div class="info-section">
            <h2>🎤 OpenAI Whisper STT Configuration</h2>
            <p>Configure Speech-to-Text settings for converting spoken audio into text streams for AI processing</p>
            <div class="integration-notice">
                <div class="notice-content">
                    <i class="fas fa-info-circle"></i>
                    <div>
                        <strong>ChatterPi Integration:</strong> STT settings automatically sync with jaw animation system for real-time audio-driven character performance.
                        <a href="/chatterpi" class="integration-link">🦴 Manage Jaw Animation</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions Bar -->
        <div class="quick-actions">
            <button type="button" class="button primary-btn" onclick="testConnection()">
                <i class="fas fa-test-tube"></i> Test Connection
            </button>
            <button type="button" class="button secondary-btn" onclick="toggleRecording()">
                <i class="fas fa-microphone"></i> Quick Test Recording
            </button>
            <button type="button" class="button secondary-btn" onclick="testJawAnimationWithSTT()">
                <i class="fas fa-robot"></i> Test Jaw Animation
            </button>
            <button type="button" class="button secondary-btn" onclick="document.getElementById('sttConfigForm').scrollIntoView({behavior: 'smooth'})">
                <i class="fas fa-cog"></i> Configuration Settings
            </button>
        </div>

        <!-- Status Display -->
        <div class="status-display">
            <h3>📊 System Status</h3>
            <div class="status-item">
                <span>OpenAI API Connection</span>
                <div style="display: flex; align-items: center;">
                    <span id="apiStatus">Checking...</span>
                    <div class="status-indicator" id="apiIndicator"></div>
                </div>
            </div>
            <div class="status-item">
                <span>Microphone Access</span>
                <div style="display: flex; align-items: center;">
                    <span id="micStatus">Checking...</span>
                    <div class="status-indicator" id="micIndicator"></div>
                </div>
            </div>
            <div class="status-item">
                <span>Audio Processing</span>
                <div style="display: flex; align-items: center;">
                    <span id="audioStatus">Ready</span>
                    <div class="status-indicator status-online" id="audioIndicator"></div>
                </div>
            </div>
            <div class="status-item">
                <span>ChatterPi Jaw Animation</span>
                <div style="display: flex; align-items: center;">
                    <span id="chatterpiStatus">Checking...</span>
                    <div class="status-indicator" id="chatterpiIndicator"></div>
                </div>
            </div>

            <!-- Real-time Audio Level Indicator -->
            <div class="status-item audio-level-section" id="audioLevelSection" style="display: none;">
                <span>🎤 Audio Level</span>
                <div class="audio-level-container">
                    <div class="audio-level-meter">
                        <div class="audio-level-bar" id="audioLevelBar"></div>
                        <div class="audio-level-text" id="audioLevelText">0%</div>
                    </div>
                    <div class="audio-level-controls">
                        <button class="btn-small" id="toggleAudioMonitor" onclick="toggleAudioMonitoring()">
                            📊 Start Monitoring
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Configuration Form -->
        <form id="sttConfigForm" class="config-section prominent-section">
            <div class="config-header">
                <i class="fas fa-cog config-icon"></i>
                <h3>⚙️ Configuration Settings</h3>
                <div class="config-status">
                    <span class="config-indicator" id="configStatus">Not Configured</span>
                </div>
            </div>

            <div class="config-tabs">
                <button type="button" class="tab-btn active" onclick="switchConfigTab('basic')">
                    🔧 Basic Settings
                </button>
                <button type="button" class="tab-btn" onclick="switchConfigTab('advanced')">
                    ⚡ Advanced Settings
                </button>
            </div>

            <!-- Basic Settings Tab -->
            <div id="basicSettings" class="config-tab active">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="apiKey">🔑 OpenAI API Key</label>
                        <input type="password" id="apiKey" name="apiKey" value="<%= config && config.apiKey ? '••••••••••••' : '' %>" placeholder="sk-...">
                        <div class="form-help">Your OpenAI API key for Whisper access</div>
                    </div>

                    <div class="form-group">
                        <label for="model">🤖 Whisper Model</label>
                        <select id="model" name="model">
                            <option value="whisper-1" <%= config && config.model === 'whisper-1' ? 'selected' : '' %>>whisper-1 (Recommended)</option>
                        </select>
                        <div class="form-help">OpenAI Whisper model version</div>
                    </div>

                    <div class="form-group">
                        <label for="language">🌍 Language</label>
                        <select id="language" name="language">
                            <option value="auto" <%= config && config.language === 'auto' ? 'selected' : '' %>>Auto-detect (Recommended)</option>
                            <option value="en" <%= config && config.language === 'en' ? 'selected' : '' %>>English</option>
                            <option value="es" <%= config && config.language === 'es' ? 'selected' : '' %>>Spanish</option>
                            <option value="fr" <%= config && config.language === 'fr' ? 'selected' : '' %>>French</option>
                            <option value="de" <%= config && config.language === 'de' ? 'selected' : '' %>>German</option>
                            <option value="it" <%= config && config.language === 'it' ? 'selected' : '' %>>Italian</option>
                            <option value="pt" <%= config && config.language === 'pt' ? 'selected' : '' %>>Portuguese</option>
                            <option value="ru" <%= config && config.language === 'ru' ? 'selected' : '' %>>Russian</option>
                            <option value="ja" <%= config && config.language === 'ja' ? 'selected' : '' %>>Japanese</option>
                            <option value="ko" <%= config && config.language === 'ko' ? 'selected' : '' %>>Korean</option>
                            <option value="zh" <%= config && config.language === 'zh' ? 'selected' : '' %>>Chinese</option>
                        </select>
                        <div class="form-help">Primary language for speech recognition</div>
                    </div>

                    <div class="form-group">
                        <label for="confidenceThreshold">🎯 Confidence Threshold</label>
                        <div class="slider-container">
                            <input type="range" id="confidenceThreshold" name="confidenceThreshold"
                                   min="0.1" max="1.0" step="0.1"
                                   value="<%= config && config.confidenceThreshold ? config.confidenceThreshold : '0.7' %>"
                                   oninput="updateConfidenceDisplay(this.value)">
                            <div class="slider-value" id="confidenceValue"><%= config && config.confidenceThreshold ? config.confidenceThreshold : '0.7' %></div>
                        </div>
                        <div class="form-help">Minimum confidence level for accepting transcriptions</div>
                    </div>
                </div>
            </div>

            <!-- Advanced Settings Tab -->
            <div id="advancedSettings" class="config-tab">
                <div class="form-grid">

                    <div class="form-group">
                        <label for="chunkDuration">⏱️ Audio Chunk Duration (ms)</label>
                        <input type="number" id="chunkDuration" name="chunkDuration"
                               min="1000" max="10000" step="500"
                               value="<%= config && config.chunkDuration ? config.chunkDuration : '2000' %>">
                        <div class="form-help">Length of audio chunks for processing (1000-10000ms)</div>
                    </div>

                    <div class="form-group">
                        <label for="timeout">⏰ Request Timeout (ms)</label>
                        <input type="number" id="timeout" name="timeout"
                               min="5000" max="60000" step="1000"
                               value="<%= config && config.timeout ? config.timeout : '30000' %>">
                        <div class="form-help">Maximum time to wait for API response (5000-60000ms)</div>
                    </div>

                    <div class="form-group">
                        <label for="fallbackToSystem">🔄 System Fallback</label>
                        <select id="fallbackToSystem" name="fallbackToSystem">
                            <option value="true" <%= config && config.fallbackToSystem ? 'selected' : '' %>>Enabled</option>
                            <option value="false" <%= config && !config.fallbackToSystem ? 'selected' : '' %>>Disabled</option>
                        </select>
                        <div class="form-help">Use system STT if OpenAI fails</div>
                    </div>
                </div>
            </div>

            <div class="button-group">
                <button type="submit" class="button primary-btn">
                    <i class="fas fa-save"></i> Save Configuration
                </button>
                <button type="button" class="button secondary-btn" onclick="testConnection()">
                    <i class="fas fa-test-tube"></i> Test Connection
                </button>
                <a href="/ai-management" class="button secondary-btn">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </form>

        <!-- Live Testing Section -->
        <div id="testSection" class="test-section prominent-section">
            <div class="config-header">
                <i class="fas fa-microphone-alt config-icon"></i>
                <h3>🎤 Live STT Testing</h3>
                <div class="test-status">
                    <span class="test-indicator" id="testStatus">Ready to Test</span>
                </div>
            </div>

            <div class="audio-controls">
                <button type="button" class="record-button" id="recordButton" onclick="toggleRecording()">
                    <i class="fas fa-microphone"></i>
                </button>
                <div class="audio-level">
                    <div class="audio-level-bar" id="audioLevelBar"></div>
                </div>
                <span id="recordingStatus">Click to start recording</span>
            </div>

            <div class="transcription-result" id="transcriptionResult">
                <em>Transcription will appear here...</em>
            </div>

            <div class="confidence-meter">
                <span>Confidence:</span>
                <div class="confidence-bar">
                    <div class="confidence-fill" id="confidenceFill" style="width: 0%"></div>
                </div>
                <span id="confidencePercent">0%</span>
            </div>

            <!-- ChatterPi Jaw Animation Integration -->
            <div class="jaw-animation-integration">
                <div class="integration-header">
                    <i class="fas fa-robot" style="color: #ff6600; margin-right: 6px;"></i>
                    <strong>Jaw Animation:</strong>
                    <span class="jaw-status" id="jawAnimationStatus">Checking...</span>
                </div>
                <div class="integration-controls">
                    <button class="button small-btn secondary-btn" onclick="testJawAnimationWithSTT()" title="Test jaw animation with STT input">
                        <i class="fas fa-play"></i> Test with STT
                    </button>
                    <button class="button small-btn primary-btn" onclick="configureJawAnimation()" title="Configure jaw animation settings">
                        <i class="fas fa-cog"></i> Configure
                    </button>
                    <button class="button small-btn secondary-btn" onclick="syncSTTWithChatterPi()" title="Sync STT settings with jaw animation">
                        <i class="fas fa-sync"></i> Sync Settings
                    </button>
                </div>
            </div>

            <div class="button-group">
                <button type="button" class="button secondary-btn" onclick="clearResults()">
                    <i class="fas fa-trash"></i> Clear Results
                </button>
                <button type="button" class="button secondary-btn" onclick="downloadAudio()" id="downloadBtn" disabled>
                    <i class="fas fa-download"></i> Download Audio
                </button>
            </div>
        </div>

        <!-- Messages -->
        <div id="messageContainer"></div>
    </main>

    <script>
        let mediaRecorder = null;
        let audioChunks = [];
        let isRecording = false;
        let audioContext = null;
        let analyser = null;
        let microphone = null;
        let animationId = null;

        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            checkStatus();
            updateConfidenceDisplay(document.getElementById('confidenceThreshold').value);
            // Initialize ChatterPi jaw animation status
            initializeJawAnimationStatus();
        });

        // Form submission
        document.getElementById('sttConfigForm').addEventListener('submit', function(e) {
            e.preventDefault();
            saveConfiguration();
        });

        function updateConfidenceDisplay(value) {
            document.getElementById('confidenceValue').textContent = value;
        }

        function switchConfigTab(tabName) {
            // Hide all tabs
            document.querySelectorAll('.config-tab').forEach(tab => {
                tab.classList.remove('active');
            });

            // Remove active class from all tab buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });

            // Show selected tab
            document.getElementById(tabName + 'Settings').classList.add('active');

            // Activate corresponding button
            event.target.classList.add('active');
        }

        async function checkStatus() {
            try {
                // Check API status
                const apiResponse = await fetch('/ai-management/api/stt/status');
                const apiData = await apiResponse.json();

                updateStatusIndicator('apiStatus', 'apiIndicator',
                    apiData.success ? 'Connected' : 'Disconnected',
                    apiData.success ? 'online' : 'offline'
                );

                // Check microphone access
                await checkMicrophoneAccess();

                // Check ChatterPi status
                await checkChatterPiStatus();
            } catch (error) {
                console.error('Status check failed:', error);
                updateStatusIndicator('apiStatus', 'apiIndicator', 'Error', 'offline');
            }
        }

        async function checkChatterPiStatus() {
            try {
                const response = await fetch('/chatterpi/api/status');
                const result = await response.json();

                const isConnected = result.success && result.status.servo.connected;
                updateStatusIndicator('chatterpiStatus', 'chatterpiIndicator',
                    isConnected ? 'Connected' : 'Disconnected',
                    isConnected ? 'online' : 'offline'
                );
            } catch (error) {
                console.error('ChatterPi status check failed:', error);
                updateStatusIndicator('chatterpiStatus', 'chatterpiIndicator', 'Error', 'offline');
            }
        }

        function updateStatusIndicator(statusId, indicatorId, text, status) {
            document.getElementById(statusId).textContent = text;
            const indicator = document.getElementById(indicatorId);
            indicator.className = `status-indicator status-${status}`;
        }

        async function checkMicrophoneAccess() {
            try {
                // First check if we're in a secure context
                if (!window.isSecureContext) {
                    updateStatusIndicator('micStatus', 'micIndicator', 'Requires HTTPS', 'offline');
                    showMicrophoneHelp('This feature requires HTTPS or localhost access for security reasons.');
                    return;
                }

                // Check if MediaDevices API is available
                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    updateStatusIndicator('micStatus', 'micIndicator', 'Not Supported', 'offline');
                    showMicrophoneHelp('Your browser does not support microphone access.');
                    return;
                }

                // Check current permission status
                if (navigator.permissions) {
                    try {
                        const permission = await navigator.permissions.query({ name: 'microphone' });

                        if (permission.state === 'denied') {
                            updateStatusIndicator('micStatus', 'micIndicator', 'Permission Denied', 'offline');
                            showMicrophoneHelp('Microphone access has been denied. Please enable it in your browser settings.');
                            return;
                        } else if (permission.state === 'granted') {
                            // Permission already granted, test access
                            await testMicrophoneAccess();
                            return;
                        }
                        // If permission.state === 'prompt', continue to request access
                    } catch (permError) {
                        console.log('Permission API not fully supported, proceeding with getUserMedia test');
                    }
                }

                // Show permission request button instead of automatically requesting
                updateStatusIndicator('micStatus', 'micIndicator', 'Click to Enable', 'warning');
                showMicrophonePermissionButton();

            } catch (error) {
                console.error('Error checking microphone access:', error);
                updateStatusIndicator('micStatus', 'micIndicator', 'Error', 'offline');
                showMicrophoneHelp('Error checking microphone access: ' + error.message);
            }
        }

        async function testMicrophoneAccess() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({
                    audio: {
                        echoCancellation: true,
                        noiseSuppression: true,
                        autoGainControl: true
                    }
                });

                updateStatusIndicator('micStatus', 'micIndicator', 'Available', 'online');
                stream.getTracks().forEach(track => track.stop());
                hideMicrophoneHelp();

                // Show audio level section when microphone is available
                document.getElementById('audioLevelSection').style.display = 'block';

            } catch (error) {
                console.error('Microphone access test failed:', error);

                if (error.name === 'NotAllowedError') {
                    updateStatusIndicator('micStatus', 'micIndicator', 'Permission Denied', 'offline');
                    showMicrophoneHelp('Microphone access was denied. Please click the microphone icon in your browser\'s address bar to enable access.');
                } else if (error.name === 'NotFoundError') {
                    updateStatusIndicator('micStatus', 'micIndicator', 'No Device Found', 'offline');
                    showMicrophoneHelp('No microphone device was found. Please connect a microphone and try again.');
                } else {
                    updateStatusIndicator('micStatus', 'micIndicator', 'Access Failed', 'offline');
                    showMicrophoneHelp('Failed to access microphone: ' + error.message);
                }
            }
        }

        function showMicrophonePermissionButton() {
            const micStatusElement = document.getElementById('micStatus');
            const originalText = micStatusElement.textContent;

            micStatusElement.innerHTML = `
                <span style="margin-right: 10px;">${originalText}</span>
                <button onclick="requestMicrophonePermission()"
                        style="background: #00ff00; color: #000; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">
                    🎤 Enable Microphone
                </button>
            `;
        }

        async function requestMicrophonePermission() {
            try {
                updateStatusIndicator('micStatus', 'micIndicator', 'Requesting Permission...', 'warning');
                await testMicrophoneAccess();
            } catch (error) {
                console.error('Error requesting microphone permission:', error);
            }
        }

        function showMicrophoneHelp(message) {
            let helpDiv = document.getElementById('microphoneHelp');
            if (!helpDiv) {
                helpDiv = document.createElement('div');
                helpDiv.id = 'microphoneHelp';
                helpDiv.style.cssText = `
                    background: #330000;
                    border: 1px solid #ff6666;
                    border-radius: 8px;
                    padding: 15px;
                    margin: 15px 0;
                    color: #ff9999;
                `;

                const statusSection = document.querySelector('.config-section');
                statusSection.appendChild(helpDiv);
            }

            helpDiv.innerHTML = `
                <div style="display: flex; align-items: center; margin-bottom: 10px;">
                    <i class="fas fa-exclamation-triangle" style="margin-right: 10px; color: #ff6666;"></i>
                    <strong>Microphone Access Issue</strong>
                </div>
                <p style="margin: 0 0 15px 0;">${message}</p>
                <div style="font-size: 0.9em;">
                    <strong>Current connection:</strong> ${window.location.protocol.toUpperCase()}<br>
                    ${!window.isSecureContext ? '<strong style="color: #ff6666;">⚠️ HTTPS required for microphone access</strong>' : ''}
                </div>
                ${!window.isSecureContext ? `
                    <div style="margin-top: 15px;">
                        <a href="${window.location.href.replace('http:', 'https:')}"
                           style="background: #00ff00; color: #000; padding: 8px 15px; text-decoration: none; border-radius: 4px; display: inline-block;">
                            🔒 Try HTTPS Version
                        </a>
                    </div>
                ` : ''}
            `;
        }

        function hideMicrophoneHelp() {
            const helpDiv = document.getElementById('microphoneHelp');
            if (helpDiv) {
                helpDiv.remove();
            }
        }

        async function saveConfiguration() {
            const formData = new FormData(document.getElementById('sttConfigForm'));
            const config = Object.fromEntries(formData.entries());

            try {
                showMessage('Saving configuration...', 'info');

                const response = await fetch('/ai-management/api/stt/config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config)
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('Configuration saved successfully!', 'success');
                    checkStatus(); // Refresh status
                } else {
                    showMessage(`Failed to save configuration: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error saving configuration: ${error.message}`, 'error');
            }
        }

        async function testConnection() {
            try {
                showMessage('Testing OpenAI Whisper connection...', 'info');

                const response = await fetch('/ai-management/api/stt/test', {
                    method: 'POST'
                });

                const data = await response.json();

                if (data.success) {
                    showMessage(`API connection test successful! Response time: ${data.responseTime}ms`, 'success');

                    // Also test microphone access
                    showMessage('Testing microphone access...', 'info');
                    await testMicrophoneAccess();
                    showMessage('Complete connection test successful!', 'success');
                } else {
                    showMessage(`API connection test failed: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Connection test error: ${error.message}`, 'error');
            }
        }

        async function toggleRecording() {
            if (isRecording) {
                stopRecording();
            } else {
                await startRecording();
            }
        }

        async function startRecording() {
            try {
                // Check microphone access first
                if (!window.isSecureContext) {
                    showMessage('Recording requires HTTPS or localhost access', 'error');
                    return;
                }

                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    showMessage('Your browser does not support microphone access', 'error');
                    return;
                }

                const stream = await navigator.mediaDevices.getUserMedia({
                    audio: {
                        echoCancellation: true,
                        noiseSuppression: true,
                        autoGainControl: true
                    }
                });

                // Set up audio context for level monitoring
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                analyser = audioContext.createAnalyser();
                microphone = audioContext.createMediaStreamSource(stream);
                microphone.connect(analyser);
                analyser.fftSize = 256;

                // Start level monitoring
                monitorAudioLevel();

                // Set up media recorder with WebM format
                mediaRecorder = new MediaRecorder(stream, {
                    mimeType: 'audio/webm;codecs=opus'
                });
                audioChunks = [];

                mediaRecorder.ondataavailable = function(event) {
                    audioChunks.push(event.data);
                };

                mediaRecorder.onstop = function() {
                    processRecording();
                };

                mediaRecorder.start();
                isRecording = true;

                // Update UI
                const recordButton = document.getElementById('recordButton');
                recordButton.classList.add('recording');
                recordButton.innerHTML = '<i class="fas fa-stop"></i>';
                document.getElementById('recordingStatus').textContent = 'Recording... Click to stop';

            } catch (error) {
                console.error('Recording start error:', error);

                if (error.name === 'NotAllowedError') {
                    showMessage('Microphone access was denied. Please enable microphone permissions and try again.', 'error');
                    updateStatusIndicator('micStatus', 'micIndicator', 'Permission Denied', 'offline');
                    showMicrophoneHelp('Microphone access was denied. Please click the microphone icon in your browser\'s address bar to enable access.');
                } else if (error.name === 'NotFoundError') {
                    showMessage('No microphone device found. Please connect a microphone and try again.', 'error');
                    updateStatusIndicator('micStatus', 'micIndicator', 'No Device Found', 'offline');
                } else if (error.name === 'NotReadableError') {
                    showMessage('Microphone is already in use by another application.', 'error');
                    updateStatusIndicator('micStatus', 'micIndicator', 'Device Busy', 'offline');
                } else {
                    showMessage(`Failed to start recording: ${error.message}`, 'error');
                    updateStatusIndicator('micStatus', 'micIndicator', 'Access Failed', 'offline');
                }
            }
        }

        function stopRecording() {
            if (mediaRecorder && isRecording) {
                mediaRecorder.stop();
                isRecording = false;

                // Stop audio monitoring
                if (animationId) {
                    cancelAnimationFrame(animationId);
                }
                if (audioContext) {
                    audioContext.close();
                }

                // Update UI
                const recordButton = document.getElementById('recordButton');
                recordButton.classList.remove('recording');
                recordButton.innerHTML = '<i class="fas fa-microphone"></i>';
                document.getElementById('recordingStatus').textContent = 'Processing...';
                document.getElementById('audioLevelBar').style.width = '0%';
            }
        }

        function monitorAudioLevel() {
            const bufferLength = analyser.frequencyBinCount;
            const dataArray = new Uint8Array(bufferLength);

            function updateLevel() {
                analyser.getByteFrequencyData(dataArray);

                let sum = 0;
                for (let i = 0; i < bufferLength; i++) {
                    sum += dataArray[i];
                }
                const average = sum / bufferLength;
                const percentage = (average / 255) * 100;

                document.getElementById('audioLevelBar').style.width = percentage + '%';

                if (isRecording) {
                    animationId = requestAnimationFrame(updateLevel);
                }
            }

            updateLevel();
        }

        async function processRecording() {
            try {
                const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                const formData = new FormData();
                formData.append('audio', audioBlob, 'recording.webm');

                showMessage('Transcribing audio...', 'info');

                const response = await fetch('/ai-management/api/stt/transcribe', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    document.getElementById('transcriptionResult').innerHTML =
                        `<strong>Transcription:</strong><br>"${data.text}"<br><br>` +
                        `<small>Provider: ${data.provider} | Response Time: ${data.responseTime}ms</small>`;

                    const confidence = data.confidence || 1.0;
                    const confidencePercent = Math.round(confidence * 100);
                    document.getElementById('confidenceFill').style.width = confidencePercent + '%';
                    document.getElementById('confidencePercent').textContent = confidencePercent + '%';

                    document.getElementById('downloadBtn').disabled = false;
                    showMessage('Transcription completed successfully!', 'success');
                } else {
                    showMessage(`Transcription failed: ${data.error}`, 'error');
                }

                document.getElementById('recordingStatus').textContent = 'Click to start recording';
            } catch (error) {
                showMessage(`Processing error: ${error.message}`, 'error');
                document.getElementById('recordingStatus').textContent = 'Click to start recording';
            }
        }

        function clearResults() {
            document.getElementById('transcriptionResult').innerHTML = '<em>Transcription will appear here...</em>';
            document.getElementById('confidenceFill').style.width = '0%';
            document.getElementById('confidencePercent').textContent = '0%';
            document.getElementById('downloadBtn').disabled = true;
            audioChunks = [];
        }

        function downloadAudio() {
            if (audioChunks.length > 0) {
                const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                const url = URL.createObjectURL(audioBlob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `stt-test-${Date.now()}.webm`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            }
        }

        function showMessage(message, type) {
            const container = document.getElementById('messageContainer');
            const messageDiv = document.createElement('div');
            messageDiv.className = `${type}-message`;
            messageDiv.innerHTML = `<i class="fas fa-${type === 'error' ? 'exclamation-triangle' : type === 'success' ? 'check-circle' : 'info-circle'}"></i> ${message}`;

            container.innerHTML = '';
            container.appendChild(messageDiv);

            setTimeout(() => {
                if (messageDiv.parentNode) {
                    messageDiv.parentNode.removeChild(messageDiv);
                }
            }, 5000);
        }

        // Audio Level Monitoring Functions
        let audioMonitoringActive = false;
        let audioMonitoringStream = null;
        let audioMonitoringContext = null;
        let audioMonitoringAnalyser = null;
        let audioMonitoringAnimationId = null;

        async function toggleAudioMonitoring() {
            if (audioMonitoringActive) {
                stopAudioMonitoring();
            } else {
                await startAudioMonitoring();
            }
        }

        async function startAudioMonitoring() {
            try {
                // Check microphone access first
                if (!window.isSecureContext) {
                    showMessage('Audio monitoring requires HTTPS or localhost access', 'error');
                    return;
                }

                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    showMessage('Your browser does not support microphone access', 'error');
                    return;
                }

                // Get microphone stream
                audioMonitoringStream = await navigator.mediaDevices.getUserMedia({
                    audio: {
                        echoCancellation: true,
                        noiseSuppression: true,
                        autoGainControl: true
                    }
                });

                // Set up audio context for level monitoring
                audioMonitoringContext = new (window.AudioContext || window.webkitAudioContext)();
                audioMonitoringAnalyser = audioMonitoringContext.createAnalyser();
                const microphone = audioMonitoringContext.createMediaStreamSource(audioMonitoringStream);
                microphone.connect(audioMonitoringAnalyser);
                audioMonitoringAnalyser.fftSize = 256;

                // Show the audio level section
                document.getElementById('audioLevelSection').style.display = 'block';

                // Update button
                const button = document.getElementById('toggleAudioMonitor');
                button.textContent = '⏹️ Stop Monitoring';
                button.classList.add('active');

                audioMonitoringActive = true;

                // Start monitoring loop
                monitorAudioLevelRealtime();

                showMessage('Audio level monitoring started', 'success');

            } catch (error) {
                console.error('Audio monitoring start error:', error);

                if (error.name === 'NotAllowedError') {
                    showMessage('Microphone access was denied. Please enable microphone permissions.', 'error');
                } else if (error.name === 'NotFoundError') {
                    showMessage('No microphone device found. Please connect a microphone.', 'error');
                } else {
                    showMessage(`Failed to start audio monitoring: ${error.message}`, 'error');
                }
            }
        }

        function stopAudioMonitoring() {
            audioMonitoringActive = false;

            // Stop animation loop
            if (audioMonitoringAnimationId) {
                cancelAnimationFrame(audioMonitoringAnimationId);
                audioMonitoringAnimationId = null;
            }

            // Close audio context
            if (audioMonitoringContext) {
                audioMonitoringContext.close();
                audioMonitoringContext = null;
            }

            // Stop stream
            if (audioMonitoringStream) {
                audioMonitoringStream.getTracks().forEach(track => track.stop());
                audioMonitoringStream = null;
            }

            // Reset UI
            const levelBar = document.getElementById('audioLevelBar');
            const levelText = document.getElementById('audioLevelText');
            const button = document.getElementById('toggleAudioMonitor');

            if (levelBar) {
                levelBar.style.setProperty('--level', '0%');
                levelBar.className = 'audio-level-bar';
            }
            if (levelText) levelText.textContent = '0%';
            if (button) {
                button.textContent = '📊 Start Monitoring';
                button.classList.remove('active');
            }

            showMessage('Audio level monitoring stopped', 'info');
        }

        function monitorAudioLevelRealtime() {
            if (!audioMonitoringActive || !audioMonitoringAnalyser) return;

            const bufferLength = audioMonitoringAnalyser.frequencyBinCount;
            const dataArray = new Uint8Array(bufferLength);

            function updateLevel() {
                if (!audioMonitoringActive) return;

                audioMonitoringAnalyser.getByteFrequencyData(dataArray);

                // Calculate RMS level
                let sum = 0;
                for (let i = 0; i < bufferLength; i++) {
                    sum += dataArray[i] * dataArray[i];
                }
                const rms = Math.sqrt(sum / bufferLength);
                const percentage = Math.min((rms / 255) * 100, 100);

                // Update visual indicator
                const levelBar = document.getElementById('audioLevelBar');
                const levelText = document.getElementById('audioLevelText');

                if (levelBar && levelText) {
                    levelBar.style.setProperty('--level', percentage + '%');
                    levelText.textContent = Math.round(percentage) + '%';

                    // Update color class based on level
                    levelBar.className = 'audio-level-bar';
                    if (percentage > 70) {
                        levelBar.classList.add('high');
                    } else if (percentage > 30) {
                        levelBar.classList.add('medium');
                    } else {
                        levelBar.classList.add('low');
                    }
                }

                audioMonitoringAnimationId = requestAnimationFrame(updateLevel);
            }

            updateLevel();
        }

        // ChatterPi Jaw Animation Integration Functions
        async function initializeJawAnimationStatus() {
            try {
                const response = await fetch('/chatterpi/api/status');
                const result = await response.json();

                const isConnected = result.success && result.status.servo.connected;
                updateJawAnimationStatus(isConnected);
            } catch (error) {
                console.error('Failed to check jaw animation status:', error);
                updateJawAnimationStatus(false);
            }
        }

        function updateJawAnimationStatus(isConnected) {
            const statusElement = document.getElementById('jawAnimationStatus');
            if (isConnected) {
                statusElement.textContent = 'Connected';
                statusElement.className = 'jaw-status connected';
            } else {
                statusElement.textContent = 'Disconnected';
                statusElement.className = 'jaw-status disconnected';
            }
        }

        async function testJawAnimationWithSTT() {
            try {
                showMessage('Testing jaw animation with STT...', 'info');

                // First check if we have a recent transcription to use
                const transcriptionElement = document.getElementById('transcriptionResult');
                const hasTranscription = transcriptionElement &&
                    !transcriptionElement.innerHTML.includes('Transcription will appear here');

                if (!hasTranscription) {
                    showMessage('Please record some audio first to test jaw animation with STT', 'error');
                    return;
                }

                const response = await fetch('/chatterpi/api/test/stt-animation', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        testMode: 'stt-integration',
                        duration: 3000 // 3 second test
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showMessage('STT jaw animation test completed successfully!', 'success');
                } else {
                    showMessage(`STT jaw animation test failed: ${result.error}`, 'error');
                }
            } catch (error) {
                console.error('STT jaw animation test error:', error);
                showMessage(`STT jaw animation test error: ${error.message}`, 'error');
            }
        }

        function configureJawAnimation() {
            // Open ChatterPi configuration page
            window.open('/chatterpi', '_blank');
        }

        async function syncSTTWithChatterPi() {
            try {
                showMessage('Syncing STT settings with ChatterPi...', 'info');

                // Get current STT configuration
                const formData = new FormData(document.getElementById('sttConfigForm'));
                const sttConfig = Object.fromEntries(formData.entries());

                const response = await fetch('/chatterpi/api/sync/stt', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        sttConfig: sttConfig,
                        syncTimestamp: Date.now()
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showMessage('STT settings synced with ChatterPi jaw animation system', 'success');
                    // Refresh jaw animation status
                    await initializeJawAnimationStatus();
                } else {
                    showMessage(`Failed to sync STT settings: ${result.error}`, 'error');
                }
            } catch (error) {
                console.error('STT sync error:', error);
                showMessage(`STT sync error: ${error.message}`, 'error');
            }
        }

    </script>
</body>
</html>
