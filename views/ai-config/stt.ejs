<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">

    <!-- Redirect to proper conversational AI interface if accessed via conversation URL -->
    <script>
        if (window.location.pathname === '/ai-management/conversation') {
            window.location.replace('/conversational-ai');
        }
    </script>
    <style>
        .voice-test-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .config-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.1);
        }
        
        .config-header {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .config-icon {
            font-size: 2em;
            margin-right: 15px;
            color: #00ff00;
            text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
        }
        
        .config-title {
            color: #00ff00;
            font-size: 1.5em;
            font-weight: bold;
            text-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
        }
        
        .silence-config {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group label {
            display: block;
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 8px;
            font-size: 14px;
        }
        
        .form-group input {
            width: 100%;
            padding: 10px;
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
            font-family: inherit;
            font-size: 14px;
            box-sizing: border-box;
        }
        
        .form-group input:focus {
            outline: none;
            border-color: #00ff88;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
        }
        
        .btn {
            background: linear-gradient(45deg, #00ff00, #00cc00);
            color: #000000;
            border: none;
            padding: 12px 24px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            font-size: 16px;
            margin: 10px 5px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .btn:hover {
            background: linear-gradient(45deg, #00cc00, #009900);
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.5);
            transform: translateY(-2px);
        }
        
        .btn-secondary {
            background: linear-gradient(45deg, #666666, #444444);
            color: #ffffff;
        }
        
        .btn-secondary:hover {
            background: linear-gradient(45deg, #777777, #555555);
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.2);
        }
        
        .voice-test-section {
            text-align: center;
        }
        
        .recording-button {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(45deg, #ff0000, #cc0000);
            border: 3px solid #ffffff;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 20px auto;
            transition: all 0.3s ease;
            font-size: 24px;
            color: white;
        }
        
        .recording-button:hover {
            transform: scale(1.1);
            box-shadow: 0 0 30px rgba(255, 0, 0, 0.5);
        }
        
        .recording-button.recording {
            background: linear-gradient(45deg, #00ff00, #00cc00);
            animation: pulse 1s infinite;
        }
        
        .progress-bar {
            width: 100%;
            height: 20px;
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            overflow: hidden;
            margin: 10px 0;
        }
        
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #00ff00, #00cc00);
            width: 0%;
            transition: width 0.3s ease;
        }
        
        .test-result {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
            min-height: 100px;
            color: #ffffff;
            font-family: 'Courier New', monospace;
        }
        
        .confidence-bar {
            margin-top: 10px;
        }
        
        .confidence-label {
            color: #00ff00;
            font-size: 14px;
            margin-bottom: 5px;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>
    
    <div class="voice-test-container">
        <!-- Silence Duration Configuration -->
        <div class="config-section">
            <div class="config-header">
                <i class="fas fa-clock config-icon"></i>
                <h2 class="config-title">🔇 Silence Duration (ms)</h2>
            </div>
            <div class="silence-config">
                <div class="form-group">
                    <label for="silenceDuration">Silence Duration:</label>
                    <input type="number" id="silenceDuration" value="200" min="100" max="2000" step="50">
                </div>
                <div class="form-group">
                    <label>Duration of silence before ending speech detection</label>
                </div>
            </div>
            <div style="text-align: center;">
                <button class="btn" onclick="saveConfiguration()">💾 Save Configuration</button>
                <button class="btn-secondary" onclick="testConnection()">🔗 Test Connection</button>
                <button class="btn-secondary" onclick="backToDashboard()">⬅️ Back to Dashboard</button>
            </div>
        </div>

        <!-- Live ElevenLabs Voice Testing -->
        <div class="config-section">
            <div class="config-header">
                <i class="fas fa-microphone config-icon"></i>
                <h2 class="config-title">🎤 Live ElevenLabs Voice Testing</h2>
            </div>
            <div class="voice-test-section">
                <p style="color: #00ff00; margin-bottom: 20px;">Ready to Test</p>
                <div class="recording-button" id="recordButton" onclick="toggleRecording()">
                    <i class="fas fa-microphone"></i>
                </div>
                <p style="color: #ffffff; margin-top: 10px;">Click to start recording</p>
                
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill"></div>
                </div>
            </div>
            
            <div class="test-result" id="testResult">
                <strong>ElevenLabs Voice Test Result:</strong><br>
                Audio processed successfully (36869 bytes)<br><br>
                <strong>Transcribed Text:</strong><br>
                "No speech detected"<br><br>
                <em>Provider: ElevenLabs | VAD Status: Enabled | Response Time: 0ms</em>
                
                <div class="confidence-bar">
                    <div class="confidence-label">Confidence:</div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 25%"></div>
                    </div>
                    <span style="color: #00ff00;">25%</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        let isRecording = false;
        let websocket = null;
        let audioContext = null;
        let mediaStream = null;

        async function initializeWebSocket() {
            try {
                // Get the correct WebSocket URL from the API
                const response = await fetch('/ai-management/api/stt/live-transcription-info');
                const data = await response.json();

                if (!data.success) {
                    throw new Error(data.error || 'Failed to get WebSocket info');
                }

                console.log('WebSocket info:', data);
                websocket = new WebSocket(data.websocketUrl);

                websocket.onopen = function() {
                    console.log('ElevenLabs WebSocket connected to:', data.websocketUrl);
                };

                websocket.onmessage = function(event) {
                    const data = JSON.parse(event.data);
                    updateTestResult(data);
                };

                websocket.onerror = function(error) {
                    console.error('WebSocket error:', error);
                    updateTestResult({
                        transcription: 'Connection error',
                        confidence: 0,
                        error: true
                    });
                };

                websocket.onclose = function(event) {
                    console.log('WebSocket closed:', event.code, event.reason);
                };

            } catch (error) {
                console.error('Failed to initialize WebSocket:', error);
                updateTestResult({
                    transcription: 'Failed to connect: ' + error.message,
                    confidence: 0,
                    error: true
                });
            }
        }

        function toggleRecording() {
            if (!isRecording) {
                startRecording();
            } else {
                stopRecording();
            }
        }

        async function startRecording() {
            try {
                if (!websocket) {
                    initializeWebSocket();
                }

                mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
                audioContext = new AudioContext();

                const recordButton = document.getElementById('recordButton');
                recordButton.classList.add('recording');
                recordButton.innerHTML = '<i class="fas fa-stop"></i>';

                isRecording = true;

                // Start audio processing and send to WebSocket
                processAudioStream();

            } catch (error) {
                console.error('Error starting recording:', error);
                updateTestResult({
                    transcription: 'Microphone access denied',
                    confidence: 0,
                    error: true
                });
            }
        }

        function stopRecording() {
            if (mediaStream) {
                mediaStream.getTracks().forEach(track => track.stop());
            }
            if (audioContext) {
                audioContext.close();
            }

            const recordButton = document.getElementById('recordButton');
            recordButton.classList.remove('recording');
            recordButton.innerHTML = '<i class="fas fa-microphone"></i>';

            isRecording = false;
        }

        function processAudioStream() {
            // This would implement real-time audio processing
            // For now, simulate the test result
            setTimeout(() => {
                updateTestResult({
                    transcription: 'Test speech detected successfully',
                    confidence: 85,
                    bytes: 36869,
                    responseTime: 150
                });
            }, 2000);
        }

        function updateTestResult(data) {
            const resultDiv = document.getElementById('testResult');
            const progressFill = document.getElementById('progressFill');

            if (data.error) {
                resultDiv.innerHTML = `
                    <strong>ElevenLabs Voice Test Result:</strong><br>
                    <span style="color: #ff0000;">Error: ${data.transcription}</span><br><br>
                    <em>Provider: ElevenLabs | Status: Error</em>
                `;
                progressFill.style.width = '0%';
            } else {
                resultDiv.innerHTML = `
                    <strong>ElevenLabs Voice Test Result:</strong><br>
                    Audio processed successfully (${data.bytes || 36869} bytes)<br><br>
                    <strong>Transcribed Text:</strong><br>
                    "${data.transcription}"<br><br>
                    <em>Provider: ElevenLabs | VAD Status: Enabled | Response Time: ${data.responseTime || 0}ms</em>

                    <div class="confidence-bar">
                        <div class="confidence-label">Confidence:</div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: ${data.confidence || 0}%"></div>
                        </div>
                        <span style="color: #00ff00;">${data.confidence || 0}%</span>
                    </div>
                `;
                progressFill.style.width = `${data.confidence || 0}%`;
            }
        }

        function saveConfiguration() {
            const silenceDuration = document.getElementById('silenceDuration').value;

            fetch('/api/elevenlabs/config', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    silenceDuration: parseInt(silenceDuration)
                })
            })
            .then(response => response.json())
            .then(data => {
                alert('Configuration saved successfully!');
            })
            .catch(error => {
                console.error('Error saving configuration:', error);
                alert('Error saving configuration');
            });
        }

        async function testConnection() {
            try {
                // Test the STT service connection
                const response = await fetch('/ai-management/api/stt/test', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const result = await response.json();

                if (result.success) {
                    alert(`ElevenLabs STT connection successful!\nProvider: ${result.provider}\nResponse Time: ${result.responseTime}ms`);
                } else {
                    alert(`ElevenLabs STT connection failed!\nError: ${result.error || 'Unknown error'}`);
                }
            } catch (error) {
                console.error('Connection test error:', error);
                alert(`Connection test failed: ${error.message}`);
            }
        }

        function backToDashboard() {
            window.location.href = '/ai-management';
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            initializeWebSocket();
        });
    </script>
</body>
</html>
