<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ElevenLabs Agents Configuration - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .personalities-config {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .config-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 0;
            margin: 20px 0;
        }

        .config-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px;
            margin: 0;
            cursor: pointer;
            background: rgba(0, 255, 0, 0.1);
            border-radius: 8px 8px 0 0;
            transition: background-color 0.3s ease;
        }

        .config-header:hover {
            background: rgba(0, 255, 0, 0.15);
        }

        .config-content {
            padding: 20px;
            display: block;
        }

        .config-content.collapsed {
            display: none;
        }

        .collapse-icon {
            font-size: 1.2em;
            transition: transform 0.3s ease;
        }

        .collapse-icon.collapsed {
            transform: rotate(-90deg);
        }

        .config-icon {
            font-size: 2em;
            margin-right: 15px;
            color: #00ff00;
        }

        .character-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .personality-assignment {
            margin: 10px 0;
        }

        .personality-assignment select {
            width: 100%;
            padding: 8px;
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
            font-size: 14px;
        }

        .personality-assignment select option {
            background: #001100;
            color: #ffffff;
        }

        .character-card {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            position: relative;
        }

        .character-header {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }

        .character-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #00ff00;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5em;
            margin-right: 15px;
        }

        .character-info h4 {
            color: #00ff00;
            margin: 0 0 5px 0;
        }

        .character-info p {
            color: #cccccc;
            margin: 0;
            font-size: 0.9em;
        }

        .character-status {
            position: absolute;
            top: 15px;
            right: 15px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }

        .status-online { background-color: #00ff00; }
        .status-offline { background-color: #ff0000; }
        .status-warning { background-color: #ffff00; }

        .character-details {
            margin: 15px 0;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            margin: 8px 0;
            font-size: 0.9em;
        }

        .detail-label {
            color: #cccccc;
        }

        .detail-value {
            color: #ffffff;
            font-weight: bold;
        }

        .character-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .global-config {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
        }

        .form-group {
            margin-bottom: 35px;
            padding: 15px 15px 50px 15px; /* Much more bottom padding for help text */
            background: rgba(0, 255, 0, 0.05);
            border-radius: 8px;
            border: 1px solid rgba(0, 255, 0, 0.2);
            position: relative;
            overflow: visible;
            min-height: 110px; /* Ensure minimum height for proper spacing */
            display: block; /* Ensure block layout */
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-group label {
            display: block;
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 10px;
            font-size: 16px;
            width: 100%;
            clear: both;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px;
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
            font-family: inherit;
            font-size: 14px;
            display: block;
            box-sizing: border-box;
            margin-top: 5px;
        }

        .form-group select {
            background: #001100;
            color: #ffffff;
            cursor: pointer;
            position: relative;
            z-index: 10;
        }

        .form-group select:focus {
            z-index: 20;
        }

        .form-group select option {
            background: #001100;
            color: #ffffff;
            padding: 8px;
            border: none;
        }

        .form-group select option:hover,
        .form-group select option:selected {
            background: #00ff00;
            color: #000000;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #ffff00;
            box-shadow: 0 0 8px rgba(255, 255, 0, 0.5);
            background: #002200;
        }

        .form-help {
            font-size: 11px;
            color: #aaffaa;
            margin-top: 10px;
            margin-bottom: 0;
            font-style: italic;
            line-height: 1.3;
            position: absolute;
            bottom: 10px;
            left: 15px;
            right: 15px;
            z-index: 1;
            display: block;
        }

        .test-section {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }

        .test-controls {
            display: flex;
            gap: 15px;
            align-items: center;
            margin: 15px 0;
        }

        .test-input {
            flex: 1;
        }

        .test-response {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
            min-height: 80px;
            color: #ffffff;
            white-space: pre-wrap;
        }

        .response-meta {
            font-size: 0.8em;
            color: #cccccc;
            margin-top: 10px;
            padding-top: 10px;
            border-top: 1px solid #333333;
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
        }

        .modal-content {
            background-color: #001100;
            margin: 5% auto;
            padding: 0;
            border: 2px solid #00ff00;
            border-radius: 10px;
            width: 90%;
            max-width: 800px;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal-header {
            background-color: #000800;
            padding: 15px 20px;
            border-bottom: 1px solid #00ff00;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h3 {
            margin: 0;
            color: #00ff00;
        }

        .close {
            color: #ff0000;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

        .close:hover {
            color: #ff6666;
        }

        .modal-body {
            padding: 20px;
            color: #cccccc;
        }

        .error-message {
            background: #330000;
            border: 1px solid #ff0000;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #ff6666;
        }

        .success-message {
            background: #003300;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #66ff66;
        }

        .info-message {
            background: #000033;
            border: 1px solid #0066ff;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #6666ff;
        }

        .slider-container {
            display: flex;
            align-items: center;
            gap: 15px;
            margin: 10px 0 35px 0; /* Extra bottom margin for help text */
        }

        .slider-container input[type="range"] {
            flex: 1;
            height: 8px;
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 5px;
            outline: none;
            cursor: pointer;
        }

        .slider-container input[type="range"]::-webkit-slider-thumb {
            appearance: none;
            width: 20px;
            height: 20px;
            background: #00ff00;
            border-radius: 50%;
            cursor: pointer;
            border: 2px solid #ffffff;
        }

        .slider-container input[type="range"]::-moz-range-thumb {
            width: 20px;
            height: 20px;
            background: #00ff00;
            border-radius: 50%;
            cursor: pointer;
            border: 2px solid #ffffff;
        }

        .slider-value {
            min-width: 50px;
            text-align: center;
            background: #00ff00;
            border: 2px solid #00ff00;
            border-radius: 5px;
            padding: 8px 12px;
            color: #000000;
            font-family: monospace;
            font-weight: bold;
            font-size: 14px;
        }



        /* Save Button Styles */
        .save-btn {
            background: #004400;
            color: #00ff00;
            border: 1px solid #00ff00;
            border-radius: 5px;
            padding: 8px 16px;
            font-size: 0.9em;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .save-btn:hover {
            background: #006600;
            box-shadow: 0 0 10px #00ff00;
        }

        .save-btn:disabled {
            background: #222222;
            color: #666666;
            border-color: #666666;
            cursor: not-allowed;
        }

        .save-btn.saving {
            background: #666600;
            color: #ffff00;
            border-color: #ffff00;
        }
    </style>
</head>
<body>
    <header class="compact-header">
        <div class="header-content">
            <h1 class="page-title">🤖 ElevenLabs Agents Configuration</h1>
            <nav class="compact-nav">
                <a href="/" class="nav-link">🏠 Home</a>
                <span class="nav-separator">•</span>
                <a href="/ai-management" class="nav-link">🤖 Conversational AI</a>
                <span class="nav-separator">•</span>
                <span class="nav-current">ElevenLabs Agents</span>
            </nav>
        </div>
    </header>

    <main class="personalities-config">
        <div class="info-section">
            <h2>🤖 ElevenLabs Conversational AI Agents</h2>
            <p>Configure ElevenLabs agents for each character with custom prompts, voices, and conversation settings</p>
        </div>



        <!-- ElevenLabs Agents -->
        <div class="config-section">
            <div class="config-header" onclick="toggleSection('agents')">
                <div>
                    <i class="config-icon fas fa-robot"></i>
                    ElevenLabs Agents
                </div>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <button class="button primary-btn" onclick="addNewAgent(); event.stopPropagation();">
                        <i class="fas fa-plus"></i> Add Agent
                    </button>

                    <i class="collapse-icon fas fa-chevron-down" id="personalities-icon"></i>
                </div>
            </div>

            <div class="config-content" id="personalities-content">
                <div class="character-grid" id="personalitiesGrid">
                    <!-- Personalities will be loaded here -->
                </div>
            </div>
        </div>

        <!-- AI Personality Testing -->
        <div class="config-section">
            <div class="config-header" onclick="toggleSection('testing')">
                <div>
                    <i class="config-icon fas fa-flask"></i>
                    AI Personality Testing
                </div>
                <i class="collapse-icon fas fa-chevron-down" id="testing-icon"></i>
            </div>

            <div class="config-content" id="testing-content">
                <div class="test-section">
                    <div class="test-controls">
                        <label for="testCharacter">Select Character to Test</label>
                        <select id="testCharacter" class="test-input">
                            <option value="">Choose a character...</option>
                            <option value="1">Orlok</option>
                            <option value="2">Coffin Breaker</option>
                            <option value="3">PumpkinHead</option>
                            <option value="4">Skulltalker</option>
                        </select>
                    </div>
                    <div class="test-controls">
                        <input type="text" id="testPrompt" class="test-input" placeholder="Enter test message..." value="Hello, this is a test message. Please respond in character.">
                        <button class="button primary-btn" onclick="runAITest()">
                            <i class="fas fa-paper-plane"></i> Send
                        </button>
                    </div>

                    <div id="testResponse" class="test-response">
                        AI response will appear here...
                    </div>
                </div>
            </div>
        </div>

        <!-- Global AI Settings -->
        <div class="config-section">
            <div class="config-header" onclick="toggleSection('global')">
                <div>
                    <i class="config-icon fas fa-cog"></i>
                    Global AI Settings
                </div>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <button class="button primary-btn" onclick="saveGlobalConfig(); event.stopPropagation();">
                        <i class="fas fa-save"></i> Save Global Settings
                    </button>
                    <i class="collapse-icon fas fa-chevron-down collapsed" id="global-icon"></i>
                </div>
            </div>

            <div class="config-content collapsed" id="global-content">
                <form id="globalConfigForm" class="global-config">
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="defaultProvider">Default Provider</label>
                            <select id="defaultProvider" name="defaultProvider">
                                <option value="elevenlabs">ElevenLabs</option>
                            </select>
                            <div class="form-help">Conversational AI provider for all characters</div>
                        </div>

                        <div class="form-group">
                            <label for="defaultVoiceId">Default Voice</label>
                            <select id="defaultVoiceId" name="defaultVoiceId">
                                <option value="">Select a voice...</option>
                                <!-- Voice options will be loaded dynamically -->
                            </select>
                            <div class="form-help">Default voice for new agents</div>
                        </div>

                        <div class="form-group">
                            <label for="defaultVadThreshold">Default VAD Threshold</label>
                            <div class="slider-container">
                                <input type="range" id="defaultVadThreshold" name="defaultVadThreshold"
                                       min="0.1" max="1.0" step="0.1" value="0.5"
                                       oninput="updateVadThresholdDisplay(this.value)">
                                <span class="slider-value" id="vadThresholdValue">0.5</span>
                            </div>
                            <div class="form-help">
                                Voice activity detection sensitivity (0.1 = very sensitive, 1.0 = less sensitive)
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="defaultPrefixPadding">Default Prefix Padding (ms)</label>
                            <input type="number" id="defaultPrefixPadding" name="defaultPrefixPadding" value="300" min="0" max="1000" step="50">
                            <div class="form-help">Audio padding before detected speech</div>
                        </div>

                        <div class="form-group">
                            <label for="defaultSilenceDuration">Default Silence Duration (ms)</label>
                            <input type="number" id="defaultSilenceDuration" name="defaultSilenceDuration" value="200" min="100" max="2000" step="50">
                            <div class="form-help">Duration of silence before ending speech detection</div>
                        </div>

                        <div class="form-group">
                            <label for="responseTimeout">Response Timeout (ms)</label>
                            <input type="number" id="responseTimeout" name="responseTimeout" value="30000" min="5000" max="120000">
                            <div class="form-help">Maximum time to wait for AI response</div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Navigation -->
        <div class="button-group" style="margin-top: 30px;">
            <a href="/ai-management" class="button secondary-btn">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
            <a href="/characters" class="button">
                <i class="fas fa-users"></i> Manage Characters
            </a>
        </div>

        <!-- Messages -->
        <div id="messageContainer"></div>
    </main>

    <!-- Character Configuration Modal -->
    <div id="characterModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modalTitle">Configure Character AI</h3>
                <span class="close" onclick="closeModal()">&times;</span>
            </div>
            <div class="modal-body">
                <form id="characterConfigForm">
                    <input type="hidden" id="characterId" name="characterId">

                    <div class="form-group full-width" id="personalityNameGroup" style="display: none;">
                        <label for="personalityName">Personality Name</label>
                        <input type="text" id="personalityName" name="personalityName" placeholder="Enter a unique name for this personality">
                        <div class="form-help">
                            A descriptive name for this AI personality (e.g., "Mysterious Vampire", "Friendly Ghost", "Wise Oracle")
                        </div>
                    </div>

                    <div class="form-group full-width" id="characterAssignmentGroup" style="display: none;">
                        <label for="assignedCharacter">Assign to Character</label>
                        <select id="assignedCharacter" name="assignedCharacter">
                            <option value="">No Character Assignment</option>
                        </select>
                        <div class="form-help">
                            Optionally assign this personality to a specific character. Each character can only have one personality assigned.
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label for="aiProvider">Provider</label>
                            <select id="aiProvider" name="aiProvider">
                                <option value="elevenlabs">ElevenLabs</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="voiceId">Voice</label>
                            <select id="voiceId" name="voiceId">
                                <option value="">Select a voice...</option>
                                <!-- Voice options will be loaded dynamically -->
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="vadThreshold">VAD Threshold</label>
                            <div class="slider-container">
                                <input type="range" id="vadThreshold" name="vadThreshold"
                                       min="0.1" max="1.0" step="0.1" value="0.5"
                                       oninput="updateModalVadThresholdDisplay(this.value)">
                                <span class="slider-value" id="modalVadThresholdValue">0.5</span>
                            </div>
                            <div class="form-help">
                                Voice activity detection sensitivity
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="prefixPadding">Prefix Padding (ms)</label>
                            <input type="number" id="prefixPadding" name="prefixPadding"
                                   min="0" max="1000" step="50" value="300">
                        </div>

                        <div class="form-group full-width">
                            <label for="agentPrompt">Agent Prompt / Personality</label>
                            <textarea id="agentPrompt" name="agentPrompt" rows="6"
                                      placeholder="Define the character's personality, speaking style, background, and behavioral traits for ElevenLabs agent..."></textarea>
                            <div class="form-help">Detailed personality description that defines how the ElevenLabs agent should behave and respond</div>
                        </div>

                        <div class="form-group">
                            <label for="silenceDuration">Silence Duration (ms)</label>
                            <input type="number" id="silenceDuration" name="silenceDuration"
                                   min="100" max="2000" step="50" value="200">
                            <div class="form-help">Duration of silence before ending speech detection</div>
                        </div>

                        <div class="form-group">
                            <label for="enabled">Enable AI</label>
                            <select id="enabled" name="enabled">
                                <option value="true">Enabled</option>
                                <option value="false">Disabled</option>
                            </select>
                        </div>
                    </div>

                    <div class="button-group">
                        <button type="submit" class="button primary-btn">
                            <i class="fas fa-save"></i> Save Configuration
                        </button>
                        <button type="button" class="button secondary-btn" onclick="testModalCharacter()">
                            <i class="fas fa-test-tube"></i> Test AI
                        </button>
                        <button type="button" class="button secondary-btn" onclick="closeModal()">
                            Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            updateTemperatureDisplay(document.getElementById('defaultTemperature').value);
            loadPersonalities();
            loadAvailableVoices();
        });

        // Section toggle functionality
        function toggleSection(sectionId) {
            const content = document.getElementById(sectionId + '-content');
            const icon = document.getElementById(sectionId + '-icon');

            if (content.classList.contains('collapsed')) {
                content.classList.remove('collapsed');
                icon.classList.remove('collapsed');
            } else {
                content.classList.add('collapsed');
                icon.classList.add('collapsed');
            }
        }

        // Global configuration functions
        function updateTemperatureDisplay(value) {
            document.getElementById('temperatureValue').textContent = value;
        }

        function updateModalTemperatureDisplay(value) {
            document.getElementById('modalTemperatureValue').textContent = value;
        }

        async function saveGlobalConfig() {
            const formData = new FormData(document.getElementById('globalConfigForm'));
            const config = Object.fromEntries(formData.entries());

            try {
                showMessage('Saving global configuration...', 'info');

                const response = await fetch('/ai-management/api/personalities/global', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config)
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('Global configuration saved successfully!', 'success');
                } else {
                    showMessage(`Failed to save global configuration: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error saving global configuration: ${error.message}`, 'error');
            }
        }

        // Character management functions
        function configureCharacter(characterId) {
            // Load character configuration
            fetch(`/ai-management/api/personalities/character/${characterId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        populateModal(data.character);
                        document.getElementById('characterModal').style.display = 'block';
                    } else {
                        showMessage(`Failed to load character configuration: ${data.error}`, 'error');
                    }
                })
                .catch(error => {
                    showMessage(`Error loading character configuration: ${error.message}`, 'error');
                });
        }

        function populateModal(character) {
            document.getElementById('characterId').value = character.id;
            document.getElementById('modalTitle').textContent = `Configure ${character.char_name || 'Character'} AI`;

            // Hide personality name field and character assignment when editing existing character personalities
            document.getElementById('personalityNameGroup').style.display = 'none';
            document.getElementById('characterAssignmentGroup').style.display = 'none';

            const config = character.aiConfig || {};
            document.getElementById('aiProvider').value = config.provider || 'openai';
            document.getElementById('aiModel').value = config.model || 'gpt-4';
            document.getElementById('aiTemperature').value = config.temperature || '0.8';
            document.getElementById('aiMaxTokens').value = config.maxTokens || '150';
            document.getElementById('systemPrompt').value = config.systemPrompt || '';
            document.getElementById('contextLength').value = config.contextLength || '5';
            document.getElementById('enabled').value = config.enabled ? 'true' : 'false';

            updateModalTemperatureDisplay(config.temperature || '0.8');
        }

        function closeModal() {
            document.getElementById('characterModal').style.display = 'none';
        }

        // Form submission for character configuration
        document.getElementById('characterConfigForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const formData = new FormData(this);
            const config = Object.fromEntries(formData.entries());
            const characterId = config.characterId;

            try {
                if (characterId === 'new') {
                    // Creating a new personality
                    if (!config.personalityName || !config.personalityName.trim()) {
                        showMessage('Please enter a name for the personality', 'error');
                        return;
                    }

                    showMessage('Creating new AI personality...', 'info');

                    const response = await fetch('/ai-management/api/personalities/create', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(config)
                    });

                    const data = await response.json();

                    if (data.success) {
                        showMessage('AI personality created successfully!', 'success');
                        closeModal();
                        loadPersonalities(); // Reload personalities list
                    } else {
                        showMessage(`Failed to create personality: ${data.error}`, 'error');
                    }
                } else if (document.getElementById('personalityNameGroup').style.display !== 'none') {
                    // Updating existing personality
                    if (!config.personalityName || !config.personalityName.trim()) {
                        showMessage('Please enter a name for the personality', 'error');
                        return;
                    }

                    showMessage('Updating AI personality...', 'info');

                    const response = await fetch(`/ai-management/api/personalities/${characterId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(config)
                    });

                    const data = await response.json();

                    if (data.success) {
                        showMessage('AI personality updated successfully!', 'success');
                        closeModal();
                        loadPersonalities(); // Reload personalities list
                    } else {
                        showMessage(`Failed to update personality: ${data.error}`, 'error');
                    }
                } else {
                    // Updating existing character personality
                    showMessage('Saving character configuration...', 'info');

                    const response = await fetch(`/ai-management/api/personalities/character/${characterId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(config)
                    });

                    const data = await response.json();

                    if (data.success) {
                        showMessage('Character configuration saved successfully!', 'success');
                        closeModal();
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showMessage(`Failed to save character configuration: ${data.error}`, 'error');
                    }
                }
            } catch (error) {
                showMessage(`Error saving configuration: ${error.message}`, 'error');
            }
        });

        async function testCharacter(characterId) {
            const prompt = 'Hello, this is a test message. Please respond in character.';

            try {
                showMessage('Testing character AI...', 'info');

                const response = await fetch('/ai-management/api/personalities/test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ characterId, prompt })
                });

                const data = await response.json();

                if (data.success) {
                    showMessage(`Test successful! Response: "${data.response}"`, 'success');
                } else {
                    showMessage(`Test failed: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Test error: ${error.message}`, 'error');
            }
        }

        async function toggleCharacter(characterId, enable) {
            try {
                showMessage(`${enable ? 'Enabling' : 'Disabling'} character AI...`, 'info');

                const response = await fetch(`/ai-management/api/personalities/character/${characterId}/toggle`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ enabled: enable })
                });

                const data = await response.json();

                if (data.success) {
                    showMessage(`Character AI ${enable ? 'enabled' : 'disabled'} successfully!`, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showMessage(`Failed to ${enable ? 'enable' : 'disable'} character AI: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error ${enable ? 'enabling' : 'disabling'} character AI: ${error.message}`, 'error');
            }
        }

        // Testing functions
        async function runAITest() {
            const characterId = document.getElementById('testCharacter').value;
            const prompt = document.getElementById('testPrompt').value;

            if (!characterId) {
                showMessage('Please select a character to test', 'error');
                return;
            }

            if (!prompt.trim()) {
                showMessage('Please enter a test message', 'error');
                return;
            }

            try {
                document.getElementById('testResponse').innerHTML = '<em>Generating response...</em>';

                const response = await fetch('/ai-management/api/personalities/test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ characterId, prompt })
                });

                const data = await response.json();

                if (data.success) {
                    document.getElementById('testResponse').innerHTML =
                        `<strong>Response:</strong><br>"${data.response}"<br><br>` +
                        `<div class="response-meta">` +
                        `Model: ${data.model} | Provider: ${data.provider}<br>` +
                        `Response Time: ${data.responseTime}ms | Tokens: ${data.tokens || 'N/A'}` +
                        `</div>`;
                } else {
                    document.getElementById('testResponse').innerHTML =
                        `<strong>Error:</strong> ${data.error}`;
                }
            } catch (error) {
                document.getElementById('testResponse').innerHTML =
                    `<strong>Error:</strong> ${error.message}`;
            }
        }

        async function testModalCharacter() {
            const characterId = document.getElementById('characterId').value;
            const prompt = 'Hello, this is a test message. Please respond in character.';

            try {
                const response = await fetch('/ai-management/api/personalities/test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ characterId, prompt })
                });

                const data = await response.json();

                if (data.success) {
                    alert(`Test Response: "${data.response}"`);
                } else {
                    alert(`Test Failed: ${data.error}`);
                }
            } catch (error) {
                alert(`Test Error: ${error.message}`);
            }
        }

        async function addNewAgent() {
            // Open modal for creating a new ElevenLabs agent
            document.getElementById('characterId').value = 'new';
            document.getElementById('modalTitle').textContent = 'Create New ElevenLabs Agent';

            // Show personality name field and character assignment for new personalities
            document.getElementById('personalityNameGroup').style.display = 'block';
            document.getElementById('characterAssignmentGroup').style.display = 'block';
            document.getElementById('personalityName').value = '';

            // Load available characters for assignment
            await loadAvailableCharacters();

            // Load available voices
            await loadAvailableVoices();

            // Reset form to defaults
            document.getElementById('aiProvider').value = 'elevenlabs';
            document.getElementById('voiceId').value = '';
            document.getElementById('vadThreshold').value = '0.5';
            document.getElementById('prefixPadding').value = '300';
            document.getElementById('agentPrompt').value = '';
            document.getElementById('silenceDuration').value = '200';
            document.getElementById('enabled').value = 'true';
            document.getElementById('assignedCharacter').value = '';

            updateModalTemperatureDisplay('0.8');
            document.getElementById('characterModal').style.display = 'block';
        }

        // Load and display personalities
        async function loadPersonalities() {
            try {
                const response = await fetch('/ai-management/api/elevenlabs/agents');
                const data = await response.json();

                if (data.success) {
                    displayPersonalities(data.agents);
                } else {
                    console.error('Failed to load ElevenLabs agents:', data.error);
                }
            } catch (error) {
                console.error('Error loading ElevenLabs agents:', error);
            }
        }

        function displayPersonalities(personalities) {
            const grid = document.getElementById('personalitiesGrid');

            if (!personalities || personalities.length === 0) {
                grid.innerHTML = '<div class="info-message">No ElevenLabs agents found. ElevenLabs agents are automatically loaded from your ElevenLabs account.</div>';
                return;
            }

            grid.innerHTML = personalities.map(agent => `
                <div class="character-card" data-agent-id="${agent.agentId}">
                    <div class="character-status status-online"></div>

                    <div class="character-header">
                        <div class="character-avatar">
                            ${agent.name.charAt(0).toUpperCase()}
                        </div>
                        <div class="character-info">
                            <h4>${agent.name}</h4>
                            <p>ElevenLabs Conversational Agent</p>
                        </div>
                    </div>

                    <div class="character-details">
                        <div class="detail-row">
                            <span class="detail-label">Provider:</span>
                            <span class="detail-value">ElevenLabs</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Character ID:</span>
                            <span class="detail-value">${agent.characterId}</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Agent ID:</span>
                            <span class="detail-value">${agent.agentId.substring(0, 20)}...</span>
                        </div>
                        <div class="personality-assignment">
                            <label>Character Assignment:</label>
                            <div class="assignment-info">
                                <span class="detail-value">Character ${agent.characterId} (${agent.name})</span>
                                <span class="assignment-status">✅ Active</span>
                            </div>
                        </div>
                    </div>

                    <div class="character-actions">
                        <button class="button secondary-btn" onclick="testElevenLabsAgent('${agent.agentId}')">
                            <i class="fas fa-vial"></i> Test Agent
                        </button>
                        <button class="button secondary-btn" onclick="viewElevenLabsAgent('${agent.agentId}')">
                            <i class="fas fa-eye"></i> View Details
                        </button>
                        <button class="button secondary-btn" onclick="openElevenLabsConsole('${agent.agentId}')">
                            <i class="fas fa-external-link-alt"></i> ElevenLabs Console
                        </button>
                    </div>
                </div>
            `).join('');
        }

        // Load available characters for personality assignment
        async function loadAvailableCharacters() {
            try {
                const response = await fetch('/ai-management/api/personalities/available-characters');
                const data = await response.json();

                if (data.success) {
                    const select = document.getElementById('assignedCharacter');

                    // Clear existing options except the first one
                    while (select.children.length > 1) {
                        select.removeChild(select.lastChild);
                    }

                    // Add character options
                    data.characters.forEach(character => {
                        const option = document.createElement('option');
                        option.value = character.id;
                        option.textContent = `${character.name} - ${character.description.substring(0, 50)}...`;
                        select.appendChild(option);
                    });
                } else {
                    console.error('Failed to load available characters:', data.error);
                }
            } catch (error) {
                console.error('Error loading available characters:', error);
            }
        }

        // Personality management functions
        async function editPersonality(personalityId) {
            try {
                const response = await fetch(`/ai-management/api/personalities/${personalityId}`);
                const data = await response.json();

                if (data.success) {
                    populatePersonalityModal(data.personality);
                    document.getElementById('characterModal').style.display = 'block';
                } else {
                    showMessage(`Failed to load personality: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error loading personality: ${error.message}`, 'error');
            }
        }

        function populatePersonalityModal(personality) {
            document.getElementById('characterId').value = personality.id;
            document.getElementById('modalTitle').textContent = `Edit ${personality.name}`;

            // Show personality name field and character assignment for editing personalities
            document.getElementById('personalityNameGroup').style.display = 'block';
            document.getElementById('characterAssignmentGroup').style.display = 'block';

            // Populate fields
            document.getElementById('personalityName').value = personality.name;
            document.getElementById('aiProvider').value = personality.provider;
            document.getElementById('aiModel').value = personality.model;
            document.getElementById('aiTemperature').value = personality.temperature;
            document.getElementById('aiMaxTokens').value = personality.maxTokens;
            document.getElementById('systemPrompt').value = personality.systemPrompt;
            document.getElementById('contextLength').value = personality.contextLength;
            document.getElementById('enabled').value = personality.enabled ? 'true' : 'false';

            // Load characters and set assignment
            loadAvailableCharacters().then(() => {
                document.getElementById('assignedCharacter').value = personality.assignedCharacter || '';
            });

            updateModalTemperatureDisplay(personality.temperature);
        }

        async function testPersonality(personalityId) {
            const prompt = 'Hello, this is a test message. Please respond according to your personality.';

            try {
                showMessage('Testing personality...', 'info');

                const response = await fetch('/ai-management/api/personalities/test-personality', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ personalityId, prompt })
                });

                const data = await response.json();

                if (data.success) {
                    showMessage(`Test successful! Response: "${data.response}"`, 'success');
                } else {
                    showMessage(`Test failed: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Test error: ${error.message}`, 'error');
            }
        }

        async function togglePersonality(personalityId, enable) {
            try {
                showMessage(`${enable ? 'Enabling' : 'Disabling'} personality...`, 'info');

                const response = await fetch(`/ai-management/api/personalities/${personalityId}/toggle`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ enabled: enable })
                });

                const data = await response.json();

                if (data.success) {
                    showMessage(`Personality ${enable ? 'enabled' : 'disabled'} successfully!`, 'success');
                    loadPersonalities(); // Reload to update display
                } else {
                    showMessage(`Failed to ${enable ? 'enable' : 'disable'} personality: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error ${enable ? 'enabling' : 'disabling'} personality: ${error.message}`, 'error');
            }
        }

        // Mark personality as changed when assignment dropdown changes
        function markPersonalityChanged(personalityId) {
            const saveBtn = document.getElementById(`save-${personalityId}`);
            if (saveBtn) {
                saveBtn.disabled = false;
                saveBtn.classList.remove('saving');
            }
        }

        // Save personality assignment
        async function savePersonalityAssignment(personalityId) {
            const select = document.getElementById(`assign-${personalityId}`);
            const saveBtn = document.getElementById(`save-${personalityId}`);

            if (!select || !saveBtn) return;

            const characterId = select.value;

            try {
                saveBtn.disabled = true;
                saveBtn.classList.add('saving');
                saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

                showMessage('Updating character assignment...', 'info');

                const response = await fetch(`/ai-management/api/personalities/${personalityId}/assign`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ characterId: characterId || null })
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('Character assignment saved successfully!', 'success');
                    saveBtn.innerHTML = '<i class="fas fa-check"></i> Saved';
                    saveBtn.classList.remove('saving');

                    // Keep button disabled since no changes to save
                    setTimeout(() => {
                        saveBtn.innerHTML = '<i class="fas fa-save"></i> Save Assignment';
                    }, 2000);

                    loadPersonalities(); // Reload to update display
                } else {
                    showMessage(`Failed to save assignment: ${data.error}`, 'error');
                    saveBtn.disabled = false;
                    saveBtn.classList.remove('saving');
                    saveBtn.innerHTML = '<i class="fas fa-save"></i> Save Assignment';
                }
            } catch (error) {
                showMessage(`Save error: ${error.message}`, 'error');
                saveBtn.disabled = false;
                saveBtn.classList.remove('saving');
                saveBtn.innerHTML = '<i class="fas fa-save"></i> Save Assignment';
            }
        }

        // Legacy function for backward compatibility (if needed elsewhere)
        async function assignPersonalityToCharacter(personalityId, characterId) {
            return savePersonalityAssignment(personalityId);
        }



        // Utility functions
        function showMessage(message, type) {
            const container = document.getElementById('messageContainer');
            const messageDiv = document.createElement('div');
            messageDiv.className = `${type}-message`;
            messageDiv.innerHTML = `<i class="fas fa-${type === 'error' ? 'exclamation-triangle' : type === 'success' ? 'check-circle' : 'info-circle'}"></i> ${message}`;

            container.innerHTML = '';
            container.appendChild(messageDiv);

            setTimeout(() => {
                if (messageDiv.parentNode) {
                    messageDiv.parentNode.removeChild(messageDiv);
                }
            }, 5000);
        }
        async function syncAssistant(personalityId) {
            try {
                showMessage('Syncing OpenAI Assistant...', 'info');
                const res = await fetch(`/ai-management/api/personalities/${personalityId}/sync-assistant`, { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    showMessage('Assistant synced successfully!', 'success');
                } else {
                    showMessage(`Assistant sync failed: ${data.error}`, 'error');
                }
            } catch (e) {
                showMessage(`Assistant sync error: ${e.message}`, 'error');
            }
        }

        async function testAssistant(personalityId) {
            try {
                showMessage('Testing Assistant...', 'info');
                const res = await fetch(`/ai-management/api/personalities/${personalityId}/test-assistant`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prompt: 'Please introduce yourself in character.' })
                });
                const data = await res.json();
                if (data.success) {
                    showMessage(`Assistant responded: "${data.response}"`, 'success');
                } else {
                    showMessage(`Assistant test failed: ${data.error}`, 'error');
                }
            } catch (e) {
                showMessage(`Assistant test error: ${e.message}`, 'error');
            }
        }

        document.addEventListener('change', async (evt) => {
            if (evt.target && evt.target.id && evt.target.id.startsWith('docs-input-')) {
                const personalityId = evt.target.id.replace('docs-input-', '');
                const files = evt.target.files;
                if (!files || files.length === 0) return;
                try {
                    showMessage('Uploading documents...', 'info');
                    const form = new FormData();
                    [...files].forEach(f => form.append('docs', f));
                    const res = await fetch(`/ai-management/api/personalities/${personalityId}/upload-docs`, {
                        method: 'POST',
                        body: form
                    });
                    const data = await res.json();
                    if (data.success) {
                        showMessage(`Uploaded ${data.uploaded.length} documents.`, 'success');
                    } else {
                        showMessage(`Upload failed: ${data.error}`, 'error');
                    }
                } catch (e) {
                    showMessage(`Upload error: ${e.message}`, 'error');
                } finally {
                    evt.target.value = '';
                }
            }
        });

        // Load available ElevenLabs voices
        async function loadAvailableVoices() {
            try {
                const response = await fetch('/ai-management/api/elevenlabs/voices');
                const data = await response.json();

                if (data.success) {
                    const voiceSelect = document.getElementById('voiceId');
                    const defaultVoiceSelect = document.getElementById('defaultVoiceId');

                    // Clear existing options
                    voiceSelect.innerHTML = '<option value="">Select a voice...</option>';
                    defaultVoiceSelect.innerHTML = '<option value="">Select a voice...</option>';

                    // Add voice options
                    data.voices.forEach(voice => {
                        const option = new Option(voice.name, voice.voice_id);
                        const defaultOption = new Option(voice.name, voice.voice_id);
                        voiceSelect.add(option);
                        defaultVoiceSelect.add(defaultOption);
                    });
                }
            } catch (error) {
                console.error('Error loading voices:', error);
            }
        }

        // Update VAD threshold display functions
        function updateVadThresholdDisplay(value) {
            document.getElementById('vadThresholdValue').textContent = value;
        }

        function updateModalVadThresholdDisplay(value) {
            document.getElementById('modalVadThresholdValue').textContent = value;
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('characterModal');
            if (event.target === modal) {
                closeModal();
            }
        }
        // ElevenLabs Agent Functions
        function testElevenLabsAgent(agentId) {
            showMessage('Testing ElevenLabs agent...', 'info');
            // Redirect to test chat with the specific agent
            window.open(`/test-chat?agent=${agentId}`, '_blank');
        }

        function viewElevenLabsAgent(agentId) {
            showMessage('Viewing ElevenLabs agent details...', 'info');
            // Show agent details in a modal or redirect to details page
            alert(`Agent ID: ${agentId}\n\nThis would show detailed agent information from ElevenLabs.`);
        }

        function openElevenLabsConsole(agentId) {
            showMessage('Opening ElevenLabs console...', 'info');
            // Open ElevenLabs console in new tab
            window.open('https://elevenlabs.io/app/conversational-ai', '_blank');
        }

    </script>
</body>
