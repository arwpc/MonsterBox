<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Personalities Configuration - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .personalities-config {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .config-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .config-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        
        .config-icon {
            font-size: 2em;
            margin-right: 15px;
            color: #00ff00;
        }
        
        .character-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }
        
        .character-card {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            position: relative;
        }
        
        .character-header {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .character-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #00ff00;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5em;
            margin-right: 15px;
        }
        
        .character-info h4 {
            color: #00ff00;
            margin: 0 0 5px 0;
        }
        
        .character-info p {
            color: #cccccc;
            margin: 0;
            font-size: 0.9em;
        }
        
        .character-status {
            position: absolute;
            top: 15px;
            right: 15px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }
        
        .status-online { background-color: #00ff00; }
        .status-offline { background-color: #ff0000; }
        .status-warning { background-color: #ffff00; }
        
        .character-details {
            margin: 15px 0;
        }
        
        .detail-row {
            display: flex;
            justify-content: space-between;
            margin: 8px 0;
            font-size: 0.9em;
        }
        
        .detail-label {
            color: #cccccc;
        }
        
        .detail-value {
            color: #ffffff;
            font-weight: bold;
        }
        
        .character-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }
        
        .global-config {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group.full-width {
            grid-column: 1 / -1;
        }
        
        .form-group label {
            display: block;
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 8px;
        }
        
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px;
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
            font-family: inherit;
        }
        
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #ffff00;
            box-shadow: 0 0 5px rgba(255, 255, 0, 0.3);
        }
        
        .form-help {
            font-size: 0.9em;
            color: #cccccc;
            margin-top: 5px;
        }
        
        .test-section {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 20px 0;
        }
        
        .test-controls {
            display: flex;
            gap: 15px;
            align-items: center;
            margin: 15px 0;
        }
        
        .test-input {
            flex: 1;
        }
        
        .test-response {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
            min-height: 80px;
            color: #ffffff;
            white-space: pre-wrap;
        }
        
        .response-meta {
            font-size: 0.8em;
            color: #cccccc;
            margin-top: 10px;
            padding-top: 10px;
            border-top: 1px solid #333333;
        }
        
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
        }

        .modal-content {
            background-color: #001100;
            margin: 5% auto;
            padding: 0;
            border: 2px solid #00ff00;
            border-radius: 10px;
            width: 90%;
            max-width: 800px;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal-header {
            background-color: #000800;
            padding: 15px 20px;
            border-bottom: 1px solid #00ff00;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h3 {
            margin: 0;
            color: #00ff00;
        }

        .close {
            color: #ff0000;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

        .close:hover {
            color: #ff6666;
        }

        .modal-body {
            padding: 20px;
            color: #cccccc;
        }
        
        .error-message {
            background: #330000;
            border: 1px solid #ff0000;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #ff6666;
        }
        
        .success-message {
            background: #003300;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #66ff66;
        }
        
        .info-message {
            background: #000033;
            border: 1px solid #0066ff;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #6666ff;
        }
    </style>
</head>
<body>
    <header>
        <h1>🧠 AI Personalities Configuration</h1>
        <nav class="breadcrumb">
            <a href="/">Home</a> &gt; 
            <a href="/ai-management">AI Management</a> &gt; 
            <span>AI Personalities</span>
        </nav>
    </header>

    <main class="personalities-config">
        <div class="info-section">
            <h2>🎭 Character AI Personality Management</h2>
            <p>Configure AI personalities for each character with custom models, prompts, and behavioral parameters</p>
        </div>

        <!-- Global Configuration -->
        <div class="config-section">
            <div class="config-header">
                <div style="display: flex; align-items: center;">
                    <i class="fas fa-globe config-icon"></i>
                    <h3>Global AI Settings</h3>
                </div>
                <button class="button primary-btn" onclick="saveGlobalConfig()">
                    <i class="fas fa-save"></i> Save Global Settings
                </button>
            </div>

            <form id="globalConfigForm" class="global-config">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="defaultProvider">Default AI Provider</label>
                        <select id="defaultProvider" name="defaultProvider">
                            <option value="openai" <%= globalConfig && globalConfig.defaultProvider === 'openai' ? 'selected' : '' %>>OpenAI</option>
                            <option value="anthropic" <%= globalConfig && globalConfig.defaultProvider === 'anthropic' ? 'selected' : '' %>>Anthropic</option>
                            <option value="google" <%= globalConfig && globalConfig.defaultProvider === 'google' ? 'selected' : '' %>>Google AI</option>
                        </select>
                        <div class="form-help">Primary AI provider for all characters</div>
                    </div>

                    <div class="form-group">
                        <label for="defaultModel">Default Model</label>
                        <select id="defaultModel" name="defaultModel">
                            <option value="gpt-4" <%= globalConfig && globalConfig.defaultModel === 'gpt-4' ? 'selected' : '' %>>GPT-4</option>
                            <option value="gpt-3.5-turbo" <%= globalConfig && globalConfig.defaultModel === 'gpt-3.5-turbo' ? 'selected' : '' %>>GPT-3.5 Turbo</option>
                            <option value="claude-3-opus" <%= globalConfig && globalConfig.defaultModel === 'claude-3-opus' ? 'selected' : '' %>>Claude 3 Opus</option>
                            <option value="claude-3-sonnet" <%= globalConfig && globalConfig.defaultModel === 'claude-3-sonnet' ? 'selected' : '' %>>Claude 3 Sonnet</option>
                            <option value="gemini-pro" <%= globalConfig && globalConfig.defaultModel === 'gemini-pro' ? 'selected' : '' %>>Gemini Pro</option>
                        </select>
                        <div class="form-help">Default model for new characters</div>
                    </div>

                    <div class="form-group">
                        <label for="defaultTemperature">Default Temperature</label>
                        <input type="range" id="defaultTemperature" name="defaultTemperature" 
                               min="0" max="2" step="0.1" 
                               value="<%= globalConfig && globalConfig.defaultTemperature ? globalConfig.defaultTemperature : '0.8' %>"
                               oninput="updateTemperatureDisplay(this.value)">
                        <div class="form-help">
                            Creativity level: <span id="temperatureValue"><%= globalConfig && globalConfig.defaultTemperature ? globalConfig.defaultTemperature : '0.8' %></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="defaultMaxTokens">Default Max Tokens</label>
                        <input type="number" id="defaultMaxTokens" name="defaultMaxTokens" 
                               min="50" max="4000" step="50"
                               value="<%= globalConfig && globalConfig.defaultMaxTokens ? globalConfig.defaultMaxTokens : '150' %>">
                        <div class="form-help">Maximum response length</div>
                    </div>

                    <div class="form-group">
                        <label for="contextLength">Context Length</label>
                        <input type="number" id="contextLength" name="contextLength" 
                               min="1" max="20" step="1"
                               value="<%= globalConfig && globalConfig.contextLength ? globalConfig.contextLength : '5' %>">
                        <div class="form-help">Number of previous messages to remember</div>
                    </div>

                    <div class="form-group">
                        <label for="responseTimeout">Response Timeout (ms)</label>
                        <input type="number" id="responseTimeout" name="responseTimeout" 
                               min="5000" max="60000" step="1000"
                               value="<%= globalConfig && globalConfig.responseTimeout ? globalConfig.responseTimeout : '30000' %>">
                        <div class="form-help">Maximum time to wait for AI response</div>
                    </div>
                </div>
            </form>
        </div>

        <!-- Character Personalities -->
        <div class="config-section">
            <div class="config-header">
                <div style="display: flex; align-items: center;">
                    <i class="fas fa-users config-icon"></i>
                    <h3>Character Personalities</h3>
                </div>
                <button class="button primary-btn" onclick="addNewCharacter()">
                    <i class="fas fa-plus"></i> Add Character
                </button>
            </div>

            <div class="character-grid" id="characterGrid">
                <% if (characters && characters.length > 0) { %>
                    <% characters.forEach(function(character) { %>
                        <div class="character-card" data-character-id="<%= character.id %>">
                            <div class="character-status status-<%= character.aiConfig && character.aiConfig.enabled ? 'online' : 'offline' %>"></div>

                            <div class="character-header">
                                <div class="character-avatar">
                                    <%= character.char_name ? character.char_name.charAt(0).toUpperCase() : '?' %>
                                </div>
                                <div class="character-info">
                                    <h4><%= character.char_name || 'Unnamed Character' %></h4>
                                    <p><%= character.char_description || 'No description' %></p>
                                </div>
                            </div>

                            <div class="character-details">
                                <div class="detail-row">
                                    <span class="detail-label">Model:</span>
                                    <span class="detail-value"><%= character.aiConfig ? character.aiConfig.model || 'Default' : 'Not configured' %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label">Temperature:</span>
                                    <span class="detail-value"><%= character.aiConfig ? character.aiConfig.temperature || '0.8' : 'Default' %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label">Max Tokens:</span>
                                    <span class="detail-value"><%= character.aiConfig ? character.aiConfig.maxTokens || '150' : 'Default' %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label">Status:</span>
                                    <span class="detail-value"><%= character.aiConfig && character.aiConfig.enabled ? 'Active' : 'Inactive' %></span>
                                </div>
                            </div>

                            <div class="character-actions">
                                <button class="button small-btn primary-btn" onclick="configureCharacter('<%= character.id %>')">
                                    <i class="fas fa-cog"></i> Configure
                                </button>
                                <button class="button small-btn secondary-btn" onclick="testCharacter('<%= character.id %>')">
                                    <i class="fas fa-test-tube"></i> Test
                                </button>
                                <button class="button small-btn secondary-btn" onclick="toggleCharacter('<%= character.id %>', <%= character.aiConfig && character.aiConfig.enabled ? 'false' : 'true' %>)">
                                    <i class="fas fa-<%= character.aiConfig && character.aiConfig.enabled ? 'pause' : 'play' %>"></i>
                                    <%= character.aiConfig && character.aiConfig.enabled ? 'Disable' : 'Enable' %>
                                </button>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="character-card">
                        <div class="character-header">
                            <div class="character-info">
                                <h4>No Characters Found</h4>
                                <p>Create characters in the Characters section first</p>
                            </div>
                        </div>
                        <div class="character-actions">
                            <a href="/characters" class="button primary-btn">
                                <i class="fas fa-plus"></i> Create Characters
                            </a>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- AI Testing Section -->
        <div class="test-section">
            <div class="config-header">
                <div style="display: flex; align-items: center;">
                    <i class="fas fa-flask config-icon"></i>
                    <h3>AI Personality Testing</h3>
                </div>
            </div>

            <div class="test-controls">
                <select id="testCharacter" class="form-control">
                    <option value="">Select Character to Test</option>
                    <% if (characters && characters.length > 0) { %>
                        <% characters.forEach(function(character) { %>
                            <option value="<%= character.id %>"><%= character.char_name || 'Unnamed Character' %></option>
                        <% }); %>
                    <% } %>
                </select>
                <input type="text" id="testPrompt" class="test-input" placeholder="Enter test message..." value="Hello, how are you today?">
                <button class="button primary-btn" onclick="runAITest()">
                    <i class="fas fa-paper-plane"></i> Send
                </button>
            </div>

            <div class="test-response" id="testResponse">
                <em>AI response will appear here...</em>
            </div>
        </div>

        <!-- Navigation -->
        <div class="button-group" style="margin-top: 30px;">
            <a href="/ai-management" class="button secondary-btn">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
            <a href="/characters" class="button">
                <i class="fas fa-users"></i> Manage Characters
            </a>
            <a href="/ai-instances" class="button">
                <i class="fas fa-brain"></i> AI Instances
            </a>
        </div>

        <!-- Messages -->
        <div id="messageContainer"></div>
    </main>

    <!-- Character Configuration Modal -->
    <div id="characterModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modalTitle">Configure Character AI</h3>
                <span class="close" onclick="closeModal()">&times;</span>
            </div>
            <div class="modal-body">
                <form id="characterConfigForm">
                    <input type="hidden" id="characterId" name="characterId">

                    <div class="form-grid">
                        <div class="form-group">
                            <label for="aiProvider">AI Provider</label>
                            <select id="aiProvider" name="aiProvider">
                                <option value="openai">OpenAI</option>
                                <option value="anthropic">Anthropic</option>
                                <option value="google">Google AI</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="aiModel">AI Model</label>
                            <select id="aiModel" name="aiModel">
                                <option value="gpt-4">GPT-4</option>
                                <option value="gpt-3.5-turbo">GPT-3.5 Turbo</option>
                                <option value="claude-3-opus">Claude 3 Opus</option>
                                <option value="claude-3-sonnet">Claude 3 Sonnet</option>
                                <option value="gemini-pro">Gemini Pro</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="aiTemperature">Temperature</label>
                            <input type="range" id="aiTemperature" name="aiTemperature"
                                   min="0" max="2" step="0.1" value="0.8"
                                   oninput="updateModalTemperatureDisplay(this.value)">
                            <div class="form-help">
                                Creativity: <span id="modalTemperatureValue">0.8</span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="aiMaxTokens">Max Tokens</label>
                            <input type="number" id="aiMaxTokens" name="aiMaxTokens"
                                   min="50" max="4000" step="50" value="150">
                        </div>

                        <div class="form-group full-width">
                            <label for="systemPrompt">System Prompt / Personality</label>
                            <textarea id="systemPrompt" name="systemPrompt" rows="6"
                                      placeholder="Define the character's personality, speaking style, background, and behavioral traits..."></textarea>
                            <div class="form-help">Detailed personality description that defines how the character should behave and respond</div>
                        </div>

                        <div class="form-group">
                            <label for="contextLength">Context Length</label>
                            <input type="number" id="contextLength" name="contextLength"
                                   min="1" max="20" step="1" value="5">
                            <div class="form-help">Messages to remember</div>
                        </div>

                        <div class="form-group">
                            <label for="enabled">Enable AI</label>
                            <select id="enabled" name="enabled">
                                <option value="true">Enabled</option>
                                <option value="false">Disabled</option>
                            </select>
                        </div>
                    </div>

                    <div class="button-group">
                        <button type="submit" class="button primary-btn">
                            <i class="fas fa-save"></i> Save Configuration
                        </button>
                        <button type="button" class="button secondary-btn" onclick="testModalCharacter()">
                            <i class="fas fa-test-tube"></i> Test AI
                        </button>
                        <button type="button" class="button secondary-btn" onclick="closeModal()">
                            Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            updateTemperatureDisplay(document.getElementById('defaultTemperature').value);
        });

        // Global configuration functions
        function updateTemperatureDisplay(value) {
            document.getElementById('temperatureValue').textContent = value;
        }

        function updateModalTemperatureDisplay(value) {
            document.getElementById('modalTemperatureValue').textContent = value;
        }

        async function saveGlobalConfig() {
            const formData = new FormData(document.getElementById('globalConfigForm'));
            const config = Object.fromEntries(formData.entries());

            try {
                showMessage('Saving global configuration...', 'info');

                const response = await fetch('/ai-management/api/personalities/global', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config)
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('Global configuration saved successfully!', 'success');
                } else {
                    showMessage(`Failed to save global configuration: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error saving global configuration: ${error.message}`, 'error');
            }
        }

        // Character management functions
        function configureCharacter(characterId) {
            // Load character configuration
            fetch(`/ai-management/api/personalities/character/${characterId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        populateModal(data.character);
                        document.getElementById('characterModal').style.display = 'block';
                    } else {
                        showMessage(`Failed to load character configuration: ${data.error}`, 'error');
                    }
                })
                .catch(error => {
                    showMessage(`Error loading character configuration: ${error.message}`, 'error');
                });
        }

        function populateModal(character) {
            document.getElementById('characterId').value = character.id;
            document.getElementById('modalTitle').textContent = `Configure ${character.char_name || 'Character'} AI`;

            const config = character.aiConfig || {};
            document.getElementById('aiProvider').value = config.provider || 'openai';
            document.getElementById('aiModel').value = config.model || 'gpt-4';
            document.getElementById('aiTemperature').value = config.temperature || '0.8';
            document.getElementById('aiMaxTokens').value = config.maxTokens || '150';
            document.getElementById('systemPrompt').value = config.systemPrompt || '';
            document.getElementById('contextLength').value = config.contextLength || '5';
            document.getElementById('enabled').value = config.enabled ? 'true' : 'false';

            updateModalTemperatureDisplay(config.temperature || '0.8');
        }

        function closeModal() {
            document.getElementById('characterModal').style.display = 'none';
        }

        // Form submission for character configuration
        document.getElementById('characterConfigForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const formData = new FormData(this);
            const config = Object.fromEntries(formData.entries());
            const characterId = config.characterId;

            try {
                showMessage('Saving character configuration...', 'info');

                const response = await fetch(`/ai-management/api/personalities/character/${characterId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config)
                });

                const data = await response.json();

                if (data.success) {
                    showMessage('Character configuration saved successfully!', 'success');
                    closeModal();
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showMessage(`Failed to save character configuration: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error saving character configuration: ${error.message}`, 'error');
            }
        });

        async function testCharacter(characterId) {
            const prompt = 'Hello, this is a test message. Please respond in character.';

            try {
                showMessage('Testing character AI...', 'info');

                const response = await fetch('/ai-management/api/personalities/test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ characterId, prompt })
                });

                const data = await response.json();

                if (data.success) {
                    showMessage(`Test successful! Response: "${data.response}"`, 'success');
                } else {
                    showMessage(`Test failed: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Test error: ${error.message}`, 'error');
            }
        }

        async function toggleCharacter(characterId, enable) {
            try {
                showMessage(`${enable ? 'Enabling' : 'Disabling'} character AI...`, 'info');

                const response = await fetch(`/ai-management/api/personalities/character/${characterId}/toggle`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ enabled: enable })
                });

                const data = await response.json();

                if (data.success) {
                    showMessage(`Character AI ${enable ? 'enabled' : 'disabled'} successfully!`, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showMessage(`Failed to ${enable ? 'enable' : 'disable'} character AI: ${data.error}`, 'error');
                }
            } catch (error) {
                showMessage(`Error ${enable ? 'enabling' : 'disabling'} character AI: ${error.message}`, 'error');
            }
        }

        // Testing functions
        async function runAITest() {
            const characterId = document.getElementById('testCharacter').value;
            const prompt = document.getElementById('testPrompt').value;

            if (!characterId) {
                showMessage('Please select a character to test', 'error');
                return;
            }

            if (!prompt.trim()) {
                showMessage('Please enter a test message', 'error');
                return;
            }

            try {
                document.getElementById('testResponse').innerHTML = '<em>Generating response...</em>';

                const response = await fetch('/ai-management/api/personalities/test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ characterId, prompt })
                });

                const data = await response.json();

                if (data.success) {
                    document.getElementById('testResponse').innerHTML =
                        `<strong>Response:</strong><br>"${data.response}"<br><br>` +
                        `<div class="response-meta">` +
                        `Model: ${data.model} | Provider: ${data.provider}<br>` +
                        `Response Time: ${data.responseTime}ms | Tokens: ${data.tokens || 'N/A'}` +
                        `</div>`;
                } else {
                    document.getElementById('testResponse').innerHTML =
                        `<strong>Error:</strong> ${data.error}`;
                }
            } catch (error) {
                document.getElementById('testResponse').innerHTML =
                    `<strong>Error:</strong> ${error.message}`;
            }
        }

        async function testModalCharacter() {
            const characterId = document.getElementById('characterId').value;
            const prompt = 'Hello, this is a test message. Please respond in character.';

            try {
                const response = await fetch('/ai-management/api/personalities/test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ characterId, prompt })
                });

                const data = await response.json();

                if (data.success) {
                    alert(`Test Response: "${data.response}"`);
                } else {
                    alert(`Test Failed: ${data.error}`);
                }
            } catch (error) {
                alert(`Test Error: ${error.message}`);
            }
        }

        function addNewCharacter() {
            window.location.href = '/characters/new';
        }

        // Utility functions
        function showMessage(message, type) {
            const container = document.getElementById('messageContainer');
            const messageDiv = document.createElement('div');
            messageDiv.className = `${type}-message`;
            messageDiv.innerHTML = `<i class="fas fa-${type === 'error' ? 'exclamation-triangle' : type === 'success' ? 'check-circle' : 'info-circle'}"></i> ${message}`;

            container.innerHTML = '';
            container.appendChild(messageDiv);

            setTimeout(() => {
                if (messageDiv.parentNode) {
                    messageDiv.parentNode.removeChild(messageDiv);
                }
            }, 5000);
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('characterModal');
            if (event.target === modal) {
                closeModal();
            }
        }
    </script>
</body>
</html>
