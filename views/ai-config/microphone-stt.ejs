<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎤 Microphone and STT Testing</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        .stt-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .stt-header {
            background: #001100;
            border: 1px solid #003300;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            text-align: center;
        }

        .stt-controls {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
            align-items: start;
        }

        .controls-row {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .controls-row.full-width {
            grid-column: 1 / -1;
            display: flex;
            flex-direction: row;
            justify-content: center;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .character-selector, .microphone-selector {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .character-selector label, .microphone-selector label {
            color: #00ff88;
            font-weight: bold;
            font-size: 0.9em;
        }

        .character-selector select, .microphone-selector select {
            background: #001100;
            border: 1px solid #003300;
            color: #00ff88;
            padding: 8px 12px;
            border-radius: 4px;
            min-width: 200px;
            width: 100%;
        }

        .recording-controls {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .record-button {
            background: #001100;
            border: 2px solid #003300;
            color: #00ff88;
            padding: 12px 24px;
            border-radius: 50px;
            cursor: pointer;
            font-size: 16px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .record-button:hover {
            border-color: #00ff00;
            background: #002200;
        }

        .record-button.recording {
            background: #220000;
            border-color: #ff0000;
            color: #ff4444;
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.7; }
            100% { opacity: 1; }
        }

        .audio-level {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .level-meter {
            width: 200px;
            height: 20px;
            background: #001100;
            border: 1px solid #003300;
            border-radius: 10px;
            overflow: hidden;
            position: relative;
        }

        .level-fill {
            height: 100%;
            background: linear-gradient(to right, #00ff00, #ffff00, #ff0000);
            width: 0%;
            transition: width 0.1s ease;
        }

        .level-value {
            color: #00ff88;
            font-family: monospace;
            min-width: 60px;
        }

        .stt-dashboard {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 20px;
        }

        .transcription-panel, .metrics-panel {
            background: #001100;
            border: 1px solid #003300;
            border-radius: 8px;
            padding: 20px;
        }

        .transcription-log {
            background: #000800;
            border: 1px solid #002200;
            border-radius: 4px;
            padding: 15px;
            height: 400px;
            overflow-y: auto;
            font-family: monospace;
            font-size: 14px;
            line-height: 1.4;
        }

        .log-entry {
            margin-bottom: 15px;
            padding: 10px;
            background: #001100;
            border-left: 3px solid #003300;
            border-radius: 4px;
        }

        .log-entry.success {
            border-left-color: #00ff00;
        }

        .log-entry.error {
            border-left-color: #ff0000;
        }

        .log-entry.transcript {
            border-left-color: #00ffff;
            background: rgba(0, 255, 255, 0.05);
        }

        .transcript-text {
            font-weight: bold;
            color: #00ffff;
            font-size: 1.1em;
        }

        .log-timestamp {
            color: #666;
            font-size: 12px;
            margin-bottom: 5px;
        }

        .log-text {
            color: #00ff88;
            margin-bottom: 8px;
            font-weight: bold;
        }

        .log-metrics {
            color: #888;
            font-size: 12px;
            display: flex;
            gap: 15px;
        }

        .metrics-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .metric-card {
            background: #000800;
            border: 1px solid #002200;
            border-radius: 4px;
            padding: 15px;
            text-align: center;
        }

        .metric-value {
            font-size: 24px;
            font-weight: bold;
            color: #00ff88;
            margin-bottom: 5px;
        }

        .metric-label {
            color: #888;
            font-size: 12px;
        }

        .clear-log-btn {
            background: #220000;
            border: 1px solid #440000;
            color: #ff4444;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            float: right;
            margin-bottom: 10px;
        }

        .clear-log-btn:hover {
            background: #330000;
            border-color: #660000;
        }

        .status-indicator {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 8px;
        }

        .status-online {
            background: #00ff00;
            box-shadow: 0 0 10px #00ff00;
        }

        .status-offline {
            background: #666;
        }

        .status-recording {
            background: #ff0000;
            box-shadow: 0 0 10px #ff0000;
            animation: pulse 1s infinite;
        }

        /* STT Settings Card */
        .stt-settings-card {
            background: #001100;
            border: 1px solid #003300;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .stt-settings-card h3 {
            color: #00ff88;
            margin-bottom: 15px;
            text-align: center;
        }

        .settings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .setting-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .setting-group label {
            color: #00ff88;
            font-weight: bold;
            font-size: 0.9em;
        }

        .setting-group select, .setting-group input[type="number"] {
            background: #000000;
            border: 1px solid #003300;
            color: #00ff88;
            padding: 8px 12px;
            border-radius: 4px;
        }

        .setting-group input[type="range"] {
            background: #000000;
            border-radius: 4px;
        }

        .setting-group input[type="checkbox"] {
            width: 20px;
            height: 20px;
            accent-color: #00ff88;
        }

        .range-value {
            color: #00ff88;
            font-weight: bold;
            text-align: center;
            font-size: 0.9em;
        }

        .settings-actions {
            display: flex;
            gap: 10px;
            justify-content: center;
        }



        /* Live status indicator */
        .transcription-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .live-status {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #00ff88;
            font-weight: bold;
        }

        .status-indicator {
            width: 12px;
            height: 12px;
            background: #00ff88;
            border-radius: 50%;
            animation: pulse 1s infinite;
        }

        /* Compact Header Styles */
        .compact-header {
            background: #000000;
            border-bottom: 2px solid #00ff00;
            padding: 15px 20px;
            margin: -20px -20px 20px -20px;
        }

        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .page-title {
            font-family: 'Creepster', cursive;
            font-size: 2em;
            margin: 0;
            color: #00ff00;
            text-shadow: 0 0 10px #00ff00;
        }

        .breadcrumb-vertical {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9em;
        }

        .breadcrumb-item {
            color: #00ffff;
            text-decoration: none;
            transition: all 0.3s ease;
            padding: 4px 8px;
            border-radius: 4px;
        }

        .breadcrumb-item:hover {
            color: #ffffff;
            background: rgba(0, 255, 255, 0.1);
        }

        .breadcrumb-item.active {
            color: #00ff00;
            font-weight: bold;
        }

        .breadcrumb-item:not(:last-child):after {
            content: "→";
            margin-left: 8px;
            color: #666;
        }

        /* Info Section */
        .info-section {
            text-align: center;
            margin-bottom: 30px;
        }

        .info-section h2 {
            color: #00ff00;
            margin-bottom: 10px;
            text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
        }

        .info-section p {
            color: #00ff88;
            margin-bottom: 0;
        }

        @media (max-width: 768px) {
            .compact-header {
                padding: 10px 15px;
                margin: -20px -20px 15px -20px;
            }

            .header-content {
                flex-direction: column;
                gap: 10px;
                text-align: center;
            }

            .page-title {
                font-size: 1.5em;
            }

            .breadcrumb-vertical {
                font-size: 0.8em;
                flex-wrap: wrap;
                justify-content: center;
            }
        }

        /* Main Container */
        .stt-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            background: #000000;
            border-radius: 10px;
            border: 2px solid #00ff00;
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.3);
        }
    </style>
</head>
<body>
    <header class="compact-header">
        <div class="header-content">
            <h1 class="page-title">🎤 Microphone and STT Testing</h1>
            <div class="breadcrumb-vertical">
                <a href="/" class="breadcrumb-item">🏠 Home</a>
                <a href="/ai-management" class="breadcrumb-item">🤖 AI Management</a>
                <span class="breadcrumb-item active">🎤 Microphone and STT</span>
            </div>
        </div>
    </header>

    <main class="stt-container">
        <div class="info-section" style="display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
            <div>
                <h2>🎤 Microphone and STT Testing</h2>
                <p>Test your microphone and Speech-to-Text functionality with real-time transcription and performance metrics</p>
            </div>
            <div>
                <a href="/ai-management/enhanced-test-chat" style="
                    color:#00ff41; text-decoration:none; border:1px solid #00ff41; padding:6px 10px; border-radius:6px;
                    box-shadow:0 0 10px rgba(0,255,65,0.2); background:rgba(0,0,0,0.6); font-weight:bold;">
                    ↩ Back to Enhanced Test Chat
                </a>
            </div>
        </div>

        <div class="stt-controls">
            <div class="controls-row">
                <div class="character-selector">
                    <label for="characterSelect">Character:</label>
                    <select id="characterSelect">
                        <option value="">Select character...</option>
                        <% if (characters && characters.length > 0) { %>
                            <% characters.forEach(function(character) { %>
                                <option value="<%= character.id %>" data-agent-id="<%= character.elevenLabsAgentId %>"><%= character.char_name %></option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>

                <div class="microphone-selector">
                    <label for="microphoneSelect">Microphone:</label>
                    <select id="microphoneSelect">
                        <option value="">Select microphone...</option>
                        <% if (microphones && microphones.length > 0) { %>
                            <% microphones.forEach(function(microphone) { %>
                                <option value="<%= microphone.id %>"><%= microphone.name %></option>
                            <% }); %>
                        <% } else { %>
                            <option value="default">Default System Microphone</option>
                        <% } %>
                    </select>
                </div>
            </div>

            <div class="controls-row">
                <div class="audio-level">
                    <span>Level:</span>
                    <div class="level-meter">
                        <div class="level-fill" id="audioLevel"></div>
                    </div>
                    <span class="level-value" id="levelValue">0%</span>
                </div>
            </div>

            <div class="controls-row full-width">
                <div class="recording-controls">
                    <button id="recordButton" class="record-button" disabled>
                        <i class="fas fa-microphone"></i>
                        <span>Start Recording</span>
                    </button>
                    <button id="stopButton" class="button secondary-btn" disabled>
                        <i class="fas fa-stop"></i>
                        Stop
                    </button>

                </div>
            </div>
        </div>



        <div class="stt-dashboard">
            <div class="transcription-panel">
                <h3>📝 Transcription Log</h3>
                <div class="transcription-controls">
                    <button class="clear-log-btn" onclick="clearLog()">Clear Log</button>
                    <div class="live-status" id="liveStatus" style="display: none;">
                        <span class="status-indicator"></span>
                        <span>Live Transcription Active</span>
                    </div>
                </div>
                <div class="transcription-log" id="transcriptionLog">
                    <div class="log-entry">
                        <div class="log-timestamp">Ready to start transcription...</div>
                        <div class="log-text">Select a character and microphone, then click "Start Recording" to begin</div>
                    </div>
                </div>
            </div>

            <div class="metrics-panel">
                <h3>📊 Performance Metrics</h3>
                <div class="metrics-grid">
                    <div class="metric-card">
                        <div class="metric-value" id="totalTests">0</div>
                        <div class="metric-label">Total Tests</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-value" id="avgResponseTime">0ms</div>
                        <div class="metric-label">Avg Response Time</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-value" id="successRate">0%</div>
                        <div class="metric-label">Success Rate</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-value" id="currentStatus">
                            <span class="status-indicator status-offline"></span>
                            Offline
                        </div>
                        <div class="metric-label">STT Status</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Character + Microphone Specific STT Settings Card -->
        <div class="stt-settings-card" id="sttSettingsCard" style="display: none;">
            <h3>🎛️ ElevenLabs STT Settings for <span id="selectedCharacterName">Character</span> + <span id="selectedMicrophoneName">Microphone</span></h3>
            <div class="settings-grid">
                <div class="setting-group">
                    <label for="sttLanguage">Language:</label>
                    <select id="sttLanguage">
                        <option value="en">English</option>
                        <option value="es">Spanish</option>
                        <option value="fr">French</option>
                        <option value="de">German</option>
                        <option value="it">Italian</option>
                        <option value="pt">Portuguese</option>
                        <option value="ja">Japanese</option>
                        <option value="ko">Korean</option>
                        <option value="zh">Chinese</option>
                    </select>
                </div>

                <div class="setting-group">
                    <label for="confidenceThreshold">Confidence Threshold:</label>
                    <input type="range" id="confidenceThreshold" min="0.1" max="1.0" step="0.1" value="0.7">
                    <span class="range-value" id="confidenceValue">0.7</span>
                </div>

                <div class="setting-group">
                    <label for="realTimeProcessing">Real-time Processing:</label>
                    <input type="checkbox" id="realTimeProcessing" checked>
                </div>

                <div class="setting-group">
                    <label for="vadThreshold">Voice Activity Detection:</label>
                    <input type="range" id="vadThreshold" min="0.1" max="1.0" step="0.1" value="0.5">
                    <span class="range-value" id="vadValue">0.5</span>
                </div>

                <div class="setting-group">
                    <label for="silenceDuration">Silence Duration (ms):</label>
                    <input type="number" id="silenceDuration" min="100" max="5000" step="100" value="200">
                </div>

                <div class="setting-group">
                    <label for="prefixPadding">Prefix Padding (ms):</label>
                    <input type="number" id="prefixPadding" min="0" max="1000" step="50" value="300">
                </div>
            </div>

            <div class="settings-actions">
                <button id="saveSettingsButton" class="button primary-btn">
                    <i class="fas fa-save"></i>
                    Save Settings
                </button>
                <button id="testSettingsButton" class="button secondary-btn">
                    <i class="fas fa-test-tube"></i>
                    Test Configuration
                </button>
            </div>
        </div>
    </div>

    <script>
        let mediaRecorder = null;
        let audioStream = null;
        let audioContext = null;
        let analyser = null;
        let isRecording = false;
        let recordingStartTime = null;
        let selectedCharacterId = null;
        let testMetrics = {
            totalTests: 0,
            successfulTests: 0,
            responseTimes: []
        };

        $(document).ready(function() {
            initializePage();
            setupEventHandlers();
            updateMetrics();
        });

        function initializePage() {
            // Enable selectors
            $('#characterSelect').prop('disabled', false);
            $('#microphoneSelect').prop('disabled', false);

            // Debug: Log available characters
            const characterOptions = $('#characterSelect option');
            console.log('Available characters:', characterOptions.length - 1); // -1 for the "Select character..." option
            characterOptions.each(function(index) {
                if (this.value) {
                    console.log(`Character ${index}: ID=${this.value}, Name=${this.text}`);
                }
            });

            // Check for microphone access
            if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                updateStatus('Ready', 'status-online');
            } else {
                addLogEntry('error', 'Microphone access not supported in this browser', '', {});
                updateStatus('Not Supported', 'status-offline');
            }
        }

        function enableControls() {
            $('#recordButton').prop('disabled', false);
        }

        function disableControls() {
            $('#recordButton').prop('disabled', true);
        }

        function setupEventHandlers() {
            $('#characterSelect').change(function() {
                const characterId = this.value;
                selectedCharacterId = characterId;

                if (characterId) {
                    loadCharacterSTTSettings(characterId);
                    $('#sttSettingsCard').show();
                    const characterName = $(this).find('option:selected').text();
                    $('#selectedCharacterName').text(characterName);

                    // Enable controls if microphone is also selected
                    if ($('#microphoneSelect').val()) {
                        enableControls();
                    }
                } else {
                    $('#sttSettingsCard').hide();
                    disableControls();
                }
            });

            $('#microphoneSelect').change(function() {
                if (this.value && selectedCharacterId) {
                    enableControls();
                    // Update microphone name in STT settings card
                    const selectedOption = $(this).find('option:selected');
                    $('#selectedMicrophoneName').text(selectedOption.text());
                    // Reload STT settings for this character + microphone combination
                    loadCharacterSTTSettings(selectedCharacterId);
                } else {
                    disableControls();
                }
            });

            $('#recordButton').click(function() {
                if (!isRecording) {
                    startRecording();
                } else {
                    stopRecording();
                }
            });

            $('#stopButton').click(function() {
                stopRecording();
            });



            $('#saveSettingsButton').click(function() {
                saveCharacterSTTSettings();
            });

            $('#testSettingsButton').click(function() {
                testSTTConfiguration();
            });

            // Range input updates
            $('#confidenceThreshold').on('input', function() {
                $('#confidenceValue').text(this.value);
            });

            $('#vadThreshold').on('input', function() {
                $('#vadValue').text(this.value);
            });
        }

        async function startRecording() {
            try {
                recordingStartTime = Date.now();
                updateStatus('Starting...', 'status-recording');

                // Get user media
                const constraints = {
                    audio: {
                        echoCancellation: true,
                        noiseSuppression: true,
                        autoGainControl: true,
                        sampleRate: 44100
                    }
                };

                audioStream = await navigator.mediaDevices.getUserMedia(constraints);

                // Setup audio context for level monitoring
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                const source = audioContext.createMediaStreamSource(audioStream);
                analyser = audioContext.createAnalyser();
                analyser.fftSize = 256;
                source.connect(analyser);

                // Start level monitoring
                monitorAudioLevel();

                // Setup media recorder
                mediaRecorder = new MediaRecorder(audioStream, {
                    mimeType: 'audio/webm;codecs=opus'
                });

                let audioChunks = [];

                mediaRecorder.ondataavailable = function(event) {
                    if (event.data.size > 0) {
                        audioChunks.push(event.data);
                    }
                };

                mediaRecorder.onstop = function() {
                    const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                    processAudioForSTT(audioBlob);
                };

                // Start recording
                mediaRecorder.start();
                isRecording = true;

                // Update UI
                $('#recordButton').addClass('recording');
                $('#recordButton span').text('Recording...');
                $('#stopButton').prop('disabled', false);
                updateStatus('Recording', 'status-recording');

                addLogEntry('info', 'Recording started', 'Listening for speech...', {});

            } catch (error) {
                console.error('Error starting recording:', error);
                addLogEntry('error', 'Failed to start recording', error.message, {});
                updateStatus('Error', 'status-offline');
            }
        }

        function stopRecording() {
            if (mediaRecorder && isRecording) {
                mediaRecorder.stop();
                isRecording = false;

                // Stop audio stream
                if (audioStream) {
                    audioStream.getTracks().forEach(track => track.stop());
                }

                // Close audio context
                if (audioContext) {
                    audioContext.close();
                }

                // Update UI
                $('#recordButton').removeClass('recording');
                $('#recordButton span').text('Start Recording');
                $('#stopButton').prop('disabled', true);
                $('#audioLevel').css('width', '0%');
                $('#levelValue').text('0%');
                updateStatus('Processing...', 'status-online');

                addLogEntry('info', 'Recording stopped', 'Processing audio for transcription...', {});
            }
        }

        function monitorAudioLevel() {
            if (!analyser || !isRecording) return;

            const dataArray = new Uint8Array(analyser.frequencyBinCount);
            analyser.getByteFrequencyData(dataArray);

            // Calculate average volume
            let sum = 0;
            for (let i = 0; i < dataArray.length; i++) {
                sum += dataArray[i];
            }
            const average = sum / dataArray.length;
            const percentage = Math.round((average / 255) * 100);

            // Update level meter
            $('#audioLevel').css('width', percentage + '%');
            $('#levelValue').text(percentage + '%');

            // Continue monitoring
            if (isRecording) {
                requestAnimationFrame(monitorAudioLevel);
            }
        }

        async function loadCharacterSTTSettings(characterId) {
            try {
                const microphoneId = $('#microphoneSelect').val();

                if (!microphoneId) {
                    // No microphone selected, load character-level defaults
                    const response = await fetch(`/ai-management/api/stt/character/${characterId}/config`);
                    const data = await response.json();

                    if (data.success) {
                        const config = data.config;
                        $('#sttLanguage').val(config.language || 'en');
                        $('#confidenceThreshold').val(config.confidenceThreshold || 0.7);
                        $('#confidenceValue').text(config.confidenceThreshold || 0.7);
                        $('#realTimeProcessing').prop('checked', config.realTimeProcessing !== false);
                        $('#vadThreshold').val(config.vadThreshold || 0.5);
                        $('#vadValue').text(config.vadThreshold || 0.5);
                        $('#silenceDuration').val(config.silenceDuration || 200);
                        $('#prefixPadding').val(config.prefixPadding || 300);
                    }
                } else {
                    // Load character + microphone specific settings
                    const response = await fetch(`/ai-management/api/stt/character/${characterId}/microphone/${microphoneId}/config`);
                    const data = await response.json();

                    if (data.success) {
                        const config = data.config;
                        $('#sttLanguage').val(config.language || 'en');
                        $('#confidenceThreshold').val(config.confidenceThreshold || 0.7);
                        $('#confidenceValue').text(config.confidenceThreshold || 0.7);
                        $('#realTimeProcessing').prop('checked', config.realTimeProcessing !== false);
                        $('#vadThreshold').val(config.vadThreshold || 0.5);
                        $('#vadValue').text(config.vadThreshold || 0.5);
                        $('#silenceDuration').val(config.silenceDuration || 200);
                        $('#prefixPadding').val(config.prefixPadding || 300);
                    }
                }
            } catch (error) {
                console.error('Error loading character STT settings:', error);
                addLogEntry('error', 'Failed to load character STT settings', '', {});
            }
        }

        async function saveCharacterSTTSettings() {
            if (!selectedCharacterId) {
                alert('Please select a character first');
                return;
            }

            const microphoneId = $('#microphoneSelect').val();
            if (!microphoneId) {
                alert('Please select a microphone first');
                return;
            }

            try {
                const settings = {
                    language: $('#sttLanguage').val(),
                    confidenceThreshold: parseFloat($('#confidenceThreshold').val()),
                    realTimeProcessing: $('#realTimeProcessing').is(':checked'),
                    vadThreshold: parseFloat($('#vadThreshold').val()),
                    silenceDuration: parseInt($('#silenceDuration').val()),
                    prefixPadding: parseInt($('#prefixPadding').val()),
                    provider: 'elevenlabs'
                };

                // Save to character + microphone specific endpoint
                const response = await fetch(`/ai-management/api/stt/character/${selectedCharacterId}/microphone/${microphoneId}/config`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(settings)
                });

                const data = await response.json();

                if (data.success) {
                    addLogEntry('success', 'STT settings saved successfully', `Character ${selectedCharacterId} + Microphone ${microphoneId}`, {});
                    alert('Settings saved successfully for this character and microphone combination!');
                } else {
                    throw new Error(data.error || 'Failed to save settings');
                }
            } catch (error) {
                console.error('Error saving STT settings:', error);
                addLogEntry('error', 'Failed to save STT settings: ' + error.message, '', {});
                alert('Error saving settings: ' + error.message);
            }
        }

        async function testSTTConfiguration() {
            if (!selectedCharacterId) {
                alert('Please select a character first');
                return;
            }

            addLogEntry('info', 'Testing STT configuration...', '', {});

            try {
                // This would test the current configuration
                // For now, we'll just show the current settings
                const settings = {
                    language: $('#sttLanguage').val(),
                    confidenceThreshold: $('#confidenceThreshold').val(),
                    vadThreshold: $('#vadThreshold').val(),
                    silenceDuration: $('#silenceDuration').val()
                };

                addLogEntry('success', 'STT Configuration Test', JSON.stringify(settings, null, 2), {
                    confidence: Math.round(parseFloat(settings.confidenceThreshold) * 100),
                    size: '0 KB'
                });
            } catch (error) {
                addLogEntry('error', 'STT configuration test failed: ' + error.message, '', {});
            }
        }




        async function processAudioForSTT(audioBlob) {
            const processingStartTime = Date.now();

            try {
                // Create form data
                const formData = new FormData();
                formData.append('audio', audioBlob, 'recording.webm');
                formData.append('microphone', $('#microphoneSelect').val() || 'default');
                formData.append('characterId', selectedCharacterId);

                // Send to STT API
                const response = await fetch('/ai-management/api/stt/transcribe', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();
                const responseTime = Date.now() - processingStartTime;

                // Update metrics
                testMetrics.totalTests++;
                testMetrics.responseTimes.push(responseTime);

                if (data.success && data.transcription) {
                    testMetrics.successfulTests++;

                    addLogEntry('success', 'Transcription completed', data.transcription, {
                        responseTime: responseTime,
                        confidence: data.confidence || 'N/A',
                        audioSize: Math.round(audioBlob.size / 1024) + ' KB'
                    });

                    updateStatus('Ready', 'status-online');
                } else {
                    addLogEntry('error', 'Transcription failed', data.error || 'Unknown error', {
                        responseTime: responseTime,
                        audioSize: Math.round(audioBlob.size / 1024) + ' KB'
                    });

                    updateStatus('Error', 'status-offline');
                }

                updateMetrics();

            } catch (error) {
                console.error('STT processing error:', error);
                const responseTime = Date.now() - processingStartTime;
                testMetrics.totalTests++;
                testMetrics.responseTimes.push(responseTime);

                addLogEntry('error', 'STT request failed', error.message, {
                    responseTime: responseTime
                });

                updateStatus('Error', 'status-offline');
                updateMetrics();
            }
        }

        function addLogEntry(type, title, message, metrics) {
            const timestamp = new Date().toLocaleTimeString();

            // Special handling for transcript entries
            if (type === 'transcript') {
                const roleIcon = metrics.role === 'user' ? '🎤' : '🤖';
                const logEntry = $(`
                    <div class="log-entry ${type}">
                        <div class="log-timestamp">${timestamp} ${roleIcon}</div>
                        <div class="log-text transcript-text">${title}</div>
                        <div class="log-metrics">
                            ${metrics.confidence ? `<span>Confidence: ${metrics.confidence}%</span>` : ''}
                            ${metrics.role ? `<span>Role: ${metrics.role}</span>` : ''}
                        </div>
                    </div>
                `);
                $('#transcriptionLog').prepend(logEntry);
            } else {
                const logEntry = $(`
                    <div class="log-entry ${type}">
                        <div class="log-timestamp">${timestamp}</div>
                        <div class="log-text">${title}${message ? ': ' + message : ''}</div>
                        <div class="log-metrics">
                            ${metrics.responseTime ? `<span>Response: ${metrics.responseTime}ms</span>` : ''}
                            ${metrics.confidence ? `<span>Confidence: ${metrics.confidence}%</span>` : ''}
                            ${metrics.audioSize ? `<span>Size: ${metrics.audioSize}</span>` : ''}
                            ${metrics.size ? `<span>Size: ${metrics.size}</span>` : ''}
                        </div>
                    </div>
                `);
                $('#transcriptionLog').prepend(logEntry);
            }

            // Keep only last 50 entries
            const entries = $('#transcriptionLog .log-entry');
            if (entries.length > 50) {
                entries.slice(50).remove();
            }
        }

        function updateMetrics() {
            $('#totalTests').text(testMetrics.totalTests);

            if (testMetrics.responseTimes.length > 0) {
                const avgTime = Math.round(
                    testMetrics.responseTimes.reduce((a, b) => a + b, 0) / testMetrics.responseTimes.length
                );
                $('#avgResponseTime').text(avgTime + 'ms');
            }

            if (testMetrics.totalTests > 0) {
                const successRate = Math.round((testMetrics.successfulTests / testMetrics.totalTests) * 100);
                $('#successRate').text(successRate + '%');
            }
        }

        function updateStatus(text, className) {
            const statusElement = $('#currentStatus');
            statusElement.html(`<span class="status-indicator ${className}"></span>${text}`);
        }

        function clearLog() {
            $('#transcriptionLog').html(`
                <div class="log-entry">
                    <div class="log-timestamp">Log cleared</div>
                    <div class="log-text">Ready for new transcriptions</div>
                </div>
            `);

            // Reset metrics
            testMetrics = {
                totalTests: 0,
                successfulTests: 0,
                responseTimes: []
            };
            updateMetrics();
        }
    </script>
</body>
</html>
