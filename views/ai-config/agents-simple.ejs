<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Simple Agents Test</title>
</head>
<body>
  <h1>ElevenLabs Agents Test</h1>
  
  <p>Service Status: <%= serviceStatus && serviceStatus.isRunning ? 'Running' : 'Offline' %></p>
  <p>Agent Count: <%= agents.length %></p>
  
  <% if (agents && agents.length > 0) { %>
    <h2>Agents:</h2>
    <ul>
      <% agents.forEach(agent => { %>
        <li>
          <strong><%= agent.name %></strong> 
          (ID: <%= agent.agentId %>, Character: <%= agent.characterId %>)
        </li>
      <% }); %>
    </ul>
  <% } else { %>
    <p>No agents found.</p>
  <% } %>
  
  <h2>Characters:</h2>
  <ul>
    <% characters.forEach(character => { %>
      <li><%= character.char_name %> (ID: <%= character.id %>)</li>
    <% }); %>
  </ul>
</body>
</html>
