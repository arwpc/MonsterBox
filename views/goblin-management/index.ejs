                <!-- Network Status -->
                <div class="card mb-3">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <i class="bi bi-wifi"></i> Network Status
                        </h6>
                    </div>
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between mb-1">
                            <small>Last Update:</small>
                            <small id="lastUpdate">Never</small>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <small>Avg Response:</small>
                            <small id="avgResponse">0ms</small>
                        </div>
                        <div class="d-flex justify-content-between">
                            <small>Success Rate:</small>
                            <small id="successRate">0%</small>
                        </div>
                    </div>
                </div>

                <!-- Quick Deploy -->
                <div class="card mb-3">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <i class="bi bi-lightning"></i> Quick Deploy
                        </h6>
                    </div>
                    <div class="card-body">
                        <button class="btn btn-sm btn-outline-primary w-100 mb-2"
                            onclick="goblinManager.openVideoLibrary()">
                            <i class="bi bi-camera-video"></i> Video Library
                        </button>
                        <button class="btn btn-sm btn-outline-success w-100 mb-2"
                            onclick="goblinManager.testAllConnections()">
                            <i class="bi bi-wifi"></i> Test All
                        </button>
                        <button class="btn btn-sm btn-outline-info w-100" onclick="goblinManager.showSystemHealth()">
                            <i class="bi bi-heart-pulse"></i> System Health
                        </button>
                    </div>
                </div>

                <!-- Activity Log -->
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">
                            <i class="bi bi-list-ul"></i> Activity Log
