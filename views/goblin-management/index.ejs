                        <i class="bi bi-grid-3x3-gap"></i> Registered Goblins
                    </h5>
                    <div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" id="autoRefresh" checked>
                            <label class="form-check-label" for="autoRefresh">Auto Refresh</label>
                        </div>
                        <select class="form-select form-select-sm d-inline-block ms-2" style="width: auto;"
                            id="statusFilter">
                            <option value="all">All Status</option>
                            <option value="online">Online Only</option>
                            <option value="offline">Offline Only</option>
                            <option value="locked">Locked Only</option>
                        </select>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Goblin Cards -->
                    <div class="row g-3" id="goblinGrid">
                        <!-- Goblin cards will be populated here -->
                    </div>

                    <!-- Empty State -->
                    <div id="emptyState" style="display: none;" class="text-center py-5">
                        <i class="bi bi-cpu text-muted" style="font-size: 4rem;"></i>
                        <h3 class="text-muted mt-3">No Goblins Registered</h3>
                        <p class="text-muted">Register your first MonsterBox Goblin to get started!</p>
                        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#registerGoblinModal">
                            <i class="bi bi-plus-circle"></i> Register First Goblin
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions & Log -->
