                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

<!-- Register Goblin Modal -->
<div class="modal fade" id="registerGoblinModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle"></i> Register New Goblin
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="registerGoblinForm">
                    <div class="mb-3">
                        <label class="form-label">Goblin Name *</label>
                        <input type="text" class="form-control" name="name" required
                            placeholder="e.g., living-room-goblin, porch-display">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">IP Address or Hostname *</label>
                        <input type="text" class="form-control" name="host" required
                            placeholder="e.g., 192.168.1.100 or goblin1.local">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Port</label>
                        <input type="number" class="form-control" name="port" value="3001" min="1" max="65535">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Capabilities</label>
                        <div class="row">
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="capabilities"
                                        value="video-playback" id="cap1" checked>
                                    <label class="form-check-label" for="cap1">Video Playback</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="capabilities"
                                        value="audio-playback" id="cap2" checked>
                                    <label class="form-check-label" for="cap2">Audio Playback</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="capabilities"
                                        value="screen-effects" id="cap3">
                                    <label class="form-check-label" for="cap3">Screen Effects</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="capabilities"
                                        value="hardware-control" id="cap4">
                                    <label class="form-check-label" for="cap4">Hardware Control</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <input type="text" class="form-control" name="location"
                            placeholder="e.g., Living Room, Front Porch, Basement">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="description" rows="2"
                            placeholder="Optional description of this Goblin's purpose"></textarea>
                    </div>

                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="testConnection" id="testConnection"
                            checked>
                        <label class="form-check-label" for="testConnection">
                            Test connection before registering
                        </label>
                    </div>

                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="autoDeploy" id="autoDeploy">
                        <label class="form-check-label" for="autoDeploy">
                            👽 <strong>FACEHUGGER MODE</strong> - Auto-deploy if not responding
                        </label>
                        <small class="form-text text-muted d-block">
                            Automatically deploy Goblin system via SSH if the host is not responding
                        </small>
                    </div>

                    <div id="sshPasswordGroup" class="mb-3" style="display: none;">
                        <label class="form-label">SSH Password *</label>
                        <input type="password" class="form-control" name="sshPassword" id="sshPassword"
                            placeholder="Enter SSH password for deployment">
                        <small class="form-text text-muted">
                            Required for facehugger deployment (default: klrklr89!)
                        </small>
                    </div>
                </form>

                <div class="alert alert-info mt-3" id="registrationStatus" style="display: none;">
                    <i class="bi bi-info-circle"></i> <span id="statusMessage">Testing connection...</span>
                </div>

                <!-- Facehugger Progress -->
                <div id="facehuggerProgress" class="mt-3" style="display: none;">
                    <div class="card bg-dark border-success">
                        <div class="card-body">
                            <h6 class="card-title text-success">
                                <i class="bi bi-broadcast-pin"></i> 👽 FACEHUGGER DEPLOYMENT IN PROGRESS
                            </h6>
                            <div class="progress mb-2" style="height: 25px;">
                                <div id="facehuggerProgressBar"
                                    class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                                    role="progressbar" style="width: 0%">0%</div>
                            </div>
                            <div id="facehuggerStatus" class="text-light small">
                                Initializing...
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"
                    title="Close without registering">Cancel</button>
                <button type="button" class="btn btn-success" id="registerBtn" onclick="goblinManager.registerGoblin()"
                    title="Register this Goblin and optionally deploy via Facehugger">
                    <i class="bi bi-plus-circle"></i> Register Goblin
                </button>
            </div>
        </div>
    </div>
</div>

