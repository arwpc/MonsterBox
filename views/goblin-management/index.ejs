<!-- Video Queue Modal -->
<div class="modal fade" id="videoQueueModal" tabindex="-1">
    <div class="modal-dialog" style="max-width: 95%; width: 95%;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-film"></i> Video Queue Manager
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <!-- Queue Status and Controls -->
                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h6 class="mb-0">Queue Status</h6>
                                <button class="btn btn-sm btn-outline-secondary" onclick="goblinManager.refreshQueue()"
                                    title="Refresh queue status from Goblin">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                            </div>
                            <div class="card-body">
                                <div id="queueStatus"></div>
                            </div>
                        </div>

                        <div class="card mb-3">
                            <div class="card-header">
                                <h6 class="mb-0">Queue Controls</h6>
                            </div>
                            <div class="card-body">
                                <div class="d-grid gap-2">
                                    <button class="btn btn-success" onclick="goblinManager.startQueue('sequential')"
                                        title="Play all videos in queue once, then stop">
                                        <i class="bi bi-play-fill"></i> Start Sequential
                                    </button>
                                    <button class="btn btn-success" onclick="goblinManager.startQueue('loop')"
                                        title="Play all videos in queue continuously in a loop">
                                        <i class="bi bi-arrow-repeat"></i> Start Loop
                                    </button>
                                    <div class="btn-group">
                                        <button class="btn btn-warning" onclick="goblinManager.pauseQueue()"
                                            title="Pause queue playback (can be resumed)">
                                            <i class="bi bi-pause-fill"></i> Pause
                                        </button>
                                        <button class="btn btn-info" onclick="goblinManager.resumeQueue()"
                                            title="Resume paused queue playback">
                                            <i class="bi bi-play-fill"></i> Resume
                                        </button>
                                    </div>
                                    <button class="btn btn-outline-primary" onclick="goblinManager.skipVideo()"
                                        title="Skip to the next video in queue">
                                        <i class="bi bi-skip-forward-fill"></i> Skip
                                    </button>
                                    <button class="btn btn-outline-danger" onclick="goblinManager.stopQueue()"
                                        title="Stop queue playback completely">
                                        <i class="bi bi-stop-fill"></i> Stop
                                    </button>
                                    <button class="btn btn-outline-secondary" onclick="goblinManager.clearQueue()"
                                        title="Remove all videos from the queue">
                                        <i class="bi bi-trash"></i> Clear Queue
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header">
                                <h6 class="mb-0">Current Queue</h6>
                            </div>
                            <div class="card-body p-0">
                                <div class="list-group list-group-flush" id="videoQueueList"
                                    style="max-height: 300px; overflow-y: auto;">
                                    <div class="text-muted text-center py-3">Loading...</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Available Videos -->
                    <div class="col-md-6">
                        <!-- Currently Playing -->
                        <div class="card mb-3" id="currentlyPlayingCard">
                            <div class="card-header text-white" id="currentlyPlayingHeader">
                                <h6 class="mb-0"><i class="bi bi-play-circle-fill"></i> Playback Status</h6>
                            </div>
                            <div class="card-body">
                                <div id="currentlyPlayingContent">
                                    <div class="text-center text-muted py-3">
                                        <div class="spinner-border spinner-border-sm" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <p class="mb-0 mt-2">Loading status...</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header">
                                <h6 class="mb-0">Available Videos</h6>
                            </div>
                            <div class="card-body p-0">
                                <div class="list-group list-group-flush" id="availableVideosList"
                                    style="max-height: 600px; overflow-y: auto;">
                                    <div class="text-muted text-center py-3">Loading...</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"
                    title="Close video queue manager">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Broadcast Command Modal -->
<div class="modal fade" id="broadcastModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-broadcast"></i> Broadcast Command
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="broadcastForm">
                    <div class="mb-3">
                        <label class="form-label">Command</label>
                        <select class="form-select" name="command" id="broadcastCommand">
                            <option value="stop-all">Stop All Playback</option>
                            <option value="test-video">Test Video Playback</option>
                            <option value="health">Health Check</option>
                            <option value="restart-service">Restart Service</option>
                            <option value="clear-cache">Clear Cache</option>
                            <option value="custom">Custom Command</option>
                        </select>
                    </div>

                    <div class="mb-3" id="customCommandGroup" style="display: none;">
                        <label class="form-label">Custom Command</label>
                        <input type="text" class="form-control" name="customCommand"
                            placeholder="Enter custom endpoint">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Data (JSON)</label>
                        <textarea class="form-control" name="data" rows="3" placeholder='{"key": "value"}'></textarea>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="onlineOnly" id="onlineOnly" checked>
                        <label class="form-check-label" for="onlineOnly">
                            Send to online Goblins only
                        </label>
                    </div>
                </form>

                <div class="mt-3" id="broadcastResults" style="display: none;">
                    <h6>Results:</h6>
                    <div id="broadcastResultsList"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"
                    title="Cancel broadcast">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="goblinManager.executeBroadcast()"
                    title="Send this command to selected Goblins">
                    <i class="bi bi-broadcast"></i> Send Command
                </button>
            </div>
        </div>
    </div>
</div>

<script src="/js/goblin-management.js?v=5.3.3"></script>
<script>
    // Handle facehugger checkbox toggle
    document.getElementById('autoDeploy').addEventListener('change', function () {
        const sshPasswordGroup = document.getElementById('sshPasswordGroup');
        if (this.checked) {
            sshPasswordGroup.style.display = 'block';
            document.getElementById('sshPassword').required = true;
        } else {
            sshPasswordGroup.style.display = 'none';
            document.getElementById('sshPassword').required = false;
        }
    });
</script>