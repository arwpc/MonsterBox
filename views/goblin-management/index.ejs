                        <button class="btn btn-sm btn-outline-secondary" onclick="goblinManager.clearLog()">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="mb-terminal-log" id="activityLog">
