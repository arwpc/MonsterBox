            <header class="mb-page-header">
                <h1 class="mb-page-header-title">
                    <i class="bi bi-film"></i> Video Library
                    <span class="mb-text-secondary">· manage Goblin video assets</span>
                </h1>
            </header>

            <!-- Toolbar -->
            <div class="row mb-2">
                <div class="col">
                    <div class="d-flex justify-content-end align-items-center flex-wrap gap-2">
                        <div>
                            <div class="btn-group me-2 mb-view-toggle" role="group" aria-label="View toggle">
                                <button class="btn btn-primary btn-sm" id="viewGrid" onclick="videoLibrary.setView('grid')" data-bs-toggle="tooltip" data-bs-placement="top" title="Switch to card grid view">
                                    <i class="bi bi-grid-3x3-gap"></i>
                                </button>
                                <button class="btn btn-outline-secondary btn-sm" id="viewList" onclick="videoLibrary.setView('list')" data-bs-toggle="tooltip" data-bs-placement="top" title="Switch to list view">
                                    <i class="bi bi-list-ul"></i>
                                </button>
                            </div>
                            <div class="btn-group me-2" role="group">
                                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal" title="Upload new video files">
                                    <i class="bi bi-cloud-upload"></i> Upload Videos
                                </button>
                                <button class="btn btn-outline-secondary" id="bulkSelectBtn"
                                    onclick="videoLibrary.toggleBulkSelect()"
                                    data-bs-toggle="tooltip" data-bs-placement="top" title="Select multiple videos for bulk actions">
                                    <i class="bi bi-check-square"></i> Bulk Select
                                </button>
                                <button class="btn btn-outline-info" data-bs-toggle="modal"
                                    data-bs-target="#goblinDeployModal"
                                    title="Deploy videos to Goblin display devices">
                                    <i class="bi bi-broadcast"></i> Deploy to Goblins
                                </button>
                            </div>
                            <div class="bulk-actions mt-2" id="bulkActions" style="display: none;">
                                <div class="btn-group" role="group">
                                    <button class="btn btn-sm btn-outline-success"
                                        onclick="videoLibrary.bulkFavorite(true)"
                                        data-bs-toggle="tooltip" data-bs-placement="top" title="Mark selected videos as favorites">
                                        <i class="bi bi-heart"></i> Favorite
                                    </button>
                                    <button class="btn btn-sm btn-outline-warning"
                                        onclick="videoLibrary.bulkFavorite(false)"
                                        data-bs-toggle="tooltip" data-bs-placement="top" title="Remove favorite status from selected videos">
                                        <i class="bi bi-heart"></i> Unfavorite
                                    </button>
                                    <button class="btn btn-sm btn-outline-info"
                                        onclick="videoLibrary.bulkChangeCategory()"
                                        data-bs-toggle="tooltip" data-bs-placement="top" title="Change category for selected videos">
                                        <i class="bi bi-tags"></i> Change Category
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="videoLibrary.bulkDelete()"
                                        data-bs-toggle="tooltip" data-bs-placement="top" title="Delete all selected videos">
                                        <i class="bi bi-trash"></i> Delete Selected
                                    </button>
                                </div>
                                <small class="text-muted ms-2">
                                    <span id="selectedCount">0</span> selected
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Row -->
            <div class="row mb-2">
                <div class="col-md-3">
                    <div class="card bg-primary">
                        <div class="card-body text-center">
                            <i class="bi bi-camera-video fs-1"></i>
                            <h3 class="mt-2 mb-0" id="totalFiles">0</h3>
                            <small>Total Videos</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success">
                        <div class="card-body text-center">
                            <i class="bi bi-hdd fs-1"></i>
                            <h3 class="mt-2 mb-0" id="totalSize">0 MB</h3>
                            <small>Total Size</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-info">
                        <div class="card-body text-center">
                            <i class="bi bi-tags fs-1"></i>
                            <h3 class="mt-2 mb-0" id="totalCategories">0</h3>
                            <small>Categories</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-warning">
                        <div class="card-body text-center">
                            <i class="bi bi-cpu fs-1"></i>
                            <h3 class="mt-2 mb-0" id="totalGoblins">0</h3>
                            <small>Online Goblins</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="row">
                <!-- Video Player (Center) -->
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="bi bi-play-circle"></i> Video Preview
                            </h5>
                            <div id="videoPlayerControls" style="display: none;">
                                <button class="btn btn-sm btn-outline-primary"
                                    onclick="videoLibrary.toggleFullscreen()"
                                    data-bs-toggle="tooltip" data-bs-placement="top" title="Toggle fullscreen video preview">
                                    <i class="bi bi-fullscreen"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-success"
                                    onclick="videoLibrary.deployCurrentVideo()"
                                    data-bs-toggle="tooltip" data-bs-placement="top" title="Deploy current video to Goblin devices">
                                    <i class="bi bi-broadcast"></i> Deploy
                                </button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="main-video-player" id="mainVideoPlayer">
                                <div class="player-placeholder">
                                    <i class="bi bi-camera-video" style="font-size: 4rem;"></i>
                                    <h4 class="mt-3">Select a video to preview</h4>
                                    <p class="text-muted">Click any video from the library to start playing</p>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer" id="videoPlayerInfo" style="display: none;">
                            <div class="row">
                                <div class="col-md-8">
                                    <h6 class="mb-1" id="currentVideoTitle">Video Title</h6>
                                    <small class="text-muted" id="currentVideoInfo">Format • Duration • Size</small>
                                </div>
                                <div class="col-md-4 text-end">
                                    <div id="currentVideoTags"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Video Library Grid -->
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="bi bi-collection-play"></i> Video Library
                            </h5>
                        </div>
                        <div class="card-body p-2">
                            <!-- Search and Filters -->
                            <div class="mb-3">
                                <div class="input-group mb-2">
                                    <span class="input-group-text">
                                        <i class="bi bi-search"></i>
                                    </span>
                                    <input type="text" class="form-control form-control-sm" id="searchInput"
                                        placeholder="Search videos..."
                                        data-bs-toggle="tooltip" data-bs-placement="top" title="Search videos by name or tag">
                                </div>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <select class="form-select form-select-sm" id="categoryFilter"
                                            data-bs-toggle="tooltip" data-bs-placement="top" title="Filter videos by category">
                                            <option value="all">All Categories</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <select class="form-select form-select-sm" id="sortBy"
                                            data-bs-toggle="tooltip" data-bs-placement="top" title="Sort video list order">
                                            <option value="uploadedAt">Newest</option>
                                            <option value="title">Title A-Z</option>
                                            <option value="duration">Duration</option>
                                            <option value="fileSize">File Size</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Video Grid -->
                            <div class="video-grid-container">
                                <div class="row g-2" id="videoGrid">
                                    <!-- Video cards will be populated here -->
                                </div>

                                <!-- Video List View -->
                                <div id="videoListContainer" style="display: none;">
                                    <table class="table table-hover table-sm mb-list-table mb-0" id="videoListTable">
                                        <thead>
                                            <tr>
                                                <th style="width:28px;" class="bulk-col-header"></th>
                                                <th style="width:28px;" data-sort="favorite"><i class="bi bi-heart"></i></th>
                                                <th data-sort="title">Title <span class="sort-icon"></span></th>
                                                <th data-sort="format" style="width:45px;">Fmt <span class="sort-icon"></span></th>
                                                <th data-sort="duration" style="width:55px;">Dur <span class="sort-icon"></span></th>
                                                <th data-sort="fileSize" style="width:55px;">Size <span class="sort-icon"></span></th>
                                                <th style="width:60px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody id="videoListBody">
                                        </tbody>
                                    </table>
                                </div>

                                <!-- Empty State -->
                                <div id="emptyState" style="display: none;" class="text-center py-4">
                                    <i class="bi bi-camera-video text-muted" style="font-size: 3rem;"></i>
                                    <h6 class="text-muted mt-2">No Videos Found</h6>
                                    <button class="btn btn-sm btn-primary" data-bs-toggle="modal"
                                        data-bs-target="#uploadModal"
                                        title="Upload new video files">
                                        <i class="bi bi-cloud-upload"></i> Upload Videos
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Goblin Status Bar (if any online) -->
            <div class="row mt-4" id="goblinStatusBar" style="display: none;">
                <div class="col">
                    <div class="card">
                        <div class="card-body py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="text-muted">Active Goblins:</small>
                                    <span id="goblinStatusList"></span>
                                </div>
                                <div>
                                    <button class="btn btn-sm btn-outline-success"
                                        onclick="videoLibrary.showGoblinManager()"
                                        data-bs-toggle="tooltip" data-bs-placement="top" title="Configure and manage Goblin display devices">
                                        <i class="bi bi-gear"></i> Manage Goblins
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <!-- Upload Modal -->
        <div class="modal fade" id="uploadModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-cloud-upload"></i> Upload Video Files
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" title="Close"></button>
                    </div>
                    <div class="modal-body">
                        <!-- Drag and Drop Zone -->
                        <div class="mb-drop-zone mb-4" id="dragDropZone">
                            <i class="bi bi-camera-video fs-1 text-muted"></i>
                            <h4 class="mt-3">Drag & Drop Video Files Here</h4>
                            <p class="text-muted">Supports MP4, WebM, AVI, MOV files up to 500MB</p>
                            <input type="file" id="videoFileInput" multiple accept="video/*" style="display: none;">
                            <button type="button" class="btn btn-outline-primary"
                                onclick="document.getElementById('videoFileInput').click()"
                                data-bs-toggle="tooltip" data-bs-placement="top" title="Browse local files for upload">
                                <i class="bi bi-folder2-open"></i> Browse Files
                            </button>
                        </div>

                        <!-- Upload Form -->
                        <form id="uploadForm">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Category</label>
                                    <select class="form-select" name="category" id="uploadCategory" title="Select a category">
                                        <option value="general">General</option>
                                        <option value="halloween">Halloween</option>
                                        <option value="christmas">Christmas</option>
                                        <option value="animations">Animations</option>
                                        <option value="backgrounds">Backgrounds</option>
                                        <option value="effects">Effects</option>
                                        <option value="other">Other</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Tags (comma separated)</label>
                                    <input type="text" class="form-control" name="tags" title="Comma-separated tags"
                                        placeholder="spooky, halloween, animation">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Description</label>
                                    <textarea class="form-control" name="description" rows="2" title="Optional description"
                                        placeholder="Optional description for the video files"></textarea>
                                </div>
                            </div>
                        </form>

                        <!-- Upload Progress -->
                        <div class="upload-progress mt-3">
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                            </div>
                            <div class="mt-2">
                                <small class="text-muted" id="uploadStatus">Preparing upload...</small>
                            </div>
                        </div>

                        <!-- Selected Files List -->
                        <div id="selectedFilesList" class="mt-3" style="display: none;">
                            <h6>Selected Files:</h6>
                            <div id="filesList"></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" title="Cancel and close">Cancel</button>
                        <button type="button" class="btn btn-primary" id="uploadBtn" disabled
                            data-bs-toggle="tooltip" data-bs-placement="top" title="Start uploading selected video files">
                            <i class="bi bi-cloud-upload"></i> Upload Videos
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Goblin Deploy Modal -->
        <div class="modal fade" id="goblinDeployModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-broadcast"></i> Deploy to Goblins
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" title="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <!-- Available Videos -->
                            <div class="col-md-6">
                                <h6>Select Videos to Deploy:</h6>
                                <div class="border rounded p-2" style="max-height: 300px; overflow-y: auto;"
                                    id="deployVideoList">
                                    <!-- Video selection list -->
                                </div>
                            </div>
                            <!-- Available Goblins -->
                            <div class="col-md-6">
                                <h6>Select Target Goblins:</h6>
                                <div class="border rounded p-2" style="max-height: 300px; overflow-y: auto;"
                                    id="deployGoblinList">
                                    <!-- Goblin selection list -->
                                </div>
                            </div>
                        </div>

                        <!-- Deployment Progress -->
                        <div class="rounded p-2 mt-3" style="background: rgba(var(--bs-primary-rgb), 0.1); border: 1px solid var(--bs-primary);" id="deploymentProgress" style="display: none;">
                            <h6>Deployment Progress:</h6>
                            <div id="deploymentStatus"></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" title="Cancel and close">Cancel</button>
                        <button type="button" class="btn btn-success" id="deployBtn"
                            onclick="videoLibrary.executeDeployment()"
                            data-bs-toggle="tooltip" data-bs-placement="top" title="Deploy selected videos to chosen Goblins">
                            <i class="bi bi-broadcast"></i> Deploy Selected
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script src="/js/video-library.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var tooltipEls = document.querySelectorAll('[data-bs-toggle="tooltip"]');
                for (var i = 0; i < tooltipEls.length; i++) {
                    new bootstrap.Tooltip(tooltipEls[i]);
                }
                // Initialize tooltips on modal-trigger buttons that use title but cannot use data-bs-toggle="tooltip"
                var modalBtns = document.querySelectorAll('[data-bs-toggle="modal"][title]');
                for (var j = 0; j < modalBtns.length; j++) {
                    new bootstrap.Tooltip(modalBtns[j]);
                }
            });
        </script>
