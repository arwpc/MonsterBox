<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Dashboard - MonsterBox 4.0</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
    <!-- Unified Navigation - Same on ALL pages -->
    <%- include('../components/unified-navigation', { page: 'live' }) %>

    <main class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1><i class="bi bi-play-circle"></i> Live Dashboard</h1>
                    <div class="d-flex gap-2">
                        <span class="badge bg-success fs-6">Live Mode Active</span>
                        <button class="btn btn-outline-secondary" onclick="location.reload()">
                            <i class="bi bi-arrow-clockwise"></i> Refresh
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-person-arms-up"></i> Quick Poses</h5>
                    </div>
                    <div class="card-body">
                        <div id="posesContainer">
                            <div class="text-center text-muted py-4">
                                <i class="bi bi-hourglass-split fs-1"></i>
                                <p class="mt-2">Loading poses...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-activity"></i> System Status</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0"><i class="bi bi-person-circle fs-4 me-3"></i></div>
                            <div class="flex-grow-1">
                                <div class="fw-bold">Character</div>
                                <span class="badge bg-info" id="systemCharBadge">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            var liveDashboard = {
                poses: [],
                init: function () {
                    this.loadPoses();
                },
                loadPoses: function () {
                    var self = this;
                    fetch('/live/api/poses')
                        .then(function (r) { return r.json(); })
                        .then(function (data) { self.poses = data; self.renderPoses(); })
                        .catch(function () {
                            document.getElementById('posesContainer').innerHTML = '<div class="alert alert-danger">Failed to load poses</div>';
                        });

                },
                renderPoses: function () {
                    var container = document.getElementById('posesContainer');
                    if (!this.poses || this.poses.length === 0) {
                        container.innerHTML = '<div class="text-center text-muted py-4">No poses available</div>';
                        return;
                    }
                    var html = '<div class="row g-3">';
                    for (var i = 0; i < this.poses.length; i++) {
                        var pose = this.poses[i];
                        html += '<div class="col-md-6">';
                        html += '<button class="btn btn-outline-primary w-100" onclick="liveDashboard.executePose(this,' + pose.id + ')">';
                        html += '<i class="bi bi-play-fill"></i> ' + (pose.name || ('Pose ' + pose.id));
                        html += '</button>';
                        html += '</div>';
                    }
                    html += '</div>';
                    container.innerHTML = html;
                }
                ,
                executePose: function (btn, poseId) {
                    var statusBox = document.getElementById('posesStatus');
                    if (!statusBox) { var container = document.getElementById('posesContainer'); var div = document.createElement('div'); div.id = 'posesStatus'; container.parentNode.insertBefore(div, container); statusBox = div; }
                    var orig = btn.innerHTML; btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Running...';
                    fetch('/poses/' + poseId + '/execute', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' })
                        .then(function (r) { return r.json().catch(function () { return { success: false, error: 'Bad JSON' }; }); })
                        .then(function (j) {
                            if (j && j.success) {
                                statusBox.innerHTML = '<div class="alert alert-success py-2 mb-2">Pose executed</div>';
                            } else {
                                statusBox.innerHTML = '<div class="alert alert-danger py-2 mb-2">Failed: ' + ((j && j.error) || 'Unknown error') + '</div>';
                            }
                        })
                        .catch(function (e) { statusBox.innerHTML = '<div class="alert alert-danger py-2 mb-2">Error: ' + (e && e.message ? e.message : e) + '</div>'; })
                        .finally(function () { btn.disabled = false; btn.innerHTML = orig; setTimeout(function () { if (statusBox) { statusBox.innerHTML = ''; } }, 2000); });
                }
            };
            document.addEventListener('DOMContentLoaded', function () { liveDashboard.init(); });
        })();
    </script>
    <script src="/js/character-menu.js"></script>

</body>

</html>