<!-- Pose Editor - Position parts and save as a named Pose -->
<!-- Styles live in /public/css/animation.css (.part-card, .angle-display, .mb-page-header-sticky). -->

<div class="mb-cluster-animation">

  <div class="mb-page-header mb-page-header-sticky" role="toolbar" aria-label="Pose editor toolbar">
    <div class="mb-row-sm" style="align-items:center;">
      <a href="/scenes" class="mb-btn mb-btn-ghost mb-btn-sm mb-btn-icon" title="Back to Animation Studio"><i class="bi bi-arrow-left"></i></a>
      <h1 class="mb-page-header-title" style="font-size: var(--mb-text-xl); margin: 0;">
        <i class="bi bi-person-arms-up"></i> Pose Editor
      </h1>
      <span id="poseEditorStatus" class="mb-text-muted mb-text-sm"></span>
    </div>
    <div class="mb-page-header-actions">
      <button id="btnTestPose" class="mb-btn mb-btn-secondary mb-btn-sm" title="Test all parts simultaneously">
        <i class="bi bi-play-fill"></i> Test Pose
      </button>
      <button id="btnSavePose" class="mb-btn mb-btn-primary mb-btn-sm" title="Save current pose configuration">
        <i class="bi bi-save"></i> Save Pose
      </button>
      <button id="btnDeletePose" class="mb-btn mb-btn-danger mb-btn-sm d-none" title="Delete this pose">
        <i class="bi bi-trash"></i> Delete
      </button>
    </div>
  </div>

  <div class="container-fluid py-3">
    <div class="row g-3">

      <!-- LEFT: Pose Settings -->
      <div class="col-lg-4">
        <div class="mb-panel mb-panel-accent" style="margin-bottom: var(--mb-space-3);">
          <div class="mb-panel-header">
            <h2 class="mb-panel-title"><i class="bi bi-tag"></i> Pose Details</h2>
          </div>
          <div class="mb-panel-body">
            <div class="mb-field">
              <label for="poseName" class="mb-field-label">Name</label>
              <input type="text" id="poseName" class="mb-input" placeholder="e.g. Scare, Wave, Rest">
            </div>
            <div class="mb-field">
              <label for="poseCategory" class="mb-field-label">Category</label>
              <input type="text" id="poseCategory" class="mb-input" placeholder="e.g. attack, greeting, idle">
            </div>
            <div class="mb-field">
              <label for="poseDescription" class="mb-field-label">Description</label>
              <textarea id="poseDescription" class="mb-textarea" rows="2" placeholder="Optional description"></textarea>
            </div>
            <label class="mb-check">
              <input type="checkbox" id="poseConcurrent">
              Move all parts simultaneously
            </label>
          </div>
        </div>

        <!-- Optional Audio -->
        <div class="mb-panel" style="margin-bottom: var(--mb-space-3);">
          <div class="mb-panel-header">
            <h2 class="mb-panel-title"><i class="bi bi-music-note"></i> Optional Audio</h2>
          </div>
          <div class="mb-panel-body">
            <div class="mb-field">
              <label for="audioType" class="mb-field-label">Audio Type</label>
              <select id="audioType" class="mb-select">
                <option value="none">None</option>
                <option value="file">Sound File</option>
                <option value="tts">Text-to-Speech</option>
              </select>
            </div>
            <div id="audioFileSection" class="mb-field" style="display:none;">
              <label for="audioFile" class="mb-field-label">Sound File</label>
              <select id="audioFile" class="mb-select">
                <option value="">Select audio…</option>
              </select>
            </div>
            <div id="audioTtsSection" class="mb-field" style="display:none;">
              <label for="audioTtsText" class="mb-field-label">TTS Text</label>
              <input type="text" id="audioTtsText" class="mb-input" placeholder="What should the character say?">
            </div>
          </div>
        </div>

        <!-- Existing Poses List -->
        <div class="mb-panel">
          <div class="mb-panel-header">
            <h2 class="mb-panel-title"><i class="bi bi-list"></i> Saved Poses</h2>
            <button id="btnNewPose" class="mb-btn mb-btn-ghost mb-btn-sm mb-btn-icon" title="Clear form for new pose">
              <i class="bi bi-plus"></i>
            </button>
          </div>
          <div class="mb-panel-body" style="padding: 0;">
            <div id="posesList" style="max-height: 300px; overflow-y: auto; padding: var(--mb-space-3);">
              <div class="mb-text-muted mb-text-sm" style="text-align:center;">Loading…</div>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Hardware Parts -->
      <div class="col-lg-8">
        <div class="mb-panel mb-panel-accent-ai">
          <div class="mb-panel-header">
            <h2 class="mb-panel-title"><i class="bi bi-gear"></i> Hardware Parts</h2>
            <span id="partCount" class="mb-badge mb-badge-primary">0 parts</span>
          </div>
          <div class="mb-panel-body">
            <div id="partsContainer" class="mb-part-grid">
              <div class="mb-text-muted mb-text-sm" style="text-align:center; padding: var(--mb-space-6);">
                Loading hardware parts…
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Bootstrap data for the pose editor (EJS values extracted v8.1.1). -->
<script id="mbPoseEditorBoot" type="application/json">
{
  "editPoseId":  <%= typeof editPoseId !== 'undefined' && editPoseId ? editPoseId : 'null' %>,
  "characterId": <%= typeof currentCharacter !== 'undefined' && currentCharacter ? currentCharacter : 'null' %>
}
</script>
<script src="/js/poses-editor.js" defer></script>
