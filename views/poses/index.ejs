<div class="mb-cluster-animation">

  <header class="mb-page-header">
    <h1 class="mb-page-header-title" data-testid="page-heading">
      <i class="bi bi-arrows-move"></i> Poses
      <span class="mb-text-secondary">· saved motion sequences</span>
    </h1>
    <div class="mb-page-header-actions">
      <a class="mb-btn mb-btn-secondary" href="/setup/calibration" title="Open servo calibration">
        <i class="bi bi-gear"></i> Calibration
      </a>
      <a class="mb-btn mb-btn-primary" href="/poses/editor" title="Create a new pose">
        <i class="bi bi-plus-circle"></i> New Pose
      </a>
    </div>
  </header>

  <div class="mb-split-7-5">
    <div class="mb-panel mb-panel-accent" id="poses-summary-card">
      <div class="mb-panel-header">
        <h2 class="mb-panel-title"><i class="bi bi-list-ul"></i> Available Poses</h2>
        <span class="mb-badge mb-badge-primary" id="poses-count" data-testid="poses-count">--</span>
      </div>
      <div class="mb-panel-body">
        <div id="poses-status" class="mb-text-secondary mb-text-sm" data-testid="poses-status" style="margin-bottom: var(--mb-space-3);">
          Loading poses…
        </div>
        <ul class="list-group" id="poses-list" data-testid="poses-list" style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap: var(--mb-space-2);"></ul>
      </div>
    </div>

    <div class="mb-panel" id="poses-actions-card">
      <div class="mb-panel-header">
        <h2 class="mb-panel-title"><i class="bi bi-sliders"></i> Quick Actions</h2>
      </div>
      <div class="mb-panel-body">
        <p class="mb-text-secondary mb-text-sm" style="margin-top:0;">
          Jump into the editor to adjust servo ranges, tweak timing, or stage a new pose for a seasonal show.
        </p>
        <div class="mb-stack" style="gap: var(--mb-space-2);">
          <a class="mb-btn mb-btn-primary mb-btn-block" href="/poses/editor" title="Create or edit poses">
            <i class="bi bi-plus-circle"></i> Create or Edit Poses
          </a>
          <a class="mb-btn mb-btn-secondary mb-btn-block" href="/setup/calibration" title="Adjust servo configuration">
            <i class="bi bi-gear"></i> Adjust Servo Configuration
          </a>
          <a class="mb-btn mb-btn-ghost mb-btn-block" href="/scenes" title="Go to Animation Studio">
            <i class="bi bi-film"></i> Animation Studio
          </a>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
    (function () {
        const API_URL = '/poses?format=json';
        const listEl = document.getElementById('poses-list');
        const statusEl = document.getElementById('poses-status');
        const countEl = document.getElementById('poses-count');

        async function loadPoses() {
            try {
                const response = await fetch(API_URL, { headers: { 'Accept': 'application/json' } });
                const data = await response.json();
                if (!data || data.success !== true || !Array.isArray(data.poses)) {
                    showError('Failed to load poses list.');
                    return;
                }
                renderPoses(data.poses);
            } catch (error) {
                console.error('Failed to load poses page data:', error);
                showError('Unable to load poses. Please check your connection.');
            }
        }

        function renderPoses(poses) {
            const count = poses.length || 0;
            countEl.textContent = String(count);
            if (count === 0) {
                statusEl.textContent = 'No poses configured yet for this character.';
                listEl.innerHTML = `
                    <li class="mb-empty">
                      <i class="bi bi-person-arms-up mb-empty-icon"></i>
                      <h3 class="mb-empty-title">No poses yet</h3>
                      <p class="mb-empty-body">Create your first pose to see it here.</p>
                      <a class="mb-btn mb-btn-primary" href="/poses/editor" title="Create a new pose"><i class="bi bi-plus-circle"></i> Create Pose</a>
                    </li>`;
                return;
            }
            statusEl.textContent = 'Tap a pose to simulate the motion sequence on the selected character.';
            listEl.innerHTML = poses.map(pose => `
              <li class="mb-list-item">
                <div class="mb-list-item-body">
                  <div class="mb-list-item-title">${escapeHtml(pose.name || ('Pose ' + pose.id))}</div>
                  <div class="mb-list-item-meta">${escapeHtml(pose.description || 'No description')}</div>
                </div>
                <div class="mb-list-item-actions">
                  <a class="mb-btn mb-btn-ghost mb-btn-sm mb-btn-icon" href="/poses/editor/${pose.id}" title="Edit"><i class="bi bi-pencil"></i></a>
                  <button class="mb-btn mb-btn-primary mb-btn-sm mb-btn-icon" data-pose-id="${pose.id}" title="Play">
                    <i class="bi bi-play"></i>
                  </button>
                </div>
              </li>
            `).join('');

            listEl.querySelectorAll('button[data-pose-id]').forEach(btn => {
                btn.addEventListener('click', () => executePose(btn));
            });
        }

        function showError(message) {
            countEl.textContent = '--';
            statusEl.textContent = message;
            listEl.innerHTML = '';
        }

        async function executePose(button) {
            const poseId = button.getAttribute('data-pose-id');
            if (!poseId) return;
            button.disabled = true;
            const original = button.innerHTML;
            button.innerHTML = '<span class="mb-spinner"></span>';
            try {
                const response = await fetch(`/poses/${poseId}/execute`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                    body: JSON.stringify({ fromPage: 'poses-dashboard' })
                });
                if (!response.ok) {
                    throw new Error('Pose execute request failed');
                }
                const payload = await response.json();
                if (!payload || payload.success !== true) {
                    console.warn('Pose execution returned non-success payload:', payload);
                }
            } catch (error) {
                console.error('Failed to execute pose from poses page:', error);
            } finally {
                button.disabled = false;
                button.innerHTML = original;
            }
        }

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        document.addEventListener('DOMContentLoaded', loadPoses);
    })();
</script>
