<div class="row">
  <div class="col-12">
    <h1 class="mb-3" data-testid="page-heading"><i class="bi bi-arrows-move"></i> Poses</h1>
    <p class="text-muted mb-4">Review, trigger, and manage saved poses for the currently selected animatronic.</p>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-7">
    <div class="card" id="poses-summary-card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0"><i class="bi bi-list-ul"></i> Available Poses</h2>
        <span class="badge bg-secondary" id="poses-count" data-testid="poses-count">--</span>
      </div>
      <div class="card-body">
        <div id="poses-status" class="mb-3 text-muted" data-testid="poses-status">Loading poses...</div>
        <ul class="list-group" id="poses-list" data-testid="poses-list"></ul>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card" id="poses-actions-card">
      <div class="card-header">
        <h2 class="h5 mb-0"><i class="bi bi-sliders"></i> Quick Actions</h2>
      </div>
      <div class="card-body">
        <p class="text-muted small">Jump into the setup workflow to edit servo ranges, tweak timing, or create new poses for seasonal shows.</p>
        <div class="d-grid gap-2">
          <a class="btn btn-primary" href="/setup/poses"><i class="bi bi-plus-circle"></i> Create or Edit Poses</a>
          <a class="btn btn-outline-secondary" href="/setup/parts"><i class="bi bi-gear"></i> Adjust Servo Configuration</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const API_URL = '/poses?format=json';
    const listEl = document.getElementById('poses-list');
    const statusEl = document.getElementById('poses-status');
    const countEl = document.getElementById('poses-count');

    async function loadPoses() {
      try {
        const response = await fetch(API_URL, { headers: { 'Accept': 'application/json' } });
        const data = await response.json();
        if (!data || data.success !== true || !Array.isArray(data.poses)) {
          showError('Failed to load poses list.');
          return;
        }
        renderPoses(data.poses);
      } catch (error) {
        console.error('Failed to load poses page data:', error);
        showError('Unable to load poses. Please check your connection.');
      }
    }

    function renderPoses(poses) {
      const count = poses.length || 0;
      countEl.textContent = String(count);
      if (count === 0) {
        statusEl.textContent = 'No poses configured yet for this character.';
        listEl.innerHTML = '<li class="list-group-item text-muted">Create your first pose to see it here.</li>';
        return;
      }
      statusEl.textContent = 'Tap a pose to simulate the motion sequence on the selected character.';
      listEl.innerHTML = poses.map(pose => `
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <div>
            <div class="fw-semibold">${escapeHtml(pose.name || ('Pose ' + pose.id))}</div>
            <small class="text-muted">${escapeHtml(pose.description || 'No description')}</small>
          </div>
          <button class="btn btn-sm btn-outline-primary" data-pose-id="${pose.id}">
            <i class="bi bi-play"></i>
          </button>
        </li>
      `).join('');

      listEl.querySelectorAll('button[data-pose-id]').forEach(btn => {
        btn.addEventListener('click', () => executePose(btn));
      });
    }

    function showError(message) {
      countEl.textContent = '--';
      statusEl.textContent = message;
      listEl.innerHTML = '';
    }

    async function executePose(button) {
      const poseId = button.getAttribute('data-pose-id');
      if (!poseId) return;
      button.disabled = true;
      const original = button.innerHTML;
      button.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
      try {
        const response = await fetch(`/poses/${poseId}/execute`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ fromPage: 'poses-dashboard' })
        });
        if (!response.ok) {
          throw new Error('Pose execute request failed');
        }
        const payload = await response.json();
        if (!payload || payload.success !== true) {
          console.warn('Pose execution returned non-success payload:', payload);
        }
      } catch (error) {
        console.error('Failed to execute pose from poses page:', error);
      } finally {
        button.disabled = false;
        button.innerHTML = original;
      }
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    document.addEventListener('DOMContentLoaded', loadPoses);
  })();
</script>
