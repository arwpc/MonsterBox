<!DOCTYPE html>
<html lang="en" data-bs-theme="<%= config?.theme || 'dark' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <!-- Bootstrap 5 CSS - Local with CDN fallback -->
    <link href="/vendor/bootstrap/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link href="/css/monsterbox4.css" rel="stylesheet">

    <!-- Page-specific CSS -->
    <% if (typeof styles !=='undefined' && styles) { %>
        <% if (Array.isArray(styles)) { %>
            <% styles.forEach(function(style){ %>
                <link href="<%= style %>" rel="stylesheet">
                <% }); %>
                    <% } else { %>
                        <link href="<%= styles %>" rel="stylesheet">
                        <% } %>
                            <% } %>

                                <% if (typeof headExtras !=='undefined' && headExtras) { %>
                                    <%- headExtras %>
                                        <% } %>
</head>

<body>
    <!-- Navigation - Automatically included on ALL pages -->
    <%- include('../components/unified-navigation', { page: page || 'dashboard' , currentCharacter: currentCharacter,
        config: config }) %>

        <!-- Main Content -->
        <% if (typeof includeMainWrapper==='undefined' || includeMainWrapper !==false) { %>
            <main class="container-fluid py-4">
                <%- content %>
            </main>
            <% } else { %>
                <%- content %>
                    <% } %>

                        <!-- Footer -->
                        <%- include('../components/footer') %>

                            <!-- Bootstrap JS - Local with CDN fallback -->
                            <script src="/vendor/bootstrap/bootstrap.bundle.min.js"></script>
                            <script>
                                // CDN fallback if local Bootstrap fails
                                if (typeof bootstrap === 'undefined') {
                                    document.write('<scr' + 'ipt src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></scr' + 'ipt>');
                                }
                            </script>

                            <!-- Core MonsterBox JS -->
                            <script src="/js/monsterbox4.js"></script>
                            <script src="/js/character-menu.js"></script>

                            <!-- Page-specific scripts -->
                            <% if (typeof scripts !=='undefined' && scripts) { %>
                                <% if (Array.isArray(scripts)) { %>
                                    <% scripts.forEach(function(script){ %>
                                        <script src="<%= script %>"></script>
                                        <% }); %>
                                            <% } else { %>
                                                <script src="<%= scripts %>"></script>
                                                <% } %>
                                                    <% } %>

                                                        <% if (typeof bodyExtras !=='undefined' && bodyExtras) { %>
                                                            <%- bodyExtras %>
                                                                <% } %>
</body>

</html>