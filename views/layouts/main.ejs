<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'MonsterBox Control Panel' %></title>

    <!-- Preload critical fonts -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&family=Creepster&display=swap" as="style">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&family=Creepster&display=swap">

    <!-- MonsterBox CSS -->
    <link rel="stylesheet" href="/css/main.css?v=<%= Date.now() %>">

    <!-- Custom MonsterBox themes -->
    <link rel="stylesheet" href="/css/custom-themes.css?v=<%= Date.now() %>">
    
    <!-- Favicon and meta tags -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <meta name="description" content="MonsterBox - Advanced Animatronic Control System">
    <meta name="theme-color" content="#00ff00">
    
    <!-- Open Graph meta tags -->
    <meta property="og:title" content="<%= title || 'MonsterBox Control Panel' %>">
    <meta property="og:description" content="Advanced Animatronic Control System">
    <meta property="og:type" content="website">
    
    <!-- Additional head content -->
    <%- typeof additionalHead !== 'undefined' ? additionalHead : '' %>
</head>

<body style="min-height: 100vh; background-color: var(--base-100); color: var(--base-content); font-family: 'VT323', 'Courier New', monospace;" class="scrollbar-monsterbox">
    <!-- Skip to main content for accessibility -->
    <a href="#main-content" style="position: absolute; top: 16px; left: 16px; z-index: 50;" class="btn-monsterbox">
        Skip to main content
    </a>

    <!-- Navigation -->
    <nav style="background-color: var(--base-200); border-bottom: 1px solid var(--primary); box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); position: sticky; top: 0; z-index: 40;">
        <div class="container-monsterbox">
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 16px 0;">
                <!-- Mobile menu button -->
                <div class="nav-mobile">
                    <button style="background: none; border: none; color: var(--base-content); cursor: pointer; padding: 8px;" aria-label="Open menu" onclick="toggleMobileMenu()">
                        <svg style="width: 24px; height: 24px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                    <div id="mobile-menu" style="display: none; position: absolute; top: 100%; left: 0; background-color: var(--base-200); border: 1px solid var(--primary); border-radius: 8px; width: 208px; padding: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); z-index: 10;">
                        <%- include('../components/navigation-mobile') %>
                    </div>
                </div>

                <!-- Logo -->
                <a href="/" style="text-decoration: none; font-size: 1.25rem; font-family: 'Creepster', cursive; color: var(--primary); padding: 8px 16px; transition: color 0.3s ease;">
                    🎭 MonsterBox™
                </a>

                <!-- Desktop navigation -->
                <div class="nav-desktop">
                    <ul style="display: flex; list-style: none; margin: 0; padding: 0;">
                        <%- include('../components/navigation-desktop') %>
                    </ul>
                </div>

                <!-- User actions -->
                <div>
                    <!-- Theme selector -->
                    <div style="position: relative; display: inline-block;">
                        <button style="background: none; border: none; color: var(--base-content); cursor: pointer; padding: 8px; border-radius: 50%;" aria-label="Change theme" onclick="toggleThemeMenu()">
                            <svg style="width: 24px; height: 24px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                            </svg>
                        </button>
                        <div id="theme-menu" style="display: none; position: absolute; right: 0; top: 100%; background-color: var(--base-200); border: 1px solid var(--primary); border-radius: 8px; width: 208px; padding: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); z-index: 10;">
                            <a onclick="setTheme('monsterbox')" style="display: block; padding: 8px 12px; color: var(--base-content); text-decoration: none; cursor: pointer; border-radius: 4px; transition: background-color 0.3s ease;" onmouseover="this.style.backgroundColor='var(--primary)'; this.style.color='var(--primary-content)'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--base-content)'">🖥️ Terminal</a>
                            <a onclick="setTheme('monsterbox-halloween')" style="display: block; padding: 8px 12px; color: var(--base-content); text-decoration: none; cursor: pointer; border-radius: 4px; transition: background-color 0.3s ease;" onmouseover="this.style.backgroundColor='var(--primary)'; this.style.color='var(--primary-content)'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--base-content)'">🎃 Halloween</a>
                            <a onclick="setTheme('monsterbox-retro')" style="display: block; padding: 8px 12px; color: var(--base-content); text-decoration: none; cursor: pointer; border-radius: 4px; transition: background-color 0.3s ease;" onmouseover="this.style.backgroundColor='var(--primary)'; this.style.color='var(--primary-content)'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--base-content)'">👾 Retro</a>
                            <a onclick="setTheme('dracula')" style="display: block; padding: 8px 12px; color: var(--base-content); text-decoration: none; cursor: pointer; border-radius: 4px; transition: background-color 0.3s ease;" onmouseover="this.style.backgroundColor='var(--primary)'; this.style.color='var(--primary-content)'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--base-content)'">🧛 Dracula</a>
                            <a onclick="setTheme('dark')" style="display: block; padding: 8px 12px; color: var(--base-content); text-decoration: none; cursor: pointer; border-radius: 4px; transition: background-color 0.3s ease;" onmouseover="this.style.backgroundColor='var(--primary)'; this.style.color='var(--primary-content)'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--base-content)'">🌙 Dark</a>
                            <a onclick="setTheme('light')" style="display: block; padding: 8px 12px; color: var(--base-content); text-decoration: none; cursor: pointer; border-radius: 4px; transition: background-color 0.3s ease;" onmouseover="this.style.backgroundColor='var(--primary)'; this.style.color='var(--primary-content)'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--base-content)'">☀️ Light</a>
                        </div>
                    </div>

                    <!-- Settings -->
                    <a href="/configuration" style="background: none; border: none; color: var(--base-content); cursor: pointer; padding: 8px; border-radius: 50%; text-decoration: none; display: inline-block; margin-left: 8px;" aria-label="Settings">
                        <svg style="width: 24px; height: 24px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main content -->
    <main id="main-content" style="flex: 1; padding: 32px 0;" class="container-monsterbox">
        <!-- Breadcrumbs -->
        <% if (typeof breadcrumbs !== 'undefined' && breadcrumbs.length > 0) { %>
        <div style="font-size: 0.875rem; margin-bottom: 24px;">
            <ul style="display: flex; list-style: none; margin: 0; padding: 0; align-items: center;">
                <% breadcrumbs.forEach(function(crumb, index) { %>
                <li style="display: flex; align-items: center;">
                    <% if (index === breadcrumbs.length - 1) { %>
                        <span style="color: var(--primary);"><%= crumb.name %></span>
                    <% } else { %>
                        <a href="<%= crumb.url %>" style="color: var(--base-content); text-decoration: none; transition: color 0.3s ease;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--base-content)'"><%= crumb.name %></a>
                        <span style="margin: 0 8px; color: var(--base-content); opacity: 0.5;"> > </span>
                    <% } %>
                </li>
                <% }); %>
            </ul>
        </div>
        <% } %>

        <!-- Page title -->
        <% if (typeof pageTitle !== 'undefined') { %>
        <div style="margin-bottom: 32px;">
            <h1 style="font-size: 2.25rem; font-weight: bold; color: var(--primary); font-family: 'Creepster', cursive; margin-bottom: 8px;" class="glow-text">
                <%= pageTitle %>
            </h1>
            <% if (typeof pageDescription !== 'undefined') { %>
            <p style="color: var(--base-content); opacity: 0.7; font-size: 1.125rem;">
                <%= pageDescription %>
            </p>
            <% } %>
        </div>
        <% } %>

        <!-- Alert messages -->
        <% if (typeof messages !== 'undefined') { %>
            <% if (messages.success) { %>
            <div style="padding: 16px; border-radius: 8px; border-left: 4px solid var(--success); background-color: rgba(0, 255, 0, 0.1); margin-bottom: 24px; display: flex; align-items: center; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
                <svg style="width: 24px; height: 24px; margin-right: 12px; color: var(--success);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span style="color: var(--success);"><%= messages.success %></span>
            </div>
            <% } %>
            <% if (messages.error) { %>
            <div style="padding: 16px; border-radius: 8px; border-left: 4px solid var(--error); background-color: rgba(255, 0, 64, 0.1); margin-bottom: 24px; display: flex; align-items: center; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
                <svg style="width: 24px; height: 24px; margin-right: 12px; color: var(--error);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span style="color: var(--error);"><%= messages.error %></span>
            </div>
            <% } %>
            <% if (messages.warning) { %>
            <div style="padding: 16px; border-radius: 8px; border-left: 4px solid var(--warning); background-color: rgba(255, 128, 0, 0.1); margin-bottom: 24px; display: flex; align-items: center; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
                <svg style="width: 24px; height: 24px; margin-right: 12px; color: var(--warning);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                </svg>
                <span style="color: var(--warning);"><%= messages.warning %></span>
            </div>
            <% } %>
            <% if (messages.info) { %>
            <div style="padding: 16px; border-radius: 8px; border-left: 4px solid var(--info); background-color: rgba(0, 255, 255, 0.1); margin-bottom: 24px; display: flex; align-items: center; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
                <svg style="width: 24px; height: 24px; margin-right: 12px; color: var(--info);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span style="color: var(--info);"><%= messages.info %></span>
            </div>
            <% } %>
        <% } %>

        <!-- Page content -->
        <%- body %>
    </main>

    <!-- Footer -->
    <footer style="text-align: center; padding: 40px; background-color: var(--base-200); color: var(--base-content); border-top: 1px solid var(--primary);">
        <div>
            <div style="display: flex; justify-content: center; gap: 16px; margin-bottom: 16px;">
                <a href="https://github.com/arwpc/MonsterBox" target="_blank" style="background: none; border: none; color: var(--base-content); cursor: pointer; padding: 8px; border-radius: 50%; text-decoration: none; display: inline-block;" aria-label="GitHub">
                    <svg style="width: 24px; height: 24px;" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                </a>
            </div>
            <div>
                <p style="font-weight: bold; color: var(--primary); font-family: 'Creepster', cursive; margin: 8px 0;">MonsterBox™</p>
                <p style="margin: 8px 0;">An animatronic automation package by ARW Halloween 2024 2.0</p>
            </div>
        </div>
    </footer>

    <!-- Loading overlay -->
    <div id="loading-overlay" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0, 0, 0, 0.75); display: none; align-items: center; justify-content: center; z-index: 50;">
        <div style="text-align: center;">
            <div class="loading-spinner" style="margin: 0 auto 16px;"></div>
            <p style="color: var(--primary); font-family: 'VT323', 'Courier New', monospace;">Loading...</p>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        // Mobile menu toggle
        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }

        // Theme menu toggle
        function toggleThemeMenu() {
            const menu = document.getElementById('theme-menu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }

        // Close menus when clicking outside
        document.addEventListener('click', function(event) {
            const mobileMenu = document.getElementById('mobile-menu');
            const themeMenu = document.getElementById('theme-menu');

            if (!event.target.closest('[onclick="toggleMobileMenu()"]') && !event.target.closest('#mobile-menu')) {
                mobileMenu.style.display = 'none';
            }

            if (!event.target.closest('[onclick="toggleThemeMenu()"]') && !event.target.closest('#theme-menu')) {
                themeMenu.style.display = 'none';
            }
        });

        // Theme management
        function setTheme(theme) {
            // Since we removed DaisyUI, we'll just store the theme preference
            localStorage.setItem('monsterbox-theme', theme);
            console.log('Theme set to:', theme);
        }

        // Load saved theme
        const savedTheme = localStorage.getItem('monsterbox-theme') || 'monsterbox';
        setTheme(savedTheme);

        // Character selection management
        function updateCharacter(characterId) {
            localStorage.setItem('selectedCharacter', characterId);
            updateNavigation(characterId);
            
            fetch('/set-character', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ characterId: characterId }),
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    console.log('Character updated successfully');
                } else {
                    console.error('Failed to update character');
                }
            })
            .catch((error) => {
                console.error('Error:', error);
            });
        }

        // Navigation updates based on character selection
        function updateNavigation(characterId) {
            // Update navigation links with character context
            const navLinks = document.querySelectorAll('[data-character-link]');
            navLinks.forEach(link => {
                const baseUrl = link.getAttribute('data-character-link');
                if (characterId) {
                    link.href = `${baseUrl}?character=${characterId}`;
                } else {
                    link.href = baseUrl;
                }
            });
        }

        // Loading overlay management
        function showLoading() {
            document.getElementById('loading-overlay').style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loading-overlay').style.display = 'none';
        }

        // Initialize character selection on page load
        document.addEventListener('DOMContentLoaded', function() {
            const savedCharacter = localStorage.getItem('selectedCharacter');
            if (savedCharacter) {
                updateNavigation(savedCharacter);
                const characterSelect = document.getElementById('character-select');
                if (characterSelect) {
                    characterSelect.value = savedCharacter;
                }
            }
        });
    </script>

    <!-- Additional scripts -->
    <%- typeof additionalScripts !== 'undefined' ? additionalScripts : '' %>
</body>
</html>
