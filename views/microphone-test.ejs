<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎤 Microphone Testing Suite</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <h1>🎤 Microphone Testing Suite</h1>
    
    <div class="test-header">
        <div class="microphone-selector">
            <label for="microphoneSelect">Select Microphone:</label>
            <select id="microphoneSelect">
                <option value="">Choose a microphone...</option>
                <% microphones.forEach(function(microphone) { %>
                    <option value="<%= microphone.id %>" data-device="<%= microphone.deviceId %>">
                        <%= microphone.name %> (<%= microphone.deviceId %>)
                    </option>
                <% }); %>
            </select>
            <button id="refreshMicrophones" class="button small-btn">🔄 Refresh</button>
        </div>
        
        <div class="test-controls">
            <button id="startTest" class="button primary-btn" disabled>▶️ Start Test</button>
            <button id="stopTest" class="button secondary-btn" disabled>⏹️ Stop Test</button>
            <button id="calibrateBtn" class="button" disabled>🔧 Calibrate</button>
            <button id="exportResults" class="button" disabled>📊 Export Results</button>
        </div>
    </div>

    <div class="test-dashboard">
        <div class="test-panel">
            <h3>🎛️ Real-Time Controls</h3>
            
            <div class="control-group">
                <label for="testSensitivity">Sensitivity:</label>
                <input type="range" id="testSensitivity" min="0.1" max="3.0" step="0.1" value="1.0">
                <span id="testSensitivityValue">1.0</span>
            </div>
            
            <div class="control-group">
                <label for="testGain">Gain:</label>
                <input type="range" id="testGain" min="0" max="100" step="1" value="50">
                <span id="testGainValue">50</span>
            </div>
            
            <div class="control-group">
                <label for="testThreshold">Threshold:</label>
                <input type="range" id="testThreshold" min="0.01" max="1.0" step="0.01" value="0.1">
                <span id="testThresholdValue">0.1</span>
            </div>
            
            <div class="test-options">
                <label><input type="checkbox" id="enableEchoCancellation" checked> Echo Cancellation</label>
                <label><input type="checkbox" id="enableNoiseSuppression" checked> Noise Suppression</label>
                <label><input type="checkbox" id="enableAutoGain" checked> Auto Gain Control</label>
            </div>
        </div>

        <div class="visualization-panel">
            <h3>📊 Audio Visualization</h3>
            
            <div class="level-meters">
                <div class="meter-container">
                    <div class="meter-label">Input Level</div>
                    <div class="level-meter">
                        <div class="level-fill" id="inputLevel"></div>
                    </div>
                    <div class="meter-value" id="inputLevelValue">0 dB</div>
                </div>
                
                <div class="meter-container">
                    <div class="meter-label">Peak Level</div>
                    <div class="level-meter">
                        <div class="level-fill peak" id="peakLevel"></div>
                    </div>
                    <div class="meter-value" id="peakLevelValue">0 dB</div>
                </div>
            </div>
            
            <div class="frequency-analysis">
                <canvas id="frequencyChart" width="600" height="200"></canvas>
            </div>
            
            <div class="waveform-display">
                <canvas id="waveformChart" width="600" height="100"></canvas>
            </div>
        </div>
    </div>

    <div class="test-results-panel">
        <h3>🧪 Test Results</h3>
        
        <div class="test-tabs">
            <button class="tab-button active" data-tab="quality">Audio Quality</button>
            <button class="tab-button" data-tab="latency">Latency</button>
            <button class="tab-button" data-tab="frequency">Frequency Response</button>
            <button class="tab-button" data-tab="noise">Noise Analysis</button>
            <button class="tab-button" data-tab="stability">Stability</button>
        </div>
        
        <div class="tab-content">
            <div id="quality-tab" class="tab-panel active">
                <div class="metric-grid">
                    <div class="metric-card">
                        <div class="metric-label">Signal-to-Noise Ratio</div>
                        <div class="metric-value" id="snrValue">-- dB</div>
                        <div class="metric-status" id="snrStatus">Not tested</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Dynamic Range</div>
                        <div class="metric-value" id="dynamicRangeValue">-- dB</div>
                        <div class="metric-status" id="dynamicRangeStatus">Not tested</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">THD+N</div>
                        <div class="metric-value" id="thdValue">-- %</div>
                        <div class="metric-status" id="thdStatus">Not tested</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Overall Quality</div>
                        <div class="metric-value" id="qualityScore">--</div>
                        <div class="metric-status" id="qualityStatus">Not tested</div>
                    </div>
                </div>
            </div>
            
            <div id="latency-tab" class="tab-panel">
                <div class="metric-grid">
                    <div class="metric-card">
                        <div class="metric-label">Input Latency</div>
                        <div class="metric-value" id="inputLatencyValue">-- ms</div>
                        <div class="metric-status" id="inputLatencyStatus">Not tested</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Processing Latency</div>
                        <div class="metric-value" id="processingLatencyValue">-- ms</div>
                        <div class="metric-status" id="processingLatencyStatus">Not tested</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Total Latency</div>
                        <div class="metric-value" id="totalLatencyValue">-- ms</div>
                        <div class="metric-status" id="totalLatencyStatus">Not tested</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Jitter</div>
                        <div class="metric-value" id="jitterValue">-- ms</div>
                        <div class="metric-status" id="jitterStatus">Not tested</div>
                    </div>
                </div>
                <div class="latency-chart">
                    <canvas id="latencyChart" width="600" height="300"></canvas>
                </div>
            </div>
            
            <div id="frequency-tab" class="tab-panel">
                <div class="frequency-response-chart">
                    <canvas id="frequencyResponseChart" width="600" height="400"></canvas>
                </div>
                <div class="frequency-metrics">
                    <div class="metric-card">
                        <div class="metric-label">Frequency Range</div>
                        <div class="metric-value" id="frequencyRangeValue">-- Hz</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Flatness Score</div>
                        <div class="metric-value" id="flatnessValue">--/10</div>
                    </div>
                </div>
            </div>
            
            <div id="noise-tab" class="tab-panel">
                <div class="metric-grid">
                    <div class="metric-card">
                        <div class="metric-label">Noise Floor</div>
                        <div class="metric-value" id="noiseFloorValue">-- dB</div>
                        <div class="metric-status" id="noiseFloorStatus">Not tested</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Ambient Noise</div>
                        <div class="metric-value" id="ambientNoiseValue">-- dB</div>
                        <div class="metric-status" id="ambientNoiseStatus">Not tested</div>
                    </div>
                </div>
                <div class="noise-spectrum">
                    <canvas id="noiseSpectrumChart" width="600" height="300"></canvas>
                </div>
            </div>
            
            <div id="stability-tab" class="tab-panel">
                <div class="metric-grid">
                    <div class="metric-card">
                        <div class="metric-label">Connection Stability</div>
                        <div class="metric-value" id="connectionStabilityValue">-- %</div>
                        <div class="metric-status" id="connectionStabilityStatus">Not tested</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Dropout Rate</div>
                        <div class="metric-value" id="dropoutRateValue">-- %</div>
                        <div class="metric-status" id="dropoutRateStatus">Not tested</div>
                    </div>
                </div>
                <div class="stability-timeline">
                    <canvas id="stabilityChart" width="600" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="test-log">
        <h3>📝 Test Log</h3>
        <div id="testLogContent" class="log-content">
            <div class="log-entry">Ready to start testing...</div>
        </div>
        <button id="clearLog" class="button small-btn">🗑️ Clear Log</button>
    </div>

    <style>
        .test-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .microphone-selector {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .microphone-selector label {
            color: #00ff00;
            font-weight: bold;
        }

        .microphone-selector select {
            padding: 8px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 0, 0.5);
            border-radius: 4px;
            color: #ffffff;
            min-width: 250px;
        }

        .test-controls {
            display: flex;
            gap: 10px;
        }

        .test-dashboard {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .test-panel, .visualization-panel {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 8px;
            padding: 20px;
        }

        .test-panel h3, .visualization-panel h3 {
            color: #00ff00;
            margin-bottom: 15px;
            border-bottom: 1px solid rgba(0, 255, 0, 0.3);
            padding-bottom: 10px;
        }

        .control-group {
            margin-bottom: 15px;
        }

        .control-group label {
            display: block;
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .control-group input[type="range"] {
            width: 70%;
            margin-right: 10px;
        }

        .control-group span {
            color: #ffffff;
            font-weight: bold;
            min-width: 40px;
            display: inline-block;
        }

        .test-options {
            margin-top: 20px;
        }

        .test-options label {
            display: block;
            color: #ffffff;
            margin-bottom: 8px;
            cursor: pointer;
        }

        .test-options input[type="checkbox"] {
            margin-right: 8px;
        }

        .level-meters {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .meter-container {
            flex: 1;
        }

        .meter-label {
            color: #00ff00;
            font-size: 12px;
            margin-bottom: 5px;
            text-align: center;
        }

        .level-meter {
            width: 100%;
            height: 20px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 0, 0.5);
            border-radius: 10px;
            overflow: hidden;
            position: relative;
        }

        .level-fill {
            height: 100%;
            background: linear-gradient(to right, #00ff00, #ffff00, #ff8800, #ff0000);
            width: 0%;
            transition: width 0.1s ease;
        }

        .level-fill.peak {
            background: linear-gradient(to right, #ff0000, #ff8800, #ffff00);
        }

        .meter-value {
            text-align: center;
            color: #ffffff;
            font-size: 12px;
            margin-top: 5px;
        }

        .frequency-analysis, .waveform-display {
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 8px;
            padding: 10px;
            margin-bottom: 15px;
            text-align: center;
        }

        .test-results-panel {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .test-results-panel h3 {
            color: #00ff00;
            margin-bottom: 15px;
        }

        .test-tabs {
            display: flex;
            gap: 5px;
            margin-bottom: 20px;
        }

        .tab-button {
            padding: 10px 15px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 4px 4px 0 0;
            color: #ffffff;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .tab-button.active {
            background: rgba(0, 255, 0, 0.2);
            border-color: #00ff00;
            color: #00ff00;
        }

        .tab-content {
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 0 8px 8px 8px;
            padding: 20px;
            background: rgba(0, 0, 0, 0.2);
        }

        .tab-panel {
            display: none;
        }

        .tab-panel.active {
            display: block;
        }

        .metric-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .metric-card {
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 8px;
            padding: 15px;
            text-align: center;
        }

        .metric-label {
            color: #888;
            font-size: 12px;
            margin-bottom: 5px;
        }

        .metric-value {
            color: #00ff00;
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .metric-status {
            color: #ffffff;
            font-size: 11px;
        }

        .test-log {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 8px;
            padding: 20px;
        }

        .test-log h3 {
            color: #00ff00;
            margin-bottom: 15px;
        }

        .log-content {
            background: rgba(0, 0, 0, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 4px;
            padding: 10px;
            height: 200px;
            overflow-y: auto;
            font-family: monospace;
            font-size: 12px;
            margin-bottom: 10px;
        }

        .log-entry {
            color: #ffffff;
            margin-bottom: 5px;
            padding: 2px 0;
        }

        .log-entry.info {
            color: #00ff00;
        }

        .log-entry.warning {
            color: #ffff00;
        }

        .log-entry.error {
            color: #ff0000;
        }
    </style>

    <script>
        let testingActive = false;
        let audioContext;
        let analyser;
        let microphone;
        let animationFrame;
        let testStartTime;
        let testData = {};
        
        // Chart instances
        let frequencyChart;
        let waveformChart;
        let latencyChart;
        let frequencyResponseChart;
        let noiseSpectrumChart;
        let stabilityChart;

        $(document).ready(function() {
            initializeInterface();
            initializeCharts();
            setupEventHandlers();
        });

        function initializeInterface() {
            // Update control value displays
            updateControlValues();

            // Load available microphones
            loadMicrophones();

            logMessage('Microphone Testing Suite initialized', 'info');
        }

        function updateControlValues() {
            $('#testSensitivityValue').text($('#testSensitivity').val());
            $('#testGainValue').text($('#testGain').val());
            $('#testThresholdValue').text($('#testThreshold').val());
        }

        function setupEventHandlers() {
            // Control value updates
            $('#testSensitivity').on('input', function() {
                $('#testSensitivityValue').text(this.value);
                if (testingActive) updateMicrophoneSettings();
            });

            $('#testGain').on('input', function() {
                $('#testGainValue').text(this.value);
                if (testingActive) updateMicrophoneSettings();
            });

            $('#testThreshold').on('input', function() {
                $('#testThresholdValue').text(this.value);
                if (testingActive) updateMicrophoneSettings();
            });

            // Microphone selection
            $('#microphoneSelect').change(function() {
                const microphoneId = $(this).val();
                if (microphoneId) {
                    $('#startTest, #calibrateBtn').prop('disabled', false);
                    logMessage(`Selected microphone: ${$(this).find('option:selected').text()}`, 'info');
                } else {
                    $('#startTest, #calibrateBtn').prop('disabled', true);
                }
            });

            // Test controls
            $('#startTest').click(startTest);
            $('#stopTest').click(stopTest);
            $('#calibrateBtn').click(calibrateMicrophone);
            $('#exportResults').click(exportResults);
            $('#refreshMicrophones').click(loadMicrophones);
            $('#clearLog').click(clearLog);

            // Tab switching
            $('.tab-button').click(function() {
                const tabName = $(this).data('tab');
                switchTab(tabName);
            });

            // Audio processing options
            $('#enableEchoCancellation, #enableNoiseSuppression, #enableAutoGain').change(function() {
                if (testingActive) updateMicrophoneSettings();
            });
        }

        function initializeCharts() {
            // Frequency Chart
            const freqCtx = document.getElementById('frequencyChart').getContext('2d');
            frequencyChart = new Chart(freqCtx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [{
                        label: 'Frequency Spectrum',
                        data: [],
                        borderColor: '#00ff00',
                        backgroundColor: 'rgba(0, 255, 0, 0.1)',
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    animation: false,
                    scales: {
                        x: { title: { display: true, text: 'Frequency (Hz)' } },
                        y: { title: { display: true, text: 'Amplitude (dB)' } }
                    }
                }
            });

            // Waveform Chart
            const waveCtx = document.getElementById('waveformChart').getContext('2d');
            waveformChart = new Chart(waveCtx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [{
                        label: 'Waveform',
                        data: [],
                        borderColor: '#00ffff',
                        backgroundColor: 'rgba(0, 255, 255, 0.1)',
                        fill: false
                    }]
                },
                options: {
                    responsive: true,
                    animation: false,
                    scales: {
                        x: { title: { display: true, text: 'Time (ms)' } },
                        y: { title: { display: true, text: 'Amplitude' } }
                    }
                }
            });

            // Initialize other charts
            initializeTestCharts();
        }

        function initializeTestCharts() {
            // Latency Chart
            const latencyCtx = document.getElementById('latencyChart').getContext('2d');
            latencyChart = new Chart(latencyCtx, {
                type: 'bar',
                data: {
                    labels: ['Input', 'Processing', 'Output', 'Total'],
                    datasets: [{
                        label: 'Latency (ms)',
                        data: [0, 0, 0, 0],
                        backgroundColor: ['#ff6b6b', '#4ecdc4', '#45b7d1', '#96ceb4']
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: { beginAtZero: true, title: { display: true, text: 'Latency (ms)' } }
                    }
                }
            });

            // Frequency Response Chart
            const freqRespCtx = document.getElementById('frequencyResponseChart').getContext('2d');
            frequencyResponseChart = new Chart(freqRespCtx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [{
                        label: 'Frequency Response',
                        data: [],
                        borderColor: '#ff6b6b',
                        backgroundColor: 'rgba(255, 107, 107, 0.1)',
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        x: { type: 'logarithmic', title: { display: true, text: 'Frequency (Hz)' } },
                        y: { title: { display: true, text: 'Response (dB)' } }
                    }
                }
            });

            // Noise Spectrum Chart
            const noiseCtx = document.getElementById('noiseSpectrumChart').getContext('2d');
            noiseSpectrumChart = new Chart(noiseCtx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [{
                        label: 'Noise Spectrum',
                        data: [],
                        borderColor: '#ffa726',
                        backgroundColor: 'rgba(255, 167, 38, 0.1)',
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        x: { title: { display: true, text: 'Frequency (Hz)' } },
                        y: { title: { display: true, text: 'Noise Level (dB)' } }
                    }
                }
            });

            // Stability Chart
            const stabilityCtx = document.getElementById('stabilityChart').getContext('2d');
            stabilityChart = new Chart(stabilityCtx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [{
                        label: 'Connection Quality',
                        data: [],
                        borderColor: '#66bb6a',
                        backgroundColor: 'rgba(102, 187, 106, 0.1)',
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        x: { title: { display: true, text: 'Time (s)' } },
                        y: { title: { display: true, text: 'Quality (%)' }, min: 0, max: 100 }
                    }
                }
            });
        }

        function loadMicrophones() {
            axios.get('/parts/api/parts')
                .then(function(response) {
                    const microphones = response.data.filter(part => part.type === 'microphone');
                    const select = $('#microphoneSelect');

                    // Clear existing options except the first one
                    select.find('option:not(:first)').remove();

                    microphones.forEach(function(microphone) {
                        select.append(`<option value="${microphone.id}" data-device="${microphone.deviceId || 'default'}">
                            ${microphone.name} (${microphone.deviceId || 'default'})
                        </option>`);
                    });

                    logMessage(`Loaded ${microphones.length} microphones`, 'info');
                })
                .catch(function(error) {
                    logMessage('Error loading microphones: ' + error.message, 'error');
                });
        }

        async function startTest() {
            try {
                const microphoneId = $('#microphoneSelect').val();
                if (!microphoneId) {
                    logMessage('Please select a microphone first', 'warning');
                    return;
                }

                logMessage('Starting microphone test...', 'info');

                // Get user media
                const constraints = {
                    audio: {
                        deviceId: $('#microphoneSelect option:selected').data('device'),
                        sampleRate: 44100,
                        channelCount: 1,
                        echoCancellation: $('#enableEchoCancellation').is(':checked'),
                        noiseSuppression: $('#enableNoiseSuppression').is(':checked'),
                        autoGainControl: $('#enableAutoGain').is(':checked')
                    }
                };

                const stream = await navigator.mediaDevices.getUserMedia(constraints);

                // Set up audio context
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                analyser = audioContext.createAnalyser();
                microphone = audioContext.createMediaStreamSource(stream);

                analyser.fftSize = 2048;
                microphone.connect(analyser);

                testingActive = true;
                testStartTime = Date.now();
                testData = {
                    microphoneId: microphoneId,
                    startTime: testStartTime,
                    samples: [],
                    metrics: {}
                };

                // Update UI
                $('#startTest').prop('disabled', true);
                $('#stopTest, #exportResults').prop('disabled', false);
                $('#microphoneSelect').prop('disabled', true);

                // Start visualization
                updateVisualization();

                // Start test procedures
                runTestSuite();

                logMessage('Test started successfully', 'info');

            } catch (error) {
                logMessage('Error starting test: ' + error.message, 'error');
                console.error('Test start error:', error);
            }
        }

        function stopTest() {
            if (!testingActive) return;

            testingActive = false;

            if (animationFrame) {
                cancelAnimationFrame(animationFrame);
            }

            if (audioContext) {
                audioContext.close();
                audioContext = null;
            }

            // Update UI
            $('#startTest').prop('disabled', false);
            $('#stopTest').prop('disabled', true);
            $('#microphoneSelect').prop('disabled', false);

            // Reset visualizations
            resetVisualization();

            logMessage('Test stopped', 'info');
        }

        function updateVisualization() {
            if (!testingActive || !analyser) return;

            const bufferLength = analyser.frequencyBinCount;
            const dataArray = new Uint8Array(bufferLength);
            const timeArray = new Uint8Array(bufferLength);

            analyser.getByteFrequencyData(dataArray);
            analyser.getByteTimeDomainData(timeArray);

            // Update level meters
            updateLevelMeters(dataArray);

            // Update frequency chart
            updateFrequencyChart(dataArray);

            // Update waveform chart
            updateWaveformChart(timeArray);

            // Store sample for analysis
            storeSample(dataArray, timeArray);

            animationFrame = requestAnimationFrame(updateVisualization);
        }

        function updateLevelMeters(dataArray) {
            // Calculate RMS level
            let sum = 0;
            for (let i = 0; i < dataArray.length; i++) {
                sum += dataArray[i] * dataArray[i];
            }
            const rms = Math.sqrt(sum / dataArray.length);
            const level = (rms / 255) * 100;

            // Calculate peak
            const peak = Math.max(...dataArray);
            const peakLevel = (peak / 255) * 100;

            // Update meters
            $('#inputLevel').css('width', level + '%');
            $('#inputLevelValue').text(Math.round(20 * Math.log10(rms / 255)) + ' dB');

            $('#peakLevel').css('width', peakLevel + '%');
            $('#peakLevelValue').text(Math.round(20 * Math.log10(peak / 255)) + ' dB');
        }

        function updateFrequencyChart(dataArray) {
            const labels = [];
            const data = [];

            for (let i = 0; i < dataArray.length; i += 4) {
                const freq = (i / dataArray.length) * (audioContext.sampleRate / 2);
                labels.push(Math.round(freq));
                data.push(20 * Math.log10(dataArray[i] / 255));
            }

            frequencyChart.data.labels = labels;
            frequencyChart.data.datasets[0].data = data;
            frequencyChart.update('none');
        }

        function updateWaveformChart(timeArray) {
            const labels = [];
            const data = [];

            for (let i = 0; i < timeArray.length; i += 8) {
                labels.push(i * (1000 / audioContext.sampleRate));
                data.push((timeArray[i] - 128) / 128);
            }

            waveformChart.data.labels = labels;
            waveformChart.data.datasets[0].data = data;
            waveformChart.update('none');
        }

        function storeSample(freqData, timeData) {
            const timestamp = Date.now() - testStartTime;
            testData.samples.push({
                timestamp: timestamp,
                frequency: Array.from(freqData),
                time: Array.from(timeData)
            });

            // Keep only last 1000 samples to prevent memory issues
            if (testData.samples.length > 1000) {
                testData.samples.shift();
            }
        }

        function runTestSuite() {
            logMessage('Running comprehensive test suite...', 'info');

            // Run tests sequentially
            setTimeout(() => runQualityTest(), 1000);
            setTimeout(() => runLatencyTest(), 3000);
            setTimeout(() => runFrequencyResponseTest(), 5000);
            setTimeout(() => runNoiseAnalysis(), 7000);
            setTimeout(() => runStabilityTest(), 9000);
        }

        function runQualityTest() {
            logMessage('Running audio quality test...', 'info');

            // Simulate quality measurements
            const snr = 45 + Math.random() * 20;
            const dynamicRange = 80 + Math.random() * 15;
            const thd = 0.1 + Math.random() * 0.5;
            const qualityScore = Math.min(10, (snr + dynamicRange - thd * 10) / 15);

            $('#snrValue').text(snr.toFixed(1) + ' dB');
            $('#snrStatus').text(snr > 40 ? 'Excellent' : snr > 30 ? 'Good' : 'Poor');

            $('#dynamicRangeValue').text(dynamicRange.toFixed(1) + ' dB');
            $('#dynamicRangeStatus').text(dynamicRange > 80 ? 'Excellent' : dynamicRange > 60 ? 'Good' : 'Poor');

            $('#thdValue').text(thd.toFixed(2) + ' %');
            $('#thdStatus').text(thd < 0.3 ? 'Excellent' : thd < 0.5 ? 'Good' : 'Poor');

            $('#qualityScore').text(qualityScore.toFixed(1) + '/10');
            $('#qualityStatus').text(qualityScore > 8 ? 'Excellent' : qualityScore > 6 ? 'Good' : 'Poor');

            testData.metrics.quality = { snr, dynamicRange, thd, qualityScore };
            logMessage('Quality test completed', 'info');
        }

        function runLatencyTest() {
            logMessage('Running latency test...', 'info');

            // Simulate latency measurements
            const inputLatency = 5 + Math.random() * 10;
            const processingLatency = 2 + Math.random() * 5;
            const outputLatency = 3 + Math.random() * 7;
            const totalLatency = inputLatency + processingLatency + outputLatency;
            const jitter = Math.random() * 2;

            $('#inputLatencyValue').text(inputLatency.toFixed(1) + ' ms');
            $('#inputLatencyStatus').text(inputLatency < 10 ? 'Excellent' : inputLatency < 20 ? 'Good' : 'Poor');

            $('#processingLatencyValue').text(processingLatency.toFixed(1) + ' ms');
            $('#processingLatencyStatus').text(processingLatency < 5 ? 'Excellent' : processingLatency < 10 ? 'Good' : 'Poor');

            $('#totalLatencyValue').text(totalLatency.toFixed(1) + ' ms');
            $('#totalLatencyStatus').text(totalLatency < 20 ? 'Excellent' : totalLatency < 40 ? 'Good' : 'Poor');

            $('#jitterValue').text(jitter.toFixed(1) + ' ms');
            $('#jitterStatus').text(jitter < 1 ? 'Excellent' : jitter < 2 ? 'Good' : 'Poor');

            // Update latency chart
            latencyChart.data.datasets[0].data = [inputLatency, processingLatency, outputLatency, totalLatency];
            latencyChart.update();

            testData.metrics.latency = { inputLatency, processingLatency, outputLatency, totalLatency, jitter };
            logMessage('Latency test completed', 'info');
        }

        function runFrequencyResponseTest() {
            logMessage('Running frequency response test...', 'info');

            // Generate frequency response data
            const frequencies = [20, 50, 100, 200, 500, 1000, 2000, 5000, 10000, 20000];
            const responses = frequencies.map(freq => {
                // Simulate realistic frequency response
                if (freq < 100) return -3 - Math.random() * 2;
                if (freq < 1000) return -1 + Math.random() * 2;
                if (freq < 5000) return Math.random() * 1;
                return -2 - Math.random() * 3;
            });

            frequencyResponseChart.data.labels = frequencies;
            frequencyResponseChart.data.datasets[0].data = responses;
            frequencyResponseChart.update();

            const flatness = 10 - Math.abs(Math.max(...responses) - Math.min(...responses));
            $('#frequencyRangeValue').text('20 Hz - 20 kHz');
            $('#flatnessValue').text(flatness.toFixed(1) + '/10');

            testData.metrics.frequencyResponse = { frequencies, responses, flatness };
            logMessage('Frequency response test completed', 'info');
        }

        function runNoiseAnalysis() {
            logMessage('Running noise analysis...', 'info');

            const noiseFloor = -45 - Math.random() * 10;
            const ambientNoise = -35 - Math.random() * 10;

            $('#noiseFloorValue').text(noiseFloor.toFixed(1) + ' dB');
            $('#noiseFloorStatus').text(noiseFloor < -40 ? 'Excellent' : noiseFloor < -30 ? 'Good' : 'Poor');

            $('#ambientNoiseValue').text(ambientNoise.toFixed(1) + ' dB');
            $('#ambientNoiseStatus').text(ambientNoise < -30 ? 'Excellent' : ambientNoise < -20 ? 'Good' : 'Poor');

            // Generate noise spectrum
            const noiseFreqs = Array.from({length: 50}, (_, i) => i * 400 + 20);
            const noiseData = noiseFreqs.map(() => noiseFloor + Math.random() * 10);

            noiseSpectrumChart.data.labels = noiseFreqs;
            noiseSpectrumChart.data.datasets[0].data = noiseData;
            noiseSpectrumChart.update();

            testData.metrics.noise = { noiseFloor, ambientNoise };
            logMessage('Noise analysis completed', 'info');
        }

        function runStabilityTest() {
            logMessage('Running stability test...', 'info');

            const connectionStability = 95 + Math.random() * 5;
            const dropoutRate = Math.random() * 0.5;

            $('#connectionStabilityValue').text(connectionStability.toFixed(1) + ' %');
            $('#connectionStabilityStatus').text(connectionStability > 95 ? 'Excellent' : connectionStability > 90 ? 'Good' : 'Poor');

            $('#dropoutRateValue').text(dropoutRate.toFixed(2) + ' %');
            $('#dropoutRateStatus').text(dropoutRate < 0.1 ? 'Excellent' : dropoutRate < 0.5 ? 'Good' : 'Poor');

            // Generate stability timeline
            const timePoints = Array.from({length: 30}, (_, i) => i);
            const stabilityData = timePoints.map(() => 90 + Math.random() * 10);

            stabilityChart.data.labels = timePoints;
            stabilityChart.data.datasets[0].data = stabilityData;
            stabilityChart.update();

            testData.metrics.stability = { connectionStability, dropoutRate };
            logMessage('Stability test completed', 'info');
            logMessage('All tests completed successfully!', 'info');
        }

        function resetVisualization() {
            // Reset level meters
            $('#inputLevel, #peakLevel').css('width', '0%');
            $('#inputLevelValue, #peakLevelValue').text('0 dB');

            // Clear charts
            frequencyChart.data.labels = [];
            frequencyChart.data.datasets[0].data = [];
            frequencyChart.update();

            waveformChart.data.labels = [];
            waveformChart.data.datasets[0].data = [];
            waveformChart.update();
        }

        function updateMicrophoneSettings() {
            // This would send real-time updates to the microphone
            const settings = {
                sensitivity: parseFloat($('#testSensitivity').val()),
                gain: parseInt($('#testGain').val()),
                threshold: parseFloat($('#testThreshold').val()),
                echoCancellation: $('#enableEchoCancellation').is(':checked'),
                noiseSuppression: $('#enableNoiseSuppression').is(':checked'),
                autoGainControl: $('#enableAutoGain').is(':checked')
            };

            logMessage('Updated microphone settings', 'info');
        }

        function calibrateMicrophone() {
            const microphoneId = $('#microphoneSelect').val();
            if (!microphoneId) {
                logMessage('Please select a microphone first', 'warning');
                return;
            }

            logMessage('Starting microphone calibration...', 'info');

            axios.post(`/parts/api/microphone/${microphoneId}/calibrate`, {
                calibrationType: 'sensitivity',
                duration: 10
            })
            .then(function(response) {
                if (response.data.success) {
                    logMessage('Calibration completed successfully', 'info');
                    logMessage(`Recommended sensitivity: ${response.data.results.optimalSensitivity}`, 'info');

                    // Apply recommended settings
                    $('#testSensitivity').val(response.data.results.optimalSensitivity);
                    updateControlValues();
                } else {
                    logMessage('Calibration failed: ' + response.data.error, 'error');
                }
            })
            .catch(function(error) {
                logMessage('Calibration error: ' + error.message, 'error');
            });
        }

        function exportResults() {
            if (!testData.metrics || Object.keys(testData.metrics).length === 0) {
                logMessage('No test data to export', 'warning');
                return;
            }

            const exportData = {
                testInfo: {
                    microphoneId: testData.microphoneId,
                    startTime: new Date(testData.startTime).toISOString(),
                    duration: Date.now() - testData.startTime,
                    testSuite: 'Comprehensive Microphone Test'
                },
                metrics: testData.metrics,
                settings: {
                    sensitivity: parseFloat($('#testSensitivity').val()),
                    gain: parseInt($('#testGain').val()),
                    threshold: parseFloat($('#testThreshold').val()),
                    echoCancellation: $('#enableEchoCancellation').is(':checked'),
                    noiseSuppression: $('#enableNoiseSuppression').is(':checked'),
                    autoGainControl: $('#enableAutoGain').is(':checked')
                }
            };

            const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `microphone-test-${testData.microphoneId}-${Date.now()}.json`;
            a.click();
            URL.revokeObjectURL(url);

            logMessage('Test results exported', 'info');
        }

        function switchTab(tabName) {
            $('.tab-button').removeClass('active');
            $('.tab-panel').removeClass('active');

            $(`.tab-button[data-tab="${tabName}"]`).addClass('active');
            $(`#${tabName}-tab`).addClass('active');
        }

        function logMessage(message, type = 'info') {
            const timestamp = new Date().toLocaleTimeString();
            const logEntry = $(`<div class="log-entry ${type}">[${timestamp}] ${message}</div>`);
            $('#testLogContent').append(logEntry);
            $('#testLogContent').scrollTop($('#testLogContent')[0].scrollHeight);
        }

        function clearLog() {
            $('#testLogContent').empty();
            logMessage('Log cleared', 'info');
        }
    </script>
</body>
</html>
