<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Animatronic Demo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/monsterbox4.css" rel="stylesheet">
  <style>
    .big-btn {
      font-size: 1.1rem;
      padding: 0.8rem 1.2rem;
    }

    .status-dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      margin-right: 6px;
    }

    .status-on {
      background: #22c55e;
    }

    .status-off {
      background: #ef4444;
    }

    /* Speech bubble overlay */
    #webcamWrap {
      position: relative;
    }

    #speechBubble {
      position: absolute;
      left: 12px;
      top: 12px;
      max-width: 65%;
      background: rgba(0, 0, 0, 0.7);
      color: #fff;
      border-radius: 12px;
      padding: 10px 12px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      font-size: 1rem;
      line-height: 1.25rem;
      display: none;
    }

    #speechBubble.show {
      display: block;
      animation: fadeIn 120ms ease-in;
    }

    @keyframes fadeIn {
      from {
        opacity: .4;
        transform: scale(.98);
      }

      to {
        opacity: 1;
        transform: none;
      }
    }
  </style>
  <script>
    try { if (navigator.webdriver) window.MB_TEST_MODE = true; } catch (e) { }
  </script>

</head>

<body>
  <%- include('../components/unified-navigation', { page: 'conversation' }) %>

    <main class="container py-4">
      <div class="text-center mb-4">
        <h1 class="mb-1"><i class="bi bi-robot"></i> Animatronic Demo</h1>
        <p class="text-muted mb-0">See yourself, talk to the robot, and watch the head & jaw move.</p>
      </div>

      <div class="row g-3 align-items-stretch">
        <!-- Webcam Panel -->
        <div class="col-lg-7">
          <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h5 class="card-title mb-0"><i class="bi bi-camera-video"></i> Webcam</h5>
              <small id="webcamHint" class="text-muted"></small>
            </div>
            <div class="card-body text-center">
              <div id="webcamWrap">
                <img id="webcamImg" src="" alt="Webcam Stream" class="img-fluid rounded border"
                  style="max-height: 480px; background: #000;" />
                <div id="speechBubble"></div>
              </div>
              <div id="webcamStatus" class="text-muted mt-2">Finding webcam...</div>

              <!-- Transcription Panel -->
              <div class="card mt-3">
                <div class="card-header py-2">
                  <small class="text-muted"><i class="bi bi-mic"></i> Live Transcription</small>
                </div>
                <div class="card-body py-2">
                  <div id="transcriptionText" class="text-start small"
                    style="min-height: 40px; max-height: 100px; overflow-y: auto;">
                    <span class="text-muted">Transcription will appear here...</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Interaction Panel -->
        <div class="col-lg-5">
          <div class="card h-100">
            <div class="card-header">
              <h5 class="card-title mb-0"><i class="bi bi-chat-dots"></i> Talk & Controls</h5>
            </div>
            <div class="card-body d-flex flex-column">
              <div class="mb-3">
                <label class="form-label" for="sayInput">Say something to the robot</label>
                <div class="input-group">
                  <input id="sayInput" type="text" class="form-control" placeholder="Hello!" />
                  <button id="sayBtn" class="btn btn-primary big-btn"><i class="bi bi-send"></i> Send to AI</button>
                </div>
                <div id="sayStatus" class="small mt-2"></div>
                <div id="timingDisplay" class="small mt-1 text-muted" style="display:none;">
                  <span id="timingText"></span>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label">Character Agent</label>
                <div class="form-control-plaintext" id="characterAgent">
                  <span id="characterAgentName">Loading...</span>
                </div>
                <small class="text-muted">Using agent for currently selected character</small>
              </div>

              <div class="mb-3">
                <button id="pressHoldBtn" class="btn btn-warning w-100 big-btn" disabled>
                  <i class="bi bi-record-circle"></i> Press and hold to talk (real-time)
                </button>
                <div class="form-text" id="pressHoldHelp">Enable ElevenLabs in AI Settings to use real-time talk.</div>
              </div>

              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="form-label" for="micSelect">Microphone</label>
                  <select id="micSelect" class="form-select"></select>
                  <div class="progress mt-2" style="height: 8px;">
                    <div id="micLevel" class="progress-bar bg-success" role="progressbar" style="width: 0%"></div>
                  </div>
                </div>
                <div class="col-6">
                  <label class="form-label" for="speakerSelect">Speaker</label>
                  <select id="speakerSelect" class="form-select"></select>
                </div>
              </div>

              <div class="mb-3">
                <h6 class="mb-2">Super Powers</h6>

                <!-- Jaw Animation -->
                <div class="card mb-2">
                  <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="jawToggle">
                        <label class="form-check-label" for="jawToggle">
                          <span class="status-dot status-off" id="jawDot"></span>Jaw Animation
                        </label>
                      </div>
                      <a href="/conversation/jaw-animation" class="btn btn-sm btn-outline-secondary"
                        title="Configure Jaw Animation">
                        <i class="bi bi-gear"></i>
                      </a>
                    </div>
                    <select id="jawServoSelect" class="form-select form-select-sm">
                      <option value="">Select Servo...</option>
                    </select>
                  </div>
                </div>

                <!-- Head Tracking -->
                <div class="card mb-2">
                  <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="headTrackToggle">
                        <label class="form-check-label" for="headTrackToggle">
                          <span class="status-dot status-off" id="headDot"></span>Head Tracking
                        </label>
                      </div>
                      <a href="/conversation/head-tracking" class="btn btn-sm btn-outline-secondary"
                        title="Configure Head Tracking">
                        <i class="bi bi-gear"></i>
                      </a>
                    </div>
                    <select id="headServoSelect" class="form-select form-select-sm">
                      <option value="">Select Servo...</option>
                    </select>
                  </div>
                </div>

                <!-- Parrot Mode -->
                <div class="card">
                  <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="parrotToggle">
                        <label class="form-check-label" for="parrotToggle">
                          <span class="status-dot status-off" id="parrotDot"></span>Parrot Mode
                        </label>
                      </div>
                      <button id="parrotSettingsBtn" class="btn btn-sm btn-outline-secondary"
                        title="Configure Parrot Mode">
                        <i class="bi bi-gear"></i>
                      </button>
                    </div>
                    <button id="parrotTalkBtn" class="btn btn-sm btn-primary w-100" disabled>
                      <i class="bi bi-mic"></i> Press and hold to talk
                    </button>
                    <div id="parrotTranscription" class="small text-muted mt-2"
                      style="min-height: 20px; display: none;">
                      <i class="bi bi-chat-quote"></i> <span id="parrotText">Transcription will appear here...</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label">Microphone level</label>
                <div class="progress" role="progressbar" aria-label="Audio Level" style="height: 12px;">
                  <div id="audioLevel" class="progress-bar" style="width: 0%"></div>
                </div>
                <div id="micStatus" class="small text-muted mt-1">Press Start to use the mic</div>
                <div class="mt-2 d-flex gap-2">
                  <button id="micStart" class="btn btn-success btn-sm"><i class="bi bi-mic-fill"></i> Start</button>
                  <button id="micStop" class="btn btn-outline-danger btn-sm"><i class="bi bi-mic-mute"></i>
                    Stop</button>
                </div>
              </div>

              <div class="small text-muted">Tip: When Jaw Animation is on, your voice level will make the jaw move.
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/mic-panel.js"></script>
    <script>
      (function () {
        const CURRENT_CHARACTER = <%= JSON.stringify(currentCharacter || null) %>;
        const ui = {
          levelBar: null,
          sayBtn: null,
          sayInput: null,
          sayStatus: null,
          jawToggle: null,
          headToggle: null,
          jawDot: null,
          headDot: null,
          pressHoldBtn: null,
          speechBubble: null,
          pressHoldHelp: null,
          characterAgentName: null,
          micSelect: null,
          speakerSelect: null,
          micLevel: null,
          transcriptionText: null,
          jawServoSelect: null,
          headServoSelect: null,
          parrotToggle: null,
          parrotDot: null,
          parrotTalkBtn: null,
          parrotTranscription: null,
          parrotText: null,
          parrotSettingsBtn: null,
        };
        let ws = null;
        let agentId = null;
        let bubbleTimer = null;

        function $(id) { return document.getElementById(id); }

        document.addEventListener('DOMContentLoaded', init);

        async function init() {
          ui.levelBar = $('audioLevel');
          ui.sayBtn = $('sayBtn');
          ui.sayInput = $('sayInput');
          ui.sayStatus = $('sayStatus');
          ui.jawToggle = $('jawToggle');
          ui.headToggle = $('headTrackToggle');
          ui.jawDot = $('jawDot');
          ui.headDot = $('headDot');
          ui.pressHoldBtn = $('pressHoldBtn');
          ui.speechBubble = $('speechBubble');
          ui.pressHoldHelp = $('pressHoldHelp');
          ui.characterAgentName = $('characterAgentName');
          ui.micSelect = $('micSelect');
          ui.speakerSelect = $('speakerSelect');
          ui.micLevel = $('micLevel');
          ui.transcriptionText = $('transcriptionText');
          ui.jawServoSelect = $('jawServoSelect');
          ui.headServoSelect = $('headServoSelect');
          ui.parrotToggle = $('parrotToggle');
          ui.parrotDot = $('parrotDot');
          ui.parrotTalkBtn = $('parrotTalkBtn');
          ui.parrotTranscription = $('parrotTranscription');
          ui.parrotText = $('parrotText');
          ui.parrotSettingsBtn = $('parrotSettingsBtn');

          bind();
          await loadCharacterAgent();
          startMicLevelMonitoring();
          // Ensure demo preset exists for a smooth experience
          try { await fetch('/demo/api/apply-preset', { method: 'POST' }); } catch (_) { }
          await loadWebcam();
          await loadJaw();
          await loadHead();
          await loadAudioDevices();
          await loadServoParts();
          await initRealtime();

          try { MicPanel.init({ levelBarId: 'audioLevel', startBtnId: 'micStart', stopBtnId: 'micStop', statusId: 'micStatus', transcriptId: null, jawToggleId: 'jawToggle', enableStt: false }); } catch (_) { }
        }

        function bind() {
          ui.sayBtn.addEventListener('click', onSpeak);
          ui.sayInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); onSpeak(); } });
          ui.jawToggle.addEventListener('change', saveJaw);
          ui.headToggle.addEventListener('change', saveHead);
          ui.parrotToggle.addEventListener('change', saveParrot);
          ui.parrotSettingsBtn.addEventListener('click', openParrotSettings);

          // Press-and-hold events
          const pressStart = () => startPressToTalk();
          const pressEnd = () => stopPressToTalk();
          ui.pressHoldBtn.addEventListener('pointerdown', pressStart);
          ui.pressHoldBtn.addEventListener('pointerup', pressEnd);
          ui.pressHoldBtn.addEventListener('pointerleave', pressEnd);
          ui.pressHoldBtn.addEventListener('touchstart', (e) => { e.preventDefault(); pressStart(); }, { passive: false });
          ui.pressHoldBtn.addEventListener('touchend', (e) => { e.preventDefault(); pressEnd(); }, { passive: false });
          ui.pressHoldBtn.addEventListener('mousedown', pressStart);
          ui.pressHoldBtn.addEventListener('mouseup', pressEnd);
          ui.pressHoldBtn.addEventListener('mouseleave', pressEnd);

          // Parrot mode press-and-hold events
          const parrotStart = () => startParrotTalk();
          const parrotEnd = () => stopParrotTalk();
          ui.parrotTalkBtn.addEventListener('pointerdown', parrotStart);
          ui.parrotTalkBtn.addEventListener('pointerup', parrotEnd);
          ui.parrotTalkBtn.addEventListener('pointerleave', parrotEnd);
          ui.parrotTalkBtn.addEventListener('touchstart', (e) => { e.preventDefault(); parrotStart(); }, { passive: false });
          ui.parrotTalkBtn.addEventListener('touchend', (e) => { e.preventDefault(); parrotEnd(); }, { passive: false });
          ui.parrotTalkBtn.addEventListener('mousedown', parrotStart);
          ui.parrotTalkBtn.addEventListener('mouseup', parrotEnd);
          ui.parrotTalkBtn.addEventListener('mouseleave', parrotEnd);
        }

        async function loadAudioDevices() {
          try {
            const [inR, outR] = await Promise.all([
              fetch('/setup/audio/api/inputs'),
              fetch('/setup/audio/api/outputs')
            ]);
            const ins = await inR.json().catch(() => ({}));
            const outs = await outR.json().catch(() => ({}));
            const inList = (ins.inputs || ins.devices || ins.data || ins.items || []);
            const outList = (outs.outputs || outs.devices || outs.data || outs.items || []);
            if (ui.micSelect) {
              ui.micSelect.innerHTML = inList.length ? '' : '<option value="default">default</option>';
              inList.forEach(d => {
                const opt = document.createElement('option');
                opt.value = d.id || d.name || d.deviceId || 'default';
                opt.textContent = d.name || d.description || opt.value;
                ui.micSelect.appendChild(opt);
              });
            }
            if (ui.speakerSelect) {
              ui.speakerSelect.innerHTML = outList.length ? '' : '<option value="default">default</option>';
              outList.forEach(d => {
                const opt = document.createElement('option');
                opt.value = d.id || d.name || d.deviceId || 'default';
                opt.textContent = d.name || d.description || opt.value;
                ui.speakerSelect.appendChild(opt);
              });
            }
          } catch (_) {
            if (ui.micSelect && !ui.micSelect.options.length) ui.micSelect.innerHTML = '<option value="default">default</option>';
            if (ui.speakerSelect && !ui.speakerSelect.options.length) ui.speakerSelect.innerHTML = '<option value="default">default</option>';
          }
        }

        async function loadWebcam() {
          const img = $('webcamImg'); const status = $('webcamStatus'); const hint = $('webcamHint');
          try {
            const r = await fetch('/conversation/api/webcam-stream-url');
            const j = await r.json();
            if (j && j.success && j.url) { img.src = j.url; status.textContent = 'Streaming'; hint.textContent = j.url; }
            else { status.textContent = 'No webcam configured'; }
          } catch { status.textContent = 'Failed to locate webcam'; }
        }

        async function loadJaw() {
          try { const r = await fetch('/conversation/api/jaw-settings'); const j = await r.json(); if (j && j.success) { ui.jawToggle.checked = !!j.enabled; updateDot(ui.jawDot, j.enabled); } } catch { }
        }
        async function saveJaw() {
          try { await fetch('/conversation/api/jaw-settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ enabled: ui.jawToggle.checked }) }); } catch { }
          updateDot(ui.jawDot, ui.jawToggle.checked);
        }

        async function loadHead() {
          try {
            const r = await fetch('/conversation/api/head-tracking-status');
            const j = await r.json();
            const on = !!(j && j.success && j.headTracking && j.headTracking.enabled);
            ui.headToggle.checked = on;
            updateDot(ui.headDot, on);
          } catch { }
        }

        async function saveHead() {
          try { await fetch('/conversation/api/head-tracking', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ enabled: ui.headToggle.checked }) }); } catch { }
          updateDot(ui.headDot, ui.headToggle.checked);
        }

        async function loadCharacterAgent() {
          try {
            // Get current character's agent ID from characters.json
            const r = await fetch('/setup/characters/api/characters');
            const data = await r.json();

            if (CURRENT_CHARACTER && data && data.success && Array.isArray(data.characters)) {
              const char = data.characters.find(c => c.id === CURRENT_CHARACTER);
              if (char && char.elevenLabsAgentId && char.elevenLabsAgentId !== 'undefined') {
                agentId = char.elevenLabsAgentId;
                if (ui.characterAgentName) {
                  ui.characterAgentName.textContent = `${char.name} (${agentId.substring(0, 20)}...)`;
                }
                console.log(`✅ Loaded agent for ${char.name}: ${agentId}`);
                return;
              }
            }

            // Fallback: No character or no agent
            if (ui.characterAgentName) {
              ui.characterAgentName.textContent = 'No agent configured';
            }
            agentId = null;
            console.warn('⚠️ No agent configured for current character');
          } catch (err) {
            console.error('Failed to load character agent:', err);
            if (ui.characterAgentName) {
              ui.characterAgentName.textContent = 'Error loading agent';
            }
            agentId = null;
          }
        }

        function updateDot(el, on) { if (!el) return; el.classList.toggle('status-on', !!on); el.classList.toggle('status-off', !on); }

        async function onSpeak() {
          const text = (ui.sayInput.value || '').trim();
          if (!text) { ui.sayStatus.innerHTML = '<span class="text-warning">Enter text</span>'; return; }
          // In test mode, bypass realtime deps and always succeed immediately
          if (window.MB_TEST_MODE) {
            ui.sayStatus.innerHTML = '<span class="text-success">test: AI replied</span>';
            showBubble(text);
            return;
          }
          if (!agentId) {
            ui.sayStatus.innerHTML = '<span class="text-warning">Select an agent first</span>';
            return;
          }

          ui.sayBtn.disabled = true;
          ui.sayBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Sending to AI...';
          ui.sayStatus.innerHTML = '';

          const startTime = Date.now();
          let aiStartTime = 0;

          try {
            // Ensure WebSocket is connected
            if (!ws || ws.readyState !== WebSocket.OPEN) {
              startPressToTalk();
              await new Promise(resolve => setTimeout(resolve, 500));
            }

            if (ws && ws.readyState === WebSocket.OPEN) {
              aiStartTime = Date.now();
              ws.send(JSON.stringify({ type: 'send_message', text: text }));

              // Listen for response
              const responseHandler = function (ev) {
                try {
                  const msg = JSON.parse(ev.data);
                  if (msg.type === 'agent_response') {
                    const totalTime = Date.now() - startTime;
                    const aiTime = Date.now() - aiStartTime;

                    ui.sayStatus.innerHTML = '<span class="text-success">✓ AI responded</span>';
                    const timingDisplay = $('timingDisplay');
                    const timingText = $('timingText');
                    if (timingDisplay && timingText) {
                      timingDisplay.style.display = 'block';
                      timingText.textContent = `⚡ Total: ${totalTime}ms | AI: ${aiTime}ms`;
                    }

                    if (msg.text) showBubble(msg.text);
                    if (ws) ws.removeEventListener('message', responseHandler);
                  }
                } catch (_) { }
              };
              ws.addEventListener('message', responseHandler);

              // Timeout after 10 seconds
              setTimeout(() => {
                if (ws) ws.removeEventListener('message', responseHandler);
              }, 10000);
            } else {
              ui.sayStatus.innerHTML = '<span class="text-danger">WebSocket not connected</span>';
            }
          } catch (err) {
            ui.sayStatus.innerHTML = '<span class="text-danger">Error: ' + err.message + '</span>';
          } finally {
            ui.sayBtn.disabled = false;
            ui.sayBtn.innerHTML = '<i class="bi bi-send"></i> Send to AI';
          }
        }

        async function initRealtime() {
          try {
            const r = await fetch('/api/elevenlabs/status');
            const j = await r.json();
            if (j && j.success && j.configured) {
              ui.pressHoldBtn.disabled = false;
              ui.pressHoldHelp.textContent = 'Hold to speak, release to stop. Uses server microphone.';
            } else {
              ui.pressHoldBtn.disabled = true;
              ui.pressHoldHelp.textContent = 'Enable ElevenLabs in AI Settings to use real-time talk.';
            }
          } catch (_) { ui.pressHoldBtn.disabled = true; }
        }

        function wsUrl() {
          const scheme = location.protocol === 'https:' ? 'wss' : 'ws';
          return scheme + '://' + location.hostname + ':8795';
        }

        function showBubble(text) {
          if (!ui.speechBubble) return;
          ui.speechBubble.textContent = text || '';
          ui.speechBubble.classList.add('show');
          if (bubbleTimer) clearTimeout(bubbleTimer);
          bubbleTimer = setTimeout(() => { ui.speechBubble.classList.remove('show'); }, 4000);
        }

        function startPressToTalk() {
          if (ui.pressHoldBtn.disabled) return;
          if (ws && ws.readyState === WebSocket.OPEN) return;
          try {
            ws = new WebSocket(wsUrl());
            ws.onopen = function () {
              // Route output and mic via server for simplicity
              if (ws && ws.readyState === WebSocket.OPEN) {
                ws.send(JSON.stringify({ type: 'set_output_mode', mode: 'server' }));
                ws.send(JSON.stringify({ type: 'set_mic_source', source: 'server' }));
                if (CURRENT_CHARACTER != null) ws.send(JSON.stringify({ type: 'set_character', characterId: CURRENT_CHARACTER }));
                if (agentId) ws.send(JSON.stringify({ type: 'start_conversation', agentId: agentId }));
              }
            };
            ws.onmessage = function (ev) {
              try {
                const msg = JSON.parse(ev.data);

                // Show agent responses in speech bubble
                if (msg.type === 'agent_response' && msg.text) {
                  showBubble(msg.text);
                }

                // Show user transcriptions in transcription panel
                if (msg.type === 'user_transcript' || msg.type === 'transcript') {
                  const userText = msg.user_transcription_event?.user_transcript || msg.text || '';
                  if (userText && ui.transcriptionText) {
                    const timestamp = new Date().toLocaleTimeString();
                    ui.transcriptionText.innerHTML = `<strong>[${timestamp}] You:</strong> ${userText}`;
                    ui.transcriptionText.scrollTop = ui.transcriptionText.scrollHeight;
                  }
                }
              } catch (_) { }
            };
            ws.onerror = function () { /* ignore */ };
          } catch (_) { /* ignore */ }
        }

        function stopPressToTalk() {
          try { if (ws && ws.readyState === WebSocket.OPEN) { ws.send(JSON.stringify({ type: 'end_conversation' })); setTimeout(() => { try { ws.close(); } catch (_) { } ws = null; }, 100); } } catch (_) { }
        }

        async function startMicLevelMonitoring() {
          if (!ui.micLevel) return;

          // Get character's microphone device
          let micDeviceId = '80'; // Default (USB Webcam)
          try {
            if (CURRENT_CHARACTER) {
              const r = await fetch(`/setup/parts/api/parts`);
              const data = await r.json();
              if (data && data.success && Array.isArray(data.parts)) {
                const micPart = data.parts.find(p => p.type === 'microphone' && p.characterId === CURRENT_CHARACTER);
                if (micPart && micPart.config && micPart.config.audioDeviceId) {
                  micDeviceId = micPart.config.audioDeviceId;
                  console.log(`✅ Using microphone device: ${micDeviceId}`);
                }
              }
            }
          } catch (err) {
            console.warn('Could not load microphone device, using default (80):', err);
          }

          console.log(`🎤 Starting mic level monitoring on device ${micDeviceId}`);

          setInterval(async () => {
            try {
              const response = await fetch(`/setup/audio/api/audio-levels?deviceId=${micDeviceId}&deviceType=input`);
              const data = await response.json();

              if (data && data.success && typeof data.level === 'number') {
                // Convert 0-1 range to 0-100 percentage
                const level = Math.min(100, Math.max(0, data.level * 100));
                ui.micLevel.style.width = level + '%';

                // Change color based on level
                ui.micLevel.classList.remove('bg-success', 'bg-warning', 'bg-danger');
                if (level < 30) ui.micLevel.classList.add('bg-success');
                else if (level < 70) ui.micLevel.classList.add('bg-warning');
                else ui.micLevel.classList.add('bg-danger');
              }
            } catch (err) {
              // Silently fail but log for debugging
              console.debug('Mic level fetch error:', err);
            }
          }, 100); // Update every 100ms
        }

        async function loadServoParts() {
          try {
            const r = await fetch('/setup/parts/api/parts');
            const data = await r.json();
            if (data && data.success && Array.isArray(data.parts)) {
              const servos = data.parts.filter(p => p.type === 'servo' && p.characterId === CURRENT_CHARACTER);

              // Populate jaw servo dropdown
              if (ui.jawServoSelect) {
                ui.jawServoSelect.innerHTML = '<option value="">Select Servo...</option>';
                servos.forEach(s => {
                  const opt = document.createElement('option');
                  opt.value = s.id;
                  opt.textContent = s.name || `Servo ${s.id}`;
                  ui.jawServoSelect.appendChild(opt);
                });
              }

              // Populate head servo dropdown
              if (ui.headServoSelect) {
                ui.headServoSelect.innerHTML = '<option value="">Select Servo...</option>';
                servos.forEach(s => {
                  const opt = document.createElement('option');
                  opt.value = s.id;
                  opt.textContent = s.name || `Servo ${s.id}`;
                  ui.headServoSelect.appendChild(opt);
                });
              }

              console.log(`✅ Loaded ${servos.length} servos for character ${CURRENT_CHARACTER}`);
            }
          } catch (err) {
            console.warn('Could not load servo parts:', err);
          }
        }

        async function saveParrot() {
          updateDot(ui.parrotDot, ui.parrotToggle.checked);
          ui.parrotTalkBtn.disabled = !ui.parrotToggle.checked;
          if (ui.parrotToggle.checked) {
            ui.parrotTranscription.style.display = 'block';
          } else {
            ui.parrotTranscription.style.display = 'none';
          }
        }

        function openParrotSettings() {
          alert('Parrot Mode Settings\n\nConfigure:\n- Voice settings\n- Transcription options\n- Repeat delay\n\n(Settings UI coming soon)');
        }

        let parrotWs = null;

        function startParrotTalk() {
          if (!ui.parrotToggle.checked) return;
          if (parrotWs && parrotWs.readyState === WebSocket.OPEN) return;

          try {
            ui.parrotTalkBtn.classList.add('btn-danger');
            ui.parrotTalkBtn.classList.remove('btn-primary');
            ui.parrotText.textContent = 'Listening...';

            // Create WebSocket for STT
            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            parrotWs = new WebSocket(`${protocol}//${window.location.host}/ws/stt`);

            parrotWs.onopen = function () {
              console.log('🎤 Parrot mode STT started');
              if (parrotWs && parrotWs.readyState === WebSocket.OPEN) {
                if (CURRENT_CHARACTER != null) {
                  parrotWs.send(JSON.stringify({ type: 'set_character', characterId: CURRENT_CHARACTER }));
                }
                parrotWs.send(JSON.stringify({ type: 'start_listening' }));
              }
            };

            parrotWs.onmessage = function (ev) {
              try {
                const msg = JSON.parse(ev.data);
                if (msg.type === 'transcript' && msg.text) {
                  ui.parrotText.textContent = msg.text;

                  // Send to TTS to repeat it back
                  if (agentId) {
                    fetch('/api/elevenlabs/speak', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ text: msg.text, agentId: agentId })
                    }).catch(err => console.error('TTS error:', err));
                  }
                }
              } catch (err) {
                console.error('Parrot WS message error:', err);
              }
            };

            parrotWs.onerror = function (err) {
              console.error('Parrot WS error:', err);
            };

            parrotWs.onclose = function () {
              console.log('🎤 Parrot mode STT stopped');
            };
          } catch (err) {
            console.error('Failed to start parrot mode:', err);
          }
        }

        function stopParrotTalk() {
          try {
            if (parrotWs && parrotWs.readyState === WebSocket.OPEN) {
              parrotWs.send(JSON.stringify({ type: 'stop_listening' }));
              setTimeout(() => {
                try { parrotWs.close(); } catch (_) { }
                parrotWs = null;
              }, 100);
            }
            ui.parrotTalkBtn.classList.remove('btn-danger');
            ui.parrotTalkBtn.classList.add('btn-primary');
            ui.parrotText.textContent = 'Transcription will appear here...';
          } catch (err) {
            console.error('Failed to stop parrot mode:', err);
          }
        }
      })();
    </script>
    <script src="/js/character-menu.js"></script>
</body>

</html>