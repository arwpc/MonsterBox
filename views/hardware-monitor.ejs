            async refreshAnimatronic(animatronicId) {
                const animatronic = this.animatronics.find(a => a.id === animatronicId);
                if (!animatronic) return;

                this.log(`Refreshing ${animatronic.name}...`, 'info');

                const startTime = Date.now();
                try {
                    const response = await fetch(`${animatronic.baseUrl}/api/hub/status`);
                    const responseTime = Date.now() - startTime;

                    if (response.ok) {
                        const statusData = await response.json();
                        animatronic.status = 'online';
                        animatronic.lastSeen = new Date();
                        animatronic.responseTime = responseTime;
                        animatronic.hubStatus = statusData;

                        // Refresh services
                        const servicesResponse = await fetch(`${animatronic.baseUrl}/api/hub/services`);
                        if (servicesResponse.ok) {
                            const servicesData = await servicesResponse.json();
                            animatronic.services = servicesData.services || [];
                        }

                        this.log(`${animatronic.name} refreshed successfully`, 'success');
                    } else {
                        throw new Error(`HTTP ${response.status}`);
                    }
                } catch (error) {
                    animatronic.status = 'offline';
                    animatronic.responseTime = Date.now() - startTime;
                    this.log(`${animatronic.name} refresh failed: ${error.message}`, 'error');
                }

                this.updateFleetStats();
                this.renderAnimatronicsGrid();

                // Update modal if it's open for this character
                if (this.selectedCharacter && this.selectedCharacter.id === animatronicId) {
                    this.showCharacterDetails(animatronic);
                }
            }

