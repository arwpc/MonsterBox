<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Services Monitor - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .services-monitor {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        .info-section {
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 5px;
            padding: 15px;
            margin-bottom: 20px;
        }

        .info-section h2 {
            margin: 0 0 10px 0;
            color: #00ff00;
            font-size: 1.3em;
        }

        .info-section p {
            margin: 0;
            color: #cccccc;
            line-height: 1.4;
        }

        .character-grid, .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }

        .character-card {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
        }

        .character-card:hover {
            background: #002200;
            border-color: #00ff88;
            transform: translateY(-2px);
        }

        .character-card.active {
            background: #003300;
            border-color: #00ff00;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
        }

        .character-name {
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .character-status {
            color: #888888;
            font-size: 0.9em;
        }

        .services-section {
            margin-top: 30px;
            display: none;
        }

        .services-section.active {
            display: block;
        }

        .service-card {
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            transition: all 0.3s ease;
        }

        .service-card:hover {
            background: #002200;
            border-color: #00ff88;
        }

        .service-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .service-icon {
            font-size: 1.5em;
            margin-right: 10px;
        }

        .service-name {
            color: #00ff00;
            font-weight: bold;
            flex-grow: 1;
        }

        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-left: 10px;
        }

        .status-online {
            background: #00ff00;
            box-shadow: 0 0 8px #00ff00;
        }

        .status-offline {
            background: #ff0000;
            box-shadow: 0 0 8px #ff0000;
        }

        .status-checking {
            background: #ffff00;
            box-shadow: 0 0 8px #ffff00;
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .service-details {
            color: #888888;
            font-size: 0.9em;
            margin-top: 8px;
        }

        .activity-log {
            margin-top: 30px;
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
        }

        .log-container {
            background: #000000;
            border: 1px solid #333333;
            border-radius: 4px;
            padding: 15px;
            height: 300px;
            overflow-y: auto;
            font-family: 'Courier New', monospace;
            font-size: 0.9em;
        }

        .log-entry {
            margin-bottom: 5px;
            padding: 2px 0;
        }

        .log-info { color: #00ff00; }
        .log-warning { color: #ffff00; }
        .log-error { color: #ff0000; }

        .info-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 30px;
            text-align: center;
        }

        .info-section h2 {
            color: #00ff00;
            font-family: 'Creepster', cursive;
            font-size: 2em;
            margin-bottom: 10px;
            text-shadow: 0 0 10px #00ff00;
        }

        .info-section p {
            color: #cccccc;
            font-size: 1.1em;
            margin: 0;
        }

        .character-selector {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .character-selector h3 {
            color: #00ff00;
            margin-bottom: 15px;
            font-size: 1.3em;
        }

        .back-button {
            background: #001100;
            border: 2px solid #00ff00;
            color: #00ff00;
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            display: inline-block;
            margin-top: 30px;
            transition: all 0.3s ease;
            font-family: 'VT323', monospace;
            font-size: 1.1em;
        }

        .back-button:hover {
            background: #00ff00;
            color: #000000;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.5);
        }

        h1, h2, h3 {
            color: #00ff00;
        }

        h1 {
            font-family: 'Creepster', cursive;
            font-size: 2.5em;
            text-align: center;
            margin-bottom: 10px;
            text-shadow: 0 0 15px #00ff00;
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .monitor-container {
                padding: 10px;
            }

            .character-grid, .services-grid {
                grid-template-columns: 1fr;
            }

            .info-section h2 {
                font-size: 1.5em;
            }

            .log-container {
                height: 200px;
            }
        }

        /* Loading animation */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(0, 255, 0, 0.3);
            border-radius: 50%;
            border-top-color: #00ff00;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <%- include('partials/compact-header', { 
        title: 'Services Monitor', 
        icon: '🔧', 
        breadcrumbs: [
            { name: 'Home', url: '/', icon: '🏠' },
            { name: 'Configuration', url: '/configuration', icon: '⚙️' },
            { name: 'Services Monitor', current: true }
        ]
    }) %>

    <main class="monitor-container">
        <div class="info-section">
            <h2>🔧 Character Services Overview</h2>
            <p>Monitor all services by character. Select a character to view their specific service status, performance metrics, and detailed information.</p>
            <div id="systemStatus" style="margin-top: 15px; padding: 10px; border: 1px solid #666; border-radius: 5px; background: #001100;">
                <strong>System Status:</strong> <span id="overallStatus">Checking...</span>
            </div>
        </div>

        <div class="character-selector">
            <h3>📋 Select Character</h3>
            <div class="character-grid" id="characterGrid">
                <!-- Characters will be loaded here -->
            </div>
        </div>

        <div class="services-section" id="servicesSection">
            <h3>🔧 Character Services</h3>
            <div class="services-grid" id="servicesGrid">
                <!-- Services will be loaded here based on selected character -->
            </div>
        </div>

        <div class="activity-log">
            <h3>📊 Activity Log</h3>
            <div class="log-container" id="logContainer">
                <div class="log-entry log-info">Services monitor initialized...</div>
            </div>
        </div>

        <a href="/configuration" class="back-button">← Back to Configuration</a>
    </main>

    <script>
        class ServicesMonitor {
            constructor() {
                this.selectedCharacter = null;
                this.characters = [];
                this.services = [];
                this.maxLogEntries = 100;
                this.serviceConnections = {};

                this.init();
            }

            init() {
                this.log('Services monitor initialized...', 'info');
                this.loadCharacters();
                this.setupEventListeners();

                // Initial status update
                setTimeout(() => {
                    this.updateOverallStatus();
                }, 1000);
            }

            async loadCharacters() {
                try {
                    this.log('Fetching characters from /api/characters...', 'info');
                    const response = await fetch('/api/characters');
                    
                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }
                    
                    this.characters = await response.json();

                    this.renderCharacterGrid();
                    this.log(`Loaded ${this.characters.length} characters`, 'info');
                    
                    // Auto-select the first character if available
                    if (this.characters.length > 0) {
                        this.selectCharacter(this.characters[0]);
                    } else {
                        this.log('No characters found, loading default services', 'warning');
                        this.loadDefaultServices();
                    }
                } catch (error) {
                    this.log('Failed to load characters: ' + error.message, 'error');
                    // If character loading fails, show services anyway for the current device
                    this.loadDefaultServices();
                }
            }

            loadDefaultServices() {
                // Show services even if no characters are loaded
                const servicesSection = document.getElementById('servicesSection');
                servicesSection.classList.add('active');

                const expectedServices = [
                    { name: 'Main Hardware Server', port: 8780, icon: '🔧', type: 'hardware' },
                    { name: 'Motor Service', port: 8771, icon: '🔄', type: 'motor' },
                    { name: 'Light Service', port: 8772, icon: '💡', type: 'light' },
                    { name: 'Sensor Service', port: 8773, icon: '📡', type: 'sensor' },
                    { name: 'Webcam Service', port: 8774, icon: '📹', type: 'webcam' },
                    { name: 'Motion Sensor Service', port: 8777, icon: '🔍', type: 'motion' },
                    { name: 'Head Tracking Service', port: 8778, icon: '🎯', type: 'tracking' },
                    { name: 'Service Registry', port: 8770, icon: '📋', type: 'registry' }
                ];

                this.renderServices(expectedServices);
                this.monitorServices(expectedServices);
                this.log('Loaded default services for current device', 'info');
            }

            renderCharacterGrid() {
                const grid = document.getElementById('characterGrid');
                grid.innerHTML = '';

                this.characters.forEach(character => {
                    const card = document.createElement('div');
                    card.className = 'character-card';
                    card.dataset.characterId = character.id;

                    // Count expected services (all characters have the same base services)
                    const expectedServiceCount = 8; // Main, Motor, Light, Sensor, Webcam, Motion, Head Tracking, Registry

                    card.innerHTML = `
                        <div class="character-name">${character.char_name || character.name}</div>
                        <div class="character-status">${expectedServiceCount} services</div>
                    `;

                    card.addEventListener('click', () => this.selectCharacter(character));
                    grid.appendChild(card);
                });
            }

            selectCharacter(character) {
                console.log('Selecting character:', character);

                // Update UI to show selected character
                document.querySelectorAll('.character-card').forEach(card => {
                    card.classList.remove('active');
                });

                const selectedCard = document.querySelector(`[data-character-id="${character.id}"]`);
                console.log('Selected card:', selectedCard);
                if (selectedCard) {
                    selectedCard.classList.add('active');
                }

                this.selectedCharacter = character;
                this.loadCharacterServices(character);
                this.log(`Selected character: ${character.char_name || character.name}`, 'info');
            }

            async loadCharacterServices(character) {
                const servicesSection = document.getElementById('servicesSection');
                servicesSection.classList.add('active');

                // Define expected services for each character
                const expectedServices = [
                    { name: 'Main Hardware Server', port: 8780, icon: '🔧', type: 'hardware' },
                    { name: 'Motor Service', port: 8771, icon: '🔄', type: 'motor' },
                    { name: 'Light Service', port: 8772, icon: '💡', type: 'light' },
                    { name: 'Sensor Service', port: 8773, icon: '📡', type: 'sensor' },
                    { name: 'Webcam Service', port: 8774, icon: '📹', type: 'webcam' },
                    { name: 'Motion Sensor Service', port: 8777, icon: '🔍', type: 'motion' },
                    { name: 'Head Tracking Service', port: 8778, icon: '🎯', type: 'tracking' },
                    { name: 'Service Registry', port: 8770, icon: '📋', type: 'registry' }
                ];

                this.renderServices(expectedServices);
                this.monitorServices(expectedServices);
            }

            renderServices(services) {
                const grid = document.getElementById('servicesGrid');
                grid.innerHTML = '';

                services.forEach(service => {
                    const card = document.createElement('div');
                    card.className = 'service-card';
                    card.dataset.serviceType = service.type;
                    card.dataset.servicePort = service.port;

                    card.innerHTML = `
                        <div class="service-header">
                            <div class="service-icon">${service.icon}</div>
                            <div class="service-name">${service.name}</div>
                            <div class="status-indicator status-checking" id="status-${service.type}"></div>
                        </div>
                        <div class="service-details" id="details-${service.type}">
                            <div>Port: ${service.port}</div>
                            <div id="status-text-${service.type}">Checking...</div>
                        </div>
                    `;

                    grid.appendChild(card);
                });
            }

            monitorServices(services) {
                services.forEach(service => {
                    this.checkServiceStatus(service);
                });

                // Check services every 30 seconds (reduced frequency to minimize log spam)
                setInterval(() => {
                    services.forEach(service => {
                        this.checkServiceStatus(service);
                    });
                }, 30000);
            }

            async checkServiceStatus(service) {
                console.log('Checking service:', service);
                const statusIndicator = document.getElementById(`status-${service.type}`);
                const statusText = document.getElementById(`status-text-${service.type}`);
                const details = document.getElementById(`details-${service.type}`);

                // Skip check if service was recently marked as offline to reduce log spam
                if (service.lastFailTime && (Date.now() - service.lastFailTime) < 60000) {
                    console.log('Skipping service check due to recent failure:', service.type);
                    return;
                }

                try {
                    // Try HTTP first to see if it's a WebSocket service
                    const controller = new AbortController();
                    const timeoutId = setTimeout(() => controller.abort(), 3000);

                    try {
                        // Try HTTP request to detect WebSocket services
                        const response = await fetch(`http://${window.location.hostname}:${service.port}/`, {
                            method: 'GET',
                            signal: controller.signal
                        });
                        clearTimeout(timeoutId);

                        const text = await response.text();

                        // Check if it's a WebSocket service based on response
                        if (text.includes('WebSocket') || text.includes('Upgrade Required') || response.status === 426) {
                            // It's a WebSocket service - try WebSocket connection
                            try {
                                const ws = new WebSocket(`ws://${window.location.hostname}:${service.port}`);

                                const wsTimeout = setTimeout(() => {
                                    ws.close();
                                    service.lastFailTime = Date.now();
                                    this.updateServiceStatus(service, 'offline', 'WebSocket connection timeout');
                                }, 3000);

                                ws.onopen = () => {
                                    clearTimeout(wsTimeout);
                                    service.lastFailTime = null;
                                    this.updateServiceStatus(service, 'online', 'WebSocket service online');
                                    ws.close();
                                };

                                ws.onerror = (error) => {
                                    clearTimeout(wsTimeout);
                                    service.lastFailTime = Date.now();
                                    this.updateServiceStatus(service, 'offline', 'WebSocket connection failed');
                                };

                                return;
                            } catch (wsError) {
                                service.lastFailTime = Date.now();
                                this.updateServiceStatus(service, 'offline', 'WebSocket connection error');
                                return;
                            }
                        } else if (response.ok) {
                            // It's an HTTP service
                            service.lastFailTime = null;
                            this.updateServiceStatus(service, 'online', 'HTTP service responding');
                            return;
                        }
                    } catch (httpError) {
                        clearTimeout(timeoutId);
                        // HTTP failed completely - service likely offline
                    }

                    // Service is offline
                    service.lastFailTime = Date.now();
                    this.updateServiceStatus(service, 'offline', 'Service unavailable');

                } catch (error) {
                    service.lastFailTime = Date.now();
                    this.updateServiceStatus(service, 'offline', `Error: ${error.message}`);
                }
            }

            updateServiceStatus(service, status, message) {
                const statusIndicator = document.getElementById(`status-${service.type}`);
                const statusText = document.getElementById(`status-text-${service.type}`);
                const details = document.getElementById(`details-${service.type}`);

                if (statusIndicator && statusText && details) {
                    statusIndicator.className = `status-indicator status-${status}`;
                    statusText.textContent = status === 'online' ? 'Online' : 'Offline';

                    const timestamp = new Date().toLocaleTimeString();
                    details.innerHTML = `
                        <div>Port: ${service.port}</div>
                        <div>${message}</div>
                        <div>Last checked: ${timestamp}</div>
                    `;

                    // Only log status changes, not repeated failures
                    if (!service.lastStatus || service.lastStatus !== status) {
                        this.log(`${service.name}: ${status} - ${message}`, status === 'online' ? 'info' : 'warning');
                        service.lastStatus = status;
                    }
                }

                // Update overall system status
                this.updateOverallStatus();
            }

            updateOverallStatus() {
                const statusElements = document.querySelectorAll('.status-indicator');
                let onlineCount = 0;
                let totalCount = statusElements.length;

                statusElements.forEach(element => {
                    if (element.classList.contains('status-online')) {
                        onlineCount++;
                    }
                });

                const overallStatusElement = document.getElementById('overallStatus');
                if (overallStatusElement) {
                    if (onlineCount === 0) {
                        overallStatusElement.innerHTML = '<span style="color: #ff6666;">All services offline</span> - <span style="color: #888;">Hardware services not running. Services will show as online when hardware processes are started.</span>';
                    } else if (onlineCount === totalCount) {
                        overallStatusElement.innerHTML = '<span style="color: #00ff00;">All services online</span> - <span style="color: #888;">Hardware services are running normally.</span>';
                    } else {
                        overallStatusElement.innerHTML = `<span style="color: #ffff00;">${onlineCount}/${totalCount} services online</span> - <span style="color: #888;">Some services may be starting up or unavailable.</span>`;
                    }
                }
            }

            setupEventListeners() {
                // Add any additional event listeners here
            }

            log(message, type = 'info') {
                const logContainer = document.getElementById('logContainer');
                const timestamp = new Date().toLocaleTimeString();

                const logEntry = document.createElement('div');
                logEntry.className = `log-entry log-${type}`;
                logEntry.textContent = `[${timestamp}] ${message}`;

                logContainer.appendChild(logEntry);

                // Remove old entries if we have too many
                const entries = logContainer.querySelectorAll('.log-entry');
                if (entries.length > this.maxLogEntries) {
                    entries[0].remove();
                }

                // Auto-scroll to bottom
                logContainer.scrollTop = logContainer.scrollHeight;
            }
        }

        // Initialize the Services Monitor when the page loads
        document.addEventListener('DOMContentLoaded', function() {
            window.servicesMonitor = new ServicesMonitor();
        });
    </script>
</body>
</html>
