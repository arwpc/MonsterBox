<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Animatronic Fleet Monitor - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .fleet-monitor {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }

        .fleet-overview {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .fleet-stat-card {
            background: linear-gradient(135deg, #001100, #002200);
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.3);
        }

        .fleet-stat-card h3 {
            color: #00ff00;
            margin: 0 0 10px 0;
            font-size: 1.1em;
            text-transform: uppercase;
        }

        .fleet-stat-value {
            font-size: 2.5em;
            font-weight: bold;
            color: #ffffff;
            margin: 10px 0;
        }

        .fleet-stat-label {
            color: #cccccc;
            font-size: 0.9em;
        }
        .info-section {
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 5px;
            padding: 15px;
            margin-bottom: 20px;
        }

        .info-section h2 {
            margin: 0 0 10px 0;
            color: #00ff00;
            font-size: 1.3em;
        }

        .info-section p {
            margin: 0;
            color: #cccccc;
            line-height: 1.4;
        }

        .animatronics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .animatronic-card {
            background: linear-gradient(135deg, #000800, #001800);
            border: 2px solid #00ff00;
            border-radius: 12px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .animatronic-card:hover {
            border-color: #00ffff;
            box-shadow: 0 0 25px rgba(0, 255, 255, 0.4);
            transform: translateY(-2px);
        }

        .animatronic-card.online {
            border-color: #00ff00;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
        }

        .animatronic-card.offline {
            border-color: #ff4444;
            box-shadow: 0 0 15px rgba(255, 68, 68, 0.3);
            opacity: 0.7;
        }

        .animatronic-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .animatronic-name {
            color: #00ff00;
            font-size: 1.3em;
            font-weight: bold;
            margin: 0;
        }

        .animatronic-status {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8em;
            font-weight: bold;
            text-transform: uppercase;
        }

        .status-online {
            background: rgba(0, 255, 0, 0.2);
            color: #00ff00;
            border: 1px solid #00ff00;
        }

        .status-offline {
            background: rgba(255, 68, 68, 0.2);
            color: #ff4444;
            border: 1px solid #ff4444;
        }

        .animatronic-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 15px;
        }

        .info-item {
            text-align: center;
        }

        .info-value {
            font-size: 1.5em;
            font-weight: bold;
            color: #ffffff;
            margin-bottom: 5px;
        }

        .info-label {
            color: #cccccc;
            font-size: 0.9em;
        }

        .service-status-bar {
            background: #001100;
            border-radius: 10px;
            padding: 10px;
            margin-top: 10px;
        }

        .service-status-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .service-count {
            color: #00ff00;
            font-weight: bold;
        }

        .service-indicators {
            display: flex;
            gap: 4px;
        }

        .service-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #333;
        }

        .service-dot.active {
            background: #00ff00;
            box-shadow: 0 0 4px rgba(0, 255, 0, 0.6);
        }

        .service-dot.error {
            background: #ff4444;
            box-shadow: 0 0 4px rgba(255, 68, 68, 0.6);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .section-header h2 {
            color: #00ff00;
            margin: 0;
            font-size: 1.5em;
        }

        .modal {
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
        }

        .modal-content {
            background: linear-gradient(135deg, #001100, #002200);
            margin: 5% auto;
            padding: 0;
            border: 2px solid #00ff00;
            border-radius: 12px;
            width: 90%;
            max-width: 800px;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: 0 0 30px rgba(0, 255, 0, 0.4);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            border-bottom: 1px solid #00ff00;
        }

        .modal-header h2 {
            color: #00ff00;
            margin: 0;
        }

        .close {
            color: #ff4444;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            transition: color 0.3s ease;
        }

        .close:hover {
            color: #ff6666;
        }

        .modal-body {
            padding: 20px;
        }

        .detail-section {
            margin-bottom: 25px;
            padding: 15px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 8px;
            border: 1px solid #333;
        }

        .detail-section h3 {
            color: #00ff00;
            margin: 0 0 15px 0;
            font-size: 1.2em;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }

        .detail-item {
            background: rgba(0, 255, 0, 0.05);
            padding: 10px;
            border-radius: 5px;
            border: 1px solid rgba(0, 255, 0, 0.2);
        }

        .detail-label {
            color: #cccccc;
            font-size: 0.9em;
            margin-bottom: 5px;
        }

        .detail-value {
            color: #ffffff;
            font-weight: bold;
            font-size: 1.1em;
        }

        .character-card:hover {
            background: #002200;
            border-color: #00ff88;
            transform: translateY(-2px);
        }

        .character-card.active {
            background: #003300;
            border-color: #00ff00;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
        }

        .character-name {
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .character-status {
            color: #888888;
            font-size: 0.9em;
        }

        .services-section {
            margin-top: 30px;
            display: none;
        }

        .services-section.active {
            display: block;
        }

        .service-card {
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            transition: all 0.3s ease;
        }

        .service-card:hover {
            background: #002200;
            border-color: #00ff88;
        }

        .service-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .service-icon {
            font-size: 1.5em;
            margin-right: 10px;
        }

        .service-name {
            color: #00ff00;
            font-weight: bold;
            flex-grow: 1;
        }

        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-left: 10px;
        }

        .status-online {
            background: #00ff00;
            box-shadow: 0 0 8px #00ff00;
        }

        .status-offline {
            background: #ff0000;
            box-shadow: 0 0 8px #ff0000;
        }

        .status-unknown {
            background: #888888;
            box-shadow: 0 0 8px #888888;
        }

        .status-checking {
            background: #ffff00;
            box-shadow: 0 0 8px #ffff00;
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .service-details {
            color: #888888;
            font-size: 0.9em;
            margin-top: 8px;
        }

        .activity-log {
            margin-top: 30px;
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
        }

        .log-container {
            background: #000000;
            border: 1px solid #333333;
            border-radius: 4px;
            padding: 15px;
            height: 300px;
            overflow-y: auto;
            font-family: 'Courier New', monospace;
            font-size: 0.9em;
        }

        .log-entry {
            margin-bottom: 5px;
            padding: 2px 0;
        }

        .log-info { color: #00ff00; }
        .log-warning { color: #ffff00; }
        .log-error { color: #ff0000; }
        .log-success { color: #00ff88; }

        .info-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 30px;
            text-align: center;
        }

        .info-section h2 {
            color: #00ff00;
            font-family: 'Creepster', cursive;
            font-size: 2em;
            margin-bottom: 10px;
            text-shadow: 0 0 10px #00ff00;
        }

        .info-section p {
            color: #cccccc;
            font-size: 1.1em;
            margin: 0;
        }

        .character-selector {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .character-selector h3 {
            color: #00ff00;
            margin-bottom: 15px;
            font-size: 1.3em;
        }

        .back-button {
            background: #001100;
            border: 2px solid #00ff00;
            color: #00ff00;
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            display: inline-block;
            margin-top: 30px;
            transition: all 0.3s ease;
            font-family: 'VT323', monospace;
            font-size: 1.1em;
        }

        .back-button:hover {
            background: #00ff00;
            color: #000000;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.5);
        }

        .connection-controls {
            display: flex;
            gap: 15px;
            align-items: center;
            padding: 15px;
            background: #000800;
            border: 1px solid #00aa00;
            border-radius: 8px;
        }

        .connection-btn {
            background: #001100;
            border: 2px solid #00ff00;
            color: #00ff00;
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'VT323', monospace;
            font-size: 1.1em;
            min-width: 120px;
        }

        .connection-btn:hover {
            background: #00ff00;
            color: #000000;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.4);
        }

        .connection-btn:disabled {
            background: #333333;
            border-color: #666666;
            color: #666666;
            cursor: not-allowed;
            box-shadow: none;
        }

        .connect-btn {
            border-color: #00ff00;
            color: #00ff00;
        }

        .disconnect-btn {
            border-color: #ff6666;
            color: #ff6666;
        }

        .disconnect-btn:hover {
            background: #ff6666;
            color: #000000;
            box-shadow: 0 0 10px rgba(255, 102, 102, 0.4);
        }

        .connection-status {
            flex: 1;
            text-align: right;
            color: #cccccc;
            font-family: 'VT323', monospace;
            font-size: 1.1em;
        }

        h1, h2, h3 {
            color: #00ff00;
        }

        h1 {
            font-family: 'Creepster', cursive;
            font-size: 2.5em;
            text-align: center;
            margin-bottom: 10px;
            text-shadow: 0 0 15px #00ff00;
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .monitor-container {
                padding: 10px;
            }

            .character-grid, .services-grid {
                grid-template-columns: 1fr;
            }

            .info-section h2 {
                font-size: 1.5em;
            }

            .log-container {
                height: 200px;
            }
        }

        /* Loading animation */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(0, 255, 0, 0.3);
            border-radius: 50%;
            border-top-color: #00ff00;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <%- include('partials/compact-header', {
        title: 'Animatronic Fleet Monitor',
        icon: '🎭',
        breadcrumbs: [
            { name: 'Home', url: '/', icon: '🏠' },
            { name: 'Configuration', url: '/configuration', icon: '⚙️' },
            { name: 'Fleet Monitor', current: true }
        ]
    }) %>

    <main class="fleet-monitor">
        <!-- Fleet Overview Stats -->
        <div class="fleet-overview">
            <div class="fleet-stat-card">
                <h3>🎭 Total Animatronics</h3>
                <div class="fleet-stat-value" id="totalAnimatronics">-</div>
                <div class="fleet-stat-label">Managed Characters</div>
            </div>
            <div class="fleet-stat-card">
                <h3>✅ Online</h3>
                <div class="fleet-stat-value" id="onlineCount">-</div>
                <div class="fleet-stat-label">Active Systems</div>
            </div>
            <div class="fleet-stat-card">
                <h3>🔧 Total Services</h3>
                <div class="fleet-stat-value" id="totalServices">-</div>
                <div class="fleet-stat-label">Running Services</div>
            </div>
            <div class="fleet-stat-card">
                <h3>⚡ System Health</h3>
                <div class="fleet-stat-value" id="systemHealth">-</div>
                <div class="fleet-stat-label">Overall Status</div>
            </div>
        </div>

        <!-- Animatronics Grid -->
        <div class="section-header">
            <h2>🎭 Animatronic Fleet Status</h2>
            <button id="refreshAllBtn" class="connection-btn">🔄 Refresh All</button>
        </div>

        <div class="animatronics-grid" id="animatronicsGrid">
            <!-- Animatronic cards will be loaded here -->
        </div>

        <!-- Character Detail Modal -->
        <div id="characterModal" class="modal" style="display: none;">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 id="modalCharacterName">Character Details</h2>
                    <span class="close" id="closeModal">&times;</span>
                </div>
                <div class="modal-body" id="modalBody">
                    <!-- Character details will be loaded here -->
                </div>
            </div>
        </div>

        <!-- Activity Log -->
        <div class="activity-log">
            <h3>📊 Fleet Activity Log</h3>
            <div class="log-container" id="logContainer">
                <div class="log-entry log-info">Fleet monitor initialized...</div>
            </div>
        </div>

        <a href="/configuration" class="back-button">← Back to Configuration</a>
    </main>

    <script>
        // Cache buster: <%= Date.now() %>
        class FleetMonitor {
            constructor() {
                this.animatronics = [];
                this.fleetStats = {
                    total: 0,
                    online: 0,
                    totalServices: 0,
                    systemHealth: 'Unknown'
                };
                this.maxLogEntries = 100;
                this.pollingInterval = null;
                this.selectedCharacter = null;
                this.isConnected = false;

                this.init().catch(error => {
                    console.error('Failed to initialize fleet monitor:', error);
                    this.log(`Initialization error: ${error.message}`, 'error');
                });
            }

            async init() {
                this.log('Fleet monitor initialized...', 'info');
                await this.loadAnimatronics();
                this.setupEventListeners();
                this.startFleetMonitoring();

                // Initial status update
                setTimeout(() => {
                    this.updateFleetStats();
                }, 1000);
            }

            startFleetMonitoring() {
                // Refresh fleet status every 15 seconds
                this.pollingInterval = setInterval(async () => {
                    try {
                        await this.refreshFleetStatus();
                    } catch (error) {
                        console.error('Error refreshing fleet status:', error);
                    }
                }, 15000);

                this.log('Started fleet monitoring (every 15 seconds)', 'info');
            }

            async loadAnimatronics() {
                try {
                    this.log('Loading animatronic fleet data...', 'info');

                    // Load characters from API
                    const response = await fetch('/api/characters');
                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }

                    const characters = await response.json();
                    this.log(`Found ${characters.length} characters in database`, 'info');

                    // Create animatronic objects with network info
                    this.animatronics = characters.map(character => ({
                        id: character.id,
                        name: character.name,
                        hostname: this.getHostnameForCharacter(character.name),
                        baseUrl: this.getBaseUrlForCharacter(character.name),
                        status: 'checking',
                        services: [],
                        parts: character.parts || [],
                        lastSeen: null,
                        responseTime: null
                    }));

                    // Start checking status for each animatronic
                    await this.refreshFleetStatus();
                    this.renderAnimatronicsGrid();

                } catch (error) {
                    this.log(`Failed to load animatronics: ${error.message}`, 'error');
                    this.animatronics = [];
                }
            }

            getHostnameForCharacter(characterName) {
                // Check if this is the current machine
                const currentHostname = window.location.hostname;

                if (characterName === 'Skulltalker' && currentHostname.includes('skulltalker')) {
                    return currentHostname; // Use current hostname
                }

                // For other characters, use their network addresses
                const hostnames = {
                    'Orlok': 'orlok.monsterbox.local',
                    'Coffin Breaker': 'coffinbreaker.monsterbox.local',
                    'PumpkinHead': 'pumpkinhead.monsterbox.local',
                    'Skulltalker': 'skulltalker.monsterbox.local'
                };
                return hostnames[characterName] || `${characterName.toLowerCase()}.monsterbox.local`;
            }

            getBaseUrlForCharacter(characterName) {
                const hostname = this.getHostnameForCharacter(characterName);

                // If this is the current machine, use relative URL
                if (hostname === window.location.hostname) {
                    return `${window.location.protocol}//${window.location.host}`;
                }

                return `https://${hostname}:8080`;
            }

            async refreshFleetStatus() {
                this.log('Refreshing fleet status...', 'info');

                const statusPromises = this.animatronics.map(async (animatronic) => {
                    const startTime = Date.now();

                    try {
                        // Check if animatronic is online
                        const healthResponse = await fetch(`${animatronic.baseUrl}/api/hub/status`, {
                            method: 'GET',
                            timeout: 5000
                        });

                        const responseTime = Date.now() - startTime;

                        if (healthResponse.ok) {
                            const statusData = await healthResponse.json();

                            // Get services information
                            const servicesResponse = await fetch(`${animatronic.baseUrl}/api/hub/services`);
                            let services = [];

                            if (servicesResponse.ok) {
                                const servicesData = await servicesResponse.json();
                                services = servicesData.services || [];
                            }

                            animatronic.status = 'online';
                            animatronic.services = services;
                            animatronic.lastSeen = new Date();
                            animatronic.responseTime = responseTime;
                            animatronic.hubStatus = statusData;

                            this.log(`${animatronic.name}: Online (${services.length} services, ${responseTime}ms)`, 'success');

                        } else {
                            throw new Error(`HTTP ${healthResponse.status}`);
                        }

                    } catch (error) {
                        animatronic.status = 'offline';
                        animatronic.services = [];
                        animatronic.responseTime = Date.now() - startTime;
                        animatronic.hubStatus = null;

                        this.log(`${animatronic.name}: Offline (${error.message})`, 'warning');
                    }
                });

                await Promise.all(statusPromises);
                this.updateFleetStats();
                this.renderAnimatronicsGrid();
            }

            updateFleetStats() {
                const online = this.animatronics.filter(a => a.status === 'online');
                const totalServices = online.reduce((sum, a) => sum + a.services.length, 0);

                this.fleetStats = {
                    total: this.animatronics.length,
                    online: online.length,
                    totalServices: totalServices,
                    systemHealth: online.length === this.animatronics.length ? '100%' :
                                 online.length > 0 ? `${Math.round((online.length / this.animatronics.length) * 100)}%` : '0%'
                };

                // Update UI
                document.getElementById('totalAnimatronics').textContent = this.fleetStats.total;
                document.getElementById('onlineCount').textContent = this.fleetStats.online;
                document.getElementById('totalServices').textContent = this.fleetStats.totalServices;
                document.getElementById('systemHealth').textContent = this.fleetStats.systemHealth;

                this.log(`Fleet Status: ${this.fleetStats.online}/${this.fleetStats.total} online, ${this.fleetStats.totalServices} services`, 'info');
            }

            renderAnimatronicsGrid() {
                const grid = document.getElementById('animatronicsGrid');
                if (!grid) return;

                grid.innerHTML = '';

                this.animatronics.forEach(animatronic => {
                    const card = document.createElement('div');
                    card.className = `animatronic-card ${animatronic.status}`;
                    card.onclick = () => this.showCharacterDetails(animatronic);

                    const serviceCount = animatronic.services.length;
                    const activeServices = animatronic.services.filter(s => s.status === 'active').length;
                    const lastSeenText = animatronic.lastSeen ?
                        `Last seen: ${animatronic.lastSeen.toLocaleTimeString()}` :
                        'Never contacted';

                    // Create service indicator dots
                    const maxDots = 12; // Expected max services
                    const serviceDots = Array.from({length: maxDots}, (_, i) => {
                        if (i < activeServices) {
                            return '<div class="service-dot active"></div>';
                        } else if (i < serviceCount) {
                            return '<div class="service-dot error"></div>';
                        } else {
                            return '<div class="service-dot"></div>';
                        }
                    }).join('');

                    card.innerHTML = `
                        <div class="animatronic-header">
                            <h3 class="animatronic-name">${animatronic.name}</h3>
                            <div class="animatronic-status status-${animatronic.status}">
                                ${animatronic.status.toUpperCase()}
                            </div>
                        </div>

                        <div class="animatronic-info">
                            <div class="info-item">
                                <div class="info-value">${serviceCount}</div>
                                <div class="info-label">Services</div>
                            </div>
                            <div class="info-item">
                                <div class="info-value">${animatronic.parts.length}</div>
                                <div class="info-label">Parts</div>
