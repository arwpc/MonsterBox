<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Services Monitor - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .services-monitor {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        .info-section {
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 5px;
            padding: 15px;
            margin-bottom: 20px;
        }

        .info-section h2 {
            margin: 0 0 10px 0;
            color: #00ff00;
            font-size: 1.3em;
        }

        .info-section p {
            margin: 0;
            color: #cccccc;
            line-height: 1.4;
        }

        .character-grid, .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }

        .character-card {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
        }

        .character-card:hover {
            background: #002200;
            border-color: #00ff88;
            transform: translateY(-2px);
        }

        .character-card.active {
            background: #003300;
            border-color: #00ff00;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
        }

        .character-name {
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .character-status {
            color: #888888;
            font-size: 0.9em;
        }

        .services-section {
            margin-top: 30px;
            display: none;
        }

        .services-section.active {
            display: block;
        }

        .service-card {
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 15px;
            transition: all 0.3s ease;
        }

        .service-card:hover {
            background: #002200;
            border-color: #00ff88;
        }

        .service-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .service-icon {
            font-size: 1.5em;
            margin-right: 10px;
        }

        .service-name {
            color: #00ff00;
            font-weight: bold;
            flex-grow: 1;
        }

        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-left: 10px;
        }

        .status-online {
            background: #00ff00;
            box-shadow: 0 0 8px #00ff00;
        }

        .status-offline {
            background: #ff0000;
            box-shadow: 0 0 8px #ff0000;
        }

        .status-unknown {
            background: #888888;
            box-shadow: 0 0 8px #888888;
        }

        .status-checking {
            background: #ffff00;
            box-shadow: 0 0 8px #ffff00;
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .service-details {
            color: #888888;
            font-size: 0.9em;
            margin-top: 8px;
        }

        .activity-log {
            margin-top: 30px;
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
        }

        .log-container {
            background: #000000;
            border: 1px solid #333333;
            border-radius: 4px;
            padding: 15px;
            height: 300px;
            overflow-y: auto;
            font-family: 'Courier New', monospace;
            font-size: 0.9em;
        }

        .log-entry {
            margin-bottom: 5px;
            padding: 2px 0;
        }

        .log-info { color: #00ff00; }
        .log-warning { color: #ffff00; }
        .log-error { color: #ff0000; }
        .log-success { color: #00ff88; }

        .info-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 30px;
            text-align: center;
        }

        .info-section h2 {
            color: #00ff00;
            font-family: 'Creepster', cursive;
            font-size: 2em;
            margin-bottom: 10px;
            text-shadow: 0 0 10px #00ff00;
        }

        .info-section p {
            color: #cccccc;
            font-size: 1.1em;
            margin: 0;
        }

        .character-selector {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .character-selector h3 {
            color: #00ff00;
            margin-bottom: 15px;
            font-size: 1.3em;
        }

        .back-button {
            background: #001100;
            border: 2px solid #00ff00;
            color: #00ff00;
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            display: inline-block;
            margin-top: 30px;
            transition: all 0.3s ease;
            font-family: 'VT323', monospace;
            font-size: 1.1em;
        }

        .back-button:hover {
            background: #00ff00;
            color: #000000;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.5);
        }

        .connection-controls {
            display: flex;
            gap: 15px;
            align-items: center;
            padding: 15px;
            background: #000800;
            border: 1px solid #00aa00;
            border-radius: 8px;
        }

        .connection-btn {
            background: #001100;
            border: 2px solid #00ff00;
            color: #00ff00;
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'VT323', monospace;
            font-size: 1.1em;
            min-width: 120px;
        }

        .connection-btn:hover {
            background: #00ff00;
            color: #000000;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.4);
        }

        .connection-btn:disabled {
            background: #333333;
            border-color: #666666;
            color: #666666;
            cursor: not-allowed;
            box-shadow: none;
        }

        .connect-btn {
            border-color: #00ff00;
            color: #00ff00;
        }

        .disconnect-btn {
            border-color: #ff6666;
            color: #ff6666;
        }

        .disconnect-btn:hover {
            background: #ff6666;
            color: #000000;
            box-shadow: 0 0 10px rgba(255, 102, 102, 0.4);
        }

        .connection-status {
            flex: 1;
            text-align: right;
            color: #cccccc;
            font-family: 'VT323', monospace;
            font-size: 1.1em;
        }

        h1, h2, h3 {
            color: #00ff00;
        }

        h1 {
            font-family: 'Creepster', cursive;
            font-size: 2.5em;
            text-align: center;
            margin-bottom: 10px;
            text-shadow: 0 0 15px #00ff00;
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .monitor-container {
                padding: 10px;
            }

            .character-grid, .services-grid {
                grid-template-columns: 1fr;
            }

            .info-section h2 {
                font-size: 1.5em;
            }

            .log-container {
                height: 200px;
            }
        }

        /* Loading animation */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(0, 255, 0, 0.3);
            border-radius: 50%;
            border-top-color: #00ff00;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <%- include('partials/compact-header', { 
        title: 'Services Monitor', 
        icon: '🔧', 
        breadcrumbs: [
            { name: 'Home', url: '/', icon: '🏠' },
            { name: 'Configuration', url: '/configuration', icon: '⚙️' },
            { name: 'Services Monitor', current: true }
        ]
    }) %>

    <main class="monitor-container">
        <div class="info-section">
            <h2>🔧 Character Services Overview</h2>
            <p>Monitor all services by character. Select a character to view their specific service status, performance metrics, and detailed information.</p>
            <div id="systemStatus" style="margin-top: 15px; padding: 10px; border: 1px solid #666; border-radius: 5px; background: #001100;">
                <strong>System Status:</strong> <span id="overallStatus">Checking...</span>
            </div>
        </div>

        <div class="character-selector">
            <h3>📋 Select Character</h3>
            <div class="character-grid" id="characterGrid">
                <!-- Characters will be loaded here -->
            </div>
            <div class="connection-controls" id="connectionControls" style="margin-top: 15px; display: none;">
                <button id="connectBtn" class="connection-btn connect-btn">🔌 Connect</button>
                <button id="disconnectBtn" class="connection-btn disconnect-btn">🔌 Disconnect</button>
                <div class="connection-status" id="connectionStatus">
                    <span id="connectionStatusText">No character selected</span>
                </div>
            </div>
        </div>

        <div class="services-section" id="servicesSection">
            <h3>🔧 Character Services</h3>
            <div class="services-grid" id="servicesGrid">
                <!-- Services will be loaded here based on selected character -->
            </div>
        </div>

        <div class="activity-log">
            <h3>📊 Activity Log</h3>
            <div class="log-container" id="logContainer">
                <div class="log-entry log-info">Services monitor initialized...</div>
            </div>
        </div>

        <a href="/configuration" class="back-button">← Back to Configuration</a>
    </main>

    <script>
        // Cache buster: <%= Date.now() %>
        class ServicesMonitor {
            constructor() {
                this.selectedCharacter = null;
                this.characters = [];
                this.services = [];
                this.maxLogEntries = 100;
                this.serviceConnections = {};
                this.pollingInterval = null;
                this.lastConnectionsSnapshot = null;
                this.isConnected = false;

                this.init().catch(error => {
                    console.error('Failed to initialize services monitor:', error);
                    this.log(`Initialization error: ${error.message}`, 'error');
                });
            }

            async init() {
                this.log('Services monitor initialized...', 'info');
                await this.loadCharacters();
                this.setupEventListeners();
                this.startCharacterRefresh();

                // Initial status update
                setTimeout(() => {
                    this.updateOverallStatus();
                }, 1000);
            }

            startCharacterRefresh() {
                // Refresh character list every 30 seconds to detect new characters
                setInterval(async () => {
                    try {
                        await this.loadCharacters();
                    } catch (error) {
                        console.error('Error refreshing character list:', error);
                    }
                }, 30000);

                this.log('Started periodic character list refresh (every 30 seconds)', 'info');
            }

            async loadCharacters() {
                try {
                    this.log('Fetching characters from /api/characters...', 'info');
                    const response = await fetch('/api/characters');

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }

                    const newCharacters = await response.json();

                    // Check if characters have changed
                    const charactersChanged = JSON.stringify(this.characters) !== JSON.stringify(newCharacters);
                    this.characters = newCharacters;

                    this.renderCharacterGrid();
                    this.log(`Loaded ${this.characters.length} characters`, 'info');

                    // Only auto-select if no character is currently selected or if characters changed
                    if (!this.selectedCharacter || charactersChanged) {
                        if (this.characters.length > 0) {
                            // Try to reselect the same character if it still exists
                            let characterToSelect = this.characters[0];
                            if (this.selectedCharacter) {
                                const existingCharacter = this.characters.find(c => c.id === this.selectedCharacter.id);
                                if (existingCharacter) {
                                    characterToSelect = existingCharacter;
                                }
                            }
                            this.selectCharacter(characterToSelect);
                        } else {
                            this.log('No characters found, loading default services', 'warning');
                            this.hideConnectionControls();
                            this.loadDefaultServices();
                        }
                    }
                } catch (error) {
                    this.log('Failed to load characters: ' + error.message, 'error');
                    // If character loading fails, show services anyway for the current device
                    this.hideConnectionControls();
                    this.loadDefaultServices();
                }
            }

            loadDefaultServices() {
                // Show services even if no characters are loaded
                const servicesSection = document.getElementById('servicesSection');
                servicesSection.classList.add('active');

                const expectedServices = [
                    { name: 'Main Hardware Server', port: 8780, icon: '🔧', type: 'hardware' },
                    { name: 'Motor Service', port: 8771, icon: '🔄', type: 'motor' },
                    { name: 'Light Service', port: 8772, icon: '💡', type: 'light' },
                    { name: 'Sensor Service', port: 8773, icon: '📡', type: 'sensor' },
                    { name: 'Webcam Service', port: 8774, icon: '📹', type: 'webcam' },
                    { name: 'Motion Sensor Service', port: 8777, icon: '🔍', type: 'motion' },
                    { name: 'Head Tracking Service', port: 8778, icon: '🎯', type: 'tracking' },
                    { name: 'Service Registry', port: 8770, icon: '📋', type: 'registry' }
                ];

                // Show placeholder message instead of starting polling
                const grid = document.getElementById('servicesGrid');
                if (grid) {
                    grid.innerHTML = '<div style="text-align: center; color: #888; padding: 20px;">Select a character and click Connect to monitor services</div>';
                }

                this.log('Default services loaded - select a character to begin monitoring', 'info');
            }

            renderCharacterGrid() {
                const grid = document.getElementById('characterGrid');
                grid.innerHTML = '';

                this.characters.forEach(character => {
                    const card = document.createElement('div');
                    card.className = 'character-card';
                    card.dataset.characterId = character.id;

                    // Count expected services (all characters have the same base services)
                    const expectedServiceCount = 8; // Main, Motor, Light, Sensor, Webcam, Motion, Head Tracking, Registry

                    card.innerHTML = `
                        <div class="character-name">${character.char_name || character.name}</div>
                        <div class="character-status">${expectedServiceCount} services</div>
                    `;

                    card.addEventListener('click', () => this.selectCharacter(character));
                    grid.appendChild(card);
                });
            }

            selectCharacter(character) {
                // Update UI to show selected character
                document.querySelectorAll('.character-card').forEach(card => {
                    card.classList.remove('active');
                });

                const selectedCard = document.querySelector(`[data-character-id="${character.id}"]`);
                if (selectedCard) {
                    selectedCard.classList.add('active');
                }

                this.selectedCharacter = character;
                console.log('Character selected:', character);
                console.log('Character host:', character.animatronic?.rpi_config?.host);

                this.showConnectionControls();
                this.updateConnectionStatus();
                this.loadCharacterServices(character);
                this.log(`Selected character: ${character.char_name || character.name}`, 'info');
            }

            async loadCharacterServices(character) {
                const servicesSection = document.getElementById('servicesSection');
                servicesSection.classList.add('active');

                // Define expected services for each character
                const expectedServices = [
                    { name: 'Main Hardware Server', port: 8780, icon: '🔧', type: 'hardware' },
                    { name: 'Motor Service', port: 8771, icon: '🔄', type: 'motor' },
                    { name: 'Light Service', port: 8772, icon: '💡', type: 'light' },
                    { name: 'Sensor Service', port: 8773, icon: '📡', type: 'sensor' },
                    { name: 'Webcam Service', port: 8774, icon: '📹', type: 'webcam' },
                    { name: 'Motion Sensor Service', port: 8777, icon: '🔍', type: 'motion' },
                    { name: 'Head Tracking Service', port: 8778, icon: '🎯', type: 'tracking' },
                    { name: 'Service Registry', port: 8770, icon: '📋', type: 'registry' }
                ];

                // Show placeholder message - user needs to click Connect to start monitoring
                const grid = document.getElementById('servicesGrid');
                if (grid) {
                    const characterName = character.char_name || character.name;
                    grid.innerHTML = `<div style="text-align: center; color: #888; padding: 20px;">Ready to monitor services for ${characterName}<br>Click Connect to begin</div>`;
                }
            }



            async loadServiceConnections() {
                try {
                    // Determine which host to query for service connections
                    let apiUrl = '/api/service-management/connections';

                    // If connected to a remote character, query their services directly
                    if (this.selectedCharacter && this.selectedCharacter.animatronic &&
                        this.selectedCharacter.animatronic.rpi_config &&
                        this.selectedCharacter.animatronic.rpi_config.host) {

                        const characterHost = this.selectedCharacter.animatronic.rpi_config.host;
                        const characterName = this.selectedCharacter.char_name || this.selectedCharacter.name;

                        // For remote characters, log the connection and use legacy service checking
                        this.log(`Connecting to ${characterName} at ${characterHost}...`, 'info');

                        // Still call the API to log the remote connection
                        try {
                            await fetch(apiUrl);
                        } catch (error) {
                            console.log('API call for logging failed, continuing with remote service check:', error.message);
                        }

                        // Use legacy service checking for remote characters
                        this.log(`Checking services on remote character ${characterName} (${characterHost})`, 'info');
                        await this.renderLegacyServices();
                        return;
                    }

                    const response = await fetch(apiUrl);

                    if (response.status === 503) {
                        const errorData = await response.json();
                        if (errorData.legacy) {
                            this.handleLegacyFallback();
                            return;
                        }
                    }

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }

                    const connections = await response.json();

                    // Debounce updates - only render if connections have changed
                    const connectionsSnapshot = JSON.stringify(connections);
                    if (this.lastConnectionsSnapshot !== connectionsSnapshot) {
                        await this.renderServicesFromConnections(connections);
                        this.lastConnectionsSnapshot = connectionsSnapshot;
                        this.log('Service connections updated from centralized API', 'info');
                    }

                } catch (error) {
                    console.error('Error loading service connections:', error);
                    this.log(`Failed to load service connections: ${error.message}`, 'error');
                    this.handleLegacyFallback();
                }
            }

            async renderServicesFromConnections(connections) {
                const grid = document.getElementById('servicesGrid');
                grid.innerHTML = '';

                // Check if centralized system has services
                const hasServices = Object.keys(connections).length > 0;

                if (!hasServices) {
                    // Show legacy services that are actually running
                    await this.renderLegacyServices();
                    return;
                }

                // Define service display order and icons for centralized services
                const serviceOrder = [
                    { key: 'hardwareRegistry', name: 'Main Hardware Server', icon: '🔧', type: 'hardware' },
                    { key: 'motorService', name: 'Motor Service', icon: '🔄', type: 'motor' },
                    { key: 'lightService', name: 'Light Service', icon: '💡', type: 'light' },
                    { key: 'sensorService', name: 'Sensor Service', icon: '📡', type: 'sensor' },
                    { key: 'webcamService', name: 'Webcam Service', icon: '📹', type: 'webcam' },
                    { key: 'motionSensorService', name: 'Motion Sensor Service', icon: '🔍', type: 'motion' },
                    { key: 'headTrackingService', name: 'Head Tracking Service', icon: '🎯', type: 'tracking' },
                    { key: 'serviceRegistry', name: 'Service Registry', icon: '📋', type: 'registry' }
                ];

                serviceOrder.forEach(serviceConfig => {
                    const connection = connections[serviceConfig.key];
                    const card = document.createElement('div');
                    card.className = 'service-card';
                    card.dataset.serviceType = serviceConfig.type;

                    let status = 'offline';
                    let statusText = 'Offline';
                    let details = 'Service not found';
                    let port = 'N/A';

                    if (connection) {
                        status = connection.status === 'running' ? 'online' : 'offline';
                        statusText = connection.status === 'running' ? 'Online' : 'Offline';
                        port = connection.port || connection.proxyPort || 'N/A';
                        details = connection.description || `${connection.type} service`;
                    }

                    card.innerHTML = `
                        <div class="service-header">
                            <div class="service-icon">${serviceConfig.icon}</div>
                            <div class="service-name">${serviceConfig.name}</div>
                            <div class="status-indicator status-${status}" id="status-${serviceConfig.type}"></div>
                        </div>
                        <div class="service-details" id="details-${serviceConfig.type}">
                            <div>Port: ${port}</div>
                            <div id="status-text-${serviceConfig.type}">${statusText}</div>
                            <div>${details}</div>
                            <div>Last updated: ${new Date().toLocaleTimeString()}</div>
                        </div>
                    `;

                    grid.appendChild(card);
                });

                // Update overall system status
                this.updateOverallStatus();
            }

            handleLegacyFallback() {
                // Show fallback banner
                const systemStatus = document.getElementById('systemStatus');
                if (systemStatus) {
                    systemStatus.innerHTML = `
                        <div style="background: #331100; border: 1px solid #ff6600; padding: 10px; border-radius: 5px; margin-bottom: 10px;">
                            <strong style="color: #ff6600;">⚠️ Centralized service integration not available</strong><br>
                            <span style="color: #cccccc; font-size: 0.9em;">Showing expected services with unknown status. Direct service monitoring is disabled.</span>
                        </div>
                        <strong>System Status:</strong> <span id="overallStatus">Integration unavailable</span>
                    `;
                }

                // Render expected services with unknown status
                const expectedServices = [
                    { name: 'Main Hardware Server', port: 8780, icon: '🔧', type: 'hardware' },
                    { name: 'Motor Service', port: 8771, icon: '🔄', type: 'motor' },
                    { name: 'Light Service', port: 8772, icon: '💡', type: 'light' },
                    { name: 'Sensor Service', port: 8773, icon: '📡', type: 'sensor' },
                    { name: 'Webcam Service', port: 8774, icon: '📹', type: 'webcam' },
                    { name: 'Motion Sensor Service', port: 8777, icon: '🔍', type: 'motion' },
                    { name: 'Head Tracking Service', port: 8778, icon: '🎯', type: 'tracking' },
                    { name: 'Service Registry', port: 8770, icon: '📋', type: 'registry' }
                ];

                this.renderFallbackServices(expectedServices);
                this.log('Using legacy fallback mode - centralized integration unavailable', 'warning');

                // Update system status for fallback mode
                const statusElement = document.getElementById('overallStatus');
                if (statusElement) {
                    statusElement.textContent = 'All services offline - Hardware services not running. Services will show as online when hardware processes are started.';
                    statusElement.style.color = '#ff6b6b';
                }
            }

            async renderLegacyServices() {
                const grid = document.getElementById('servicesGrid');
                grid.innerHTML = '';

                // Get the currently selected character
                const selectedCharacter = this.selectedCharacter;
                const characterName = selectedCharacter ? (selectedCharacter.char_name || selectedCharacter.name) : 'Unknown';

                // Define services to check
                const allServices = [
                    { name: 'ElevenLabs Conversational AI', port: 8771, icon: '🤖', type: 'elevenlabs' },
                    { name: 'ElevenLabs Live STT', port: 8778, icon: '🎤', type: 'stt' },
                    { name: 'Microphone Service', port: 8776, icon: '🎙️', type: 'microphone' },
                    { name: 'ElevenLabs SSL Proxy', port: 8872, icon: '🔐', type: 'proxy-ssl' },
                    { name: 'STT SSL Proxy', port: 8873, icon: '🔐', type: 'proxy-stt' },
                    { name: 'Main Hardware Server', port: 8780, icon: '🔧', type: 'hardware' },
                    { name: 'Service Registry', port: 8770, icon: '📋', type: 'registry' },
                    { name: 'Light Service', port: 8772, icon: '💡', type: 'light' }
                ];

                // First render services with "checking" status
                this.renderServicesWithStatus(allServices, 'checking', characterName);

                // Then check each service status
                const serviceStatuses = await this.checkServiceStatuses(allServices, characterName);

                // Re-render with actual statuses
                this.renderServicesWithStatus(serviceStatuses, null, characterName);
            }

            async checkServiceStatuses(services, characterName) {
                // Use unified hub endpoint for consolidated status checking
                try {
                    const hubUrl = this.getHubUrl(characterName);
                    const response = await fetch(`${hubUrl}/api/hub/status`, {
                        method: 'GET',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        signal: AbortSignal.timeout(5000) // 5 second timeout
                    });

                    if (!response.ok) {
                        throw new Error(`Hub status request failed: ${response.status}`);
                    }

                    const hubData = await response.json();

                    // Convert hub response to expected format
                    return this.convertHubStatusToServiceList(hubData.services, services);

                } catch (error) {
                    this.log(`Hub status check failed for ${characterName}: ${error.message}`, 'warning');

                    // Fallback to individual service checks
                    return this.checkServiceStatusesIndividually(services, characterName);
                }
            }

            /**
             * Get hub URL for character
             */
            getHubUrl(characterName) {
                // For local character, use localhost
                if (characterName === 'Local' || !characterName) {
                    return 'http://localhost:3000';
                }

                // For remote characters, use their IP addresses
                const characterIPs = {
                    'PumpkinHead': 'https://192.168.1.200:8080',
                    'Skulltalker': 'https://192.168.1.201:8080',
                    'CoffinBreaker': 'https://192.168.1.202:8080',
                    'Orlok': 'https://192.168.1.203:8080'
                };

                return characterIPs[characterName] || 'http://localhost:3000';
            }

            /**
             * Convert hub status response to service list format
             */
            convertHubStatusToServiceList(hubServices, originalServices) {
                const convertedServices = [];

                for (const originalService of originalServices) {
                    const hubService = hubServices[originalService.name];

                    if (hubService) {
                        convertedServices.push({
                            ...originalService,
                            status: hubService.status,
                            lastChecked: hubService.lastChecked,
                            details: hubService.details,
                            responseTime: hubService.responseTime
                        });
                    } else {
                        // Service not found in hub response
                        convertedServices.push({
                            ...originalService,
                            status: 'offline',
                            lastChecked: new Date().toLocaleTimeString(),
                            details: 'Service not found in hub response'
                        });
                    }
                }

                return convertedServices;
            }

            /**
             * Fallback to individual service checks (original method)
             */
            async checkServiceStatusesIndividually(services, characterName) {
                const promises = services.map(service => {
                    return this.checkServiceStatus(service, characterName)
                        .then(status => ({
                            ...service,
                            status: status.online ? 'online' : 'offline',
                            lastChecked: new Date().toLocaleTimeString(),
                            details: status.details
                        }))
                        .catch(error => ({
                            ...service,
                            status: 'offline',
                            lastChecked: new Date().toLocaleTimeString(),
                            details: `Error: ${error.message}`
                        }));
                });

                return Promise.all(promises);
            }

            checkServiceStatus(service, characterName) {
                // Check services for all characters - services may be available depending on configuration
                try {
                    const controller = new AbortController();
                    const timeoutId = setTimeout(() => controller.abort(), 3000);

                    // Try WebSocket connection for WebSocket services
                    if (['elevenlabs', 'stt', 'microphone', 'hardware', 'registry', 'light'].includes(service.type)) {
                        return this.checkWebSocketService(service.port, controller.signal);
                    }

                    // Try HTTPS connection for SSL proxy services
                    if (service.type.includes('proxy')) {
                        return this.checkHttpsService(service.port, controller.signal);
                    }

                    clearTimeout(timeoutId);
                    return Promise.resolve({ online: false, details: 'Unknown service type' });

                } catch (error) {
                    return Promise.resolve({ online: false, details: error.message });
                }
            }

            async checkWebSocketService(port, signal) {
                return new Promise((resolve) => {
                    try {
                        // Use the selected character's host if available, otherwise use current host
                        let hostname = window.location.hostname;
                        let isRemoteCharacter = false;

                        if (this.selectedCharacter && this.selectedCharacter.animatronic &&
                            this.selectedCharacter.animatronic.rpi_config &&
                            this.selectedCharacter.animatronic.rpi_config.host) {

                            const characterHost = this.selectedCharacter.animatronic.rpi_config.host;
                            const currentHostname = window.location.hostname;

                            // Check if this is actually the local system
                            // Compare with current hostname and common local addresses
                            const isLocalSystem = (
                                characterHost === currentHostname ||
                                characterHost === 'localhost' ||
                                characterHost === '127.0.0.1' ||
                                (currentHostname === 'skulltalker' && characterHost === '192.168.8.130') ||
                                (currentHostname === 'orlok' && characterHost === '192.168.8.140') ||
                                (currentHostname === 'pumpkinhead' && characterHost === '192.168.1.200')
                            );

                            if (!isLocalSystem) {
                                hostname = characterHost;
                                isRemoteCharacter = true;
                            }
                            // If it's the local system, keep hostname as window.location.hostname
                        }

                        console.log(`Checking WebSocket service on ${hostname}:${port} (isRemote: ${isRemoteCharacter})`);

                        // Determine protocols based on page security and character type
                        let protocols = [];
                        const isSecurePage = window.location.protocol === 'https:';

                        if (isSecurePage) {
                            // For HTTPS pages, only use WSS to avoid mixed content issues
                            protocols = [`wss://${hostname}:${port}`];
                        } else {
                            // For HTTP pages, try WSS first, then WS for remote characters
                            protocols = isRemoteCharacter ? [`wss://${hostname}:${port}`, `ws://${hostname}:${port}`] : [`wss://${hostname}:${port}`];
                        }

                        let attemptIndex = 0;

                        const tryConnection = () => {
                            if (attemptIndex >= protocols.length) {
                                resolve({ online: false, details: `All WebSocket connection attempts failed to ${hostname}:${port}` });
                                return;
                            }

                            const wsUrl = protocols[attemptIndex];
                            const ws = new WebSocket(wsUrl);

                            const timeout = setTimeout(() => {
                                ws.close();
                                attemptIndex++;
                                tryConnection();
                            }, 2000);

                            ws.onopen = () => {
                                clearTimeout(timeout);
                                ws.close();
                                resolve({ online: true, details: `WebSocket connection successful to ${hostname}:${port}` });
                            };

                            ws.onerror = () => {
                                clearTimeout(timeout);
                                attemptIndex++;
                                tryConnection();
                            };

                            if (signal.aborted) {
                                clearTimeout(timeout);
                                ws.close();
                                resolve({ online: false, details: 'Request aborted' });
                            }
                        };

                        tryConnection();

                    } catch (error) {
                        resolve({ online: false, details: `WebSocket error: ${error.message}` });
                    }
                });
            }

            async checkHttpsService(port, signal) {
                // Use the selected character's host if available, otherwise use current host
                let hostname = window.location.hostname;

                if (this.selectedCharacter && this.selectedCharacter.animatronic &&
                    this.selectedCharacter.animatronic.rpi_config &&
                    this.selectedCharacter.animatronic.rpi_config.host) {
                    hostname = this.selectedCharacter.animatronic.rpi_config.host;
                }

                try {
                    const response = await fetch(`https://${hostname}:${port}`, {
                        method: 'GET',
                        signal: signal,
                        timeout: 2000
                    });

                    return {
                        online: true,
                        details: `HTTPS proxy responding from ${hostname}:${port} (${response.status})`
                    };
                } catch (error) {
                    if (error.name === 'AbortError') {
                        return { online: false, details: 'Request timeout' };
                    }
                    return {
                        online: false,
                        details: `HTTPS connection failed to ${hostname}:${port} - ${error.message}`
                    };
                }
            }

            renderServicesWithStatus(services, defaultStatus, characterName) {
                const grid = document.getElementById('servicesGrid');
                grid.innerHTML = '';

                services.forEach(service => {
                    const card = document.createElement('div');
                    card.className = 'service-card';
                    card.dataset.serviceType = service.type;
                    card.dataset.servicePort = service.port;

                    let statusClass, statusText, statusDetail;

                    if (defaultStatus === 'checking') {
                        statusClass = 'status-unknown';
                        statusText = 'Checking...';
                        statusDetail = 'Testing connection';
                    } else {
                        statusClass = service.status === 'online' ? 'status-online' : 'status-offline';
                        statusText = service.status === 'online' ? 'Online' : 'Offline';
                        statusDetail = service.details || (service.status === 'online' ? 'Service running' : 'Service not found');
                    }

                    card.innerHTML = `
                        <div class="service-header">
                            <div class="service-icon">${service.icon}</div>
                            <div class="service-name">${service.name}</div>
                            <div class="status-indicator ${statusClass}" id="status-${service.type}"></div>
                        </div>
                        <div class="service-details" id="details-${service.type}">
                            <div>Port: ${service.port}</div>
                            <div id="status-text-${service.type}">${statusText}</div>
                            <div>${statusDetail}</div>
                            <div>Last checked: ${service.lastChecked || 'N/A'}</div>
                        </div>
                    `;

                    grid.appendChild(card);
                });

                // Update system status (only if not checking)
                if (defaultStatus !== 'checking') {
                    const onlineCount = services.filter(s => s.status === 'online').length;
                    const totalCount = services.length;
                    const statusElement = document.getElementById('overallStatus');
                    if (statusElement) {
                        if (onlineCount > 0) {
                            statusElement.textContent = `${onlineCount}/${totalCount} services online for ${characterName}`;
                            statusElement.style.color = '#00ff00';
                        } else {
                            statusElement.textContent = `All services offline for ${characterName}`;
                            statusElement.style.color = '#ff6b6b';
                        }
                    }

                    this.log(`Found ${onlineCount} online services for ${characterName}`, 'info');
                }
            }

            renderFallbackServices(services) {
                const grid = document.getElementById('servicesGrid');
                grid.innerHTML = '';

                services.forEach(service => {
                    const card = document.createElement('div');
                    card.className = 'service-card';
                    card.dataset.serviceType = service.type;
                    card.dataset.servicePort = service.port;

                    card.innerHTML = `
                        <div class="service-header">
                            <div class="service-icon">${service.icon}</div>
                            <div class="service-name">${service.name}</div>
                            <div class="status-indicator status-unknown" id="status-${service.type}"></div>
                        </div>
                        <div class="service-details" id="details-${service.type}">
                            <div>Port: ${service.port}</div>
                            <div id="status-text-${service.type}">Unknown</div>
                            <div>Status monitoring unavailable</div>
                            <div>Last checked: N/A</div>
                        </div>
                    `;

                    grid.appendChild(card);
                });
            }

            startPolling() {
                // Clear any existing polling interval
                if (this.pollingInterval) {
                    clearInterval(this.pollingInterval);
                }

                // Only start polling if connected to a character
                if (!this.isConnected || !this.selectedCharacter) {
                    this.log('Not starting polling - no character connected', 'info');
                    return;
                }

                // Initial load
                this.loadServiceConnections();

                // Poll every 10 seconds
                this.pollingInterval = setInterval(() => {
                    this.loadServiceConnections();
                }, 10000);

                const characterName = this.selectedCharacter.char_name || this.selectedCharacter.name;
                this.log(`Started polling service connections for ${characterName} every 10 seconds`, 'info');
            }

            stopPolling() {
                if (this.pollingInterval) {
                    clearInterval(this.pollingInterval);
                    this.pollingInterval = null;
                    this.log('Stopped polling service connections', 'info');
                }
            }

            updateServiceStatus(service, status, message) {
                const statusIndicator = document.getElementById(`status-${service.type}`);
                const statusText = document.getElementById(`status-text-${service.type}`);
                const details = document.getElementById(`details-${service.type}`);

                if (statusIndicator && statusText && details) {
                    statusIndicator.className = `status-indicator status-${status}`;
                    statusText.textContent = status === 'online' ? 'Online' : 'Offline';

                    const timestamp = new Date().toLocaleTimeString();
                    details.innerHTML = `
                        <div>Port: ${service.port}</div>
                        <div>${message}</div>
                        <div>Last checked: ${timestamp}</div>
                    `;

                    // Only log status changes, not repeated failures
                    if (!service.lastStatus || service.lastStatus !== status) {
                        this.log(`${service.name}: ${status} - ${message}`, status === 'online' ? 'info' : 'warning');
                        service.lastStatus = status;
                    }
                }

                // Update overall system status
                this.updateOverallStatus();
            }

            updateOverallStatus() {
                const statusElements = document.querySelectorAll('.status-indicator');
                let onlineCount = 0;
                let totalCount = statusElements.length;

                statusElements.forEach(element => {
                    if (element.classList.contains('status-online')) {
                        onlineCount++;
                    }
                });

                const overallStatusElement = document.getElementById('overallStatus');
                if (overallStatusElement) {
                    if (onlineCount === 0) {
                        overallStatusElement.innerHTML = '<span style="color: #ff6666;">All services offline</span> - <span style="color: #888;">Hardware services not running. Services will show as online when hardware processes are started.</span>';
                    } else if (onlineCount === totalCount) {
                        overallStatusElement.innerHTML = '<span style="color: #00ff00;">All services online</span> - <span style="color: #888;">Hardware services are running normally.</span>';
                    } else {
                        overallStatusElement.innerHTML = `<span style="color: #ffff00;">${onlineCount}/${totalCount} services online</span> - <span style="color: #888;">Some services may be starting up or unavailable.</span>`;
                    }
                }
            }

            setupEventListeners() {
                // Connection control event listeners
                const connectBtn = document.getElementById('connectBtn');
                const disconnectBtn = document.getElementById('disconnectBtn');

                if (connectBtn) {
                    connectBtn.addEventListener('click', () => this.connectToCharacter());
                }

                if (disconnectBtn) {
                    disconnectBtn.addEventListener('click', () => this.disconnectFromCharacter());
                }
            }

            showConnectionControls() {
                const connectionControls = document.getElementById('connectionControls');
                if (connectionControls) {
                    connectionControls.style.display = 'flex';
                }
            }

            hideConnectionControls() {
                const connectionControls = document.getElementById('connectionControls');
                if (connectionControls) {
                    connectionControls.style.display = 'none';
                }
            }

            updateConnectionStatus() {
                const statusText = document.getElementById('connectionStatusText');
                const connectBtn = document.getElementById('connectBtn');
                const disconnectBtn = document.getElementById('disconnectBtn');

                if (!this.selectedCharacter) {
                    if (statusText) statusText.textContent = 'No character selected';
                    if (connectBtn) connectBtn.disabled = true;
                    if (disconnectBtn) disconnectBtn.disabled = true;
                    return;
                }

                const characterName = this.selectedCharacter.char_name || this.selectedCharacter.name;

                if (this.isConnected) {
                    if (statusText) statusText.textContent = `Connected to ${characterName}`;
                    if (connectBtn) connectBtn.disabled = true;
                    if (disconnectBtn) disconnectBtn.disabled = false;
                } else {
                    if (statusText) statusText.textContent = `Ready to connect to ${characterName}`;
                    if (connectBtn) connectBtn.disabled = false;
                    if (disconnectBtn) disconnectBtn.disabled = true;
                }
            }

            async connectToCharacter() {
                if (!this.selectedCharacter) {
                    this.log('No character selected for connection', 'error');
                    return;
                }

                const characterName = this.selectedCharacter.char_name || this.selectedCharacter.name;
                const characterHost = this.selectedCharacter.animatronic &&
                                    this.selectedCharacter.animatronic.rpi_config &&
                                    this.selectedCharacter.animatronic.rpi_config.host
                                    ? this.selectedCharacter.animatronic.rpi_config.host
                                    : 'localhost';

                this.log(`Connecting to ${characterName} at ${characterHost}...`, 'info');
                console.log('Selected character data:', this.selectedCharacter);

                try {
                    // Reset connections and point to the selected character
                    this.stopPolling();
                    this.serviceConnections = {};
                    this.lastConnectionsSnapshot = null;

                    // Mark as connected
                    this.isConnected = true;
                    this.updateConnectionStatus();

                    // Restart service monitoring for the selected character
                    this.startPolling();

                    this.log(`Successfully connected to ${characterName} at ${characterHost}`, 'success');

                } catch (error) {
                    this.log(`Failed to connect to ${characterName}: ${error.message}`, 'error');
                    this.isConnected = false;
                    this.updateConnectionStatus();
                }
            }

            async disconnectFromCharacter() {
                if (!this.selectedCharacter) {
                    this.log('No character selected for disconnection', 'error');
                    return;
                }

                const characterName = this.selectedCharacter.char_name || this.selectedCharacter.name;
                this.log(`Disconnecting from ${characterName}...`, 'info');

                try {
                    // Stop polling and clear connections
                    this.stopPolling();
                    this.serviceConnections = {};
                    this.lastConnectionsSnapshot = null;

                    // Clear services display
                    const grid = document.getElementById('servicesGrid');
                    if (grid) {
                        grid.innerHTML = '<div style="text-align: center; color: #888; padding: 20px;">Disconnected - Click Connect to monitor services</div>';
                    }

                    // Mark as disconnected
                    this.isConnected = false;
                    this.updateConnectionStatus();

                    this.log(`Successfully disconnected from ${characterName}`, 'info');

                } catch (error) {
                    this.log(`Error during disconnection: ${error.message}`, 'error');
                }
            }

            log(message, type = 'info') {
                const logContainer = document.getElementById('logContainer');
                const timestamp = new Date().toLocaleTimeString();

                const logEntry = document.createElement('div');
                logEntry.className = `log-entry log-${type}`;
                logEntry.textContent = `[${timestamp}] ${message}`;

                logContainer.appendChild(logEntry);

                // Remove old entries if we have too many
                const entries = logContainer.querySelectorAll('.log-entry');
                if (entries.length > this.maxLogEntries) {
                    entries[0].remove();
                }

                // Auto-scroll to bottom
                logContainer.scrollTop = logContainer.scrollHeight;
            }
        }

        // Initialize the Services Monitor when the page loads
        document.addEventListener('DOMContentLoaded', function() {
            window.servicesMonitor = new ServicesMonitor();
        });
    </script>
</body>
</html>
