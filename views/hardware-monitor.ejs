            async checkServiceStatuses(services, characterName) {
                // Use unified hub endpoint for consolidated status checking
                try {
                    const hubUrl = this.getHubUrl(characterName);
                    console.log(`🎯 Hub status check: ${characterName} -> ${hubUrl}`);

                    const response = await fetch(`${hubUrl}/api/hub/status`, {
                        method: 'GET',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        signal: AbortSignal.timeout(5000) // 5 second timeout
                    });

                    if (!response.ok) {
                        throw new Error(`Hub status request failed: ${response.status}`);
                    }

                    const hubData = await response.json();
                    console.log(`✅ Hub data received for ${characterName}:`, hubData.summary);

                    // Convert hub response to expected format
                    return this.convertHubStatusToServiceList(hubData.services, services);

                } catch (error) {
                    console.log(`❌ Hub status check failed for ${characterName}: ${error.message}`);
                    this.log(`Hub status check failed for ${characterName}: ${error.message}`, 'warning');

                    // Fallback to individual service checks
                    return this.checkServiceStatusesIndividually(services, characterName);
                }
            }

            /**
             * Get hub URL for character
             */
            getHubUrl(characterName) {
                // For local character, use localhost
                if (characterName === 'Local' || !characterName) {
                    return 'http://localhost:3000';
                }

                // For remote characters, use their IP addresses
                // Handle both character names and hostnames
                const characterIPs = {
                    'PumpkinHead': 'https://192.168.8.150:8080',
                    'pumpkinhead': 'https://192.168.8.150:8080',
                    'Skulltalker': 'https://10.10.10.78:8080',
                    'skulltalker': 'https://10.10.10.78:8080',
                    'CoffinBreaker': 'https://192.168.8.140:8080',
                    'coffin': 'https://192.168.8.140:8080',
                    'Orlok': 'https://192.168.8.120:8080',
                    'orlok': 'https://192.168.8.120:8080'
                };

                // Try exact match first, then lowercase
                const hubUrl = characterIPs[characterName] || characterIPs[characterName.toLowerCase()];

                // If we're on Skulltalker (localhost), return localhost for local testing
                if (!hubUrl && window.location.hostname === 'localhost') {
                    return 'http://localhost:3000';
                }

                return hubUrl || 'http://localhost:3000';
            }

            /**
             * Convert hub status response to service list format
             */
            convertHubStatusToServiceList(hubServices, originalServices) {
                const convertedServices = [];

                for (const originalService of originalServices) {
                    const hubService = hubServices[originalService.name];

                    if (hubService) {
                        convertedServices.push({
                            ...originalService,
                            status: hubService.status,
                            lastChecked: hubService.lastChecked,
                            details: hubService.details,
                            responseTime: hubService.responseTime
                        });
                    } else {
                        // Service not found in hub response
                        convertedServices.push({
                            ...originalService,
                            status: 'offline',
                            lastChecked: new Date().toLocaleTimeString(),
                            details: 'Service not found in hub response'
                        });
                    }
                }

                return convertedServices;
            }

            /**
             * Fallback to individual service checks (original method)
             */
            async checkServiceStatusesIndividually(services, characterName) {
                const promises = services.map(service => {
                    return this.checkServiceStatus(service, characterName)
                        .then(status => ({
                            ...service,
                            status: status.online ? 'online' : 'offline',
                            lastChecked: new Date().toLocaleTimeString(),
                            details: status.details
                        }))
                        .catch(error => ({
                            ...service,
                            status: 'offline',
                            lastChecked: new Date().toLocaleTimeString(),
                            details: `Error: ${error.message}`
                        }));
                });

                return Promise.all(promises);
            }

            checkServiceStatus(service, characterName) {
                // Check services for all characters - services may be available depending on configuration
                try {
                    const controller = new AbortController();
                    const timeoutId = setTimeout(() => controller.abort(), 3000);

                    // Try WebSocket connection for WebSocket services
                    if (['elevenlabs', 'stt', 'microphone', 'hardware', 'registry', 'light'].includes(service.type)) {
                        return this.checkWebSocketService(service.port, controller.signal);
                    }

                    // Try HTTPS connection for SSL proxy services
                    if (service.type.includes('proxy')) {
                        return this.checkHttpsService(service.port, controller.signal);
                    }

                    clearTimeout(timeoutId);
                    return Promise.resolve({ online: false, details: 'Unknown service type' });

                } catch (error) {
                    return Promise.resolve({ online: false, details: error.message });
                }
            }

            async checkWebSocketService(port, signal) {
                return new Promise((resolve) => {
                    try {
                        // Use the selected character's host if available, otherwise use current host
                        let hostname = window.location.hostname;
                        let isRemoteCharacter = false;

                        if (this.selectedCharacter && this.selectedCharacter.animatronic &&
                            this.selectedCharacter.animatronic.rpi_config &&
                            this.selectedCharacter.animatronic.rpi_config.host) {

                            const characterHost = this.selectedCharacter.animatronic.rpi_config.host;
                            const currentHostname = window.location.hostname;

                            // Check if this is actually the local system
                            // Compare with current hostname and common local addresses
                            const isLocalSystem = (
                                characterHost === currentHostname ||
                                characterHost === 'localhost' ||
                                characterHost === '127.0.0.1' ||
                                (currentHostname === 'skulltalker' && characterHost === '192.168.8.130') ||
                                (currentHostname === 'orlok' && characterHost === '192.168.8.140') ||
                                (currentHostname === 'pumpkinhead' && characterHost === '192.168.1.200')
                            );

                            if (!isLocalSystem) {
                                hostname = characterHost;
                                isRemoteCharacter = true;
                            }
                            // If it's the local system, keep hostname as window.location.hostname
                        }

                        console.log(`Checking WebSocket service on ${hostname}:${port} (isRemote: ${isRemoteCharacter})`);

                        // Determine protocols based on page security and character type
                        let protocols = [];
                        const isSecurePage = window.location.protocol === 'https:';

                        if (isSecurePage) {
                            // For HTTPS pages, only use WSS to avoid mixed content issues
                            protocols = [`wss://${hostname}:${port}`];
                        } else {
                            // For HTTP pages, try WSS first, then WS for remote characters
                            protocols = isRemoteCharacter ? [`wss://${hostname}:${port}`, `ws://${hostname}:${port}`] : [`wss://${hostname}:${port}`];
                        }

                        let attemptIndex = 0;

                        const tryConnection = () => {
                            if (attemptIndex >= protocols.length) {
                                resolve({ online: false, details: `All WebSocket connection attempts failed to ${hostname}:${port}` });
                                return;
                            }

                            const wsUrl = protocols[attemptIndex];
                            const ws = new WebSocket(wsUrl);

                            const timeout = setTimeout(() => {
                                ws.close();
                                attemptIndex++;
                                tryConnection();
                            }, 2000);

                            ws.onopen = () => {
                                clearTimeout(timeout);
                                ws.close();
                                resolve({ online: true, details: `WebSocket connection successful to ${hostname}:${port}` });
                            };

                            ws.onerror = () => {
                                clearTimeout(timeout);
                                attemptIndex++;
                                tryConnection();
                            };

                            if (signal.aborted) {
                                clearTimeout(timeout);
                                ws.close();
                                resolve({ online: false, details: 'Request aborted' });
                            }
                        };

                        tryConnection();

                    } catch (error) {
                        resolve({ online: false, details: `WebSocket error: ${error.message}` });
                    }
                });
            }

            async checkHttpsService(port, signal) {
                // Use the selected character's host if available, otherwise use current host
                let hostname = window.location.hostname;

                if (this.selectedCharacter && this.selectedCharacter.animatronic &&
                    this.selectedCharacter.animatronic.rpi_config &&
                    this.selectedCharacter.animatronic.rpi_config.host) {
                    hostname = this.selectedCharacter.animatronic.rpi_config.host;
                }

                try {
                    const response = await fetch(`https://${hostname}:${port}`, {
                        method: 'GET',
                        signal: signal,
                        timeout: 2000
                    });

                    return {
                        online: true,
                        details: `HTTPS proxy responding from ${hostname}:${port} (${response.status})`
                    };
                } catch (error) {
                    if (error.name === 'AbortError') {
                        return { online: false, details: 'Request timeout' };
                    }
                    return {
                        online: false,
                        details: `HTTPS connection failed to ${hostname}:${port} - ${error.message}`
                    };
                }
            }

            renderServicesWithStatus(services, defaultStatus, characterName) {
                const grid = document.getElementById('servicesGrid');
                grid.innerHTML = '';

                services.forEach(service => {
                    const card = document.createElement('div');
                    card.className = 'service-card';
                    card.dataset.serviceType = service.type;
                    card.dataset.servicePort = service.port;

                    let statusClass, statusText, statusDetail;

                    if (defaultStatus === 'checking') {
                        statusClass = 'status-unknown';
                        statusText = 'Checking...';
                        statusDetail = 'Testing connection';
                    } else {
                        statusClass = service.status === 'online' ? 'status-online' : 'status-offline';
                        statusText = service.status === 'online' ? 'Online' : 'Offline';
                        statusDetail = service.details || (service.status === 'online' ? 'Service running' : 'Service not found');
                    }

                    card.innerHTML = `
                        <div class="service-header">
                            <div class="service-icon">${service.icon}</div>
                            <div class="service-name">${service.name}</div>
                            <div class="status-indicator ${statusClass}" id="status-${service.type}"></div>
                        </div>
                        <div class="service-details" id="details-${service.type}">
                            <div>Port: ${service.port}</div>
                            <div id="status-text-${service.type}">${statusText}</div>
                            <div>${statusDetail}</div>
                            <div>Last checked: ${service.lastChecked || 'N/A'}</div>
                        </div>
                    `;

                    grid.appendChild(card);
                });

                // Update system status (only if not checking)
                if (defaultStatus !== 'checking') {
                    const onlineCount = services.filter(s => s.status === 'online').length;
                    const totalCount = services.length;
                    const statusElement = document.getElementById('overallStatus');
                    if (statusElement) {
                        if (onlineCount > 0) {
                            statusElement.textContent = `${onlineCount}/${totalCount} services online for ${characterName}`;
                            statusElement.style.color = '#00ff00';
                        } else {
                            statusElement.textContent = `All services offline for ${characterName}`;
                            statusElement.style.color = '#ff6b6b';
                        }
                    }

                    this.log(`Found ${onlineCount} online services for ${characterName}`, 'info');
                }
            }

            renderFallbackServices(services) {
                const grid = document.getElementById('servicesGrid');
                grid.innerHTML = '';

                services.forEach(service => {
                    const card = document.createElement('div');
                    card.className = 'service-card';
                    card.dataset.serviceType = service.type;
                    card.dataset.servicePort = service.port;

                    card.innerHTML = `
                        <div class="service-header">
                            <div class="service-icon">${service.icon}</div>
                            <div class="service-name">${service.name}</div>
                            <div class="status-indicator status-unknown" id="status-${service.type}"></div>
                        </div>
                        <div class="service-details" id="details-${service.type}">
                            <div>Port: ${service.port}</div>
                            <div id="status-text-${service.type}">Unknown</div>
                            <div>Status monitoring unavailable</div>
                            <div>Last checked: N/A</div>
                        </div>
                    `;

                    grid.appendChild(card);
                });
            }

            startPolling() {
                // Clear any existing polling interval
                if (this.pollingInterval) {
                    clearInterval(this.pollingInterval);
                }

                // Only start polling if connected to a character
                if (!this.isConnected || !this.selectedCharacter) {
                    this.log('Not starting polling - no character connected', 'info');
                    return;
                }

                // Initial load
                this.loadServiceConnections();

                // Poll every 10 seconds
                this.pollingInterval = setInterval(() => {
                    this.loadServiceConnections();
                }, 10000);

                const characterName = this.selectedCharacter.char_name || this.selectedCharacter.name;
                this.log(`Started polling service connections for ${characterName} every 10 seconds`, 'info');
            }

            stopPolling() {
                if (this.pollingInterval) {
                    clearInterval(this.pollingInterval);
                    this.pollingInterval = null;
                    this.log('Stopped polling service connections', 'info');
                }
            }

            updateServiceStatus(service, status, message) {
                const statusIndicator = document.getElementById(`status-${service.type}`);
                const statusText = document.getElementById(`status-text-${service.type}`);
                const details = document.getElementById(`details-${service.type}`);

                if (statusIndicator && statusText && details) {
                    statusIndicator.className = `status-indicator status-${status}`;
                    statusText.textContent = status === 'online' ? 'Online' : 'Offline';

                    const timestamp = new Date().toLocaleTimeString();
                    details.innerHTML = `
                        <div>Port: ${service.port}</div>
                        <div>${message}</div>
                        <div>Last checked: ${timestamp}</div>
                    `;

                    // Only log status changes, not repeated failures
                    if (!service.lastStatus || service.lastStatus !== status) {
                        this.log(`${service.name}: ${status} - ${message}`, status === 'online' ? 'info' : 'warning');
                        service.lastStatus = status;
                    }
                }

                // Update overall system status
                this.updateOverallStatus();
            }

            updateOverallStatus() {
                const statusElements = document.querySelectorAll('.status-indicator');
                let onlineCount = 0;
                let totalCount = statusElements.length;

                statusElements.forEach(element => {
                    if (element.classList.contains('status-online')) {
                        onlineCount++;
                    }
                });

                const overallStatusElement = document.getElementById('overallStatus');
                if (overallStatusElement) {
                    if (onlineCount === 0) {
                        overallStatusElement.innerHTML = '<span style="color: #ff6666;">All services offline</span> - <span style="color: #888;">Hardware services not running. Services will show as online when hardware processes are started.</span>';
                    } else if (onlineCount === totalCount) {
                        overallStatusElement.innerHTML = '<span style="color: #00ff00;">All services online</span> - <span style="color: #888;">Hardware services are running normally.</span>';
                    } else {
                        overallStatusElement.innerHTML = `<span style="color: #ffff00;">${onlineCount}/${totalCount} services online</span> - <span style="color: #888;">Some services may be starting up or unavailable.</span>`;
                    }
                }
            }

            setupEventListeners() {
                // Refresh all button
                const refreshAllBtn = document.getElementById('refreshAllBtn');
                if (refreshAllBtn) {
                    refreshAllBtn.addEventListener('click', () => this.refreshFleetStatus());
                }

                // Modal close button
                const closeModal = document.getElementById('closeModal');
                if (closeModal) {
                    closeModal.addEventListener('click', () => this.closeModal());
                }

                // Close modal when clicking outside
                const modal = document.getElementById('characterModal');
                if (modal) {
                    modal.addEventListener('click', (e) => {
                        if (e.target === modal) {
                            this.closeModal();
                        }
                    });
                }

                // Keyboard shortcuts
                document.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape') {
                        this.closeModal();
                    }
                    if (e.key === 'F5' || (e.ctrlKey && e.key === 'r')) {
                        e.preventDefault();
                        this.refreshFleetStatus();
                    }
                });
            }

            closeModal() {
                const modal = document.getElementById('characterModal');
                if (modal) {
                    modal.style.display = 'none';
                }
                this.selectedCharacter = null;
            }

            showConnectionControls() {
                const connectionControls = document.getElementById('connectionControls');
                if (connectionControls) {
                    connectionControls.style.display = 'flex';
                }
            }

            hideConnectionControls() {
                const connectionControls = document.getElementById('connectionControls');
                if (connectionControls) {
                    connectionControls.style.display = 'none';
                }
            }

            updateConnectionStatus() {
                const statusText = document.getElementById('connectionStatusText');
                const connectBtn = document.getElementById('connectBtn');
                const disconnectBtn = document.getElementById('disconnectBtn');

                if (!this.selectedCharacter) {
                    if (statusText) statusText.textContent = 'No character selected';
                    if (connectBtn) connectBtn.disabled = true;
                    if (disconnectBtn) disconnectBtn.disabled = true;
                    return;
                }

                const characterName = this.selectedCharacter.char_name || this.selectedCharacter.name;

                if (this.isConnected) {
                    if (statusText) statusText.textContent = `Connected to ${characterName}`;
                    if (connectBtn) connectBtn.disabled = true;
                    if (disconnectBtn) disconnectBtn.disabled = false;
                } else {
                    if (statusText) statusText.textContent = `Ready to connect to ${characterName}`;
                    if (connectBtn) connectBtn.disabled = false;
                    if (disconnectBtn) disconnectBtn.disabled = true;
                }
            }

            async connectToCharacter() {
                if (!this.selectedCharacter) {
                    this.log('No character selected for connection', 'error');
                    return;
                }

                const characterName = this.selectedCharacter.char_name || this.selectedCharacter.name;
                const characterHost = this.selectedCharacter.animatronic &&
                                    this.selectedCharacter.animatronic.rpi_config &&
                                    this.selectedCharacter.animatronic.rpi_config.host
                                    ? this.selectedCharacter.animatronic.rpi_config.host
                                    : 'localhost';

                this.log(`Connecting to ${characterName} at ${characterHost}...`, 'info');
                console.log('Selected character data:', this.selectedCharacter);

                try {
                    // Reset connections and point to the selected character
                    this.stopPolling();
                    this.serviceConnections = {};
                    this.lastConnectionsSnapshot = null;

                    // Mark as connected
                    this.isConnected = true;
                    this.updateConnectionStatus();

                    // Restart service monitoring for the selected character
                    this.startPolling();

                    this.log(`Successfully connected to ${characterName} at ${characterHost}`, 'success');

                } catch (error) {
                    this.log(`Failed to connect to ${characterName}: ${error.message}`, 'error');
                    this.isConnected = false;
                    this.updateConnectionStatus();
                }
            }

            async disconnectFromCharacter() {
                if (!this.selectedCharacter) {
                    this.log('No character selected for disconnection', 'error');
                    return;
                }

                const characterName = this.selectedCharacter.char_name || this.selectedCharacter.name;
                this.log(`Disconnecting from ${characterName}...`, 'info');

                try {
                    // Stop polling and clear connections
                    this.stopPolling();
                    this.serviceConnections = {};
                    this.lastConnectionsSnapshot = null;

                    // Clear services display
                    const grid = document.getElementById('servicesGrid');
                    if (grid) {
                        grid.innerHTML = '<div style="text-align: center; color: #888; padding: 20px;">Disconnected - Click Connect to monitor services</div>';
                    }

                    // Mark as disconnected
                    this.isConnected = false;
                    this.updateConnectionStatus();

                    this.log(`Successfully disconnected from ${characterName}`, 'info');

                } catch (error) {
                    this.log(`Error during disconnection: ${error.message}`, 'error');
                }
            }

            log(message, type = 'info') {
                const logContainer = document.getElementById('logContainer');
                const timestamp = new Date().toLocaleTimeString();

                const logEntry = document.createElement('div');
                logEntry.className = `log-entry log-${type}`;
                logEntry.textContent = `[${timestamp}] ${message}`;

                logContainer.appendChild(logEntry);

                // Remove old entries if we have too many
                const entries = logContainer.querySelectorAll('.log-entry');
                if (entries.length > this.maxLogEntries) {
                    entries[0].remove();
                }

                // Auto-scroll to bottom
                logContainer.scrollTop = logContainer.scrollHeight;
            }
        }

        // Initialize the Fleet Monitor when the page loads
        document.addEventListener('DOMContentLoaded', function() {
            window.fleetMonitor = new FleetMonitor();
        });
    </script>
</body>
</html>
