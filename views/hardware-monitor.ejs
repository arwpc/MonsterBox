            async loadServiceConnections() {
                try {
                    // Determine which host to query for service connections
                    let apiUrl = '/api/service-management/connections';

                    // If connected to a remote character, query their services directly
                    if (this.selectedCharacter && this.selectedCharacter.animatronic &&
                        this.selectedCharacter.animatronic.rpi_config &&
                        this.selectedCharacter.animatronic.rpi_config.host) {

                        const characterHost = this.selectedCharacter.animatronic.rpi_config.host;
                        const characterName = this.selectedCharacter.char_name || this.selectedCharacter.name;

                        // For remote characters, log the connection and use legacy service checking
                        this.log(`Connecting to ${characterName} at ${characterHost}...`, 'info');

                        // Still call the API to log the remote connection
                        try {
                            await fetch(apiUrl);
                        } catch (error) {
                            console.log('API call for logging failed, continuing with remote service check:', error.message);
                        }

                        // Use legacy service checking for remote characters
                        this.log(`Checking services on remote character ${characterName} (${characterHost})`, 'info');
                        await this.renderLegacyServices();
                        return;
                    }

                    const response = await fetch(apiUrl);

                    if (response.status === 503) {
                        const errorData = await response.json();
                        if (errorData.legacy) {
                            this.handleLegacyFallback();
                            return;
                        }
                    }

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }

                    const connections = await response.json();

                    // Debounce updates - only render if connections have changed
                    const connectionsSnapshot = JSON.stringify(connections);
                    if (this.lastConnectionsSnapshot !== connectionsSnapshot) {
                        await this.renderServicesFromConnections(connections);
                        this.lastConnectionsSnapshot = connectionsSnapshot;
                        this.log('Service connections updated from centralized API', 'info');
                    }

                } catch (error) {
                    console.error('Error loading service connections:', error);
                    this.log(`Failed to load service connections: ${error.message}`, 'error');
                    this.handleLegacyFallback();
                }
            }

