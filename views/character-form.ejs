<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .character-dashboard {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .character-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .character-card {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        .custom-file-upload:hover {
            background-color: #cc0000;
        }

        /* Audio Configuration Styles */
        .audio-config-container {
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            padding: 20px;
            margin: 15px 0;
        }

        .audio-settings {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 20px;
        }

        .audio-settings .form-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .audio-settings .form-group label {
            color: #00ff00;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .audio-settings input[type="range"] {
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 4px;
        }

        .setting-value {
            color: #00ff00;
            font-weight: bold;
            min-width: 40px;
            text-align: center;
        }

        .microphone-test-section {
            border-top: 1px solid #00ff00;
            padding-top: 20px;
            margin-top: 20px;
        }

        .microphone-test-section h4 {
            color: #00ff00;
            margin-bottom: 15px;
        }

        /* Enhanced Audio Configuration Styles */
        .config-section {
            background: #000600;
            border: 1px solid #00cc00;
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
        }

        .config-section h4 {
            color: #00ff00;
            margin: 0 0 15px 0;
            font-size: 1.1em;
            border-bottom: 1px solid #00cc00;
            padding-bottom: 8px;
        }

        .settings-loading {
            text-align: center;
            color: #cccccc;
            padding: 20px;
        }

        .settings-loading i {
            margin-right: 10px;
            color: #00ff00;
        }

        .config-error {
            background: #330000;
            border: 1px solid #ff0000;
            border-radius: 8px;
            padding: 15px;
            color: #ff6666;
            text-align: center;
        }

        .config-error i {
            margin-right: 10px;
            color: #ff0000;
        }

        .config-error button {
            background: #ff0000;
            border: none;
            color: white;
            padding: 5px 15px;
            border-radius: 4px;
            margin-left: 10px;
            cursor: pointer;
        }

        .config-actions {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid #00cc00;
        }

        .form-message {
            padding: 10px 15px;
            margin: 10px 0;
            border-radius: 5px;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideIn 0.3s ease;
        }

        .form-message-info {
            background: #003366;
            border: 1px solid #0066cc;
            color: #66ccff;
        }

        .form-message-success {
            background: #003300;
            border: 1px solid #00ff00;
            color: #66ff66;
        }

        .form-message-error {
            background: #330000;
            border: 1px solid #ff0000;
            color: #ff6666;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 768px) {
            .audio-settings {
                grid-template-columns: 1fr;
            }

            .config-actions {
                flex-direction: column;
            }
        }
    </style>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/js/shared-streaming-service.js"></script>
</head>
<body>
    <%- include('components/universal-header') %>

    <main class="character-dashboard">
        <form action="<%= action %>" method="POST" enctype="multipart/form-data">
            <% if (character && character.id) { %>
                <input type="hidden" name="id" value="<%= character.id %>">
            <% } %>

            <div class="character-grid">
                <!-- Character Image Card -->
                <div class="character-card">
                    <div class="card-header">
                        <span class="card-icon">🖼️</span>
                        <h3 class="card-title">Character Image</h3>
                    </div>

                    <div style="text-align: center;">
                        <% if (character && character.image) { %>
                            <img src="/images/characters/<%= character.image %>" alt="Character image" class="image-preview">
                        <% } else { %>
                            <div class="image-preview" style="background-color: #002200; display: flex; align-items: center; justify-content: center;">
                                <span>No Image Selected</span>
                            </div>
                        <% } %>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="character_image" class="custom-file-upload">
                                Upload Picture
                            </label>
                            <input type="file" id="character_image" name="character_image" accept="image/*" style="width: 0.1px; height: 0.1px; opacity: 0; overflow: hidden; position: absolute; z-index: -1;">
                        </div>
                        <% if (character && character.id && character.id !== 'new') { %>
                            <a href="/ai-management/tts?characterId=<%= character.id %>" class="button" style="display: block; margin-top: 10px;">🎤 Configure Voice</a>
                        <% } else if (isNewCharacter) { %>
                            <div class="text-muted" style="display: block; margin-top: 10px; text-align: center;">Voice configuration available after saving</div>
                        <% } %>
                    </div>
                </div>

                <!-- Basic Information Card -->
                <div class="character-card">
                    <div class="card-header">
                        <span class="card-icon">📝</span>
                        <h3 class="card-title">Basic Information</h3>
                    </div>

                    <div class="form-group">
                        <label for="char_name">Name:</label>
                        <input type="text" id="char_name" name="char_name" value="<%= character ? character.char_name : '' %>" required>
                    </div>

                    <div class="form-group">
                        <label for="char_description">Description:</label>
                        <textarea id="char_description" name="char_description" required><%= character ? character.char_description : '' %></textarea>
                    </div>
                </div>


                <!-- ElevenLabs Assistant Card -->
                <div class="character-card">
                    <div class="card-header">
                        <span class="card-icon">🧠</span>
                        <h3 class="card-title">ElevenLabs Assistant</h3>
                    </div>

                    <% if (character && character.openaiAssistantId) { %>
                        <div class="info-section">
                            <div><strong>Currently Assigned Assistant:</strong> <span class="badge"><%= character.openaiAssistantId %></span></div>
                        </div>
                        <div class="button-group">
                            <a href="/ai-management/assistants" class="button">🧠 Assign Assistant</a>
                        </div>
                    <% } else { %>
                        <p class="text-muted">No Assistant assigned</p>
                        <div class="button-group">
                            <a href="/ai-management/assistants" class="button">🧠 Assign Assistant</a>
                        </div>
                    <% } %>
                </div>

                <!-- RPI Configuration Card -->
                <div class="character-card">
                    <div class="card-header">
                        <span class="card-icon">🖥️</span>
                        <h3 class="card-title">RPI4b Configuration</h3>
                    </div>

                    <div class="form-group">
                        <label for="rpi_host">IP Address:</label>
                        <input type="text" id="rpi_host" name="rpi_host"
                               value="<%= (character && character.animatronic && character.animatronic.rpi_config) ? character.animatronic.rpi_config.host || '' : '' %>"
                               placeholder="192.168.x.x">
                    </div>

                    <div class="form-group">
                        <label for="rpi_user">SSH User:</label>
                        <input type="text" id="rpi_user" name="rpi_user"
                               value="<%= (character && character.animatronic && character.animatronic.rpi_config) ? character.animatronic.rpi_config.user || 'remote' : 'remote' %>">
                    </div>

                    <div class="form-group">
                        <label for="rpi_password">SSH Password:</label>
                        <input type="password" id="rpi_password" name="rpi_password"
                               value="<%= (character && character.animatronic && character.animatronic.rpi_config) ? character.animatronic.rpi_config.password || '' : '' %>"
                               placeholder="Enter SSH password">
                        <small style="color: #888;">Password will be stored securely and used for automated SSH connections</small>
                    </div>
                </div>

                <!-- WebCam Configuration Card -->
                <% if (character && character.id && character.id !== 'new') { %>
                    <div class="character-card">
                        <div class="card-header">
                            <span class="card-icon">📹</span>
                            <h3 class="card-title">WebCam Configuration</h3>
                        </div>
                        <div class="button-group">
                            <a href="/configuration/webcam" class="button">📹 Configure WebCam</a>
                        </div>
                    </div>
                <% } %>

                <!-- Hardware Parts Card -->
                <div class="character-card">
                    <div class="card-header">
                        <span class="card-icon">🔧</span>
                        <h3 class="card-title">Hardware Parts</h3>
                    </div>

                    <div class="dual-select">
                        <div class="select-container">
                            <label class="select-label">Available Parts</label>
                            <select id="available-parts" multiple>
                                <% parts.forEach(function(part) { %>
                                    <% if (!part.characterId || (character && character.id && part.characterId !== character.id)) { %>
                                        <option value="<%= part.id %>"><%= part.name %></option>
                                    <% } %>
                                <% }); %>
                            </select>
                        </div>
                        <div class="dual-select-controls">
                            <button type="button" onclick="moveSelectedOptions('available-parts', 'assigned-parts')">></button>
                            <button type="button" onclick="moveSelectedOptions('assigned-parts', 'available-parts')"><</button>
                        </div>
                        <div class="select-container">
                            <label class="select-label">Assigned Parts</label>
                            <select id="assigned-parts" name="parts[]" multiple>
                                <% if (character && character.id) { %>
                                    <% parts.forEach(function(part) { %>
                                        <% if (part.characterId === character.id) { %>
                                            <option value="<%= part.id %>" selected><%= part.name %></option>
                                        <% } %>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Sounds Card -->
                <div class="character-card">
                    <div class="card-header">
                        <span class="card-icon">🔊</span>
                        <h3 class="card-title">Sounds</h3>
                    </div>

                    <div class="dual-select">
                        <div class="select-container">
                            <label class="select-label">Available Sounds</label>
                            <select id="available-sounds" multiple>
                                <% sounds.forEach(function(sound) { %>
                                    <% if (!(sound.characterIds && sound.characterIds.includes(character.id))) { %>
                                        <option value="<%= sound.id %>"><%= sound.name %></option>
                                    <% } %>
                                <% }); %>
                            </select>
                        </div>
                        <div class="dual-select-controls">
                            <button type="button" onclick="moveSelectedOptions('available-sounds', 'assigned-sounds')">></button>
                            <button type="button" onclick="moveSelectedOptions('assigned-sounds', 'available-sounds')"><</button>
                        </div>
                        <div class="select-container">
                            <label class="select-label">Assigned Sounds</label>
                            <select id="assigned-sounds" name="sounds[]" multiple>
                                <% if (character && character.id) { %>
                                    <% sounds.forEach(function(sound) { %>
                                        <% if (sound.characterIds && sound.characterIds.includes(character.id)) { %>
                                            <option value="<%= sound.id %>" selected><%= sound.name %></option>
                                        <% } %>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Audio Configuration Card -->
                <% if (character && character.id) { %>
                    <div class="character-card">
                        <div class="card-header">
                            <span class="card-icon">🎤</span>
                            <h3 class="card-title">Audio Configuration</h3>
                        </div>
                        <div class="button-group">
                            <a href="/parts/microphone/management" class="button">🎤 Configure Microphone</a>
                            <a href="/ai-management/stt" class="button">🗣️ Speech to Text Settings</a>
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- Save Button -->
            <div style="text-align: center; margin: 30px 0;">
                <button type="submit" class="button primary-btn" style="font-size: 18px; padding: 15px 40px;">
                    💾 <%= character && character.id !== 'new' ? 'Update Character' : 'Create Character' %>
                </button>
            </div>

        </form>
    </main>

    <script>
        // Unassign Assistant function
        async function unassignAssistant(characterId){
            try{
                const res = await fetch(`/characters/${characterId}/ai/remove-all`, { method:'POST', headers:{'Content-Type':'application/json'} });
                const data = await res.json();
                if (data.success) location.reload(); else alert('Error: '+data.error);
            } catch(e){ alert('Error: '+e.message); }
        }
        // Add preview functionality for image upload
        const imageInput = document.getElementById('character_image');
        const imagePreview = document.querySelector('.image-preview');

        imageInput.addEventListener('change', function(e) {
            if (e.target.files && e.target.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    if (imagePreview.tagName.toLowerCase() === 'img') {
                        imagePreview.src = e.target.result;
                    } else {
                        // Replace the div with an img element
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = 'image-preview';
                        img.alt = 'Character image';
                        imagePreview.parentNode.replaceChild(img, imagePreview);
                    }

                    // Display file name next to the Upload Picture button
                    const fileName = e.target.files[0].name;
                    document.querySelector('.custom-file-upload').innerHTML = `Selected: ${fileName.length > 15 ? fileName.substring(0, 12) + '...' : fileName}`;
                }
                reader.readAsDataURL(e.target.files[0]);
            }
        });

        function moveSelectedOptions(fromSelectId, toSelectId) {
            const fromSelect = document.getElementById(fromSelectId);
            const toSelect = document.getElementById(toSelectId);

            for (let option of fromSelect.selectedOptions) {
                toSelect.appendChild(option.cloneNode(true));
                fromSelect.remove(option.index);
            }
        }



        // Form submission handling
        const form = document.querySelector('form');
        if (form) {
            form.onsubmit = function() {
                const assignedParts = document.getElementById('assigned-parts');
                const assignedSounds = document.getElementById('assigned-sounds');

                if (assignedParts) {
                    for (let option of assignedParts.options) {
                        option.selected = true;
                    }
                }

                if (assignedSounds) {
                    for (let option of assignedSounds.options) {
                        option.selected = true;
                    }
                }

                return true;
            };
        }

        // Animatronic management functions (reuse from characters.ejs)
        function showModal(title, content) {
            // Create modal if it doesn't exist
            let modal = document.getElementById('resultModal');
            if (!modal) {
                modal = document.createElement('div');
                modal.id = 'resultModal';
                modal.className = 'modal';
                modal.style.display = 'none';
                modal.innerHTML = `
                    <div class="modal-content">
                        <span class="close" onclick="closeModal()">&times;</span>
                        <h2 id="modalTitle">Result</h2>
                        <div id="modalBody"></div>
                    </div>
                `;
                document.body.appendChild(modal);

                // Add modal styles if they don't exist
                if (!document.getElementById('modalStyles')) {
                    const style = document.createElement('style');
                    style.id = 'modalStyles';
                    style.textContent = `
                        .modal {
                            position: fixed;
                            z-index: 1000;
                            left: 0;
                            top: 0;
                            width: 100%;
                            height: 100%;
                            background-color: rgba(0,0,0,0.8);
                        }
                        .modal-content {
                            background-color: #000;
                            border: 2px solid #00ff00;
                            margin: 5% auto;
                            padding: 20px;
                            width: 80%;
                            max-width: 800px;
                            border-radius: 5px;
                            color: #00ff00;
                            max-height: 80vh;
                            overflow-y: auto;
                        }
                        .close {
                            color: #ff0000;
                            float: right;
                            font-size: 28px;
                            font-weight: bold;
                            cursor: pointer;
                        }
                        .close:hover {
                            color: #ff6666;
                        }
                        .test-result {
                            margin: 10px 0;
                            padding: 10px;
                            border: 1px solid #333;
                            border-radius: 3px;
                        }
                        .test-passed {
                            border-color: #00ff00;
                            background-color: rgba(0, 255, 0, 0.1);
                        }
                        .test-failed {
                            border-color: #ff0000;
                            background-color: rgba(255, 0, 0, 0.1);
                        }

                    `;
                    document.head.appendChild(style);
                }
            }

            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalBody').innerHTML = content;
            modal.style.display = 'block';
        }

        function closeModal() {
            const modal = document.getElementById('resultModal');
            if (modal) {
                modal.style.display = 'none';
            }
        }

        // Include the same animatronic management functions from characters.ejs
        function testConnection(characterId) {
            showModal('Testing Connection...', '<p>Testing animatronic connection, please wait...</p>');

            fetch('/characters/' + characterId + '/test-connection', { method: 'POST' })
                .then(response => response.json())
                .then(response => {
                    if (response.success) {
                        const result = response.result;
                        let html = '<h3>Connection Test Results for ' + result.character + '</h3>';
                        html += '<p><strong>Host:</strong> ' + result.host + '</p>';
                        html += '<p><strong>Timestamp:</strong> ' + new Date(result.timestamp).toLocaleString() + '</p>';

                        // Ping test
                        const pingClass = result.tests.ping.passed ? 'test-passed' : 'test-failed';
                        html += '<div class="test-result ' + pingClass + '">';
                        html += '<h4>🌐 Network Connectivity (Ping)</h4>';
                        html += '<p><strong>Status:</strong> ' + (result.tests.ping.passed ? '✅ PASSED' : '❌ FAILED') + '</p>';
                        html += '<p><strong>Message:</strong> ' + result.tests.ping.message + '</p>';
                        html += '<p><strong>Duration:</strong> ' + result.tests.ping.duration + 'ms</p>';
                        html += '</div>';





                        showModal('Connection Test Results', html);
                    } else {
                        showModal('Connection Test Failed', '<p style="color: #ff0000;">❌ ' + response.error + '</p>');
                    }
                })
                .catch(error => {
                    showModal('Connection Test Error', '<p style="color: #ff0000;">❌ Error: ' + error.message + '</p>');
                });
        }



        function showSystemInfo(characterId) {
            showModal('Getting System Info...', '<p>Retrieving comprehensive system information, please wait...</p>');

            fetch('/characters/' + characterId + '/system-info')
                .then(response => response.json())
                .then(response => {
                    if (response.success) {
                        const result = response.result;
                        let html = '<h3>📊 System Information for ' + result.character + '</h3>';
                        html += '<p><strong>Timestamp:</strong> ' + new Date(result.timestamp).toLocaleString() + '</p>';

                        // Local System Information
                        if (result.localSystem && !result.localSystem.error) {
                            const local = result.localSystem;
                            html += '<div class="test-result test-passed">';
                            html += '<h4>🖥️ MonsterBox Server (Local)</h4>';
                            html += '<p><strong>Platform:</strong> ' + local.platform + '</p>';
                            html += '<p><strong>Architecture:</strong> ' + local.architecture + '</p>';
                            html += '<p><strong>Hostname:</strong> ' + local.hostname + '</p>';
                            html += '<p><strong>OS Type:</strong> ' + local.osType + '</p>';
                            html += '<p><strong>OS Release:</strong> ' + local.osRelease + '</p>';
                            html += '<p><strong>Node Version:</strong> ' + local.nodeVersion + '</p>';
                            html += '<p><strong>MonsterBox Version:</strong> ' + local.monsterBoxVersion + '</p>';
                            html += '</div>';

                            html += '<div class="test-result test-passed">';
                            html += '<h4>🧠 Hardware Specifications</h4>';
                            html += '<p><strong>CPU Count:</strong> ' + local.cpuCount + '</p>';
                            html += '<p><strong>CPU Model:</strong> ' + local.cpuModel + '</p>';
                            html += '<p><strong>Total Memory:</strong> ' + local.totalMemory + '</p>';
                            html += '<p><strong>Used Memory:</strong> ' + local.usedMemory + '</p>';
                            html += '<p><strong>Free Memory:</strong> ' + local.freeMemory + '</p>';
                            html += '<p><strong>System Uptime:</strong> ' + local.uptime + '</p>';
                            html += '<p><strong>Process Uptime:</strong> ' + local.processUptime + '</p>';
                            if (local.temperature) {
                                html += '<p><strong>Temperature:</strong> ' + local.temperature + '</p>';
                            }
                            html += '</div>';

                            if (local.diskUsage) {
                                html += '<div class="test-result test-passed">';
                                html += '<h4>💾 Storage Information</h4>';
                                html += '<p><strong>Filesystem:</strong> ' + local.diskUsage.filesystem + '</p>';
                                html += '<p><strong>Size:</strong> ' + local.diskUsage.size + '</p>';
                                html += '<p><strong>Used:</strong> ' + local.diskUsage.used + '</p>';
                                html += '<p><strong>Available:</strong> ' + local.diskUsage.available + '</p>';
                                html += '<p><strong>Usage:</strong> ' + local.diskUsage.usePercent + '</p>';
                                html += '</div>';
                            }

                            if (local.networkInterfaces && local.networkInterfaces.length > 0) {
                                html += '<div class="test-result test-passed">';
                                html += '<h4>🌐 Network Configuration</h4>';
                                local.networkInterfaces.forEach(iface => {
                                    html += '<p><strong>' + iface.interface + ':</strong> ' + iface.address + '</p>';
                                });
                                html += '</div>';
                            }

                            if (local.services) {
                                html += '<div class="test-result test-passed">';
                                html += '<h4>🔧 MonsterBox Services</h4>';
                                Object.values(local.services).forEach(service => {
                                    const statusColor = service.status === 'running' ? '#00ff00' : '#ff0000';
                                    html += '<p><strong>' + service.name + ':</strong> <span style="color: ' + statusColor + '">' + service.status + '</span>';
                                    if (service.port) {
                                        html += ' (Port: ' + service.port + ')';
                                    }
                                    html += '</p>';
                                });
                                html += '</div>';
                            }
                        } else {
                            html += '<div class="test-result test-failed">';
                            html += '<h4>❌ Local System Error</h4>';
                            html += '<p>' + (result.localSystem?.error || 'Unknown error') + '</p>';
                            html += '</div>';
                        }

                        // Remote System Information (Character RPI)
                        if (result.remoteSystem && !result.remoteSystem.error) {
                            const remote = result.remoteSystem;
                            const info = remote.systemInfo;
                            html += '<div class="test-result test-passed">';
                            html += '<h4>🤖 Character RPI (' + remote.host + ')</h4>';
                            html += '<p><strong>Platform:</strong> ' + info.platform + '</p>';
                            html += '<p><strong>Architecture:</strong> ' + info.arch + '</p>';
                            html += '<p><strong>Hostname:</strong> ' + info.hostname + '</p>';
                            html += '<p><strong>Uptime:</strong> ' + info.uptime + '</p>';
                            html += '<p><strong>Total Memory:</strong> ' + info.totalMem + '</p>';
                            html += '<p><strong>Used Memory:</strong> ' + info.usedMem + '</p>';
                            html += '<p><strong>Free Memory:</strong> ' + info.freeMem + '</p>';
                            html += '<p><strong>Temperature:</strong> ' + info.temperature + '</p>';
                            html += '<p><strong>Voltage:</strong> ' + info.voltage + '</p>';
                            html += '<p><strong>WiFi Signal:</strong> ' + info.wifiSignal + '</p>';
                            html += '</div>';
                        } else {
                            html += '<div class="test-result test-warning">';
                            html += '<h4>⚠️ Remote Character System</h4>';
                            html += '<p>' + (result.remoteSystem?.error || 'No remote system configured') + '</p>';
                            html += '</div>';
                        }

                        showModal('System Information', html);
                    } else {
                        showModal('System Info Failed', '<p style="color: #ff0000;">❌ ' + response.error + '</p>');
                    }
                })
                .catch(error => {
                    showModal('System Info Error', '<p style="color: #ff0000;">❌ Error: ' + error.message + '</p>');
                });
        }

        function rebootSystem(characterId) {
            if (confirm('Are you sure you want to reboot this animatronic system? This will disconnect all users and stop all running processes.')) {
                showModal('Rebooting System...', '<p>Sending reboot command to animatronic, please wait...</p>');

                fetch('/characters/' + characterId + '/reboot', { method: 'POST' })
                    .then(response => response.json())
                    .then(response => {
                        if (response.success) {
                            const result = response.result;
                            let html = '<h3>Reboot Command Sent</h3>';
                            html += '<p style="color: #00ff00;">✅ ' + result.message + '</p>';
                            html += '<p><strong>Timestamp:</strong> ' + new Date(result.timestamp).toLocaleString() + '</p>';
                            html += '<p><em>The system should be back online in 1-2 minutes.</em></p>';

                            showModal('System Reboot', html);
                        } else {
                            showModal('Reboot Failed', '<p style="color: #ff0000;">❌ ' + response.error + '</p>');
                        }
                    })
                    .catch(error => {
                        showModal('Reboot Error', '<p style="color: #ff0000;">❌ Error: ' + error.message + '</p>');
                    });
            }
        }

        function manageServos(characterId) {
            // Navigate to the character servo management page
            window.location.href = '/characters/' + characterId + '/servos';
        }

        function viewSystemConfig(characterId) {
            showModal('Loading System Configuration...', '<p>Loading system configuration for this character...</p>');

            fetch('/characters/' + characterId + '/system-info')
                .then(response => response.json())
                .then(response => {
                    if (response.success) {
                        const result = response.result;
                        const info = result.systemInfo;
                        let html = '<h3>System Configuration for ' + result.character + '</h3>';
                        html += '<p><strong>Host:</strong> ' + result.host + '</p>';
                        html += '<p><strong>Timestamp:</strong> ' + new Date(result.timestamp).toLocaleString() + '</p>';

                        html += '<div class="test-result test-passed">';
                        html += '<h4>🖥️ System Information</h4>';
                        html += '<p><strong>Platform:</strong> ' + info.platform + '</p>';
                        html += '<p><strong>Architecture:</strong> ' + info.arch + '</p>';
                        html += '<p><strong>Hostname:</strong> ' + info.hostname + '</p>';
                        html += '<p><strong>Uptime:</strong> ' + info.uptime + '</p>';
                        html += '</div>';

                        html += '<div class="test-result test-passed">';
                        html += '<h4>💾 Memory & Storage</h4>';
                        html += '<p><strong>Total Memory:</strong> ' + info.totalMem + '</p>';
                        html += '<p><strong>Used Memory:</strong> ' + info.usedMem + '</p>';
                        html += '<p><strong>Free Memory:</strong> ' + info.freeMem + '</p>';
                        html += '<p><strong>Disk Total:</strong> ' + info.diskTotal + '</p>';
                        html += '<p><strong>Disk Used:</strong> ' + info.diskUsed + '</p>';
                        html += '<p><strong>Disk Free:</strong> ' + info.diskFree + '</p>';
                        html += '</div>';

                        html += '<div class="test-result test-passed">';
                        html += '<h4>⚡ Hardware Status</h4>';
                        html += '<p><strong>Temperature:</strong> ' + info.temperature + '</p>';
                        html += '<p><strong>Voltage:</strong> ' + info.voltage + '</p>';
                        html += '<p><strong>WiFi Signal:</strong> ' + info.wifiSignal + '</p>';
                        html += '</div>';

                        showModal('System Configuration', html);
                    } else {
                        showModal('System Config Failed', '<p style="color: #ff0000;">❌ ' + response.error + '</p>');
                    }
                })
                .catch(error => {
                    showModal('System Config Error', '<p style="color: #ff0000;">❌ Error: ' + error.message + '</p>');
                });
        }

        // Close modal when clicking outside of it
        window.onclick = function(event) {
            const modal = document.getElementById('resultModal');
            if (event.target == modal) {
                closeModal();
            }
        }

        // Initialize Enhanced Microphone Component and Audio Configuration
        document.addEventListener('DOMContentLoaded', function() {
            const characterId = <%= character && character.id ? character.id : 'null' %>;

            if (characterId) {
                // Load character audio configuration
                loadCharacterAudioConfig(characterId);

                // Initialize microphone component
                const micContainer = document.getElementById('characterMicrophoneContainer');
                if (micContainer) {
                    const microphoneComponent = new EnhancedMicrophoneComponent({
                        containerId: 'characterMicrophoneContainer',
                        characterId: characterId,
                        onTranscription: function(text, confidence) {
                            console.log('Character microphone transcription:', text, 'Confidence:', confidence);
                        },
                        onError: function(error) {
                            console.error('Character microphone error:', error);
                        },
                        onStatusChange: function(status, message) {
                            console.log('Character microphone status:', status, message);
                        }
                    });
                }
            }
        });

        // Load character audio configuration
        async function loadCharacterAudioConfig(characterId) {
            try {
                const response = await fetch(`/api/character-audio-config/${characterId}`);
                const result = await response.json();

                if (result.success) {
                    renderAudioConfigForm(result.data);
                } else {
                    console.error('Failed to load audio config:', result.error);
                    renderAudioConfigError('Failed to load audio configuration');
                }
            } catch (error) {
                console.error('Error loading audio config:', error);
                renderAudioConfigError('Error loading audio configuration');
            }
        }

        // Render audio configuration form
        function renderAudioConfigForm(config) {
            const container = document.getElementById('audioSettings');
            container.innerHTML = `
                <div class="config-section">
                    <h4>🎤 Microphone Settings</h4>
                    <div class="form-group">
                        <label for="microphoneEnabled">Enable Microphone</label>
                        <select id="microphoneEnabled" name="microphoneEnabled">
                            <option value="true" ${config.microphone.enabled ? 'selected' : ''}>Enabled</option>
                            <option value="false" ${!config.microphone.enabled ? 'selected' : ''}>Disabled</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="microphoneSensitivity">Microphone Sensitivity</label>
                        <input type="range" id="microphoneSensitivity" name="microphoneSensitivity"
                               min="0.1" max="3.0" step="0.1" value="${config.microphone.sensitivity}">
                        <span class="setting-value">${config.microphone.sensitivity}</span>
                    </div>
                    <div class="form-group">
                        <label>
                            <input type="checkbox" id="voiceActivation" name="voiceActivation"
                                   ${config.microphone.voiceActivation ? 'checked' : ''}>
                            Voice Activation Detection
                        </label>
                    </div>
                    <div class="form-group">
                        <label for="voiceActivationThreshold">Voice Activation Threshold</label>
                        <input type="range" id="voiceActivationThreshold" name="voiceActivationThreshold"
                               min="0.01" max="1.0" step="0.01" value="${config.microphone.voiceActivationThreshold}">
                        <span class="setting-value">${config.microphone.voiceActivationThreshold}</span>
                    </div>
                </div>

                <div class="config-section">
                    <h4>🗣️ Speech-to-Text Settings</h4>
                    <div class="form-group">
                        <label for="sttEnabled">Enable STT</label>
                        <select id="sttEnabled" name="sttEnabled">
                            <option value="true" ${config.stt.enabled ? 'selected' : ''}>Enabled</option>
                            <option value="false" ${!config.stt.enabled ? 'selected' : ''}>Disabled</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="sttLanguage">Language</label>
                        <select id="sttLanguage" name="sttLanguage">
                            <option value="en" ${config.stt.language === 'en' ? 'selected' : ''}>English</option>
                            <option value="es" ${config.stt.language === 'es' ? 'selected' : ''}>Spanish</option>
                            <option value="fr" ${config.stt.language === 'fr' ? 'selected' : ''}>French</option>
                            <option value="de" ${config.stt.language === 'de' ? 'selected' : ''}>German</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="sttConfidenceThreshold">Confidence Threshold</label>
                        <input type="range" id="sttConfidenceThreshold" name="sttConfidenceThreshold"
                               min="0.1" max="1.0" step="0.1" value="${config.stt.confidenceThreshold}">
                        <span class="setting-value">${config.stt.confidenceThreshold}</span>
                    </div>
                </div>

                <div class="config-section">
                    <h4>🦴 Jaw Animation Settings</h4>
                    <div class="form-group">
                        <label for="jawAnimationEnabled">Enable Jaw Animation</label>
                        <select id="jawAnimationEnabled" name="jawAnimationEnabled">
                            <option value="true" ${config.jawAnimation.enabled ? 'selected' : ''}>Enabled</option>
                            <option value="false" ${!config.jawAnimation.enabled ? 'selected' : ''}>Disabled</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="jawAnimationSensitivity">Animation Sensitivity</label>
                        <input type="range" id="jawAnimationSensitivity" name="jawAnimationSensitivity"
                               min="0.1" max="5.0" step="0.1" value="${config.jawAnimation.sensitivity}">
                        <span class="setting-value">${config.jawAnimation.sensitivity}</span>
                    </div>
                    <div class="form-group">
                        <label for="jawAttackTime">Attack Time (seconds)</label>
                        <input type="range" id="jawAttackTime" name="jawAttackTime"
                               min="0.01" max="1.0" step="0.01" value="${config.jawAnimation.attackTime}">
                        <span class="setting-value">${config.jawAnimation.attackTime}</span>
                    </div>
                    <div class="form-group">
                        <label for="jawReleaseTime">Release Time (seconds)</label>
                        <input type="range" id="jawReleaseTime" name="jawReleaseTime"
                               min="0.01" max="1.0" step="0.01" value="${config.jawAnimation.releaseTime}">
                        <span class="setting-value">${config.jawAnimation.releaseTime}</span>
                    </div>
                </div>

                <div class="config-actions">
                    <button type="button" class="action-btn primary" onclick="saveAudioConfig()">
                        <i class="fas fa-save"></i> Save Audio Config
                    </button>
                    <button type="button" class="action-btn secondary" onclick="testAudioConfig()">
                        <i class="fas fa-test-tube"></i> Test Configuration
                    </button>
                    <button type="button" class="action-btn secondary" onclick="resetAudioConfig()">
                        <i class="fas fa-undo"></i> Reset to Defaults
                    </button>
                </div>
            `;

            // Add event listeners for range inputs
            container.querySelectorAll('input[type="range"]').forEach(input => {
                input.addEventListener('input', function(e) {
                    e.target.nextElementSibling.textContent = e.target.value;
                });
            });
        }

        // Render audio configuration error
        function renderAudioConfigError(message) {
            const container = document.getElementById('audioSettings');
            container.innerHTML = `
                <div class="config-error">
                    <i class="fas fa-exclamation-triangle"></i>
                    ${message}
                    <button type="button" onclick="location.reload()">Retry</button>
                </div>
            `;
        }

        // Save audio configuration
        async function saveAudioConfig() {
            const characterId = <%= character && character.id ? character.id : 'null' %>;
            if (!characterId) return;

            try {
                const config = {
                    microphone: {
                        enabled: document.getElementById('microphoneEnabled').value === 'true',
                        sensitivity: parseFloat(document.getElementById('microphoneSensitivity').value),
                        voiceActivation: document.getElementById('voiceActivation').checked,
                        voiceActivationThreshold: parseFloat(document.getElementById('voiceActivationThreshold').value)
                    },
                    stt: {
                        enabled: document.getElementById('sttEnabled').value === 'true',
                        language: document.getElementById('sttLanguage').value,
                        confidenceThreshold: parseFloat(document.getElementById('sttConfidenceThreshold').value)
                    },
                    jawAnimation: {
                        enabled: document.getElementById('jawAnimationEnabled').value === 'true',
                        sensitivity: parseFloat(document.getElementById('jawAnimationSensitivity').value),
                        attackTime: parseFloat(document.getElementById('jawAttackTime').value),
                        releaseTime: parseFloat(document.getElementById('jawReleaseTime').value)
                    }
                };

                const response = await fetch(`/api/character-audio-config/${characterId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(config)
                });

                const result = await response.json();

                if (result.success) {
                    showMessage('Audio configuration saved successfully!', 'success');
                } else {
                    showMessage('Failed to save audio configuration: ' + result.error, 'error');
                }
            } catch (error) {
                console.error('Error saving audio config:', error);
                showMessage('Error saving audio configuration', 'error');
            }
        }

        // Test audio configuration
        async function testAudioConfig() {
            const characterId = <%= character && character.id ? character.id : 'null' %>;
            if (!characterId) return;

            try {
                const response = await fetch(`/api/character-audio-config/${characterId}/test`);
                const result = await response.json();

                if (result.success) {
                    const testResults = result.data.testResults;
                    let message = 'Audio Configuration Test Results:\\n';
                    message += `- Configuration exists: ${testResults.configExists ? '✓' : '✗'}\\n`;
                    message += `- Microphone enabled: ${testResults.microphoneEnabled ? '✓' : '✗'}\\n`;
                    message += `- STT enabled: ${testResults.sttEnabled ? '✓' : '✗'}\\n`;
                    message += `- Jaw animation enabled: ${testResults.jawAnimationEnabled ? '✓' : '✗'}\\n`;
                    message += `- Optimized settings generated: ${testResults.optimizedSettingsGenerated ? '✓' : '✗'}`;

                    alert(message);
                } else {
                    showMessage('Failed to test audio configuration: ' + result.error, 'error');
                }
            } catch (error) {
                console.error('Error testing audio config:', error);
                showMessage('Error testing audio configuration', 'error');
            }
        }

        // Reset audio configuration to defaults
        async function resetAudioConfig() {
            const characterId = <%= character && character.id ? character.id : 'null' %>;
            if (!characterId) return;

            if (!confirm('Are you sure you want to reset the audio configuration to defaults? This will overwrite all current settings.')) {
                return;
            }

            try {
                const response = await fetch(`/api/character-audio-config/${characterId}/reset`, {
                    method: 'POST'
                });

                const result = await response.json();

                if (result.success) {
                    renderAudioConfigForm(result.data);
                    showMessage('Audio configuration reset to defaults', 'success');
                } else {
                    showMessage('Failed to reset audio configuration: ' + result.error, 'error');
                }
            } catch (error) {
                console.error('Error resetting audio config:', error);
                showMessage('Error resetting audio configuration', 'error');
            }
        }

        // Show message to user
        function showMessage(message, type = 'info') {
            // Create or update message display
            let messageDiv = document.querySelector('.form-message');
            if (!messageDiv) {
                messageDiv = document.createElement('div');
                messageDiv.className = 'form-message';
                document.querySelector('.audio-config-container').appendChild(messageDiv);
            }

            messageDiv.className = `form-message form-message-${type}`;
            messageDiv.innerHTML = `
                <i class="fas fa-${type === 'error' ? 'exclamation-triangle' : type === 'success' ? 'check-circle' : 'info-circle'}"></i>
                ${message}
            `;

            // Auto-hide after 5 seconds
            setTimeout(() => {
                if (messageDiv.parentNode) {
                    messageDiv.parentNode.removeChild(messageDiv);
                }
            }, 5000);
        }
    </script>
    <script src="/js/video-configuration.js"></script>
</body>
</html>
