<%
// Fleet Command Center (v8.5.0) — a single pane to monitor and run the entire
// network of animatronics. Self-contained: inline styles + one ES6 controller.
// Backend: /api/orchestration/* (fleet-health, nodes, superpower, emergency-stop,
// volume, per-node say/ask/audio/auto-ai/webcam-stream). See routes/api/orchestrationRoutes.js.
%>
<style>
  /* ---- Fleet Command Center chrome ---- */
  .fcc-bar { position: sticky; top: 0; z-index: 1020; background: var(--bs-body-bg);
    border-bottom: 1px solid var(--bs-border-color); padding: .5rem .25rem; margin: -0.5rem -0.5rem .75rem; }
  .fcc-bar .fcc-row { display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; }
  .fcc-pill { display: inline-flex; align-items: center; gap: .4rem; font-weight: 600;
    padding: .3rem .7rem; border-radius: 999px; border: 1px solid var(--bs-border-color); }
  .fcc-dot { width: .6rem; height: .6rem; border-radius: 50%; display: inline-block; background: #888; }
  .fcc-dot.online { background: #2ecc71; box-shadow: 0 0 6px #2ecc71; }
  .fcc-dot.offline { background: #6c757d; }
  .fcc-dot.warn { background: #f1c40f; }
  .fcc-sep { width: 1px; align-self: stretch; background: var(--bs-border-color); margin: 0 .25rem; }
  /* Superpower master toggles */
  .fcc-sp.on { background: #2ecc71; border-color: #2ecc71; color: #06280f; }
  .fcc-sp.mixed { background: repeating-linear-gradient(45deg, rgba(241,196,15,.85), rgba(241,196,15,.85) 6px, rgba(241,196,15,.55) 6px, rgba(241,196,15,.55) 12px); border-color: #f1c40f; color: #2b2200; }
  .fcc-estop { font-weight: 800; letter-spacing: .04em; }
  /* Node wall */
  .fcc-card { height: 100%; display: flex; flex-direction: column; }
  .fcc-cam-wrap { position: relative; background: #000; aspect-ratio: 16 / 9; overflow: hidden; cursor: zoom-in; }
  .fcc-cam-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .fcc-cam-off { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    color: #6c757d; font-size: .8rem; text-align: center; padding: .5rem; }
  .fcc-chip { font-size: .68rem; padding: .1rem .4rem; border-radius: .35rem; border: 1px solid var(--bs-border-color); }
  .fcc-chip.config { color: #adb5bd; }
  .fcc-chip.discovered { color: #2ecc71; border-color: #2ecc71; }
  .fcc-chip.manual { color: #4da3ff; border-color: #4da3ff; }
  .fcc-chip.untrusted { color: #ff6b6b; border-color: #ff6b6b; }
  .fcc-health { font-size: .72rem; color: var(--bs-secondary-color); font-variant-numeric: tabular-nums; }
  .fcc-ghost { opacity: .6; }
  .fcc-log { height: 190px; overflow-y: auto; background: #0b0d10; color: #c7f0d8; font-family: var(--bs-font-monospace);
    font-size: .74rem; padding: .5rem; border-radius: .4rem; }
  .fcc-log .err { color: #ff8080; }
  .fcc-log .warn { color: #ffd166; }
  .fcc-log .ok { color: #7CFC9E; }
  .fcc-log .muted { color: #7a8a99; }
  #fccCamModal img { width: 100%; height: auto; background: #000; }
  .fcc-vol { width: 130px; }
</style>

<div class="mb-1 d-flex align-items-center justify-content-between flex-wrap gap-2">
  <h4 class="mb-0"><i class="bi bi-diagram-3"></i> Fleet Command Center</h4>
  <span class="text-secondary small">Monitor &amp; run the entire MonsterNet from one place</span>
</div>

<!-- ============ STICKY COMMAND BAR ============ -->
<div class="fcc-bar">
  <div class="fcc-row">
    <!-- Fleet health rollup -->
    <span class="fcc-pill" id="fleetPill" title="Nodes currently online / total in the fleet">
      <span class="fcc-dot" id="fleetDot"></span>
      <span id="fleetCount">— / —</span>
    </span>

    <span class="fcc-sep"></span>

    <!-- Fleet superpower masters -->
    <div class="btn-group btn-group-sm" role="group" aria-label="Fleet superpowers">
      <button class="btn btn-outline-secondary fcc-sp" data-sp="lurk" title="Toggle Lurk mode on every animatronic">Lurk</button>
      <button class="btn btn-outline-secondary fcc-sp" data-sp="jaw" title="Toggle jaw animation fleet-wide">Jaw</button>
      <button class="btn btn-outline-secondary fcc-sp" data-sp="head" title="Toggle head tracking fleet-wide">Head</button>
      <button class="btn btn-outline-secondary fcc-sp" data-sp="motion" title="Toggle PIR motion sensor fleet-wide">Motion</button>
      <button class="btn btn-outline-secondary fcc-sp" data-sp="idle" title="Toggle idle movement loop fleet-wide">Idle</button>
      <button class="btn btn-outline-secondary fcc-sp" data-sp="mute" title="Mute / unmute all speakers">Mute</button>
    </div>

    <span class="fcc-sep"></span>

    <!-- Master volume -->
    <span class="d-inline-flex align-items-center gap-1" title="Set master speaker volume on every node">
      <i class="bi bi-volume-up"></i>
      <input type="range" class="form-range fcc-vol" id="masterVol" min="0" max="100" value="80">
      <span class="small text-secondary" id="masterVolVal" style="width:2.4em">80%</span>
    </span>

    <span class="fcc-sep"></span>

    <!-- Show transport -->
    <button class="btn btn-sm btn-success" id="startLoops" title="Start each node's default scene queue loop">
      <i class="bi bi-play-fill"></i> Start Loops</button>
    <button class="btn btn-sm btn-outline-warning" id="stopLoops" title="Stop all scene queue loops across the fleet">
      <i class="bi bi-stop-fill"></i> Stop Loops</button>

    <!-- Panic -->
    <button class="btn btn-sm btn-danger fcc-estop ms-auto" id="estop"
      title="Immediately halt every animatronic: stop queues, stop audio, disable random poses, mute">
      <i class="bi bi-exclamation-octagon-fill"></i> EMERGENCY STOP</button>
  </div>

  <div class="fcc-row mt-2">
    <!-- Say to all -->
    <div class="input-group input-group-sm" style="max-width: 480px;">
      <input type="text" class="form-control" id="sayAllText" placeholder="Say to targeted nodes…"
        title="Broadcast this text as speech">
      <button class="btn btn-outline-info" id="sayAllBtn" title="Speak on the targeted nodes (all if none selected)">
        <i class="bi bi-megaphone"></i> Say</button>
    </div>

    <span class="fcc-sep"></span>

    <!-- Target scope -->
    <span class="small text-secondary" title="Global actions apply to selected nodes; none selected = all online">
      Target: <span id="targetSummary" class="fw-semibold">All</span></span>
    <button class="btn btn-sm btn-outline-secondary" id="clearTargets" title="Clear node selection (target all)">Clear</button>

    <span class="fcc-sep"></span>

    <button class="btn btn-sm btn-outline-secondary" id="refreshBtn" title="Refresh fleet health now">
      <i class="bi bi-arrow-clockwise"></i> Refresh</button>
    <button class="btn btn-sm btn-outline-secondary" id="restartSvc" title="Restart the MonsterBox service on targeted nodes">
      <i class="bi bi-arrow-repeat"></i> Restart Services</button>
    <button class="btn btn-sm btn-outline-danger" id="rebootAll" title="Reboot targeted animatronics (SSH)">
      <i class="bi bi-power"></i> Reboot</button>
  </div>
</div>

<!-- ============ NODE WALL ============ -->
<div class="row g-3" id="nodeWall">
  <div class="col-12 text-center text-secondary py-5" id="wallLoading">
    <div class="spinner-border spinner-border-sm"></div> Loading fleet…
  </div>
</div>

<!-- ============ GOBLINS ============ -->
<div class="mt-4">
  <h6 class="text-secondary"><i class="bi bi-tv"></i> Goblins (video displays)</h6>
  <div class="row g-2" id="goblinRow"><div class="col-12 text-secondary small">Loading…</div></div>
</div>

<!-- ============ BOTTOM RAIL: LOG + DISCOVERY ============ -->
<div class="row g-3 mt-3">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header py-1 d-flex justify-content-between align-items-center">
        <span><i class="bi bi-terminal"></i> Command Log</span>
        <button class="btn btn-sm btn-outline-secondary" id="clearLog" title="Clear the command log">Clear</button>
      </div>
      <div class="fcc-log" id="commandLog"></div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header py-1"><i class="bi bi-broadcast"></i> Discovery</div>
      <div class="card-body py-2">
        <div class="small mb-2" id="discoveryState">mDNS: <span class="text-secondary">checking…</span></div>
        <div class="small text-secondary mb-2" id="sourceBreakdown"></div>
        <form id="pinForm" class="row g-1" title="Pin a node by IP for networks that block mDNS multicast">
          <div class="col-3"><input class="form-control form-control-sm" id="pinId" placeholder="id" title="Node id"></div>
          <div class="col-5"><input class="form-control form-control-sm" id="pinIp" placeholder="IP address" title="Node IP"></div>
          <div class="col-4"><input class="form-control form-control-sm" id="pinName" placeholder="name" title="Display name"></div>
          <div class="col-12 d-grid mt-1">
            <button class="btn btn-sm btn-outline-primary" type="submit" title="Persist this pinned node (survives restarts)">
              <i class="bi bi-pin-map"></i> Pin node</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Webcam expand modal -->
<div class="modal fade" id="fccCamModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header py-2"><h6 class="modal-title" id="fccCamTitle">Webcam</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div>
      <div class="modal-body p-0"><img id="fccCamModalImg" alt="Live webcam"></div>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict';
  const API = '/api/orchestration';
  const POLL_MS = 15000;
  const state = { nodes: new Map(), targets: new Set(), avahi: null };

  // ---------- helpers ----------
  const $ = (sel, root) => (root || document).querySelector(sel);
  const el = (tag, cls, html) => { const e = document.createElement(tag); if (cls) e.className = cls; if (html != null) e.innerHTML = html; return e; };
  const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

  function log(msg, type) {
    const line = el('div', type || 'muted', '<span class="muted">' + new Date().toLocaleTimeString() + '</span> ' + esc(msg));
    const box = $('#commandLog'); box.appendChild(line); box.scrollTop = box.scrollHeight;
    while (box.children.length > 300) box.removeChild(box.firstChild);
  }
  function summarize(r) {
    if (!r) return '';
    if (typeof r.successful === 'number' && typeof r.total === 'number') return r.successful + '/' + r.total + ' ok';
    if (r.online != null && r.total != null) return r.online + '/' + r.total + ' online';
    return r.success ? 'ok' : 'failed';
  }
  async function api(path, opts) {
    const res = await fetch(API + path, Object.assign({ headers: { 'Content-Type': 'application/json' } }, opts));
    let body = null; try { body = await res.json(); } catch (_) {}
    if (!res.ok) throw new Error((body && (body.error || body.message)) || ('HTTP ' + res.status));
    return body;
  }
  function targetIds() { return state.targets.size ? Array.from(state.targets) : undefined; }
  function targetLabel() {
    if (!state.targets.size) return 'All';
    return Array.from(state.targets).map(id => { const n = state.nodes.get(String(id)); return n ? n.name : id; }).join(', ');
  }
  function refreshTargetSummary() { $('#targetSummary').textContent = targetLabel(); }

  // ---------- node cards ----------
  function cardId(id) { return 'node-' + String(id).replace(/[^a-z0-9]/gi, '_'); }

  function buildCard(node) {
    const col = el('div', 'col-sm-6 col-lg-4 col-xxl-3');
    col.id = cardId(node.id);
    const card = el('div', 'card fcc-card');

    // header
    const head = el('div', 'card-header py-1 d-flex align-items-center gap-2');
    head.innerHTML =
      '<span class="fcc-dot ' + (node.online ? 'online' : 'offline') + '" data-role="dot"></span>' +
      '<strong class="me-auto text-truncate" title="' + esc(node.name) + '">' + esc(node.name) + '</strong>' +
      '<span class="fcc-chip ' + (node.trusted === false ? 'untrusted' : (node.source || 'config')) + '" data-role="chip" title="Discovery source / trust">' +
        (node.trusted === false ? 'untrusted' : (node.source || 'config')) + '</span>' +
      '<input type="checkbox" class="form-check-input" data-role="target" title="Target this node for global actions">';
    card.appendChild(head);

    // webcam
    const cam = el('div', 'fcc-cam-wrap');
    const img = el('img'); img.alt = esc(node.name) + ' webcam'; img.loading = 'lazy';
    const off = el('div', 'fcc-cam-off', 'Webcam unavailable');
    off.style.display = 'none';
    if (node.online) { img.src = API + '/animatronic/' + node.id + '/webcam-stream'; }
    else { off.textContent = 'Node offline'; off.style.display = 'flex'; img.style.visibility = 'hidden'; }
    img.onerror = function () { off.textContent = 'Webcam unavailable'; off.style.display = 'flex'; img.style.visibility = 'hidden'; };
    img.onload = function () { off.style.display = 'none'; img.style.visibility = 'visible'; };
    cam.appendChild(img); cam.appendChild(off);
    cam.onclick = function () { openCam(node); };
    card.appendChild(cam);

    // body
    const body = el('div', 'card-body p-2 d-flex flex-column gap-2');

    const health = el('div', 'fcc-health', '');
    health.setAttribute('data-role', 'health');
    body.appendChild(health);

    // Say / Ask row
    const sayGrp = el('div', 'input-group input-group-sm');
    sayGrp.innerHTML =
      '<input type="text" class="form-control" data-role="text" placeholder="Say or Ask…" title="Text to speak or ask the AI">' +
      '<button class="btn btn-outline-info" data-role="say" title="Speak this text (TTS)"><i class="bi bi-megaphone"></i></button>' +
      '<button class="btn btn-outline-primary" data-role="ask" title="Ask the AI agent and speak the reply"><i class="bi bi-robot"></i></button>';
    body.appendChild(sayGrp);

    // Audio row
    const audioGrp = el('div', 'input-group input-group-sm');
    audioGrp.innerHTML =
      '<select class="form-select" data-role="audioSel" title="Audio clip on this node"><option value="">— audio —</option></select>' +
      '<button class="btn btn-outline-success" data-role="playAudio" title="Play selected audio"><i class="bi bi-play"></i></button>' +
      '<button class="btn btn-outline-secondary" data-role="loopAudio" title="Loop selected audio"><i class="bi bi-repeat"></i></button>' +
      '<button class="btn btn-outline-warning" data-role="stopAudio" title="Stop audio on this node"><i class="bi bi-stop"></i></button>';
    body.appendChild(audioGrp);

    // Auto-AI row
    const autoGrp = el('div', 'input-group input-group-sm');
    autoGrp.innerHTML =
      '<span class="input-group-text" title="Auto-AI makes the node speak on an interval">Auto-AI</span>' +
      '<input type="number" class="form-control" data-role="autoInterval" value="30" min="5" title="Interval in seconds">' +
      '<button class="btn btn-outline-success" data-role="autoStart" title="Start Auto-AI"><i class="bi bi-play-circle"></i></button>' +
      '<button class="btn btn-outline-warning" data-role="autoStop" title="Stop Auto-AI"><i class="bi bi-stop-circle"></i></button>';
    body.appendChild(autoGrp);

    card.appendChild(body);
    col.appendChild(card);
    wireCard(col, node);
    return col;
  }

  function wireCard(col, node) {
    const id = node.id;
    const q = (r) => col.querySelector('[data-role="' + r + '"]');
    q('target').addEventListener('change', function () {
      if (this.checked) state.targets.add(String(id)); else state.targets.delete(String(id));
      refreshTargetSummary();
    });
    const textEl = q('text');
    q('say').addEventListener('click', () => doNode(id, '/say', { text: textEl.value }, node.name + ' speaking'));
    q('ask').addEventListener('click', () => doNode(id, '/ask-ai', { text: textEl.value }, node.name + ' asked AI'));
    q('playAudio').addEventListener('click', () => playAudio(id, node, false));
    q('loopAudio').addEventListener('click', () => playAudio(id, node, true));
    q('stopAudio').addEventListener('click', () => doNode(id, '/stop-audio', {}, node.name + ' audio stopped'));
    q('autoStart').addEventListener('click', () => doNode(id, '/auto-ai/start', { interval: parseInt(q('autoInterval').value, 10) || 30 }, node.name + ' Auto-AI on'));
    q('autoStop').addEventListener('click', () => doNode(id, '/auto-ai/stop', {}, node.name + ' Auto-AI off'));
    // lazy-load audio list once the node is known online
    if (node.online) loadAudio(id, col);
  }

  function patchCard(col, node) {
    const dot = col.querySelector('[data-role="dot"]');
    if (dot) dot.className = 'fcc-dot ' + (node.online ? 'online' : 'offline');
    const chip = col.querySelector('[data-role="chip"]');
    if (chip) { const c = node.trusted === false ? 'untrusted' : (node.source || 'config'); chip.className = 'fcc-chip ' + c; chip.textContent = c; }
    const h = col.querySelector('[data-role="health"]');
    if (h) {
      if (node.online) {
        const bits = [];
        if (node.version) bits.push('v' + node.version);
        if (node.rssMb != null) bits.push(Math.round(node.rssMb) + 'MB');
        if (node.uptimeSec != null) bits.push('up ' + fmtUptime(node.uptimeSec));
        if (node.servoLatencyMs != null) bits.push(node.servoLatencyMs + 'ms');
        if (node.cpuCount != null) bits.push(node.cpuCount + ' cpu');
        h.textContent = bits.join(' · ') || (node.ip || '');
      } else {
        h.textContent = (node.error ? node.error : 'offline') + ' (' + (node.ip || '?') + ')';
      }
    }
    // If a node just came online and its webcam img has no src, start it.
    const img = col.querySelector('.fcc-cam-wrap img');
    if (img && node.online && !img.getAttribute('src')) { img.src = API + '/animatronic/' + node.id + '/webcam-stream'; }
  }

  function fmtUptime(s) { s = Math.round(s); if (s < 90) return s + 's'; if (s < 5400) return Math.round(s / 60) + 'm'; return Math.round(s / 3600) + 'h'; }

  // ---------- node actions ----------
  async function doNode(id, path, body, okMsg) {
    try { const r = await api('/animatronic/' + id + '/' + path.replace(/^\//, ''), { method: 'POST', body: JSON.stringify(body || {}) });
      log(okMsg + (r && r.data && r.data.text ? ': “' + r.data.text + '”' : ''), 'ok');
    } catch (e) { log('Node ' + id + ' ' + path + ' failed: ' + e.message, 'err'); }
  }
  async function loadAudio(id, col) {
    try {
      const r = await api('/animatronic/' + id + '/audio-files');
      const sel = col.querySelector('[data-role="audioSel"]');
      if (!sel) return;
      const files = (r && (r.audio || r.files)) || [];
      for (const f of files) {
        const o = el('option'); o.value = f.id || f.filename; o.textContent = f.title || f.filename || o.value;
        o.setAttribute('data-filename', f.filename || ''); sel.appendChild(o);
      }
    } catch (e) { /* node may have no audio API — non-fatal */ }
  }
  async function playAudio(id, node, loop) {
    const col = $('#' + cardId(id)); const sel = col && col.querySelector('[data-role="audioSel"]');
    if (!sel || !sel.value) { log(node.name + ': pick an audio clip first', 'warn'); return; }
    const opt = sel.options[sel.selectedIndex];
    try {
      await api('/animatronic/' + id + '/play-audio', { method: 'POST', body: JSON.stringify({ audioId: sel.value, filename: opt.getAttribute('data-filename') || undefined, audioTitle: opt.textContent, loop: !!loop }) });
      log(node.name + (loop ? ' looping ' : ' playing ') + '“' + opt.textContent + '”', 'ok');
    } catch (e) { log(node.name + ' play-audio failed: ' + e.message, 'err'); }
  }

  // ---------- webcam modal ----------
  let camModal = null;
  function openCam(node) {
    if (!node.online) return;
    if (!camModal) camModal = new bootstrap.Modal($('#fccCamModal'));
    $('#fccCamTitle').textContent = node.name + ' — live';
    $('#fccCamModalImg').src = API + '/animatronic/' + node.id + '/webcam-stream';
    camModal.show();
  }
  $('#fccCamModal').addEventListener('hidden.bs.modal', () => { $('#fccCamModalImg').src = ''; });

  // ---------- fleet health poll ----------
  async function refresh() {
    let health, nodesInfo;
    try { health = await api('/fleet-health'); }
    catch (e) { log('Fleet health failed: ' + e.message, 'err'); showWallError(e.message); return; }
    try { nodesInfo = await api('/nodes'); } catch (_) { nodesInfo = { nodes: [], avahiAvailable: null }; }

    // merge /nodes provenance (source/trust) into health cards by id
    const prov = new Map();
    (nodesInfo.nodes || []).forEach(n => prov.set(String(n.id), n));
    const merged = (health.nodes || []).map(n => {
      const p = prov.get(String(n.id)) || {};
      return Object.assign({}, n, { source: p.source || n.source, trusted: p.trusted, hostname: p.hostname });
    });

    renderWall(merged);
    renderFleetPill(health);
    renderDiscovery(nodesInfo);
  }

  function renderWall(nodes) {
    const loading = $('#wallLoading'); if (loading) loading.remove();
    const wall = $('#nodeWall');
    // online first, then offline; stable by id within group
    nodes.sort((a, b) => (b.online === a.online) ? String(a.id).localeCompare(String(b.id)) : (b.online ? 1 : -1));
    for (const node of nodes) {
      state.nodes.set(String(node.id), node);
      let col = $('#' + cardId(node.id));
      if (!col) { col = buildCard(node); wall.appendChild(col); }
      patchCard(col, node); // populate health/dot immediately on first render too
      col.classList.toggle('fcc-ghost', !node.online);
    }
    refreshTargetSummary();
  }
  function showWallError(msg) {
    const wall = $('#nodeWall');
    if (wall.querySelector('.fcc-card')) return; // keep existing cards
    wall.innerHTML = '<div class="col-12"><div class="alert alert-danger d-flex justify-content-between align-items-center">' +
      '<span>Could not load fleet: ' + esc(msg) + '</span>' +
      '<button class="btn btn-sm btn-outline-light" onclick="location.reload()">Retry</button></div></div>';
  }
  function renderFleetPill(health) {
    const online = health.online || 0, total = health.total || 0;
    $('#fleetCount').textContent = online + ' / ' + total + ' online';
    const dot = $('#fleetDot');
    dot.className = 'fcc-dot ' + (online === 0 ? 'offline' : (online < total ? 'warn' : 'online'));
  }
  function renderDiscovery(info) {
    state.avahi = info.avahiAvailable;
    const ds = $('#discoveryState');
    if (info.avahiAvailable === true) ds.innerHTML = 'mDNS: <span class="text-success">available</span>';
    else if (info.avahiAvailable === false) ds.innerHTML = 'mDNS: <span class="text-warning">unavailable</span> — using config + pins';
    else ds.innerHTML = 'mDNS: <span class="text-secondary">unknown</span>';
    const counts = { config: 0, discovered: 0, manual: 0 };
    (info.nodes || []).forEach(n => { counts[n.source] = (counts[n.source] || 0) + 1; });
    $('#sourceBreakdown').textContent = counts.config + ' config · ' + counts.discovered + ' discovered · ' + counts.manual + ' pinned';
  }

  // ---------- goblins ----------
  async function loadGoblins() {
    const row = $('#goblinRow');
    try {
      const res = await fetch('/goblin-management/api/goblins');
      const data = await res.json();
      const goblins = (data && (data.goblins || data)) || [];
      if (!goblins.length) { row.innerHTML = '<div class="col-12 text-secondary small">No goblins registered.</div>'; return; }
      row.innerHTML = '';
      goblins.forEach(g => {
        const id = g.id || g.goblinId; // fixed: goblin objects expose `id`, not `goblinId`
        const online = g.online || g.status === 'online';
        const col = el('div', 'col-sm-6 col-lg-3');
        col.innerHTML = '<div class="card"><div class="card-body py-2 d-flex align-items-center gap-2">' +
          '<span class="fcc-dot ' + (online ? 'online' : 'offline') + '"></span>' +
          '<span class="me-auto text-truncate" title="' + esc(g.name || id) + '">' + esc(g.name || id) + '</span>' +
          '<a class="btn btn-sm btn-outline-secondary" href="/goblin-management?goblin=' + encodeURIComponent(id) + '" title="Open in Goblin Management">Manage</a>' +
          '</div></div>';
        row.appendChild(col);
      });
    } catch (e) { row.innerHTML = '<div class="col-12 text-danger small">Goblin list failed: ' + esc(e.message) + '</div>'; }
  }

  // ---------- global actions ----------
  async function fleetAction(desc, path, opts) {
    try { const r = await api(path, opts); log(desc + ' → ' + summarize(r), r && r.success === false ? 'warn' : 'ok'); return r; }
    catch (e) { log(desc + ' failed: ' + e.message, 'err'); }
  }

  document.querySelectorAll('.fcc-sp').forEach(btn => {
    btn.addEventListener('click', async () => {
      const sp = btn.getAttribute('data-sp');
      const next = !btn.classList.contains('on');
      const r = await fleetAction((next ? 'Enable ' : 'Disable ') + sp, '/superpower/' + sp,
        { method: 'POST', body: JSON.stringify({ enabled: next, ids: targetIds() }) });
      if (r) { btn.classList.toggle('on', next); btn.classList.remove('mixed'); }
    });
  });

  $('#sayAllBtn').addEventListener('click', async () => {
    const text = $('#sayAllText').value.trim(); if (!text) return;
    // targeted say uses per-node say when a subset is chosen, else say-all
    if (state.targets.size) { for (const id of state.targets) doNode(id, '/say', { text }, (state.nodes.get(String(id)) || {}).name + ' speaking'); }
    else fleetAction('Say-all', '/say-all', { method: 'POST', body: JSON.stringify({ text }) });
  });

  $('#startLoops').addEventListener('click', () => fleetAction('Start queue loops', '/start-all-queue-loops', { method: 'POST' }));
  $('#stopLoops').addEventListener('click', () => fleetAction('Stop queue loops', '/stop-all-queue-loops', { method: 'POST', body: JSON.stringify({ ids: targetIds() }) }));
  $('#restartSvc').addEventListener('click', () => { if (confirm('Restart the MonsterBox service on ' + targetLabel() + '?')) fleetAction('Restart services', '/restart-services', { method: 'POST' }); });
  $('#rebootAll').addEventListener('click', () => { if (confirm('REBOOT ' + targetLabel() + '? Animatronics will go offline for ~30s.')) fleetAction('Reboot', '/reboot/animatronics', { method: 'POST', body: JSON.stringify({ ids: targetIds() ? targetIds().map(Number) : undefined }) }); });
  $('#estop').addEventListener('click', () => { if (confirm('EMERGENCY STOP ' + targetLabel() + '? Halts queues, audio, poses and mutes.')) fleetAction('EMERGENCY STOP', '/emergency-stop', { method: 'POST', body: JSON.stringify({ ids: targetIds() }) }); });

  const volEl = $('#masterVol'); let volTimer = null;
  volEl.addEventListener('input', () => { $('#masterVolVal').textContent = volEl.value + '%'; });
  volEl.addEventListener('change', () => {
    clearTimeout(volTimer);
    volTimer = setTimeout(() => fleetAction('Master volume ' + volEl.value + '%', '/volume', { method: 'PUT', body: JSON.stringify({ volume: parseInt(volEl.value, 10), ids: targetIds() }) }), 250);
  });

  $('#clearTargets').addEventListener('click', () => {
    state.targets.clear();
    document.querySelectorAll('[data-role="target"]').forEach(c => { c.checked = false; });
    refreshTargetSummary();
  });
  $('#refreshBtn').addEventListener('click', refresh);
  $('#clearLog').addEventListener('click', () => { $('#commandLog').innerHTML = ''; });

  $('#pinForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = $('#pinId').value.trim(), ip = $('#pinIp').value.trim(), name = $('#pinName').value.trim();
    if (!id || !ip) { log('Pin needs at least id and IP', 'warn'); return; }
    try { await api('/nodes/manual', { method: 'POST', body: JSON.stringify({ id, ip, name }) }); log('Pinned node ' + name + ' (' + ip + ')', 'ok'); $('#pinForm').reset(); refresh(); }
    catch (err) { log('Pin failed: ' + err.message, 'err'); }
  });

  // ---------- boot ----------
  log('Fleet Command Center ready', 'muted');
  refresh(); loadGoblins();
  setInterval(refresh, POLL_MS);
})();
</script>
