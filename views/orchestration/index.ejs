<div class="container-fluid">

    <header class="mb-page-header">
        <h1 class="mb-page-header-title">
            <i class="bi bi-broadcast"></i> Orchestration
            <span class="mb-text-secondary">· multi-animatronic broadcast control</span>
        </h1>
        <div class="mb-page-header-actions">
            <a href="/goblin-management" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-hdd-network"></i> Goblins
            </a>
        </div>
    </header>

    <!-- Command Log - Moved to Top -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-terminal"></i> Command Log
                    <button class="btn btn-sm btn-secondary float-end" onclick="clearLog()">
                        <i class="bi bi-trash"></i> Clear
                    </button>
                </div>
                <div class="card-body p-2">
                    <div class="mb-terminal-log" id="commandLog">
                        <div class="log-entry">🎃 Orchestration Control Center initialized...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- System Status -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-activity"></i> System Status
                    <button class="btn btn-sm btn-secondary float-end ms-2" onclick="disableAllWebcams()">
                        <i class="bi bi-camera-video-off"></i> Disable All Webcams
                    </button>
                    <button class="btn btn-sm btn-secondary float-end ms-2" onclick="enableAllWebcams()">
                        <i class="bi bi-camera-video"></i> Enable All Webcams
                    </button>
                    <button class="btn btn-sm btn-warning float-end" onclick="refreshStatus()">
                        <i class="bi bi-arrow-clockwise"></i> Refresh
                    </button>
                </div>
                <div class="card-body">
                    <div class="row" id="animatronicsStatus">
                        <div class="col-12 text-center">
                            <div class="spinner-border text-warning" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Goblin Panel -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-display"></i> Goblin Status
                    <a href="/goblin-management" class="btn btn-sm btn-outline-secondary float-end" target="_blank">
                        <i class="bi bi-box-arrow-up-right"></i> Goblin Management
                    </a>
                    <button class="btn btn-sm btn-outline-secondary float-end me-2" onclick="refreshGoblins()">
                        <i class="bi bi-arrow-clockwise"></i> Refresh
                    </button>
                </div>
                <div class="card-body">
                    <div class="row" id="goblinsStatus">
                        <div class="col-12 text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Broadcast Controls -->
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">
                    <i class="bi bi-megaphone"></i> Broadcast Speech
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Message to All Animatronics:</label>
                        <textarea class="form-control" id="broadcastText" rows="3"
                            placeholder="Enter message...">Welcome to Warner Castle!</textarea>
                    </div>
                    <button class="btn btn-warning w-100" onclick="sayAll()">
                        <i class="bi bi-volume-up"></i> Say to All
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">
                    <i class="bi bi-person-arms-up"></i> Random Poses
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Cooldown (ms):</label>
                        <input type="number" class="form-control" id="poseCooldown" value="3000">
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <button class="btn btn-success w-100" onclick="enableRandomPoses()">
                                <i class="bi bi-play-circle"></i> Enable All
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-danger w-100" onclick="disableRandomPoses()">
                                <i class="bi bi-stop-circle"></i> Disable All
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- System Commands -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-gear"></i> System Commands
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <button class="btn btn-warning w-100" onclick="restartServices()">
                                <i class="bi bi-arrow-clockwise"></i> Restart All Services
                            </button>
                        </div>
                        <div class="col-md-4 mb-3">
                            <button class="btn btn-info w-100" onclick="healthCheck()">
                                <i class="bi bi-heart-pulse"></i> Health Check
                            </button>
                        </div>
                        <div class="col-md-4 mb-3">
                            <button class="btn btn-danger w-100" onclick="rebootAll()">
                                <i class="bi bi-power"></i> Reboot All
                            </button>
                        </div>
                        <div class="col-md-4 mb-3">
                            <button class="btn btn-success w-100" onclick="startAllQueueLoops()">
                                <i class="bi bi-play-circle"></i> Start All Queue Loops
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function log(message, type) {
        type = type || 'info';
        var logDiv = document.getElementById('commandLog');
        var timestamp = new Date().toLocaleTimeString();
        var icon = type === 'error' ? '❌' : type === 'success' ? '✅' : 'ℹ️';

        // Limit to 15 lines
        var lines = logDiv.querySelectorAll('div');
        if (lines.length >= 15) {
            logDiv.removeChild(lines[0]);
        }

        logDiv.innerHTML += '<div class="log-entry">' + icon + ' [' + timestamp + '] ' + message + '</div>';
        logDiv.scrollTop = logDiv.scrollHeight;
    }

    function clearLog() {
        document.getElementById('commandLog').innerHTML = '<div class="log-entry">🎃 Log cleared...</div>';
    }

    // Webcam state management
    var webcamStates = {}; // { [animId]: boolean }
    var currentOnlineAnimatronics = []; // cache of online anims from last refresh

    function refreshStatus() {
        log('Refreshing system status...');
        fetch('/api/orchestration/status')
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    displayAnimatronics(data.animatronics);
                    log('Status refreshed successfully', 'success');
                } else {
                    log('Failed to refresh status', 'error');
                }
            })
            .catch(function (error) {
                log('Error: ' + error.message, 'error');
            });
    }

    function displayAnimatronics(animatronics) {
        var html = '';
        var onlineAnimatronics = animatronics.filter(function (a) { return a.online; });
        currentOnlineAnimatronics = onlineAnimatronics;
        var offlineAnimatronics = animatronics.filter(function (a) { return !a.online; });

        // Display offline animatronics as compact list
        if (offlineAnimatronics.length > 0) {
            html += '<div class="col-12 mb-3">';
            html += '  <div class="d-flex flex-wrap align-items-center gap-2 p-2 rounded bg-body-secondary border">';
            html += '    <strong>Offline:</strong> ';
            offlineAnimatronics.forEach(function (anim) {
                html += '<span class="badge bg-danger">';
                html += '  <i class="bi bi-exclamation-triangle"></i> ' + anim.name + ' (' + anim.ip + ')';
                html += '</span>';
            });
            html += '  </div>';
            html += '</div>';
        }

        // Display online animatronics with full controls
        onlineAnimatronics.forEach(function (anim) {
            // Use hostname for URL if available, fallback to IP
            var hostname = anim.hostname || anim.name.toLowerCase().replace(/\s+/g, '-');
            var conversationUrl = 'http://' + hostname + ':' + anim.port + '/conversation';
            var adminUrl = 'http://' + hostname + ':' + anim.port;

            html += '<div class="col-md-6 col-lg-4 col-xl-3 mb-3">';
            html += '  <div class="card mb-media-card">';
            html += '    <div class="card-body" data-agent-id="' + (anim.agentId || '') + '" data-character-id="' + (anim.characterId || '') + '" ondblclick="window.open(\'' + conversationUrl + '\', \'_blank\')" style="cursor: pointer;">';

            // Header with name and status
            html += '      <div class="d-flex justify-content-between align-items-center mb-2">';
            html += '        <h5 class="mb-0" onclick="event.stopPropagation(); window.open(\'' + adminUrl + '\', \'_blank\')" style="cursor: pointer;">';
            html += '          <i class="bi bi-box-arrow-up-right"></i> ' + anim.name;
            html += '        </h5>';
            html += '        <span class="mb-status-badge online">';
            html += '          <i class="bi bi-circle-fill"></i> ONLINE';
            html += '        </span>';
            html += '      </div>';

            // Character name if available
            if (anim.characterName) {
                html += '      <div class="text-warning fw-bold small mb-2">' + anim.characterName + '</div>';
            }

            // Webcam controls and stream (default OFF for performance)
            html += '      <div class="d-flex justify-content-between align-items-center mb-2" onclick="event.stopPropagation();">';
            html += '        <button id="webcam-toggle-' + anim.id + '" class="btn btn-sm btn-outline-light" onclick="toggleWebcam(' + anim.id + '); event.stopPropagation();">';
            html += '          <i class="bi bi-camera-video-off"></i> Webcam Off';
            html += '        </button>';
            html += '      </div>';
            html += '      <div onclick="event.stopPropagation();">';
            html += '        <img id="webcam-' + anim.id + '" class="w-100 rounded mb-2" alt="Live webcam feed" style="display:none; background: var(--bs-dark);" />';
            html += '        <div id="webcam-loading-' + anim.id + '" class="text-muted text-center py-3">';
            html += '          <i class="bi bi-camera-video-off"></i> Webcam off';
            html += '        </div>';
            html += '      </div>';

            // Audio file selector with Play/Loop controls
            html += '      <div class="p-2 rounded bg-body-secondary mb-2" onclick="event.stopPropagation();">';
            html += '        <select class="form-select form-select-sm mb-1" id="audio-' + anim.id + '">';
            html += '          <option value="">Select audio file...</option>';
            html += '        </select>';
            html += '        <div class="btn-group w-100 mb-1" role="group">';
            html += '          <button class="btn btn-sm btn-success" onclick="playAudio(\'' + anim.id + '\', \'' + anim.ip + '\', \'' + anim.port + '\', \'' + anim.name + '\')">';
            html += '            <i class="bi bi-play-fill"></i> Play';
            html += '          </button>';
            html += '          <button class="btn btn-sm btn-danger" onclick="stopAudio(\'' + anim.id + '\', \'' + anim.ip + '\', \'' + anim.port + '\', \'' + anim.name + '\')">';
            html += '            <i class="bi bi-stop-fill"></i> Stop';
            html += '          </button>';
            html += '        </div>';
            html += '        <div class="form-check form-check-sm">';
            html += '          <input class="form-check-input" type="checkbox" id="loop-' + anim.id + '">';
            html += '          <label class="form-check-label small" for="loop-' + anim.id + '">Loop continuously</label>';
            html += '        </div>';
            html += '      </div>';

            // AI interaction input group
            html += '      <div class="mb-2" onclick="event.stopPropagation();">';
            html += '        <input type="text" class="form-control form-control-sm mb-1" id="text-' + anim.id + '" placeholder="Type message...">';
            html += '        <div class="btn-group w-100 mb-1" role="group">';
            html += '          <button class="btn btn-sm btn-primary" onclick="askAI(\'' + anim.id + '\', \'' + anim.ip + '\', \'' + anim.port + '\', \'' + anim.name + '\')">';
            html += '            <i class="bi bi-chat-dots"></i> Ask AI';
            html += '          </button>';
            html += '          <button class="btn btn-sm btn-success" onclick="makeSay(\'' + anim.id + '\', \'' + anim.ip + '\', \'' + anim.port + '\', \'' + anim.name + '\')">';
            html += '            <i class="bi bi-megaphone"></i> Say';
            html += '          </button>';
            html += '        </div>';
            html += '      </div>';

            // Auto AI controls
            html += '      <div class="d-flex align-items-center gap-2" onclick="event.stopPropagation();">';
            html += '        <input type="number" id="autoai-interval-' + anim.id + '" class="form-control form-control-sm" ';
            html += '               value="30" min="10" max="300" placeholder="Interval (s)" style="width: 80px;">';
            html += '        <button id="autoai-btn-' + anim.id + '" class="btn btn-sm btn-warning flex-grow-1" ';
            html += '                onclick="toggleAutoAI(' + anim.id + ')">';
            html += '          <i class="bi bi-robot"></i> <span id="autoai-text-' + anim.id + '">Auto AI</span>';
            html += '        </button>';
            html += '      </div>';

            html += '      <small class="text-muted d-block text-center mt-2" onclick="event.stopPropagation();">' + anim.ip + ':' + anim.port + '</small>';
            html += '    </div>';
            html += '  </div>';
            html += '</div>';
        });
        document.getElementById('animatronicsStatus').innerHTML = html;

        // Re-apply webcam state after DOM re-render
        onlineAnimatronics.forEach(function (anim) {
            updateWebcamToggleUI(anim.id);
            if (webcamStates[anim.id]) {
                // Ensure enabled webcams are (re)loaded
                enableWebcam(anim.id);
            }
        });

        // Load audio files for each online animatronic
        onlineAnimatronics.forEach(function (anim) {
            loadAudioFiles(anim.id, anim.ip, anim.port);
        });

        // Load Auto AI statuses
        loadAutoAIStatuses();
    }

    async function loadWebcamForAnimatronic(anim) {
        const imgId = 'webcam-' + anim.id;
        const loadingId = 'webcam-loading-' + anim.id;

        try {
            // Prefer direct proxy stream endpoint to simplify client and avoid CORS
            const proxyUrl = '/api/orchestration/animatronic/' + anim.id + '/webcam-stream';
            const img = document.getElementById(imgId);
            const loading = document.getElementById(loadingId);

            if (img && loading) {
                img.src = proxyUrl + '?_=' + Date.now();
                img.style.display = 'block';
                img.onerror = function () {
                    this.style.display = 'none';
                    loading.innerHTML = '<small class="text-muted">Webcam unavailable</small>';
                };
                loading.style.display = 'none';
            }
        } catch (err) {
            console.error('Error loading webcam for ' + anim.id + ':', err);
            const loading = document.getElementById(loadingId);
            if (loading) {
                loading.innerHTML = '<small class="text-muted">Webcam unavailable</small>';
            }
        }
    }

    // Webcam control helpers
    function updateWebcamToggleUI(animId) {
        var btn = document.getElementById('webcam-toggle-' + animId);
        var img = document.getElementById('webcam-' + animId);
        var loading = document.getElementById('webcam-loading-' + animId);
        var isOn = !!webcamStates[animId];

        if (btn) {
            if (isOn) {
                btn.classList.remove('btn-outline-light');
                btn.classList.add('btn-warning');
                btn.innerHTML = '<i class="bi bi-camera-video"></i> Webcam On';
            } else {
                btn.classList.remove('btn-warning');
                btn.classList.add('btn-outline-light');
                btn.innerHTML = '<i class="bi bi-camera-video-off"></i> Webcam Off';
            }
        }

        if (!isOn) {
            if (img) {
                img.style.display = 'none';
                try { img.src = ''; } catch (e) { }
            }
            if (loading) {
                loading.style.display = 'block';
                loading.innerHTML = '<i class="bi bi-camera-video-off"></i> Webcam off';
            }
        }
    }

    function toggleWebcam(animId) {
        if (webcamStates[animId]) {
            disableWebcam(animId);
        } else {
            enableWebcam(animId);
        }
    }

    function enableWebcam(animId) {
        webcamStates[animId] = true;
        var loading = document.getElementById('webcam-loading-' + animId);
        var img = document.getElementById('webcam-' + animId);
        if (loading) {
            loading.style.display = 'block';
            loading.innerHTML = '<div class="spinner-border spinner-border-sm"></div> Loading webcam...';
        }
        if (img) {
            try { img.src = ''; } catch (e) { }
        }
        updateWebcamToggleUI(animId);
        // Reuse existing loader to fetch URL and attach stream
        loadWebcamForAnimatronic({ id: animId });
    }

    function disableWebcam(animId) {
        webcamStates[animId] = false;
        var img = document.getElementById('webcam-' + animId);
        var loading = document.getElementById('webcam-loading-' + animId);
        if (img) {
            try { img.src = ''; } catch (e) { }
            img.style.display = 'none';
        }
        if (loading) {
            loading.style.display = 'block';
            loading.innerHTML = '<i class="bi bi-camera-video-off"></i> Webcam off';
        }
        updateWebcamToggleUI(animId);
    }

    function enableAllWebcams() {
        if (!currentOnlineAnimatronics || currentOnlineAnimatronics.length === 0) return;
        log('Enabling webcams for all online animatronics...');
        currentOnlineAnimatronics.forEach(function (anim) { enableWebcam(anim.id); });
    }

    function disableAllWebcams() {
        if (!currentOnlineAnimatronics || currentOnlineAnimatronics.length === 0) return;
        log('Disabling webcams for all online animatronics...');
        currentOnlineAnimatronics.forEach(function (anim) { disableWebcam(anim.id); });
    }

    function sayAll() {
        var text = document.getElementById('broadcastText').value;
        if (!text) {
            log('Please enter a message', 'error');
            return;
        }
        log('Broadcasting message to all animatronics...');
        fetch('/api/orchestration/say-all', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text: text })
        })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    log('Message broadcast successfully to ' + data.results.length + ' animatronics', 'success');
                } else {
                    log('Broadcast failed', 'error');
                }
            })
            .catch(function (error) {
                log('Error: ' + error.message, 'error');
            });
    }

    function enableRandomPoses() {
        var cooldown = document.getElementById('poseCooldown').value;
        log('Enabling random poses on all animatronics...');
        fetch('/api/orchestration/enable-random-poses', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ cooldownMs: parseInt(cooldown) })
        })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    log('Random poses enabled on all animatronics', 'success');
                } else {
                    log('Failed to enable random poses', 'error');
                }
            })
            .catch(function (error) {
                log('Error: ' + error.message, 'error');
            });
    }

    function disableRandomPoses() {
        log('Disabling random poses on all animatronics...');
        fetch('/api/orchestration/disable-random-poses', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    log('Random poses disabled on all animatronics', 'success');
                } else {
                    log('Failed to disable random poses', 'error');
                }
            })
            .catch(function (error) {
                log('Error: ' + error.message, 'error');
            });
    }

    // Restart all services on animatronics
    function restartServices() {
        if (!confirm('Restart all animatronic services? This will take about 30 seconds.')) return;
        log('Restarting all services...');
        fetch('/api/orchestration/restart-services', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    log('All services restarted successfully', 'success');
                    setTimeout(refreshStatus, 5000);
                } else {
                    log('Service restart failed: ' + (data.error || 'Unknown error'), 'error');
                }
            })
            .catch(function (error) {
                log('Error: ' + error.message, 'error');
            });
    }

    // Reboot only currently online animatronics and goblins
    function rebootAll() {
        if (!confirm('Reboot all online animatronics and goblins? Devices will be unavailable for ~90 seconds.')) return;

        var onlineAnimIds = (window.currentOnlineAnimatronics || []).map(function (a) { return a.id; });
        var onlineGoblinIds = (Array.isArray(window.currentGoblins) ? window.currentGoblins : [])
            .filter(function (g) { return g.status === 'online'; })
            .map(function (g) { return g.id; });

        if ((!onlineAnimIds || onlineAnimIds.length === 0) && (!onlineGoblinIds || onlineGoblinIds.length === 0)) {
            log('No online devices detected to reboot.', 'error');
            return;
        }

        log('Rebooting ' + (onlineAnimIds.length) + ' animatronics and ' + (onlineGoblinIds.length) + ' goblins...');

        var requests = [];

        if (onlineAnimIds && onlineAnimIds.length > 0) {
            requests.push(
                fetch('/api/orchestration/reboot/animatronics', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ids: onlineAnimIds })
                })
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (data.success) {
                            log('Reboot command sent to animatronics', 'success');
                        } else {
                            log('Failed to reboot animatronics: ' + (data.error || 'Unknown error'), 'error');
                        }
                    })
                    .catch(function (error) {
                        log('Error rebooting animatronics: ' + error.message, 'error');
                    })
            );
        }

        if (onlineGoblinIds && onlineGoblinIds.length > 0) {
            requests.push(
                fetch('/api/orchestration/reboot/goblins', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ids: onlineGoblinIds })
                })
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (data.success) {
                            log('Reboot command sent to goblins', 'success');
                        } else {
                            log('Failed to reboot goblins: ' + (data.error || 'Unknown error'), 'error');
                        }
                    })
                    .catch(function (error) {
                        log('Error rebooting goblins: ' + error.message, 'error');
                    })
            );
        }

        Promise.allSettled(requests).then(function () {
            log('Devices will be back online in ~90 seconds. Auto-refreshing in 2 minutes...');
            setTimeout(function () {
                refreshStatus();
                refreshGoblins();
                log('Auto-refresh complete', 'success');
            }, 120000);
        });
    }

    function healthCheck() {
        log('Running health check on all animatronics...');
        fetch('/api/orchestration/status')
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    var online = data.animatronics.filter(function (a) { return a.online; }).length;
                    var total = data.animatronics.length;
                    log('Health check complete: ' + online + '/' + total + ' animatronics online', 'success');
                }
            })
            .catch(function (error) {
                log('Health check failed: ' + error.message, 'error');
            });
    }

    function startAllQueueLoops() {
        if (!confirm('Start all animatronic queue loops? This will start their programmed scenes.')) return;
        log('Starting all queue loops...');
        fetch('/api/orchestration/start-all-queue-loops', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    log('All queue loops started successfully', 'success');
                    if (data.results) {
                        data.results.forEach(function (result) {
                            if (result.success) {
                                log('  ' + result.name + ': ' + result.message, 'success');
                            } else {
                                log('  ' + result.name + ': ' + result.error, 'error');
                            }
                        });
                    }
                } else {
                    log('Failed to start queue loops: ' + (data.error || 'Unknown error'), 'error');
                }
            })
            .catch(function (error) {
                log('Error starting queue loops: ' + error.message, 'error');
            });
    }

    // WebSocket connections for AI chat per animatronic
    var aiWebSockets = {}; // { [animId]: { ws, agentId, characterId, name, ready, pendingMessage } }

    function connectAIWebSocket(animId, ip, port, name, agentId, characterId) {
        // Don't reconnect if already connected
        if (aiWebSockets[animId] && aiWebSockets[animId].ws && aiWebSockets[animId].ws.readyState === WebSocket.OPEN) {
            return aiWebSockets[animId];
        }

        var wsPort = document.body.getAttribute('data-ws-port') || '8795';
        var wsUrl = 'ws://' + ip + ':' + wsPort;
        console.log('Connecting to AI WebSocket for ' + name + ':', wsUrl);

        var ws = new WebSocket(wsUrl);
        var wsData = {
            ws: ws,
            agentId: agentId,
            characterId: characterId,
            name: name,
            ready: false,
            pendingMessage: null
        };

        ws.onopen = function () {
            console.log('AI WebSocket opened for ' + name + ', waiting for server confirmation...');
        };

        ws.onmessage = function (event) {
            var message = JSON.parse(event.data);

            if (message.type === 'connected') {
                // Now we can start the conversation
                console.log('AI WebSocket connected for ' + name);
                // Send configuration messages with slight delays to ensure processing
                setTimeout(function () {
                    console.log('Setting character ID:', characterId);
                    ws.send(JSON.stringify({
                        type: 'set_character',
                        characterId: characterId
                    }));
                }, 50);
                setTimeout(function () {
                    console.log('Setting output mode to server');
                    ws.send(JSON.stringify({
                        type: 'set_output_mode',
                        mode: 'server' // Play on animatronic's speaker
                    }));
                }, 100);
                setTimeout(function () {
                    console.log('Starting conversation with agent:', agentId);
                    ws.send(JSON.stringify({
                        type: 'start_conversation',
                        agentId: agentId
                    }));
                }, 150);
            } else if (message.type === 'conversation_started') {
                console.log('Conversation started with agent for ' + name);
                wsData.ready = true;
                // Send any pending message now that conversation is ready
                if (wsData.pendingMessage) {
                    console.log('Sending pending message:', wsData.pendingMessage);
                    ws.send(JSON.stringify({
                        type: 'send_message',
                        text: wsData.pendingMessage
                    }));
                    wsData.pendingMessage = null;
                }
            } else if (message.type === 'agent_response') {
                // Got AI response with text and audio
                var responseText = message.text || 'Audio response';

                // Only log if we have actual text (not just "Audio response")
                if (responseText && responseText !== 'Audio response') {
                    var displayText = responseText.length > 150 ? responseText.substring(0, 150) + '...' : responseText;
                    log(name + ' AI responded: "' + displayText + '"', 'success');
                }

                // Audio should be playing automatically on the server speaker
            } else if (message.type === 'error') {
                console.error('WebSocket error from ' + name + ':', message);
                log(name + ' AI error: ' + (message.message || JSON.stringify(message)), 'error');
            } else {
                // Suppress excessive debug logging
                if (message.type !== 'debug') {
                    console.log('WebSocket message from ' + name + ':', message.type, message);
                }
            }
        };

        ws.onerror = function (error) {
            console.error('AI WebSocket error for ' + name + ':', error);
        };

        ws.onclose = function () {
            console.log('AI WebSocket closed for ' + name);
            delete aiWebSockets[animId];
        };

        aiWebSockets[animId] = wsData;
        return wsData;
    }

    function askAI(animId, ip, port, name) {
        var inputEl = document.getElementById('text-' + animId);
        var question = inputEl.value.trim();

        if (!question) {
            log('Please enter a question for ' + name, 'error');
            return;
        }

        log('Asking AI on ' + name + ': "' + question + '"');

        // Get agent ID and character ID from the card
        var card = inputEl.closest('.card-body');
        var agentId = card.getAttribute('data-agent-id');
        var characterId = card.getAttribute('data-character-id');

        if (!agentId) {
            log(name + ' has no AI agent configured', 'error');
            return;
        }

        // Connect or reuse WebSocket
        var wsData = aiWebSockets[animId];
        if (!wsData || !wsData.ws || wsData.ws.readyState !== WebSocket.OPEN) {
            wsData = connectAIWebSocket(animId, ip, port, name, agentId, characterId);
            wsData.pendingMessage = question;
        } else if (!wsData.ready) {
            // Connection is open but conversation not started yet, queue the message
            wsData.pendingMessage = question;
        } else {
            // Already connected and ready, send immediately
            wsData.ws.send(JSON.stringify({
                type: 'send_message',
                text: question
            }));
        }

        inputEl.value = '';
    }

    function makeSay(animId, ip, port, name) {
        var inputEl = document.getElementById('text-' + animId);
        var text = inputEl.value.trim();

        if (!text) {
            log('Please enter text for ' + name + ' to say', 'error');
            return;
        }

        log('Making ' + name + ' say: "' + text + '"');

        var url = '/api/orchestration/animatronic/' + animId + '/say';
        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text: text })
        })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    log(name + ' is speaking', 'success');
                    inputEl.value = '';
                } else {
                    log(name + ' speech failed: ' + (data.error || 'Unknown error'), 'error');
                }
            })
            .catch(function (error) {
                log('Error making ' + name + ' speak: ' + error.message, 'error');
            });
    }

    async function loadAudioFiles(animId, ip, port) {
        const url = '/api/orchestration/animatronic/' + animId + '/audio-files';
        const selectEl = document.getElementById('audio-' + animId);

        if (!selectEl) {
            console.error('Audio select element not found for animId:', animId);
            return;
        }

        const maxAttempts = 3;
        for (let attempt = 1; attempt <= maxAttempts; attempt++) {
            try {
                const response = await fetch(url);
                if (!response.ok) {
                    throw new Error('HTTP ' + response.status);
                }
                const data = await response.json();
                if (data.success && data.audio && data.audio.length > 0) {
                    // Clear ALL options including placeholder
                    selectEl.innerHTML = '';

                    // Add placeholder option
                    const placeholder = document.createElement('option');
                    placeholder.value = '';
                    placeholder.textContent = 'Select audio file...';
                    selectEl.appendChild(placeholder);

                    // Create a Set to track unique audio IDs and prevent duplicates
                    const seenIds = new Set();

                    // Add audio files (filter out duplicates by ID)
                    data.audio.forEach(function (file) {
                        if (!seenIds.has(file.id)) {
                            seenIds.add(file.id);
                            const option = document.createElement('option');
                            option.value = file.id;
                            option.textContent = file.title || file.filename;
                            if (file.filename) option.setAttribute('data-filename', file.filename);
                            selectEl.appendChild(option);
                        }
                    });
                }
                return; // success or empty; stop retrying
            } catch (err) {
                console.error('Attempt ' + attempt + ' failed loading audio files for animId ' + animId + ':', err.message);
                if (attempt >= maxAttempts) {
                    log('Failed to load audio files for animatronic ' + animId + ' after ' + maxAttempts + ' attempts', 'error');
                    return;
                }
                await new Promise(r => setTimeout(r, 200 * attempt));
            }
        }
    }

    function playAudio(animId, ip, port, name) {
        var selectEl = document.getElementById('audio-' + animId);
        var audioId = selectEl.value;
        var loopEl = document.getElementById('loop-' + animId);
        var loop = loopEl.checked;

        if (!audioId) {
            log('Please select an audio file for ' + name, 'error');
            return;
        }

        var audioName = selectEl.options[selectEl.selectedIndex].text;
        log('Playing audio on ' + name + ': "' + audioName + '"' + (loop ? ' (looping)' : ''));

        var url = '/api/orchestration/animatronic/' + animId + '/play-audio';
        var audioTitle = audioName;
        var selectedOption = selectEl.options[selectEl.selectedIndex];
        var filename = selectedOption && selectedOption.getAttribute('data-filename') ? selectedOption.getAttribute('data-filename') : undefined;
        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ audioId: audioId, loop: loop, audioTitle: audioTitle, filename: filename })
        })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    log(name + ' is playing audio' + (loop ? ' (looping)' : ''), 'success');
                } else {
                    log(name + ' audio playback failed: ' + (data.error || 'Unknown error'), 'error');
                }
            })
            .catch(function (error) {
                log('Error playing audio on ' + name + ': ' + error.message, 'error');
            });
    }

    function stopAudio(animId, ip, port, name) {
        log('Stopping audio on ' + name);

        var url = '/api/orchestration/animatronic/' + animId + '/stop-audio';
        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                if (data.success) {
                    log(name + ' audio stopped', 'success');
                } else {
                    log(name + ' audio stop failed: ' + (data.error || 'Unknown error'), 'error');
                }
            })
            .catch(function (error) {
                log('Error stopping audio on ' + name + ': ' + error.message, 'error');
            });
    }

    // Auto AI Functions
    async function loadAutoAIStatuses() {
        try {
            const response = await fetch('/api/orchestration/auto-ai/status');
            const data = await response.json();

            if (data.success && data.statuses) {
                Object.keys(data.statuses).forEach(animId => {
                    const status = data.statuses[animId];
                    if (status.active) {
                        updateAutoAIButton(parseInt(animId), true, status.interval);
                    }
                });
            }
        } catch (error) {
            console.error('Error loading Auto AI statuses:', error);
        }
    }

    async function toggleAutoAI(animId) {
        const btn = document.getElementById('autoai-btn-' + animId);
        const btnText = document.getElementById('autoai-text-' + animId);
        const intervalInput = document.getElementById('autoai-interval-' + animId);

        if (!btn || !btnText) return;

        // Check if Auto AI is currently active
        const isActive = btn.classList.contains('btn-danger');

        try {
            if (isActive) {
                // Stop Auto AI
                log('Stopping Auto AI for animatronic ' + animId + '...');
                const response = await fetch('/api/orchestration/animatronic/' + animId + '/auto-ai/stop', {
                    method: 'POST'
                });
                const data = await response.json();

                if (data.success) {
                    log('Auto AI stopped for animatronic ' + animId, 'success');
                    updateAutoAIButton(animId, false);
                } else {
                    log('Failed to stop Auto AI: ' + (data.error || 'Unknown error'), 'error');
                }
            } else {
                // Start Auto AI
                const interval = parseInt(intervalInput.value) || 30;
                log('Starting Auto AI for animatronic ' + animId + ' with ' + interval + 's interval...');

                const response = await fetch('/api/orchestration/animatronic/' + animId + '/auto-ai/start', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ interval: interval })
                });
                const data = await response.json();

                if (data.success) {
                    log('Auto AI started for animatronic ' + animId, 'success');
                    updateAutoAIButton(animId, true, interval);
                } else {
                    log('Failed to start Auto AI: ' + (data.error || 'Unknown error'), 'error');
                }
            }
        } catch (error) {
            log('Error toggling Auto AI: ' + error.message, 'error');
        }
    }

    function updateAutoAIButton(animId, isActive, interval) {
        var btn = document.getElementById('autoai-btn-' + animId);
        var btnText = document.getElementById('autoai-text-' + animId);
        var intervalInput = document.getElementById('autoai-interval-' + animId);

        if (!btn || !btnText) return;

        if (isActive) {
            btn.classList.remove('btn-warning');
            btn.classList.add('btn-danger');
            btnText.textContent = 'Stop Auto AI';
            if (intervalInput && interval) {
                intervalInput.value = interval;
                intervalInput.disabled = true;
            }
        } else {
            btn.classList.remove('btn-danger');
            btn.classList.add('btn-warning');
            btnText.textContent = 'Auto AI';
            if (intervalInput) {
                intervalInput.disabled = false;
            }
        }
    }

    // Goblin Functions
    async function refreshGoblins() {
        log('Refreshing Goblin status...');
        try {
            const response = await fetch('/goblin-management/api/goblins');
            const data = await response.json();

            if (data.success) {
                // cache goblins globally for actions like rebootAll
                window.currentGoblins = data.goblins || [];
                displayGoblins(data.goblins);
                log('Goblin status refreshed (' + data.goblins.length + ' total)', 'success');
            } else {
                log('Failed to refresh Goblin status', 'error');
            }
        } catch (error) {
            log('Error: ' + error.message, 'error');
        }
    }

    function displayGoblins(goblins) {
        var html = '';

        if (!goblins || goblins.length === 0) {
            html += '<div class="col-12 text-center text-muted py-4">';
            html += '  <i class="bi bi-inbox"></i> No Goblins registered';
            html += '</div>';
        } else {
            goblins.forEach(function (goblin) {
                var statusClass = goblin.status === 'online' ? 'online' : 'offline';
                var statusText = goblin.status === 'online' ? 'ONLINE' : 'OFFLINE';
                var goblinUrl = '/goblin-management?goblin=' + goblin.goblinId;

                html += '<div class="col-md-6 col-lg-4 col-xl-3 mb-3">';
                html += '  <div class="card mb-device-card ' + statusClass + '" ondblclick="window.open(\'' + goblinUrl + '\', \'_blank\')" style="cursor: pointer;">';
                html += '    <div class="card-body">';
                html += '      <div class="d-flex justify-content-between align-items-center mb-2">';
                html += '        <h6 class="mb-0"><i class="bi bi-display"></i> ' + goblin.name + '</h6>';
                html += '        <span class="mb-status-badge ' + statusClass + '">' + statusText + '</span>';
                html += '      </div>';
                html += '      <div class="text-muted small mb-2">';
                html += '        <div><strong>ID:</strong> ' + goblin.goblinId + '</div>';
                html += '        <div><strong>IP:</strong> ' + (goblin.ipAddress || 'N/A') + '</div>';
                html += '        <div><strong>Host:</strong> ' + (goblin.hostname || 'N/A') + '</div>';
                html += '      </div>';

                // Currently Playing section
                if (goblin.status === 'online' && (goblin.currentVideo || goblin.currentAudio)) {
                    html += '      <div class="p-2 rounded bg-body-secondary small mt-2">';
                    html += '        <strong><i class="bi bi-play-circle"></i> Currently Playing:</strong><br>';

                    if (goblin.currentVideo) {
                        html += '        <span class="text-truncate d-block"><i class="bi bi-film"></i> ' + (goblin.currentVideo.title || goblin.currentVideo.filename || 'Video') + '</span>';
                    }
                    if (goblin.currentAudio) {
                        html += '        <span class="text-truncate d-block"><i class="bi bi-music-note"></i> ' + (goblin.currentAudio.title || goblin.currentAudio.filename || 'Audio') + '</span>';
                    }

                    html += '      </div>';
                } else if (goblin.status === 'online') {
                    html += '      <div class="p-2 rounded bg-body-secondary small mt-2 text-muted">';
                    html += '        <i class="bi bi-pause-circle"></i> Nothing playing';
                    html += '      </div>';
                }

                html += '      <div class="text-muted small mt-2">';
                html += '        <i class="bi bi-clock"></i> Last seen: ' + (goblin.lastSeen ? new Date(goblin.lastSeen).toLocaleString() : 'Never');
                html += '      </div>';
                html += '    </div>';
                html += '  </div>';
                html += '</div>';
            });
        }

        document.getElementById('goblinsStatus').innerHTML = html;
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function () {
        refreshStatus();
        refreshGoblins();
        // Auto-refresh every 30 seconds
        setInterval(refreshStatus, 30000);
        setInterval(refreshGoblins, 30000);
    });
</script>
