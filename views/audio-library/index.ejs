        <script src="/js/audio-library.js"></script>
        <script>
            // Stop all audio playback
            function stopAllAudio() {
                fetch('/api/audio/stop-all', { method: 'POST' })
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (data.success) {
                            console.log('✅ All audio stopped');
                            hideCurrentPlayback();
                        }
                    })
                    .catch(function (error) {
                        console.error('❌ Error stopping audio:', error);
                    });
            }

            // Show current playback indicator
            function showCurrentPlayback(filename) {
                var indicator = document.getElementById('currentPlaybackIndicator');
                var fileSpan = document.getElementById('currentPlaybackFile');
                if (indicator && fileSpan) {
                    fileSpan.textContent = filename;
                    indicator.classList.remove('d-none');
                }
            }

            // Hide current playback indicator
            function hideCurrentPlayback() {
                var indicator = document.getElementById('currentPlaybackIndicator');
                if (indicator) {
                    indicator.classList.add('d-none');
                }
            }

            // Override the play function to show current playback
            var originalPlayAudio = window.playAudio;
            window.playAudio = function (file) {
                showCurrentPlayback(file.name);
                if (originalPlayAudio) {
                    originalPlayAudio(file);
                }
            };
        </script>
