            <!-- Toolbar: single compact row -->
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="d-flex align-items-center gap-2">
                    <h5 class="mb-0"><i class="bi bi-music-note-list"></i> Audio Library</h5>
                    <span class="badge bg-primary" id="totalFiles">0 files</span>
                    <span class="badge bg-secondary" id="totalSize">0 B</span>
                    <span class="badge bg-info" id="totalCategories">0 categories</span>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <!-- Speaker Part Selector -->
                    <div class="d-inline-flex align-items-center">
                        <label for="speakerSelect" class="me-1 mb-0 small text-muted"><i class="bi bi-speaker"></i></label>
                        <select id="speakerSelect" class="form-select form-select-sm" style="min-width: 180px;" data-bs-toggle="tooltip" data-bs-placement="top" title="Select audio output speaker"></select>
                    </div>
                    <button class="btn btn-danger btn-sm" id="stopAllBtn" data-bs-toggle="tooltip" data-bs-placement="top" title="Stop all audio playback">
                        <i class="bi bi-stop-circle"></i> Stop All
                    </button>
                    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#uploadModal" data-bs-tooltip="tooltip" data-bs-placement="top" title="Upload audio files to the library">
                        <i class="bi bi-cloud-upload"></i> Upload
                    </button>
                </div>
            </div>

            <!-- Now Playing bar (hidden by default) -->
            <div id="nowPlaying" class="alert alert-info py-1 px-3 d-none mb-2 d-flex align-items-center">
                <i class="bi bi-volume-up me-2"></i> Now Playing: <strong class="ms-1" id="nowPlayingTitle">-</strong>
                <button class="btn btn-sm btn-outline-danger ms-auto" id="nowPlayingStop">Stop</button>
            </div>

            <!-- Search/Filter: single compact row -->
            <div class="d-flex gap-2 mb-2 flex-wrap align-items-center">
                <input type="text" class="form-control form-control-sm" id="searchInput" placeholder="Search files..." style="max-width:300px;" data-bs-toggle="tooltip" data-bs-placement="top" title="Search audio files by name">
                <select class="form-select form-select-sm" id="categoryFilter" style="max-width:150px;" data-bs-toggle="tooltip" data-bs-placement="top" title="Filter by category">
                    <option value="all">All Categories</option>
                </select>
                <select class="form-select form-select-sm" id="sortBy" style="max-width:150px;" data-bs-toggle="tooltip" data-bs-placement="top" title="Sort audio files">
                    <option value="title">Title A-Z</option>
                    <option value="uploadedAt">Newest First</option>
                    <option value="duration">Duration</option>
                    <option value="fileSize">File Size</option>
                    <option value="playCount">Most Played</option>
                </select>
                <div class="form-check form-switch d-flex align-items-center ms-1">
                    <input class="form-check-input" type="checkbox" id="favoritesOnly" data-bs-toggle="tooltip" data-bs-placement="top" title="Show favorites only">
                    <label class="form-check-label ms-1 small" for="favoritesOnly">Favs</label>
                </div>
            </div>

            <!-- Audio Files Table -->
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle" id="audioTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:40px;"></th>
                            <th style="width:30px;"></th>
                            <th>Title</th>
                            <th style="width:110px;">Category</th>
                            <th style="width:60px;">Time</th>
                            <th style="width:50px;">Fmt</th>
                            <th style="width:70px;">Size</th>
                            <th style="width:150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="audioTableBody">
                    </tbody>
                </table>
            </div>

            <!-- Empty State -->
            <div id="emptyState" style="display:none;" class="text-center py-5">
                <i class="bi bi-music-note-list text-muted" style="font-size:3rem;"></i>
                <h5 class="text-muted mt-2">No Audio Files</h5>
                <p class="text-muted">Upload some audio files to get started.</p>
                <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="bi bi-cloud-upload"></i> Upload Audio
                </button>
            </div>

        <!-- Upload Modal -->
        <div class="modal fade" id="uploadModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-cloud-upload"></i> Upload Audio Files
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <!-- Drag and Drop Zone -->
                        <div class="mb-drop-zone mb-4" id="dragDropZone">
                            <i class="bi bi-cloud-upload fs-1 text-muted"></i>
                            <h4 class="mt-3">Drag & Drop Audio Files Here</h4>
                            <p class="text-muted">Or click to browse files</p>
                            <input type="file" id="audioFileInput" multiple accept="audio/*" style="display: none;">
                            <button type="button" class="btn btn-outline-primary"
                                onclick="document.getElementById('audioFileInput').click()"
                                data-bs-toggle="tooltip" data-bs-placement="top" title="Browse local files to upload">
                                <i class="bi bi-folder2-open"></i> Browse Files
                            </button>
                        </div>

                        <!-- Upload Form -->
                        <form id="uploadForm">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Category</label>
                                    <select class="form-select" name="category" id="uploadCategory">
                                        <option value="other">Other</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Tags (comma separated)</label>
                                    <input type="text" class="form-control" name="tags"
                                        placeholder="spooky, halloween, monster">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Description</label>
                                    <textarea class="form-control" name="description" rows="2"
                                        placeholder="Optional description for the audio files"></textarea>
                                </div>
                            </div>
                        </form>

                        <!-- Upload Progress -->
                        <div class="upload-progress mt-3" style="display:none;">
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                            </div>
                            <div class="mt-2">
                                <small class="text-muted" id="uploadStatus">Preparing upload...</small>
                            </div>
                        </div>

                        <!-- Selected Files List -->
                        <div id="selectedFilesList" class="mt-3" style="display: none;">
                            <h6>Selected Files:</h6>
                            <div id="filesList"></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" id="uploadBtn" disabled>
                            <i class="bi bi-cloud-upload"></i> Upload Files
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Audio Player Modal -->
        <div class="modal fade" id="audioPlayerModal" tabindex="-1">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="playerTitle">
                            <i class="bi bi-play-circle"></i> Audio Player
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div id="audioPlayerContainer">
                            <div class="text-center py-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2">Loading audio player...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script src="/js/audio-library.js"></script>
        <script>
            // Global stop function for compatibility
            function stopAllAudio() {
                if (window.audioLibrary && window.audioLibrary.stopAll) {
                    window.audioLibrary.stopAll();
                }
            }
        </script>
