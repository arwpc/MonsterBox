<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Configuration - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .config-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .config-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
        }

        .config-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .config-icon {
            font-size: 2em;
            margin-right: 15px;
            color: #00ff00;
        }

        .config-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .config-card {
            background: #000800;
            border: 2px solid #00ff00;
            border-radius: 12px;
            padding: 24px;
            position: relative;
            transition: all 0.3s ease;
        }

        .config-card:hover {
            border-color: #66ff66;
            box-shadow: 0 4px 12px rgba(0, 255, 0, 0.2);
        }

        .card-header {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }

        .card-icon {
            font-size: 1.5em;
            margin-right: 12px;
            color: #00ff00;
        }

        .card-title {
            color: #00ff00;
            font-size: 1.2em;
            font-weight: bold;
            margin: 0;
        }

        .setting-group {
            margin-bottom: 15px;
        }

        .setting-group label {
            display: block;
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .setting-group input,
        .setting-group select {
            width: 100%;
            padding: 8px;
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
        }

        .setting-group input:focus,
        .setting-group select:focus {
            outline: none;
            border-color: #ffff00;
            box-shadow: 0 0 5px rgba(255, 255, 0, 0.3);
        }

        .info-display {
            display: flex;
            justify-content: space-between;
            margin: 8px 0;
            padding: 8px 0;
            border-bottom: 1px solid #333333;
        }

        .info-label {
            color: #cccccc;
            font-size: 0.9em;
        }

        .info-value {
            color: #00ff00;
            font-family: monospace;
            font-weight: bold;
        }

        .status-indicator {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 8px;
        }

        .status-online { background-color: #00ff00; }
        .status-offline { background-color: #ff0000; }
        .status-warning { background-color: #ffff00; }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: #333333;
            border-radius: 4px;
            overflow: hidden;
            margin: 8px 0;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #00ff00, #66ff66);
            transition: width 0.3s ease;
        }

        .control-group {
            display: flex;
            gap: 10px;
            margin: 15px 0;
        }

        .control-input {
            flex: 1;
            padding: 8px;
            background: #001100;
            border: 1px solid #00ff00;
            border-radius: 5px;
            color: #ffffff;
        }

        .log-display {
            background: #000800;
            border: 1px solid #333333;
            border-radius: 5px;
            padding: 15px;
            height: 200px;
            overflow-y: auto;
            font-family: monospace;
            font-size: 0.85em;
            color: #cccccc;
            white-space: pre-wrap;
        }

        .alert-box {
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            display: flex;
            align-items: center;
        }

        .alert-info {
            background: #000033;
            border: 1px solid #0066ff;
            color: #6666ff;
        }

        .alert-warning {
            background: #333300;
            border: 1px solid #ffff00;
            color: #ffff66;
        }

        .alert-error {
            background: #330000;
            border: 1px solid #ff0000;
            color: #ff6666;
        }

        .alert-success {
            background: #003300;
            border: 1px solid #00ff00;
            color: #66ff66;
        }

        .tab-navigation {
            display: flex;
            background: #000800;
            border: 1px solid #00ff00;
            border-radius: 8px;
            margin: 20px 0;
            overflow: hidden;
        }

        .tab-button {
            flex: 1;
            padding: 12px 20px;
            background: transparent;
            border: none;
            color: #cccccc;
            cursor: pointer;
            transition: all 0.3s ease;
            border-right: 1px solid #333333;
        }

        .tab-button:last-child {
            border-right: none;
        }

        .tab-button:hover {
            background: #002200;
            color: #00ff00;
        }

        .tab-button.active {
            background: #00ff00;
            color: #000000;
            font-weight: bold;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }
    </style>
</head>
<body>
    <header>
        <h1>⚙️ System Configuration</h1>
        <div class="breadcrumb-vertical mb-6">
            <a href="/" class="breadcrumb-item">🏠 Home</a>
            <span class="breadcrumb-item active">⚙️ Configuration</span>
        </div>
    </header>

    <main class="config-container">
        <div class="info-section">
            <h2>🖥️ MonsterBox System Configuration</h2>
            <p>Manage system settings, monitor hardware, and maintain your MonsterBox installation</p>
        </div>

        <!-- Tab Navigation -->
        <div class="tab-navigation">
            <button class="tab-button active" onclick="showTab('ui-settings')">
                <i class="fas fa-palette"></i> UI Settings
            </button>
            <button class="tab-button" onclick="showTab('system-info')">
                <i class="fas fa-info-circle"></i> System Info
            </button>
            <button class="tab-button" onclick="showTab('storage-info')">
                <i class="fas fa-hdd"></i> Storage
            </button>
            <button class="tab-button" onclick="showTab('hardware-monitor')">
                <i class="fas fa-microchip"></i> Hardware
            </button>
            <button class="tab-button" onclick="showTab('system-maintenance')">
                <i class="fas fa-tools"></i> Maintenance
            </button>
            <button class="tab-button" onclick="showTab('log-collection')">
                <i class="fas fa-file-alt"></i> Logs
            </button>
        </div>

        <!-- UI Settings Tab -->
        <div id="ui-settings" class="tab-content active">
            <div class="config-grid">
                <!-- Theme Configuration -->
                <div class="config-card">
                    <div class="card-header">
                        <i class="fas fa-palette card-icon"></i>
                        <h3 class="card-title">Theme Settings</h3>
                    </div>

                    <div class="setting-group">
                        <label for="theme-selector">Choose Theme:</label>
                        <select id="theme-selector" onchange="previewTheme(this.value)">
                            <option value="monsterbox" <%= (!userSettings || userSettings.theme === 'monsterbox') ? 'selected' : '' %>>🖥️ Terminal</option>
                            <option value="monsterbox-halloween" <%= (userSettings && userSettings.theme === 'monsterbox-halloween') ? 'selected' : '' %>>🎃 Halloween</option>
                            <option value="monsterbox-retro" <%= (userSettings && userSettings.theme === 'monsterbox-retro') ? 'selected' : '' %>>👾 Retro</option>
                            <option value="dracula" <%= (userSettings && userSettings.theme === 'dracula') ? 'selected' : '' %>>🧛 Dracula</option>
                            <option value="dark" <%= (userSettings && userSettings.theme === 'dark') ? 'selected' : '' %>>🌙 Dark</option>
                            <option value="light" <%= (userSettings && userSettings.theme === 'light') ? 'selected' : '' %>>☀️ Light</option>
                        </select>
                        <small style="color: #cccccc; font-size: 0.8em;">Changes are previewed in real-time</small>
                    </div>

                    <div class="setting-group">
                        <label for="font-selector">Font Family:</label>
                        <select id="font-selector" onchange="previewFont(this.value)">
                            <option value="terminal" <%= (!userSettings || userSettings.fontFamily === 'terminal') ? 'selected' : '' %>>Terminal</option>
                            <option value="retro" <%= (userSettings && userSettings.fontFamily === 'retro') ? 'selected' : '' %>>Retro</option>
                            <option value="creepster" <%= (userSettings && userSettings.fontFamily === 'creepster') ? 'selected' : '' %>>Creepster</option>
                            <option value="mono" <%= (userSettings && userSettings.fontFamily === 'mono') ? 'selected' : '' %>>Monospace</option>
                        </select>
                    </div>

                    <div class="setting-group">
                        <label>Font Size:</label>
                        <div class="control-group">
                            <label style="display: flex; align-items: center; color: #cccccc; font-weight: normal;">
                                <input type="radio" name="font-size" value="small" <%= (userSettings && userSettings.fontSize === 'small') ? 'checked' : '' %> onchange="previewFontSize(this.value)" style="margin-right: 8px;">
                                Small
                            </label>
                            <label style="display: flex; align-items: center; color: #cccccc; font-weight: normal;">
                                <input type="radio" name="font-size" value="medium" <%= (!userSettings || userSettings.fontSize === 'medium') ? 'checked' : '' %> onchange="previewFontSize(this.value)" style="margin-right: 8px;">
                                Medium
                            </label>
                            <label style="display: flex; align-items: center; color: #cccccc; font-weight: normal;">
                                <input type="radio" name="font-size" value="large" <%= (userSettings && userSettings.fontSize === 'large') ? 'checked' : '' %> onchange="previewFontSize(this.value)" style="margin-right: 8px;">
                                Large
                            </label>
                        </div>
                    </div>

                    <div class="control-group">
                        <button class="button primary-btn" onclick="saveSettings()">
                            <i class="fas fa-save"></i> Save Settings
                        </button>
                        <button class="button secondary-btn" onclick="resetSettings()">
                            <i class="fas fa-undo"></i> Reset
                        </button>
                    </div>
                </div>

                <!-- Live Preview -->
                <div class="config-card">
                    <div class="card-header">
                        <i class="fas fa-eye card-icon"></i>
                        <h3 class="card-title">Live Preview</h3>
                    </div>

                    <div id="preview-area" style="background: #000800; border: 1px solid #333333; border-radius: 8px; padding: 15px; margin: 15px 0;">
                        <h4 style="color: #00ff00; font-size: 1.1em; margin-bottom: 10px;">Sample Content</h4>
                        <p style="color: #cccccc; margin-bottom: 15px;">This is how your MonsterBox interface will look with the selected theme and font settings.</p>
                        <div style="display: flex; gap: 10px;">
                            <button class="button primary-btn small-btn">Primary Button</button>
                            <button class="button secondary-btn small-btn">Secondary Button</button>
                        </div>
                    </div>

                    <div class="alert-box alert-info">
                        <i class="fas fa-info-circle" style="margin-right: 10px;"></i>
                        <span>Theme changes are applied immediately. Save your settings to make them permanent.</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Information Tab -->
        <div id="system-info" class="tab-content">
            <div class="config-grid">
                <% if (typeof systemInfo !== 'undefined') { %>
                    <!-- System Details -->
                    <div class="config-card">
                        <div class="card-header">
                            <i class="fas fa-desktop card-icon"></i>
                            <h3 class="card-title">System Details</h3>
                        </div>

                        <div class="info-display">
                            <span class="info-label">Hostname:</span>
                            <span class="info-value"><%= systemInfo.hostname || 'Unknown' %></span>
                        </div>
                        <div class="info-display">
                            <span class="info-label">Platform:</span>
                            <span class="info-value"><%= systemInfo.platform || 'Unknown' %></span>
                        </div>
                        <div class="info-display">
                            <span class="info-label">Architecture:</span>
                            <span class="info-value"><%= systemInfo.arch || 'Unknown' %></span>
                        </div>
                        <div class="info-display">
                            <span class="info-label">Uptime:</span>
                            <span class="info-value"><%= systemInfo.uptime || 'Unknown' %></span>
                        </div>

                        <button class="button secondary-btn" onclick="refreshSystemInfo()">
                            <i class="fas fa-sync"></i> Refresh Info
                        </button>
                    </div>

                    <!-- CPU & Memory -->
                    <div class="config-card">
                        <div class="card-header">
                            <i class="fas fa-microchip card-icon"></i>
                            <h3 class="card-title">CPU & Memory</h3>
                        </div>

                        <div class="info-display">
                            <span class="info-label">CPU Model:</span>
                            <span class="info-value" style="font-size: 0.8em;"><%= systemInfo.cpuModel || 'Unknown' %></span>
                        </div>
                        <div class="info-display">
                            <span class="info-label">CPU Cores:</span>
                            <span class="info-value"><%= systemInfo.cpuCores || 'Unknown' %></span>
                        </div>
                        <div class="info-display">
                            <span class="info-label">Total Memory:</span>
                            <span class="info-value"><%= systemInfo.totalMemory || 'Unknown' %></span>
                        </div>
                        <div class="info-display">
                            <span class="info-label">Free Memory:</span>
                            <span class="info-value" style="color: #66ff66;"><%= systemInfo.freeMemory || 'Unknown' %></span>
                        </div>
                        <div class="info-display">
                            <span class="info-label">Load Average:</span>
                            <span class="info-value" style="color: #ffff66;"><%= systemInfo.loadAverage || 'Unknown' %></span>
                        </div>
                    </div>

                    <!-- Network & Power -->
                    <div class="config-card">
                        <div class="card-header">
                            <i class="fas fa-wifi card-icon"></i>
                            <h3 class="card-title">Network & Power</h3>
                        </div>

                        <div class="info-display">
                            <span class="info-label">IP Address:</span>
                            <span class="info-value"><%= typeof ipAddress !== 'undefined' ? ipAddress : 'Unknown' %></span>
                        </div>
                        <div class="info-display">
                            <span class="info-label">WiFi Signal:</span>
                            <span class="info-value" style="color: #66ccff;"><%= typeof wifiSignal !== 'undefined' ? wifiSignal : 'Unknown' %></span>
                        </div>
                        <div class="info-display">
                            <span class="info-label">Power Status:</span>
                            <span class="info-value" style="color: #66ff66;"><%= typeof power !== 'undefined' ? power : 'Unknown' %></span>
                        </div>

                        <button class="button secondary-btn" onclick="refreshNetworkInfo()">
                            <i class="fas fa-network-wired"></i> Check Network
                        </button>
                    </div>
                <% } else { %>
                    <div class="config-card">
                        <div class="alert-box alert-warning">
                            <i class="fas fa-exclamation-triangle" style="margin-right: 10px;"></i>
                            <span>System information is not available at this time.</span>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Storage Information Tab -->
        <div id="storage-info" class="tab-content">
            <% if (typeof driveInfo !== 'undefined' && driveInfo.length > 0) { %>
                <div class="config-grid">
                    <% driveInfo.forEach(function(drive) { %>
                        <div class="config-card">
                            <div class="card-header">
                                <i class="fas fa-hdd card-icon"></i>
                                <h3 class="card-title"><%= drive.filesystem || 'Storage Device' %></h3>
                            </div>

                            <div class="info-display">
                                <span class="info-label">Total Size:</span>
                                <span class="info-value"><%= drive.size || 'Unknown' %></span>
                            </div>
                            <div class="info-display">
                                <span class="info-label">Used Space:</span>
                                <span class="info-value" style="color: #ffff66;"><%= drive.used || 'Unknown' %></span>
                            </div>
                            <div class="info-display">
                                <span class="info-label">Available:</span>
                                <span class="info-value" style="color: #66ff66;"><%= drive.available || 'Unknown' %></span>
                            </div>
                            <div class="info-display">
                                <span class="info-label">Mount Point:</span>
                                <span class="info-value" style="color: #66ccff;"><%= drive.mount || 'Unknown' %></span>
                            </div>

                            <!-- Usage Progress Bar -->
                            <div style="margin: 15px 0;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                                    <span class="info-label">Usage:</span>
                                    <span class="info-value"><%= drive.capacity || '0%' %></span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: <%= drive.capacity || '0%' %>"></div>
                                </div>
                            </div>

                            <button class="button secondary-btn" onclick="refreshStorageInfo('<%= drive.filesystem %>')">
                                <i class="fas fa-sync"></i> Refresh
                            </button>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="config-section">
                    <div class="alert-box alert-info">
                        <i class="fas fa-info-circle" style="margin-right: 10px;"></i>
                        <span>Storage information is not available at this time.</span>
                    </div>
                    <button class="button primary-btn" onclick="loadStorageInfo()">
                        <i class="fas fa-sync"></i> Load Storage Information
                    </button>
                </div>
            <% } %>
        </div>

        <!-- Hardware Monitor Tab -->
        <div id="hardware-monitor" class="tab-content">
            <div class="config-grid">
                <!-- Service Status -->
                <div class="config-card">
                    <div class="card-header">
                        <i class="fas fa-server card-icon"></i>
                        <h3 class="card-title">Service Status</h3>
                    </div>

                    <div class="info-display">
                        <span class="info-label">Main Server:</span>
                        <span class="info-value">
                            <span class="status-indicator status-online"></span>
                            <span id="main-status">Connected</span>
                        </span>
                    </div>
                    <div class="info-display">
                        <span class="info-label">Motor Service:</span>
                        <span class="info-value">
                            <span class="status-indicator status-warning"></span>
                            <span id="motor-status">Checking...</span>
                        </span>
                    </div>
                    <div class="info-display">
                        <span class="info-label">Light Service:</span>
                        <span class="info-value">
                            <span class="status-indicator status-warning"></span>
                            <span id="light-status">Checking...</span>
                        </span>
                    </div>
                    <div class="info-display">
                        <span class="info-label">Sensor Service:</span>
                        <span class="info-value">
                            <span class="status-indicator status-warning"></span>
                            <span id="sensor-status">Checking...</span>
                        </span>
                    </div>
                    <div class="info-display">
                        <span class="info-label">Registry Service:</span>
                        <span class="info-value">
                            <span class="status-indicator status-warning"></span>
                            <span id="registry-status">Checking...</span>
                        </span>
                    </div>

                    <button class="button primary-btn" onclick="refreshServiceStatus()">
                        <i class="fas fa-sync"></i> Refresh Status
                    </button>
                </div>



                <!-- Real-time Monitoring -->
                <div class="config-card" style="grid-column: 1 / -1;">
                    <div class="card-header">
                        <i class="fas fa-chart-line card-icon"></i>
                        <h3 class="card-title">Real-time Monitoring</h3>
                    </div>

                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin: 15px 0;">
                        <div style="background: #000800; border: 1px solid #333333; border-radius: 8px; padding: 15px; text-align: center;">
                            <div class="info-label">CPU Usage</div>
                            <div style="color: #00ff00; font-size: 1.5em; font-weight: bold; margin: 5px 0;" id="cpu-usage">--</div>
                            <div style="color: #888888; font-size: 0.8em;">Percentage</div>
                        </div>
                        <div style="background: #000800; border: 1px solid #333333; border-radius: 8px; padding: 15px; text-align: center;">
                            <div class="info-label">Memory Usage</div>
                            <div style="color: #ffff66; font-size: 1.5em; font-weight: bold; margin: 5px 0;" id="memory-usage">--</div>
                            <div style="color: #888888; font-size: 0.8em;">MB Used</div>
                        </div>
                        <div style="background: #000800; border: 1px solid #333333; border-radius: 8px; padding: 15px; text-align: center;">
                            <div class="info-label">Temperature</div>
                            <div style="color: #ff6666; font-size: 1.5em; font-weight: bold; margin: 5px 0;" id="cpu-temp">--</div>
                            <div style="color: #888888; font-size: 0.8em;">°C</div>
                        </div>
                    </div>

                    <!-- Activity Log -->
                    <div class="setting-group">
                        <label>Activity Log:</label>
                        <div class="log-display" id="hardware-log"></div>
                    </div>

                    <div class="control-group">
                        <button class="button primary-btn" onclick="startMonitoring()">
                            <i class="fas fa-play"></i> Start Monitoring
                        </button>
                        <button class="button secondary-btn" onclick="stopMonitoring()">
                            <i class="fas fa-stop"></i> Stop Monitoring
                        </button>
                        <button class="button secondary-btn" onclick="clearLog()">
                            <i class="fas fa-trash"></i> Clear Log
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Maintenance Tab -->
        <div id="system-maintenance" class="tab-content">
            <div class="config-grid">
                <!-- Cleanup Operations -->
                <div class="config-card">
                    <div class="card-header">
                        <i class="fas fa-broom card-icon"></i>
                        <h3 class="card-title">Cleanup Operations</h3>
                    </div>

                    <div class="alert-box alert-info">
                        <i class="fas fa-info-circle" style="margin-right: 10px;"></i>
                        <span>Cleanup operations help maintain system performance by removing unused files.</span>
                    </div>

                    <div class="setting-group">
                        <label>Sound Files Cleanup:</label>
                        <div class="control-group" style="flex-direction: column; gap: 8px;">
                            <button class="button primary-btn" onclick="analyzeSoundFiles()">
                                <i class="fas fa-search"></i> Analyze Unused Sound Files
                            </button>
                            <button class="button warning-btn" onclick="cleanupSoundFiles()" disabled id="cleanup-btn">
                                <i class="fas fa-trash"></i> Delete Unused Sound Files
                            </button>
                        </div>
                        <div id="cleanup-results" style="display: none; margin-top: 15px;">
                            <div class="alert-box alert-warning">
                                <span id="cleanup-message">Analysis results will appear here</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- System Operations -->
                <div class="config-card">
                    <div class="card-header">
                        <i class="fas fa-cog card-icon"></i>
                        <h3 class="card-title">System Operations</h3>
                    </div>

                    <div class="alert-box alert-warning">
                        <i class="fas fa-exclamation-triangle" style="margin-right: 10px;"></i>
                        <span>System operations will affect all running services.</span>
                    </div>

                    <div class="setting-group">
                        <label>System Reboot:</label>
                        <button class="button danger-btn" onclick="confirmReboot()" style="width: 100%;">
                            <i class="fas fa-power-off"></i> Reboot System
                        </button>
                    </div>

                    <div class="setting-group">
                        <label>Service Management:</label>
                        <div class="control-group" style="flex-direction: column; gap: 8px;">
                            <button class="button secondary-btn" onclick="restartServices()">
                                <i class="fas fa-sync"></i> Restart All Services
                            </button>
                            <button class="button secondary-btn" onclick="checkSystemHealth()">
                                <i class="fas fa-heartbeat"></i> System Health Check
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Log Collection Tab -->
        <div id="log-collection" class="tab-content">
            <div class="config-grid">
                <!-- Log Stream Controls -->
                <div class="config-card">
                    <div class="card-header">
                        <i class="fas fa-stream card-icon"></i>
                        <h3 class="card-title">Log Stream Controls</h3>
                    </div>

                    <div class="setting-group">
                        <label for="log-level">Log Level Filter:</label>
                        <select id="log-level">
                            <option value="all">All Levels</option>
                            <option value="error">Error Only</option>
                            <option value="warning">Warning & Above</option>
                            <option value="info">Info & Above</option>
                            <option value="debug">Debug & Above</option>
                        </select>
                    </div>

                    <div class="setting-group">
                        <label for="service-filter">Service Filter:</label>
                        <select id="service-filter">
                            <option value="all">All Services</option>
                            <option value="main">Main Server</option>
                            <option value="motor">Motor Service</option>
                            <option value="light">Light Service</option>
                            <option value="sensor">Sensor Service</option>
                            <option value="ai">AI Service</option>
                        </select>
                    </div>

                    <div class="control-group">
                        <button class="button primary-btn" onclick="startLogStream()">
                            <i class="fas fa-play"></i> Start Stream
                        </button>
                        <button class="button secondary-btn" onclick="pauseLogStream()">
                            <i class="fas fa-pause"></i> Pause
                        </button>
                    </div>

                    <div class="control-group">
                        <button class="button secondary-btn" onclick="clearLogStream()">
                            <i class="fas fa-trash"></i> Clear
                        </button>
                        <button class="button secondary-btn" onclick="exportLogs()">
                            <i class="fas fa-download"></i> Export
                        </button>
                    </div>
                </div>

                <!-- Device Management -->
                <div class="config-card">
                    <div class="card-header">
                        <i class="fas fa-network-wired card-icon"></i>
                        <h3 class="card-title">Device Management</h3>
                    </div>

                    <div class="setting-group">
                        <label>Add Device:</label>
                        <div class="control-group">
                            <input type="text" id="device-ip" placeholder="IP Address" class="control-input">
                            <button class="button primary-btn" onclick="addDevice()">Add</button>
                        </div>
                    </div>

                    <div class="setting-group">
                        <label>Network Scan:</label>
                        <button class="button primary-btn" onclick="scanDevices()" style="width: 100%;">
                            <i class="fas fa-search"></i> Scan for Devices
                        </button>
                    </div>

                    <div class="setting-group">
                        <label>Connected Devices:</label>
                        <div id="device-list" style="background: #000800; border: 1px solid #333333; border-radius: 5px; padding: 10px; min-height: 60px;">
                            <div class="alert-box alert-info" style="margin: 0;">
                                <span>No devices configured</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Live Log Display -->
                <div class="config-card" style="grid-column: 1 / -1;">
                    <div class="card-header">
                        <i class="fas fa-file-alt card-icon"></i>
                        <h3 class="card-title">Live Log Stream</h3>
                    </div>

                    <div class="setting-group">
                        <div class="log-display" id="log-stream" style="height: 300px;">Log entries will appear here when streaming is started...</div>
                    </div>

                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 15px;">
                        <div style="color: #cccccc; font-size: 0.9em;">
                            <span id="log-count">0</span> entries |
                            <span id="log-status">Stopped</span>
                        </div>
                        <label style="display: flex; align-items: center; color: #cccccc; cursor: pointer;">
                            <input type="checkbox" id="auto-scroll" checked style="margin-right: 8px;">
                            Auto-scroll
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="button-group" style="margin-top: 30px; text-align: center;">
            <a href="/" class="button secondary-btn">
                <i class="fas fa-home"></i> Back to Home
            </a>
            <a href="/ai-management" class="button">
                <i class="fas fa-brain"></i> AI Management
            </a>
            <a href="/characters" class="button">
                <i class="fas fa-users"></i> Characters
            </a>
        </div>

        <!-- Messages -->
        <div id="messageContainer"></div>
    </main>

    <script>
        // Current settings state
        let currentSettings = {
            theme: '<%= userSettings ? userSettings.theme : "monsterbox" %>',
            fontSize: '<%= userSettings ? userSettings.fontSize : "medium" %>',
            fontFamily: '<%= userSettings ? userSettings.fontFamily : "terminal" %>',
        };

        // Tab management
        function showTab(tabId) {
            // Hide all tab contents
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });

            // Remove active class from all tab buttons
            document.querySelectorAll('.tab-button').forEach(tab => {
                tab.classList.remove('active');
            });

            // Show selected tab content
            document.getElementById(tabId).classList.add('active');

            // Add active class to clicked tab button
            event.target.classList.add('active');
        }

        // Theme management
        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('monsterbox-theme', theme);
        }

        function previewTheme(theme) {
            setTheme(theme);
            currentSettings.theme = theme;
            showMessage('Theme changed to ' + theme, 'success');
        }

        function previewFont(fontFamily) {
            const fontClasses = {
                'terminal': 'font-terminal',
                'retro': 'font-retro',
                'creepster': 'font-creepster',
                'mono': 'font-mono'
            };

            // Remove all font classes from body
            document.body.classList.remove('font-terminal', 'font-retro', 'font-creepster', 'font-mono');

            // Add selected font class
            if (fontClasses[fontFamily]) {
                document.body.classList.add(fontClasses[fontFamily]);
            }

            currentSettings.fontFamily = fontFamily;
            showMessage('Font changed to ' + fontFamily, 'success');
        }

        function previewFontSize(fontSize) {
            const sizeClasses = {
                'small': 'text-sm',
                'medium': 'text-base',
                'large': 'text-lg'
            };

            // Remove all size classes from body
            document.body.classList.remove('text-sm', 'text-base', 'text-lg');

            // Add selected size class
            if (sizeClasses[fontSize]) {
                document.body.classList.add(sizeClasses[fontSize]);
            }

            currentSettings.fontSize = fontSize;
            showMessage('Font size changed to ' + fontSize, 'success');
        }

        // Settings management
        async function saveSettings() {
            try {
                const response = await fetch('/configuration/api/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ settings: currentSettings }),
                });

                const result = await response.json();

                if (result.success) {
                    showMessage('Settings saved successfully!', 'success');
                    localStorage.setItem('monsterbox-theme', currentSettings.theme);
                } else {
                    showMessage('Failed to save settings: ' + result.error, 'error');
                }
            } catch (error) {
                console.error('Error saving settings:', error);
                showMessage('Failed to save settings. Please try again.', 'error');
            }
        }

        async function resetSettings() {
            if (confirm('Are you sure you want to reset all settings to defaults?')) {
                try {
                    // Reset to defaults
                    currentSettings = {
                        theme: 'monsterbox',
                        fontSize: 'medium',
                        fontFamily: 'terminal'
                    };

                    // Apply defaults
                    setTheme(currentSettings.theme);
                    previewFont(currentSettings.fontFamily);
                    previewFontSize(currentSettings.fontSize);

                    // Reset form values
                    document.getElementById('theme-selector').value = currentSettings.theme;
                    document.getElementById('font-selector').value = currentSettings.fontFamily;
                    document.querySelector(`input[name="font-size"][value="${currentSettings.fontSize}"]`).checked = true;

                    showMessage('Settings reset to defaults!', 'success');
                } catch (error) {
                    console.error('Error resetting settings:', error);
                    showMessage('Failed to reset settings. Please try again.', 'error');
                }
            }
        }

        // Message system
        function showMessage(message, type = 'info') {
            const messageContainer = document.getElementById('messageContainer');
            const messageDiv = document.createElement('div');
            messageDiv.className = `alert-box alert-${type}`;
            messageDiv.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 1000; max-width: 400px;';
            messageDiv.innerHTML = `
                <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle'}" style="margin-right: 10px;"></i>
                <span>${message}</span>
            `;

            document.body.appendChild(messageDiv);

            // Remove message after 3 seconds
            setTimeout(() => {
                messageDiv.remove();
            }, 3000);
        }

        // Hardware Monitor Functions
        let monitoringInterval = null;

        function refreshServiceStatus() {
            fetch('/api/hardware/status')
                .then(response => response.json())
                .then(data => {
                    updateServiceStatus(data);
                    showMessage('Service status refreshed', 'success');
                })
                .catch(error => {
                    console.error('Error checking service status:', error);
                    showMessage('Error checking service status: ' + error.message, 'error');
                });
        }

        function updateServiceStatus(statusData) {
            const services = ['main', 'motor', 'light', 'sensor', 'registry'];
            services.forEach(service => {
                const statusElement = document.getElementById(`${service}-status`);
                const indicatorElement = statusElement?.previousElementSibling;

                if (statusElement && statusData[service]) {
                    const isConnected = statusData[service].connected;
                    statusElement.textContent = isConnected ? 'Connected' : 'Disconnected';

                    if (indicatorElement && indicatorElement.classList.contains('status-indicator')) {
                        indicatorElement.className = `status-indicator status-${isConnected ? 'online' : 'offline'}`;
                    }
                }
            });
        }



        function startMonitoring() {
            if (monitoringInterval) return;

            monitoringInterval = setInterval(() => {
                fetch('/api/system/stats')
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById('cpu-usage').textContent = data.cpu + '%';
                            document.getElementById('memory-usage').textContent = data.memory + ' MB';
                            document.getElementById('cpu-temp').textContent = data.temperature === 'N/A' ? 'N/A' : data.temperature + '°C';
                        } else {
                            document.getElementById('cpu-usage').textContent = '--';
                            document.getElementById('memory-usage').textContent = '--';
                            document.getElementById('cpu-temp').textContent = '--';
                        }
                    })
                    .catch(error => {
                        logHardwareActivity(`Monitoring error: ${error.message}`);
                        document.getElementById('cpu-usage').textContent = '--';
                        document.getElementById('memory-usage').textContent = '--';
                        document.getElementById('cpu-temp').textContent = '--';
                    });
            }, 2000);

            logHardwareActivity('Hardware monitoring started');
            showMessage('Hardware monitoring started', 'success');
        }

        function stopMonitoring() {
            if (monitoringInterval) {
                clearInterval(monitoringInterval);
                monitoringInterval = null;
                logHardwareActivity('Hardware monitoring stopped');
                showMessage('Hardware monitoring stopped', 'info');
            }
        }

        function logHardwareActivity(message) {
            const logArea = document.getElementById('hardware-log');
            const timestamp = new Date().toLocaleTimeString();
            logArea.textContent += `[${timestamp}] ${message}\n`;
            logArea.scrollTop = logArea.scrollHeight;
        }

        function clearLog() {
            document.getElementById('hardware-log').textContent = '';
            showMessage('Log cleared', 'info');
        }

        // System Maintenance Functions
        function analyzeSoundFiles() {
            showMessage('Analyzing sound files...', 'info');

            fetch('/configuration/api/cleanup/analyze', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                const resultsDiv = document.getElementById('cleanup-results');
                const messageSpan = document.getElementById('cleanup-message');
                const cleanupBtn = document.getElementById('cleanup-btn');

                resultsDiv.style.display = 'block';

                if (data.success && data.unusedFilesFound > 0) {
                    messageSpan.textContent = `Found ${data.unusedFilesFound} unused sound files that can be deleted.`;
                    cleanupBtn.disabled = false;
                    cleanupBtn.innerHTML = `<i class="fas fa-trash"></i> Delete ${data.unusedFilesFound} Unused Files`;
                    showMessage(`Found ${data.unusedFilesFound} unused sound files`, 'warning');
                } else if (data.success) {
                    messageSpan.textContent = 'No unused sound files found. Your system is clean!';
                    cleanupBtn.disabled = true;
                    showMessage('No unused sound files found', 'success');
                } else {
                    messageSpan.textContent = 'Error analyzing sound files: ' + (data.error || 'Unknown error');
                    cleanupBtn.disabled = true;
                    showMessage('Error analyzing sound files', 'error');
                }
            })
            .catch(error => {
                showMessage('Failed to analyze sound files: ' + error.message, 'error');
            });
        }

        function cleanupSoundFiles() {
            if (confirm('Are you sure you want to delete unused sound files? This action cannot be undone.')) {
                showMessage('Cleaning up sound files...', 'info');

                fetch('/configuration/api/cleanup/execute', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(response => response.json())
                .then(data => {
                    const messageSpan = document.getElementById('cleanup-message');
                    const cleanupBtn = document.getElementById('cleanup-btn');

                    if (data.success && data.deletedCount > 0) {
                        messageSpan.textContent = `Successfully deleted ${data.deletedCount} unused sound files.`;
                        showMessage(`Deleted ${data.deletedCount} unused sound files`, 'success');
                    } else if (data.success) {
                        messageSpan.textContent = 'No files were deleted.';
                        showMessage('No files were deleted', 'info');
                    } else {
                        messageSpan.textContent = 'Error during cleanup: ' + (data.error || 'Unknown error');
                        showMessage('Error during cleanup', 'error');
                    }

                    cleanupBtn.disabled = true;
                    cleanupBtn.innerHTML = '<i class="fas fa-trash"></i> Delete Unused Sound Files';
                })
                .catch(error => {
                    showMessage('Failed to cleanup sound files: ' + error.message, 'error');
                });
            }
        }

        function confirmReboot() {
            if (confirm('Are you sure you want to reboot the system? This will disconnect all users and stop all running processes.')) {
                showMessage('System reboot initiated...', 'warning');

                fetch('/api/system/reboot', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(response => response.json())
                .then(data => {
                    showMessage('System reboot initiated. The system will be unavailable for a few minutes.', 'warning');
                })
                .catch(error => {
                    showMessage('Failed to initiate reboot: ' + error.message, 'error');
                });
            }
        }

        function restartServices() {
            showMessage('Restarting all services...', 'info');

            fetch('/api/system/restart-services', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                showMessage('All services restarted successfully', 'success');
                refreshServiceStatus();
            })
            .catch(error => {
                showMessage('Failed to restart services: ' + error.message, 'error');
            });
        }

        function checkSystemHealth() {
            showMessage('Performing system health check...', 'info');

            fetch('/api/system/health-check')
                .then(response => response.json())
                .then(data => {
                    const issues = data.issues || [];
                    if (issues.length === 0) {
                        showMessage('System health check passed - no issues found', 'success');
                    } else {
                        showMessage(`Health check found ${issues.length} issues: ${issues.join(', ')}`, 'warning');
                    }
                })
                .catch(error => {
                    showMessage('Failed to perform health check: ' + error.message, 'error');
                });
        }

        // Log Collection Functions
        let logCount = 0;

        function startLogStream() {
            const level = document.getElementById('log-level').value;
            const service = document.getElementById('service-filter').value;

            document.getElementById('log-status').textContent = 'Streaming';
            showMessage(`Started log stream (${level} level, ${service} service)`, 'success');

            // Simulate log streaming with sample data
            const sampleLogs = [
                '[INFO] System initialized successfully',
                '[DEBUG] Loading configuration files',
                '[WARN] High memory usage detected',
                '[ERROR] Connection timeout to external service',
                '[INFO] User authentication successful'
            ];

            let logIndex = 0;
            const streamInterval = setInterval(() => {
                if (logIndex < sampleLogs.length) {
                    const logArea = document.getElementById('log-stream');
                    const timestamp = new Date().toLocaleTimeString();
                    const logEntry = `[${timestamp}] ${sampleLogs[logIndex]}`;

                    logArea.textContent += logEntry + '\n';
                    logCount++;
                    document.getElementById('log-count').textContent = logCount;

                    if (document.getElementById('auto-scroll').checked) {
                        logArea.scrollTop = logArea.scrollHeight;
                    }

                    logIndex++;
                } else {
                    clearInterval(streamInterval);
                    document.getElementById('log-status').textContent = 'Completed';
                }
            }, 1000);
        }

        function pauseLogStream() {
            document.getElementById('log-status').textContent = 'Paused';
            showMessage('Log stream paused', 'info');
        }

        function clearLogStream() {
            document.getElementById('log-stream').textContent = '';
            logCount = 0;
            document.getElementById('log-count').textContent = '0';
            showMessage('Log stream cleared', 'info');
        }

        function exportLogs() {
            const logContent = document.getElementById('log-stream').textContent;
            const blob = new Blob([logContent], { type: 'text/plain' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `monsterbox-logs-${new Date().toISOString().slice(0, 19)}.txt`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);
            showMessage('Logs exported successfully', 'success');
        }

        function addDevice() {
            const ip = document.getElementById('device-ip').value;
            if (!ip) {
                showMessage('Please enter an IP address', 'error');
                return;
            }

            showMessage(`Adding device ${ip}...`, 'info');
            document.getElementById('device-ip').value = '';

            // Simulate adding device
            setTimeout(() => {
                showMessage(`Device ${ip} added successfully`, 'success');
                loadDeviceList();
            }, 1000);
        }

        function scanDevices() {
            showMessage('Scanning network for devices...', 'info');

            // Simulate network scan
            setTimeout(() => {
                showMessage('Found 2 new devices', 'success');
                loadDeviceList();
            }, 2000);
        }

        function loadDeviceList() {
            const deviceList = document.getElementById('device-list');
            // Simulate device list
            deviceList.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px; background: #000800; border: 1px solid #333333; border-radius: 5px; margin: 5px 0;">
                    <span style="font-family: monospace; color: #00ff00;">192.168.1.100</span>
                    <span class="status-indicator status-online" style="margin-left: 10px;"></span>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 8px; background: #000800; border: 1px solid #333333; border-radius: 5px; margin: 5px 0;">
                    <span style="font-family: monospace; color: #00ff00;">192.168.1.101</span>
                    <span class="status-indicator status-offline" style="margin-left: 10px;"></span>
                </div>
            `;
        }

        // Additional utility functions
        function refreshSystemInfo() {
            showMessage('Refreshing system information...', 'info');
            setTimeout(() => {
                showMessage('System information refreshed', 'success');
                location.reload();
            }, 1000);
        }

        function refreshNetworkInfo() {
            showMessage('Checking network status...', 'info');
            setTimeout(() => {
                showMessage('Network status updated', 'success');
            }, 1000);
        }

        function refreshStorageInfo(filesystem) {
            showMessage(`Refreshing storage info for ${filesystem}...`, 'info');
            setTimeout(() => {
                showMessage('Storage information refreshed', 'success');
            }, 1000);
        }

        function loadStorageInfo() {
            showMessage('Loading storage information...', 'info');
            setTimeout(() => {
                showMessage('Storage information loaded', 'success');
                location.reload();
            }, 1000);
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Load saved theme
            const savedTheme = localStorage.getItem('monsterbox-theme') || currentSettings.theme;
            setTheme(savedTheme);

            // Apply current font settings
            previewFont(currentSettings.fontFamily);
            previewFontSize(currentSettings.fontSize);

            // Initialize components
            refreshServiceStatus();
            loadDeviceList();

            showMessage('Configuration page loaded successfully', 'success');
        });
    </script>
</body>
</html>
