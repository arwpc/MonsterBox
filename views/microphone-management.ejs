<script src="/js/EnhancedMicrophoneComponent.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script>
    // Microphone Management System
    class MicrophoneManagementSystem {
        constructor() {
            this.selectedMicrophones = new Set();
            this.microphoneStatuses = new Map();
            this.websockets = new Map();
            this.testingActive = false;
            this.monitoringActive = false;

            this.init();
        }

        async init() {
            this.setupEventHandlers();
            await this.setupWebSocketConnections();
            await this.loadInitialData();
            this.startStatusMonitoring();
            this.startPeriodicHealthCheck();
        }

        setupEventHandlers() {
            // Tab switching
            document.querySelectorAll('.tab-button').forEach(button => {
                button.addEventListener('click', (e) => {
                    this.switchTab(e.target.dataset.tab);
                });
            });

            // Service restart buttons
            document.getElementById('restartMicService').addEventListener('click', () => {
                this.restartService('microphone', 8776);
            });

            document.getElementById('restartAudioService').addEventListener('click', () => {
                this.restartService('audioStream', 8777);
            });

            // Quick actions
            document.getElementById('createNewMicrophone').addEventListener('click', () => {
                this.showCreateForm();
            });

            document.getElementById('detectDevices').addEventListener('click', () => {
                this.detectAudioDevices();
            });

            document.getElementById('testAllMicrophones').addEventListener('click', () => {
                this.testAllMicrophones();
            });

            document.getElementById('exportConfiguration').addEventListener('click', () => {
                this.exportConfiguration();
            });

            // Search and filter
            document.getElementById('searchMicrophones').addEventListener('input', (e) => {
                this.filterMicrophones(e.target.value);
            });

            document.getElementById('filterStatus').addEventListener('change', (e) => {
                this.filterByStatus(e.target.value);
            });

            document.getElementById('refreshMicrophones').addEventListener('click', () => {
                this.refreshMicrophonesList();
            });

            // Create form handlers
            document.getElementById('createMicrophoneForm').addEventListener('submit', (e) => {
                e.preventDefault();
                this.createMicrophone();
            });

            document.getElementById('cancelCreate').addEventListener('click', () => {
                this.hideCreateForm();
            });

            document.getElementById('testNewMicrophone').addEventListener('click', () => {
                this.testNewMicrophoneConfiguration();
            });

            // Sensitivity slider
            document.getElementById('newMicSensitivity').addEventListener('input', (e) => {
                document.getElementById('sensitivityValue').textContent = e.target.value;
            });

            // Bulk operations
            document.getElementById('selectAll').addEventListener('click', () => {
                this.selectAllMicrophones();
            });

            document.getElementById('selectNone').addEventListener('click', () => {
                this.selectNoMicrophones();
            });

            document.getElementById('bulkDelete').addEventListener('click', () => {
                this.bulkDeleteMicrophones();
            });

            document.getElementById('bulkTest').addEventListener('click', () => {
                this.bulkTestMicrophones();
            });

            document.getElementById('bulkExport').addEventListener('click', () => {
                this.bulkExportMicrophones();
            });

            // Testing controls
            document.getElementById('testMicrophoneSelect').addEventListener('change', (e) => {
                const microphoneId = e.target.value;
                const testButtons = ['startComprehensiveTest', 'quickTest', 'ambientTest'];
                testButtons.forEach(buttonId => {
                    document.getElementById(buttonId).disabled = !microphoneId;
                });
            });

            document.getElementById('startComprehensiveTest').addEventListener('click', () => {
                this.startComprehensiveTest();
            });

            document.getElementById('stopTest').addEventListener('click', () => {
                this.stopTest();
            });

            document.getElementById('quickTest').addEventListener('click', () => {
                this.quickTest();
            });

            document.getElementById('ambientTest').addEventListener('click', () => {
                this.ambientTest();
            });

            // Microphone card actions
            this.setupMicrophoneCardHandlers();
        }

        setupMicrophoneCardHandlers() {
            document.addEventListener('click', (e) => {
                if (e.target.classList.contains('test-btn')) {
                    const microphoneId = e.target.dataset.id;
                    this.testMicrophone(microphoneId);
                } else if (e.target.classList.contains('edit-btn')) {
                    const microphoneId = e.target.dataset.id;
                    this.editMicrophone(microphoneId);
                } else if (e.target.classList.contains('monitor-btn')) {
                    const microphoneId = e.target.dataset.id;
                    this.monitorMicrophone(microphoneId);
                } else if (e.target.classList.contains('delete-btn')) {
                    const microphoneId = e.target.dataset.id;
                    this.deleteMicrophone(microphoneId);
                }
            });

            // Checkbox selection for bulk operations
            document.addEventListener('change', (e) => {
                if (e.target.type === 'checkbox' && e.target.classList.contains('microphone-select')) {
                    const microphoneId = e.target.dataset.id;
                    if (e.target.checked) {
                        this.selectedMicrophones.add(microphoneId);
                    } else {
                        this.selectedMicrophones.delete(microphoneId);
                    }
                    this.updateBulkOperationsUI();
                }
            });
        }

        async setupWebSocketConnections() {
            try {
                // Connect to microphone service via proxy (fixes browser compatibility)
                await this.connectWebSocket('microphone', `ws://${window.location.hostname}:8794`);

                // Connect to audio stream service via proxy (fixes browser compatibility)
                await this.connectWebSocket('audioStream', `ws://${window.location.hostname}:8795`);

                this.updateServiceStatus('micServiceStatus', 'Connected', 'active');
                this.updateServiceStatus('audioStreamServiceStatus', 'Connected', 'active');
            } catch (error) {
                console.error('Failed to setup WebSocket connections:', error);
                this.updateServiceStatus('micServiceStatus', 'Connection Failed', 'error');
                this.updateServiceStatus('audioStreamServiceStatus', 'Connection Failed', 'error');
            }
        }

        async connectWebSocket(serviceId, url) {
            return new Promise((resolve, reject) => {
                const ws = new WebSocket(url);
                const timeout = setTimeout(() => {
                    reject(new Error(`WebSocket connection timeout for ${serviceId}`));
                }, 5000);

                ws.onopen = () => {
                    clearTimeout(timeout);
                    this.websockets.set(serviceId, ws);
                    console.log(`Connected to ${serviceId} WebSocket service`);
                    resolve();
                };

                ws.onerror = (error) => {
                    clearTimeout(timeout);
                    console.error(`WebSocket error for ${serviceId}:`, error);
                    reject(error);
                };

                ws.onclose = () => {
                    console.log(`WebSocket disconnected: ${serviceId}`);
                    this.websockets.delete(serviceId);
                    // Auto-reconnect after delay
                    setTimeout(() => this.connectWebSocket(serviceId, url), 5000);
                };

                ws.onmessage = (event) => {
                    this.handleWebSocketMessage(serviceId, JSON.parse(event.data));
                };
            });
        }

        handleWebSocketMessage(serviceId, message) {
            switch (message.type) {
                case 'microphone_status_update':
                    this.updateMicrophoneStatus(message.microphoneId, message.status);
                    break;
                case 'audio_level_update':
                    this.updateAudioLevel(message.microphoneId, message.level);
                    break;
                case 'microphones_discovered':
                    this.updateAvailableDevices(message.microphones);
                    break;
                case 'test_result':
                    this.handleTestResult(message);
                    break;
                default:
                    console.log(`Unknown message type from ${serviceId}:`, message.type);
            }
        }

        async loadInitialData() {
            try {
                // Load microphones
                await this.refreshMicrophonesList();

                // Detect available audio devices
                await this.detectAudioDevices();

                // Update overview metrics
                this.updateOverviewMetrics();

            } catch (error) {
                console.error('Error loading initial data:', error);
            }
        }

        startStatusMonitoring() {
            // Update system status every 5 seconds
            setInterval(() => {
                this.updateSystemStatus();
            }, 5000);

            // Update audio levels every 100ms
            setInterval(() => {
                this.updateAudioLevels();
            }, 100);
        }

        switchTab(tabName) {
            // Hide all tab contents
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });

            // Remove active class from all tab buttons
            document.querySelectorAll('.tab-button').forEach(button => {
                button.classList.remove('active');
            });

            // Show selected tab content
            document.getElementById(`${tabName}-tab`).classList.add('active');
            document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');

            // Load tab-specific content
            this.loadTabContent(tabName);
        }

        async loadTabContent(tabName) {
            switch (tabName) {
                case 'testing':
                    await this.loadTestingInterface();
                    break;
                case 'monitoring':
                    await this.loadMonitoringInterface();
                    break;
                case 'configuration':
                    await this.loadConfigurationInterface();
                    break;
            }
        }

        async restartService(serviceType, port) {
            try {
                const response = await axios.post('/api/services/restart', {
                    serviceType,
                    port
                });

                if (response.data.success) {
                    this.showNotification(`${serviceType} service restarted successfully`, 'success');
                    // Reconnect WebSocket after delay
                    setTimeout(() => {
                        if (serviceType === 'microphone') {
                            this.connectWebSocket('microphone', 'ws://localhost:8776');
                        } else if (serviceType === 'audioStream') {
                            this.connectWebSocket('audioStream', 'ws://localhost:8777');
                        }
                    }, 2000);
                } else {
                    this.showNotification(`Failed to restart ${serviceType} service`, 'error');
                }
            } catch (error) {
                console.error(`Error restarting ${serviceType} service:`, error);
                this.showNotification(`Error restarting ${serviceType} service`, 'error');
            }
        }

        showCreateForm() {
            document.getElementById('createFormContainer').style.display = 'block';
            document.getElementById('createFormContainer').scrollIntoView({ behavior: 'smooth' });
        }

        hideCreateForm() {
            document.getElementById('createFormContainer').style.display = 'none';
            document.getElementById('createMicrophoneForm').reset();
        }

        async detectAudioDevices() {
            try {
                // Send request to microphone service to discover devices
                const ws = this.websockets.get('microphone');
                if (ws && ws.readyState === WebSocket.OPEN) {
                    ws.send(JSON.stringify({
                        type: 'discover_microphones'
                    }));
                }

                // Also try browser API
                if (navigator.mediaDevices && navigator.mediaDevices.enumerateDevices) {
                    const devices = await navigator.mediaDevices.enumerateDevices();
                    const audioInputs = devices.filter(device => device.kind === 'audioinput');
                    this.updateDeviceSelect(audioInputs);
                }
            } catch (error) {
                console.error('Error detecting audio devices:', error);
                this.showNotification('Error detecting audio devices', 'error');
            }
        }

        updateDeviceSelect(devices) {
            const select = document.getElementById('newMicDevice');
            // Clear existing options except the first one
            while (select.children.length > 1) {
                select.removeChild(select.lastChild);
            }

            devices.forEach(device => {
                const option = document.createElement('option');
                option.value = device.deviceId || device.index;
                option.textContent = device.label || device.name || `Device ${device.index}`;
                select.appendChild(option);
            });

            document.getElementById('availableDevices').textContent = devices.length;
        }

        async createMicrophone() {
            try {
                const formData = new FormData(document.getElementById('createMicrophoneForm'));
                const microphoneData = Object.fromEntries(formData.entries());

                // Convert checkboxes to boolean
                microphoneData.echoCancellation = document.getElementById('newMicEcho').checked;
                microphoneData.noiseSuppression = document.getElementById('newMicNoise').checked;
                microphoneData.autoGainControl = document.getElementById('newMicGain').checked;

                const response = await axios.post('/parts/microphone', microphoneData);

                if (response.data.success || response.status === 200) {
                    this.showNotification('Microphone created successfully', 'success');
                    this.hideCreateForm();
                    await this.refreshMicrophonesList();
                } else {
                    this.showNotification('Failed to create microphone', 'error');
                }
            } catch (error) {
                console.error('Error creating microphone:', error);
                this.showNotification('Error creating microphone: ' + error.message, 'error');
            }
        }

        async testNewMicrophoneConfiguration() {
            try {
                const deviceId = document.getElementById('newMicDevice').value;
                const sampleRate = document.getElementById('newMicSampleRate').value;
                const channels = document.getElementById('newMicChannels').value;

                if (!deviceId) {
                    this.showNotification('Please select a device first', 'warning');
                    return;
                }

                // Test the configuration using browser API
                const constraints = {
                    audio: {
                        deviceId: deviceId,
                        sampleRate: parseInt(sampleRate),
                        channelCount: parseInt(channels),
                        echoCancellation: document.getElementById('newMicEcho').checked,
                        noiseSuppression: document.getElementById('newMicNoise').checked,
                        autoGainControl: document.getElementById('newMicGain').checked
                    }
                };

                const stream = await navigator.mediaDevices.getUserMedia(constraints);

                // Test successful
                this.showNotification('Microphone configuration test successful', 'success');

                // Stop the stream
                stream.getTracks().forEach(track => track.stop());

            } catch (error) {
                console.error('Error testing microphone configuration:', error);
                this.showNotification('Microphone test failed: ' + error.message, 'error');
            }
        }

