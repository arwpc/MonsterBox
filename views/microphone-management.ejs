        async startTestAudioMonitoring() {
            try {
                // Get user media for real-time monitoring
                const stream = await navigator.mediaDevices.getUserMedia({
                    audio: {
                        echoCancellation: false,
                        noiseSuppression: false,
                        autoGainControl: false
                    }
                });

                const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                const analyser = audioContext.createAnalyser();
                const source = audioContext.createMediaStreamSource(stream);

                analyser.fftSize = 2048;
                source.connect(analyser);

                this.testAudioContext = audioContext;
                this.testAnalyser = analyser;
                this.testStream = stream;

                // Start monitoring loop
                this.updateTestVisualization();

            } catch (error) {
                console.error('Error starting test audio monitoring:', error);
                this.showNotification('Could not access microphone for real-time monitoring', 'warning');
            }
        }

        updateTestVisualization() {
            if (!this.testingActive || !this.testAnalyser) return;

            const bufferLength = this.testAnalyser.frequencyBinCount;
            const dataArray = new Uint8Array(bufferLength);
            const timeArray = new Uint8Array(bufferLength);

            this.testAnalyser.getByteFrequencyData(dataArray);
            this.testAnalyser.getByteTimeDomainData(timeArray);

            // Update level meters
            this.updateTestLevelMeters(dataArray);

            // Update frequency chart
            this.updateTestFrequencyChart(dataArray);

            // Continue monitoring
            if (this.testingActive) {
                requestAnimationFrame(() => this.updateTestVisualization());
            }
        }

        updateTestLevelMeters(dataArray) {
            // Calculate RMS level
            let sum = 0;
            for (let i = 0; i < dataArray.length; i++) {
                sum += dataArray[i] * dataArray[i];
            }
            const rms = Math.sqrt(sum / dataArray.length);
            const level = (rms / 255) * 100;

            // Calculate peak
            const peak = Math.max(...dataArray);
            const peakLevel = (peak / 255) * 100;

            // Update meters
            const inputLevel = document.getElementById('testInputLevel');
            const peakLevelEl = document.getElementById('testPeakLevel');
            const inputValue = document.getElementById('testInputValue');
            const peakValue = document.getElementById('testPeakValue');

            if (inputLevel) inputLevel.style.width = level + '%';
            if (peakLevelEl) peakLevelEl.style.width = peakLevel + '%';
            if (inputValue) inputValue.textContent = Math.round(20 * Math.log10(rms / 255)) + ' dB';
            if (peakValue) peakValue.textContent = Math.round(20 * Math.log10(peak / 255)) + ' dB';
        }

        updateTestFrequencyChart(dataArray) {
            if (!this.testFrequencyChart) return;

            const labels = [];
            const data = [];

            for (let i = 0; i < dataArray.length; i += 8) {
                const freq = (i / dataArray.length) * (this.testAudioContext.sampleRate / 2);
                labels.push(Math.round(freq));
                data.push(20 * Math.log10(dataArray[i] / 255));
            }

            this.testFrequencyChart.data.labels = labels;
            this.testFrequencyChart.data.datasets[0].data = data;
            this.testFrequencyChart.update('none');
        }

