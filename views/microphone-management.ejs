                    </div>
                </div>
            `;
        }

        async startSystemMonitoring() {
            this.monitoringActive = true;
            this.showNotification('System monitoring started', 'success');
        }

        async stopSystemMonitoring() {
            this.monitoringActive = false;
            this.showNotification('System monitoring stopped', 'info');
        }

        // Health check and auto-recovery methods
        async performHealthCheck() {
            try {
                const response = await axios.get('/parts/api/microphone/health');
                const healthData = response.data;

                this.updateSystemHealthStatus(healthData);

                // Auto-restart failed services if needed
                if (healthData.overall === 'degraded' || healthData.overall === 'error') {
                    this.showNotification('Service issues detected, attempting auto-restart...', 'warning');
                    await this.autoRestartServices();
                }

                return healthData;
            } catch (error) {
                console.error('Health check failed:', error);
                this.updateSystemHealthStatus({ overall: 'error', error: error.message });
                return null;
            }
        }

        async autoRestartServices() {
            try {
                const response = await axios.post('/parts/api/microphone/auto-restart');

                if (response.data.success) {
                    this.showNotification(response.data.message, 'success');

                    // Wait a moment then reconnect WebSockets
                    setTimeout(() => {
                        this.setupWebSocketConnections();
                    }, 3000);
                } else {
                    this.showNotification('Auto-restart failed: ' + response.data.error, 'error');
                }
            } catch (error) {
                console.error('Auto-restart failed:', error);
                this.showNotification('Auto-restart failed: ' + error.message, 'error');
            }
        }

        updateSystemHealthStatus(healthData) {
            const statusDot = document.getElementById('systemStatusDot');
            const statusText = document.getElementById('systemStatusText');

            if (!statusDot || !statusText) return;

            switch (healthData.overall) {
                case 'healthy':
                    statusDot.className = 'indicator-dot active';
                    statusText.textContent = 'All systems operational';
                    break;
                case 'degraded':
                    statusDot.className = 'indicator-dot';
                    statusText.textContent = 'Some services degraded';
                    break;
                case 'error':
                    statusDot.className = 'indicator-dot error';
                    statusText.textContent = 'System errors detected';
                    break;
                default:
                    statusDot.className = 'indicator-dot';
                    statusText.textContent = 'Status unknown';
            }

            // Update individual service statuses
            if (healthData.services) {
                Object.entries(healthData.services).forEach(([serviceId, service]) => {
                    const statusMap = {
                        'microphoneService': 'micServiceStatus',
                        'audioStreamService': 'audioStreamServiceStatus'
                    };

                    const elementId = statusMap[serviceId];
                    if (elementId) {
                        this.updateServiceStatus(elementId,
                            service.running ? 'Connected' : 'Disconnected',
                            service.running ? 'active' : 'error'
                        );
                    }
                });
            }
        }

        // Enhanced error handling for WebSocket connections
        async connectWebSocketWithRetry(serviceId, url, maxRetries = 3) {
            let retries = 0;

            while (retries < maxRetries) {
                try {
                    await this.connectWebSocket(serviceId, url);
                    return true;
                } catch (error) {
                    retries++;
                    console.warn(`WebSocket connection attempt ${retries} failed for ${serviceId}:`, error);

                    if (retries < maxRetries) {
                        // Wait before retry with exponential backoff
                        const delay = Math.pow(2, retries) * 1000;
                        await new Promise(resolve => setTimeout(resolve, delay));
                    }
                }
            }

            // All retries failed, try auto-restart
            this.showNotification(`Failed to connect to ${serviceId} after ${maxRetries} attempts. Trying auto-restart...`, 'warning');
            await this.autoRestartServices();

            return false;
        }

        // Periodic health monitoring
        startPeriodicHealthCheck() {
            // Perform health check every 30 seconds
            setInterval(async () => {
                if (this.monitoringActive) {
                    await this.performHealthCheck();
                }
            }, 30000);

            // Initial health check
            setTimeout(() => {
                this.performHealthCheck();
            }, 2000);
        }

        // Enhanced WebSocket setup with error handling
        async setupWebSocketConnections() {
            try {
                // Connect to microphone service with retry via proxy (fixes browser compatibility)
                const micConnected = await this.connectWebSocketWithRetry('microphone', 'ws://192.168.8.130:8794');

                // Connect to audio stream service with retry via proxy (fixes browser compatibility)
                const audioConnected = await this.connectWebSocketWithRetry('audioStream', 'ws://192.168.8.130:8795');

                if (micConnected && audioConnected) {
                    this.updateServiceStatus('micServiceStatus', 'Connected', 'active');
                    this.updateServiceStatus('audioStreamServiceStatus', 'Connected', 'active');
                    this.showNotification('All WebSocket services connected successfully', 'success');
                } else {
                    this.showNotification('Some WebSocket connections failed', 'warning');
                }
            } catch (error) {
                console.error('Failed to setup WebSocket connections:', error);
                this.updateServiceStatus('micServiceStatus', 'Connection Failed', 'error');
                this.updateServiceStatus('audioStreamServiceStatus', 'Connection Failed', 'error');
                this.showNotification('WebSocket connection setup failed', 'error');
            }
        }
    }

    // Initialize the system when page loads
    document.addEventListener('DOMContentLoaded', function() {
        window.microphoneManagement = new MicrophoneManagementSystem();
    });
