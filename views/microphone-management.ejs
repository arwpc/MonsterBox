                            <!-- Microphone level meters will be populated here -->
                        </div>
                    </div>

                    <!-- Monitoring Controls -->
                    <div class="monitoring-controls">
                        <button class="btn primary" id="startMonitoringBtn" onclick="window.microphoneManagement.startSystemMonitoring()">
                            ▶️ Start System Monitoring
                        </button>
                        <button class="btn secondary" id="stopMonitoringBtn" onclick="window.microphoneManagement.stopSystemMonitoring()" disabled>
                            ⏹️ Stop System Monitoring
                        </button>
