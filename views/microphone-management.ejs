        initializeMonitoring() {
            // Initialize monitoring state
            this.monitoringActive = false;
            this.monitoringInterval = null;
            this.microphoneLevels = new Map();

            // Start initial status check
            this.refreshMonitoring();
        }

        async startSystemMonitoring() {
            if (this.monitoringActive) return;

            this.monitoringActive = true;
            this.addLogEntry('Starting system monitoring...');

            // Update button states
            document.getElementById('startMonitoringBtn').disabled = true;
            document.getElementById('stopMonitoringBtn').disabled = false;

            // Start monitoring interval
            this.monitoringInterval = setInterval(() => {
                this.updateMonitoringData();
            }, 1000); // Update every second

            // Initial update
            this.updateMonitoringData();
            this.addLogEntry('System monitoring started');
        }

        async stopSystemMonitoring() {
            if (!this.monitoringActive) return;

            this.monitoringActive = false;
            this.addLogEntry('Stopping system monitoring...');

            // Clear monitoring interval
            if (this.monitoringInterval) {
                clearInterval(this.monitoringInterval);
                this.monitoringInterval = null;
            }

            // Update button states
            document.getElementById('startMonitoringBtn').disabled = false;
            document.getElementById('stopMonitoringBtn').disabled = true;

            this.addLogEntry('System monitoring stopped');
        }

        async refreshMonitoring() {
            this.addLogEntry('Refreshing monitoring status...');

            // Check service status
            await this.updateServiceStatus();

            // Update microphone levels display
            this.updateMicrophoneLevels();
        }

        async updateServiceStatus() {
            try {
                // Check microphone service status
                const micStatus = await this.checkServiceStatus(8776);
                this.updateServiceIndicator('micServiceStatus', 'micServiceDetails', micStatus, 'Microphone Service', 8776);

                // Check audio stream service status
                const audioStatus = await this.checkServiceStatus(8777);
                this.updateServiceIndicator('audioServiceStatus', 'audioServiceDetails', audioStatus, 'Audio Stream Service', 8777);

            } catch (error) {
                console.error('Error updating service status:', error);
                this.addLogEntry('Error checking service status: ' + error.message, 'error');
            }
        }

        async checkServiceStatus(port) {
            try {
                const ws = new WebSocket(`ws://127.0.0.1:${port}`);

                return new Promise((resolve) => {
                    const timeout = setTimeout(() => {
                        ws.close();
                        resolve(false);
                    }, 3000);

                    ws.onopen = () => {
                        clearTimeout(timeout);
                        ws.close();
                        resolve(true);
                    };

                    ws.onerror = () => {
                        clearTimeout(timeout);
                        resolve(false);
                    };
                });
            } catch (error) {
                return false;
            }
        }

        updateServiceIndicator(statusId, detailsId, isConnected, serviceName, port) {
            try {
                const statusElement = document.getElementById(statusId);
                const detailsElement = document.getElementById(detailsId);

                if (statusElement) {
                    const dot = statusElement.querySelector('.status-dot');
                    const text = statusElement.querySelector('.status-text');

                    if (dot && text) {
                        if (isConnected) {
                            dot.className = 'status-dot connected';
                            text.textContent = 'Connected';
                        } else {
                            dot.className = 'status-dot disconnected';
                            text.textContent = 'Disconnected';
                        }
                    }
                }

                if (detailsElement) {
                    detailsElement.textContent = `Port: ${port} | Status: ${isConnected ? 'Online' : 'Offline'}`;
                }
            } catch (error) {
                console.warn(`Error updating service indicator for ${statusId}:`, error);
            }
        }

        async updateMonitoringData() {
            if (!this.monitoringActive) return;

            try {
                // Update service status
                await this.updateServiceStatus();

                // Update microphone levels (simulated for now)
                this.updateMicrophoneLevels();

            } catch (error) {
                console.error('Error updating monitoring data:', error);
                this.addLogEntry('Error updating monitoring data: ' + error.message, 'error');
            }
        }

        updateMicrophoneLevels() {
            const container = document.getElementById('microphoneLevelsContainer');
            if (!container) return;

            // Get current microphones
            const microphones = this.microphones || [];

            if (microphones.length === 0) {
                container.innerHTML = '<p class="no-microphones">No microphones configured</p>';
                return;
            }

            let levelsHtml = '';
            microphones.forEach(mic => {
                // Simulate audio level (in real implementation, this would come from WebSocket)
                const level = this.monitoringActive ? Math.random() * 100 : 0;
                const levelClass = level > 70 ? 'high' : level > 30 ? 'medium' : 'low';

                levelsHtml += `
                    <div class="microphone-level-meter">
                        <div class="meter-header">
                            <span class="mic-name">${mic.name}</span>
                            <span class="mic-level">${level.toFixed(1)}%</span>
                        </div>
                        <div class="level-bar">
                            <div class="level-fill ${levelClass}" style="width: ${level}%"></div>
                        </div>
                        <div class="meter-details">
                            Device: ${mic.deviceId || 'Unknown'} | Sample Rate: ${mic.sampleRate || 16000}Hz
                        </div>
                    </div>
                `;
            });

            container.innerHTML = levelsHtml;
        }

        addLogEntry(message, type = 'info') {
            const logContainer = document.getElementById('monitoringLog');
            if (!logContainer) return;

            const timestamp = new Date().toLocaleTimeString();
            const logEntry = document.createElement('div');
            logEntry.className = `log-entry ${type}`;
            logEntry.innerHTML = `
                <span class="log-time">${timestamp}</span>
                <span class="log-message">${message}</span>
            `;

            logContainer.insertBefore(logEntry, logContainer.firstChild);

            // Keep only last 50 entries
            while (logContainer.children.length > 50) {
                logContainer.removeChild(logContainer.lastChild);
            }
        }



        async startSystemMonitoring() {
            this.monitoringActive = true;
            this.showNotification('System monitoring started', 'success');
        }

        async stopSystemMonitoring() {
            this.monitoringActive = false;
            this.showNotification('System monitoring stopped', 'info');
        }

        // Health check and auto-recovery methods
        async performHealthCheck() {
            try {
                const response = await axios.get('/parts/api/microphone/health');
                const healthData = response.data;

                this.updateSystemHealthStatus(healthData);

                // Auto-restart failed services if needed
                if (healthData.overall === 'degraded' || healthData.overall === 'error') {
                    this.showNotification('Service issues detected, attempting auto-restart...', 'warning');
                    await this.autoRestartServices();
                }

                return healthData;
            } catch (error) {
                console.error('Health check failed:', error);
                this.updateSystemHealthStatus({ overall: 'error', error: error.message });
                return null;
            }
        }

        async autoRestartServices() {
            try {
                const response = await axios.post('/parts/api/microphone/auto-restart');

                if (response.data.success) {
                    this.showNotification(response.data.message, 'success');

                    // Wait a moment then reconnect WebSockets
                    setTimeout(() => {
                        this.setupWebSocketConnections();
                    }, 3000);
                } else {
                    this.showNotification('Auto-restart failed: ' + (response.data.error || response.data.message || 'Unknown error'), 'error');
                }
            } catch (error) {
                console.error('Auto-restart failed:', error);
                this.showNotification('Auto-restart failed: ' + error.message, 'error');
            }
        }

        updateSystemHealthStatus(healthData) {
            const statusDot = document.getElementById('systemStatusDot');
            const statusText = document.getElementById('systemStatusText');

            if (!statusDot || !statusText) return;

            switch (healthData.overall) {
                case 'healthy':
                    statusDot.className = 'indicator-dot active';
                    statusText.textContent = 'All systems operational';
                    break;
                case 'degraded':
                    statusDot.className = 'indicator-dot';
                    statusText.textContent = 'Some services degraded';
                    break;
                case 'error':
                    statusDot.className = 'indicator-dot error';
                    statusText.textContent = 'System errors detected';
                    break;
                default:
                    statusDot.className = 'indicator-dot';
                    statusText.textContent = 'Status unknown';
            }

            // Update individual service statuses
            if (healthData.services) {
                Object.entries(healthData.services).forEach(([serviceId, service]) => {
                    const statusMap = {
                        'microphoneService': 'micServiceStatus',
                        'audioStreamService': 'audioStreamServiceStatus'
                    };

                    const elementId = statusMap[serviceId];
                    if (elementId) {
                        this.updateServiceStatus(elementId,
                            service.running ? 'Connected' : 'Disconnected',
                            service.running ? 'active' : 'error'
                        );
                    }
                });
            }
        }

        // Enhanced error handling for WebSocket connections
        async connectWebSocketWithRetry(serviceId, url, maxRetries = 3) {
            let retries = 0;

            while (retries < maxRetries) {
                try {
                    await this.connectWebSocket(serviceId, url);
                    return true;
                } catch (error) {
                    retries++;
                    console.warn(`WebSocket connection attempt ${retries} failed for ${serviceId}:`, error);

                    if (retries < maxRetries) {
                        // Wait before retry with exponential backoff
                        const delay = Math.pow(2, retries) * 1000;
                        await new Promise(resolve => setTimeout(resolve, delay));
                    }
                }
            }

            // All retries failed, try auto-restart
            this.showNotification(`Failed to connect to ${serviceId} after ${maxRetries} attempts. Trying auto-restart...`, 'warning');
            await this.autoRestartServices();

            return false;
        }

        // Periodic health monitoring
        startPeriodicHealthCheck() {
            // Perform health check every 30 seconds
            setInterval(async () => {
                if (this.monitoringActive) {
                    await this.performHealthCheck();
                }
            }, 30000);

            // Initial health check
            setTimeout(() => {
                this.performHealthCheck();
            }, 2000);
        }

        // Populate microphone device select dropdown
        async populateMicrophoneDevices() {
            try {
                const deviceSelect = document.getElementById('microphoneDeviceSelect');
                if (!deviceSelect) return;

                // Get available audio devices
                const devices = await navigator.mediaDevices.enumerateDevices();
                const audioInputs = devices.filter(device => device.kind === 'audioinput');

                deviceSelect.innerHTML = '<option value="">Select microphone device...</option>';
                audioInputs.forEach(device => {
                    const option = document.createElement('option');
                    option.value = device.deviceId;
                    option.textContent = device.label || `Microphone ${device.deviceId.substring(0, 8)}`;
                    deviceSelect.appendChild(option);
                });
            } catch (error) {
                console.error('Error populating microphone devices:', error);
            }
        }

