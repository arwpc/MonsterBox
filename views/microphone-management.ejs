            this.updateAudioLevel(0);

            // Update button states
            const startBtn = document.getElementById('startAudioMonitoringBtn');
            const stopBtn = document.getElementById('stopAudioMonitoringBtn');

            if (startBtn) startBtn.disabled = false;
            if (stopBtn) stopBtn.disabled = true;
        }
















