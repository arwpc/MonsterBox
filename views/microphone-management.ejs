<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <header>
        <h1 class="landing-title">🎤 Microphone Parts Management</h1>
    </header>

    <main>
        <div class="info-section">
            <h3>🎤 Microphone Overview</h3>
            <p>Comprehensive microphone configuration, testing, and monitoring</p>
        </div>

        <div class="button-group">
            <a href="/parts" class="button secondary-btn">🔧 All Hardware Parts</a>
            <a href="/" class="button secondary-btn">🏠 Back to Main Menu</a>
        </div>

    <div class="container">

    <!-- Service Status Panel -->
    <div class="service-status-panel">
        <h3>🔧 Service Status</h3>
        <div class="status-grid">
            <div class="status-card" id="microphoneServiceStatus">
                <div class="status-icon">🎤</div>
                <div class="status-info">
                    <div class="status-label">Microphone Service</div>
                    <div class="status-value" id="micServiceStatus">Checking...</div>
                    <div class="status-port">Port 8776</div>
                </div>
                <button class="status-action" id="restartMicService">🔄 Restart</button>
            </div>
            <div class="status-card" id="audioStreamStatus">
                <div class="status-icon">🔊</div>
                <div class="status-info">
                    <div class="status-label">Audio Stream Service</div>
                    <div class="status-value" id="audioStreamServiceStatus">Checking...</div>
                    <div class="status-port">Port 8777</div>
                </div>
                <button class="status-action" id="restartAudioService">🔄 Restart</button>
            </div>
        </div>
    </div>

    <!-- Main Management Tabs -->
    <div class="management-tabs">
        <div class="tab-navigation">
            <button class="tab-button active" data-tab="overview">📊 Overview</button>
            <button class="tab-button" data-tab="crud">🔧 Manage Parts</button>
            <button class="tab-button" data-tab="testing">🧪 Testing Suite</button>
            <button class="tab-button" data-tab="monitoring">👁️ Live Monitoring</button>
            <button class="tab-button" data-tab="configuration">⚙️ Configuration</button>
        </div>

        <!-- Overview Tab -->
        <div id="overview-tab" class="tab-content active">
            <div class="overview-grid">
                <div class="overview-card">
                    <h4>📈 System Overview</h4>
                    <div class="metric-row">
                        <span class="metric-label">Total Microphones:</span>
                        <span class="metric-value" id="totalMicrophones"><%= microphones.length %></span>
                    </div>
                    <div class="metric-row">
                        <span class="metric-label">Active Microphones:</span>
                        <span class="metric-value" id="activeMicrophones">0</span>
                    </div>
                    <div class="metric-row">
                        <span class="metric-label">Available Devices:</span>
                        <span class="metric-value" id="availableDevices">Detecting...</span>
                    </div>
                </div>

                <div class="overview-card">
                    <h4>🎯 Quick Actions</h4>
                    <div class="quick-actions">
                        <button class="action-btn primary" id="createNewMicrophone">➕ Add New Microphone</button>
                        <button class="action-btn secondary" id="detectDevices">🔍 Detect Devices</button>
                        <button class="action-btn secondary" id="testAllMicrophones">🧪 Test All</button>
                        <button class="action-btn secondary" id="exportConfiguration">📤 Export Config</button>
                    </div>
                </div>

                <div class="overview-card">
                    <h4>⚡ Real-Time Status</h4>
                    <div id="realTimeOverview">
                        <div class="status-indicator">
                            <span class="indicator-dot" id="systemStatusDot"></span>
                            <span id="systemStatusText">Initializing...</span>
                        </div>
                        <div class="audio-level-overview">
                            <div class="level-label">System Audio Level</div>
                            <div class="level-bar-container">
                                <div class="level-bar" id="systemAudioLevel"></div>
                            </div>
                            <div class="level-value" id="systemAudioValue">0%</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Microphones List -->
            <div class="microphones-list">
                <h4>🎤 Microphone Parts</h4>
                <div class="list-controls">
                    <input type="text" id="searchMicrophones" placeholder="🔍 Search microphones..." class="search-input">
                    <select id="filterStatus" class="filter-select">
                        <option value="">All Status</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                        <option value="error">Error</option>
                    </select>
                    <button class="refresh-btn" id="refreshMicrophones">🔄 Refresh</button>
                </div>
                
                <div class="microphones-grid" id="microphonesGrid">
                    <% microphones.forEach(function(microphone) { %>
                        <div class="microphone-card" data-id="<%= microphone.id %>">
                            <div class="card-header">
                                <h5><%= microphone.name %></h5>
                                <div class="status-badge" data-status="inactive">Inactive</div>
                            </div>
                            <div class="card-body">
                                <div class="device-info">
                                    <span class="info-label">Device:</span>
                                    <span class="info-value"><%= microphone.deviceId || 'default' %></span>
                                </div>
                                <div class="device-info">
                                    <span class="info-label">Sample Rate:</span>
                                    <span class="info-value"><%= microphone.sampleRate || '16000' %> Hz</span>
                                </div>
                                <div class="device-info">
                                    <span class="info-label">Channels:</span>
                                    <span class="info-value"><%= microphone.channels || '1' %></span>
                                </div>
                                <div class="audio-level-mini">
                                    <div class="level-bar-mini" data-id="<%= microphone.id %>"></div>
                                </div>
                            </div>
                            <div class="card-actions">
                                <button class="btn-small test-btn" data-id="<%= microphone.id %>">🧪 Test</button>
                                <button class="btn-small edit-btn" data-id="<%= microphone.id %>">✏️ Edit</button>
                                <button class="btn-small monitor-btn" data-id="<%= microphone.id %>">👁️ Monitor</button>
                                <button class="btn-small delete-btn" data-id="<%= microphone.id %>">🗑️ Delete</button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </div>

        <!-- CRUD Operations Tab -->
        <div id="crud-tab" class="tab-content">
            <div class="crud-section">
                <h4>🔧 Microphone Parts Management</h4>
                
                <!-- Create New Microphone Form -->
                <div class="create-form-container" id="createFormContainer" style="display: none;">
                    <h5>➕ Create New Microphone</h5>
                    <form id="createMicrophoneForm" class="microphone-form">
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="newMicName">Name:</label>
                                <input type="text" id="newMicName" name="name" required placeholder="Enter microphone name">
                            </div>
                            <div class="form-group">
                                <label for="newMicDevice">Device ID:</label>
                                <select id="newMicDevice" name="deviceId" required>
                                    <option value="">Select device...</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="newMicSampleRate">Sample Rate:</label>
                                <select id="newMicSampleRate" name="sampleRate">
                                    <option value="8000">8000 Hz</option>
                                    <option value="16000" selected>16000 Hz</option>
                                    <option value="22050">22050 Hz</option>
                                    <option value="44100">44100 Hz</option>
                                    <option value="48000">48000 Hz</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="newMicChannels">Channels:</label>
                                <select id="newMicChannels" name="channels">
                                    <option value="1" selected>Mono (1)</option>
                                    <option value="2">Stereo (2)</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="advanced-settings" id="advancedSettings">
                            <h6>🔧 Advanced Settings</h6>
                            <div class="form-grid">
                                <div class="form-group">
                                    <label for="newMicSensitivity">Sensitivity:</label>
                                    <input type="range" id="newMicSensitivity" name="sensitivity" min="0.1" max="3.0" step="0.1" value="1.0">
                                    <span class="range-value" id="sensitivityValue">1.0</span>
                                </div>
                                <div class="form-group checkbox-group">
                                    <label>
                                        <input type="checkbox" id="newMicEcho" name="echoCancellation" checked>
                                        Echo Cancellation
                                    </label>
                                </div>
                                <div class="form-group checkbox-group">
                                    <label>
                                        <input type="checkbox" id="newMicNoise" name="noiseSuppression" checked>
                                        Noise Suppression
                                    </label>
                                </div>
                                <div class="form-group checkbox-group">
                                    <label>
                                        <input type="checkbox" id="newMicGain" name="autoGainControl" checked>
                                        Auto Gain Control
                                    </label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-actions">
                            <button type="submit" class="btn primary">💾 Create Microphone</button>
                            <button type="button" class="btn secondary" id="cancelCreate">❌ Cancel</button>
                            <button type="button" class="btn secondary" id="testNewMicrophone">🧪 Test Configuration</button>
                        </div>
                    </form>
                </div>

                <!-- Bulk Operations -->
                <div class="bulk-operations">
                    <h5>📦 Bulk Operations</h5>
                    <div class="bulk-controls">
                        <div class="selection-info">
                            <span id="selectedCount">0</span> microphones selected
                        </div>
                        <div class="bulk-actions">
                            <button class="btn secondary" id="selectAll">☑️ Select All</button>
                            <button class="btn secondary" id="selectNone">☐ Select None</button>
                            <button class="btn warning" id="bulkDelete" disabled>🗑️ Delete Selected</button>
                            <button class="btn secondary" id="bulkTest" disabled>🧪 Test Selected</button>
                            <button class="btn secondary" id="bulkExport" disabled>📤 Export Selected</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Testing Suite Tab -->
        <div id="testing-tab" class="tab-content">
            <div class="testing-suite">
                <h4>🧪 Microphone Testing Suite</h4>
                <div class="test-controls">
                    <div class="test-selector">
                        <label for="testMicrophoneSelect">Select Microphone:</label>
                        <select id="testMicrophoneSelect">
                            <option value="">Choose microphone...</option>
                            <% microphones.forEach(function(microphone) { %>
                                <option value="<%= microphone.id %>" data-device="<%= microphone.deviceId %>">
                                    <%= microphone.name %> (<%= microphone.deviceId || 'default' %>)
                                </option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="test-actions">
                        <button class="btn primary" id="startComprehensiveTest" disabled>▶️ Start Test</button>
                        <button class="btn secondary" id="stopTest" disabled>⏹️ Stop Test</button>
                        <button class="btn secondary" id="quickTest" disabled>⚡ Quick Test</button>
                        <button class="btn secondary" id="ambientTest" disabled>🌊 Ambient Test</button>
                    </div>
                </div>
                
                <!-- Test Results will be loaded here -->
                <div id="testResultsContainer">
                    <!-- This will be populated by the testing interface -->
                </div>
            </div>
        </div>

        <!-- Live Monitoring Tab -->
        <div id="monitoring-tab" class="tab-content">
            <div class="monitoring-suite">
                <h4>👁️ Live Microphone Monitoring</h4>
                <!-- Monitoring interface will be loaded here -->
                <div id="monitoringContainer">
                    <!-- This will be populated by the monitoring interface -->
                </div>
            </div>
        </div>

        <!-- Configuration Tab -->
        <div id="configuration-tab" class="tab-content">
            <div class="configuration-suite">
                <h4>⚙️ System Configuration</h4>
                <!-- Configuration interface will be loaded here -->
                <div id="configurationContainer">
                    <!-- This will be populated by the configuration interface -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CSS Styling -->
<style>
    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }

    .page-header {
        text-align: center;
        margin-bottom: 30px;
        padding: 20px;
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(0, 255, 0, 0.3);
        border-radius: 8px;
    }

    .page-header h1 {
        color: #00ff00;
        margin-bottom: 10px;
        font-size: 2.5em;
    }

    .subtitle {
        color: #ffffff;
        font-size: 1.1em;
        opacity: 0.8;
    }

    /* Service Status Panel */
    .service-status-panel {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(0, 255, 0, 0.3);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 30px;
    }

    .service-status-panel h3 {
        color: #00ff00;
        margin-bottom: 15px;
        border-bottom: 1px solid rgba(0, 255, 0, 0.3);
        padding-bottom: 10px;
    }

    .status-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
    }

    .status-card {
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(0, 255, 0, 0.3);
        border-radius: 8px;
        padding: 15px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .status-icon {
        font-size: 2em;
        width: 60px;
        text-align: center;
    }

    .status-info {
        flex: 1;
    }

    .status-label {
        color: #00ff00;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .status-value {
        color: #ffffff;
        font-size: 1.1em;
        margin-bottom: 3px;
    }

    .status-port {
        color: #888;
        font-size: 0.9em;
    }

    .status-action {
        background: rgba(0, 255, 0, 0.2);
        border: 1px solid rgba(0, 255, 0, 0.5);
        border-radius: 4px;
        color: #00ff00;
        padding: 8px 12px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .status-action:hover {
        background: rgba(0, 255, 0, 0.3);
    }

    /* Management Tabs */
    .management-tabs {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(0, 255, 0, 0.3);
        border-radius: 8px;
        overflow: hidden;
    }

    .tab-navigation {
        display: flex;
        background: rgba(0, 0, 0, 0.5);
        border-bottom: 1px solid rgba(0, 255, 0, 0.3);
    }

    .tab-button {
        flex: 1;
        padding: 15px 20px;
        background: transparent;
        border: none;
        color: #ffffff;
        cursor: pointer;
        transition: all 0.3s ease;
        border-right: 1px solid rgba(0, 255, 0, 0.3);
    }

    .tab-button:last-child {
        border-right: none;
    }

    .tab-button.active {
        background: rgba(0, 255, 0, 0.2);
        color: #00ff00;
    }

    .tab-button:hover:not(.active) {
        background: rgba(0, 255, 0, 0.1);
    }

    .tab-content {
        display: none;
        padding: 30px;
    }

    .tab-content.active {
        display: block;
    }

    /* Overview Grid */
    .overview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .overview-card {
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(0, 255, 0, 0.3);
        border-radius: 8px;
        padding: 20px;
    }

    .overview-card h4 {
        color: #00ff00;
        margin-bottom: 15px;
        border-bottom: 1px solid rgba(0, 255, 0, 0.3);
        padding-bottom: 10px;
    }

    .metric-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
        padding: 5px 0;
    }

    .metric-label {
        color: #ffffff;
    }

    .metric-value {
        color: #00ff00;
        font-weight: bold;
    }

    .quick-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .action-btn {
        padding: 10px 15px;
        border: 1px solid rgba(0, 255, 0, 0.5);
        border-radius: 4px;
        background: rgba(0, 255, 0, 0.1);
        color: #00ff00;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: left;
    }

    .action-btn.primary {
        background: rgba(0, 255, 0, 0.2);
        border-color: #00ff00;
    }

    .action-btn:hover {
        background: rgba(0, 255, 0, 0.3);
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 15px;
    }

    .indicator-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #888;
        animation: pulse 2s infinite;
    }

    .indicator-dot.active {
        background: #00ff00;
    }

    .indicator-dot.error {
        background: #ff0000;
    }

    @keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }

    .audio-level-overview {
        margin-top: 15px;
    }

    .level-label {
        color: #00ff00;
        font-size: 12px;
        margin-bottom: 5px;
    }

    .level-bar-container {
        width: 100%;
        height: 20px;
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(0, 255, 0, 0.5);
        border-radius: 10px;
        overflow: hidden;
        position: relative;
        margin-bottom: 5px;
    }

    .level-bar {
        height: 100%;
        background: linear-gradient(to right, #00ff00, #ffff00, #ff8800, #ff0000);
        width: 0%;
        transition: width 0.1s ease;
    }

    .level-value {
        text-align: center;
        color: #ffffff;
        font-size: 12px;
    }

    /* Microphones List */
    .microphones-list {
        margin-top: 30px;
    }

    .microphones-list h4 {
        color: #00ff00;
        margin-bottom: 20px;
        border-bottom: 1px solid rgba(0, 255, 0, 0.3);
        padding-bottom: 10px;
    }

    .list-controls {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
        align-items: center;
    }

    .search-input, .filter-select {
        padding: 8px 12px;
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(0, 255, 0, 0.5);
        border-radius: 4px;
        color: #ffffff;
    }

    .search-input {
        flex: 1;
        min-width: 200px;
    }

    .filter-select {
        min-width: 120px;
    }

    .refresh-btn {
        padding: 8px 15px;
        background: rgba(0, 255, 0, 0.2);
        border: 1px solid rgba(0, 255, 0, 0.5);
        border-radius: 4px;
        color: #00ff00;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .refresh-btn:hover {
        background: rgba(0, 255, 0, 0.3);
    }

    .microphones-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
    }

    .microphone-card {
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(0, 255, 0, 0.3);
        border-radius: 8px;
        padding: 15px;
        transition: all 0.3s ease;
    }

    .microphone-card:hover {
        border-color: #00ff00;
        box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        border-bottom: 1px solid rgba(0, 255, 0, 0.3);
        padding-bottom: 10px;
    }

    .card-header h5 {
        color: #00ff00;
        margin: 0;
    }

    .status-badge {
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.8em;
        font-weight: bold;
    }

    .status-badge[data-status="active"] {
        background: rgba(0, 255, 0, 0.2);
        color: #00ff00;
        border: 1px solid rgba(0, 255, 0, 0.5);
    }

    .status-badge[data-status="inactive"] {
        background: rgba(128, 128, 128, 0.2);
        color: #888;
        border: 1px solid rgba(128, 128, 128, 0.5);
    }

    .status-badge[data-status="error"] {
        background: rgba(255, 0, 0, 0.2);
        color: #ff0000;
        border: 1px solid rgba(255, 0, 0, 0.5);
    }

    .card-body {
        margin-bottom: 15px;
    }

    .device-info {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
    }

    .info-label {
        color: #888;
        font-size: 0.9em;
    }

    .info-value {
        color: #ffffff;
        font-weight: bold;
    }

    .audio-level-mini {
        margin-top: 10px;
        height: 8px;
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(0, 255, 0, 0.3);
        border-radius: 4px;
        overflow: hidden;
    }

    .level-bar-mini {
        height: 100%;
        background: linear-gradient(to right, #00ff00, #ffff00, #ff8800);
        width: 0%;
        transition: width 0.2s ease;
    }

    .card-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-small {
        padding: 6px 10px;
        font-size: 0.8em;
        border: 1px solid rgba(0, 255, 0, 0.5);
        border-radius: 4px;
        background: rgba(0, 255, 0, 0.1);
        color: #00ff00;
        cursor: pointer;
        transition: all 0.3s ease;
        flex: 1;
        min-width: 60px;
        text-align: center;
    }

    .btn-small:hover {
        background: rgba(0, 255, 0, 0.2);
    }

    .btn-small.delete-btn {
        background: rgba(255, 0, 0, 0.1);
        border-color: rgba(255, 0, 0, 0.5);
        color: #ff0000;
    }

    .btn-small.delete-btn:hover {
        background: rgba(255, 0, 0, 0.2);
    }

    /* Form Styling */
    .create-form-container {
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(0, 255, 0, 0.3);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 30px;
    }

    .create-form-container h5 {
        color: #00ff00;
        margin-bottom: 20px;
        border-bottom: 1px solid rgba(0, 255, 0, 0.3);
        padding-bottom: 10px;
    }

    .microphone-form {
        max-width: 800px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group label {
        color: #00ff00;
        margin-bottom: 5px;
        font-weight: bold;
    }

