<!-- Include required JavaScript files -->
<script src="/js/EnhancedMicrophoneComponent.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script>
    // Microphone Management System
    class MicrophoneManagementSystem {
        constructor() {
            this.selectedMicrophones = new Set();
            this.microphoneStatuses = new Map();
            this.websockets = new Map();
            this.monitoringActive = false;

            this.init();
        }

        async init() {
            this.setupEventHandlers();
            await this.setupWebSocketConnections();
            await this.loadInitialData();
            this.startStatusMonitoring();
            this.startPeriodicHealthCheck();
        }

        setupEventHandlers() {
            // Tab switching
            document.querySelectorAll('.tab-button').forEach(button => {
                button.addEventListener('click', (e) => {
                    this.switchTab(e.target.dataset.tab);
                });
            });

            // Service restart buttons
            document.getElementById('restartMicService').addEventListener('click', () => {
                this.restartService('microphone', 8776);
            });

            document.getElementById('restartAudioService').addEventListener('click', () => {
                this.restartService('audioStream', 8777);
            });

            // Quick actions
            document.getElementById('createNewMicrophone').addEventListener('click', () => {
                this.showCreateForm();
            });

            document.getElementById('detectDevices').addEventListener('click', () => {
                this.detectAudioDevices();
            });



            document.getElementById('exportConfiguration').addEventListener('click', () => {
                this.exportConfiguration();
            });

            // Search and filter
            document.getElementById('searchMicrophones').addEventListener('input', (e) => {
                this.filterMicrophones(e.target.value);
            });

            document.getElementById('filterStatus').addEventListener('change', (e) => {
                this.filterByStatus(e.target.value);
            });

            document.getElementById('refreshMicrophones').addEventListener('click', () => {
                this.refreshMicrophonesList();
            });

            // Create form handlers
            document.getElementById('createMicrophoneForm').addEventListener('submit', (e) => {
                e.preventDefault();
                this.createMicrophone();
            });

            document.getElementById('cancelCreate').addEventListener('click', () => {
                this.hideCreateForm();
            });



            // Sensitivity slider
            document.getElementById('newMicSensitivity').addEventListener('input', (e) => {
                document.getElementById('sensitivityValue').textContent = e.target.value;
            });

            // Bulk operations
            document.getElementById('selectAll').addEventListener('click', () => {
                this.selectAllMicrophones();
            });

            document.getElementById('selectNone').addEventListener('click', () => {
                this.selectNoMicrophones();
            });

            document.getElementById('bulkDelete').addEventListener('click', () => {
                this.bulkDeleteMicrophones();
            });



            document.getElementById('bulkExport').addEventListener('click', () => {
                this.bulkExportMicrophones();
            });





            // Microphone card actions
            this.setupMicrophoneCardHandlers();
        }

        setupMicrophoneCardHandlers() {
            document.addEventListener('click', (e) => {
                if (e.target.classList.contains('edit-btn')) {
                    const microphoneId = e.target.dataset.id;
                    this.editMicrophone(microphoneId);
                } else if (e.target.classList.contains('monitor-btn')) {
                    const microphoneId = e.target.dataset.id;
                    this.monitorMicrophone(microphoneId);
                } else if (e.target.classList.contains('delete-btn')) {
                    const microphoneId = e.target.dataset.id;
                    this.deleteMicrophone(microphoneId);
                }
            });

            // Checkbox selection for bulk operations
            document.addEventListener('change', (e) => {
                if (e.target.type === 'checkbox' && e.target.classList.contains('microphone-select')) {
                    const microphoneId = e.target.dataset.id;
                    if (e.target.checked) {
                        this.selectedMicrophones.add(microphoneId);
                    } else {
                        this.selectedMicrophones.delete(microphoneId);
                    }
                    this.updateBulkOperationsUI();
                }
            });
        }



        async setupWebSocketConnections() {
            try {
                // Get the correct hostname (use IP if localhost resolves incorrectly)
                const hostname = window.location.hostname === 'localhost' ? '192.168.8.130' : window.location.hostname;

                // Connect to microphone service via proxy (fixes browser compatibility)
                await this.connectWebSocket('microphone', `ws://${hostname}:8794`);

                // Connect to audio stream service via proxy (fixes browser compatibility)
                await this.connectWebSocket('audioStream', `ws://${hostname}:8795`);

                this.updateServiceStatus('micServiceStatus', 'Connected', 'active');
                this.updateServiceStatus('audioStreamServiceStatus', 'Connected', 'active');
            } catch (error) {
                console.error('Failed to setup WebSocket connections:', error);
                this.updateServiceStatus('micServiceStatus', 'Connection Failed', 'error');
                this.updateServiceStatus('audioStreamServiceStatus', 'Connection Failed', 'error');
            }
        }

        async connectWebSocket(serviceId, url) {
            return new Promise((resolve, reject) => {
                const ws = new WebSocket(url);
                const timeout = setTimeout(() => {
                    reject(new Error(`WebSocket connection timeout for ${serviceId}`));
                }, 5000);

                ws.onopen = () => {
                    clearTimeout(timeout);
                    this.websockets.set(serviceId, ws);
                    console.log(`Connected to ${serviceId} WebSocket service`);
                    resolve();
                };

                ws.onerror = (error) => {
                    clearTimeout(timeout);
                    console.error(`WebSocket error for ${serviceId}:`, error);
                    reject(error);
                };

                ws.onclose = () => {
                    console.log(`WebSocket disconnected: ${serviceId}`);
                    this.websockets.delete(serviceId);
                    // Auto-reconnect after delay
                    setTimeout(() => this.connectWebSocket(serviceId, url), 5000);
                };

                ws.onmessage = (event) => {
                    this.handleWebSocketMessage(serviceId, JSON.parse(event.data));
                };
            });
        }

        handleWebSocketMessage(serviceId, message) {
            switch (message.type) {
                case 'microphone_status_update':
                    this.updateMicrophoneStatus(message.microphoneId, message.status);
                    break;
                case 'audio_level_update':
                    this.updateAudioLevel(message.microphoneId, message.level);
                    break;
                case 'microphones_discovered':
                    this.updateAvailableDevices(message.microphones);
                    break;

                default:
                    console.log(`Unknown message type from ${serviceId}:`, message.type);
            }
        }

        async loadInitialData() {
            try {
                // Load microphones
                await this.refreshMicrophonesList();

                // Detect available audio devices
                await this.detectAudioDevices();

                // Update overview metrics
                this.updateOverviewMetrics();

            } catch (error) {
                console.error('Error loading initial data:', error);
            }
        }

        startStatusMonitoring() {
            // Update system status every 5 seconds
            setInterval(() => {
                this.updateSystemStatus();
            }, 5000);

            // Update audio levels every 100ms
            setInterval(() => {
                this.updateAudioLevels();
            }, 100);
        }

        switchTab(tabName) {
            // Hide all tab contents
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });

            // Remove active class from all tab buttons
            document.querySelectorAll('.tab-button').forEach(button => {
                button.classList.remove('active');
            });

            // Show selected tab content
            document.getElementById(`${tabName}-tab`).classList.add('active');
            document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');

            // Load tab-specific content
            this.loadTabContent(tabName);
        }

        async loadTabContent(tabName) {
            switch (tabName) {
                case 'monitoring':
                    await this.loadMonitoringInterface();
                    break;
            }
        }

        async restartService(serviceType, port) {
            try {
                const response = await axios.post('/api/services/restart', {
                    serviceType,
                    port
                });

                if (response.data.success) {
                    this.showNotification(`${serviceType} service restarted successfully`, 'success');
                    // Reconnect WebSocket after delay
                    setTimeout(() => {
                        const hostname = window.location.hostname === 'localhost' ? '192.168.8.130' : window.location.hostname;
                        if (serviceType === 'microphone') {
                            this.connectWebSocket('microphone', `ws://${hostname}:8794`);
                        } else if (serviceType === 'audioStream') {
                            this.connectWebSocket('audioStream', `ws://${hostname}:8795`);
                        }
                    }, 2000);
                } else {
                    this.showNotification(`Failed to restart ${serviceType} service`, 'error');
                }
            } catch (error) {
                console.error(`Error restarting ${serviceType} service:`, error);
                this.showNotification(`Error restarting ${serviceType} service`, 'error');
            }
        }

        showCreateForm() {
            document.getElementById('createFormContainer').style.display = 'block';
            document.getElementById('createFormContainer').scrollIntoView({ behavior: 'smooth' });
        }

        hideCreateForm() {
            document.getElementById('createFormContainer').style.display = 'none';
            document.getElementById('createMicrophoneForm').reset();
        }

        async detectAudioDevices() {
            try {
                // Send request to microphone service to discover devices
                const ws = this.websockets.get('microphone');
                if (ws && ws.readyState === WebSocket.OPEN) {
                    ws.send(JSON.stringify({
                        type: 'discover_microphones'
                    }));
                }

                // Also try browser API
                if (navigator.mediaDevices && navigator.mediaDevices.enumerateDevices) {
                    const devices = await navigator.mediaDevices.enumerateDevices();
                    const audioInputs = devices.filter(device => device.kind === 'audioinput');
                    this.updateDeviceSelect(audioInputs);
                }
            } catch (error) {
                console.error('Error detecting audio devices:', error);
                this.showNotification('Error detecting audio devices', 'error');
            }
        }

        updateDeviceSelect(devices) {
            const select = document.getElementById('newMicDevice');
            // Clear existing options except the first one
            while (select.children.length > 1) {
                select.removeChild(select.lastChild);
            }

            devices.forEach(device => {
                const option = document.createElement('option');
                option.value = device.deviceId || device.index;
                option.textContent = device.label || device.name || `Device ${device.index}`;
                select.appendChild(option);
            });

            document.getElementById('availableDevices').textContent = devices.length;
        }

        async createMicrophone() {
            try {
                const formData = new FormData(document.getElementById('createMicrophoneForm'));
                const microphoneData = Object.fromEntries(formData.entries());

                // Convert checkboxes to boolean
                microphoneData.echoCancellation = document.getElementById('newMicEcho').checked;
                microphoneData.noiseSuppression = document.getElementById('newMicNoise').checked;
                microphoneData.autoGainControl = document.getElementById('newMicGain').checked;

                const response = await axios.post('/parts/microphone', microphoneData);

                if (response.data.success || response.status === 200) {
                    this.showNotification('Microphone created successfully', 'success');
                    this.hideCreateForm();
                    await this.refreshMicrophonesList();
                } else {
                    this.showNotification('Failed to create microphone', 'error');
                }
            } catch (error) {
                console.error('Error creating microphone:', error);
                this.showNotification('Error creating microphone: ' + error.message, 'error');
            }
        }



        async refreshMicrophonesList() {
            try {
                const response = await axios.get('/parts/api/parts');
                const microphones = response.data.filter(part => part.type === 'microphone');

                this.renderMicrophonesList(microphones);
                this.updateOverviewMetrics();

            } catch (error) {
                console.error('Error refreshing microphones list:', error);
                this.showNotification('Error refreshing microphones list', 'error');
            }
        }

        renderMicrophonesList(microphones) {
            const grid = document.getElementById('microphonesGrid');
            grid.innerHTML = '';

            microphones.forEach(microphone => {
                const card = this.createMicrophoneCard(microphone);
                grid.appendChild(card);
            });

            document.getElementById('totalMicrophones').textContent = microphones.length;
        }

        createMicrophoneCard(microphone) {
            const card = document.createElement('div');
            card.className = 'microphone-card';
            card.dataset.id = microphone.id;

            const status = this.microphoneStatuses.get(microphone.id) || 'inactive';

            card.innerHTML = `
                <div class="card-header">
                    <h5>${microphone.name}</h5>
                    <div class="status-badge" data-status="${status}">${status.charAt(0).toUpperCase() + status.slice(1)}</div>
                </div>
                <div class="card-body">
                    <div class="device-info">
                        <span class="info-label">Device:</span>
                        <span class="info-value">${microphone.deviceId || 'default'}</span>
                    </div>
                    <div class="device-info">
                        <span class="info-label">Sample Rate:</span>
                        <span class="info-value">${microphone.sampleRate || '16000'} Hz</span>
                    </div>
                    <div class="device-info">
                        <span class="info-label">Channels:</span>
                        <span class="info-value">${microphone.channels || '1'}</span>
                    </div>
                    <div class="audio-level-mini">
                        <div class="level-bar-mini" data-id="${microphone.id}"></div>
                    </div>
                </div>
                <div class="card-actions">
                    <button class="btn-small edit-btn" data-id="${microphone.id}">✏️ Edit</button>
                    <button class="btn-small monitor-btn" data-id="${microphone.id}">👁️ Monitor</button>
                    <button class="btn-small delete-btn" data-id="${microphone.id}">🗑️ Delete</button>
                </div>
            `;

            return card;
        }

        updateServiceStatus(elementId, status, type) {
            const element = document.getElementById(elementId);
            if (element) {
                element.textContent = status;
                element.className = `status-value ${type}`;
            }
        }

        updateSystemStatus() {
            const micServiceConnected = this.websockets.has('microphone');
            const audioServiceConnected = this.websockets.has('audioStream');

            const systemStatusDot = document.getElementById('systemStatusDot');
            const systemStatusText = document.getElementById('systemStatusText');

            if (micServiceConnected && audioServiceConnected) {
                systemStatusDot.className = 'indicator-dot active';
                systemStatusText.textContent = 'All services operational';
            } else if (micServiceConnected || audioServiceConnected) {
                systemStatusDot.className = 'indicator-dot';
                systemStatusText.textContent = 'Partial service availability';
            } else {
                systemStatusDot.className = 'indicator-dot error';
                systemStatusText.textContent = 'Service connection issues';
            }
        }

        showNotification(message, type = 'info') {
            // Create notification element
            const notification = document.createElement('div');
            notification.className = `notification ${type}`;
            notification.textContent = message;

            // Style the notification
            notification.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                padding: 15px 20px;
                border-radius: 4px;
                color: white;
                font-weight: bold;
                z-index: 10000;
                max-width: 300px;
                word-wrap: break-word;
            `;

            switch (type) {
                case 'success':
                    notification.style.background = 'rgba(0, 255, 0, 0.8)';
                    notification.style.border = '1px solid #00ff00';
                    break;
                case 'error':
                    notification.style.background = 'rgba(255, 0, 0, 0.8)';
                    notification.style.border = '1px solid #ff0000';
                    break;
                case 'warning':
                    notification.style.background = 'rgba(255, 165, 0, 0.8)';
                    notification.style.border = '1px solid #ffa500';
                    break;
                default:
                    notification.style.background = 'rgba(0, 0, 255, 0.8)';
                    notification.style.border = '1px solid #0000ff';
            }

            document.body.appendChild(notification);

            // Remove after 5 seconds
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.parentNode.removeChild(notification);
                }
            }, 5000);
        }















        // Microphone card action methods

        async editMicrophone(microphoneId) {
            window.location.href = `/parts/microphone/${microphoneId}/edit`;
        }

        async monitorMicrophone(microphoneId) {
            try {
                const response = await axios.post(`/parts/api/microphone/${microphoneId}/start-monitoring`);

                if (response.data.success) {
                    this.showNotification(`Started monitoring microphone ${microphoneId}`, 'success');
                    this.switchTab('monitoring');
                } else {
                    this.showNotification('Failed to start monitoring', 'error');
                }
            } catch (error) {
                console.error('Error starting monitoring:', error);
                this.showNotification('Error starting monitoring', 'error');
            }
        }

        async deleteMicrophone(microphoneId) {
            if (!confirm('Are you sure you want to delete this microphone?')) {
                return;
            }

            try {
                const response = await axios.delete(`/parts/microphone/${microphoneId}`);

                if (response.status === 200) {
                    this.showNotification('Microphone deleted successfully', 'success');
                    await this.refreshMicrophonesList();
                } else {
                    this.showNotification('Failed to delete microphone', 'error');
                }
            } catch (error) {
                console.error('Error deleting microphone:', error);
                this.showNotification('Error deleting microphone', 'error');
            }
        }

        // Additional utility methods
        filterMicrophones(searchTerm) {
            const cards = document.querySelectorAll('.microphone-card');
            cards.forEach(card => {
                const name = card.querySelector('h5').textContent.toLowerCase();
                const device = card.querySelector('.info-value').textContent.toLowerCase();
                const matches = name.includes(searchTerm.toLowerCase()) ||
                               device.includes(searchTerm.toLowerCase());
                card.style.display = matches ? 'block' : 'none';
            });
        }

        filterByStatus(status) {
            const cards = document.querySelectorAll('.microphone-card');
            cards.forEach(card => {
                const statusBadge = card.querySelector('.status-badge');
                const cardStatus = statusBadge.dataset.status;
                const matches = !status || cardStatus === status;
                card.style.display = matches ? 'block' : 'none';
            });
        }

        updateOverviewMetrics() {
            const totalMics = document.querySelectorAll('.microphone-card').length;
            const activeMics = document.querySelectorAll('.status-badge[data-status="active"]').length;

            document.getElementById('totalMicrophones').textContent = totalMics;
            document.getElementById('activeMicrophones').textContent = activeMics;
        }

        updateMicrophoneStatus(microphoneId, status) {
            const card = document.querySelector(`[data-id="${microphoneId}"]`);
            if (card) {
                const statusBadge = card.querySelector('.status-badge');
                statusBadge.dataset.status = status;
                statusBadge.textContent = status.charAt(0).toUpperCase() + status.slice(1);
            }
        }

        updateAudioLevel(microphoneId, level) {
            const levelBar = document.querySelector(`.level-bar-mini[data-id="${microphoneId}"]`);
            if (levelBar) {
                levelBar.style.width = Math.min(level, 100) + '%';
            }

            // Update system audio level
            const systemLevel = document.getElementById('systemAudioLevel');
            const systemValue = document.getElementById('systemAudioValue');
            if (systemLevel && systemValue) {
                systemLevel.style.width = Math.min(level, 100) + '%';
                systemValue.textContent = Math.round(level) + '%';
            }
        }

        updateAvailableDevices(devices) {
            document.getElementById('availableDevices').textContent = devices.length;
            this.updateDeviceSelect(devices);
        }



        // Bulk operations
        selectAllMicrophones() {
            const checkboxes = document.querySelectorAll('.microphone-select');
            checkboxes.forEach(checkbox => {
                checkbox.checked = true;
                this.selectedMicrophones.add(checkbox.dataset.id);
            });
            this.updateBulkOperationsUI();
        }

        selectNoMicrophones() {
            const checkboxes = document.querySelectorAll('.microphone-select');
            checkboxes.forEach(checkbox => {
                checkbox.checked = false;
            });
            this.selectedMicrophones.clear();
            this.updateBulkOperationsUI();
        }

        updateBulkOperationsUI() {
            const count = this.selectedMicrophones.size;
            document.getElementById('selectedCount').textContent = count;

            const bulkButtons = ['bulkDelete', 'bulkExport'];
            bulkButtons.forEach(buttonId => {
                document.getElementById(buttonId).disabled = count === 0;
            });
        }

        async bulkDeleteMicrophones() {
            if (this.selectedMicrophones.size === 0) return;

            if (!confirm(`Delete ${this.selectedMicrophones.size} selected microphones?`)) {
                return;
            }

            const promises = Array.from(this.selectedMicrophones).map(id =>
                axios.delete(`/parts/microphone/${id}`)
            );

            try {
                await Promise.all(promises);
                this.showNotification('Selected microphones deleted', 'success');
                this.selectedMicrophones.clear();
                await this.refreshMicrophonesList();
            } catch (error) {
                this.showNotification('Error deleting microphones', 'error');
            }
        }



        async bulkExportMicrophones() {
            if (this.selectedMicrophones.size === 0) return;

            try {
                const response = await axios.get('/parts/api/parts');
                const microphones = response.data.filter(part =>
                    part.type === 'microphone' && this.selectedMicrophones.has(part.id.toString())
                );

                const exportData = {
                    exportDate: new Date().toISOString(),
                    microphoneCount: microphones.length,
                    microphones: microphones
                };

                const blob = new Blob([JSON.stringify(exportData, null, 2)],
                    { type: 'application/json' });
                const url = URL.createObjectURL(blob);

                const a = document.createElement('a');
                a.href = url;
                a.download = `microphones-export-${new Date().toISOString().split('T')[0]}.json`;
                a.click();

                URL.revokeObjectURL(url);
                this.showNotification('Microphones exported successfully', 'success');
            } catch (error) {
                this.showNotification('Error exporting microphones', 'error');
            }
        }

        async exportConfiguration() {
            try {
                const response = await axios.get('/parts/api/parts');
                const microphones = response.data.filter(part => part.type === 'microphone');

                const config = {
                    exportDate: new Date().toISOString(),
                    version: '1.0',
                    microphoneCount: microphones.length,
                    microphones: microphones,
                    systemConfiguration: {
                        defaultSampleRate: 16000,
                        defaultChannels: 1,
                        audioProcessing: {
                            echoCancellation: true,
                            noiseSuppression: true,
                            autoGainControl: true
                        }
                    }
                };

                const blob = new Blob([JSON.stringify(config, null, 2)],
                    { type: 'application/json' });
                const url = URL.createObjectURL(blob);

                const a = document.createElement('a');
                a.href = url;
                a.download = `monsterbox-microphone-config-${new Date().toISOString().split('T')[0]}.json`;
                a.click();

                URL.revokeObjectURL(url);
                this.showNotification('Configuration exported successfully', 'success');
            } catch (error) {
                this.showNotification('Error exporting configuration', 'error');
            }
        }



