        async bulkDeleteMicrophones() {
            if (this.selectedMicrophones.size === 0) return;

            if (!confirm(`Delete ${this.selectedMicrophones.size} selected microphones?`)) {
                return;
            }

            const promises = Array.from(this.selectedMicrophones).map(id =>
                axios.delete(`/parts/microphone/${id}`)
            );

            try {
                await Promise.all(promises);
                this.showNotification('Selected microphones deleted', 'success');
                this.selectedMicrophones.clear();
                await this.refreshMicrophonesList();
            } catch (error) {
                this.showNotification('Error deleting microphones', 'error');
            }
        }

        async bulkTestMicrophones() {
            if (this.selectedMicrophones.size === 0) return;

            this.showNotification(`Testing ${this.selectedMicrophones.size} microphones...`, 'info');

            const promises = Array.from(this.selectedMicrophones).map(id =>
                axios.post(`/parts/api/microphone/${id}/test`, { testType: 'basic', duration: 3 })
            );

            try {
                const results = await Promise.all(promises);
                const successCount = results.filter(r => r.data.success).length;
                this.showNotification(`${successCount}/${results.length} tests passed`, 'success');
            } catch (error) {
                this.showNotification('Error running bulk tests', 'error');
            }
        }

        async bulkExportMicrophones() {
            if (this.selectedMicrophones.size === 0) return;

            try {
                const response = await axios.get('/parts/api/parts');
                const microphones = response.data.filter(part =>
                    part.type === 'microphone' && this.selectedMicrophones.has(part.id.toString())
                );

                const exportData = {
                    exportDate: new Date().toISOString(),
                    microphoneCount: microphones.length,
                    microphones: microphones
                };

                const blob = new Blob([JSON.stringify(exportData, null, 2)],
                    { type: 'application/json' });
                const url = URL.createObjectURL(blob);

                const a = document.createElement('a');
                a.href = url;
                a.download = `microphones-export-${new Date().toISOString().split('T')[0]}.json`;
                a.click();

                URL.revokeObjectURL(url);
                this.showNotification('Microphones exported successfully', 'success');
            } catch (error) {
                this.showNotification('Error exporting microphones', 'error');
            }
        }

        async exportConfiguration() {
            try {
                const response = await axios.get('/parts/api/parts');
                const microphones = response.data.filter(part => part.type === 'microphone');

                const config = {
                    exportDate: new Date().toISOString(),
                    version: '1.0',
                    microphoneCount: microphones.length,
                    microphones: microphones,
                    systemConfiguration: {
                        defaultSampleRate: 16000,
                        defaultChannels: 1,
                        audioProcessing: {
                            echoCancellation: true,
                            noiseSuppression: true,
                            autoGainControl: true
                        }
                    }
                };

                const blob = new Blob([JSON.stringify(config, null, 2)],
                    { type: 'application/json' });
                const url = URL.createObjectURL(blob);

                const a = document.createElement('a');
                a.href = url;
                a.download = `monsterbox-microphone-config-${new Date().toISOString().split('T')[0]}.json`;
                a.click();

                URL.revokeObjectURL(url);
                this.showNotification('Configuration exported successfully', 'success');
            } catch (error) {
                this.showNotification('Error exporting configuration', 'error');
            }
        }

        async testAllMicrophones() {
            try {
                const response = await axios.get('/parts/api/parts');
                const microphones = response.data.filter(part => part.type === 'microphone');

                if (microphones.length === 0) {
                    this.showNotification('No microphones found to test', 'warning');
                    return;
                }

                this.showNotification(`Testing all ${microphones.length} microphones...`, 'info');

                const promises = microphones.map(mic =>
                    axios.post(`/parts/api/microphone/${mic.id}/test`, {
                        testType: 'basic',
                        duration: 3
                    })
                );

                const results = await Promise.all(promises);
                const successCount = results.filter(r => r.data.success).length;

                this.showNotification(
                    `Test completed: ${successCount}/${microphones.length} microphones passed`,
                    successCount === microphones.length ? 'success' : 'warning'
                );
            } catch (error) {
                this.showNotification('Error testing all microphones', 'error');
            }
        }

        updateAudioLevels() {
            // Update audio levels for all active microphones
            this.microphoneStatuses.forEach((status, microphoneId) => {
                if (status.status === 'monitoring') {
                    // Simulate audio level updates
                    const level = Math.random() * 100;
                    this.updateAudioLevel(microphoneId, level);
                }
            });
        }

        // Tab-specific loading methods
        async loadTestingInterface() {
            const container = document.getElementById('testResultsContainer');
            if (container.children.length === 0) {
                container.innerHTML = `
