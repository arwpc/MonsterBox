        }

        async loadMonitoringInterface() {
            const container = document.getElementById('monitoringContainer');
            container.innerHTML = `
                <div class="monitoring-interface">
                    <h5>👁️ Live Microphone Monitoring</h5>

                    <!-- System Status Overview -->
                    <div class="monitoring-status">
                        <div class="status-grid">
                            <div class="status-card">
                                <h6>🎤 Microphone Service</h6>
                                <div class="status-indicator" id="micServiceStatus">
                                    <span class="status-dot disconnected"></span>
                                    <span class="status-text">Disconnected</span>
                                </div>
                                <div class="status-details" id="micServiceDetails">Port: 8776</div>
                            </div>
                            <div class="status-card">
                                <h6>🔊 Audio Stream Service</h6>
                                <div class="status-indicator" id="audioServiceStatus">
                                    <span class="status-dot disconnected"></span>
                                    <span class="status-text">Disconnected</span>
                                </div>
                                <div class="status-details" id="audioServiceDetails">Port: 8777</div>
                            </div>
                        </div>
                    </div>

                    <!-- Real-time Microphone Levels -->
                    <div class="microphone-levels">
                        <h6>📊 Real-time Audio Levels</h6>
