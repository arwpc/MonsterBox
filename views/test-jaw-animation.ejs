<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - MonsterBox</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 8px;
        }
        .status-running { background-color: #28a745; }
        .status-stopped { background-color: #dc3545; }
        .status-unknown { background-color: #6c757d; }
        
        .volume-meter {
            height: 20px;
            background-color: #e9ecef;
            border-radius: 10px;
            overflow: hidden;
            position: relative;
        }
        
        .volume-bar {
            height: 100%;
            background: linear-gradient(90deg, #28a745 0%, #ffc107 70%, #dc3545 100%);
            width: 0%;
            transition: width 0.1s ease;
        }
        
        .servo-position {
            font-family: 'Courier New', monospace;
            font-size: 1.2em;
            font-weight: bold;
        }
        
        .config-section {
            background-color: #f8f9fa;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
        }
        
        .performance-stats {
            font-size: 0.9em;
        }
        
        .log-output {
            background-color: #000;
            color: #00ff00;
            font-family: 'Courier New', monospace;
            font-size: 0.8em;
            height: 200px;
            overflow-y: auto;
            padding: 10px;
            border-radius: 4px;
        }
    </style>
</head>
<body>
    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <h1><i class="fas fa-robot"></i> <%= title %></h1>
                <p class="text-muted">Test and configure jaw animation for MonsterBox characters</p>
                <hr>
            </div>
        </div>
        
        <div class="row">
            <!-- Character Selection -->
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-user"></i> Character Selection</h5>
                    </div>
                    <div class="card-body">
                        <% if (characters && characters.length > 0) { %>
                            <div class="mb-3">
                                <label for="characterSelect" class="form-label">Select Character:</label>
                                <select class="form-select" id="characterSelect" onchange="selectCharacter()">
                                    <% characters.forEach(char => { %>
                                        <option value="<%= char.id %>" <%= char.id == selectedCharacterId ? 'selected' : '' %>>
                                            <%= char.char_name %>
                                        </option>
                                    <% }); %>
                                </select>
                            </div>
                            
                            <% if (servos && servos.length > 0) { %>
                                <div class="mb-3">
                                    <label for="servoSelect" class="form-label">Select Jaw Servo:</label>
                                    <select class="form-select" id="servoSelect">
                                        <% servos.forEach(servo => { %>
                                            <option value="<%= servo.id %>">
                                                <%= servo.name %> (Pin: <%= servo.pin %><%= servo.usePCA9685 ? ', Channel: ' + servo.channel : '' %>)
                                            </option>
                                        <% }); %>
                                    </select>
                                </div>
                            <% } else { %>
                                <div class="alert alert-warning">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    No servos found for this character. Please add a servo part first.
                                </div>
                            <% } %>
                        <% } else { %>
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i>
                                No characters found. Please create a character first.
                            </div>
                        <% } %>
                    </div>
                </div>
                
                <!-- Control Panel -->
                <div class="card mt-3">
                    <div class="card-header">
                        <h5><i class="fas fa-play-circle"></i> Control Panel</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <span class="status-indicator status-unknown" id="statusIndicator"></span>
                                <span id="statusText">Unknown</span>
                            </div>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button class="btn btn-success" id="startBtn" onclick="startAnimation()" disabled>
                                <i class="fas fa-play"></i> Start Animation
                            </button>
                            <button class="btn btn-danger" id="stopBtn" onclick="stopAnimation()" disabled>
                                <i class="fas fa-stop"></i> Stop Animation
                            </button>
                            <button class="btn btn-info" onclick="testServo()" disabled id="testBtn">
                                <i class="fas fa-cog"></i> Test Servo
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Real-time Monitoring -->
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-chart-line"></i> Real-time Monitoring</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Audio Volume:</label>
                            <div class="volume-meter">
                                <div class="volume-bar" id="volumeBar"></div>
                            </div>
                            <small class="text-muted">Raw: <span id="rawVolume">0.00</span> | Smoothed: <span id="smoothedVolume">0.00</span></small>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Servo Position:</label>
                            <div class="servo-position text-center" id="servoPosition">0°</div>
                            <div class="progress">
                                <div class="progress-bar" id="servoProgressBar" style="width: 0%"></div>
                            </div>
                        </div>
                        
                        <div class="performance-stats">
                            <h6>Performance:</h6>
                            <div class="row">
                                <div class="col-6">
                                    <small>Updates/sec: <span id="updatesPerSec">0</span></small>
                                </div>
                                <div class="col-6">
                                    <small>Latency: <span id="latency">0</span>ms</small>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <small>Memory: <span id="memoryUsage">0</span>MB</small>
                                </div>
                                <div class="col-6">
                                    <small>Clients: <span id="connectedClients">0</span></small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Log Output -->
                <div class="card mt-3">
                    <div class="card-header">
                        <h6><i class="fas fa-terminal"></i> System Log</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="log-output" id="logOutput">
                            System ready...<br>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Configuration -->
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-cogs"></i> Configuration</h5>
                    </div>
                    <div class="card-body">
                        <!-- Presets -->
                        <div class="config-section">
                            <h6>Presets:</h6>
                            <div class="d-grid gap-1">
                                <button class="btn btn-outline-primary btn-sm" onclick="applyPreset('skeleton')">Skeleton</button>
                                <button class="btn btn-outline-primary btn-sm" onclick="applyPreset('bear')">Bear</button>
                                <button class="btn btn-outline-primary btn-sm" onclick="applyPreset('fish')">Fish</button>
                                <button class="btn btn-outline-primary btn-sm" onclick="applyPreset('demon')">Demon</button>
                            </div>
                        </div>
                        
                        <!-- Audio Settings -->
                        <div class="config-section">
                            <h6>Audio Analysis:</h6>
                            <div class="mb-2">
                                <label class="form-label form-label-sm">Volume Threshold:</label>
                                <input type="range" class="form-range" id="volumeThreshold" min="0" max="0.1" step="0.001" value="0.01" onchange="updateConfig()">
                                <small class="text-muted"><span id="volumeThresholdValue">0.01</span></small>
                            </div>
                            <div class="mb-2">
                                <label class="form-label form-label-sm">Smoothing:</label>
                                <input type="range" class="form-range" id="smoothingFactor" min="0" max="1" step="0.1" value="0.8" onchange="updateConfig()">
                                <small class="text-muted"><span id="smoothingFactorValue">0.8</span></small>
                            </div>
                        </div>
                        
                        <!-- Servo Settings -->
                        <div class="config-section">
                            <h6>Servo Mapping:</h6>
                            <div class="mb-2">
                                <label class="form-label form-label-sm">Min Position:</label>
                                <input type="number" class="form-control form-control-sm" id="minPosition" value="0" min="0" max="180" onchange="updateConfig()">
                            </div>
                            <div class="mb-2">
                                <label class="form-label form-label-sm">Max Position:</label>
                                <input type="number" class="form-control form-control-sm" id="maxPosition" value="180" min="0" max="180" onchange="updateConfig()">
                            </div>
                            <div class="mb-2">
                                <label class="form-label form-label-sm">Sensitivity:</label>
                                <input type="range" class="form-range" id="sensitivity" min="0.1" max="3" step="0.1" value="1.0" onchange="updateConfig()">
                                <small class="text-muted"><span id="sensitivityValue">1.0</span></small>
                            </div>
                            <div class="mb-2">
                                <label class="form-label form-label-sm">Response Curve:</label>
                                <select class="form-select form-select-sm" id="responseCurve" onchange="updateConfig()">
                                    <option value="linear">Linear</option>
                                    <option value="exponential">Exponential</option>
                                    <option value="logarithmic">Logarithmic</option>
                                    <option value="custom">Custom</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let jawWebSocket = null;
        let currentCharacterId = <%= selectedCharacterId || 'null' %>;
        let currentServoId = null;
        let isAnimationRunning = false;
        
        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            initializeWebSocket();
            updateStatus();
            loadConfiguration();
            
            // Enable controls if we have character and servo
            if (currentCharacterId && document.getElementById('servoSelect')) {
                enableControls();
            }
        });
        
        // WebSocket connection
        function initializeWebSocket() {
            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const wsUrl = `${protocol}//${window.location.host}/jaw-animation`;
            
            jawWebSocket = new WebSocket(wsUrl);
            
            jawWebSocket.onopen = function() {
                addLog('WebSocket connected');
                
                // Subscribe to events
                jawWebSocket.send(JSON.stringify({
                    type: 'subscribe',
                    events: ['volumeUpdate', 'servoPosition', 'animationStarted', 'animationStopped']
                }));
                
                if (currentCharacterId) {
                    jawWebSocket.send(JSON.stringify({
                        type: 'setCharacter',
                        characterId: currentCharacterId
                    }));
                }
            };
            
            jawWebSocket.onmessage = function(event) {
                const data = JSON.parse(event.data);
                handleWebSocketMessage(data);
            };
            
            jawWebSocket.onclose = function() {
                addLog('WebSocket disconnected');
                setTimeout(initializeWebSocket, 5000); // Reconnect after 5 seconds
            };
            
            jawWebSocket.onerror = function(error) {
                addLog('WebSocket error: ' + error);
            };
        }
        
        // Handle WebSocket messages
        function handleWebSocketMessage(data) {
            switch (data.type) {
                case 'volumeUpdate':
                    updateVolumeDisplay(data.volume);
                    updateServoDisplay(data.servoPosition);
                    break;
                    
                case 'servoPosition':
                    updateServoDisplay(data.position);
                    break;
                    
                case 'animationStarted':
                    isAnimationRunning = true;
                    updateControlButtons();
                    addLog(`Animation started for character ${data.characterId}`);
                    break;
                    
                case 'animationStopped':
                    isAnimationRunning = false;
                    updateControlButtons();
                    addLog(`Animation stopped for character ${data.characterId}`);
                    break;
            }
        }
        
        // Character selection
        function selectCharacter() {
            const characterId = document.getElementById('characterSelect').value;
            window.location.href = `/test/jaw-animation?characterId=${characterId}`;
        }
        
        // Animation controls
        async function startAnimation() {
            const characterId = document.getElementById('characterSelect').value;
            const servoId = document.getElementById('servoSelect').value;
            
            if (!characterId || !servoId) {
                alert('Please select both character and servo');
                return;
            }
            
            try {
                const response = await fetch('/jaw-animation/start', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ characterId, servoId })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    addLog('Animation started successfully');
                    isAnimationRunning = true;
                    updateControlButtons();
                } else {
                    addLog('Failed to start animation: ' + result.message);
                    alert('Failed to start animation: ' + result.message);
                }
            } catch (error) {
                addLog('Error starting animation: ' + error.message);
                alert('Error starting animation: ' + error.message);
            }
        }
        
        async function stopAnimation() {
            try {
                const response = await fetch('/jaw-animation/stop', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    addLog('Animation stopped successfully');
                    isAnimationRunning = false;
                    updateControlButtons();
                } else {
                    addLog('Failed to stop animation: ' + result.message);
                    alert('Failed to stop animation: ' + result.message);
                }
            } catch (error) {
                addLog('Error stopping animation: ' + error.message);
                alert('Error stopping animation: ' + error.message);
            }
        }
        
        async function testServo() {
            const characterId = document.getElementById('characterSelect').value;
            const servoId = document.getElementById('servoSelect').value;
            
            if (!characterId || !servoId) {
                alert('Please select both character and servo');
                return;
            }
            
            try {
                const response = await fetch('/jaw-animation/test-servo', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ characterId, servoId })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    addLog('Servo test completed successfully');
                } else {
                    addLog('Servo test failed: ' + result.message);
                    alert('Servo test failed: ' + result.message);
                }
            } catch (error) {
                addLog('Error testing servo: ' + error.message);
                alert('Error testing servo: ' + error.message);
            }
        }
        
        // Configuration functions
        async function loadConfiguration() {
            if (!currentCharacterId) return;
            
            try {
                const response = await fetch(`/jaw-animation/config/${currentCharacterId}`);
                const result = await response.json();
                
                if (result.success) {
                    populateConfigurationForm(result.config);
                }
            } catch (error) {
                addLog('Error loading configuration: ' + error.message);
            }
        }
        
        function populateConfigurationForm(config) {
            // Audio settings
            if (config.audioAnalysis) {
                document.getElementById('volumeThreshold').value = config.audioAnalysis.volumeThreshold || 0.01;
                document.getElementById('smoothingFactor').value = config.audioAnalysis.smoothingFactor || 0.8;
                updateSliderValues();
            }
            
            // Servo settings
            if (config.servoMapping) {
                document.getElementById('minPosition').value = config.servoMapping.minPosition || 0;
                document.getElementById('maxPosition').value = config.servoMapping.maxPosition || 180;
                document.getElementById('sensitivity').value = config.servoMapping.sensitivity || 1.0;
                document.getElementById('responseCurve').value = config.servoMapping.responseCurve || 'linear';
                updateSliderValues();
            }
        }
        
        async function updateConfig() {
            if (!currentCharacterId) return;
            
            const config = {
                audioAnalysis: {
                    volumeThreshold: parseFloat(document.getElementById('volumeThreshold').value),
                    smoothingFactor: parseFloat(document.getElementById('smoothingFactor').value)
                },
                servoMapping: {
                    minPosition: parseInt(document.getElementById('minPosition').value),
                    maxPosition: parseInt(document.getElementById('maxPosition').value),
                    sensitivity: parseFloat(document.getElementById('sensitivity').value),
                    responseCurve: document.getElementById('responseCurve').value
                }
            };
            
            updateSliderValues();
            
            try {
                const response = await fetch(`/jaw-animation/config/${currentCharacterId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    addLog('Configuration updated');
                } else {
                    addLog('Failed to update configuration: ' + result.message);
                }
            } catch (error) {
                addLog('Error updating configuration: ' + error.message);
            }
        }
        
        async function applyPreset(presetName) {
            if (!currentCharacterId) return;
            
            try {
                const response = await fetch(`/jaw-animation/preset/${currentCharacterId}/${presetName}`, {
                    method: 'POST'
                });
                
                const result = await response.json();
                
                if (result.success) {
                    addLog(`Applied ${presetName} preset`);
                    loadConfiguration(); // Reload configuration
                } else {
                    addLog('Failed to apply preset: ' + result.message);
                }
            } catch (error) {
                addLog('Error applying preset: ' + error.message);
            }
        }
        
        // UI update functions
        function updateVolumeDisplay(volume) {
            const volumeBar = document.getElementById('volumeBar');
            const percentage = Math.min(volume * 100, 100);
            volumeBar.style.width = percentage + '%';
            
            document.getElementById('smoothedVolume').textContent = volume.toFixed(3);
        }
        
        function updateServoDisplay(position) {
            document.getElementById('servoPosition').textContent = position + '°';
            
            const progressBar = document.getElementById('servoProgressBar');
            const percentage = (position / 180) * 100;
            progressBar.style.width = percentage + '%';
        }
        
        function updateControlButtons() {
            const startBtn = document.getElementById('startBtn');
            const stopBtn = document.getElementById('stopBtn');
            const testBtn = document.getElementById('testBtn');
            
            startBtn.disabled = isAnimationRunning;
            stopBtn.disabled = !isAnimationRunning;
            testBtn.disabled = isAnimationRunning;
            
            // Update status indicator
            const statusIndicator = document.getElementById('statusIndicator');
            const statusText = document.getElementById('statusText');
            
            if (isAnimationRunning) {
                statusIndicator.className = 'status-indicator status-running';
                statusText.textContent = 'Running';
            } else {
                statusIndicator.className = 'status-indicator status-stopped';
                statusText.textContent = 'Stopped';
            }
        }
        
        function updateSliderValues() {
            document.getElementById('volumeThresholdValue').textContent = document.getElementById('volumeThreshold').value;
            document.getElementById('smoothingFactorValue').textContent = document.getElementById('smoothingFactor').value;
            document.getElementById('sensitivityValue').textContent = document.getElementById('sensitivity').value;
        }
        
        function enableControls() {
            document.getElementById('startBtn').disabled = false;
            document.getElementById('testBtn').disabled = false;
        }
        
        async function updateStatus() {
            try {
                const response = await fetch('/jaw-animation/status');
                const result = await response.json();
                
                if (result.success && result.status) {
                    isAnimationRunning = result.status.isRunning;
                    updateControlButtons();
                    
                    // Update performance stats
                    if (result.status.performanceStats) {
                        const stats = result.status.performanceStats;
                        document.getElementById('updatesPerSec').textContent = stats.updatesPerSecond.toFixed(1);
                        document.getElementById('latency').textContent = stats.averageLatency.toFixed(1);
                        document.getElementById('memoryUsage').textContent = stats.memoryUsage.toFixed(1);
                    }
                    
                    document.getElementById('connectedClients').textContent = result.status.connectedClients || 0;
                }
            } catch (error) {
                // Silently fail - system might not be initialized yet
            }
            
            // Update status every 5 seconds
            setTimeout(updateStatus, 5000);
        }
        
        function addLog(message) {
            const logOutput = document.getElementById('logOutput');
            const timestamp = new Date().toLocaleTimeString();
            logOutput.innerHTML += `[${timestamp}] ${message}<br>`;
            logOutput.scrollTop = logOutput.scrollHeight;
        }
    </script>
</body>
</html>
