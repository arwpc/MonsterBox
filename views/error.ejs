<div class="container" style="max-width: 640px; padding: var(--mb-space-9) var(--mb-space-4);">
  <div class="mb-panel mb-panel-accent-danger">
    <div class="mb-panel-body mb-empty" style="padding: var(--mb-space-9) var(--mb-space-5);">
      <i class="bi bi-exclamation-octagon-fill mb-empty-icon" style="color: var(--mb-danger); font-size: var(--mb-text-4xl);"></i>
      <h1 class="mb-heading mb-heading-2" style="margin: 0;"><%= error || 'An Error Occurred' %></h1>
      <p class="mb-empty-body" style="max-width: 50ch;">
        <%= message || 'Something went wrong. Please try again or contact support if the problem persists.' %>
      </p>
      <div class="mb-row" style="justify-content:center;">
        <button class="mb-btn mb-btn-secondary" onclick="history.back()">
          <i class="bi bi-arrow-left"></i> Go Back
        </button>
        <a href="/" class="mb-btn mb-btn-primary">
          <i class="bi bi-house"></i> Dashboard
        </a>
      </div>
    </div>
  </div>
</div>
