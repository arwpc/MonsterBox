<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'MonsterBox Control Panel' %></title>

    <!-- Google Fonts -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&family=Creepster&display=swap" as="style">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&family=Creepster&display=swap">

    <!-- Original MonsterBox CSS -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>

<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1 class="landing-title" style="text-align: center; margin: 20px 0;">
                🎭 MONSTERBOX
            </h1>
            <p style="text-align: center; margin-bottom: 30px;">
                System - Choose a character and navigate to get started.
            </p>
        </div>

        <!-- Character Selection -->
        <% if (characters && characters.length > 0) { %>
        <div class="form-group">
            <label for="character-select">Select Character:</label>
            <select id="character-select" onchange="updateCharacter(this.value)">
                <option value="">Choose a character...</option>
                <% characters.forEach(function(character) { %>
                <option value="<%= character.id %>"><%= character.char_name || character.name %></option>
                <% }); %>
            </select>
        </div>
        <% } %>

        <!-- Navigation Grid -->
        <div class="nav-grid">
            <!-- Character Management -->
            <div class="nav-section">
                <h3 class="font-creepster">🎭 Character Management</h3>
                <p>Create, edit, and manage your animatronic characters.</p>
                <div class="button-group">
                    <a href="/characters" class="button">Manage Characters</a>
                    <a href="/character-parts" class="button">Character Parts</a>
                </div>
            </div>

            <!-- Hardware Control -->
            <div class="nav-section">
                <h3 class="font-creepster">🔧 Hardware Control</h3>
                <p>Monitor and control your hardware components.</p>
                <div class="button-group">
                    <a href="/parts" class="button">Hardware Parts</a>
                </div>
            </div>

            <!-- AI Systems -->
            <div class="nav-section">
                <h3 class="font-creepster">🧠 AI Systems</h3>
                <p>Configure and manage AI-powered interactions.</p>
                <div class="button-group">
                    <a href="/chatterpi-chat.html" class="button">ChatterPi AI</a>
                    <a href="/ai-management" class="button">AI Management</a>
                </div>
            </div>

            <!-- Media & Content -->
            <div class="nav-section">
                <h3 class="font-creepster">🎬 Media & Content</h3>
                <p>Manage sounds, videos, and scenes for your shows.</p>
                <div class="button-group">
                    <a href="/sounds" class="button">Sounds</a>
                    <a href="/Camera" class="button">Video</a>
                    <a href="/scenes" class="button">Scenes</a>
                </div>
            </div>

            <!-- System Control -->
            <div class="nav-section">
                <h3 class="font-creepster">⚡ System Control</h3>
                <p>Live performance control and system monitoring.</p>
                <div class="button-group">
                    <a href="/active-mode" class="button">Active Mode</a>
                </div>
            </div>

            <!-- Configuration -->
            <div class="nav-section">
                <h3 class="font-creepster">⚙️ Configuration</h3>
                <p>System settings and personalization options.</p>
                <div class="button-group">
                    <a href="/configuration" class="button">Configuration</a>
                </div>
            </div>
        </div>

        <!-- System Status -->
        <div class="status-section">
            <h3 class="font-creepster">📊 System Status</h3>
            <div class="status-grid">
                <div class="status-item">
                    <strong>Characters:</strong> <%= characters ? characters.length : 0 %>
                </div>
                <div class="status-item">
                    <strong>System:</strong> Online
                </div>
                <div class="status-item">
                    <strong>Theme:</strong> MonsterBox
                </div>
            </div>
        </div>
    </div>

    <script>
        // Character selection management
        function updateCharacter(characterId) {
            localStorage.setItem('selectedCharacter', characterId);

            fetch('/set-character', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ characterId: characterId }),
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    console.log('Character updated successfully');
                } else {
                    console.error('Failed to update character');
                }
            })
            .catch((error) => {
                console.error('Error:', error);
            });
        }

        // Initialize character selection on page load
        document.addEventListener('DOMContentLoaded', function() {
            const savedCharacter = localStorage.getItem('selectedCharacter');
            if (savedCharacter) {
                const characterSelect = document.getElementById('character-select');
                if (characterSelect) {
                    characterSelect.value = savedCharacter;
                }
            }
        });
    </script>
</body>
</html>