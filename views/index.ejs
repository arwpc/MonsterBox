<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MonsterBox 4.0 Dashboard</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-robot"></i>
                MonsterBox 4.0
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">
                            <i class="bi bi-house"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-gear"></i> Setup
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/setup/parts">
                                    <i class="bi bi-cpu"></i> Parts
                                </a></li>
                            <li><a class="dropdown-item" href="/setup/calibration">
                                    <i class="bi bi-sliders"></i> Calibration
                                </a></li>
                            <li><a class="dropdown-item" href="/setup/poses">
                                    <i class="bi bi-person-arms-up"></i> Poses
                                </a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/audio">
                                    <i class="bi bi-volume-up"></i> Audio
                                </a></li>
                            <li><a class="dropdown-item" href="/setup/webcam">
                                    <i class="bi bi-camera-video"></i> Webcam
                                </a></li>
                            <li><a class="dropdown-item" href="/ai-settings">
                                    <i class="bi bi-robot"></i> AI Settings
                                </a></li>
                            <li><a class="dropdown-item" href="/setup/super-powers">
                                    <i class="bi bi-lightning"></i> Super Powers
                                </a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/system">
                                    <i class="bi bi-pc-display"></i> System
                                </a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/live">
                            <i class="bi bi-play-circle"></i> Live Mode
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/audio-library">
                            <i class="bi bi-music-note-list"></i> Audio Library
                        </a>
                    </li>
                </ul>
                <%- include('partials/characterMenu') %>

            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1><i class="bi bi-robot"></i> MonsterBox 4.0 Dashboard</h1>
                    <div class="badge bg-primary fs-6">Single Node Design</div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Quick Actions -->
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-lightning-charge"></i> Quick Actions
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="d-grid">
                                    <a href="/live" class="btn btn-success btn-lg">
                                        <i class="bi bi-play-circle"></i>
                                        Enter Live Mode
                                    </a>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-grid">
                                    <a href="/setup/poses" class="btn btn-warning btn-lg">
                                        <i class="bi bi-person-arms-up"></i>
                                        Setup Poses
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- System Status -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-activity"></i> System Status
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span>Hardware Connection</span>
                            <span class="badge bg-success">Connected</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span>Poses Available</span>
                            <span class="badge bg-secondary" id="poses-count">Loading...</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Active Services</span>
                            <span class="badge bg-success">All Running</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-4">
            <!-- Quick Poses -->
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-person-arms-up"></i> Quick Poses
                        </h5>
                        <a href="/setup/poses" class="btn btn-sm btn-outline-primary">Manage</a>
                    </div>
                    <div class="card-body">
                        <div id="quick-poses">
                            <div class="text-center text-muted">
                                <div class="spinner-border spinner-border-sm" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2">Loading poses...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Setup Progress -->
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-list-check"></i> Setup Progress
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span>Parts Configuration</span>
                                <span class="badge bg-success">Complete</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-success" style="width: 100%"></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span>Poses Setup</span>
                                <span class="badge bg-info">Ready</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-info" style="width: 100%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="/js/monsterbox4.js"></script>

    <script>
        // Load poses count and quick poses
        document.addEventListener('DOMContentLoaded', function () {
            loadPosesData();
        });

        async function loadPosesData() {
            try {
                const response = await fetch('/poses');
                const data = await response.json();

                if (data.success) {
                    // Update poses count
                    document.getElementById('poses-count').textContent = data.poses.length;

                    // Show quick poses (first 5)
                    const quickPosesContainer = document.getElementById('quick-poses');
                    if (data.poses.length > 0) {
                        const quickPoses = data.poses.slice(0, 5);
                        quickPosesContainer.innerHTML = quickPoses.map(pose =>
                            `<div class="d-flex justify-content-between align-items-center mb-2">
                                <span>${pose.name}</span>
                                <button class="btn btn-sm btn-outline-primary" onclick="executePose(${pose.id})">
                                    <i class="bi bi-play"></i>
                                </button>
                            </div>`
                        ).join('');
                    } else {
                        quickPosesContainer.innerHTML =
                            `<div class="text-center text-muted">
                                <i class="bi bi-plus-circle fs-1"></i>
                                <p>No poses created yet</p>
                                <a href="/setup/poses" class="btn btn-sm btn-primary">Create First Pose</a>
                            </div>`;
                    }
                }
            } catch (error) {
                console.error('Failed to load poses:', error);
                document.getElementById('poses-count').textContent = 'Error';
            }
        }

        async function executePose(poseId) {
            try {
                const response = await fetch(`/poses/${poseId}/execute`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const result = await response.json();
                if (result.success) {
                    console.log('Pose executed successfully:', result.message);
                } else {
                    console.error('Pose execution failed:', result.error);
                }
            } catch (error) {
                console.error('Failed to execute pose:', error);
            }
        }
    </script>

    <script src="/js/character-menu.js"></script>

    async function executePose(poseId) {
    try {
    const response = await fetch(`/poses/${poseId}/execute`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
    });

    const result = await response.json();

    if (result.success) {
    console.log('Pose executed successfully:', result.message);
    } else {
    console.error('Pose execution failed:', result.error);
    }
    } catch (error) {
    console.error('Failed to execute pose:', error);
    }
    }
    </script>
</body>

</html>