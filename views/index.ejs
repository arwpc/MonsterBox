<!-- Dashboard Content -->
<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="bi bi-robot"></i> MonsterBox 4.0 Dashboard</h1>
            <div class="badge bg-primary fs-6">Single Node Design</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Quick Actions -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-lightning-charge"></i> Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="d-grid">
                            <a href="/live" class="btn btn-success btn-lg">
                                <i class="bi bi-play-circle"></i>
                                Enter Live Mode
                            </a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-grid">
                            <a href="/setup/poses" class="btn btn-warning btn-lg">
                                <i class="bi bi-person-arms-up"></i>
                                Setup Poses
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- System Status -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-activity"></i> System Status
                </h5>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span>Hardware Connection</span>
                    <span class="badge bg-success">Connected</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span>Poses Available</span>
                    <span class="badge bg-secondary" id="poses-count">Loading...</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span>Active Services</span>
                    <span class="badge bg-success">All Running</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-4">
    <!-- Quick Poses -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-arms-up"></i> Quick Poses
                </h5>
                <a href="/setup/poses" class="btn btn-sm btn-outline-primary">Manage</a>
            </div>
            <div class="card-body">
                <div id="quick-poses">
                    <div class="text-center text-muted">
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2">Loading poses...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Setup Progress -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-list-check"></i> Setup Progress
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span>Parts Configuration</span>
                        <span class="badge bg-success">Complete</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 100%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span>Poses Setup</span>
                        <span class="badge bg-info">Ready</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-info" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Load poses count and quick poses
    document.addEventListener('DOMContentLoaded', function () {
        loadPosesData();
    });

    async function loadPosesData() {
        try {
            const response = await fetch('/poses');
            const data = await response.json();

            if (data.success) {
                // Update poses count
                document.getElementById('poses-count').textContent = data.poses.length;

                // Show quick poses (first 5)
                const quickPosesContainer = document.getElementById('quick-poses');
                if (data.poses.length > 0) {
                    const quickPoses = data.poses.slice(0, 5);
                    quickPosesContainer.innerHTML = quickPoses.map(pose =>
                        `<div class="d-flex justify-content-between align-items-center mb-2">
                                <span>${pose.name}</span>
                                <button class="btn btn-sm btn-outline-primary" onclick="executePose(${pose.id})">
                                    <i class="bi bi-play"></i>
                                </button>
                            </div>`
                    ).join('');
                } else {
                    quickPosesContainer.innerHTML =
                        `<div class="text-center text-muted">
                                <i class="bi bi-plus-circle fs-1"></i>
                                <p>No poses created yet</p>
                                <a href="/setup/poses" class="btn btn-sm btn-primary">Create First Pose</a>
                            </div>`;
                }
            }
        } catch (error) {
            console.error('Failed to load poses:', error);
            document.getElementById('poses-count').textContent = 'Error';
        }
    }

    async function executePose(poseId) {
        try {
            const response = await fetch(`/poses/${poseId}/execute`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const result = await response.json();
            if (result.success) {
                console.log('Pose executed successfully:', result.message);
            } else {
                console.error('Pose execution failed:', result.error);
            }
        } catch (error) {
            console.error('Failed to execute pose:', error);
        }
    }
</script>

<script src="/js/character-menu.js"></script>
<script>
    (function () {
        if (typeof window.bootstrap === 'undefined') {
            document.addEventListener('click', function (e) {
                var t = e.target;
                // Collapse toggler fallback
                var u = t;
                while (u && u.nodeType === 1 && !(u.matches && u.matches('[data-bs-toggle="collapse"]'))) { u = u.parentNode; }
                if (u) {
                    var sel = u.getAttribute('data-bs-target');
                    if (sel) {
                        var el = document.querySelector(sel);
                        if (el) { e.preventDefault(); el.classList.toggle('show'); return; }
                    }
                }
                // Dropdown fallback
                var d = t;
                while (d && d.nodeType === 1 && !(d.matches && d.matches('[data-bs-toggle="dropdown"]'))) { d = d.parentNode; }
                if (d) {
                    e.preventDefault();
                    var menu = d.nextElementSibling;
                    if (menu && menu.classList) { menu.classList.toggle('show'); }
                }
            }, true);
        }
    })();
</script>