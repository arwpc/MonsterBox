<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Logs - MonsterBox</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .logs-dashboard {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }

        .log-entry {
            font-family: 'Courier New', monospace;
            font-size: 0.85em;
            border-left: 3px solid #00ff00;
            margin-bottom: 5px;
            padding: 8px;
            background: #001100;
            color: #cccccc;
            border-radius: 4px;
        }
        .log-entry.error { border-left-color: #ff0040; background-color: #330000; }
        .log-entry.warn { border-left-color: #ff6600; background-color: #331100; }
        .log-entry.info { border-left-color: #00ffff; background-color: #001133; }
        .log-entry.debug { border-left-color: #666666; background-color: #111111; }

        .service-status.healthy { color: #00ff00; }
        .service-status.unhealthy { color: #ff0040; }
        .service-status.unknown { color: #666666; }

        .metrics-card {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
            transition: all 0.3s ease;
            text-align: center;
        }
        .metrics-card:hover {
            border-color: #66ff66;
            box-shadow: 0 4px 12px rgba(0, 255, 0, 0.2);
        }

        #logStream {
            height: 400px;
            overflow-y: auto;
            background: #000800;
            border: 2px solid #00ff00;
            border-radius: 8px;
            padding: 10px;
        }

        .config-section {
            background: #001100;
            border: 2px solid #00ff00;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .metric-value {
            font-size: 2em;
            color: #00ff00;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .metric-label {
            color: #cccccc;
            font-size: 0.9em;
        }

        /* Breadcrumb Navigation Styling */
        .breadcrumb-vertical {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 12px;
          margin-bottom: 20px;
          font-size: 1.1em;
        }

        .breadcrumb-item {
          color: #00ffff;
          text-decoration: none;
          transition: all 0.3s ease;
        }

        .breadcrumb-item:hover {
          color: #ffffff;
          text-shadow: 0 0 5px #00ffff;
        }

        .breadcrumb-item.active {
          color: #00ff00;
          font-weight: bold;
        }

        .breadcrumb-item:not(.active):after {
          content: ' → ';
          color: #666666;
          margin-left: 8px;
        }
    </style>
</head>
<body>
    <header>
        <h1>📊 AI System Logs</h1>
        <div class="breadcrumb-vertical">
            <a href="/" class="breadcrumb-item">🏠 Home</a>
            <a href="/ai-management" class="breadcrumb-item">🤖 AI Management</a>
            <span class="breadcrumb-item active">📊 AI Logs</span>
        </div>
    </header>

    <main class="logs-dashboard">
        <div class="info-section">
            <h2>📊 AI System Log Collection</h2>
            <p>Monitor and analyze AI system activity, errors, and performance metrics in real-time</p>

            <div class="button-group" style="margin: 20px 0;">
                <button class="button primary-btn" id="startCollection">
                    <i class="fas fa-play"></i> Start Collection
                </button>
                <button class="button secondary-btn" id="pauseCollection">
                    <i class="fas fa-pause"></i> Pause
                </button>
                <button class="button danger-btn" id="stopCollection">
                    <i class="fas fa-stop"></i> Stop
                </button>
                <button class="button" id="refreshStatus">
                    <i class="fas fa-sync"></i> Refresh
                </button>
            </div>
        </div>

        <!-- Service Status Overview -->
        <div class="metrics-grid">
            <div class="metrics-card">
                <div class="metric-label">Collection Status</div>
                <div class="metric-value" id="collectionStatus">
                    <i class="fas fa-question-circle"></i> Unknown
                </div>
            </div>
            <div class="metrics-card">
                <div class="metric-label">Active Devices</div>
                <div class="metric-value" id="activeDevices">
                    <i class="fas fa-server"></i> <span>0</span>
                </div>
            </div>
            <div class="metrics-card">
                <div class="metric-label">Logs/Minute</div>
                <div class="metric-value" id="logsPerMinute">
                    <i class="fas fa-tachometer-alt"></i> <span>0</span>
                </div>
            </div>
            <div class="metrics-card">
                <div class="metric-label">Storage Used</div>
                <div class="metric-value" id="storageUsed">
                    <i class="fas fa-hdd"></i> <span>0 MB</span>
                </div>
            </div>
        </div>

        <!-- Log Filters -->
        <div class="config-section">
            <h3><i class="fas fa-filter"></i> Log Filters</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin: 15px 0;">
                <div>
                    <label style="color: #00ff00; display: block; margin-bottom: 5px;">Device</label>
                    <select id="filterDevice" style="width: 100%; padding: 8px; background: #000800; border: 1px solid #00ff00; color: #cccccc; border-radius: 4px;">
                        <option value="">All Devices</option>
                    </select>
                </div>
                <div>
                    <label style="color: #00ff00; display: block; margin-bottom: 5px;">Service</label>
                    <select id="filterService" style="width: 100%; padding: 8px; background: #000800; border: 1px solid #00ff00; color: #cccccc; border-radius: 4px;">
                        <option value="">All Services</option>
                        <option value="ai">AI Bridge</option>
                        <option value="stt">Speech-to-Text</option>
                        <option value="tts">Text-to-Speech</option>
                        <option value="main">Main Service</option>
                    </select>
                </div>
                <div>
                    <label style="color: #00ff00; display: block; margin-bottom: 5px;">Level</label>
                    <select id="filterLevel" style="width: 100%; padding: 8px; background: #000800; border: 1px solid #00ff00; color: #cccccc; border-radius: 4px;">
                        <option value="">All Levels</option>
                        <option value="error">Error</option>
                        <option value="warn">Warning</option>
                        <option value="info">Info</option>
                        <option value="debug">Debug</option>
                    </select>
                </div>
                <div>
                    <label style="color: #00ff00; display: block; margin-bottom: 5px;">Search</label>
                    <input type="text" id="filterText" placeholder="Search text..." style="width: 100%; padding: 8px; background: #000800; border: 1px solid #00ff00; color: #cccccc; border-radius: 4px;">
                </div>
            </div>
        </div>

        <!-- Live Log Stream -->
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin: 20px 0;">
            <div class="config-section">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <h3><i class="fas fa-stream"></i> Live Log Stream</h3>
                    <div class="button-group">
                        <button class="button small-btn" id="pauseStream">
                            <i class="fas fa-pause"></i> Pause
                        </button>
                        <button class="button small-btn secondary-btn" id="clearStream">
                            <i class="fas fa-trash"></i> Clear
                        </button>
                        <button class="button small-btn primary-btn" id="exportLogs">
                            <i class="fas fa-download"></i> Export
                        </button>
                    </div>
                </div>
                <div id="logStream">
                    <div class="log-entry info">
                        <div style="display: flex; justify-content: between;">
                            <span><strong>[System]</strong> AI Management</span>
                            <span style="color: #00ffff;">INFO</span>
                        </div>
                        <div>Log collection dashboard initialized. Waiting for log data...</div>
                    </div>
                </div>
            </div>

            <div class="config-section">
                <h3><i class="fas fa-chart-bar"></i> Log Statistics</h3>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin: 15px 0;">
                    <div style="text-align: center; padding: 15px; background: #000800; border: 1px solid #ff0040; border-radius: 6px;">
                        <div style="font-size: 1.5em; color: #ff0040; font-weight: bold;" id="errorCount">0</div>
                        <div style="color: #ff0040; font-size: 0.9em;">Errors</div>
                    </div>
                    <div style="text-align: center; padding: 15px; background: #000800; border: 1px solid #ff6600; border-radius: 6px;">
                        <div style="font-size: 1.5em; color: #ff6600; font-weight: bold;" id="warningCount">0</div>
                        <div style="color: #ff6600; font-size: 0.9em;">Warnings</div>
                    </div>
                </div>

                <div style="margin-top: 20px;">
                    <h4 style="color: #00ff00; margin-bottom: 10px;">Quick Actions</h4>
                    <div class="button-group" style="flex-direction: column; gap: 8px;">
                        <button class="button small-btn" onclick="window.location.href='/ai-management'">
                            <i class="fas fa-arrow-left"></i> Back to AI Management
                        </button>
                        <button class="button small-btn secondary-btn" onclick="location.reload()">
                            <i class="fas fa-sync"></i> Refresh Page
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/protocol-utils') %>
    <script>
        // Simplified log dashboard for AI Management
        class SimpleLogDashboard {
            constructor() {
                this.logBuffer = [];
                this.maxLogEntries = 100;
                this.logCounts = { error: 0, warn: 0, info: 0, debug: 0 };
                this.init();
            }

            init() {
                this.setupEventListeners();
                this.simulateLogData();
            }

            setupEventListeners() {
                document.getElementById('pauseStream')?.addEventListener('click', () => this.toggleStreamPause());
                document.getElementById('clearStream')?.addEventListener('click', () => this.clearLogStream());
                document.getElementById('exportLogs')?.addEventListener('click', () => this.exportLogs());
                document.getElementById('refreshStatus')?.addEventListener('click', () => location.reload());

                // Filter listeners
                document.getElementById('filterDevice')?.addEventListener('change', () => this.applyFilters());
                document.getElementById('filterService')?.addEventListener('change', () => this.applyFilters());
                document.getElementById('filterLevel')?.addEventListener('change', () => this.applyFilters());
                document.getElementById('filterText')?.addEventListener('input', () => this.applyFilters());
            }

            simulateLogData() {
                // Add some sample log entries
                const sampleLogs = [
                    { timestamp: new Date(), level: 'info', service: 'ai', message: 'AI Management system initialized successfully' },
                    { timestamp: new Date(), level: 'info', service: 'stt', message: 'Speech-to-Text service ready' },
                    { timestamp: new Date(), level: 'info', service: 'tts', message: 'Text-to-Speech service connected' }
                ];

                sampleLogs.forEach(log => this.addLogEntry(log));
            }

            addLogEntry(logEntry) {
                this.logBuffer.push(logEntry);
                if (this.logBuffer.length > this.maxLogEntries) {
                    this.logBuffer.shift();
                }
                this.logCounts[logEntry.level] = (this.logCounts[logEntry.level] || 0) + 1;
                this.updateLogCounts();
                if (this.passesFilters(logEntry)) {
                    this.displayLogEntry(logEntry);
                }
            }

            displayLogEntry(logEntry) {
                const logStream = document.getElementById('logStream');
                if (!logStream) return;

                const logElement = document.createElement('div');
                logElement.className = `log-entry ${logEntry.level}`;

                const timestamp = new Date(logEntry.timestamp).toLocaleTimeString();
                logElement.innerHTML = `
                    <div style="display: flex; justify-content: space-between;">
                        <span><strong>[${timestamp}]</strong> ${logEntry.service}</span>
                        <span style="color: ${this.getLevelColor(logEntry.level)};">${logEntry.level.toUpperCase()}</span>
                    </div>
                    <div>${logEntry.message}</div>
                `;

                logStream.appendChild(logElement);
                logStream.scrollTop = logStream.scrollHeight;

                while (logStream.children.length > 50) {
                    logStream.removeChild(logStream.firstChild);
                }
            }

            getLevelColor(level) {
                const colors = {
                    error: '#ff0040',
                    warn: '#ff6600',
                    info: '#00ffff',
                    debug: '#666666'
                };
                return colors[level] || '#cccccc';
            }

            passesFilters(logEntry) {
                const serviceFilter = document.getElementById('filterService')?.value;
                const levelFilter = document.getElementById('filterLevel')?.value;
                const textFilter = document.getElementById('filterText')?.value.toLowerCase();

                if (serviceFilter && logEntry.service !== serviceFilter) return false;
                if (levelFilter && logEntry.level !== levelFilter) return false;
                if (textFilter && !logEntry.message.toLowerCase().includes(textFilter)) return false;

                return true;
            }

            applyFilters() {
                const logStream = document.getElementById('logStream');
                if (!logStream) return;

                logStream.innerHTML = '';
                this.logBuffer.forEach(logEntry => {
                    if (this.passesFilters(logEntry)) {
                        this.displayLogEntry(logEntry);
                    }
                });
            }

            updateLogCounts() {
                const errorCount = document.getElementById('errorCount');
                const warningCount = document.getElementById('warningCount');
                if (errorCount) errorCount.textContent = this.logCounts.error || 0;
                if (warningCount) warningCount.textContent = this.logCounts.warn || 0;
            }

            toggleStreamPause() {
                // Simple pause functionality
                console.log('Stream pause toggled');
            }

            clearLogStream() {
                const logStream = document.getElementById('logStream');
                if (logStream) {
                    logStream.innerHTML = '<div class="log-entry info"><div><strong>[System]</strong> Log stream cleared</div></div>';
                }
                this.logBuffer = [];
                this.logCounts = { error: 0, warn: 0, info: 0, debug: 0 };
                this.updateLogCounts();
            }

            exportLogs() {
                const logs = this.logBuffer.map(log =>
                    `[${log.timestamp}] ${log.service} ${log.level.toUpperCase()}: ${log.message}`
                ).join('\n');

                const blob = new Blob([logs], { type: 'text/plain' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `ai-logs-${new Date().toISOString().split('T')[0]}.txt`;
                a.click();
                URL.revokeObjectURL(url);
            }
        }

        // Initialize dashboard when page loads
        document.addEventListener('DOMContentLoaded', () => {
            new SimpleLogDashboard();
        });
    </script>
</body>
</html>
