<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MonsterBox - Log Collection Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        .log-entry { 
            font-family: 'Courier New', monospace; 
            font-size: 0.85em;
            border-left: 3px solid #dee2e6;
            margin-bottom: 5px;
            padding: 8px;
        }
        .log-entry.error { border-left-color: #dc3545; background-color: #f8d7da; }
        .log-entry.warn { border-left-color: #ffc107; background-color: #fff3cd; }
        .log-entry.info { border-left-color: #0dcaf0; background-color: #d1ecf1; }
        .log-entry.debug { border-left-color: #6c757d; background-color: #f8f9fa; }
        .service-status.healthy { color: #198754; }
        .service-status.unhealthy { color: #dc3545; }
        .service-status.unknown { color: #6c757d; }
        .metrics-card { transition: all 0.3s ease; }
        .metrics-card:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        #logStream { height: 400px; overflow-y: auto; background: #f8f9fa; border: 1px solid #dee2e6; }
        .config-section { border: 1px solid #dee2e6; border-radius: 8px; padding: 20px; margin-bottom: 20px; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    
    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2><i class="fas fa-chart-line"></i> Log Collection Dashboard</h2>
                    <div class="btn-group">
                        <button class="btn btn-success" id="startCollection">
                            <i class="fas fa-play"></i> Start Collection
                        </button>
                        <button class="btn btn-warning" id="pauseCollection">
                            <i class="fas fa-pause"></i> Pause
                        </button>
                        <button class="btn btn-danger" id="stopCollection">
                            <i class="fas fa-stop"></i> Stop
                        </button>
                        <button class="btn btn-info" id="refreshStatus">
                            <i class="fas fa-sync"></i> Refresh
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Service Status Overview -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card metrics-card">
                    <div class="card-body text-center">
                        <h5 class="card-title">Collection Status</h5>
                        <h3 id="collectionStatus" class="service-status unknown">
                            <i class="fas fa-question-circle"></i> Unknown
                        </h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card metrics-card">
                    <div class="card-body text-center">
                        <h5 class="card-title">Active Devices</h5>
                        <h3 id="activeDevices">
                            <i class="fas fa-server"></i> <span>0</span>
                        </h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card metrics-card">
                    <div class="card-body text-center">
                        <h5 class="card-title">Logs/Minute</h5>
                        <h3 id="logsPerMinute">
                            <i class="fas fa-tachometer-alt"></i> <span>0</span>
                        </h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card metrics-card">
                    <div class="card-body text-center">
                        <h5 class="card-title">Storage Used</h5>
                        <h3 id="storageUsed">
                            <i class="fas fa-hdd"></i> <span>0 MB</span>
                        </h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Configuration Panel -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-cog"></i> Log Collection Configuration</h5>
                    </div>
                    <div class="card-body">
                        <form id="configForm">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="config-section">
                                        <h6><i class="fas fa-server"></i> Collection Settings</h6>
                                        <div class="mb-3">
                                            <label class="form-label">Collection Interval (seconds)</label>
                                            <input type="number" class="form-control" id="collectionInterval" value="30" min="5" max="300">
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Buffer Size (entries)</label>
                                            <input type="number" class="form-control" id="bufferSize" value="1000" min="100" max="10000">
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Retention Days</label>
                                            <input type="number" class="form-control" id="retentionDays" value="30" min="1" max="365">
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="compressionEnabled" checked>
                                            <label class="form-check-label">Enable Compression</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="config-section">
                                        <h6><i class="fas fa-bell"></i> Alerting Settings</h6>
                                        <div class="mb-3">
                                            <label class="form-label">Error Threshold (per minute)</label>
                                            <input type="number" class="form-control" id="errorThreshold" value="10" min="1" max="1000">
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Warning Threshold (per minute)</label>
                                            <input type="number" class="form-control" id="warningThreshold" value="50" min="1" max="1000">
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="alertingEnabled" checked>
                                            <label class="form-check-label">Enable Alerting</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="emailAlerts">
                                            <label class="form-check-label">Email Alerts</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save"></i> Save Configuration
                                    </button>
                                    <button type="button" class="btn btn-secondary" id="resetConfig">
                                        <i class="fas fa-undo"></i> Reset to Defaults
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Device Management -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-network-wired"></i> Device Management</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Device</th>
                                        <th>IP Address</th>
                                        <th>Status</th>
                                        <th>Services</th>
                                        <th>Last Seen</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="deviceTable">
                                    <!-- Devices will be populated here -->
                                </tbody>
                            </table>
                        </div>
                        <button class="btn btn-success" id="addDevice">
                            <i class="fas fa-plus"></i> Add Device
                        </button>
                        <button class="btn btn-info" id="scanDevices">
                            <i class="fas fa-search"></i> Scan Network
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Live Log Stream -->
        <div class="row mb-4">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5><i class="fas fa-stream"></i> Live Log Stream</h5>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary" id="pauseStream">
                                <i class="fas fa-pause"></i> Pause
                            </button>
                            <button class="btn btn-outline-secondary" id="clearStream">
                                <i class="fas fa-trash"></i> Clear
                            </button>
                            <button class="btn btn-outline-info" id="exportLogs">
                                <i class="fas fa-download"></i> Export
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="row">
                                <div class="col-md-3">
                                    <select class="form-select form-select-sm" id="filterDevice">
                                        <option value="">All Devices</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <select class="form-select form-select-sm" id="filterService">
                                        <option value="">All Services</option>
                                        <option value="jaw">Jaw Animation</option>
                                        <option value="ai">AI Bridge</option>
                                        <option value="motor">Motor Control</option>
                                        <option value="light">Light Control</option>
                                        <option value="registry">Service Registry</option>
                                        <option value="main">Main Service</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <select class="form-select form-select-sm" id="filterLevel">
                                        <option value="">All Levels</option>
                                        <option value="error">Error</option>
                                        <option value="warn">Warning</option>
                                        <option value="info">Info</option>
                                        <option value="debug">Debug</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <input type="text" class="form-control form-control-sm" id="filterText" placeholder="Search text...">
                                </div>
                            </div>
                        </div>
                        <div id="logStream"></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-chart-bar"></i> Log Statistics</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="logChart" width="400" height="200"></canvas>
                        <div class="mt-3">
                            <div class="row text-center">
                                <div class="col-6">
                                    <div class="border rounded p-2">
                                        <strong id="errorCount">0</strong><br>
                                        <small class="text-danger">Errors</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="border rounded p-2">
                                        <strong id="warningCount">0</strong><br>
                                        <small class="text-warning">Warnings</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Device Modal -->
    <div class="modal fade" id="addDeviceModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Device</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addDeviceForm">
                        <div class="mb-3">
                            <label class="form-label">Device Name</label>
                            <input type="text" class="form-control" id="deviceName" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">IP Address</label>
                            <input type="text" class="form-control" id="deviceIP" required pattern="^(?:[0-9]{1,3}\.){3}[0-9]{1,3}$">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">SSH Username</label>
                            <input type="text" class="form-control" id="deviceUser" value="remote">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Services to Monitor</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="jaw" id="service_jaw" checked>
                                <label class="form-check-label">Jaw Animation (8765)</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="ai" id="service_ai" checked>
                                <label class="form-check-label">AI Bridge (8766)</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="registry" id="service_registry" checked>
                                <label class="form-check-label">Service Registry (8770)</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="motor" id="service_motor" checked>
                                <label class="form-check-label">Motor Control (8771)</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="light" id="service_light" checked>
                                <label class="form-check-label">Light Control (8772)</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="main" id="service_main" checked>
                                <label class="form-check-label">Main Service (8780)</label>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="saveDevice">Save Device</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/log-collection-dashboard.js"></script>
</body>
</html>
