<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>

<body>
    <header>
        <h1 class="landing-title">🔧 Hardware Parts Management</h1>
    </header>

    <main>
        <div class="info-section">
            <h3>🦾 Hardware Parts Overview</h3>
            <p>Manage all physical hardware components independently of characters. Configure GPIO pins, calibration
                settings, and safety limits. Parts can then be assigned to characters in the Characters menu.</p>
        </div>

        <div class="button-group">
            <a href="/parts/new/motor" class="button">🔄 Add Motor</a>
            <a href="/parts/linear-actuator/new" class="button">🦴 Add Linear Actuator</a>
            <a href="/parts/new/light" class="button">💡 Add Light</a>
            <a href="/parts/new/led" class="button">🔆 Add LED</a>
            <a href="/parts/servo/new" class="button">🦷 Add Servo</a>
            <a href="/parts/new/sensor" class="button">📡 Add Sensor</a>
            <a href="/parts/webcam/new" class="button">📹 Add Webcam</a>
            <a href="/parts/head-tracking/new" class="button">🎯 Add Head Tracking</a>
            <a href="/hardware-monitor.html" class="button secondary-btn">📊 Hardware Monitor</a>
        </div>

        <div class="hardware-status">
            <h3>🌐 WebSocket Services Status</h3>
            <div class="service-grid">
                <div class="service-card" id="mainServerCard">
                    <span class="service-indicator" id="mainServerIndicator">🔴</span>
                    <span>Main Server (8780)</span>
                </div>
                <div class="service-card" id="motorServiceCard">
                    <span class="service-indicator" id="motorServiceIndicator">🔴</span>
                    <span>Motor Service (8771)</span>
                </div>
                <div class="service-card" id="lightServiceCard">
                    <span class="service-indicator" id="lightServiceIndicator">🔴</span>
                    <span>Light Service (8772)</span>
                </div>
                <div class="service-card" id="registryCard">
                    <span class="service-indicator" id="registryIndicator">🔴</span>
                    <span>Registry (8770)</span>
                </div>
            </div>
        </div>

        <div id="partsContainer">
            <% if (parts.length===0) { %>
                <div class="empty-state">
                    <h3>🔧 No Hardware Parts Found</h3>
                    <p>Start by adding your first hardware component using the buttons above.</p>
                </div>
                <% } else { %>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th>GPIO/Config</th>
                                    <th>Status</th>
                                    <th>Assigned Characters</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% parts.forEach(function(part) { %>
                                    <tr>
                                        <td>
                                            <strong>
                                                <%= part.name %>
                                            </strong>
                                            <% if (part.description) { %>
                                                <br><small>
                                                    <%= part.description %>
                                                </small>
                                                <% } %>
                                        </td>
                                        <td>
                                            <span class="part-type-badge <%= part.type %>">
                                                <%= part.type==='linear-actuator' ? '🦴' : part.type==='servo' ? '🦷' :
                                                    part.type==='motor' ? '🔄' : part.type==='light' ? '💡' :
                                                    part.type==='led' ? '🔆' : part.type==='sensor' ? '📡' :
                                                    part.type==='webcam' ? '📹' : '🔧' %>
                                                    <%= part.type %>
                                            </span>
                                        </td>
                                        <td>
                                            <% if (part.pin !==undefined) { %>
                                                <code>GPIO <%= part.pin %></code>
                                                <% } %>
                                                    <% if (part.details) { %>
                                                        <br><small>
                                                            <%= part.details %>
                                                        </small>
                                                        <% } %>
                                        </td>
                                        <td>
                                            <span class="status-indicator status-unknown" id="status-<%= part.id %>">
                                                ⚪ Unknown
                                            </span>
                                        </td>
                                        <td>
                                            <div class="assigned-characters" id="assigned-<%= part.id %>">
                                                <small>Loading...</small>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="button-group">
                                                <% if (part.type==='linear-actuator' ) { %>
                                                    <a href="/parts/linear-actuator/<%= part.id %>/edit"
                                                        class="button small-btn">✏️ Edit</a>
                                                    <% } else if (part.type==='servo' ) { %>
                                                        <a href="/parts/servo/<%= part.id %>/edit"
                                                            class="button small-btn">✏️ Edit</a>
                                                        <% } else if (part.type==='light' ) { %>
                                                            <a href="/parts/light/<%= part.id %>/edit"
                                                                class="button small-btn">✏️ Edit</a>
                                                            <% } else if (part.type==='webcam' ) { %>
                                                                <a href="/parts/webcam/<%= part.id %>/edit"
                                                                    class="button small-btn">✏️ Edit</a>
                                                                <% } else { %>
                                                                    <a href="/parts/<%= part.id %>/edit"
                                                                        class="button small-btn">✏️ Edit</a>
                                                                    <% } %>
                                                                        <button onclick="testPart('<%= part.id %>')"
                                                                            class="button small-btn test-btn">🧪
                                                                            Test</button>
                                                                        <button
                                                                            class="button small-btn delete-btn delete-part"
                                                                            data-id="<%= part.id %>">🗑️ Delete</button>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
        </div>

        <div class="button-group">
            <a href="/" class="button secondary-btn">Back to Main Menu</a>
        </div>
    </main>

    <style>
        .info-section {
            background: rgba(0, 255, 0, 0.1);
            border: 1px solid #00ff00;
            border-radius: 5px;
            padding: 15px;
            margin: 20px 0;
        }

        .info-section h3 {
            color: #00ff00;
            margin-bottom: 10px;
        }

        .hardware-status {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(0, 255, 0, 0.3);
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
        }

        .hardware-status h3 {
            color: #00ff00;
            margin-bottom: 15px;
        }

        .service-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 10px;
        }

        .service-card {
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 5px;
            padding: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 12px;
        }

        .service-indicator {
            font-size: 16px;
        }

        .part-type-badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            background: rgba(0, 255, 0, 0.2);
            color: #00ff00;
            border: 1px solid #00ff00;
        }

        .status-indicator {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: bold;
        }

        .status-unknown {
            background: rgba(128, 128, 128, 0.2);
            color: #888;
            border: 1px solid #888;
        }

        .status-online {
            background: rgba(76, 175, 80, 0.2);
            color: #4CAF50;
            border: 1px solid #4CAF50;
        }

        .status-offline {
            background: rgba(244, 67, 54, 0.2);
            color: #f44336;
            border: 1px solid #f44336;
        }

        .assigned-characters {
            font-size: 11px;
            max-width: 150px;
        }

        .small-btn {
            padding: 4px 8px;
            font-size: 11px;
            margin: 2px;
            min-width: auto;
        }

        .test-btn {
            background: linear-gradient(45deg, #2196F3, #1976D2);
        }

        .delete-btn {
            background: linear-gradient(45deg, #f44336, #d32f2f);
        }

        .empty-state {
            text-align: center;
            padding: 40px;
            background: rgba(0, 0, 0, 0.3);
            border: 2px dashed rgba(0, 255, 0, 0.3);
            border-radius: 8px;
            margin: 20px 0;
        }

        .empty-state h3 {
            color: #00ff00;
            margin-bottom: 10px;
        }

        code {
            background: rgba(255, 255, 255, 0.1);
            padding: 2px 4px;
            border-radius: 3px;
            font-family: monospace;
        }
    </style>

    <script>
        $(document).ready(function () {
            // Initialize WebSocket connections for service status
            initializeServiceStatus();

            // Load character assignments for each part
            loadCharacterAssignments();

            $('.delete-part').on('click', function () {
                const id = $(this).data('id');
                if (confirm('Are you sure you want to delete this hardware part? This will remove it from all character assignments.')) {
                    $.post('/parts/' + id + '/delete')
                        .done(function () {
                            location.reload();
                        })
                        .fail(function (xhr, status, error) {
                            console.error('Error details:', xhr.responseText);
                            alert('Error deleting part: ' + xhr.status + ' ' + xhr.statusText);
                        });
                }
            });
        });

        function initializeServiceStatus() {
            // Check WebSocket service status
            const services = [
                { id: 'mainServer', port: 8780, name: 'Main Server' },
                { id: 'motorService', port: 8771, name: 'Motor Service' },
                { id: 'lightService', port: 8772, name: 'Light Service' },
                { id: 'registry', port: 8770, name: 'Registry' }
            ];

            services.forEach(service => {
                checkServiceStatus(service);
            });
        }

        function checkServiceStatus(service) {
            const ws = new WebSocket(`ws://localhost:${service.port}`);
            const indicator = document.getElementById(`${service.id}Indicator`);

            ws.onopen = function () {
                indicator.textContent = '🟢';
                ws.close();
            };

            ws.onerror = function () {
                indicator.textContent = '🔴';
            };

            ws.onclose = function () {
                if (indicator.textContent !== '🟢') {
                    indicator.textContent = '🔴';
                }
            };
        }

        function loadCharacterAssignments() {
            // Load character assignments for each part
            $.get('/api/characters')
                .done(function (characters) {
                    // For each part, check which characters use it
                    <% if (parts.length > 0) { %>
                        <% parts.forEach(function (part) { %>
                    loadPartAssignments('<%= part.id %>', characters);
                        <% }); %>
                    <% } %>
                })
                .fail(function () {
                    console.error('Failed to load character assignments');
                });
        }

        function loadPartAssignments(partId, characters) {
            // This would need to be implemented based on your character-part relationship logic
            const assignedDiv = document.getElementById(`assigned-${partId}`);
            if (assignedDiv) {
                assignedDiv.innerHTML = '<small>None</small>';
            }
        }

        function testPart(partId) {
            // Test hardware part functionality
            $.post(`/parts/${partId}/test`)
                .done(function (response) {
                    if (response.success) {
                        const statusElement = document.getElementById(`status-${partId}`);
                        if (statusElement) {
                            statusElement.className = 'status-indicator status-online';
                            statusElement.textContent = '🟢 Online';
                        }
                        alert('✅ Hardware test successful!');
                    } else {
                        alert('❌ Hardware test failed: ' + response.error);
                    }
                })
                .fail(function (xhr) {
                    alert('❌ Test error: ' + xhr.responseText);
                });
        }
    </script>
</body>

</html>