<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 m-0"><i class="bi bi-tools"></i> Parts</h1>
  <div class="text-muted small">Manage hardware parts</div>
</div>

<div id="alertsContainer" class="mb-3"></div>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span class="fw-semibold">All Parts</span>
    <button class="btn btn-sm btn-outline-secondary" id="refreshBtn"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
  </div>
  <div class="card-body p-0">
    <div id="parts-list" class="list-group list-group-flush">
      <div class="list-group-item text-muted">Loading parts…</div>
    </div>
  </div>
</div>

<script>
  function showAlert(message, type) {
    const c = document.getElementById('alertsContainer');
    const el = document.createElement('div');
    el.className = 'alert ' + (type === 'success' ? 'alert-success' : 'alert-danger') + ' alert-dismissible fade show';
    el.innerHTML = '<div>' + message + '</div>' +
                   '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    c.appendChild(el);
    setTimeout(() => { try { el.remove(); } catch {} }, 4000);
  }

  async function fetchParts() {
    const res = await fetch('/setup/parts/api/parts');
    const j = await res.json();
    if (!j.success) throw new Error('Failed to load parts');
    return j.parts || [];
  }

  function renderParts(parts) {
    const list = document.getElementById('parts-list');
    if (!parts.length) {
      list.innerHTML = '<div class="list-group-item text-muted">No parts found</div>';
      return;
    }
    list.innerHTML = '';
    parts.forEach(p => {
      const item = document.createElement('div');
      item.className = 'list-group-item';
      item.innerHTML = `
        <div class=\"d-flex justify-content-between align-items-center\">
          <div>
            <div class=\"fw-semibold\">${p.name}</div>
            <small class=\"text-muted\">Type: ${p.type} • ID: ${p.id}</small>
          </div>
          <div class=\"d-flex align-items-center gap-2\">
            <button class=\"btn btn-sm btn-outline-primary\" data-testid=\"open-test-btn\" data-part-id=\"${p.id}\">
              <i class=\"bi bi-bug\"></i> Test
            </button>
          </div>
        </div>
        <div id=\"test-drawer-${p.id}\" class=\"mt-2\" style=\"display:none;\">
          <div class=\"border rounded p-2\">
            <div class=\"d-flex align-items-center gap-2\">
              <button class=\"btn btn-success btn-sm\" data-testid=\"quick-test-btn\" data-part-id=\"${p.id}\"><i class=\"bi bi-play\"></i> Quick Test</button>
              <span class=\"small text-muted\">Runs a basic action for this part type</span>
            </div>
          </div>
        </div>
      `;
      list.appendChild(item);
    });

    // Bind handlers
    list.querySelectorAll('[data-testid="open-test-btn"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const pid = btn.getAttribute('data-part-id');
        const drawer = document.getElementById('test-drawer-' + pid);
        if (drawer) drawer.style.display = drawer.style.display === 'none' ? 'block' : 'none';
      });
    });

    list.querySelectorAll('[data-testid="quick-test-btn"]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const pid = btn.getAttribute('data-part-id');
        try {
          btn.disabled = true;
          const r = await fetch('/setup/parts/api/parts/' + encodeURIComponent(pid) + '/test', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({})
          });
          const j = await r.json();
          const ok = !!(j && j.success);
          showAlert(ok ? (j.message || 'Test completed') : (j.error || 'Test failed'), ok ? 'success' : 'danger');
        } catch (e) {
          showAlert('Test failed: ' + (e && e.message || e), 'danger');
        } finally {
          btn.disabled = false;
        }
      });
    });
  }

  async function refreshParts() {
    try {
      const parts = await fetchParts();
      renderParts(parts);
    } catch (e) {
      const list = document.getElementById('parts-list');
      list.innerHTML = '<div class="list-group-item text-danger">Error loading parts</div>';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    refreshParts();
    const refreshBtn = document.getElementById('refreshBtn');
    if (refreshBtn) refreshBtn.addEventListener('click', refreshParts);
  });
</script>

