<style>
  .jaw-page { max-height: calc(100vh - 56px); overflow: hidden; }
  .audio-meter { background: var(--bs-dark, #2d2d2d); height: 28px; border-radius: 4px; position: relative; overflow: hidden; border: 1px solid var(--bs-border-color, #444); }
  .audio-meter-fill { height: 100%; border-radius: 3px; transition: width 0.05s linear; background: linear-gradient(90deg, var(--mb-success) 0%, var(--mb-warning) 60%, var(--mb-danger) 90%); }
  .jaw-meter { background: var(--bs-dark, #2d2d2d); height: 28px; border-radius: 4px; position: relative; overflow: hidden; border: 1px solid var(--bs-border-color, #444); }
  .jaw-meter-fill { height: 100%; border-radius: 3px; transition: width 0.05s linear; background: linear-gradient(90deg, var(--mb-info) 0%, var(--bs-primary, #0d6efd) 70%, var(--mb-primary) 100%); }
  .meter-label { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.03em; text-transform: uppercase; color: var(--bs-secondary-color, #adb5bd); }
  .live-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; background: var(--mb-secondary); }
  .live-dot.active { background: var(--mb-danger); animation: livePulse 0.8s ease-in-out infinite; }
  @keyframes livePulse { 0%,100% { opacity: 1; box-shadow: 0 0 0 0 rgba(var(--bs-danger-rgb),.6); } 50% { opacity: .7; box-shadow: 0 0 6px 3px rgba(var(--bs-danger-rgb),.35); } }
  .meter-value { font-size: 1.05rem; font-weight: 700; font-variant-numeric: tabular-nums; min-width: 3.5em; text-align: right; }
  .meter-value.amp { color: var(--mb-warning); }
  .meter-value.jaw { color: var(--mb-info); }
  .servo-status-indicator { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 6px; }
  .jaw-section { background: rgba(13,13,13,0.6); border-left: 3px solid var(--bs-primary, #0d6efd); padding: 0.75rem; margin-bottom: 0.5rem; border-radius: 4px; }
  .quick-adj-btn { width: 32px; height: 32px; padding: 0; font-size: 0.8rem; }
  .tts-panel, .servo-test-panel { background: rgba(13,13,13,0.6); border: 1px solid var(--bs-border-color, #444); border-radius: 6px; padding: 0.75rem; }
  .compact-label { font-size: 0.85rem; margin-bottom: 0.25rem; }
  .form-range { height: 1.2rem; }
</style>

<div class="jaw-page">
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-warning alert-dismissible py-2 mb-2" role="alert">
    <i class="bi bi-exclamation-triangle"></i> <%= error %>
    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
  </div>
  <% } %>

  <!-- Config Selector Bar -->
  <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
    <div class="input-group input-group-sm" style="max-width:280px;">
      <label class="input-group-text" for="configSelector"><i class="bi bi-collection"></i></label>
      <select class="form-select form-select-sm" id="configSelector">
        <option value="">Loading...</option>
      </select>
    </div>
    <div class="btn-group btn-group-sm">
      <button type="button" class="btn btn-outline-success" id="saveAsNewBtn" title="Save current settings as a new config">
        <i class="bi bi-plus-lg"></i> Save As New
      </button>
      <button type="button" class="btn btn-outline-info" id="renameConfigBtn" title="Rename current config">
        <i class="bi bi-pencil"></i> Rename
      </button>
      <button type="button" class="btn btn-outline-danger" id="deleteConfigBtn" title="Delete current config">
        <i class="bi bi-trash"></i> Delete
      </button>
    </div>
    <div class="ms-auto">
      <button type="button" class="btn btn-primary btn-sm" id="saveConfigBtn">
        <i class="bi bi-save"></i> Save Config
      </button>
    </div>
  </div>

  <% if (currentCharacter) { %>
  <div class="row g-2">
    <!-- LEFT COLUMN: Configuration -->
    <div class="col-lg-5">
      <!-- Enable Toggle -->
      <div class="jaw-section">
        <div class="form-check form-switch mb-2">
          <input class="form-check-input" type="checkbox" role="switch" id="jawEnabled">
          <label class="form-check-label" for="jawEnabled"><strong>Enable Jaw Animation</strong></label>
        </div>

        <!-- Servo Selection -->
        <div class="mb-2">
          <label for="jawServoSelect" class="compact-label"><i class="bi bi-robot"></i> Jaw Servo</label>
          <select class="form-select form-select-sm" id="jawServoSelect">
            <option value="">Select a servo...</option>
          </select>
          <small class="text-muted">
            <span id="servoStatusIndicator"></span>
            <span id="servoStatusText">Select a servo to see its status</span>
          </small>
        </div>
      </div>

      <!-- Tuning -->
      <div class="jaw-section">
        <h6 class="text-info mb-2" style="font-size:0.9rem;"><i class="bi bi-sliders"></i> Tuning</h6>

        <div class="mb-2">
          <label for="sensitivityRange" class="compact-label">
            Sensitivity <span class="badge bg-secondary ms-1" id="sensitivityValue" title="Higher = more responsive to quiet sounds">1.0</span>
          </label>
          <input type="range" class="form-range" id="sensitivityRange" min="0.1" max="5.0" step="0.1" value="1.0">
        </div>

        <div class="mb-2">
          <label for="smoothingRange" class="compact-label">
            Smoothing <span class="badge bg-secondary ms-1" id="smoothingValue" title="Higher = smoother, less jittery">0.6</span>
          </label>
          <input type="range" class="form-range" id="smoothingRange" min="0.1" max="0.9" step="0.1" value="0.6">
        </div>

        <div class="mb-2">
          <label for="volumeThresholdRange" class="compact-label">
            Vol Threshold <span class="badge bg-secondary ms-1" id="volumeThresholdValue" title="Minimum audio level to trigger movement">0.02</span>
          </label>
          <input type="range" class="form-range" id="volumeThresholdRange" min="0.01" max="0.1" step="0.01" value="0.02">
        </div>

        <div class="row g-2 mb-2">
          <div class="col-6">
            <label for="attackTime" class="compact-label">Attack (ms)</label>
            <input type="number" class="form-control form-control-sm" id="attackTime" min="10" max="500" value="50" title="How fast the jaw opens">
          </div>
          <div class="col-6">
            <label for="releaseTime" class="compact-label">Release (ms)</label>
            <input type="number" class="form-control form-control-sm" id="releaseTime" min="10" max="1000" value="150" title="How fast the jaw closes">
          </div>
        </div>

        <hr class="my-2 border-secondary">

        <!-- Preset Buttons -->
        <div class="mb-2">
          <label class="compact-label">Preset</label>
          <div class="btn-group btn-group-sm w-100" role="group">
            <input type="radio" class="btn-check" name="jawPreset" id="presetSpeech" value="speech" checked>
            <label class="btn btn-outline-info" for="presetSpeech">Speech</label>
            <input type="radio" class="btn-check" name="jawPreset" id="presetMusic" value="music">
            <label class="btn btn-outline-info" for="presetMusic">Music</label>
            <input type="radio" class="btn-check" name="jawPreset" id="presetCustom" value="custom">
            <label class="btn btn-outline-info" for="presetCustom">Custom</label>
          </div>
        </div>

        <!-- Speech Filter Toggle -->
        <div class="form-check form-switch mb-2">
          <input class="form-check-input" type="checkbox" role="switch" id="bandpassFilter" checked>
          <label class="form-check-label compact-label" for="bandpassFilter">
            Speech Filter <small class="text-muted">(500-2500Hz bandpass)</small>
          </label>
        </div>

        <!-- AGC Toggle -->
        <div class="form-check form-switch mb-2">
          <input class="form-check-input" type="checkbox" role="switch" id="agcEnabled" checked>
          <label class="form-check-label compact-label" for="agcEnabled">
            Auto Gain Control
          </label>
        </div>

        <!-- Quantization Slider -->
        <div class="mb-2">
          <label for="quantizationRange" class="compact-label">
            Jaw Positions <span class="badge bg-secondary ms-1" id="quantizationValue" title="Number of discrete jaw positions">10</span>
          </label>
          <input type="range" class="form-range" id="quantizationRange" min="5" max="20" step="1" value="10">
        </div>
      </div>

      <!-- Calibration Quick-Adjust -->
      <div class="jaw-section">
        <h6 class="text-info mb-2" style="font-size:0.9rem;"><i class="bi bi-rulers"></i> Calibration Quick-Adjust</h6>
        <div class="row g-2">
          <div class="col-6">
            <label class="compact-label">Min Angle</label>
            <div class="input-group input-group-sm">
              <button class="btn btn-outline-secondary quick-adj-btn" type="button" id="minAngleDown" title="Decrease min angle by 1 degree">&minus;</button>
              <input type="number" class="form-control form-control-sm text-center" id="minAngleValue" readonly>
              <button class="btn btn-outline-secondary quick-adj-btn" type="button" id="minAngleUp" title="Increase min angle by 1 degree">+</button>
            </div>
          </div>
          <div class="col-6">
            <label class="compact-label">Max Angle</label>
            <div class="input-group input-group-sm">
              <button class="btn btn-outline-secondary quick-adj-btn" type="button" id="maxAngleDown" title="Decrease max angle by 1 degree">&minus;</button>
              <input type="number" class="form-control form-control-sm text-center" id="maxAngleValue" readonly>
              <button class="btn btn-outline-secondary quick-adj-btn" type="button" id="maxAngleUp" title="Increase max angle by 1 degree">+</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN: TTS Test & Monitoring -->
    <div class="col-lg-7">
      <!-- TTS Test Panel -->
      <div class="tts-panel mb-2">
        <h6 class="text-info mb-2" style="font-size:0.9rem;"><i class="bi bi-megaphone"></i> TTS Test Panel</h6>

        <div class="mb-2">
          <label for="ttsTestText" class="compact-label">Test Text</label>
          <textarea class="form-control form-control-sm" id="ttsTestText" rows="2">The quick brown fox jumped over the lazy dog</textarea>
        </div>

        <div class="d-flex gap-2 mb-2">
          <button type="button" class="btn btn-success btn-sm flex-grow-1" id="playTtsBtn">
            <i class="bi bi-play-fill"></i> Play TTS &amp; Jaw
          </button>
          <button type="button" class="btn btn-danger btn-sm" id="stopBtn">
            <i class="bi bi-stop-fill"></i> Stop
          </button>
        </div>

        <!-- Live Status Row -->
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div class="d-flex align-items-center gap-2">
            <span class="live-dot" id="liveDot"></span>
            <span class="badge status-badge" id="ttsStatus">
              <span class="bg-secondary px-2 py-1 rounded">Idle</span>
            </span>
          </div>
          <div>
            <small class="text-muted">Smoothed:</small>
            <span class="fw-bold text-info" id="smoothedAmplitude">0.000</span>
          </div>
        </div>

        <!-- Audio Level Meter -->
        <div class="mb-2">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="meter-label"><i class="bi bi-soundwave"></i> Audio Level</span>
            <span class="meter-value amp" id="currentAmplitude">0.000</span>
          </div>
          <div class="audio-meter"><div class="audio-meter-fill" id="audioMeterFill" style="width: 0%;"></div></div>
        </div>

        <!-- Jaw Angle Meter -->
        <div class="mb-1">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="meter-label"><i class="bi bi-arrows-angle-expand"></i> Jaw Angle</span>
            <span class="meter-value jaw" id="targetAngle">0&deg;</span>
          </div>
          <div class="jaw-meter"><div class="jaw-meter-fill" id="jawMeterFill" style="width: 0%;"></div></div>
          <div class="d-flex justify-content-between mt-1">
            <small class="text-muted" id="jawMeterMin">0&deg;</small>
            <small class="text-muted" id="jawMeterMax">180&deg;</small>
          </div>
        </div>
      </div>

      <!-- Jaw Timeline Visualization -->
      <div class="tts-panel mb-2" id="timelinePanel" style="display:none;">
        <h6 class="text-info mb-2" style="font-size:0.9rem;"><i class="bi bi-bar-chart"></i> Jaw Timeline</h6>
        <canvas id="jawTimelineCanvas" width="600" height="100" style="width:100%;height:100px;background:#1a1a1a;border-radius:4px;"></canvas>
      </div>

      <!-- Servo Test -->
      <div class="servo-test-panel">
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-outline-warning btn-sm flex-grow-1" id="testJawBtn">
            <i class="bi bi-arrow-left-right"></i> Test Mechanical Sweep
          </button>
          <button type="button" class="btn btn-outline-danger btn-sm" id="emergencyStopBtn">
            <i class="bi bi-exclamation-triangle"></i> E-Stop
          </button>
        </div>
      </div>
    </div>
  </div>
  <% } else { %>
  <div class="alert alert-info py-2" role="alert">
    <i class="bi bi-info-circle"></i> No character selected. Please select a character from the navigation menu.
  </div>
  <% } %>
</div>

<script src="/js/jaw-animation.js?v=<%= Date.now() %>"></script>
