<div class="container">
      <div class="d-flex justify-content-end mb-2 gap-2">
        <button id="saveBtn" class="btn btn-success btn-sm" title="Save and return to characters"><i class="bi bi-check-circle"></i> Save & Return</button>
        <a href="/setup/characters" class="btn btn-secondary btn-sm" title="Cancel and return to characters"><i class="bi bi-x-circle"></i> Cancel</a>
      </div>
      <div class="mb-3">
        <label class="form-label">Character ID</label>
        <input id="charId" class="form-control" type="number" title="Character ID"
          value="<%= (typeof currentCharacter !== 'undefined' && currentCharacter) ? currentCharacter : (config && config.selectedCharacter ? config.selectedCharacter : '') %>" />
      </div>
      <form id="uploadForm" class="mb-3">
        <div class="input-group">
          <input type="file" id="imageFile" name="image" class="form-control" accept="image/*" required title="Choose an image to upload">
          <button class="btn btn-primary" type="submit" title="Upload an image"><i class="bi bi-upload"></i> Upload</button>
        </div>
      </form>
      <div id="activeBox" class="mb-3 text-muted">Active: <span id="activeName">(none)</span></div>
  <div id="images" class="row g-3"></div>
</div>

<script>
      (function () {
        function esc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
        var elList = document.getElementById('images');
        var elActive = document.getElementById('activeName');
        function charId() { return parseInt(document.getElementById('charId').value, 10) || null; }
        function load() {
          var id = charId(); if (!id) { elList.innerHTML = '<div class="col-12 text-muted">Enter a character ID</div>'; return; }
          fetch('/api/characters/' + id + '/images').then(function (r) { return r.json(); }).then(function (data) {
            if (!data || !data.success) { elList.innerHTML = '<div class="col-12 text-danger">Failed to load</div>'; return; }
            elActive.textContent = data.active || '(none)';
            var html = '';
            for (var i = 0; i < data.images.length; i++) {
              var img = data.images[i];
              html += '<div class="col-auto">' +
                '<div class="card" style="width:12rem">' +
                '<img src="' + esc(img.url) + '" class="card-img-top" alt="">' +
                '<div class="card-body p-2 d-flex gap-1">' +
                '<button class="btn btn-sm btn-outline-success" title="Set as active image" onclick="__imgs.setActive(\'' + esc(img.filename) + '\')"><i class="bi bi-check2"></i></button>' +
                '<button class="btn btn-sm btn-outline-danger" title="Delete this image" onclick="__imgs.del(\'' + esc(img.filename) + '\')"><i class="bi bi-trash"></i></button>' +
                '</div></div></div>';
            }
            elList.innerHTML = html || '<div class="col-12 text-muted">No images yet</div>';
          });
        }
        function upload(ev) {
          ev.preventDefault(); var id = charId(); if (!id) return;
          var fd = new FormData(); var f = document.getElementById('imageFile').files[0]; if (!f) return;
          fd.append('image', f);
          fetch('/api/characters/' + id + '/images/upload', { method: 'POST', body: fd }).then(function () { load(); });
        }
        function setActive(name) {
          var id = charId(); if (!id) return;
          fetch('/api/characters/' + id + '/images/active', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ filename: name }) })
            .then(function () { load(); });
        }
        function del(name) {
          var id = charId(); if (!id) return;
          if (!confirm('Delete ' + name + '?')) return;
          fetch('/api/characters/' + id + '/images/' + encodeURIComponent(name), { method: 'DELETE' })
            .then(function () { load(); });
        }
        function saveAndReturn() {
          // The active image is already saved when user clicks the check button
          // Just return to the characters page
          window.location.href = '/setup/characters';
        }
        window.__imgs = { setActive: setActive, del: del };
        document.getElementById('uploadForm').addEventListener('submit', upload);
        document.getElementById('charId').addEventListener('change', load);
        document.getElementById('saveBtn').addEventListener('click', saveAndReturn);
        document.addEventListener('DOMContentLoaded', load);
    })();
  </script>