  // Save configuration
  async function saveConfiguration() {
    try {
      const sinkVal = document.getElementById('default-sink').value;
      const sourceVal = document.getElementById('default-source').value;

      // Map 'auto' to 'default' for the server — 'auto' means "use system default"
      const defaultSink = (sinkVal === 'auto') ? 'default' : sinkVal;
      const defaultSource = (sourceVal === 'auto') ? 'default' : sourceVal;

      console.log('💾 Saving configuration:', { defaultSink, defaultSource });

      // Persist user choice locally so UI restores after reload
      try { localStorage.setItem('setupAudio.defaultSink', sinkVal); } catch (e) { }
      try { localStorage.setItem('setupAudio.defaultSource', sourceVal); } catch (e) { }

      // Set force flags so updateDeviceSelectors keeps the user's choice during refresh
      window._forceSelectedSink = sinkVal;
      window._forceSelectedSource = sourceVal;

      const response = await fetch('/setup/audio/api/system-config', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ defaultSink, defaultSource })
      });

      const data = await response.json();

      if (data.success) {
        showNotification('Configuration saved successfully!', 'success');
        await loadSystemConfiguration(); // Refresh to show changes
      } else {
        showNotification('Failed to save configuration: ' + data.error, 'error');
      }
      // Clear force after UI has refreshed
      setTimeout(function () {
        window._forceSelectedSink = null;
        window._forceSelectedSource = null;
      }, 500);
    } catch (error) {
      console.error('Error saving configuration:', error);
      showNotification('Error saving configuration', 'error');
    }
  }

