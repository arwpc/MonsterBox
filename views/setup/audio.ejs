<!-- Browser Audio Bridge -->
<div class="row mb-4">
  <div class="col-12">
    <div class="card panel-collapsible" data-panel-id="browser-audio-bridge">
      <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-headset"></i> Browser Audio Bridge</h5>
      </div>
      <div class="card-body">
        <p class="text-muted small mb-3">
          Listen to the character's microphone through your browser speaker, or speak through your browser microphone to the character's speaker.
        </p>
        <div class="row">
          <!-- Listen In: Browser Speaker -->
          <div class="col-md-6 mb-3 mb-md-0">
            <div class="card bg-dark border-info">
              <div class="card-header bg-dark text-info border-info">
                <h6 class="mb-0"><i class="bi bi-headphones"></i> Listen In (Browser Speaker)</h6>
              </div>
              <div class="card-body">
                <p class="small text-muted mb-2">Hear what the character's microphone picks up through your browser.</p>
                <div class="mb-2">
                  <label class="form-label small">Source Microphone</label>
                  <select id="listenin-source-select" class="form-select form-select-sm" title="Select source microphone">
