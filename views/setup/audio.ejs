            <div class="card bg-dark border-warning">
              <div class="card-header bg-dark text-warning border-warning">
                <h6 class="mb-0"><i class="bi bi-mic-fill"></i> Talk Through (Browser Mic)</h6>
              </div>
              <div class="card-body">
                <p class="small text-muted mb-2">Speak into your browser mic and hear it through the character's speaker.</p>
                <div class="mb-2">
                  <label class="form-label small">Target Speaker</label>
                  <select id="talkthrough-sink-select" class="form-select form-select-sm" title="Select target speaker">
                    <option value="default">System Default Output</option>
                  </select>
                </div>
                <div class="vu-meter-container mb-2">
                  <div class="vu-meter" style="flex:1">
                    <div id="talkthrough-vu-bar" class="vu-bar" style="width:0%"></div>
                  </div>
                  <span id="talkthrough-vu-label" class="vu-label small text-muted">0%</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                  <button id="btn-talkthrough-toggle" class="btn btn-warning btn-sm" type="button" title="Start or stop talking through">
                    <i class="bi bi-mic-fill"></i> <span id="talkthrough-toggle-text">Start Talking</span>
                  </button>
                  <span id="talkthrough-status" class="badge bg-secondary">Off</span>
                </div>
                <div id="talkthrough-https-warning" class="alert alert-warning small mt-2 d-none">
                  <i class="bi bi-shield-lock"></i> Browser microphone requires HTTPS or localhost.
