  // Run audio test
  async function runAudioTest(testType, deviceId) {
    try {
      const testResults = document.getElementById('test-results');
      const timestamp = new Date().toLocaleTimeString();
      testResults.textContent = '[' + timestamp + '] Running ' + testType + ' test on device: ' + deviceId + '...\n';

      const response = await fetch('/setup/audio/api/test-system', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ testType, deviceId })
      });

      if (!response.ok) {
        throw new Error('HTTP ' + response.status + ': ' + response.statusText);
      }

      const data = await response.json();

      if (data.success) {
        testResults.textContent += '[' + new Date().toLocaleTimeString() + '] Test completed successfully!\n';

        // Show microphone-specific details (level, device used, fallback)
        if (testType === 'microphone' && data.parsed) {
          const level = data.parsed.level || 0;
          const pct = Math.round(level * 100);
          testResults.textContent += 'Device: ' + (data.deviceId || deviceId) + '\n';
          testResults.textContent += 'Peak Level: ' + level.toFixed(4) + ' (' + pct + '%)\n';
          if (data.parsed.avg) {
            testResults.textContent += 'Average Level: ' + data.parsed.avg.toFixed(4) + '\n';
          }
          if (data.fallbackUsed) {
            testResults.textContent += 'Note: Fallback device used (requested device unavailable)\n';
          }
          testResults.textContent += 'Message: ' + (data.message || '') + '\n';
        } else if (data.message) {
          testResults.textContent += 'Result: ' + data.message + '\n';
        } else if (data.result) {
          testResults.textContent += 'Result: ' + data.result + '\n';
        }
        showNotification(testType + ' test completed successfully', 'success');
      } else {
        const errorMsg = data.error || 'Unknown error';
        testResults.textContent += '[' + new Date().toLocaleTimeString() + '] Test failed: ' + errorMsg + '\n';
        showNotification(testType + ' test failed: ' + errorMsg, 'error');
      }
    } catch (error) {
      console.error('Error running test:', error);
      const testResults = document.getElementById('test-results');
      testResults.textContent += '[' + new Date().toLocaleTimeString() + '] Error running test: ' + error.message + '\n';
      showNotification('Test error: ' + error.message, 'error');
    }
  }

  // VU Meter Management
  let vuMeterIntervals = {};

  // Peak hold state for smooth VU decay
  const vuPeakLevels = {};
  const VU_DECAY_RATE = 0.7; // Faster decay for responsive meter movement

  function updateVUMeter(meterId, level) {
    const meter = document.getElementById(meterId);
    if (!meter) {
      return;
    }

    const bar = meter.querySelector('.vu-bar');
    if (!bar) {
      return;
    }

    const labelId = meterId.includes('-vu-') ? meterId + '-level-text' : meterId.replace('-vu-meter', '-level-text');
    const label = document.getElementById(labelId);

    // Subtract noise floor so background hum reads near zero, then scale linearly.
    // Background noise ~0.04-0.07 → 3-12%, normal speech ~0.15-0.40 → 36-100%.
    const gated = Math.max(0, level - 0.03);
    const scaled = Math.min(1, gated * 3);

    // Peak hold with smooth decay — keeps the bar from flickering
    const prev = vuPeakLevels[meterId] || 0;
    const displayed = scaled > prev ? scaled : prev * VU_DECAY_RATE;
    vuPeakLevels[meterId] = displayed;

    const percentage = Math.min(Math.max(displayed * 100, 0), 100);

    bar.style.width = percentage + '%';
    if (label) {
      label.textContent = Math.round(percentage) + '%';
    }

    if (percentage > 3) {
      meter.classList.add('active');
    } else {
      meter.classList.remove('active');
    }
  }

  const vuMeterBusy = {};
  const vuMeterErrorCount = {};

  function startVUMeterMonitoring(deviceId, deviceType, meterId) {
    // Stop existing monitoring for this meter
    if (vuMeterIntervals[meterId]) {
      clearInterval(vuMeterIntervals[meterId]);
    }

    // In test mode, simulate a running monitor without polling so toggles work
    try {
      if (window && window.MB_TEST_MODE) {
        vuMeterIntervals[meterId] = true; // placeholder truthy flag
        updateVUMeter(meterId, 0);
        return;
      }
    } catch (e) { /* ignore */ }

    // Start new monitoring with throttle and no console spam
    if (window.MONSTERBOX_DEBUG_AUDIO) console.log('🎵 Starting VU meter monitoring for', deviceId, deviceType);
    vuMeterBusy[meterId] = false;
    vuMeterErrorCount[meterId] = 0;

    vuMeterIntervals[meterId] = setInterval(async function () {
      if (vuMeterBusy[meterId]) return; // prevent overlapping fetches
      vuMeterBusy[meterId] = true;
      try {
        const response = await fetch('/setup/audio/api/audio-levels?deviceId=' + encodeURIComponent(deviceId) + '&deviceType=' + deviceType);

        if (!response.ok) {
          throw new Error('HTTP ' + response.status + ': ' + response.statusText);
        }

        const data = await response.json();

        if (data && data.success) {
          var level = (typeof data.level === 'number') ? data.level : 0;
          updateVUMeter(meterId, level);
          vuMeterErrorCount[meterId] = 0; // Reset error count on success
          if (window.MONSTERBOX_DEBUG_AUDIO && level > 0.01) {
            console.log('🎵 VU level detected:', level, 'for', deviceId);
          }
        } else {
          throw new Error(data.error || 'Unknown error from audio-levels endpoint');
        }
      } catch (error) {
        vuMeterErrorCount[meterId] = (vuMeterErrorCount[meterId] || 0) + 1;
        if (window.MONSTERBOX_DEBUG_AUDIO) console.warn('VU meter update failed:', error);

        // If we get too many consecutive errors, show a toast and stop monitoring
        if (vuMeterErrorCount[meterId] >= 5) {
          console.error('VU meter monitoring failed 5 times, stopping:', meterId);
          showNotification('Audio level monitoring failed for ' + deviceType + '. Check device connection.', 'error');
          stopVUMeterMonitoring(meterId);
        }
      } finally {
        vuMeterBusy[meterId] = false;
      }
    }, 150); // 150ms refresh — matches 100ms sample duration
  }

  function stopVUMeterMonitoring(meterId) {
    if (vuMeterIntervals[meterId]) {
      clearInterval(vuMeterIntervals[meterId]);
      delete vuMeterIntervals[meterId];
      updateVUMeter(meterId, 0); // Reset to zero
      console.log('🎵 Stopped VU meter monitoring for', meterId);
    }
  }

