  // ============================================================
  // Browser Audio Bridge — Listen In (Browser Speaker) & Talk Through (Browser Mic)
  // ============================================================

  // State for Listen In
  let listenInEventSource = null;
  let listenInAudioCtx = null;
  let listenInNextStart = 0;
  let listenInLeftover = null; // buffer for odd-byte chunks (PCM16 = 2 bytes/sample)
  const LISTEN_IN_RATE = 48000;

  // State for Talk Through
  let talkThroughStream = null;
  let talkThroughAudioCtx = null;
  let talkThroughProcessor = null;
  let talkThroughActive = false;
  let talkThroughVuTimer = null;
  const TALK_THROUGH_RATE = 16000;

  // Populate the Browser Audio Bridge device selectors from API
  function populateBridgeSelectors() {
    fetch('/setup/audio/api/inputs').then(r => r.json()).then(data => {
      if (!data || !data.success) return;
      const sel = document.getElementById('listenin-source-select');
      if (!sel || !data.inputs || !data.inputs.length) return;
      sel.innerHTML = '';
      data.inputs.forEach(inp => {
        const o = document.createElement('option');
        o.value = inp.id || inp.name;
        o.textContent = inp.description || inp.name || inp.id;
        sel.appendChild(o);
      });
    }).catch(() => {});

    fetch('/setup/audio/api/outputs').then(r => r.json()).then(data => {
      if (!data || !data.success) return;
      const sel = document.getElementById('talkthrough-sink-select');
      if (!sel || !data.outputs || !data.outputs.length) return;
      sel.innerHTML = '';
      data.outputs.forEach(out => {
        const o = document.createElement('option');
        o.value = out.id || out.name;
        o.textContent = out.description || out.name || out.id;
        sel.appendChild(o);
      });
    }).catch(() => {});

    // Check HTTPS for browser mic
    const isSecure = window.isSecureContext || window.location.protocol === 'https:' || /^(localhost|127\.0\.0\.1)$/i.test(window.location.hostname);
    const httpsWarn = document.getElementById('talkthrough-https-warning');
    if (!isSecure && httpsWarn) {
      httpsWarn.classList.remove('d-none');
      const btn = document.getElementById('btn-talkthrough-toggle');
      if (btn) btn.disabled = true;
    }
  }

  // ------- Listen In (Browser Speaker) -------

  function toggleListenIn() {
    if (listenInEventSource) {
      stopListenIn();
    } else {
      startListenIn();
    }
  }

  function startListenIn() {
    const sourceSelect = document.getElementById('listenin-source-select');
    const deviceId = sourceSelect ? sourceSelect.value : 'default';
    const statusBadge = document.getElementById('listenin-status');
    const toggleText = document.getElementById('listenin-toggle-text');
    const btn = document.getElementById('btn-listenin-toggle');

    if (statusBadge) { statusBadge.textContent = 'Connecting...'; statusBadge.className = 'badge bg-warning'; }
    if (toggleText) toggleText.textContent = 'Connecting...';
    if (btn) btn.disabled = true;

    // Create AudioContext for playback
    const Ctx = window.AudioContext || window.webkitAudioContext;
    listenInAudioCtx = new Ctx({ sampleRate: LISTEN_IN_RATE });
    listenInNextStart = 0;

    // Open SSE connection to mic-stream endpoint
    const url = '/setup/audio/api/mic-stream?deviceId=' + encodeURIComponent(deviceId);
    listenInEventSource = new EventSource(url);

    listenInEventSource.onmessage = function(event) {
      try {
        const msg = JSON.parse(event.data);
        if (msg.type === 'started') {
          if (statusBadge) { statusBadge.textContent = 'Listening'; statusBadge.className = 'badge bg-success'; }
          if (toggleText) toggleText.textContent = 'Stop Listening';
          if (btn) { btn.disabled = false; btn.className = 'btn btn-outline-danger btn-sm'; }
        } else if (msg.type === 'audio') {
          playListenInChunk(msg.audio);
        } else if (msg.type === 'error') {
          console.error('Listen In error:', msg.error);
          showNotification('Listen In error: ' + msg.error, 'error');
          stopListenIn();
        } else if (msg.type === 'ended') {
          stopListenIn();
        }
      } catch (e) {
        console.warn('Listen In parse error:', e);
      }
    };

    listenInEventSource.onerror = function() {
      console.warn('Listen In SSE connection error');
      stopListenIn();
    };
  }

  function playListenInChunk(base64Pcm) {
    if (!listenInAudioCtx || !base64Pcm) return;

    // Decode base64 to bytes
    const raw = atob(base64Pcm);
    const incoming = new Uint8Array(raw.length);
    for (let i = 0; i < raw.length; i++) incoming[i] = raw.charCodeAt(i);

    // Prepend any leftover byte from previous chunk (PCM16 = 2 bytes/sample)
    let pcmBytes;
    if (listenInLeftover && listenInLeftover.length > 0) {
      pcmBytes = new Uint8Array(listenInLeftover.length + incoming.length);
      pcmBytes.set(listenInLeftover, 0);
      pcmBytes.set(incoming, listenInLeftover.length);
      listenInLeftover = null;
    } else {
      pcmBytes = incoming;
    }

    // Save odd trailing byte for next chunk
    let usable = pcmBytes.length;
    if (usable % 2 !== 0) {
      listenInLeftover = pcmBytes.slice(usable - 1);
      usable -= 1;
    }
    if (usable < 2) return;

    const samples = usable / 2;

    // Convert to Float32
    const float32 = new Float32Array(samples);
    const view = new DataView(pcmBytes.buffer, pcmBytes.byteOffset, usable);
    for (let j = 0; j < samples; j++) {
      float32[j] = view.getInt16(j * 2, true) / 32768;
    }

    // Compute RMS for VU meter
    let sumSq = 0;
    for (let k = 0; k < float32.length; k++) sumSq += float32[k] * float32[k];
    const pct = Math.min(100, Math.round(Math.sqrt(sumSq / float32.length) * 500));
    const vuBar = document.getElementById('listenin-vu-bar');
    const vuLabel = document.getElementById('listenin-vu-label');
    if (vuBar) vuBar.style.width = pct + '%';
    if (vuLabel) vuLabel.textContent = pct + '%';

    // Apply volume control
    const volSlider = document.getElementById('listenin-volume');
    const volume = volSlider ? (parseInt(volSlider.value, 10) / 100) : 0.75;
    for (let m = 0; m < float32.length; m++) float32[m] *= volume;

    // Create AudioBuffer and play
    if (listenInAudioCtx.state === 'suspended') listenInAudioCtx.resume();
    const buffer = listenInAudioCtx.createBuffer(1, samples, LISTEN_IN_RATE);
    buffer.getChannelData(0).set(float32);
    const source = listenInAudioCtx.createBufferSource();
    source.buffer = buffer;
    source.connect(listenInAudioCtx.destination);

    const now = listenInAudioCtx.currentTime;
    // Jitter buffer: schedule 300ms ahead to absorb network/chunk timing variance
    if (listenInNextStart < now) listenInNextStart = now + 0.3;
    source.start(listenInNextStart);
    listenInNextStart += buffer.duration;
  }

  function stopListenIn() {
    if (listenInEventSource) {
      listenInEventSource.close();
      listenInEventSource = null;
    }
    if (listenInAudioCtx) {
      try { listenInAudioCtx.close(); } catch (_) {}
      listenInAudioCtx = null;
    }
    listenInNextStart = 0;
    listenInLeftover = null;

    const statusBadge = document.getElementById('listenin-status');
    const toggleText = document.getElementById('listenin-toggle-text');
    const btn = document.getElementById('btn-listenin-toggle');
    const vuBar = document.getElementById('listenin-vu-bar');
    const vuLabel = document.getElementById('listenin-vu-label');
    if (statusBadge) { statusBadge.textContent = 'Off'; statusBadge.className = 'badge bg-secondary'; }
    if (toggleText) toggleText.textContent = 'Start Listening';
    if (btn) { btn.disabled = false; btn.className = 'btn btn-info btn-sm'; }
    if (vuBar) vuBar.style.width = '0%';
    if (vuLabel) vuLabel.textContent = '0%';
  }

  // ------- Talk Through (Browser Mic) -------

  function toggleTalkThrough() {
    if (talkThroughActive) {
      stopTalkThrough();
    } else {
      startTalkThrough();
    }
  }

  async function startTalkThrough() {
    const sinkSelect = document.getElementById('talkthrough-sink-select');
    const deviceId = sinkSelect ? sinkSelect.value : 'default';
    const statusBadge = document.getElementById('talkthrough-status');
    const toggleText = document.getElementById('talkthrough-toggle-text');
    const btn = document.getElementById('btn-talkthrough-toggle');

    // Check browser support
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      showNotification('Browser does not support microphone capture', 'error');
      return;
    }

    if (statusBadge) { statusBadge.textContent = 'Requesting mic...'; statusBadge.className = 'badge bg-warning'; }
    if (toggleText) toggleText.textContent = 'Requesting...';
    if (btn) btn.disabled = true;

    try {
      talkThroughStream = await navigator.mediaDevices.getUserMedia({
        audio: {
          echoCancellation: true,
          noiseSuppression: true,
          autoGainControl: true,
          sampleRate: { ideal: 16000 }
        }
      });

      const Ctx = window.AudioContext || window.webkitAudioContext;
      talkThroughAudioCtx = new Ctx();
      const source = talkThroughAudioCtx.createMediaStreamSource(talkThroughStream);
      talkThroughProcessor = talkThroughAudioCtx.createScriptProcessor(4096, 1, 1);
      const nativeRate = talkThroughAudioCtx.sampleRate;
      const targetDeviceId = deviceId;

      talkThroughProcessor.onaudioprocess = function(e) {
        if (!talkThroughActive) return;
        const input = e.inputBuffer.getChannelData(0);

        // Compute RMS for VU meter
        let sumSq = 0;
        for (let i = 0; i < input.length; i++) sumSq += input[i] * input[i];
        const rms = Math.sqrt(sumSq / input.length);
        const pct = Math.min(100, Math.round(rms * 500));
        const vuBar = document.getElementById('talkthrough-vu-bar');
        const vuLabel = document.getElementById('talkthrough-vu-label');
        if (vuBar) vuBar.style.width = pct + '%';
        if (vuLabel) vuLabel.textContent = pct + '%';

        // Downsample to 16kHz
        const ratio = nativeRate / TALK_THROUGH_RATE;
        const outputLen = Math.floor(input.length / ratio);
        const pcm16 = new Int16Array(outputLen);
        for (let i = 0; i < outputLen; i++) {
          const srcIdx = Math.floor(i * ratio);
          pcm16[i] = Math.max(-32768, Math.min(32767, Math.round(input[srcIdx] * 32768)));
        }

        // Base64 encode
        const byteArr = new Uint8Array(pcm16.buffer);
        let binary = '';
        for (let j = 0; j < byteArr.length; j++) {
          binary += String.fromCharCode(byteArr[j]);
        }
        const b64 = btoa(binary);

        // Send to server (fire and forget)
        fetch('/setup/audio/api/browser-mic-chunk', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ audio: b64, deviceId: targetDeviceId })
        }).catch(function(err) {
          console.warn('Talk Through send error:', err);
        });
      };

      source.connect(talkThroughProcessor);
      talkThroughProcessor.connect(talkThroughAudioCtx.destination);
      talkThroughActive = true;

      if (statusBadge) { statusBadge.textContent = 'Active'; statusBadge.className = 'badge bg-success'; }
      if (toggleText) toggleText.textContent = 'Stop Talking';
      if (btn) { btn.disabled = false; btn.className = 'btn btn-outline-danger btn-sm'; }
    } catch (err) {
      console.error('Talk Through start error:', err);
      showNotification('Microphone error: ' + (err.message || err), 'error');
      if (statusBadge) { statusBadge.textContent = 'Error'; statusBadge.className = 'badge bg-danger'; }
      if (toggleText) toggleText.textContent = 'Start Talking';
      if (btn) { btn.disabled = false; btn.className = 'btn btn-warning btn-sm'; }
    }
  }

  function stopTalkThrough() {
    talkThroughActive = false;

    if (talkThroughProcessor) {
      try { talkThroughProcessor.disconnect(); } catch (_) {}
      talkThroughProcessor = null;
    }
    if (talkThroughStream) {
      talkThroughStream.getTracks().forEach(function(t) { t.stop(); });
      talkThroughStream = null;
    }
    if (talkThroughAudioCtx) {
      try { talkThroughAudioCtx.close(); } catch (_) {}
      talkThroughAudioCtx = null;
    }

    // Tell server to stop the pw-play stream
    fetch('/setup/audio/api/browser-mic/stop', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: '{}'
    }).catch(function() {});

    const statusBadge = document.getElementById('talkthrough-status');
    const toggleText = document.getElementById('talkthrough-toggle-text');
    const btn = document.getElementById('btn-talkthrough-toggle');
    const vuBar = document.getElementById('talkthrough-vu-bar');
    const vuLabel = document.getElementById('talkthrough-vu-label');
    if (statusBadge) { statusBadge.textContent = 'Off'; statusBadge.className = 'badge bg-secondary'; }
    if (toggleText) toggleText.textContent = 'Start Talking';
    if (btn) { btn.disabled = false; btn.className = 'btn btn-warning btn-sm'; }
    if (vuBar) vuBar.style.width = '0%';
    if (vuLabel) vuLabel.textContent = '0%';
  }

  // Init bridge: load devices and bind buttons
  document.addEventListener('DOMContentLoaded', function () {
    populateBridgeSelectors();
    const listenBtn = document.getElementById('btn-listenin-toggle');
    const talkBtn = document.getElementById('btn-talkthrough-toggle');
    if (listenBtn) listenBtn.addEventListener('click', toggleListenIn);
    if (talkBtn) talkBtn.addEventListener('click', toggleTalkThrough);
  });

  // Cleanup on page unload
  window.addEventListener('beforeunload', function() {
    if (listenInEventSource) stopListenIn();
    if (talkThroughActive) stopTalkThrough();
  });

</script>
<script src="/js/panel-sortable.js"></script>
<script>document.addEventListener('DOMContentLoaded', function () { PanelSortable.init('audio-setup'); });</script>