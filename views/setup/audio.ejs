                  </select>
                </div>
                <div class="mb-2">
                  <label class="form-label small">Browser Volume</label>
                  <input type="range" id="listenin-volume" class="form-range" min="0" max="100" value="75" step="5" title="Adjust browser volume">
                </div>
                <div class="vu-meter-container mb-2">
                  <div class="vu-meter" style="flex:1">
                    <div id="listenin-vu-bar" class="vu-bar" style="width:0%"></div>
                  </div>
