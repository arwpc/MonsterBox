  function loadEditServoValues(part, config) {
    const pin = part.pin || config.pin;
    const servoType = config.servoType || 'standard';

    const controllerType = config.controllerType || 'gpio';
    const invertDirection = config.invertDirection || false;
    const modelId = part.modelId || config.modelId;
    const address = config.address || config.pca9685Address || 64;
    const frequency = config.frequency || config.pca9685Frequency || 50;
    const channel = config.channel || config.pca9685Channel || 0;

    // Set basic values
    const pinEl = document.getElementById('editServoPin');
    if (pinEl && pin != null) pinEl.value = pin;

    const typeEl = document.getElementById('editServoType');
    if (typeEl) typeEl.value = servoType;

    const controllerEl = document.getElementById('editControllerType');
    if (controllerEl) controllerEl.value = controllerType;

    const invertEl = document.getElementById('editInvertDirection');
    if (invertEl) invertEl.value = String(invertDirection);

    const modelEl = document.getElementById('editServoModel');
    if (modelEl && modelId) modelEl.value = modelId;

    // PCA9685 configuration
    const addressEl = document.getElementById('editPca9685Address');
    if (addressEl) addressEl.value = '0x' + address.toString(16).toUpperCase();

    const frequencyEl = document.getElementById('editPca9685Frequency');
    if (frequencyEl) frequencyEl.value = frequency;

    const channelEl = document.getElementById('editPca9685Channel');
    if (channelEl) channelEl.value = channel;

    // Show/hide PCA9685 config
    const pca9685Config = document.getElementById('editPca9685Config');
    if (pca9685Config) {
      pca9685Config.style.display = controllerType === 'pca9685' ? 'block' : 'none';
    }

    // Set up event listeners
    if (controllerEl && !controllerEl._listenerAdded) {
      controllerEl._listenerAdded = true;
      controllerEl.addEventListener('change', function () {
        const pca9685Config = document.getElementById('editPca9685Config');
        if (pca9685Config) {
          pca9685Config.style.display = this.value === 'pca9685' ? 'block' : 'none';
        }
      });
    }

    // Set up channel grid
    const channelButtons = document.querySelectorAll('#editChannelGrid .channel-btn');
    channelButtons.forEach(btn => {
      btn.classList.remove('btn-primary');
      btn.classList.add('btn-outline-secondary');
      if (parseInt(btn.dataset.channel) === channel) {
        btn.classList.remove('btn-outline-secondary');
        btn.classList.add('btn-primary');
      }

      if (!btn._listenerAdded) {
        btn._listenerAdded = true;
        btn.addEventListener('click', function () {
          channelButtons.forEach(b => {
            b.classList.remove('btn-primary');
            b.classList.add('btn-outline-secondary');
          });
          this.classList.remove('btn-outline-secondary');
          this.classList.add('btn-primary');
          if (channelEl) channelEl.value = this.dataset.channel;
        });
      }
    });
  } // End loadEditServoValues - Fixed: Removed extra blank line that caused syntax error on some browsers

  function loadEditMotorValues(part, config) {
    // Decide control board
    var controlBoard = part.controlBoard || config.controlBoard;
    if (!controlBoard) {
      controlBoard = (part.rpwmPin != null || part.lpwmPin != null) ? 'BTS7960' : 'MDD10A';
    }

    console.log('loadEditMotorValues - controlBoard:', controlBoard, 'part:', part);

    var cbEl = document.getElementById('editControlBoard');
    if (cbEl) {
      cbEl.value = controlBoard;
      cbEl.addEventListener('change', function () {
        var v = this.value;
        document.getElementById('editMddGroup').style.display = (v === 'MDD10A') ? 'block' : 'none';
        document.getElementById('editBtsGroup').style.display = (v === 'BTS7960') ? 'block' : 'none';
      });
    }

    // Toggle groups initially - use setTimeout to ensure DOM is ready
    setTimeout(function () {
      if (document.getElementById('editMddGroup') && document.getElementById('editBtsGroup')) {
        document.getElementById('editMddGroup').style.display = (controlBoard === 'MDD10A') ? 'block' : 'none';
        document.getElementById('editBtsGroup').style.display = (controlBoard === 'BTS7960') ? 'block' : 'none';
      }

      // Populate pins
      const directionPin = part.directionPin || config.directionPin;
      const pwmPin = part.pwmPin || config.pwmPin;
      const rpwmPin = (part.rpwmPin != null ? part.rpwmPin : config.rpwmPin);
      const lpwmPin = (part.lpwmPin != null ? part.lpwmPin : config.lpwmPin);
      const renPin = (part.renPin != null ? part.renPin : config.renPin);
      const lenPin = (part.lenPin != null ? part.lenPin : config.lenPin);
      const maxDuration = config.maxDuration || part.maxDuration || 5000;

      console.log('Motor pins - RPWM:', rpwmPin, 'LPWM:', lpwmPin, 'R_EN:', renPin, 'L_EN:', lenPin);

      var dirEl = document.getElementById('editDirectionPin'); if (dirEl && directionPin != null) dirEl.value = directionPin;
      var pwmEl = document.getElementById('editPwmPin'); if (pwmEl && pwmPin != null) pwmEl.value = pwmPin;
      var rpEl = document.getElementById('editRpwmPin');
      if (rpEl && rpwmPin != null) {
        rpEl.value = rpwmPin;
        console.log('Set RPWM pin to:', rpwmPin);
      }
      var lpEl = document.getElementById('editLpwmPin');
      if (lpEl && lpwmPin != null) {
        lpEl.value = lpwmPin;
        console.log('Set LPWM pin to:', lpwmPin);
      }
      var reEl = document.getElementById('editRenPin');
      if (reEl && renPin != null) {
        reEl.value = renPin;
        console.log('Set R_EN pin to:', renPin);
      }
      var leEl = document.getElementById('editLenPin');
      if (leEl && lenPin != null) {
        leEl.value = lenPin;
        console.log('Set L_EN pin to:', lenPin);
      }

      var maxDurEl = document.getElementById('editMaxDuration'); if (maxDurEl) maxDurEl.value = maxDuration;
    }, 100);
  }

  function loadEditStepperValues(part, config) {
    const s = part.stepPin ?? config.stepPin;
    const d = part.dirPin ?? config.dirPin;
    const e = part.enablePin ?? config.enablePin;
    const micro = (config && config.microstepping != null) ? config.microstepping : 16;
    const spr = (config && config.stepsPerRevolution != null) ? config.stepsPerRevolution : 200;

    const sEl = document.getElementById('editStepPin'); if (sEl && s != null) sEl.value = s;
    const dEl = document.getElementById('editDirPin'); if (dEl && d != null) dEl.value = d;
    const eEl = document.getElementById('editEnablePin'); if (eEl && e != null) eEl.value = e;
    const mEl = document.getElementById('editMicrostepping'); if (mEl) mEl.value = String(micro);
    const sprEl = document.getElementById('editStepsPerRev'); if (sprEl) sprEl.value = spr;
  }

  function loadEditLinearActuatorValues(part, config) {
    // Decide control board
    var controlBoard = part.controlBoard || config.controlBoard;
    if (!controlBoard) {
      controlBoard = (part.rpwmPin != null || part.lpwmPin != null) ? 'BTS7960' : 'MDD10A';
    }
    var cbEl = document.getElementById('editControlBoard');
    if (cbEl) {
      cbEl.value = controlBoard;
      cbEl.addEventListener('change', function () {
        var v = this.value;
        document.getElementById('editMddGroup').style.display = (v === 'MDD10A') ? 'block' : 'none';
        document.getElementById('editBtsGroup').style.display = (v === 'BTS7960') ? 'block' : 'none';
      });
    }
    // Toggle groups initially
    if (document.getElementById('editMddGroup') && document.getElementById('editBtsGroup')) {
      document.getElementById('editMddGroup').style.display = (controlBoard === 'MDD10A') ? 'block' : 'none';
      document.getElementById('editBtsGroup').style.display = (controlBoard === 'BTS7960') ? 'block' : 'none';
    }

    // Populate pins
    const directionPin = part.directionPin || config.directionPin;
    const pwmPin = part.pwmPin || config.pwmPin;
    const rpwmPin = (part.rpwmPin != null ? part.rpwmPin : config.rpwmPin);
    const lpwmPin = (part.lpwmPin != null ? part.lpwmPin : config.lpwmPin);
    const renPin = (part.renPin != null ? part.renPin : config.renPin);
    const lenPin = (part.lenPin != null ? part.lenPin : config.lenPin);
    const maxExtension = config.maxExtension || part.maxExtension || 15000;
    const maxRetraction = config.maxRetraction || part.maxRetraction || 15000;

    var dirEl = document.getElementById('editDirectionPin'); if (dirEl && directionPin != null) dirEl.value = directionPin;
    var pwmEl = document.getElementById('editPwmPin'); if (pwmEl && pwmPin != null) pwmEl.value = pwmPin;
    var rpEl = document.getElementById('editRpwmPin'); if (rpEl && rpwmPin != null) rpEl.value = rpwmPin;
    var lpEl = document.getElementById('editLpwmPin'); if (lpEl && lpwmPin != null) lpEl.value = lpwmPin;
    var reEl = document.getElementById('editRenPin'); if (reEl && renPin != null) reEl.value = renPin;
    var leEl = document.getElementById('editLenPin'); if (leEl && lenPin != null) leEl.value = lenPin;

    var maxExtEl = document.getElementById('editMaxExtension'); if (maxExtEl) maxExtEl.value = maxExtension;
    var maxRetEl = document.getElementById('editMaxRetraction'); if (maxRetEl) maxRetEl.value = maxRetraction;
  }

  function loadEditLightValues(part, config) {
    const pin = part.pin || config.pin;
    const brightness = config.brightness || 100;

    const pinEl = document.getElementById('editLightPin');
    if (pinEl && pin != null) pinEl.value = pin;

    const brightnessEl = document.getElementById('editBrightness');
    if (brightnessEl) brightnessEl.value = brightness;
  }

  function loadEditSensorValues(part, config, type) {
    const pin = part.pin || config.pin;
    const sensitivity = config.sensitivity || 5;
    const windowMs = config.windowMs || 100;

    const pinEl = document.getElementById('editSensorPin');
    if (pinEl && pin != null) pinEl.value = pin;

    if (type === 'motion_sensor') {
      const sensEl = document.getElementById('editSensitivity');
      if (sensEl) sensEl.value = sensitivity;

      const windowEl = document.getElementById('editWindowMs');
      if (windowEl) windowEl.value = windowMs;
    }
  }

  function loadEditWebcamValues(part, config) {
    const devicePath = config.devicePath || '/dev/video0';
    const deviceId = config.deviceId || 0;
    const width = config.width || 1280;
    const height = config.height || 720;
    const fps = config.fps || 30;

    const pathEl = document.getElementById('editDevicePath');
    if (pathEl) pathEl.value = devicePath;

    const idEl = document.getElementById('editDeviceId');
    if (idEl) idEl.value = deviceId;

    const widthEl = document.getElementById('editWidth');
    if (widthEl) widthEl.value = width;

    const heightEl = document.getElementById('editHeight');
    if (heightEl) heightEl.value = height;

    const fpsEl = document.getElementById('editFps');
    if (fpsEl) fpsEl.value = fps;
  }

  function loadEditMicrophoneValues(part, config) {
    const device = config.device || 'default';
    const sampleRate = config.sampleRate || 44100;
    const gain = config.gain || 50;

    const deviceEl = document.getElementById('editMicDevice');
    if (deviceEl) deviceEl.value = device;

    const rateEl = document.getElementById('editSampleRate');
    if (rateEl) rateEl.value = sampleRate;

    const gainEl = document.getElementById('editGain');
    if (gainEl) gainEl.value = gain;
  }

  function loadEditSpeakerValues(part, config) {
    const device = config.device || 'default';
    const volume = config.volume || 80;
    const bass = config.bass || 0;
    const treble = config.treble || 0;

    const deviceEl = document.getElementById('editSpeakerDevice');
    if (deviceEl) deviceEl.value = device;

    const volumeEl = document.getElementById('editVolume');
    if (volumeEl) volumeEl.value = volume;

    const bassEl = document.getElementById('editBass');
    if (bassEl) bassEl.value = bass;

    const trebleEl = document.getElementById('editTreble');
    if (trebleEl) trebleEl.value = treble;
  }

