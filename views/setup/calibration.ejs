                  if (details) details.textContent = sensorDetectionCount + ' detection' + (sensorDetectionCount !== 1 ? 's' : '') + ' \u2022 sensor hold time ~30-40s \u2022 stay still to reset';
                } else {
                  if (lastState === 1) {
                    var dur = motionStartTime ? ((Date.now() - motionStartTime) / 1000).toFixed(1) : '?';
                    addLogEntry('Motion cleared after ' + dur + 's', 'clear');
                    motionStartTime = null;
                  }
                  sensorHighReadCount = 0;
                  if (indicator) { indicator.style.backgroundColor = '#198754'; indicator.style.borderColor = '#198754'; indicator.style.boxShadow = 'none'; indicator.style.animation = 'none'; }
                  if (status) { status.textContent = 'No Motion'; status.className = 'fs-5 fw-bold text-success mb-1'; }
                  if (details) details.textContent = sensorDetectionCount > 0 ? sensorDetectionCount + ' detection' + (sensorDetectionCount !== 1 ? 's' : '') : 'Listening...';
                }
                lastState = result.v;
