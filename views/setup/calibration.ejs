    // Sweep test: move from min to max 3 times at 100% speed
    async function runSweepTest() {
      var partId = window.selectedPartId;
      if (!partId) { alert('No part selected'); return; }
      if (!currentCalProfile || !currentCalProfile.bounds) {
        alert('Set Min and Max bounds first before running sweep test.');
        return;
      }
      var bounds = currentCalProfile.bounds;
      var minP = bounds.minP;
      var maxP = bounds.maxP;
      if (minP == null || maxP == null) {
        alert('Both Min and Max bounds must be set for sweep test.');
        return;
      }
      if (minP >= maxP) {
        alert('Min must be less than Max to sweep.');
        return;
      }

      var btn = document.getElementById('btnTestSweep');
      if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Sweeping...';
      }

      var SWEEPS = 3;
      var SPEED = 100;

      try {
        for (var i = 0; i < SWEEPS; i++) {
          // Go to min
          var res1 = await fetch('/api/calibration/' + encodeURIComponent(partId) + '/goto', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ p: minP, speedPct: SPEED })
          });
          var d1 = await res1.json();
          if (d1.targetP != null) updateCurrentPositionDisplay(d1.targetP);

          // Pause to let the servo/actuator reach position
          var range = maxP - minP;
          var travelMs = Math.max(300, Math.round(range * 1500));
          await new Promise(function (r) { setTimeout(r, travelMs); });

          // Go to max
          var res2 = await fetch('/api/calibration/' + encodeURIComponent(partId) + '/goto', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ p: maxP, speedPct: SPEED })
          });
          var d2 = await res2.json();
          if (d2.targetP != null) updateCurrentPositionDisplay(d2.targetP);

          await new Promise(function (r) { setTimeout(r, travelMs); });
        }

        // Return to midpoint after sweep
        var mid = (minP + maxP) / 2;
        var res3 = await fetch('/api/calibration/' + encodeURIComponent(partId) + '/goto', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ p: mid, speedPct: SPEED })
        });
        var d3 = await res3.json();
        if (d3.targetP != null) updateCurrentPositionDisplay(d3.targetP);
      } catch (err) {
        console.error('Sweep test error:', err);
        alert('Sweep test failed: ' + err.message);
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.innerHTML = '<i class="bi bi-arrows"></i> Sweep Test';
        }
      }
    }
    window.runSweepTest = runSweepTest;

    // Preset management
    function renderPresetsUI(presets) {
      const container = document.getElementById('presetsContainer');
      if (!container) return;

      if (!presets || presets.length === 0) {
        container.innerHTML = '<em class="text-muted">No presets defined</em>';
        return;
      }

      container.innerHTML = presets.map(p => `
        <div class="d-flex align-items-center gap-2 mb-2">
          <button class="btn btn-sm btn-outline-primary flex-fill" onclick="gotoPreset('${p.name}')">
            ${p.name}
          </button>
          <button class="btn btn-sm btn-outline-danger" onclick="deletePreset('${p.name}')" title="Delete">
            <i class="bi bi-trash"></i>
          </button>
        </div>
      `).join('');
    }

    async function addPreset() {
      const partId = window.selectedPartId;
      if (!partId || !currentCalProfile) return;

      const nameInput = document.getElementById('presetNameInput');
      const name = nameInput ? nameInput.value.trim() : '';
      if (!name) {
        alert('Enter a preset name');
        return;
      }

      // For now, prompt for position value since we don't have real-time position tracking yet
      const posStr = prompt('Enter position value (0.0 to 1.0):', '0.5');
      if (!posStr) return;

      const position = parseFloat(posStr);
      if (isNaN(position) || position < 0 || position > 1) {
        alert('Invalid position. Must be between 0.0 and 1.0');
        return;
      }

      try {
        // Update profile with new preset
        const updatedPresets = [...(currentCalProfile.presets || [])];
        const existingIndex = updatedPresets.findIndex(p => p.name === name);
        if (existingIndex >= 0) {
          updatedPresets[existingIndex].position = position;
        } else {
          updatedPresets.push({ name, position });
        }

        // Send complete updated profile
        const updatedProfile = { ...currentCalProfile, presets: updatedPresets };
        const updateRes = await fetch(`/api/calibration/${partId}/profile`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updatedProfile)
        });

        const updateData = await updateRes.json();
        if (!updateData.success) {
          alert('Failed to save preset: ' + (updateData.error || 'Unknown error'));
        } else {
          nameInput.value = '';
          await loadUnifiedCalibration(partId, window.selectedPart);
        }
      } catch (err) {
        console.error('Add preset error:', err);
        alert('Add preset error: ' + err.message);
      }
    }

    async function deletePreset(name) {
      const partId = window.selectedPartId;
      if (!partId || !currentCalProfile) return;

      if (!confirm(`Delete preset "${name}"?`)) return;

      try {
        const updatedPresets = (currentCalProfile.presets || []).filter(p => p.name !== name);

        // Send complete updated profile
        const updatedProfile = { ...currentCalProfile, presets: updatedPresets };
        const res = await fetch(`/api/calibration/${partId}/profile`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updatedProfile)
        });

        const data = await res.json();
        if (!data.success) {
          alert('Failed to delete preset: ' + (data.error || 'Unknown error'));
        } else {
          await loadUnifiedCalibration(partId, window.selectedPart);
        }
      } catch (err) {
        console.error('Delete preset error:', err);
        alert('Delete preset error: ' + err.message);
      }
    }

    async function gotoPreset(name) {
      const partId = window.selectedPartId;
      if (!partId || !currentCalProfile) return;

      const preset = currentCalProfile.presets.find(p => p.name === name);
      if (!preset) {
        alert('Preset not found: ' + name);
        return;
      }

      try {
        const res = await fetch(`/api/calibration/${partId}/goto`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ p: preset.position })
        });

        const data = await res.json();
        if (!data.success) {
          alert('Goto preset failed: ' + (data.error || 'Unknown error'));
        }
      } catch (err) {
        console.error('Goto preset error:', err);
        alert('Goto preset error: ' + err.message);
      }
    }

    // Learn movement (for openloop-linear parts)
    async function runLearnMovement(pwmPercent) {
      const partId = window.selectedPartId;
      if (!partId) return;

      if (!confirm(`Run learn-openloop at ${pwmPercent}% PWM? This will move the part to learn speed/distance.`)) return;

      try {
        const res = await fetch(`/api/calibration/${partId}/learn-openloop`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ pwmPercent })
        });

        const data = await res.json();
        if (!data.success) {
          alert('Learn movement failed: ' + (data.error || 'Unknown error'));
        } else {
          alert(`Learn complete!\nDistance: ${data.distanceMoved}\nTime: ${data.elapsedMs}ms`);
          // Reload profile to get updated speed calibration
          await loadUnifiedCalibration(partId, window.selectedPart);
        }
      } catch (err) {
        console.error('Learn movement error:', err);
        alert('Learn movement error: ' + err.message);
      }
    }

