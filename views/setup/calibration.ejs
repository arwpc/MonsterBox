            <input id="searchDevices" type="text" class="form-control" placeholder="Search" data-bs-toggle="tooltip" data-bs-placement="top" title="Filter parts by name or type">
          </div>
        </div>
        <div class="card-body p-0">
          <div class="p-2 d-flex align-items-center justify-content-between gap-2 border-bottom">
            <div class="form-check m-0">
              <input class="form-check-input" type="checkbox" id="selectAllParts" data-bs-toggle="tooltip" data-bs-placement="top" title="Select or deselect all visible parts for bulk operations">
              <label class="form-check-label small" for="selectAllParts">Select All</label>
            </div>
            <button class="btn btn-outline-danger btn-sm" id="deleteSelectedBtn" disabled data-bs-toggle="tooltip" data-bs-placement="top" title="Permanently delete all checked parts and their calibration data">
              <i class="bi bi-trash"></i> Delete Selected
            </button>
          </div>
