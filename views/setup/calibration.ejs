    // Markers wiring (outside renderControls to keep handlers stable)
    function unitFor(part) {
      if (!part) return undefined;
      if (part.type === 'servo' && String(part.config?.servoType || 'standard') !== 'continuous') return 'deg';
      return undefined;
    }
    async function saveMarkerFromField(fieldId, name) {
      if (!selected) return;
      const el = document.getElementById(fieldId);
      if (!el) return;
      const raw = el.value;
      const num = raw !== '' ? Number(raw) : undefined;
      const body = { name, kind: 'absolute', value: num, unit: unitFor(selected) };
      const response = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/markers`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
      }).catch(() => null);
      if (response && response.ok) {
        await loadMarkers();
      }
    }

    async function setMarkerFromCurrent(fieldId, name) {
      if (!selected) return;

      let currentValue = null;
      try {
        // Try hardware-based position first
        if (selected.type === 'servo') {
          const servoType = String(selected.config?.servoType || 'standard').toLowerCase();
          if (servoType !== 'continuous') {
            const statusResponse = await fetch(`/setup/calibration/api/standard_servo/${encodeURIComponent(selected.id)}/status`).catch(() => null);
            if (statusResponse && statusResponse.ok) {
              const statusData = await statusResponse.json().catch(() => null);
              if (statusData && statusData.currentAngle !== undefined) {
                currentValue = statusData.currentAngle;
              }
            }
          }
        } else if (selected.type === 'linear_actuator') {
          const statusResponse = await fetch(`/setup/calibration/api/linear_actuator/${encodeURIComponent(selected.id)}/status`).catch(() => null);
          if (statusResponse && statusResponse.ok) {
            const statusData = await statusResponse.json().catch(() => null);
            if (statusData && statusData.currentPosition !== undefined) {
              currentValue = statusData.currentPosition;
            }
          }
        }
      } catch (_) { /* ignore hardware errors; will fallback */ }

      // Hardware value wins; otherwise fallback to the input field value
      if (currentValue === null || isNaN(currentValue)) {
        const el = document.getElementById(fieldId);
        const raw = el ? el.value : '';
        if (raw === '') {
          showToast('Enter a value first or move hardware to a position', 'error');
          return;
        }
        const num = Number(raw);
        if (isNaN(num)) {
          showToast('Invalid number', 'error');
          return;
        }
        currentValue = num;
      }

      // Reflect in field
      const el = document.getElementById(fieldId);
      if (el) el.value = currentValue;

      // Save the marker
      const body = { name, kind: 'absolute', value: currentValue, unit: unitFor(selected) };
      const response = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/markers`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
      }).catch(() => null);

      if (response && response.ok) {
        await loadMarkers();
        showToast(`${name} marker set to ${currentValue}${unitFor(selected) ? ' ' + unitFor(selected) : ''}`, 'success');
      } else {
        showToast('Failed to save marker', 'error');
      }
    }
    async function goToField(fieldId) {
      if (!selected) return;
      const el = document.getElementById(fieldId);
      const num = el && el.value !== '' ? Number(el.value) : undefined;
      if (selected.type === 'servo' && String(selected.config?.servoType || 'standard') !== 'continuous' && typeof num === 'number') {
        await fetch(`/setup/calibration/api/standard_servo/${encodeURIComponent(selected.id)}/move`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ angle: Math.round(num) }) });
      }
    }
    const setMinBtn = document.getElementById('setMinBtn'); if (setMinBtn) setMinBtn.addEventListener('click', () => setMarkerFromCurrent('minValue', 'Min'));
    const setMidBtn = document.getElementById('setMidBtn'); if (setMidBtn) setMidBtn.addEventListener('click', () => setMarkerFromCurrent('midValue', 'Mid'));
    const setMaxBtn = document.getElementById('setMaxBtn'); if (setMaxBtn) setMaxBtn.addEventListener('click', () => setMarkerFromCurrent('maxValue', 'Max'));
    const goMinBtn = document.getElementById('goMinBtn'); if (goMinBtn) goMinBtn.addEventListener('click', () => goToField('minValue'));
    const goMidBtn = document.getElementById('goMidBtn'); if (goMidBtn) goMidBtn.addEventListener('click', () => goToField('midValue'));
    const goMaxBtn = document.getElementById('goMaxBtn'); if (goMaxBtn) goMaxBtn.addEventListener('click', () => goToField('maxValue'));

    // Add marker button
    const addMarkerBtn = document.getElementById('addMarkerBtn');
    if (addMarkerBtn) {
      addMarkerBtn.addEventListener('click', async () => {
        const nameInput = document.getElementById('newMarkerName');
        const name = nameInput ? nameInput.value.trim() : '';

