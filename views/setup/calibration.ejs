          function populateEditConfigValues(part, config) {
            const type = part.type;

            // Populate type-specific values
            switch (type) {
              case 'servo':
                setValueIfExists('editServoPin', part.pin);
                setValueIfExists('editServoType', config.servoType || 'standard');
                setValueIfExists('editControllerType', config.controllerType || 'gpio');
                setValueIfExists('editServoModel', config.modelId || '');

                // Handle invert direction checkbox
                const invertCheckbox = document.getElementById('editInvertDirection');
                if (invertCheckbox) {
                  invertCheckbox.checked = !!config.invertDirection;
                }

                if (config.controllerType === 'pca9685') {
                  const pca9685Config = document.getElementById('editPca9685Config');
                  if (pca9685Config) {
                    pca9685Config.style.display = 'block';
                    setValueIfExists('editPca9685Address', config.address ? '0x' + config.address.toString(16) : '0x40');
                    setValueIfExists('editPca9685Frequency', config.pca9685Frequency || 50);
                    setValueIfExists('editPca9685Channel', config.channel);

                    // Select the PCA9685 channel button
                    if (config.channel !== undefined) {
                      selectEditPCA9685Channel(config.channel);
                    }
                  }
                }
                break;

              case 'motor':
              case 'linear_actuator':
                setValueIfExists('editDirectionPin', part.directionPin);
                setValueIfExists('editPwmPin', part.pwmPin);
                if (type === 'linear_actuator') {
                  setValueIfExists('editMaxExtension', part.maxExtension || config.maxExtension);
                  setValueIfExists('editMaxRetraction', part.maxRetraction || config.maxRetraction);
                } else {
                  setValueIfExists('editMaxDuration', part.maxDuration || config.maxDuration || 10000);
                }
                break;

              case 'light':
              case 'led':
                setValueIfExists('editLightPin', part.pin);
                if (type === 'led') {
                  setValueIfExists('editDefaultBrightness', config.defaultBrightness || 50);
                }
                break;

              case 'sensor':
              case 'motion_sensor':
                setValueIfExists('editSensorPin', part.pin);
                if (type === 'motion_sensor') {
                  setValueIfExists('editMotionSensitivity', config.sensitivity || 5);
                  setValueIfExists('editMotionWindow', config.windowMs || 100);
                } else {
                  setValueIfExists('editSensorType', config.sensorType || 'digital');
                }
                break;

              case 'webcam':
                setValueIfExists('editWebcamDevice', config.devicePath);
                setValueIfExists('editWebcamWidth', config.width || 640);
                setValueIfExists('editWebcamHeight', config.height || 480);
                setValueIfExists('editWebcamFps', config.fps || 30);
                // Load webcam devices
                setTimeout(() => {
                  if (typeof scanWebcamsForEdit === 'function') scanWebcamsForEdit();
                }, 100);
                break;

              case 'microphone':
                setValueIfExists('editAudioInput', config.deviceId);
                setValueIfExists('editMicSampleRate', config.sampleRate || 48000);
                setValueIfExists('editMicChannels', config.channels || 1);
                setValueIfExists('editMicGain', config.gain || 50);
                setValueIfExists('editMicSensitivity', config.sensitivity || 1.2);
                setValueIfExists('editMicWindow', config.windowMs || 100);
                // Load audio inputs
                setTimeout(() => {
                  if (typeof scanAudioInputsForEdit === 'function') scanAudioInputsForEdit();
                }, 100);
                break;

              case 'speaker':
                setValueIfExists('editAudioOutput', config.audioDeviceId);
                setValueIfExists('editSpeakerVolume', config.volume || 50);
                setValueIfExists('editSpeakerBass', config.bass || 0);
                setValueIfExists('editSpeakerTreble', config.treble || 0);
                // Load audio outputs
                setTimeout(() => {
                  if (typeof scanAudioOutputsForEdit === 'function') scanAudioOutputsForEdit();
                }, 100);
                break;
            }
          }

          function setValueIfExists(elementId, value) {
            const element = document.getElementById(elementId);
            if (element && value !== undefined && value !== null) {
              element.value = value;
            }
          }

        }

        function renderBottomRail(items) {
          bottomRail.innerHTML = '';
          items.forEach(p => {
            const chip = document.createElement('span');
            chip.className = 'badge rounded-pill text-bg-dark marker-chip';
            chip.textContent = `${p.name} · Min/Mid/Max`;
            bottomRail.appendChild(chip);
          });
        }


        // Markers wiring (outside renderControls to keep handlers stable)
        function unitFor(part) {
          if (!part) return undefined;
          if (part.type === 'servo' && String(part.config?.servoType || 'standard') !== 'continuous') return 'deg';
          return undefined;
        }
        async function saveMarkerFromField(fieldId, name) {
          if (!selected) return;
          const el = document.getElementById(fieldId);
          if (!el) return;
          const raw = el.value;
          const num = raw !== '' ? Number(raw) : undefined;
          const body = { name, kind: 'absolute', value: num, unit: unitFor(selected) };
          await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/markers`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
          }).catch(() => { });
        }
        async function goToField(fieldId) {
          if (!selected) return;
          const el = document.getElementById(fieldId);
          const num = el && el.value !== '' ? Number(el.value) : undefined;
          if (selected.type === 'servo' && String(selected.config?.servoType || 'standard') !== 'continuous' && typeof num === 'number') {
            await fetch(`/setup/calibration/api/standard_servo/${encodeURIComponent(selected.id)}/move`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ angle: Math.round(num) }) });
          }
        }
        const setMinBtn = document.getElementById('setMinBtn'); if (setMinBtn) setMinBtn.addEventListener('click', () => saveMarkerFromField('minValue', 'Min'));
        const setMidBtn = document.getElementById('setMidBtn'); if (setMidBtn) setMidBtn.addEventListener('click', () => saveMarkerFromField('midValue', 'Mid'));
        const setMaxBtn = document.getElementById('setMaxBtn'); if (setMaxBtn) setMaxBtn.addEventListener('click', () => saveMarkerFromField('maxValue', 'Max'));
        const goMinBtn = document.getElementById('goMinBtn'); if (goMinBtn) goMinBtn.addEventListener('click', () => goToField('minValue'));
        const goMidBtn = document.getElementById('goMidBtn'); if (goMidBtn) goMidBtn.addEventListener('click', () => goToField('midValue'));
        const goMaxBtn = document.getElementById('goMaxBtn'); if (goMaxBtn) goMaxBtn.addEventListener('click', () => goToField('maxValue'));

        loadParts().catch(e => console.error(e));

        // Add Part Modal functionality
        const partTypes = {
          motor: { icon: '🔄', description: 'DC motors for movement', requiresPin: false },
          linear_actuator: { icon: '🦴', description: 'extending/retracting movements', requiresPin: false },
          light: { icon: '💡', description: 'basic on/off lighting', requiresPin: true },
          led: { icon: '🔆', description: 'PWM-controlled with brightness', requiresPin: true },
          servo: { icon: '🦷', description: 'precise angle control: standard, continuous, feedback', requiresPin: true },
          sensor: { icon: '📡', description: 'digital/analog sensors', requiresPin: true },
          motion_sensor: { icon: '🔍', description: 'PIR motion detection', requiresPin: true },
          webcam: { icon: '📹', description: 'video capture devices', requiresPin: false },
          microphone: { icon: '🎤', description: 'audio input devices', requiresPin: false },
          speaker: { icon: '🔊', description: 'audio output devices', requiresPin: false },
          head_tracking: { icon: '👁️', description: 'head position tracking', requiresPin: false }
        };

        // Initialize part type dropdown
        function initAddPartModal() {
          const typeSelect = document.getElementById('addPartType');
          if (!typeSelect) return;

          typeSelect.innerHTML = '<option value="">Select Part Type</option>';
          Object.keys(partTypes).forEach(type => {
            const partType = partTypes[type];
            const option = document.createElement('option');
            option.value = type;
            option.textContent = `${partType.icon} ${type.replace('_', ' ').toUpperCase()} - ${partType.description}`;
            typeSelect.appendChild(option);
          });
        }

        // Handle part type change
        window.onAddPartTypeChange = function() {
          const typeSelect = document.getElementById('addPartType');
          const modelGroup = document.getElementById('addModelGroup');
          const configArea = document.getElementById('addPartConfigArea');

          if (!typeSelect || !typeSelect.value) {
            modelGroup.style.display = 'none';
            configArea.innerHTML = '';
            return;
          }

          const type = typeSelect.value;
          const partType = partTypes[type];

          // Show model selection for supported types
          if (['servo', 'webcam'].includes(type)) {
            modelGroup.style.display = 'block';
            loadModelsForType(type);
          } else {
            modelGroup.style.display = 'none';
          }

          // Generate type-specific configuration
          configArea.innerHTML = generatePartConfig(type, partType);
        };

        function loadModelsForType(type) {
          const modelSelect = document.getElementById('addModelSelect');
          if (!modelSelect) return;

          fetch(`/setup/models/api/${type}`)
            .then(r => r.json())
            .then(data => {
              modelSelect.innerHTML = '<option value="">Select Model (optional)</option>';
              const models = (data && data.models) || [];
              models.forEach(model => {
                const option = document.createElement('option');
                option.value = model.id;
                option.textContent = model.name || model.id;
                modelSelect.appendChild(option);
              });
            })
            .catch(() => {
              modelSelect.innerHTML = '<option value="">Error loading models</option>';
            });
        }

        function generatePartConfig(type, partType) {
          let html = '';

          // GPIO Pin for parts that require it
          if (partType.requiresPin) {
            html += `
              <div class="row">
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="addGpioPin" class="form-label">GPIO Pin</label>
                    <input type="number" class="form-control" id="addGpioPin" name="pin" min="1" max="40" required>
                  </div>
                </div>
              </div>
            `;
          }

          // Type-specific configurations
          switch (type) {
            case 'servo':
              html += generateServoConfig();
              break;
            case 'motor':
            case 'linear_actuator':
              html += generateMotorConfig(type);
              break;
            case 'webcam':
              html += generateWebcamConfig();
              break;
            case 'microphone':
              html += generateMicrophoneConfig();
              break;
            case 'speaker':
              html += generateSpeakerConfig();
              break;
          }

          return html;
        }

