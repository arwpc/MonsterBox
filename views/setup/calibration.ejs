            try {
              var response = await fetch('/api/parts/' + encodeURIComponent(part.id) + '/gpio-read');
              var result = await response.json();
              if (response.ok && result.v !== undefined) {
                var motion = result.v === 1;
                if (motion) {
                  sensorHighReadCount++;
                  if (lastState !== 1) {
                    sensorDetectionCount++;
                    motionStartTime = Date.now();
                    addLogEntry('Motion detected (#' + sensorDetectionCount + ')', 'motion');
                  }
                  if (indicator) { indicator.style.backgroundColor = '#dc3545'; indicator.style.borderColor = '#dc3545'; indicator.style.boxShadow = '0 0 15px rgba(220,53,69,0.6)'; indicator.style.animation = 'sensorPulse 1s infinite'; }
                  var dur = motionStartTime ? Math.round((Date.now() - motionStartTime) / 1000) : 0;
