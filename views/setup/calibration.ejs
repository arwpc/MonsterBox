  function loadEditConfigValues(part, config, type) {
    // Load values based on part type
    switch (type) {
      case 'servo':
        loadEditServoValues(part, config);
        break;
      case 'motor':
        loadEditMotorValues(part, config);
        break;
      case 'linear_actuator':
        loadEditLinearActuatorValues(part, config);
        break;
      case 'stepper':
        loadEditStepperValues(part, config);
        break;
      case 'light':
      case 'led':
        loadEditLightValues(part, config);
        break;
      case 'sensor':
      case 'motion_sensor':
        loadEditSensorValues(part, config, type);
        break;
      case 'webcam':
        loadEditWebcamValues(part, config);
        break;
      case 'microphone':
        loadEditMicrophoneValues(part, config);
        break;
      case 'speaker':
        loadEditSpeakerValues(part, config);
        break;
    }
  }

  function loadEditServoValues(part, config) {
    const pin = part.pin || config.pin;
    const servoType = config.servoType || 'standard';

    const controllerType = config.controllerType || 'gpio';
    const invertDirection = config.invertDirection || false;
    const modelId = part.modelId || config.modelId;
    const address = config.address || config.pca9685Address || 64;
    const frequency = config.frequency || config.pca9685Frequency || 50;
    const channel = config.channel || config.pca9685Channel || 0;

    // Set basic values
    const pinEl = document.getElementById('editServoPin');
    if (pinEl && pin != null) pinEl.value = pin;

    const typeEl = document.getElementById('editServoType');
    if (typeEl) typeEl.value = servoType;

    const controllerEl = document.getElementById('editControllerType');
    if (controllerEl) controllerEl.value = controllerType;

    const invertEl = document.getElementById('editInvertDirection');
    if (invertEl) invertEl.value = String(invertDirection);

    const modelEl = document.getElementById('editServoModel');
    if (modelEl && modelId) modelEl.value = modelId;

    // PCA9685 configuration
    const addressEl = document.getElementById('editPca9685Address');
    if (addressEl) addressEl.value = '0x' + address.toString(16).toUpperCase();

    const frequencyEl = document.getElementById('editPca9685Frequency');
    if (frequencyEl) frequencyEl.value = frequency;

    const channelEl = document.getElementById('editPca9685Channel');
    if (channelEl) channelEl.value = channel;

    // Show/hide PCA9685 config
    const pca9685Config = document.getElementById('editPca9685Config');
    if (pca9685Config) {
      pca9685Config.style.display = controllerType === 'pca9685' ? 'block' : 'none';
    }

    // Set up event listeners
    if (controllerEl && !controllerEl._listenerAdded) {
      controllerEl._listenerAdded = true;
      controllerEl.addEventListener('change', function () {
        const pca9685Config = document.getElementById('editPca9685Config');
        if (pca9685Config) {
          pca9685Config.style.display = this.value === 'pca9685' ? 'block' : 'none';
        }
      });
    }

    // Render the PCA9685 board visual with current channel highlighted
    if (channelEl) channelEl.value = channel;
    window.generateEditPCA9685Channels();
  } // End loadEditServoValues - Fixed: Removed extra blank line that caused syntax error on some browsers

  function loadEditMotorValues(part, config) {
    // Decide control board
    var controlBoard = part.controlBoard || config.controlBoard;
    if (!controlBoard) {
      controlBoard = (part.rpwmPin != null || part.lpwmPin != null) ? 'BTS7960' : 'MDD10A';
    }

    console.log('loadEditMotorValues - controlBoard:', controlBoard, 'part:', part);

    var cbEl = document.getElementById('editControlBoard');
    if (cbEl) {
      cbEl.value = controlBoard;
      cbEl.addEventListener('change', function () {
        var v = this.value;
        document.getElementById('editMddGroup').style.display = (v === 'MDD10A') ? 'block' : 'none';
        document.getElementById('editBtsGroup').style.display = (v === 'BTS7960') ? 'block' : 'none';
      });
    }

    // Toggle groups initially - use setTimeout to ensure DOM is ready
    setTimeout(function () {
      if (document.getElementById('editMddGroup') && document.getElementById('editBtsGroup')) {
        document.getElementById('editMddGroup').style.display = (controlBoard === 'MDD10A') ? 'block' : 'none';
        document.getElementById('editBtsGroup').style.display = (controlBoard === 'BTS7960') ? 'block' : 'none';
      }

      // Populate pins
      const directionPin = part.directionPin || config.directionPin;
      const pwmPin = part.pwmPin || config.pwmPin;
      const rpwmPin = (part.rpwmPin != null ? part.rpwmPin : config.rpwmPin);
      const lpwmPin = (part.lpwmPin != null ? part.lpwmPin : config.lpwmPin);
      const renPin = (part.renPin != null ? part.renPin : config.renPin);
      const lenPin = (part.lenPin != null ? part.lenPin : config.lenPin);
      const maxDuration = config.maxDuration || part.maxDuration || 5000;

      console.log('Motor pins - RPWM:', rpwmPin, 'LPWM:', lpwmPin, 'R_EN:', renPin, 'L_EN:', lenPin);

      var dirEl = document.getElementById('editDirectionPin'); if (dirEl && directionPin != null) dirEl.value = directionPin;
      var pwmEl = document.getElementById('editPwmPin'); if (pwmEl && pwmPin != null) pwmEl.value = pwmPin;
      var rpEl = document.getElementById('editRpwmPin');
      if (rpEl && rpwmPin != null) {
        rpEl.value = rpwmPin;
        console.log('Set RPWM pin to:', rpwmPin);
      }
      var lpEl = document.getElementById('editLpwmPin');
      if (lpEl && lpwmPin != null) {
        lpEl.value = lpwmPin;
        console.log('Set LPWM pin to:', lpwmPin);
      }
      var reEl = document.getElementById('editRenPin');
      if (reEl && renPin != null) {
        reEl.value = renPin;
        console.log('Set R_EN pin to:', renPin);
      }
      var leEl = document.getElementById('editLenPin');
      if (leEl && lenPin != null) {
        leEl.value = lenPin;
        console.log('Set L_EN pin to:', lenPin);
      }

      var maxDurEl = document.getElementById('editMaxDuration'); if (maxDurEl) maxDurEl.value = maxDuration;
    }, 100);
  }

  function loadEditStepperValues(part, config) {
    const s = part.stepPin ?? config.stepPin;
