        function startSensorMonitoring() {
          sensorMonitoringActive = true;
          sensorDetectionCount = 0;
          sensorHighReadCount = 0;
          var lastState = -1;
          var motionStartTime = null;
          var indicator = document.getElementById('motionIndicator');
          var status = document.getElementById('motionStatus');
          var details = document.getElementById('motionDetails');
          var st = document.getElementById('ctrlStatus');

          toggleBtn.className = 'btn btn-danger btn-lg';
          toggleBtn.innerHTML = '<i class="bi bi-stop-circle me-2"></i>Disable Monitoring';

          if (indicator) { indicator.style.backgroundColor = '#198754'; indicator.style.borderColor = '#198754'; indicator.style.boxShadow = 'none'; indicator.style.animation = 'none'; }
          if (status) { status.textContent = 'No Motion'; status.className = 'fs-5 fw-bold text-success mb-1'; }
          if (details) details.textContent = 'Listening on GPIO ' + part.pin + '...';
          addLogEntry('Monitoring started on GPIO ' + part.pin, 'info');

          // Fast poll using gpioget (~3ms per read, no GPIO handle leak)
          var pollBusy = false;
          sensorPollTimer = setInterval(async function () {
            if (!sensorMonitoringActive || pollBusy) return;
