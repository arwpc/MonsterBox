    // Initialize part type dropdown
    function initAddPartModal() {
      const typeSelect = document.getElementById('addPartType');
      if (!typeSelect) return;

      typeSelect.innerHTML = '<option value="">Select Part Type</option>';
      Object.keys(partTypes).forEach(type => {
        const partType = partTypes[type];
        const option = document.createElement('option');
        option.value = type;
        option.textContent = `${partType.icon} ${type.replace('_', ' ').toUpperCase()} - ${partType.description}`;
        typeSelect.appendChild(option);
      });
    }

    // Handle part type change
    window.onAddPartTypeChange = function () {
      const typeSelect = document.getElementById('addPartType');
      const modelGroup = document.getElementById('addModelGroup');
      const configArea = document.getElementById('addPartConfigArea');

      if (!typeSelect || !typeSelect.value) {
        modelGroup.style.display = 'none';
        configArea.innerHTML = '';
        return;
      }

      const type = typeSelect.value;
      const partType = partTypes[type];

      // Show model selection for supported types
      if (['servo', 'stepper', 'webcam'].includes(type)) {
        modelGroup.style.display = 'block';
        loadModelsForType(type);
      } else {
        modelGroup.style.display = 'none';
      }

      // Generate type-specific configuration
      configArea.innerHTML = generatePartConfig(type, partType);
    };

    function loadModelsForType(type) {
      const modelSelect = document.getElementById('addModelSelect');
      if (!modelSelect) return;

      const apiType = (type === 'stepper') ? 'motor' : type;
      fetch(`/setup/models/api/${apiType}`)
        .then(r => r.json())
        .then(data => {
          modelSelect.innerHTML = '<option value="">Select Model (optional)</option>';
          const models = (data && data.models) || [];
          models.forEach(model => {
            const option = document.createElement('option');
            option.value = model.id;
            option.textContent = model.name || model.id;
            modelSelect.appendChild(option);
          });
        })
        .catch(() => {
          modelSelect.innerHTML = '<option value="">Error loading models</option>';
        });
    }

    function generatePartConfig(type, partType) {
      let html = '';

      // GPIO Pin for parts that require it
      if (partType.requiresPin) {
        html += `
              <div class="row">
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="addGpioPin" class="form-label">GPIO Pin</label>
                    <input type="number" class="form-control" id="addGpioPin" name="pin" min="1" max="40" required>
                  </div>
                </div>
              </div>
            `;
      }

      // Type-specific configurations
      switch (type) {
        case 'servo':
          html += generateServoConfig();
          break;
        case 'motor':
        case 'linear_actuator':
          html += generateMotorConfig(type);
          break;
        case 'stepper':
          html += generateStepperConfig();
          break;
        case 'webcam':
          html += generateWebcamConfig();
          break;
        case 'microphone':
          html += generateMicrophoneConfig();
          break;
        case 'speaker':
          html += generateSpeakerConfig();
          break;
      }

      return html;
    }

