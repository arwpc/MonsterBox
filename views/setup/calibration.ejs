        // Save part changes function
        function savePartChanges() {
          if (!selected) {
            alert('No part selected');
            return;
          }

          const payload = {
            name: document.getElementById('editName').value,
            enabled: document.getElementById('editEnabled').checked,
            description: document.getElementById('editDescription').value,
            config: {}
          };

          // Handle advanced JSON config if provided
          try {
            const jsonConfig = document.getElementById('editConfig').value;
            if (jsonConfig.trim()) {
              payload.config = JSON.parse(jsonConfig);
            }
          } catch (e) {
            alert('Invalid JSON in advanced configuration');
            return;
          }

          // Collect type-specific configuration
          const type = selected.type;
          let config = payload.config;

          switch (type) {
            case 'servo':
              const pin = document.getElementById('editServoPin').value;
              if (pin) payload.pin = parseInt(pin, 10);

              config.servoType = document.getElementById('editServoType').value || 'standard';
              config.controllerType = document.getElementById('editControllerType').value || 'gpio';

              // Handle model selection
              const modelId = document.getElementById('editServoModel').value;
              if (modelId) {
                config.modelId = modelId;
              }

              // Handle invert direction checkbox
              const invertDirection = document.getElementById('editInvertDirection');
              if (invertDirection) {
                config.invertDirection = invertDirection.checked;
              }

              if (config.controllerType === 'pca9685') {
                const channel = document.getElementById('editPca9685Channel').value;
                const address = document.getElementById('editPca9685Address').value;
                const frequency = document.getElementById('editPca9685Frequency').value;

                if (channel !== '') config.channel = parseInt(channel, 10);
                if (address) {
                  config.address = address.startsWith('0x') ? parseInt(address, 16) : parseInt(address, 10);
                }
                if (frequency) config.pca9685Frequency = parseInt(frequency, 10);
              }
              break;

            case 'motor':
            case 'linear_actuator':
              const directionPin = document.getElementById('editDirectionPin').value;
              const pwmPin = document.getElementById('editPwmPin').value;

              if (directionPin) payload.directionPin = parseInt(directionPin, 10);
              if (pwmPin) payload.pwmPin = parseInt(pwmPin, 10);

              if (type === 'linear_actuator') {
                const maxExtension = document.getElementById('editMaxExtension').value;
                const maxRetraction = document.getElementById('editMaxRetraction').value;
                if (maxExtension) payload.maxExtension = parseInt(maxExtension, 10);
                if (maxRetraction) payload.maxRetraction = parseInt(maxRetraction, 10);
              } else {
                const maxDuration = document.getElementById('editMaxDuration').value;
                if (maxDuration) payload.maxDuration = parseInt(maxDuration, 10);
              }
              break;

            case 'light':
            case 'led':
              const lightPin = document.getElementById('editLightPin').value;
              if (lightPin) payload.pin = parseInt(lightPin, 10);

              if (type === 'led') {
                const brightness = document.getElementById('editDefaultBrightness').value;
                if (brightness !== '') config.defaultBrightness = parseInt(brightness, 10);
              }
              break;

            case 'sensor':
            case 'motion_sensor':
              const sensorPin = document.getElementById('editSensorPin').value;
              if (sensorPin) payload.pin = parseInt(sensorPin, 10);

              if (type === 'motion_sensor') {
                const sensitivity = document.getElementById('editMotionSensitivity').value;
                const windowMs = document.getElementById('editMotionWindow').value;
                if (sensitivity !== '') config.sensitivity = parseInt(sensitivity, 10);
                if (windowMs !== '') config.windowMs = parseInt(windowMs, 10);
              } else {
                config.sensorType = document.getElementById('editSensorType').value || 'digital';
              }
              break;

            case 'webcam':
              const webcamDevice = document.getElementById('editWebcamDevice').value;
              const width = document.getElementById('editWebcamWidth').value;
              const height = document.getElementById('editWebcamHeight').value;
              const fps = document.getElementById('editWebcamFps').value;

              if (webcamDevice) {
                config.devicePath = webcamDevice;
                const deviceId = webcamDevice.match(/\/dev\/video(\d+)/);
                if (deviceId) config.deviceId = parseInt(deviceId[1], 10);
              }
              if (width) config.width = parseInt(width, 10);
              if (height) config.height = parseInt(height, 10);
              if (fps) config.fps = parseInt(fps, 10);
              break;

            case 'microphone':
              const audioInput = document.getElementById('editAudioInput').value;
              const sampleRate = document.getElementById('editMicSampleRate').value;
              const channels = document.getElementById('editMicChannels').value;
              const gain = document.getElementById('editMicGain').value;
              const micSensitivity = document.getElementById('editMicSensitivity').value;
              const micWindow = document.getElementById('editMicWindow').value;

              if (audioInput) config.deviceId = audioInput;
              if (sampleRate) config.sampleRate = parseInt(sampleRate, 10);
              if (channels) config.channels = parseInt(channels, 10);
              if (gain !== '') config.gain = parseInt(gain, 10);
              if (micSensitivity !== '') config.sensitivity = parseFloat(micSensitivity);
              if (micWindow !== '') config.windowMs = parseInt(micWindow, 10);
              break;

            case 'speaker':
              const audioOutput = document.getElementById('editAudioOutput').value;
              const volume = document.getElementById('editSpeakerVolume').value;
              const bass = document.getElementById('editSpeakerBass').value;
              const treble = document.getElementById('editSpeakerTreble').value;

              if (audioOutput) config.audioDeviceId = audioOutput;
              if (volume !== '') config.volume = parseInt(volume, 10);
              if (bass !== '') config.bass = parseInt(bass, 10);
              if (treble !== '') config.treble = parseInt(treble, 10);
              break;
          }

          // Save the part
          fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          })
          .then(r => r.json())
          .then(data => {
            if (data.success) {
              alert('Part updated successfully');
              loadParts(); // Refresh the parts list
            } else {
              alert(`Failed to update part: ${data.error || 'Unknown error'}`);
            }
          })
          .catch(error => {
            console.error('Error updating part:', error);
            alert('Error updating part');
          });
        }

        // Delete part function
        function deleteSelectedPart() {
          if (!selected) {
            alert('No part selected');
            return;
          }

          if (!confirm(`Are you sure you want to delete "${selected.name}"? This action cannot be undone.`)) {
            return;
          }

          fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}`, {
            method: 'DELETE'
          })
          .then(r => r.json())
          .then(data => {
            if (data.success) {
              alert('Part deleted successfully');
              selected = null;
              loadParts(); // Refresh the parts list

              // Clear the interface
              document.getElementById('devName').textContent = 'Select a device';
              document.getElementById('devMeta').textContent = '';
              document.getElementById('controlsArea').innerHTML = '<div class="text-muted">Select a device to show controls.</div>';

              // Switch back to Controls tab
              const ctrlTabBtn = document.querySelector('button[data-bs-target="#tabControls"]');
              if (ctrlTabBtn) ctrlTabBtn.click();
            } else {
              alert(`Failed to delete part: ${data.error || 'Unknown error'}`);
            }
          })
          .catch(error => {
            console.error('Error deleting part:', error);
            alert('Error deleting part');
          });
        }

        // Apply webcam to mjpg-streamer function
        function applyWebcamToMjpg() {
          if (!selected) {
            alert('No webcam part selected');
            return;
          }

          if (selected.type !== 'webcam') {
            alert('Selected part is not a webcam');
            return;
          }

          const devicePath = selected.config?.devicePath;
          if (!devicePath) {
            alert('Webcam device path not configured. Please save the webcam configuration first.');
            return;
          }

          fetch(`/setup/parts/api/parts/${encodeURIComponent(selected.id)}/apply-mjpg`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({})
          })
          .then(r => r.json())
          .then(data => {
            if (data.success) {
              alert(`Applied to mjpg-streamer: ${data.devicePath || devicePath}`);
            } else {
              let msg = data.error || data.message || 'Failed to apply to mjpg-streamer';
              if (data.needsSudo) msg += ' (needs sudo)';
              alert(msg);
            }
          })
          .catch(error => {
            console.error('Error applying to mjpg-streamer:', error);
            alert('Error applying to mjpg-streamer');
          });
        }

        // Initialize modal when page loads
        document.addEventListener('DOMContentLoaded', function() {
          initAddPartModal();

          // Add tab change event listener to re-render edit config when Edit tab is activated
          const editTabButton = document.querySelector('button[data-bs-target="#tabEdit"]');
          if (editTabButton) {
            editTabButton.addEventListener('click', function() {
              if (selected) {
                setTimeout(() => {
                  renderEditConfigArea(selected);
                }, 100);
              }
            });
          }
        });

      })();
    </script>

