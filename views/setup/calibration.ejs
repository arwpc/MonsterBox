            select.appendChild(option);
          });
        })
        .catch(() => {
          select.innerHTML = '<option value="">Error scanning inputs</option>';
        });
    };

    window.scanAudioOutputsForEdit = function () {
      const select = document.getElementById('editAudioOutput');
      if (!select) return;

      fetch('/setup/audio/api/outputs')
        .then(r => r.json())
        .then(data => {
          const currentValue = select.value;
          select.innerHTML = '<option value="default">Default PipeWire Sink</option>';
          const outputs = (data && data.outputs) || [];
          outputs.forEach(output => {
            const option = document.createElement('option');
            option.value = output.id || '';
            option.textContent = output.description || output.name || output.id;
            if (option.value === currentValue) option.selected = true;
            select.appendChild(option);
          });
        })
        .catch(() => {
          select.innerHTML = '<option value="">Error scanning outputs</option>';
        });
    };

    // Delete part function
    function deleteSelectedPart() {
      if (!selected) {
        alert('No part selected');
        return;
      }

      if (!confirm(`Are you sure you want to delete "${selected.name}" ? This action cannot be undone.`)) {
        return;
      }

      fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}`, {
        method: 'DELETE'
      })
        .then(r => r.json())
        .then(data => {
          if (data.success) {
            alert('Part deleted successfully');
            selected = null;
            loadParts(); // Refresh the parts list

            // Clear the interface
            document.getElementById('devName').textContent = 'Select a device';
            document.getElementById('devMeta').textContent = '';
            document.getElementById('controlsArea').innerHTML = '<div class="text-muted">Select a device to show controls.</div>';

            // Switch back to Controls tab
            const ctrlTabBtn = document.querySelector('button[data-bs-target="#tabControls"]');
            if (ctrlTabBtn) ctrlTabBtn.click();
          } else {
            alert(`Failed to delete part: ${data.error || 'Unknown error'} `);
          }
        })
        .catch(error => {
          console.error('Error deleting part:', error);
          alert('Error deleting part');
        });
    }

    // Apply webcam to mjpg-streamer function
    function applyWebcamToMjpg() {
      if (!selected) {
        alert('No webcam part selected');
        return;
      }

      if (selected.type !== 'webcam') {
        alert('Selected part is not a webcam');
        return;
      }

      const devicePath = selected.config?.devicePath;
      if (!devicePath) {
        alert('Webcam device path not configured. Please save the webcam configuration first.');
        return;
      }

      fetch(`/setup/calibration/api/webcam/parts/${encodeURIComponent(selected.id)}/apply-device`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({})
      })
        .then(r => r.json())
        .then(data => {
          if (data.success) {
            alert(`Applied to mjpg-streamer: ${data.devicePath || devicePath}`);
          } else {
            let msg = data.error || data.message || 'Failed to apply to mjpg-streamer';
            if (data.needsSudo) msg += ' (needs sudo)';
            alert(msg);
          }
        })
        .catch(error => {
          console.error('Error applying to mjpg-streamer:', error);
          alert('Error applying to mjpg-streamer');
        });
    }

    // Initialize modal when page loads
    document.addEventListener('DOMContentLoaded', function () {
      initAddPartModal();

      // Power Enable Handler
      const pwr = document.getElementById('powerEnable');
      if (pwr) {
        pwr.addEventListener('change', async (e) => {
             try {
               const s = e.target.checked; 
               const r = await fetch('/setup/calibration/api/system/power', {
                  method:'POST',
                  headers:{'Content-Type':'application/json'},
                  body:JSON.stringify({state:s})
               });
               const res = await r.json();
               if(window.showToast) window.showToast(s?'Power Enabled':'Power Disabled', s?'success':'warning');
             } catch(e) { console.error(e); }
        });
      }

      // Add tab change event listener to re-render edit config when Edit tab is activated
      const editTabButton = document.querySelector('button[data-bs-target="#tabEdit"]');
      if (editTabButton) {
        editTabButton.addEventListener('click', function () {
          if (selected) {
            setTimeout(() => {
              renderEditConfigArea(selected);
            }, 100);
          }
        });
      }
    });

  })();

  // Global functions that need to be accessible from event handlers
  // Ensure toast notifications are available globally for handlers defined below
  if (!window.showToast) {
    window.showToast = function (message, type = 'info') {
      let toastContainer = document.getElementById('toast-container');
      if (!toastContainer) {
        toastContainer = document.createElement('div');
        toastContainer.id = 'toast-container';
        toastContainer.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999;';
        document.body.appendChild(toastContainer);
      }
      const toast = document.createElement('div');
      toast.className = `alert alert-${type === 'error' ? 'danger' : type === 'success' ? 'success' : 'info'} alert-dismissible fade show`;
      toast.style.cssText = 'margin-bottom: 10px; min-width: 300px;';
      toast.innerHTML = `${message}\n<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
      toastContainer.appendChild(toast);
      setTimeout(() => { if (toast.parentNode) toast.remove(); }, 5000);
    }
  }

  // Save part changes function - moved to global scope
  async function savePartChanges() {
    const selected = window.selectedPart;
    if (!selected) {
      showToast('No part selected', 'error');
      return;
    }

    try {
      // Get basic fields
      const name = document.getElementById('editName')?.value || '';
      const type = document.getElementById('editType')?.value || '';
      const enabled = document.getElementById('editEnabled')?.checked || false;
      const description = document.getElementById('editDescription')?.value || '';

      // Get type-specific configuration
      const config = getEditConfigValues(selected.type);

      // Get pin values for parts that have pins
      let pin = null;
      let directionPin = null;
      let pwmPin = null;
      let stepPin = null;
      let dirPin = null;
      let enablePin = null;

      if (['servo', 'led', 'light', 'sensor', 'motion_sensor'].includes(type)) {
        // Try both editPin (from renderPinFields) and type-specific pin fields
        const pinEl = document.getElementById('editPin') ||
          document.getElementById('editServoPin') ||
          document.getElementById('editLightPin') ||
          document.getElementById('editSensorPin');
        if (pinEl && pinEl.value) pin = parseInt(pinEl.value);
      }

      // Declare variables for BTS7960 pins
      let rpwmPin = null;
      let lpwmPin = null;
      let renPin = null;
      let lenPin = null;
      let controlBoard = null;

      if (['motor', 'linear_actuator'].includes(type)) {
        // Control board and pins
        var cbEl = document.getElementById('editControlBoard');
        controlBoard = cbEl ? cbEl.value : null;
        if (controlBoard) {
          config.controlBoard = controlBoard; // also propagate into config for completeness
        }

        // Both motor and linear_actuator can use BTS7960
        if (controlBoard === 'BTS7960') {
          var rp = document.getElementById('editRpwmPin');
          var lp = document.getElementById('editLpwmPin');
          var re = document.getElementById('editRenPin');
          var le = document.getElementById('editLenPin');
          if (rp && rp.value) rpwmPin = parseInt(rp.value);
          if (lp && lp.value) lpwmPin = parseInt(lp.value);
          if (re && re.value) renPin = parseInt(re.value);
          if (le && le.value) lenPin = parseInt(le.value);
          // To avoid ambiguity, clear DIR/PWM if switching to BTS7960
          directionPin = null;
          pwmPin = null;
        } else {
          const dirEl = document.getElementById('editDirectionPin');
          const pwmEl = document.getElementById('editPwmPin');
          if (dirEl && dirEl.value) directionPin = parseInt(dirEl.value);
          if (pwmEl && pwmEl.value) pwmPin = parseInt(pwmEl.value);
          // Clear BTS pins if using MDD10A
          rpwmPin = null;
          lpwmPin = null;
          renPin = null;
          lenPin = null;
        }

        // Allow Advanced JSON to override motor/linear_actuator fields
        try {
          const txt = document.getElementById('editConfig')?.value || '';
          if (txt.trim().length) {
            const adv = JSON.parse(txt);
            if (adv.controlBoard != null) controlBoard = adv.controlBoard;
            // MDD10A/Cytron pins
            if (adv.directionPin != null) directionPin = parseInt(adv.directionPin);
            if (adv.pwmPin != null) pwmPin = parseInt(adv.pwmPin);
            // BTS7960 pins
            if (adv.rpwmPin != null) rpwmPin = parseInt(adv.rpwmPin);
            if (adv.lpwmPin != null) lpwmPin = parseInt(adv.lpwmPin);
            if (adv.renPin != null) renPin = parseInt(adv.renPin);
            if (adv.lenPin != null) lenPin = parseInt(adv.lenPin);
            // Limits
            if (adv.maxDuration != null) config.maxDuration = parseInt(adv.maxDuration);
            if (adv.maxExtension != null) config.maxExtension = parseInt(adv.maxExtension);
            if (adv.maxRetraction != null) config.maxRetraction = parseInt(adv.maxRetraction);
            if (adv.modelId && !config.modelId) config.modelId = adv.modelId;
          }
        } catch (e) { /* ignore parse errors; keep form values */ }
      }

      if (type === 'stepper') {
        const sEl = document.getElementById('editStepPin');
        const dEl = document.getElementById('editDirPin');
        const eEl = document.getElementById('editEnablePin');
        if (sEl && sEl.value) stepPin = parseInt(sEl.value);
        if (dEl && dEl.value) dirPin = parseInt(dEl.value);
        if (eEl && eEl.value) enablePin = parseInt(eEl.value);

        // Allow Advanced JSON to override stepper fields
        try {
          const txt = document.getElementById('editConfig')?.value || '';
          if (txt.trim().length) {
            const adv = JSON.parse(txt);
            if (adv.stepPin != null) stepPin = parseInt(adv.stepPin);
            if (adv.dirPin != null) dirPin = parseInt(adv.dirPin);
            if (adv.enablePin != null) enablePin = parseInt(adv.enablePin);
            if (adv.microstepping != null) config.microstepping = parseInt(adv.microstepping);
            if (adv.stepsPerRevolution != null) config.stepsPerRevolution = parseInt(adv.stepsPerRevolution);
            if (adv.modelId && !config.modelId) config.modelId = adv.modelId;
          }
        } catch (e) { /* ignore parse errors; keep form values */ }
      }

      // Build the update payload
      const updateData = {
        name,
        type,
        enabled,
        description,
        config
      };

      // Add pin fields if they exist
      if (pin !== null) updateData.pin = pin;
      if (directionPin !== null) updateData.directionPin = directionPin;
      if (pwmPin !== null) updateData.pwmPin = pwmPin;
      if (stepPin !== null) updateData.stepPin = stepPin;
      if (dirPin !== null) updateData.dirPin = dirPin;
      if (enablePin !== null) updateData.enablePin = enablePin;

      // Add control board and BTS7960 pins if they exist
      if (controlBoard !== null) updateData.controlBoard = controlBoard;
      if (rpwmPin !== null) updateData.rpwmPin = rpwmPin;
      if (lpwmPin !== null) updateData.lpwmPin = lpwmPin;
      if (renPin !== null) updateData.renPin = renPin;
      if (lenPin !== null) updateData.lenPin = lenPin;

      console.log('Saving part changes for', selected.name, '(', selected.type, '):', updateData);
      console.log('Configuration extracted:', config);

      // Send update request
      const response = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updateData)
      });

      if (response.ok) {
        const result = await response.json();
        showToast(`Part "${name}" saved successfully`, 'success');

        // Update the selected part object
        Object.assign(selected, updateData);

        // Refresh the parts list to show updated information
        location.reload(); // Simple refresh for now

        console.log('Part saved successfully:', result);
      } else {
        const errorData = await response.json().catch(() => ({}));
        showToast(`Failed to save part: ${errorData.error || 'Unknown error'}`, 'error');
        console.error('Failed to save part:', errorData);
      }
    } catch (error) {
      console.error('Error saving part:', error);
      showToast('Error saving part changes', 'error');
    }
  }

  // Get configuration values from Edit form - moved to global scope
  function getEditConfigValues(type) {
    const config = {};
    console.log('Extracting config values for part type:', type);

    switch (type) {
      case 'servo':
        const servoType = document.getElementById('editServoType')?.value;
        const controllerType = document.getElementById('editControllerType')?.value;
        const invertDirection = document.getElementById('editInvertDirection')?.checked;
        const modelId = document.getElementById('editServoModel')?.value;
        const pca9685Address = document.getElementById('editPca9685Address')?.value;
        const pca9685Frequency = document.getElementById('editPca9685Frequency')?.value;
        const pca9685Channel = document.getElementById('editPca9685Channel')?.value;

        if (servoType) config.servoType = servoType;
        if (controllerType) config.controllerType = controllerType;
        if (invertDirection !== undefined) config.invertDirection = invertDirection;
        if (modelId) config.modelId = modelId;

        if (controllerType === 'pca9685') {
          if (pca9685Address) {
            // Convert hex string to number
            const addr = pca9685Address.startsWith('0x') ?
              parseInt(pca9685Address, 16) : parseInt(pca9685Address);
            if (!isNaN(addr)) config.address = addr;
          }
          if (pca9685Frequency) config.pca9685Frequency = parseInt(pca9685Frequency);
          if (pca9685Channel) config.channel = parseInt(pca9685Channel);
        }
        break;

      case 'motor':
        const maxDuration = document.getElementById('editMaxDuration')?.value;
        if (maxDuration) config.maxDuration = parseInt(maxDuration);
        break;

      case 'linear_actuator':
        const maxExtension = document.getElementById('editMaxExtension')?.value;
        const maxRetraction = document.getElementById('editMaxRetraction')?.value;
        if (maxExtension) config.maxExtension = parseInt(maxExtension);
        if (maxRetraction) config.maxRetraction = parseInt(maxRetraction);
        break;

      case 'stepper':
        const micro = document.getElementById('editMicrostepping')?.value;
        const spr = document.getElementById('editStepsPerRev')?.value;
        if (micro) config.microstepping = parseInt(micro);
        if (spr) config.stepsPerRevolution = parseInt(spr);
        break;

      case 'light':
      case 'led':
        const brightness = document.getElementById('editBrightness')?.value;
        if (brightness) config.brightness = parseInt(brightness);
        break;

      case 'sensor':
      case 'motion_sensor':
        const sensitivity = document.getElementById('editSensitivity')?.value;
        const windowMs = document.getElementById('editWindowMs')?.value;
        if (sensitivity) config.sensitivity = parseInt(sensitivity);
        if (windowMs) config.windowMs = parseInt(windowMs);
        break;

      case 'webcam':
        const devicePath = document.getElementById('editDevicePath')?.value;
        const deviceId = document.getElementById('editDeviceId')?.value;
        const width = document.getElementById('editWidth')?.value;
        const height = document.getElementById('editHeight')?.value;
        const fps = document.getElementById('editFps')?.value;
        if (devicePath) config.devicePath = devicePath;
        if (deviceId) config.deviceId = parseInt(deviceId);
        if (width) config.width = parseInt(width);
        if (height) config.height = parseInt(height);
        if (fps) config.fps = parseInt(fps);
        break;

      case 'microphone':
        const micDevice = document.getElementById('editMicDevice')?.value;
        const sampleRate = document.getElementById('editSampleRate')?.value;
        const gain = document.getElementById('editGain')?.value;
        if (micDevice) config.deviceId = micDevice;
        if (sampleRate) config.sampleRate = parseInt(sampleRate);
        if (gain) config.gain = parseInt(gain);
        break;

      case 'speaker':
        const speakerDevice = document.getElementById('editSpeakerDevice')?.value;
        const volume = document.getElementById('editVolume')?.value;
        const bass = document.getElementById('editBass')?.value;
        const treble = document.getElementById('editTreble')?.value;
        if (speakerDevice) config.audioDeviceId = speakerDevice;
        if (volume) config.volume = parseInt(volume);
        if (bass) config.bass = parseInt(bass);
        if (treble) config.treble = parseInt(treble);
        break;
    }

    console.log('Extracted config for', type, ':', config);
    return config;
  }

  function renderEdit(part) {
    // Populate basic fields
    var n = document.getElementById('editName'); if (n) n.value = part.name || '';
    var t = document.getElementById('editType'); if (t) t.value = part.type || '';
    var en = document.getElementById('editEnabled'); if (en) en.checked = !!part.enabled;
    var d = document.getElementById('editDescription'); if (d) d.value = part.description || '';
    var c = document.getElementById('editConfig');
    if (c) {
      let adv = { ...(part.config || {}) };
      if ((part.type || '') === 'stepper') {
        if (part.stepPin != null) adv.stepPin = Number(part.stepPin);
        if (part.dirPin != null) adv.dirPin = Number(part.dirPin);
        if (part.enablePin != null) adv.enablePin = Number(part.enablePin);
        // Ensure useful defaults visible
        if (adv.microstepping == null) adv.microstepping = 16;
        if (adv.stepsPerRevolution == null) adv.stepsPerRevolution = 200;
        if (part.modelId) adv.modelId = part.modelId;
      }
      // Include motor/linear_actuator pins in Advanced JSON
      if ((part.type || '') === 'motor' || (part.type || '') === 'linear_actuator') {
        if (part.controlBoard != null) adv.controlBoard = part.controlBoard;
        // MDD10A/Cytron pins
        if (part.directionPin != null) adv.directionPin = Number(part.directionPin);
        if (part.pwmPin != null) adv.pwmPin = Number(part.pwmPin);
        // BTS7960 pins
        if (part.rpwmPin != null) adv.rpwmPin = Number(part.rpwmPin);
        if (part.lpwmPin != null) adv.lpwmPin = Number(part.lpwmPin);
        if (part.renPin != null) adv.renPin = Number(part.renPin);
        if (part.lenPin != null) adv.lenPin = Number(part.lenPin);
        // Limits
        if (part.maxDuration != null) adv.maxDuration = Number(part.maxDuration);
        if (part.maxExtension != null) adv.maxExtension = Number(part.maxExtension);
        if (part.maxRetraction != null) adv.maxRetraction = Number(part.maxRetraction);
        if (part.modelId) adv.modelId = part.modelId;
      }
      c.value = JSON.stringify(adv, null, 2);
    }

    // Render type-specific configuration
    renderEditConfigArea(part);

    // Bind save button (only once)
    var save = document.getElementById('saveEditBtn');
    if (save && !save._bound) {
      save._bound = true;
      save.addEventListener('click', function () {
        savePartChanges();
      });
    }

    // Bind delete button (only once)
    var deleteBtn = document.getElementById('deletePartBtn');
    if (deleteBtn && !deleteBtn._bound) {
      deleteBtn._bound = true;
      deleteBtn.addEventListener('click', function () {
        deleteSelectedPart();
      });
    }

    // Show/hide mjpg button for webcam parts
    var mjpgBtn = document.getElementById('applyMjpgBtn');
    if (mjpgBtn) {
      mjpgBtn.style.display = (part.type === 'webcam') ? 'inline-block' : 'none';
    }
  }

  function renderEditConfigArea(part) {
    const container = document.getElementById('editConfigArea');
    if (!container) return;

    const type = part.type;
    const config = part.config || {};
    let html = '';

    // Generate type-specific configuration fields
    switch (type) {
      case 'servo':
        html = generateEditServoConfig(part, config);
        break;
      case 'motor':
        html = generateEditMotorConfig(part, config);
        break;
      case 'linear_actuator':
        html = generateEditLinearActuatorConfig(part, config);
        break;
      case 'stepper':
        html = generateEditStepperConfig(part, config);
        break;
      case 'light':
      case 'led':
        html = generateEditLightConfig(part, config, type);
        break;
      case 'sensor':
      case 'motion_sensor':
        html = generateEditSensorConfig(part, config, type);
        break;
      case 'webcam':
        html = generateEditWebcamConfig(part, config);
        break;
      case 'microphone':
        html = generateEditMicrophoneConfig(part, config);
        break;
      case 'speaker':
        html = generateEditSpeakerConfig(part, config);
        break;
      default:
        html = '<div class="alert alert-info">No specific configuration options for this part type.</div>';
    }

    container.innerHTML = html;

    // Load current values into the form fields
    loadEditConfigValues(part, config, type);
  }

