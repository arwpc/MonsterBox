    async function addPreset() {
      const partId = window.selectedPartId;
      if (!partId || !currentCalProfile) return;

      const nameInput = document.getElementById('presetNameInput');
      const name = nameInput ? nameInput.value.trim() : '';
      if (!name) {
        alert('Enter a preset name');
        return;
      }

      try {
        // Fetch current position from server
        const posRes = await fetch('/api/calibration/' + encodeURIComponent(partId) + '/position');
        const posData = await posRes.json();
        if (!posData.success || posData.currentP == null) {
          alert('Cannot capture position — move the part first, then try again.');
          return;
        }

        const position = posData.currentP;
        const presetData = { name, position };
        // For absolute servos, also store the angle
        if (posData.currentAngle != null) {
          presetData.angle = posData.currentAngle;
        }

        // Update profile with new preset
        const updatedPresets = [...(currentCalProfile.presets || [])];
        const existingIndex = updatedPresets.findIndex(p => p.name === name);
        if (existingIndex >= 0) {
          updatedPresets[existingIndex] = presetData;
        } else {
          updatedPresets.push(presetData);
        }

        // Send complete updated profile
        const updatedProfile = { ...currentCalProfile, presets: updatedPresets };
        const updateRes = await fetch(`/api/calibration/${partId}/profile`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updatedProfile)
        });

        const updateData = await updateRes.json();
        if (!updateData.success) {
          alert('Failed to save preset: ' + (updateData.error || 'Unknown error'));
        } else {
          nameInput.value = '';
          await loadUnifiedCalibration(partId, window.selectedPart);
        }
      } catch (err) {
        console.error('Add preset error:', err);
        alert('Add preset error: ' + err.message);
      }
    }

    async function deletePreset(name) {
      const partId = window.selectedPartId;
      if (!partId || !currentCalProfile) return;

      if (!confirm(`Delete preset "${name}"?`)) return;

      try {
        const updatedPresets = (currentCalProfile.presets || []).filter(p => p.name !== name);

        // Send complete updated profile
        const updatedProfile = { ...currentCalProfile, presets: updatedPresets };
        const res = await fetch(`/api/calibration/${partId}/profile`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updatedProfile)
        });

        const data = await res.json();
        if (!data.success) {
          alert('Failed to delete preset: ' + (data.error || 'Unknown error'));
        } else {
          await loadUnifiedCalibration(partId, window.selectedPart);
        }
      } catch (err) {
        console.error('Delete preset error:', err);
        alert('Delete preset error: ' + err.message);
      }
    }

    async function gotoPreset(name) {
      const partId = window.selectedPartId;
      if (!partId || !currentCalProfile) return;

      const preset = currentCalProfile.presets.find(p => p.name === name);
      if (!preset) {
        alert('Preset not found: ' + name);
        return;
      }

      try {
        // Use angle-based goto for absolute servos if angle is available
        const body = (currentPartIsAbsoluteServo && preset.angle != null)
          ? { angle: preset.angle }
          : { p: preset.position };

        const res = await fetch(`/api/calibration/${partId}/goto`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });

        const data = await res.json();
        if (!data.success) {
          alert('Goto preset failed: ' + (data.error || 'Unknown error'));
        } else {
          // Sync position display
          if (data.targetP != null) {
            updateCurrentPositionDisplay(data.targetP, data.targetAngle);
          }
          // Sync LA slider if present
          if (typeof window._syncLASlider === 'function' && data.targetP != null) {
            window._syncLASlider(data.targetP);
          }
        }
      } catch (err) {
        console.error('Goto preset error:', err);
        alert('Goto preset error: ' + err.message);
      }
    }

    // Goto section: jump to min, max, or a preset
    async function gotoPosition(target) {
      const partId = window.selectedPartId;
      if (!partId || !currentCalProfile) return;

      var body = null;
      var bounds = currentCalProfile.bounds || {};

      if (target === 'min') {
        if (currentPartIsAbsoluteServo) {
          if (bounds.minAngle == null) { alert('Min bound not set. Set Min first.'); return; }
          body = { angle: bounds.minAngle };
        } else {
          if (bounds.minP == null) { alert('Min bound not set. Set Min first.'); return; }
          body = { p: bounds.minP };
        }
      } else if (target === 'max') {
        if (currentPartIsAbsoluteServo) {
          if (bounds.maxAngle == null) { alert('Max bound not set. Set Max first.'); return; }
          body = { angle: bounds.maxAngle };
        } else {
          if (bounds.maxP == null) { alert('Max bound not set. Set Max first.'); return; }
          body = { p: bounds.maxP };
        }
      } else if (target === 'preset') {
        var select = document.getElementById('gotoPresetSelect');
        var presetName = select ? select.value : '';
        if (!presetName) { alert('Select a preset first.'); return; }
        var preset = (currentCalProfile.presets || []).find(function(p) { return p.name === presetName; });
        if (!preset) { alert('Preset not found: ' + presetName); return; }
        body = (currentPartIsAbsoluteServo && preset.angle != null)
          ? { angle: preset.angle }
          : { p: preset.position };
      }

      if (!body) return;

      try {
        const res = await fetch('/api/calibration/' + encodeURIComponent(partId) + '/goto', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });

        const data = await res.json();
        if (!data.success) {
          alert('Goto failed: ' + (data.error || 'Unknown error'));
        } else {
          if (data.targetP != null) {
            updateCurrentPositionDisplay(data.targetP, data.targetAngle);
          }
          if (typeof window._syncLASlider === 'function' && data.targetP != null) {
            window._syncLASlider(data.targetP);
          }
        }
      } catch (err) {
        console.error('Goto error:', err);
        alert('Goto error: ' + err.message);
      }
    }
    window.gotoPosition = gotoPosition;

