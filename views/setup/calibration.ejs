<script>
  (function () {
    const elList = document.getElementById('deviceList');
    const searchEl = document.getElementById('searchDevices');
    const modelSelect = document.getElementById('modelSelect');
    const modelBadge = document.getElementById('modelBadge');
    const overridesEditor = document.getElementById('overridesEditor');
    const devName = document.getElementById('devName');
    const devMeta = document.getElementById('devMeta');
    const bottomRail = document.getElementById('bottomRail');
    const globalSpeedCap = document.getElementById('globalSpeedCap');
    const globalSpeedCapVal = document.getElementById('globalSpeedCapVal');
    const globalSpeedCapValue = function() { return globalSpeedCap ? parseInt(globalSpeedCap.value, 10) : 75; };

    let parts = [];
    let selected = null;
    let modelsCache = {}; // by type
    let selectedIdsMulti = new Set();
    window.selectedIdsMulti = selectedIdsMulti;

    // Initialize jog scale for unified calibration
    window.jogScale = 'medium';

    function getVisiblePartIds() { return (window.visiblePartIds || []).map(String); }
    function updateBulkUI() {
      window.updateBulkUI = updateBulkUI;
      const delBtn = document.getElementById('deleteSelectedBtn');
      if (delBtn) delBtn.disabled = selectedIdsMulti.size === 0;
      const selectAll = document.getElementById('selectAllParts');
      if (selectAll) {
        const vis = getVisiblePartIds();
        const allChecked = vis.length > 0 && vis.every(id => selectedIdsMulti.has(String(id)));
        const anyChecked = vis.some(id => selectedIdsMulti.has(String(id)));
        selectAll.checked = allChecked;
        selectAll.indeterminate = anyChecked && !allChecked;
      }
    }
    function toggleSelectPart(id, checked) {
      const sid = String(id);
      if (checked) selectedIdsMulti.add(sid); else selectedIdsMulti.delete(sid);
      updateBulkUI();
    }
    function bindListCheckboxHandlers() {
      document.querySelectorAll('.part-select').forEach(cb => {
        if (cb.dataset._bound) return; cb.dataset._bound = '1';
        cb.addEventListener('click', (e) => {
          e.stopPropagation();
          const pid = cb.getAttribute('data-pid');
          toggleSelectPart(pid, cb.checked);
        });
      });
