    /**
     * Generate realistic PCA9685 board HTML for a given container prefix.
     * Returns the HTML string for the board visual.
     * @param {string} prefix - 'add' or 'edit', used to scope element IDs
     * @param {number} selectedCh - Currently selected channel (-1 = none)
     */
    window.buildPcaBoardHTML = function (prefix, selectedCh) {
      // Build channel-to-part lookup from allParts
      var chMap = {};
      (window.allParts || []).forEach(function (p) {
        if (!p.config) return;
        var ch = p.config.channel;
        if (ch == null && p.config.pcaChannel != null) ch = p.config.pcaChannel;
        if (ch == null) return;
        var ct = p.config.controllerType || '';
        if (ct !== 'pca9685') return;
        ch = parseInt(ch, 10);
        if (isNaN(ch) || ch < 0 || ch > 15) return;
        if (!chMap[ch]) chMap[ch] = [];
        chMap[ch].push(p);
      });

      var h = '<div class="pca-board" id="' + prefix + 'PcaBoard">';
      // Header
      h += '<div class="pca-hdr"><div class="t1">PCA9685</div><div class="t2">16-CH 12-BIT PWM DRIVER</div></div>';
      // Board details
      h += '<div class="pca-details">';
      h += '<div class="pca-led-dot"></div>';
      h += '<div class="pca-ic"><span>PCA9685<br>NXP</span></div>';
      h += '<div class="pca-vplus">V+</div>';
      h += '</div>';
      // Channel grid — 4 banks of 4, matching physical PCA9685 board layout
      h += '<div class="pca-grid">';
      for (var bank = 0; bank < 4; bank++) {
        var bankStart = bank * 4;
        var bankEnd = bankStart + 3;
        h += '<div class="pca-bank-wrap">';
        h += '<div class="pca-bank">';
        for (var i = bankStart; i <= bankEnd; i++) {
          var parts = chMap[i] || [];
          var cls = 'pca-ch';
          if (i === selectedCh) cls += ' sel';
          else if (parts.length > 1) cls += ' dup';
          else if (parts.length === 1) cls += ' used';

          var tip = 'Ch ' + i + ': ';
          if (parts.length > 1) tip += parts.length + ' parts (CONFLICT)';
          else if (parts.length === 1) tip += parts[0].name;
          else tip += 'Empty';

          h += '<div class="' + cls + '" data-channel="' + i + '" ';
          h += 'onclick="selectPcaCh_' + prefix + '(' + i + ')">';
          h += '<div class="tip">' + tip + '</div>';
          h += '<div class="num">' + i + '</div>';
          h += '<div class="pins"><div class="pin ps"></div><div class="pin pv"></div><div class="pin pg"></div></div>';
          h += '</div>';
        }
        h += '</div>';
        h += '<div class="pca-bank-lbl">' + bankStart + '-' + bankEnd + '</div>';
        h += '</div>';
      }
      h += '</div>';
      h += '</div>';
      // Legend
      h += '<div class="pca-legend">';
      h += '<div class="li"><div class="ld ld-free"></div> Free</div>';
      h += '<div class="li"><div class="ld ld-sel"></div> Selected</div>';
      h += '<div class="li"><div class="ld ld-used"></div> In Use</div>';
      h += '<div class="li"><div class="ld ld-dup"></div> Conflict</div>';
      h += '</div>';
      return h;
    };

