                            <label class="form-label small mb-0">Threshold <span class="text-muted" id="calMotionThresholdValue">25</span></label>
                            <input type="range" class="form-range" id="calMotionThreshold" min="10" max="100" value="25" data-bs-toggle="tooltip" data-bs-placement="top" title="Pixel change threshold to count as motion. Higher = less sensitive. Recommended: 20-40.">
                          </div>
                          <div class="mb-1">
                            <label class="form-label small mb-0">Min Object <span class="text-muted" id="calMinContourAreaValue">500</span>px</label>
                            <input type="range" class="form-range" id="calMinContourArea" min="100" max="2000" value="500" step="100" data-bs-toggle="tooltip" data-bs-placement="top" title="Minimum motion blob size in pixels. Increase to ignore small movements like pets or shadows. Recommended: 300-800.">
                          </div>
                          <div class="mb-1">
                            <label class="form-label small mb-0">Smoothing <span class="text-muted" id="calTrackingSmoothingValue">0.3</span></label>
                            <input type="range" class="form-range" id="calTrackingSmoothing" min="0.1" max="0.9" value="0.3" step="0.1" data-bs-toggle="tooltip" data-bs-placement="top" title="How gradually tracking follows the target. Higher = smoother but slower. Lower = faster but may jitter. Recommended: 0.2-0.5.">
                          </div>
                          <div class="mb-1">
                            <label class="form-label small mb-0">Deadzone <span class="text-muted" id="calTrackingDeadzoneValue">5</span>%</label>
                            <input type="range" class="form-range" id="calTrackingDeadzone" min="1" max="20" value="5" data-bs-toggle="tooltip" data-bs-placement="top" title="Center region where no servo movement occurs, as percent of frame. Prevents jitter when target is near center. Recommended: 3-8%.">
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="card mb-2">
                      <div class="card-header py-1"><i class="bi bi-magic"></i> Head Tracking</div>
                      <div class="card-body py-2">
                        <div class="mb-2">
                          <label class="form-label small mb-0">Pan Servo</label>
                          <select id="calPanServoSelect" class="form-select form-select-sm" data-bs-toggle="tooltip" data-bs-placement="top" title="Choose which servo controls horizontal panning to follow detected motion">
                            <option value="">Select servo...</option>
                          </select>
                        </div>
                        <div class="row mb-2 gx-2">
                          <div class="col-6">
                            <label class="form-label small mb-0">Range +/-<span id="calHeadTrackingRangeValue">60</span>&deg;</label>
                            <input type="range" class="form-range" id="calHeadTrackingRange" min="30" max="120" value="60" data-bs-toggle="tooltip" data-bs-placement="top" title="Total degrees the servo can sweep for tracking. Larger = wider tracking range. Recommended: 45-90.">
                          </div>
                          <div class="col-6">
                            <label class="form-label small mb-0">Smooth <span id="calHeadTrackingSmoothingValue">0.35</span></label>
                            <input type="range" class="form-range" id="calHeadTrackingSmoothing" min="0.1" max="0.8" value="0.35" step="0.05" data-bs-toggle="tooltip" data-bs-placement="top" title="How gradually the servo follows the target. Higher = smoother but slower. Lower = faster but may jitter. Recommended: 0.25-0.5.">
                          </div>
                        </div>
                        <button id="calEnableHeadTracking" class="btn btn-outline-warning btn-sm w-100" disabled data-bs-toggle="tooltip" data-bs-placement="top" title="Start servo-based head tracking to follow detected motion. Requires a pan servo to be selected.">
                          <i class="bi bi-magic"></i> Enable Head Tracking
                        </button>
                      </div>
                    </div>
                    <button id="calSaveAdvancedBtn" class="btn btn-success w-100 mb-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Persist motion tracking and head tracking settings to the webcam part configuration">
                      <i class="bi bi-save"></i> Save Tracking Settings
                    </button>
                    <button id="calEmergencyStopBtn" class="btn btn-danger w-100" data-bs-toggle="tooltip" data-bs-placement="top" title="Immediately stop all continuous servos and linear actuators">
                      <i class="bi bi-stop-circle-fill"></i> EMERGENCY STOP ALL SERVOS
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="card-footer d-flex justify-content-between">
          <div class="text-muted small" id="devNotes">Notes: —</div>
          <div class="d-flex gap-2">
            <button class="btn btn-outline-danger btn-sm" id="btnRemove" disabled data-bs-toggle="tooltip" data-bs-placement="top" title="Delete the selected part and all its associated data"><i class="bi bi-trash"></i>
              Remove</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Panel: Unified Calibration (Positions v1.5) — only shown for movement parts -->
    <div class="col-12 col-xl-3" id="rightPanelCol">
      <div class="card h-100" id="unifiedCalPanel">
        <div class="card-header">
          <i class="bi bi-bullseye"></i> Calibration (Positions v1.5)
        </div>
        <div class="card-body">

          <!-- Current Position Display -->
          <div class="mb-3">
            <label class="form-label small fw-bold">Current Position</label>
            <div class="text-center">
              <span id="calPositionDisplay" class="badge bg-primary fs-5">—</span>
              <div class="mt-1">
                <span id="calConfidenceBadge" class="badge bg-secondary" style="display: none;">Unknown</span>
              </div>
            </div>
          </div>

          <!-- Home Button (open-loop parts only) -->
          <div id="calHomeSection" class="mb-3" style="display: none;">
            <button type="button" class="btn btn-sm btn-outline-warning w-100" id="calHomeBtn" onclick="homePart()" data-bs-toggle="tooltip" data-bs-placement="top" title="Retract the part to its physical endstop to establish a known home position">
              <i class="bi bi-house-door"></i> Home (Retract to Endstop)
            </button>
          </div>

          <!-- Calibration Bounds -->
          <div class="mb-3">
            <label class="form-label small fw-bold">Calibration Bounds</label>
            <div class="row g-2 mb-2">
              <div class="col-6">
                <small class="text-muted">Min: <span id="calMinDisplay">—</span></small>
              </div>
              <div class="col-6 text-end">
                <small class="text-muted">Max: <span id="calMaxDisplay">—</span></small>
              </div>
            </div>
            <div class="btn-group w-100 mb-2">
              <button type="button" class="btn btn-sm btn-outline-primary" onclick="setCalibrationBound('min')" data-bs-toggle="tooltip" data-bs-placement="top" title="Set the minimum bound at the current position">Set
                Min</button>
              <button type="button" class="btn btn-sm btn-outline-primary" onclick="setCalibrationBound('max')" data-bs-toggle="tooltip" data-bs-placement="top" title="Set the maximum bound at the current position">Set
                Max</button>
            </div>
            <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="clearCalibration()" data-bs-toggle="tooltip" data-bs-placement="top" title="Remove min/max bounds and all presets for this part">
              <i class="bi bi-eraser"></i> Clear
            </button>
            <button type="button" class="btn btn-sm btn-outline-info w-100 mt-2" id="btnTestSweep" onclick="runSweepTest()" data-bs-toggle="tooltip" data-bs-placement="top" title="Move 3 times between min and max bounds at full speed to verify range of motion">
              <i class="bi bi-arrows"></i> Sweep Test
            </button>
            <div class="form-check form-switch mt-2" id="invertToggleContainer" style="display: none;">
              <input class="form-check-input" type="checkbox" id="invertToggle" onchange="toggleInvert(this.checked)" data-bs-toggle="tooltip" data-bs-placement="top" title="Reverse the servo direction if it moves opposite to expected">
              <label class="form-check-label small" for="invertToggle">Invert Servo Direction</label>
            </div>
          </div>

          <!-- Position Presets -->
          <hr>
          <div class="mb-3">
            <label class="form-label small fw-bold">Position Presets</label>
            <div class="input-group input-group-sm mb-2">
              <input type="text" class="form-control" id="presetNameInput" placeholder="Preset name..." data-bs-toggle="tooltip" data-bs-placement="top" title="Enter a name for this preset (e.g., 'open', 'closed', 'half')">
              <button type="button" class="btn btn-success" onclick="addPreset()" data-bs-toggle="tooltip" data-bs-placement="top" title="Save the current position as a named preset for quick recall">Set Here</button>
            </div>
            <div id="presetsContainer" class="d-flex flex-column gap-1">
              <small class="text-muted">No presets yet</small>
            </div>
          </div>

          <!-- Goto Section (quick jump to min, max, or preset) -->
          <hr>
          <div id="gotoSection" class="mb-3" style="display: none;">
            <label class="form-label small fw-bold">Goto</label>
            <div class="d-flex gap-1 mb-2">
              <button type="button" class="btn btn-sm btn-outline-warning flex-fill" onclick="gotoPosition('min')" data-bs-toggle="tooltip" data-bs-placement="top" title="Move to the calibrated minimum position">
                <i class="bi bi-arrow-down-circle"></i> Min
              </button>
              <button type="button" class="btn btn-sm btn-outline-warning flex-fill" onclick="gotoPosition('max')" data-bs-toggle="tooltip" data-bs-placement="top" title="Move to the calibrated maximum position">
                <i class="bi bi-arrow-up-circle"></i> Max
              </button>
            </div>
            <div class="input-group input-group-sm">
              <select class="form-select" id="gotoPresetSelect">
                <option value="">— Select preset —</option>
              </select>
              <button type="button" class="btn btn-outline-warning" onclick="gotoPosition('preset')" data-bs-toggle="tooltip" data-bs-placement="top" title="Move to the selected preset position">Go</button>
            </div>
          </div>

          <!-- Learn Movement (for openloop-linear parts only) -->
          <div id="learnMovementSection" style="display: none;">
            <hr>
            <div class="mb-3">
              <label class="form-label small fw-bold">Learn Movement</label>
              <small class="text-muted d-block mb-2">Probe linear actuator speed</small>
              <div class="d-grid gap-1">
                <button type="button" class="btn btn-sm btn-outline-info" onclick="runLearnMovement(30)" data-bs-toggle="tooltip" data-bs-placement="top" title="Probe speed at 30% power — slowest, most precise">Run 30%
                  PWM</button>
                <button type="button" class="btn btn-sm btn-outline-info" onclick="runLearnMovement(50)" data-bs-toggle="tooltip" data-bs-placement="top" title="Probe speed at 50% power — balanced speed and precision">Run 50%
                  PWM</button>
                <button type="button" class="btn btn-sm btn-outline-info" onclick="runLearnMovement(70)" data-bs-toggle="tooltip" data-bs-placement="top" title="Probe speed at 70% power — faster, good for full-range movement">Run 70%
                  PWM</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Rail: Cross-Device Locations -->
  <div class="mt-3">
    <div id="bottomRail" class="d-flex flex-wrap gap-2"></div>
  </div>

<!-- Bootstrap JS is loaded by master layout, don't load it again -->
<script>
  (function () {
    const elList = document.getElementById('deviceList');
    const searchEl = document.getElementById('searchDevices');
    const modelSelect = document.getElementById('modelSelect');
    const modelBadge = document.getElementById('modelBadge');
    const overridesEditor = document.getElementById('overridesEditor');
    const devName = document.getElementById('devName');
    const devMeta = document.getElementById('devMeta');
    const bottomRail = document.getElementById('bottomRail');
    const globalSpeedCap = document.getElementById('globalSpeedCap');
    const globalSpeedCapVal = document.getElementById('globalSpeedCapVal');
    const globalSpeedCapValue = function() { return globalSpeedCap ? parseInt(globalSpeedCap.value, 10) : 75; };

    let parts = [];
    let selected = null;
    let modelsCache = {}; // by type
    let selectedIdsMulti = new Set();
    window.selectedIdsMulti = selectedIdsMulti;

    // Initialize jog scale for unified calibration
    window.jogScale = 'medium';

    function getVisiblePartIds() { return (window.visiblePartIds || []).map(String); }
    function updateBulkUI() {
      window.updateBulkUI = updateBulkUI;
      const delBtn = document.getElementById('deleteSelectedBtn');
      if (delBtn) delBtn.disabled = selectedIdsMulti.size === 0;
      const selectAll = document.getElementById('selectAllParts');
      if (selectAll) {
        const vis = getVisiblePartIds();
        const allChecked = vis.length > 0 && vis.every(id => selectedIdsMulti.has(String(id)));
        const anyChecked = vis.some(id => selectedIdsMulti.has(String(id)));
        selectAll.checked = allChecked;
        selectAll.indeterminate = anyChecked && !allChecked;
      }
    }
    function toggleSelectPart(id, checked) {
      const sid = String(id);
      if (checked) selectedIdsMulti.add(sid); else selectedIdsMulti.delete(sid);
      updateBulkUI();
    }
    function bindListCheckboxHandlers() {
      document.querySelectorAll('.part-select').forEach(cb => {
        if (cb.dataset._bound) return; cb.dataset._bound = '1';
        cb.addEventListener('click', (e) => {
          e.stopPropagation();
          const pid = cb.getAttribute('data-pid');
          toggleSelectPart(pid, cb.checked);
        });
      });
    }

    if (globalSpeedCap) globalSpeedCap.addEventListener('input', () => { if (globalSpeedCapVal) globalSpeedCapVal.textContent = globalSpeedCap.value + '%'; });

    async function loadParts() {
      // Use server-provided character ID (set at render time, no extra API call needed)
      let characterId = window.__MB_CHAR_ID || null;

      // Fallback: read from nav DOM element
      if (!characterId) {
        try {
          var charLabel = document.getElementById('charLabel');
          if (charLabel && charLabel.dataset.charId) characterId = charLabel.dataset.charId;
        } catch (e) {}
      }

      // Last resort: API call
      if (!characterId) {
        try {
          const currentRes = await fetch('/setup/characters/api/current');
          const currentData = await currentRes.json();
          characterId = currentData.selectedCharacter;
        } catch (e) {
          console.warn('Could not get current character:', e);
        }
      }

      const url = characterId ? `/setup/calibration/api/parts?characterId=${characterId}` : '/setup/calibration/api/parts';
      const res = await fetch(url);
      const j = await res.json();
      if (!j.success) throw new Error('Failed to load parts');
      parts = j.parts || [];

      // Set global variable for access from global scope functions
      window.allParts = parts;

      renderList(parts);
      renderBottomRail(parts);
    }

    function renderList(items) {
      const q = (searchEl.value || '').toLowerCase();
      elList.innerHTML = '';
      const visible = items.filter(p => !q || p.name.toLowerCase().includes(q) || p.type.includes(q));
      window.visiblePartIds = visible.map(p => String(p.id));
      visible.forEach(p => {
        const a = document.createElement('a');
        a.href = 'javascript:void(0)';
        a.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
        a.setAttribute('data-pid', p.id);
        var badges = '';
        if (p.needsModel) badges += '<span class="badge text-bg-warning me-1">Needs Model</span>';
        if (p.needsCalibration) badges += '<span class="badge text-bg-info me-1">Needs Cal</span>';
        if (p.gpioConflict) badges += '<span class="badge text-bg-danger">GPIO</span>';
        const checked = selectedIdsMulti.has(String(p.id)) ? 'checked' : '';
        a.innerHTML = `<div class="d-flex align-items-center"><input type="checkbox" class="form-check-input me-2 part-select" data-pid="${p.id}" ${checked}><div><div class=\"fw-semibold\">${p.name}</div><small class=\"text-muted\">${p.type}</small></div></div>` +
          `<div>${badges}</div>`;
        a.addEventListener('click', () => selectPart(p.id));
        elList.appendChild(a);
      });
      bindListCheckboxHandlers();
      updateBulkUI();
    }
    searchEl.addEventListener('input', () => renderList(parts));

    async function selectPart(id) {
      selected = parts.find(function (p) { return String(p.id) === String(id); });
      if (!selected) return;

      // Set global variable for access from global scope functions
      window.selectedPartId = selected.id;
      window.selectedPart = selected;
      devName.textContent = selected.name;
      devMeta.textContent = 'ID: ' + selected.id + ' | Type: ' + selected.type;
      modelBadge.textContent = 'Model: ' + (selected.modelId || '—');
      overridesEditor.value = JSON.stringify(selected.config || {}, null, 2);
      await ensureModelsLoaded(selected.type);
      populateModelSelect(selected.type, selected.modelId);
      var ctrlTabBtn = document.querySelector('button[data-bs-target="#tabControls"]');
      if (ctrlTabBtn) ctrlTabBtn.click();
      renderControls(selected);
      renderEdit(selected);
      refreshEffective(selected.id);
      renderAdvancedTab(selected);

      // Enable Remove button when a part is selected
      const removeBtn = document.getElementById('btnRemove');
      if (removeBtn) removeBtn.disabled = false;

      // Show/hide calibration panels based on whether the part type has physical movement
      var CALIBRATABLE_TYPES = ['servo', 'linear_actuator', 'motor', 'stepper'];
      var isCalPart = CALIBRATABLE_TYPES.indexOf(selected.type) !== -1;
      var rightCol = document.getElementById('rightPanelCol');
      var centerCol = document.getElementById('centerPanelCol');
      var simpleCalCard = document.getElementById('simpleCalCard');
      if (rightCol) rightCol.style.display = isCalPart ? '' : 'none';
      if (simpleCalCard) simpleCalCard.style.display = isCalPart ? '' : 'none';
      // Expand center panel when calibration panel is hidden
      if (centerCol) {
        centerCol.classList.toggle('col-xl-6', isCalPart);
        centerCol.classList.toggle('col-xl-9', !isCalPart);
      }

      // Load unified calibration for this part (only for calibratable types)
      if (isCalPart) {
        await loadUnifiedCalibration(selected.id, selected);
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // UNIFIED CALIBRATION INTEGRATION
    // ─────────────────────────────────────────────────────────────────────────
    let currentCalProfile = null;

    async function loadUnifiedCalibration(partId, partData) {
      try {
        const res = await fetch(`/api/calibration/${partId}/profile`);
        const data = await res.json();

        if (!data.success) {
          console.warn('No calibration profile for part', partId);
          currentCalProfile = null;
          updateCalibrationUI(null, partData);
          return;
        }

        currentCalProfile = data.profile;
        updateCalibrationUI(currentCalProfile, partData);

        // Also fetch current position and confidence
        try {
          var posRes = await fetch('/api/calibration/' + encodeURIComponent(partId) + '/position');
          var posData = await posRes.json();
          if (posData.success) {
            updateCurrentPositionDisplay(posData.currentP, posData.currentAngle);
            updateConfidenceBadge(posData.positionKnown, posData.confidence);
          }
        } catch (posErr) {
          console.warn('Could not fetch current position:', posErr);
        }
      } catch (err) {
        console.error('Failed to load calibration profile:', err);
        currentCalProfile = null;
        updateCalibrationUI(null, partData);
      }
    }

    // Track whether the currently selected part is an absolute servo
    var currentPartIsAbsoluteServo = false;

    function updateCalibrationUI(profile, partData) {
      var panel = document.getElementById('unifiedCalPanel');
      if (!panel) return;

      // Determine if this is an absolute servo
      currentPartIsAbsoluteServo = profile && profile.capability && profile.capability.kind === 'absolute-servo';

      // Show/hide learn-movement section and home button based on part capability
      var learnSection = document.getElementById('learnMovementSection');
      var capKind = profile && profile.capability && profile.capability.kind;
      var isOpenloop = capKind === 'openloop-linear' || capKind === 'continuous-servo';
      if (learnSection) {
        learnSection.style.display = (partData && partData.config && partData.config.capability === 'openloop-linear') ? 'block' : 'none';
      }
      var homeSection = document.getElementById('calHomeSection');
      if (homeSection) {
        homeSection.style.display = isOpenloop ? 'block' : 'none';
      }

      // Update bounds displays — use angle for absolute servos, normalized for others
      var minDisplay = document.getElementById('calMinDisplay');
      var maxDisplay = document.getElementById('calMaxDisplay');
      if (profile) {
        if (currentPartIsAbsoluteServo) {
          var minA = profile.bounds && profile.bounds.minAngle != null ? profile.bounds.minAngle : null;
          var maxA = profile.bounds && profile.bounds.maxAngle != null ? profile.bounds.maxAngle : null;
          if (minDisplay) minDisplay.textContent = minA != null ? minA + '\u00B0' : '\u2014';
          if (maxDisplay) maxDisplay.textContent = maxA != null ? maxA + '\u00B0' : '\u2014';
        } else {
          if (minDisplay) minDisplay.textContent = profile.bounds && profile.bounds.minP != null ? profile.bounds.minP.toFixed(3) : '\u2014';
          if (maxDisplay) maxDisplay.textContent = profile.bounds && profile.bounds.maxP != null ? profile.bounds.maxP.toFixed(3) : '\u2014';
        }
      } else {
        if (minDisplay) minDisplay.textContent = '\u2014';
        if (maxDisplay) maxDisplay.textContent = '\u2014';
      }

      // Update invert toggle — show for servos only
      var invertContainer = document.getElementById('invertToggleContainer');
      var invertCheckbox = document.getElementById('invertToggle');
      if (invertContainer) {
        var isServo = partData && partData.type === 'servo';
        invertContainer.style.display = isServo ? 'block' : 'none';
        if (invertCheckbox && profile && profile.capability) {
          invertCheckbox.checked = !!profile.capability.invert;
        } else if (invertCheckbox) {
          invertCheckbox.checked = false;
        }
      }

      // Update presets list
      renderPresetsUI(profile ? profile.presets : null);

      // Update Goto section — show for all calibratable parts, populate preset dropdown
      var gotoSection = document.getElementById('gotoSection');
      var gotoSelect = document.getElementById('gotoPresetSelect');
      if (gotoSection) {
        var CALIBRATABLE_TYPES = ['servo', 'linear_actuator', 'motor', 'stepper'];
        var showGoto = partData && CALIBRATABLE_TYPES.indexOf(partData.type) !== -1;
        gotoSection.style.display = showGoto ? 'block' : 'none';
      }
      if (gotoSelect) {
        var presets = profile ? profile.presets : [];
        gotoSelect.innerHTML = '<option value="">— Select preset —</option>';
        if (presets && presets.length > 0) {
          presets.forEach(function(p) {
            var opt = document.createElement('option');
            opt.value = p.name;
            opt.textContent = p.name;
            gotoSelect.appendChild(opt);
          });
        }
      }

      // Update position display (placeholder for now - API doesn't have status endpoint yet)
      var posDisplay = document.getElementById('calPositionDisplay');
      if (posDisplay) posDisplay.textContent = '\u2014';
    }

    // Jog controls
    async function jogPart(direction, scale) {
      const partId = window.selectedPartId;
      if (!partId) return;

      // Convert UI direction names to API dir values
      let dir;
      if (direction === 'backward' || direction === 'min') dir = 'min';
      else if (direction === 'forward' || direction === 'max') dir = 'max';
      else if (direction === 'stop') {
        // Handle stop separately
        try {
          const res = await fetch(`/api/calibration/${partId}/stop`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          const data = await res.json();
          if (!data.success) {
            alert('Stop failed: ' + (data.error || 'Unknown error'));
          }
        } catch (err) {
          console.error('Stop error:', err);
          alert('Stop error: ' + err.message);
        }
        return;
      } else {
        console.error('Invalid direction:', direction);
        return;
      }

      // Normalize scale (medium -> med)
      if (scale === 'medium') scale = 'med';

      try {
        const res = await fetch(`/api/calibration/${partId}/nudge`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dir, scale })
        });
        const data = await res.json();
        if (!data.success) {
          alert('Jog failed: ' + (data.error || 'Unknown error'));
        } else {
          // Update current position display — prefer angle for absolute servos
          if (currentPartIsAbsoluteServo && typeof data.currentAngle === 'number') {
            updateCurrentPositionDisplay(null, data.currentAngle);
          } else if (typeof data.currentP === 'number') {
            updateCurrentPositionDisplay(data.currentP);
          }
        }
      } catch (err) {
        console.error('Jog error:', err);
        alert('Jog error: ' + err.message);
      }
    }

    // Expose unified calibration functions to global scope for onclick handlers
    window.jogPart = jogPart;

    // Helper function to update current position display
    // For absolute servos, shows angle in degrees. For others, shows normalized 0-1.
    function updateCurrentPositionDisplay(p, angle) {
      var el = document.getElementById('calPositionDisplay');
      if (!el) return;
      if (currentPartIsAbsoluteServo && typeof angle === 'number') {
        el.textContent = angle + '\u00B0';
      } else if (typeof p === 'number') {
        el.textContent = currentPartIsAbsoluteServo ? Math.round(p * 180) + '\u00B0' : p.toFixed(3);
      } else {
        el.textContent = '\u2014';
      }
