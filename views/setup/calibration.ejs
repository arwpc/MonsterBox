    // Clear calibration for current part
    async function clearCalibration() {
      const partId = window.selectedPartId;
      if (!partId) {
        alert('No part selected');
        return;
      }

      const partName = window.selectedPart ? window.selectedPart.name : `Part ${partId}`;
      if (!confirm(`Clear calibration data for "${partName}"?\n\nThis will remove:\n• Min/Max bounds\n• Position presets\n• Calibration settings\n\nThis action cannot be undone.`)) {
        return;
      }

      try {
        const res = await fetch(`/api/calibration/${partId}/profile`, {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' }
        });

        const data = await res.json();
        if (!data.success) {
          alert('Failed to clear calibration: ' + (data.error || 'Unknown error'));
        } else {
          // Reload calibration UI to reflect cleared state
          await loadUnifiedCalibration(partId, window.selectedPart);
          if (window.showToast) {
            window.showToast(`Calibration cleared for ${partName}`, 'success');
          } else {
            alert(`Calibration cleared for ${partName}`);
          }
        }
      } catch (err) {
        console.error('Clear calibration error:', err);
        alert('Clear calibration error: ' + err.message);
      }
    }

    // Clear all calibrations for current character
    async function clearAllCalibrations() {
      try {
        // Use server-provided character ID, fall back to API
        let characterId = window.__MB_CHAR_ID || null;
        if (!characterId) {
          try {
            var charLabel = document.getElementById('charLabel');
            if (charLabel && charLabel.dataset.charId) characterId = charLabel.dataset.charId;
          } catch (e) {}
        }
        if (!characterId) {
          const currentRes = await fetch('/setup/characters/api/current');
          const currentData = await currentRes.json();
          characterId = currentData.selectedCharacter;
        }

        if (!characterId) {
          alert('No character selected');
          return;
        }

        // Get all parts for current character
        const partsRes = await fetch(`/setup/calibration/api/parts?characterId=${characterId}`);
        const partsData = await partsRes.json();
        if (!partsData.success) {
          alert('Failed to load parts');
          return;
        }

        const parts = partsData.parts || [];
        const calibratableParts = parts.filter(p => 
          ['servo', 'linear_actuator', 'motor', 'stepper'].includes(String(p.type).toLowerCase())
        );

        if (calibratableParts.length === 0) {
          alert('No calibratable parts found for current character');
          return;
        }

        const partNames = calibratableParts.map(p => p.name).join('\n• ');
        if (!confirm(`Clear ALL calibrations for current character?\n\nThis will clear calibration data for ${calibratableParts.length} part(s):\n• ${partNames}\n\nThis action cannot be undone.`)) {
          return;
        }

        const partIds = calibratableParts.map(p => parseInt(p.id, 10));
        const res = await fetch('/api/calibration/clear-all', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ characterId, partIds })
        });

        const data = await res.json();
        if (!data.success) {
          alert('Failed to clear calibrations: ' + (data.error || 'Unknown error'));
        } else {
          // Reload current part calibration if one is selected
          if (window.selectedPartId && window.selectedPart) {
            await loadUnifiedCalibration(window.selectedPartId, window.selectedPart);
          }
          
          // Reload parts list to update calibration status badges
          await loadParts();

          if (window.showToast) {
            window.showToast(`Cleared ${data.cleared} calibration profile(s)`, 'success');
          } else {
            alert(`Cleared ${data.cleared} calibration profile(s)`);
          }
        }
      } catch (err) {
        console.error('Clear all calibrations error:', err);
        alert('Clear all calibrations error: ' + err.message);
      }
    }

    // Expose clear functions to global scope
    window.clearCalibration = clearCalibration;
    window.clearAllCalibrations = clearAllCalibrations;

