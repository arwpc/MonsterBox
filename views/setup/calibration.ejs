          const n = el.querySelector('#angNum');
          s.addEventListener('input', () => { n.value = (parseInt(s.value, 10) / 1000).toFixed(3); });
          n.addEventListener('input', () => { s.value = Math.round(parseFloat(n.value || '0.5') * 1000); });
