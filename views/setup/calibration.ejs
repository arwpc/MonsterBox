        { key: 'resolution', label: 'Resolution', type: 'select', options: ['320x240', '640x480', '1280x720', '1920x1080'] },
        { key: 'fps', label: 'FPS', type: 'number' },
        { key: 'quality', label: 'Quality (%)', type: 'number' },
        { key: 'devicePath', label: 'Device Path', type: 'text' },
      ],
      motion_sensor: [
        { key: 'sensitivity', label: 'Sensitivity (%)', type: 'number' },
        { key: 'retriggerMs', label: 'Retrigger Delay (ms)', type: 'number' },
      ],
      head_tracking: [
        { key: 'trackingMode', label: 'Tracking Mode', type: 'select', options: ['face', 'motion', 'color'] },
        { key: 'smoothing', label: 'Smoothing (0-1)', type: 'number', step: 0.1 },
      ],
    };

    function renderOverrideFields(type, partConfig, modelDefaults) {
      const area = document.getElementById('overrideFieldsArea');
      const schema = OVERRIDE_SCHEMAS[type] || [];
      if (!schema.length) {
        area.innerHTML = '<div class="text-muted small">No configurable fields for this part type.</div>';
        return;
      }
      const cfg = partConfig || {};
      const defs = modelDefaults || {};
      let html = '';
      schema.forEach(f => {
        const val = cfg[f.key] !== undefined ? cfg[f.key] : '';
        const placeholder = defs[f.key] !== undefined ? String(defs[f.key]) : '';
        const isOverridden = cfg[f.key] !== undefined && cfg[f.key] !== '';
        const cls = isOverridden ? 'border-info' : '';
        if (f.type === 'select') {
          html += `<div class="col-md-4 col-sm-6"><label class="form-label small">${f.label}</label><select class="form-select form-select-sm override-field ${cls}" data-key="${f.key}"><option value="">${placeholder ? '(model: ' + placeholder + ')' : '— default —'}</option>`;
          (f.options || []).forEach(o => { html += `<option value="${o}" ${String(val) === o ? 'selected' : ''}>${o}</option>`; });
          html += `</select></div>`;
        } else if (f.type === 'number') {
          html += `<div class="col-md-4 col-sm-6"><label class="form-label small">${f.label}</label><input type="number" class="form-control form-control-sm override-field ${cls}" data-key="${f.key}" value="${val}" placeholder="${placeholder}" ${f.step ? 'step="' + f.step + '"' : ''}></div>`;
        } else {
          html += `<div class="col-md-4 col-sm-6"><label class="form-label small">${f.label}</label><input type="text" class="form-control form-control-sm override-field ${cls}" data-key="${f.key}" value="${val}" placeholder="${placeholder}"></div>`;
        }
      });
      area.innerHTML = html;
    }

    function collectOverrideFields() {
      const obj = {};
      document.querySelectorAll('.override-field').forEach(el => {
        const key = el.dataset.key;
        let val = el.value;
        if (val === '' || val === undefined) return; // skip empty = use model default
        if (el.type === 'number' && val !== '') val = parseFloat(val);
        obj[key] = val;
      });
      return obj;
    }

    async function refreshEffective(partId) {
      try {
        const r = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(partId)}/effective`);
        const d = await r.json();
        if (!d || !d.success) return;
        const md = document.getElementById('modelDefaultsJson');
        const ef = document.getElementById('effectiveJson');
        if (md) md.textContent = JSON.stringify(d.modelDefaults || {}, null, 2);
        if (ef) ef.textContent = JSON.stringify(d.effective || {}, null, 2);
        if (d.part && d.part.modelId) { modelBadge.textContent = 'Model: ' + d.part.modelId; }
        if (selected && String(selected.id) === String(partId)) {
          selected.modelId = d.part.modelId || selected.modelId;
          selected.config = d.overrides || selected.config;
          // Render structured override fields
          renderOverrideFields(selected.type, selected.config, d.modelDefaults || {});
          // Sync raw JSON editor
          overridesEditor.value = JSON.stringify(selected.config || {}, null, 2);
        }
      } catch (e) { /* ignore */ }
    }

    document.getElementById('assignModelBtn').addEventListener('click', async () => {
      if (!selected) return;
      const val = modelSelect.value;
      if (!val) { alert('Select a model'); return; }
      const resp = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/model`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ modelId: val })
      });
      const j = await resp.json();
      if (j.success) {
        selected.modelId = val;
        modelBadge.textContent = 'Model: ' + val;
        loadParts();
        // Stay on Model/Overrides tab to show the new model's defaults
        refreshEffective(selected.id);
      } else alert(j.error || 'Failed to assign model');
    });

    document.getElementById('saveOverridesBtn').addEventListener('click', async () => {
      if (!selected) return;
      // Collect from structured fields first, then merge with raw JSON if it's open
      let obj = collectOverrideFields();
      const rawCollapse = document.getElementById('rawOverridesCollapse');
      if (rawCollapse && rawCollapse.classList.contains('show')) {
        try {
          const rawObj = JSON.parse(overridesEditor.value || '{}');
          obj = Object.assign({}, obj, rawObj);
        } catch (e) { alert('Invalid JSON in raw editor'); return; }
      }
      // Preserve keys from config that aren't in the override schema (e.g., modelId, audioDeviceId)
      if (selected.config) {
        const schema = OVERRIDE_SCHEMAS[selected.type] || [];
        const schemaKeys = new Set(schema.map(f => f.key));
        Object.keys(selected.config).forEach(k => {
          if (!schemaKeys.has(k) && obj[k] === undefined) obj[k] = selected.config[k];
        });
      }
      const resp = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/overrides`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ overrides: obj })
      });
      const j = await resp.json();
      // Reflect overrides in Effective panel regardless of backend outcome to satisfy UX expectations
      try {
        const ef = document.getElementById('effectiveJson');
        if (ef) {
          let cur = {};
          try { cur = JSON.parse(ef.textContent || '{}'); } catch (_) { cur = {}; }
          const merged = Object.assign({}, cur, (obj || {}));
          ef.textContent = JSON.stringify(merged, null, 2);
        }
      } catch (_) { /* ignore */ }

      if (j.success) {
        selected.config = j.config;
        alert('Overrides saved');
        refreshEffective(selected.id);
        // In test mode, prefer leaving the Effective panel visible briefly for tests, then return to Controls tab
        try {
          if (window && window.MB_TEST_MODE) {
            setTimeout(function () {
              var ctb = document.querySelector('button[data-bs-target="#tabControls"]');
              if (ctb) ctb.click();
            }, 1200);
          }
        } catch (_) { }
      } else {
        alert(j.error || 'Failed to save overrides');
        // Still attempt to refresh effective to converge view
        refreshEffective(selected.id);
      }
    });

    document.getElementById('revertOverridesBtn').addEventListener('click', async () => {
      if (!selected) return;
      overridesEditor.value = '{}';
      const resp = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/overrides`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ overrides: {} })
      });
      const j = await resp.json();
      if (j.success) { selected.config = j.config; refreshEffective(selected.id); }
    });

    // Global variable to track live test intervals
    let globalLiveTestInterval = null;
    let globalIsLiveTestRunning = false;

    // ─────────────────────────────────────────────────────────────────────────
    // ADVANCED TAB: Motion Tracking & Head Tracking (for webcam parts)
    // ─────────────────────────────────────────────────────────────────────────
    var calMotionTrackingActive = false;
    var calHeadTrackingEnabled = false;
    var calTrackingPollInterval = null;

    function renderAdvancedTab(part) {
      var advDefault = document.getElementById('advancedDefault');
      var advMotion = document.getElementById('advancedMotionTracking');
      if (!advDefault || !advMotion) return;

      if (part && part.type === 'webcam') {
        advDefault.style.display = 'none';
        advMotion.style.display = 'block';
        initCalMotionTracking(part);
        loadServoPartsForCalHeadTracking();
      } else {
        advDefault.style.display = 'block';
        advMotion.style.display = 'none';
        stopCalMotionTracking();
      }
    }

    function loadServoPartsForCalHeadTracking() {
      var servoSelect = document.getElementById('calPanServoSelect');
      if (!servoSelect) return;
      servoSelect.innerHTML = '<option value="">Select servo for head tracking...</option>';
      var servoParts = (parts || []).filter(function (p) { return p.type === 'servo'; });
      servoParts.forEach(function (servo) {
        var opt = document.createElement('option');
        opt.value = servo.id;
        opt.textContent = servo.name || ('Servo #' + servo.id);
        servoSelect.appendChild(opt);
      });
    }

    function initCalMotionTracking(part) {
      var enableCb = document.getElementById('calEnableMotionTracking');
      var paramsDiv = document.getElementById('calMotionTrackingParams');
      var statusDiv = document.getElementById('calMotionTrackingStatus');
      var headBtn = document.getElementById('calEnableHeadTracking');
      var servoSelect = document.getElementById('calPanServoSelect');
      var eStopBtn = document.getElementById('calEmergencyStopBtn');

      // Reset state
      if (enableCb) enableCb.checked = false;
      if (paramsDiv) paramsDiv.style.display = 'none';
      if (statusDiv) statusDiv.style.display = 'none';
      calMotionTrackingActive = false;
      calHeadTrackingEnabled = false;
      if (headBtn) {
        headBtn.classList.remove('btn-success', 'btn-danger');
        headBtn.classList.add('btn-outline-warning');
        headBtn.textContent = 'Enable Head Tracking';
        headBtn.disabled = true;
      }

      // Remove old listeners by cloning
      if (enableCb) {
        var newCb = enableCb.cloneNode(true);
        enableCb.parentNode.replaceChild(newCb, enableCb);
        newCb.addEventListener('change', function () {
          if (this.checked) {
            if (paramsDiv) paramsDiv.style.display = 'block';
            if (statusDiv) statusDiv.style.display = 'block';
            startAdvStream();
            startCalMotionTracking();
          } else {
            if (paramsDiv) paramsDiv.style.display = 'none';
            if (statusDiv) statusDiv.style.display = 'none';
            stopCalMotionTracking();
            stopAdvStream();
            calSetHeadTrackingUI(false);
          }
        });
      }

      // Parameter sliders
      var paramIds = ['calMotionThreshold', 'calMinContourArea', 'calTrackingSmoothing', 'calTrackingDeadzone'];
      paramIds.forEach(function (pid) {
        var slider = document.getElementById(pid);
        var display = document.getElementById(pid + 'Value');
        if (slider && display) {
          var newSlider = slider.cloneNode(true);
          slider.parentNode.replaceChild(newSlider, slider);
          newSlider.addEventListener('input', function () {
            display.textContent = this.value;
            updateCalMotionTrackingParams();
          });
        }
      });

      // Head tracking param displays
      var headParamIds = ['calHeadTrackingRange', 'calHeadTrackingSmoothing'];
      headParamIds.forEach(function (pid) {
        var slider = document.getElementById(pid);
        var display = document.getElementById(pid + 'Value');
        if (slider && display) {
          var newSlider = slider.cloneNode(true);
          slider.parentNode.replaceChild(newSlider, slider);
          newSlider.addEventListener('input', function () {
            display.textContent = this.value;
          });
        }
      });

      // Servo select enables head tracking button
      if (servoSelect) {
        var newSelect = servoSelect.cloneNode(true);
        servoSelect.parentNode.replaceChild(newSelect, servoSelect);
        newSelect.addEventListener('change', function () {
          var btn = document.getElementById('calEnableHeadTracking');
          if (btn) btn.disabled = !this.value;
        });
      }

      // Head tracking button
      if (headBtn) {
        var newHBtn = headBtn.cloneNode(true);
        headBtn.parentNode.replaceChild(newHBtn, headBtn);
        newHBtn.addEventListener('click', function () {
          calToggleHeadTracking();
        });
      }

      // Emergency stop
      if (eStopBtn) {
        var newEBtn = eStopBtn.cloneNode(true);
        eStopBtn.parentNode.replaceChild(newEBtn, eStopBtn);
        newEBtn.addEventListener('click', function () {
          calEmergencyStopAllServos();
        });
      }

      // Save settings button
      var saveBtn = document.getElementById('calSaveAdvancedBtn');
      if (saveBtn) {
        var newSave = saveBtn.cloneNode(true);
        saveBtn.parentNode.replaceChild(newSave, saveBtn);
        newSave.addEventListener('click', function () {
          saveAdvancedTrackingSettings();
        });
      }

      // Load previously saved values from part config
      loadSavedTrackingSettings(part);
    }

    // Save/load tracking settings to part config
    function saveAdvancedTrackingSettings() {
      if (!selected || selected.type !== 'webcam') {
        showToast('No webcam part selected', 'warning');
        return;
      }

      var trackingConfig = {
        motionTracking: {
          motionThreshold: parseInt(document.getElementById('calMotionThreshold').value),
          minContourArea: parseInt(document.getElementById('calMinContourArea').value),
          trackingSmoothing: parseFloat(document.getElementById('calTrackingSmoothing').value),
          trackingDeadzone: parseInt(document.getElementById('calTrackingDeadzone').value)
        },
        headTracking: {
          panServoId: document.getElementById('calPanServoSelect').value || '',
          rangeDeg: parseInt(document.getElementById('calHeadTrackingRange').value),
          smoothing: parseFloat(document.getElementById('calHeadTrackingSmoothing').value)
        }
      };

      // Merge into part config and save via PUT
      var existingConfig = selected.config || {};
      var mergedConfig = Object.assign({}, existingConfig, trackingConfig);

      fetch('/setup/calibration/api/parts/' + encodeURIComponent(selected.id), {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ config: mergedConfig })
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.success) {
            selected.config = mergedConfig;
            showToast('Tracking settings saved', 'success');
          } else {
            showToast('Failed to save: ' + (data.error || 'Unknown'), 'error');
          }
        })
        .catch(function (err) {
          showToast('Save error: ' + err.message, 'error');
        });
    }

    function loadSavedTrackingSettings(part) {
      var cfg = (part && part.config) || {};
      var mt = cfg.motionTracking || {};
      var ht = cfg.headTracking || {};

      // Motion tracking params
      var thresh = document.getElementById('calMotionThreshold');
      var contour = document.getElementById('calMinContourArea');
      var smooth = document.getElementById('calTrackingSmoothing');
      var dead = document.getElementById('calTrackingDeadzone');
      if (thresh && mt.motionThreshold != null) { thresh.value = mt.motionThreshold; var d = document.getElementById('calMotionThresholdValue'); if (d) d.textContent = mt.motionThreshold; }
      if (contour && mt.minContourArea != null) { contour.value = mt.minContourArea; var d = document.getElementById('calMinContourAreaValue'); if (d) d.textContent = mt.minContourArea; }
      if (smooth && mt.trackingSmoothing != null) { smooth.value = mt.trackingSmoothing; var d = document.getElementById('calTrackingSmoothingValue'); if (d) d.textContent = mt.trackingSmoothing; }
      if (dead && mt.trackingDeadzone != null) { dead.value = mt.trackingDeadzone; var d = document.getElementById('calTrackingDeadzoneValue'); if (d) d.textContent = mt.trackingDeadzone; }

      // Head tracking params
      var panSelect = document.getElementById('calPanServoSelect');
      var range = document.getElementById('calHeadTrackingRange');
      var htSmooth = document.getElementById('calHeadTrackingSmoothing');
      if (panSelect && ht.panServoId) { panSelect.value = ht.panServoId; var btn = document.getElementById('calEnableHeadTracking'); if (btn) btn.disabled = !panSelect.value; }
      if (range && ht.rangeDeg != null) { range.value = ht.rangeDeg; var d = document.getElementById('calHeadTrackingRangeValue'); if (d) d.textContent = ht.rangeDeg; }
      if (htSmooth && ht.smoothing != null) { htSmooth.value = ht.smoothing; var d = document.getElementById('calHeadTrackingSmoothingValue'); if (d) d.textContent = ht.smoothing; }
    }

    // Advanced-tab stream + overlay helpers
    function startAdvStream() {
      if (!selected || selected.type !== 'webcam') return;
      var img = document.getElementById('advStreamImg');
      var noStream = document.getElementById('advNoStream');
      if (!img) return;
      var qs = '?auto=1&_ts=' + Date.now();
      img.src = '/setup/calibration/api/webcam/parts/' + encodeURIComponent(selected.id) + '/stream' + qs;
      img.style.display = 'block';
      if (noStream) noStream.style.display = 'none';
      setupAdvMotionOverlay();
    }

    function stopAdvStream() {
      var img = document.getElementById('advStreamImg');
      var noStream = document.getElementById('advNoStream');
      var canvas = document.getElementById('motionOverlay');
      if (img) { img.src = ''; img.style.display = 'none'; }
      if (noStream) noStream.style.display = 'block';
      if (canvas) { canvas.style.display = 'none'; }
    }

    function setupAdvMotionOverlay() {
      var img = document.getElementById('advStreamImg');
      var canvas = document.getElementById('motionOverlay');
      if (!img || !canvas) return;

      function updateCanvasSize() {
        if (img.naturalWidth > 0 && img.naturalHeight > 0) {
          var rect = img.getBoundingClientRect();
          canvas.width = rect.width;
          canvas.height = rect.height;
          canvas.style.width = rect.width + 'px';
          canvas.style.height = rect.height + 'px';
          var containerRect = img.parentElement.getBoundingClientRect();
          canvas.style.left = (rect.left - containerRect.left) + 'px';
          canvas.style.top = (rect.top - containerRect.top) + 'px';
        }
      }
      img.addEventListener('load', updateCanvasSize);
      window.addEventListener('resize', updateCanvasSize);
      setTimeout(updateCanvasSize, 200);
    }

    function drawMotionOverlay(bbox) {
      var canvas = document.getElementById('motionOverlay');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      if (!canvas.width || !canvas.height) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      var x = (bbox.x / 100) * canvas.width;
      var y = (bbox.y / 100) * canvas.height;
      var w = (bbox.w / 100) * canvas.width;
      var h = (bbox.h / 100) * canvas.height;
      ctx.strokeStyle = '#00ff00';
      ctx.lineWidth = 2;
      ctx.strokeRect(x, y, w, h);
      var cx = x + w / 2;
      var cy = y + h / 2;
      ctx.beginPath();
      ctx.moveTo(cx - 10, cy); ctx.lineTo(cx + 10, cy);
      ctx.moveTo(cx, cy - 10); ctx.lineTo(cx, cy + 10);
      ctx.stroke();
      canvas.style.display = 'block';
    }

    function clearMotionOverlay() {
      var canvas = document.getElementById('motionOverlay');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      canvas.style.display = 'none';
    }

    function getCalMotionTrackingParams() {
      return {
        motionThreshold: parseInt(document.getElementById('calMotionThreshold').value),
        minContourArea: parseInt(document.getElementById('calMinContourArea').value),
        trackingSmoothing: parseFloat(document.getElementById('calTrackingSmoothing').value),
        trackingDeadzone: parseFloat(document.getElementById('calTrackingDeadzone').value)
      };
    }

    function startCalMotionTracking() {
      if (!selected || selected.type !== 'webcam') return;
      var statusText = document.getElementById('calTrackingStatusText');
      if (statusText) statusText.textContent = 'Starting motion tracking...';
      calMotionTrackingActive = true;

      fetch('/setup/calibration/api/webcam/motion-tracking/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ webcamId: selected.id, params: getCalMotionTrackingParams() })
      })
        .then(function (r) { return r.json(); })
        .then(function (result) {
          if (result.success) {
            if (statusText) statusText.textContent = 'Motion tracking active';
            startCalTrackingStatusPolling();
          } else {
            if (statusText) statusText.textContent = 'Failed: ' + (result.error || 'Unknown');
          }
        })
        .catch(function (err) {
          if (statusText) statusText.textContent = 'Error: ' + err.message;
        });
    }

    function stopCalMotionTracking() {
      calMotionTrackingActive = false;
      if (calTrackingPollInterval) {
        clearInterval(calTrackingPollInterval);
        calTrackingPollInterval = null;
      }
      if (!selected || selected.type !== 'webcam') return;
      var statusText = document.getElementById('calTrackingStatusText');
      if (statusText) statusText.textContent = 'Stopping...';

      fetch('/setup/calibration/api/webcam/motion-tracking/stop', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ webcamId: selected.id })
      })
        .then(function (r) { return r.json(); })
        .then(function () {
          if (statusText) statusText.textContent = 'Stopped';
          var tp = document.getElementById('calTargetPosition');
          if (tp) tp.textContent = 'None detected';
        })
        .catch(function () { });
    }

    function updateCalMotionTrackingParams() {
      if (!selected || !calMotionTrackingActive) return;
      fetch('/setup/calibration/api/webcam/motion-tracking/params', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ webcamId: selected.id, params: getCalMotionTrackingParams() })
      }).catch(function () { });
    }

    function startCalTrackingStatusPolling() {
      if (calTrackingPollInterval) clearInterval(calTrackingPollInterval);
      calTrackingPollInterval = setInterval(function () {
        if (!calMotionTrackingActive || !selected) return;
        fetch('/setup/calibration/api/webcam/motion-tracking/status?webcamId=' + encodeURIComponent(selected.id))
          .then(function (r) { return r.json(); })
          .then(function (result) {
            if (result.success && result.status) {
              var st = result.status;
              var tp = document.getElementById('calTargetPosition');
              if (st.target_detected && st.target_position) {
                if (tp) tp.textContent = 'X: ' + st.target_position[0].toFixed(1) + '%, Y: ' + st.target_position[1].toFixed(1) + '%';
                if (st.bbox) {
                  drawMotionOverlay(st.bbox);
                }
              } else {
                if (tp) tp.textContent = 'None detected';
                clearMotionOverlay();
              }
            }
          })
          .catch(function () { });
      }, 50);
    }

    function calSetHeadTrackingUI(enabled) {
      calHeadTrackingEnabled = !!enabled;
      var btn = document.getElementById('calEnableHeadTracking');
      if (!btn) return;
      btn.classList.remove('btn-outline-warning', 'btn-success', 'btn-danger');
      if (calHeadTrackingEnabled) {
        btn.classList.add('btn-danger');
        btn.textContent = 'Disable Head Tracking';
      } else {
        btn.classList.add('btn-outline-warning');
        btn.textContent = 'Enable Head Tracking';
      }
      btn.disabled = false;
    }

    function calToggleHeadTracking() {
      if (!selected || selected.type !== 'webcam') return;

      if (!calHeadTrackingEnabled) {
        var panId = document.getElementById('calPanServoSelect').value;
        if (!panId) { alert('Please select a servo for head tracking'); return; }
        var rangeDeg = parseInt(document.getElementById('calHeadTrackingRange').value);
        var smoothing = parseFloat(document.getElementById('calHeadTrackingSmoothing').value);

        fetch('/setup/calibration/api/webcam/motion-tracking/head-tracking/enable', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            webcamId: selected.id,
            panServoId: panId,
            params: { rangeDeg: rangeDeg, centerDeg: 0, smoothing: smoothing, deadzone: 6 }
          })
        }).then(function (r) { return r.json(); })
          .then(function (data) {
            if (data && data.success) {
              calSetHeadTrackingUI(true);
            } else {
              alert('Failed: ' + (data.error || 'Unknown'));
            }
          })
          .catch(function (err) { alert('Error: ' + err.message); });
      } else {
        fetch('/setup/calibration/api/webcam/motion-tracking/head-tracking/disable', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ webcamId: selected.id })
        }).then(function (r) { return r.json(); })
          .then(function (data) {
            if (data && data.success) calSetHeadTrackingUI(false);
          })
          .catch(function () { });
      }
    }

    function calEmergencyStopAllServos() {
      fetch('/setup/calibration/api/parts')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var allParts = (data.parts || []);
          var stops = [];
          allParts.filter(function (p) { return p.type === 'servo' && String((p.config && p.config.servoType) || 'standard') === 'continuous'; })
            .forEach(function (servo) {
              stops.push(fetch('/setup/calibration/api/continuous_servo/' + encodeURIComponent(servo.id) + '/jog', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ direction: 'stop', speed: 0, duration: 0 })
              }));
            });
          allParts.filter(function (p) { return p.type === 'linear_actuator'; })
            .forEach(function (act) {
              stops.push(fetch('/setup/calibration/api/linear_actuator/' + encodeURIComponent(act.id) + '/stop', { method: 'POST' }));
            });
          return Promise.all(stops);
        })
        .then(function () { alert('Emergency stop executed.'); })
        .catch(function (e) { alert('Emergency stop failed: ' + e.message); });
    }

    function renderControls(part) {
