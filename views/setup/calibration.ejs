<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Setup Calibration - MonsterBox 4.0</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/monsterbox4.css" rel="stylesheet">
  <style>
    .safety-bar {
      position: sticky;
      top: 56px;
      z-index: 1030;
      background: #121212;
      border-bottom: 1px solid #333;
    }

    .device-list {
      max-height: calc(100vh - 200px);
      overflow: auto;
    }

    .marker-chip {
      cursor: pointer;
    }

    .ghost-tick {
      position: absolute;
      height: 6px;
      width: 2px;
      background: #8a2be2;
      top: -2px;
    }
  </style>
</head>

<body>
  <%- include('../components/unified-navigation', { page: 'setup-calibration' }) %>

    <!-- Global Safety Bar -->
    <div class="safety-bar py-2 border-bottom">
      <div class="container-fluid d-flex align-items-center gap-2">
        <button id="btnEstop" class="btn btn-danger"><i class="bi bi-x-octagon"></i> E-STOP</button>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" id="powerEnable">
          <label class="form-check-label" for="powerEnable">Power Enable</label>
        </div>
        <div class="ms-auto d-flex gap-2 align-items-center">
          <span class="badge text-bg-success">Comms</span>
          <span class="badge text-bg-success">12V</span>
          <span class="badge text-bg-secondary">Temp</span>
          <span class="badge text-bg-secondary">Current</span>
          <span class="badge text-bg-secondary">Fault</span>
          <div class="d-flex align-items-center">
            <span class="me-2 small">Global Speed Cap</span>
            <input id="globalSpeedCap" type="range" min="10" max="100" value="75" class="form-range"
              style="width:160px">
            <span class="ms-2" id="globalSpeedCapVal">75%</span>
          </div>
        </div>
      </div>
    </div>

    <main class="container-fluid py-3">
      <!-- Mode Toggle -->
      <div class="mb-3">
        <div class="btn-group" role="group">
          <input type="radio" class="btn-check" name="mode" id="modeCal" autocomplete="off" checked>
          <label class="btn btn-outline-warning" for="modeCal">CALIBRATE</label>
          <input type="radio" class="btn-check" name="mode" id="modeOperate" autocomplete="off">
          <label class="btn btn-outline-info" for="modeOperate">OPERATE</label>
        </div>
      </div>

      <!-- Quick Model assignment (always visible) -->
      <div class="mb-3">
        <label class="form-label">Model</label>
        <div class="input-group">
          <select id="modelSelect" class="form-select">
            <option value="">Select model</option>
          </select>
          <button id="assignModelBtn" class="btn btn-primary"><i class="bi bi-link"></i> Assign</button>
        </div>
        <div class="form-text">Models are shared across all characters. Overrides remain part-specific.</div>
      </div>


      <div class="row g-3">
        <!-- Left Sidebar: Devices -->
        <div class="col-12 col-xl-3">
          <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
              <span>Devices</span>
              <div class="input-group input-group-sm" style="width: 200px;">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input id="searchDevices" type="text" class="form-control" placeholder="Search">
              </div>
            </div>
            <div class="card-body p-0">
              <div class="list-group list-group-flush device-list" id="deviceList"></div>
            </div>
          </div>
        </div>

        <!-- Center Panel: Device Card -->
        <div class="col-12 col-xl-6">
          <div class="card h-100" id="deviceCard" data-empty="1">
            <div class="card-header d-flex justify-content-between align-items-center">
              <div>
                <div class="h5 mb-0" id="devName">Select a device</div>
                <small class="text-muted" id="devMeta"></small>
              </div>
              <div class="text-end">
                <span class="badge text-bg-dark" id="modelBadge">Model: —</span>
                <div class="form-check form-switch ms-2 d-inline-block">
                  <input class="form-check-input" type="checkbox" id="invertDir">
                  <label class="form-check-label" for="invertDir">Invert</label>
                </div>
              </div>
            </div>
            <div class="card-body">

              <ul class="nav nav-tabs" id="devTabs" role="tablist">
                <li class="nav-item" role="presentation"><button class="nav-link active" data-bs-toggle="tab"
                    data-bs-target="#tabControls" type="button">Controls</button></li>
                <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab"
                    data-bs-target="#tabEdit" type="button">Edit</button></li>
                <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab"
                    data-bs-target="#tabModel" type="button">Model/Overrides</button></li>
                <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab"
                    data-bs-target="#tabSafety" type="button">Safety</button></li>
                <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab"
                    data-bs-target="#tabAdvanced" type="button">Advanced</button></li>
              </ul>
              <div class="tab-content pt-3">
                <!-- Controls -->
                <div class="tab-pane fade show active" id="tabControls">
                  <div id="controlsArea" class="text-muted">Select a device to show controls.</div>
                </div>
                <!-- Edit (basic part settings) -->
                <div class="tab-pane fade" id="tabEdit">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label">Name</label>
                      <input id="editName" class="form-control" placeholder="Part name">
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                      <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="editEnabled">
                        <label class="form-check-label" for="editEnabled">Enabled</label>
                      </div>
                    </div>
                    <div class="col-12" id="pinFields">
                      <!-- Pin-specific fields will be rendered here -->
                    </div>
                    <div class="col-12">
                      <label class="form-label">Description</label>
                      <input id="editDescription" class="form-control" placeholder="Describe this part">
                    </div>
                    <div class="col-12">
                      <label class="form-label">Config (JSON)</label>
                      <textarea id="editConfig" class="form-control" rows="6" placeholder="{}"></textarea>
                    </div>
                    <div class="col-12 d-flex justify-content-end">
                      <button id="saveEditBtn" class="btn btn-success"><i class="bi bi-save"></i> Save</button>
                    </div>
                  </div>
                </div>
                <!-- Model/Overrides -->
                <div class="tab-pane fade" id="tabModel">
                  <div class="row g-3">
                    <div class="col-12">
                      <div class="alert alert-secondary py-2">Use the Model selector above to assign or change the
                        model. Defaults can be overridden below.</div>
                    </div>
                    <div class="col-12">
                      <label class="form-label">Overrides (JSON)</label>
                      <textarea id="overridesEditor" class="form-control" rows="6"
                        placeholder="{\n  &quot;minPulse&quot;: 500,\n  &quot;maxPulse&quot;: 2500\n}"></textarea>
                      <div class="d-flex justify-content-end mt-2 gap-2">
                        <button id="saveOverridesBtn" class="btn btn-success btn-sm"><i class="bi bi-save"></i> Save
                          Overrides</button>
                        <button id="revertOverridesBtn" class="btn btn-outline-warning btn-sm"><i
                            class="bi bi-arrow-counterclockwise"></i> Revert to Model</button>
                      </div>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Model Defaults</label>
                      <pre id="modelDefaultsJson" class="bg-dark text-light p-2 small" style="min-height:120px">{}</pre>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Effective</label>
                      <pre id="effectiveJson" class="bg-dark text-light p-2 small" style="min-height:120px">{}</pre>
                    </div>

                  </div>
                </div>
                <!-- Safety -->
                <div class="tab-pane fade" id="tabSafety">
                  <div class="row g-2">
                    <div class="col-6">
                      <label class="form-label">Current limit (A)</label>
                      <input id="safetyCurrent" type="number" class="form-control" placeholder="e.g., 8">
                    </div>
                    <div class="col-6">
                      <label class="form-label">Timeout (ms)</label>
                      <input id="safetyTimeout" type="number" class="form-control" placeholder="e.g., 1500">
                    </div>
                  </div>
                </div>
                <!-- Advanced -->
                <div class="tab-pane fade" id="tabAdvanced">
                  <div class="alert alert-secondary mb-0">Advanced settings per device will appear here.</div>
                </div>
              </div>
            </div>
            <div class="card-footer d-flex justify-content-between">
              <div class="text-muted small" id="devNotes">Notes: —</div>
              <div class="d-flex gap-2">
                <button class="btn btn-outline-info btn-sm" id="btnTestSweep"><i class="bi bi-arrows"></i> Sweep
                  Test</button>
                <button class="btn btn-outline-danger btn-sm" id="btnRemove" disabled><i class="bi bi-trash"></i>
                  Remove</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Panel: Markers -->
        <div class="col-12 col-xl-3">
          <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
              <span>Markers</span>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="lockMinMax">
                <label class="form-check-label" for="lockMinMax">Lock Min/Max</label>
              </div>
            </div>
            <div class="card-body">
              <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <strong>Min</strong>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-secondary" id="setMinBtn">Set from current</button>
                    <button class="btn btn-outline-primary" id="goMinBtn">Go To</button>
                  </div>
                </div>
                <input id="minValue" class="form-control form-control-sm" placeholder="deg / mm / counts / preset">
              </div>
              <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <strong>Mid</strong>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-secondary" id="setMidBtn">Set from current</button>
                    <button class="btn btn-outline-primary" id="goMidBtn">Go To</button>
                  </div>
                </div>
                <input id="midValue" class="form-control form-control-sm" placeholder="deg / mm / counts / preset">
              </div>
              <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <strong>Max</strong>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-secondary" id="setMaxBtn">Set from current</button>
                    <button class="btn btn-outline-primary" id="goMaxBtn">Go To</button>
                  </div>
                </div>
                <input id="maxValue" class="form-control form-control-sm" placeholder="deg / mm / counts / preset">
              </div>
              <hr>
              <div id="customMarkers" class="d-flex flex-wrap gap-2"></div>
              <div class="input-group input-group-sm mt-2">
                <input id="newMarkerName" class="form-control" placeholder="New marker name">
                <button id="addMarkerBtn" class="btn btn-outline-success"><i class="bi bi-plus"></i> Add</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Rail: Cross-Device Locations -->
      <div class="mt-3">
        <div id="bottomRail" class="d-flex flex-wrap gap-2"></div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/character-menu.js"></script>
    <script>
      (function () {
        const elList = document.getElementById('deviceList');
        const searchEl = document.getElementById('searchDevices');
        const modelSelect = document.getElementById('modelSelect');
        const modelBadge = document.getElementById('modelBadge');
        const overridesEditor = document.getElementById('overridesEditor');
        const devName = document.getElementById('devName');
        const devMeta = document.getElementById('devMeta');
        const bottomRail = document.getElementById('bottomRail');
        const globalSpeedCap = document.getElementById('globalSpeedCap');
        const globalSpeedCapVal = document.getElementById('globalSpeedCapVal');

        let parts = [];
        let selected = null;
        let modelsCache = {}; // by type

        globalSpeedCap.addEventListener('input', () => globalSpeedCapVal.textContent = globalSpeedCap.value + '%');

        async function loadParts() {
          // Get current character first
          let characterId = null;
          try {
            const currentRes = await fetch('/setup/characters/api/current');
            const currentData = await currentRes.json();
            characterId = currentData.selectedCharacter;
          } catch (e) {
            console.warn('Could not get current character:', e);
          }

          const url = characterId ? `/setup/calibration/api/parts?characterId=${characterId}` : '/setup/calibration/api/parts';
          const res = await fetch(url);
          const j = await res.json();
          if (!j.success) throw new Error('Failed to load parts');
          parts = j.parts || [];
          renderList(parts);
          renderBottomRail(parts);
        }

        function renderList(items) {
          const q = (searchEl.value || '').toLowerCase();
          elList.innerHTML = '';
          items.filter(p => !q || p.name.toLowerCase().includes(q) || p.type.includes(q)).forEach(p => {
            const a = document.createElement('a');
            a.href = 'javascript:void(0)';
            a.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
            a.setAttribute('data-pid', p.id);
            var badges = '';
            if (p.needsModel) badges += '<span class="badge text-bg-warning me-1">Needs Model</span>';
            if (p.needsCalibration) badges += '<span class="badge text-bg-info me-1">Needs Cal</span>';
            if (p.gpioConflict) badges += '<span class="badge text-bg-danger">GPIO</span>';
            a.innerHTML = `<div><div class="fw-semibold">${p.name}</div><small class="text-muted">${p.type}</small></div>` +
              `<div>${badges}</div>`;
            a.addEventListener('click', () => selectPart(p.id));
            elList.appendChild(a);
          });
        }
        searchEl.addEventListener('input', () => renderList(parts));

        async function selectPart(id) {
          selected = parts.find(function (p) { return String(p.id) === String(id); });
          if (!selected) return;
          devName.textContent = selected.name;
          devMeta.textContent = 'ID: ' + selected.id + ' | Type: ' + selected.type;
          modelBadge.textContent = 'Model: ' + (selected.modelId || '—');
          overridesEditor.value = JSON.stringify(selected.config || {}, null, 2);
          await ensureModelsLoaded(selected.type);
          populateModelSelect(selected.type, selected.modelId);
          var ctrlTabBtn = document.querySelector('button[data-bs-target="#tabControls"]');
          if (ctrlTabBtn) ctrlTabBtn.click();
          renderControls(selected);
          renderEdit(selected);
          refreshEffective(selected.id);
        }

        async function ensureModelsLoaded(type) {
          if (modelsCache[type]) return;
          const res = await fetch(`/setup/models/api/${encodeURIComponent(type)}`);
          const j = await res.json();
          modelsCache[type] = j.models || [];
        }

        function populateModelSelect(type, current) {
          const list = modelsCache[type] || [];
          modelSelect.innerHTML = '<option value="">Select model…</option>' + list.map(m => `<option value="${m.id}" ${String(current || '') === String(m.id) ? 'selected' : ''}>${m.name}</option>`).join('');
        }

        async function refreshEffective(partId) {
          try {
            const r = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(partId)}/effective`);
            const d = await r.json();
            if (!d || !d.success) return;
            const md = document.getElementById('modelDefaultsJson');
            const ef = document.getElementById('effectiveJson');
            if (md) md.textContent = JSON.stringify(d.modelDefaults || {}, null, 2);
            if (ef) ef.textContent = JSON.stringify(d.effective || {}, null, 2);
            if (d.part && d.part.modelId) { modelBadge.textContent = 'Model: ' + d.part.modelId; }
            if (selected && String(selected.id) === String(partId)) {
              selected.modelId = d.part.modelId || selected.modelId;
              selected.config = d.overrides || selected.config;
            }
          } catch (e) { /* ignore */ }
        }


        document.getElementById('assignModelBtn').addEventListener('click', async () => {
          if (!selected) return;
          const val = modelSelect.value;
          if (!val) { alert('Select a model'); return; }
          const resp = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/model`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ modelId: val })
          });
          const j = await resp.json();
          if (j.success) {
            selected.modelId = val;
            modelBadge.textContent = 'Model: ' + val;
            // reflect badge in list
            loadParts();
            var ctrlTabBtn = document.querySelector('button[data-bs-target="#tabControls"]');
            if (ctrlTabBtn) ctrlTabBtn.click();
          } else alert(j.error || 'Failed to assign model');
        });

        document.getElementById('saveOverridesBtn').addEventListener('click', async () => {
          if (!selected) return;
          let obj;
          try { obj = JSON.parse(overridesEditor.value || '{}'); }
          catch (e) { alert('Invalid JSON'); return; }
          const resp = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/overrides`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ overrides: obj })
          });
          const j = await resp.json();
          if (j.success) { selected.config = j.config; alert('Overrides saved'); refreshEffective(selected.id); }
          else alert(j.error || 'Failed to save overrides');
        });

        document.getElementById('revertOverridesBtn').addEventListener('click', async () => {
          if (!selected) return;
          overridesEditor.value = '{}';
          const resp = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/overrides`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ overrides: {} })
          });
          const j = await resp.json();
          if (j.success) { selected.config = j.config; refreshEffective(selected.id); }
        });

        function renderControls(part) {
          const el = document.getElementById('controlsArea');
          if (part.type === 'servo') {
            const isCont = String(part.config?.servoType || 'standard') === 'continuous';
            if (isCont) {
              el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
                '<button class="btn btn-primary btn-lg" data-dir="ccw"><i class="bi bi-arrow-counterclockwise"></i> CCW</button>' +
                '<button class="btn btn-danger btn-lg" data-dir="stop"><i class="bi bi-stop-circle"></i> Stop</button>' +
                '<button class="btn btn-primary btn-lg" data-dir="cw">CW <i class="bi bi-arrow-clockwise"></i></button>' +
                '<input type="number" id="spd" class="form-control form-control-lg" value="35" style="width:110px">% ' +
                '<input type="number" id="dur" class="form-control form-control-lg" value="300" style="width:140px"> ms' +
                '</div>' +
                '<div id="ctrlStatus" class="mt-2 small text-info"></div>';
              el.querySelectorAll('button[data-dir]').forEach(b => b.addEventListener('click', async () => {
                const dir = b.getAttribute('data-dir');
                const speed = parseInt(document.getElementById('spd').value || '35', 10);
                const duration = parseInt(document.getElementById('dur').value || '300', 10);
                const st = document.getElementById('ctrlStatus');
                if (st) st.textContent = 'Executing…';
                try {
                  await fetch(`/setup/calibration/api/continuous_servo/${encodeURIComponent(part.id)}/jog`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ direction: dir, speed, duration }) });
                  if (st) st.textContent = 'Done';
                  setTimeout(() => { if (st) st.textContent = ''; }, 800);
                } catch (e) { if (st) st.textContent = 'Failed'; }
              }));
            } else {
              el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
                '<input id="ang" type="range" min="0" max="180" value="90" class="form-range" style="width:320px">' +
                '<input id="angNum" type="number" class="form-control form-control-lg" value="90" style="width:110px">° ' +
                '<button id="goAng" class="btn btn-success btn-lg"><i class="bi bi-cursor"></i> Move</button>' +
                '</div>' +
                '<div id="ctrlStatus" class="mt-2 small text-info"></div>';
              const s = el.querySelector('#ang');
              const n = el.querySelector('#angNum');
              s.addEventListener('input', () => n.value = s.value);
              n.addEventListener('input', () => s.value = n.value);
              el.querySelector('#goAng').addEventListener('click', async () => {
                const angle = parseInt(n.value || '90', 10);
                const st = document.getElementById('ctrlStatus');
                if (st) st.textContent = 'Moving…';
                try {
                  await fetch(`/setup/calibration/api/standard_servo/${encodeURIComponent(part.id)}/move`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ angle }) });
                  if (st) st.textContent = 'Done';
                  setTimeout(() => { if (st) st.textContent = ''; }, 800);
                } catch (e) { if (st) st.textContent = 'Failed'; }

              });
            }
          } else if (part.type === 'linear_actuator') {
            el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
              '<button class="btn btn-primary btn-lg" id="extendBtn"><i class="bi bi-caret-up-fill"></i> Extend</button>' +
              '<button class="btn btn-danger btn-lg" id="stopBtn"><i class="bi bi-stop-circle"></i> Stop</button>' +
              '<button class="btn btn-primary btn-lg" id="retractBtn"><i class="bi bi-caret-down-fill"></i> Retract</button>' +
              '<input type="number" id="laSpd" class="form-control form-control-lg" value="50" style="width:110px">%' +
              '<input type="number" id="laDur" class="form-control form-control-lg" value="500" style="width:140px"> ms' +
              '</div>' +
              '<div id="ctrlStatus" class="mt-2 small text-info"></div>';
            const spd = () => parseInt(document.getElementById('laSpd').value || '50', 10);
            const dur = () => parseInt(document.getElementById('laDur').value || '500', 10);
            el.querySelector('#extendBtn').addEventListener('click', async () => { const st = document.getElementById('ctrlStatus'); if (st) st.textContent = 'Extending…'; try { await fetch(`/setup/calibration/api/linear_actuator/${encodeURIComponent(part.id)}/jog`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ direction: 'extend', speed: spd(), duration: dur() }) }); if (st) st.textContent = 'Done'; setTimeout(() => { if (st) st.textContent = ''; }, 800); } catch (e) { if (st) st.textContent = 'Failed'; } });
            el.querySelector('#retractBtn').addEventListener('click', async () => { const st = document.getElementById('ctrlStatus'); if (st) st.textContent = 'Retracting…'; try { await fetch(`/setup/calibration/api/linear_actuator/${encodeURIComponent(part.id)}/jog`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ direction: 'retract', speed: spd(), duration: dur() }) }); if (st) st.textContent = 'Done'; setTimeout(() => { if (st) st.textContent = ''; }, 800); } catch (e) { if (st) st.textContent = 'Failed'; } });
            el.querySelector('#stopBtn').addEventListener('click', async () => { const st = document.getElementById('ctrlStatus'); if (st) st.textContent = 'Stopping…'; try { await fetch(`/setup/calibration/api/linear_actuator/${encodeURIComponent(part.id)}/stop`, { method: 'POST' }); if (st) st.textContent = 'Stopped'; setTimeout(() => { if (st) st.textContent = ''; }, 800); } catch (e) { if (st) st.textContent = 'Failed'; } });
          } else if (part.type === 'motor') {
            el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
              '<select id="motDir" class="form-select form-select-lg" style="width:140px"><option value="forward">Forward</option><option value="reverse">Reverse</option></select>' +
              '<input type="number" id="motSpd" class="form-control form-control-lg" value="50" style="width:110px">%' +
              '<input type="number" id="motDur" class="form-control form-control-lg" value="500" style="width:140px"> ms' +
              '<button id="motRun" class="btn btn-success btn-lg"><i class="bi bi-play-fill"></i> Run</button>' +
              '</div><div id="ctrlStatus" class="mt-2 small text-info"></div>';
            el.querySelector('#motRun').addEventListener('click', function () {
              var dir = document.getElementById('motDir').value;
              var speed = parseInt(document.getElementById('motSpd').value || '50', 10);
              var duration = parseInt(document.getElementById('motDur').value || '500', 10);
              var st = document.getElementById('ctrlStatus'); if (st) st.textContent = 'Running…';
              fetch('/setup/parts/api/parts/' + encodeURIComponent(part.id) + '/test', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'control', params: { direction: dir, speed: speed, duration: duration } })
              }).then(function () { if (st) st.textContent = 'Done'; setTimeout(function () { if (st) st.textContent = ''; }, 800); })
                .catch(function () { if (st) st.textContent = 'Failed'; });
            });
          } else if (part.type === 'light') {
            el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
              '<button id="lightToggle" class="btn btn-primary btn-lg"><i class="bi bi-lightbulb"></i> Toggle</button>' +
              '</div><div id="ctrlStatus" class="mt-2 small text-info"></div>';
            el.querySelector('#lightToggle').addEventListener('click', function () {
              var st = document.getElementById('ctrlStatus'); if (st) st.textContent = 'Toggling…';
              fetch('/setup/parts/api/parts/' + encodeURIComponent(part.id) + '/test', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'toggle' })
              }).then(function () { if (st) st.textContent = 'Done'; setTimeout(function () { if (st) st.textContent = ''; }, 800); })
                .catch(function () { if (st) st.textContent = 'Failed'; });
            });
          } else if (part.type === 'led') {
            el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
              '<input type="range" id="ledBri" min="0" max="100" value="50" class="form-range" style="width:320px">' +
              '<button id="ledSet" class="btn btn-success btn-lg"><i class="bi bi-brightness-high"></i> Set</button>' +
              '</div><div id="ctrlStatus" class="mt-2 small text-info"></div>';
            el.querySelector('#ledSet').addEventListener('click', function () {
              var bri = parseInt(document.getElementById('ledBri').value || '50', 10);
              var st = document.getElementById('ctrlStatus'); if (st) st.textContent = 'Setting…';
              fetch('/setup/parts/api/parts/' + encodeURIComponent(part.id) + '/test', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'setBrightness', params: { brightness: bri } })
              }).then(function () { if (st) st.textContent = 'Done'; setTimeout(function () { if (st) st.textContent = ''; }, 800); })
                .catch(function () { if (st) st.textContent = 'Failed'; });
            });
          } else if (part.type === 'speaker') {
            el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
              '<button id="spkPlay" class="btn btn-success btn-lg"><i class="bi bi-megaphone"></i> Play Preview</button>' +
              '</div><div id="ctrlStatus" class="mt-2 small text-info"></div>';
            el.querySelector('#spkPlay').addEventListener('click', function () {
              var st = document.getElementById('ctrlStatus'); if (st) st.textContent = 'Playing…';
              fetch('/setup/parts/api/parts/' + encodeURIComponent(part.id) + '/test', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'play' })
              }).then(function () { if (st) st.textContent = 'Done'; setTimeout(function () { if (st) st.textContent = ''; }, 800); })
                .catch(function () { if (st) st.textContent = 'Failed'; });
            });
          } else if (part.type === 'microphone') {
            el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
              '<div class="progress" style="width:260px;height:24px"><div id="micVu" class="progress-bar" style="width:0%"></div></div>' +
              '<span id="micLevel" class="ms-2">0</span>' +
              '<button id="micPoll" class="btn btn-outline-secondary btn-lg"><i class="bi bi-activity"></i> Poll</button>' +
              '</div><div id="ctrlStatus" class="mt-2 small text-info"></div>';
            function pollOnce() {
              fetch('/setup/parts/api/parts/' + encodeURIComponent(part.id) + '/test', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'getLevel' })
              }).then(function (r) { return r.json(); }).then(function (j) {
                var lvl = (j && j.testResult && (j.testResult.details && (j.testResult.details.level || j.testResult.details.value))) || 0;
                var n = Math.max(0, Math.min(100, parseInt(lvl, 10) || 0));
                var bar = document.getElementById('micVu'); var txt = document.getElementById('micLevel');
                if (bar) bar.style.width = n + '%'; if (txt) txt.textContent = n;
              }).catch(function () { });
            }
            var pollBtn = el.querySelector('#micPoll'); if (pollBtn) pollBtn.addEventListener('click', pollOnce);
          } else if (part.type === 'webcam') {
            // Webcam live preview + typical controls (brightness, contrast, saturation, IR if available) and digital zoom
            el.innerHTML = '' +
              '<div class="row g-3 align-items-start">' +
              '<div class="col-md-6">' +
              '<div class="border bg-black d-flex justify-content-center align-items-center" style="width:100%;max-width:420px;height:320px;overflow:hidden">' +
              '<img id="camPreview" src="/setup/webcam/api/parts/' + encodeURIComponent(part.id) + '/stream" style="max-width:none;transform-origin:center center;transform:scale(1)">' +
              '</div>' +
              '<div class="mt-2">' +
              '<label class="form-label small">Digital zoom: <span id="zoomVal">100%</span></label>' +
              '<input type="range" class="form-range" id="camZoom" min="100" max="300" step="5" value="100">' +
              '</div>' +
              '<div class="mt-2 d-flex flex-wrap gap-2">' +
              '<a class="btn btn-outline-primary" href="http://localhost:8090/?action=stream" target="_blank"><i class="bi bi-box-arrow-up-right"></i> Open Stream</a>' +
              '<button id="camSnap" class="btn btn-outline-secondary"><i class="bi bi-camera"></i> Capture</button>' +
              '</div>' +
              '<div id="ctrlStatus" class="mt-2 small text-info"></div>' +
              '</div>' +
              '<div class="col-md-6">' +
              '<div class="d-flex justify-content-between align-items-center mb-2">' +
              '<h6 class="mb-0"><i class="bi bi-sliders"></i> Controls</h6>' +
              '<div class="d-flex gap-2">' +
              '<button id="loadCamCtrls" class="btn btn-sm btn-outline-info"><i class="bi bi-arrow-repeat"></i> Load</button>' +
              '<button id="applyCamCtrls" class="btn btn-sm btn-success"><i class="bi bi-check2-circle"></i> Apply & Save</button>' +
              '</div>' +
              '</div>' +
              '<div class="mb-2">' +
              '<label class="form-label">Brightness <span id="lbl_brightness" class="text-muted"></span></label>' +
              '<input id="ctrl_brightness" type="range" class="form-range" min="0" max="255" step="1" value="128">' +
              '</div>' +
              '<div class="mb-2">' +
              '<label class="form-label">Contrast <span id="lbl_contrast" class="text-muted"></span></label>' +
              '<input id="ctrl_contrast" type="range" class="form-range" min="0" max="255" step="1" value="128">' +
              '</div>' +
              '<div class="mb-2">' +
              '<label class="form-label">Saturation <span id="lbl_saturation" class="text-muted"></span></label>' +
              '<input id="ctrl_saturation" type="range" class="form-range" min="0" max="255" step="1" value="128">' +
              '</div>' +
              '<div class="form-check form-switch mb-2">' +
              '<input class="form-check-input" type="checkbox" id="ctrl_ir">' +
              '<label class="form-check-label" for="ctrl_ir">IR Cut / Night Mode</label>' +
              '</div>' +
              '</div>' +
              '</div>';

            // Zoom
            var zoom = el.querySelector('#camZoom'); var zoomLbl = el.querySelector('#zoomVal'); var prev = el.querySelector('#camPreview');
            function applyZoom() { var v = parseInt(zoom.value, 10) || 100; if (zoomLbl) zoomLbl.textContent = v + '%'; if (prev) prev.style.transform = 'scale(' + (v / 100) + ')'; }
            if (zoom) { zoom.addEventListener('input', applyZoom); applyZoom(); }

            // Capture
            var st = el.querySelector('#ctrlStatus');
            var capBtn = el.querySelector('#camSnap');
            if (capBtn) capBtn.addEventListener('click', function () {
              if (st) st.textContent = 'Capturing…';
              fetch('/setup/parts/api/parts/' + encodeURIComponent(part.id) + '/test', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'capture' })
              }).then(function () { if (st) st.textContent = 'Done'; setTimeout(function () { if (st) st.textContent = ''; }, 800); })
                .catch(function () { if (st) st.textContent = 'Failed'; });
            });

            // Controls load/apply
            function setIf(elm, v, min, max) { if (!elm) return; var nv = (typeof v === 'number') ? v : (parseInt(v, 10) || 0); if (typeof min === 'number') nv = Math.max(min, nv); if (typeof max === 'number') nv = Math.min(max, nv); elm.value = String(nv); var lbl = el.querySelector('#lbl_' + (elm.id.split('_')[1] || '')); if (lbl) lbl.textContent = '(' + nv + ')'; }
            function readControlsFromUI() {
              var o = {};
              var b = el.querySelector('#ctrl_brightness'); if (b) o.brightness = parseInt(b.value, 10);
              var c = el.querySelector('#ctrl_contrast'); if (c) o.contrast = parseInt(c.value, 10);
              var s = el.querySelector('#ctrl_saturation'); if (s) o.saturation = parseInt(s.value, 10);
              var ir = el.querySelector('#ctrl_ir'); if (ir) o.ir_cut = ir.checked ? 1 : 0;
              return o;
            }
            var loadBtn = el.querySelector('#loadCamCtrls');
            if (loadBtn) loadBtn.addEventListener('click', function () {
              if (st) st.textContent = 'Loading controls…';
              fetch('/setup/webcam/api/parts/' + encodeURIComponent(part.id) + '/controls/list')
                .then(function (r) { return r.json(); })
                .then(function (j) {
                  if (!j || j.success === false) { if (st) st.textContent = 'Failed to load controls'; return; }
                  var ctrls = j.controls || {};
                  // Common V4L2 control keys
                  setIf(el.querySelector('#ctrl_brightness'), ctrls.brightness, 0, 255);
                  setIf(el.querySelector('#ctrl_contrast'), ctrls.contrast, 0, 255);
                  setIf(el.querySelector('#ctrl_saturation'), ctrls.saturation, 0, 255);
                  var ir = el.querySelector('#ctrl_ir'); if (ir) { var v = (ctrls.ir_cut != null ? ctrls.ir_cut : (ctrls.infrared != null ? ctrls.infrared : 0)); ir.checked = !!(+v); }
                  if (st) st.textContent = 'Controls loaded'; setTimeout(function () { if (st) st.textContent = ''; }, 800);
                })
                .catch(function () { if (st) st.textContent = 'Failed to load controls'; });
            });
            var applyBtn = el.querySelector('#applyCamCtrls');
            if (applyBtn) applyBtn.addEventListener('click', function () {
              if (st) st.textContent = 'Applying…';
              var controls = readControlsFromUI();
              fetch('/setup/webcam/api/parts/' + encodeURIComponent(part.id) + '/controls/set', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ controls: controls, persist: true })
              }).then(function (r) { return r.json(); }).then(function (j) {
                if (j && j.success) { if (st) st.textContent = 'Applied'; }
                else { if (st) st.textContent = 'Failed: ' + (j && j.error || ''); }
                setTimeout(function () { if (st) st.textContent = ''; }, 1000);
              }).catch(function () { if (st) st.textContent = 'Failed'; });
            });
          } else if (part.type === 'sensor' || part.type === 'motion_sensor') {
            el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
              '<button id="snsRead" class="btn btn-primary btn-lg"><i class="bi bi-graph-up"></i> Read</button>' +
              '<pre id="snsOut" class="ms-2 small"></pre>' +
              '</div>';
            el.querySelector('#snsRead').addEventListener('click', function () {
              fetch('/setup/parts/api/parts/' + encodeURIComponent(part.id) + '/test', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'read' })
              }).then(function (r) { return r.json(); }).then(function (j) {
                var out = document.getElementById('snsOut');
                if (out) out.textContent = JSON.stringify(j && j.testResult && j.testResult.details || j, null, 2);
              }).catch(function () { });
            });
          } else if (part.type === 'head_tracking') {
            el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
              '<button id="htGet" class="btn btn-primary btn-lg"><i class="bi bi-bullseye"></i> Get Position</button>' +
              '<pre id="htOut" class="ms-2 small"></pre>' +
              '</div>';
            el.querySelector('#htGet').addEventListener('click', function () {
              fetch('/setup/parts/api/parts/' + encodeURIComponent(part.id) + '/test', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'getPosition' })
              }).then(function (r) { return r.json(); }).then(function (j) {
                var out = document.getElementById('htOut');
                if (out) out.textContent = JSON.stringify(j && j.testResult && j.testResult.details || j, null, 2);
              }).catch(function () { });
            });
          } else {
            el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
              '<button id="quickTest" class="btn btn-outline-secondary btn-lg"><i class="bi bi-gear"></i> Quick Test</button>' +
              '<div id="ctrlStatus" class="mt-2 small text-info"></div>' +
              '</div>';
            el.querySelector('#quickTest').addEventListener('click', function () {
              var st = document.getElementById('ctrlStatus'); if (st) st.textContent = 'Testing…';
              fetch('/setup/parts/api/parts/' + encodeURIComponent(part.id) + '/test', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({})
              }).then(function () { if (st) st.textContent = 'Done'; setTimeout(function () { if (st) st.textContent = ''; }, 800); })
                .catch(function () { if (st) st.textContent = 'Failed'; });
            });
          }

          function renderPinFields(part) {
            var container = document.getElementById('pinFields');
            if (!container) return;
            var html = '';
            function field(id, label, type, placeholder) {
              return '<div class="col-md-3"><label class="form-label">' + label + '</label>' +
                '<input id="' + id + '" class="form-control" ' + (type === 'number' ? 'type="number"' : '') + ' placeholder="' + (placeholder || '') + '"></div>';
            }
            if (part.type === 'motor' || part.type === 'linear_actuator') {
              html += '<div class="row g-3">';
              html += field('editPin', 'PWM Pin', 'number', 'GPIO');
              html += field('editDirectionPin', 'Direction Pin', 'number', 'GPIO');
              html += '</div>';
            } else if (part.type === 'servo' || part.type === 'led' || part.type === 'light' || part.type === 'sensor' || part.type === 'motion_sensor') {
              html += '<div class="row g-3">' + field('editPin', 'Pin', 'number', 'GPIO') + '</div>';
            } else {
              html = '<div class="text-muted">No pin fields for this part type.</div>';
            }
            container.innerHTML = html;
            // Populate current values if present
            var cfg = part || {};
            var pin = (cfg.pin != null ? cfg.pin : (cfg.config && cfg.config.pin));
            var pwm = (cfg.pwmPin != null ? cfg.pwmPin : (cfg.config && cfg.config.pwmPin));
            var dir = (cfg.directionPin != null ? cfg.directionPin : (cfg.config && cfg.config.directionPin));
            var el;
            el = document.getElementById('editPin'); if (el && pin != null) el.value = pin;
            el = document.getElementById('editDirectionPin'); if (el && dir != null) el.value = dir;
            el = document.getElementById('editPwmPin'); if (el && pwm != null) el.value = pwm;
          }

          function renderEdit(part) {
            var n = document.getElementById('editName'); if (n) n.value = part.name || '';
            var en = document.getElementById('editEnabled'); if (en) en.checked = !!part.enabled;
            var d = document.getElementById('editDescription'); if (d) d.value = part.description || '';
            var c = document.getElementById('editConfig'); if (c) c.value = JSON.stringify(part.config || {}, null, 2);
            renderPinFields(part);
            var save = document.getElementById('saveEditBtn');
            if (save && !save._bound) {
              save._bound = true;
              save.addEventListener('click', function () {
                if (!selected) return;
                var payload = {
                  name: (document.getElementById('editName') || {}).value,
                  enabled: !!((document.getElementById('editEnabled') || {}).checked),
                  description: (document.getElementById('editDescription') || {}).value,
                  config: {}
                };
                try { payload.config = JSON.parse((document.getElementById('editConfig') || { value: '{}' }).value || '{}'); } catch (e) { alert('Config must be valid JSON'); return; }
                var p;
                p = document.getElementById('editPin'); if (p && p.value !== '') payload.pin = parseInt(p.value, 10);
                p = document.getElementById('editDirectionPin'); if (p && p.value !== '') payload.directionPin = parseInt(p.value, 10);
                p = document.getElementById('editPwmPin'); if (p && p.value !== '') payload.pwmPin = parseInt(p.value, 10);
                fetch('/setup/parts/api/parts/' + encodeURIComponent(selected.id), {
                  method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
                }).then(function (r) { return r.json(); }).then(function () {
                  // Refresh list
                  if (typeof loadParts === 'function') loadParts();
                }).catch(function () { alert('Failed to save'); });
              });
            }
          }

        }

        function renderBottomRail(items) {
          bottomRail.innerHTML = '';
          items.forEach(p => {
            const chip = document.createElement('span');
            chip.className = 'badge rounded-pill text-bg-dark marker-chip';
            chip.textContent = `${p.name} · Min/Mid/Max`;
            bottomRail.appendChild(chip);
          });
        }


        // Markers wiring (outside renderControls to keep handlers stable)
        function unitFor(part) {
          if (!part) return undefined;
          if (part.type === 'servo' && String(part.config?.servoType || 'standard') !== 'continuous') return 'deg';
          return undefined;
        }
        async function saveMarkerFromField(fieldId, name) {
          if (!selected) return;
          const el = document.getElementById(fieldId);
          if (!el) return;
          const raw = el.value;
          const num = raw !== '' ? Number(raw) : undefined;
          const body = { name, kind: 'absolute', value: num, unit: unitFor(selected) };
          await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/markers`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
          }).catch(() => { });
        }
        async function goToField(fieldId) {
          if (!selected) return;
          const el = document.getElementById(fieldId);
          const num = el && el.value !== '' ? Number(el.value) : undefined;
          if (selected.type === 'servo' && String(selected.config?.servoType || 'standard') !== 'continuous' && typeof num === 'number') {
            await fetch(`/setup/calibration/api/standard_servo/${encodeURIComponent(selected.id)}/move`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ angle: Math.round(num) }) });
          }
        }
        const setMinBtn = document.getElementById('setMinBtn'); if (setMinBtn) setMinBtn.addEventListener('click', () => saveMarkerFromField('minValue', 'Min'));
        const setMidBtn = document.getElementById('setMidBtn'); if (setMidBtn) setMidBtn.addEventListener('click', () => saveMarkerFromField('midValue', 'Mid'));
        const setMaxBtn = document.getElementById('setMaxBtn'); if (setMaxBtn) setMaxBtn.addEventListener('click', () => saveMarkerFromField('maxValue', 'Max'));
        const goMinBtn = document.getElementById('goMinBtn'); if (goMinBtn) goMinBtn.addEventListener('click', () => goToField('minValue'));
        const goMidBtn = document.getElementById('goMidBtn'); if (goMidBtn) goMidBtn.addEventListener('click', () => goToField('midValue'));
        const goMaxBtn = document.getElementById('goMaxBtn'); if (goMaxBtn) goMaxBtn.addEventListener('click', () => goToField('maxValue'));

        loadParts().catch(e => console.error(e));
      })();
    </script>
</body>

</html>