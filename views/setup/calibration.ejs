      removeBtn.addEventListener('click', async () => {
        if (!selected) return;

        const confirmMessage = `Are you sure you want to delete "${selected.name}"?\n\nThis will permanently remove the part and all associated records including:\n• Calibration data\n• Saved positions\n• Markers\n• Configuration settings\n\nThis action cannot be undone.`;

        if (confirm(confirmMessage)) {
          try {
            const response = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}`, {
              method: 'DELETE'
            });

            if (response.ok) {
              showToast(`Part "${selected.name}" deleted successfully`, 'success');
              // Clear selection and reload parts list
              selected = null;
              await loadParts();
              // Clear the UI
              renderControls(null);
              renderMarkers([]);
              renderBottomRail([]);
            } else {
              const errorData = await response.json().catch(() => ({}));
              showToast(`Failed to delete part: ${errorData.error || 'Unknown error'}`, 'error');
            }
          } catch (error) {
            console.error('Error deleting part:', error);
            showToast('Error deleting part', 'error');
          }
        }
      });
    }

    // Load markers for the selected part
    async function loadMarkers() {
      if (!selected) return;
      try {
        const response = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/markers`);
        if (response.ok) {
          const data = await response.json();
          renderMarkers(data.markers || []);
        }
      } catch (error) {
        console.error('Error loading markers:', error);
      }
    }

    // Render markers in the UI
    function renderMarkers(markers) {
      const customMarkersEl = document.getElementById('customMarkers');
      if (!customMarkersEl) return;

      // Clear existing custom markers
      customMarkersEl.innerHTML = '';

      // Add custom markers (excluding Min, Mid, Max which are handled separately)
      markers.filter(m => !['Min', 'Mid', 'Max'].includes(m.name)).forEach(marker => {
        const chip = document.createElement('span');
        chip.className = 'badge rounded-pill text-bg-secondary me-1 mb-1';
        chip.innerHTML = `${marker.name}: ${marker.value}${marker.unit || ''} <button type="button" class="btn-close btn-close-white ms-1" onclick="deleteMarker('${marker.name}')"></button>`;
        customMarkersEl.appendChild(chip);
      });

      // Populate Min/Mid/Max fields
      const minMarker = markers.find(m => m.name === 'Min');
      const midMarker = markers.find(m => m.name === 'Mid');
      const maxMarker = markers.find(m => m.name === 'Max');

      const minEl = document.getElementById('minValue');
      const midEl = document.getElementById('midValue');
      const maxEl = document.getElementById('maxValue');

      if (minEl) minEl.value = minMarker ? minMarker.value : '';
      if (midEl) midEl.value = midMarker ? midMarker.value : '';
      if (maxEl) maxEl.value = maxMarker ? maxMarker.value : '';
    }

    // Delete a custom marker
    async function deleteMarker(name) {
      if (!selected) return;
      try {
        const response = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/markers/${encodeURIComponent(name)}`, {
          method: 'DELETE'
        });
        if (response.ok) {
          await loadMarkers();
          showToast(`Marker "${name}" deleted`, 'success');
        } else {
          showToast('Failed to delete marker', 'error');
        }
      } catch (error) {
        console.error('Error deleting marker:', error);
        showToast('Error deleting marker', 'error');
      }
    }

    // Show toast notification — delegates to global showToast
    function showToast(message, type) {
      if (window.showToast && window.showToast !== showToast) {
        window.showToast(message, type);
      } else if (window.MonsterBox && window.MonsterBox.showNotification) {
        window.MonsterBox.showNotification(message, type);
      }
    }

    // Expose for other inline scripts that run earlier on DOMContentLoaded
    window.loadParts = loadParts;
    loadParts().catch(e => console.error(e));

    // Simple Calibration helpers (Unified) - define if not already defined
    if (typeof window.sc_refresh === 'undefined') {
      function sc_currentValue() {
        var part = window.selectedPart || {}; var t = String(part.type || '');
        if (t === 'servo') {
          var n = document.getElementById('angNum'); if (n) { var v = parseFloat(n.value || '0.5'); if (!isNaN(v)) return v; }
          var v2 = prompt('Enter position (0.000-1.000)'); var pv = parseFloat(v2); return isNaN(pv) ? 0.5 : pv;
        } else if (t === 'motor') {
          var d = document.getElementById('motDur'); if (d) { var v3 = parseInt(d.value || '500', 10); if (!isNaN(v3)) return v3; }
          var v4 = prompt('Enter duration (ms)'); var pv2 = parseInt(v4, 10); return isNaN(pv2) ? 500 : pv2;
        } else if (t === 'linear_actuator') {
          var d2 = document.getElementById('laDur'); if (d2) { var v5 = parseInt(d2.value || '500', 10); if (!isNaN(v5)) return v5; }
          var v6 = prompt('Enter duration (ms)'); var pv3 = parseInt(v6, 10); return isNaN(pv3) ? 500 : pv3;
        }
        var fallback = prompt('Enter value'); var pf = parseInt(fallback, 10); return isNaN(pf) ? 0 : pf;
      }
      async function sc_refresh() {
        try {
          var pid = window.selectedPartId; if (!pid) return;
          const r = await fetch(`/setup/calibration/api/simple/${encodeURIComponent(pid)}`);
          const j = await r.json(); if (!j || j.success === false) return;
          var d = j.calibration || {};
          var minEl = document.getElementById('scMinVal'); var maxEl = document.getElementById('scMaxVal');
          if (minEl) minEl.textContent = (typeof d.safeMin === 'number') ? String(d.safeMin) : 'Not Set';
          if (maxEl) maxEl.textContent = (typeof d.safeMax === 'number') ? String(d.safeMax) : 'Not Set';
          var list = document.getElementById('scList'); if (list) {
            list.innerHTML = '';
            (d.points || []).forEach(function (p) {
              var li = document.createElement('li'); li.className = 'list-group-item d-flex justify-content-between align-items-center';
              var left = document.createElement('div');
              var strong = document.createElement('strong'); strong.textContent = p.name; left.appendChild(strong);
              var sub = document.createElement('div'); sub.className = 'small text-muted'; sub.textContent = String(p.value); left.appendChild(sub);
              var btns = document.createElement('div'); btns.className = 'btn-group btn-group-sm';
              var del = document.createElement('button'); del.className = 'btn btn-outline-danger'; del.innerHTML = '<i class="bi bi-trash"></i>';
              del.addEventListener('click', function () { window.sc_del(p.name); });
              btns.appendChild(del);
              li.appendChild(left); li.appendChild(btns);
              list.appendChild(li);
            });
          }
        } catch (_) { }
      }
      async function sc_set(which) {
        try {
          var pid = window.selectedPartId; if (!pid) return alert('Select a part first');
          var val = sc_currentValue();
          const r = await fetch(`/setup/calibration/api/simple/${encodeURIComponent(pid)}/set-safe`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ which: which, value: val }) });
          const j = await r.json(); if (!j.success) { alert(j.error || 'Failed'); return; }
          sc_refresh();
        } catch (e) { alert('Error: ' + (e && e.message ? e.message : e)); }
      }
      async function sc_add() {
        try {
          var pid = window.selectedPartId; if (!pid) return alert('Select a part first');
          var name = prompt('Position name'); if (!name) return;
          var val = sc_currentValue();
          const r = await fetch(`/setup/calibration/api/simple/${encodeURIComponent(pid)}/points`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name, value: val }) });
          const j = await r.json(); if (!j.success) { alert(j.error || 'Failed'); return; }
          sc_refresh();
        } catch (e) { alert('Error: ' + (e && e.message ? e.message : e)); }
      }
      async function sc_del(name) {
        try {
          var pid = window.selectedPartId; if (!pid) return;
          if (!confirm('Delete "' + name + '"?')) return;
          const r = await fetch(`/setup/calibration/api/simple/${encodeURIComponent(pid)}/points/${encodeURIComponent(name)}`, { method: 'DELETE' });
          const j = await r.json(); if (!j.success) { alert(j.error || 'Failed'); return; }
          sc_refresh();
        } catch (e) { }
      }
      window.sc_refresh = sc_refresh;
      window.sc_set = sc_set;
      window.sc_add = sc_add;
      window.sc_del = sc_del;
      document.addEventListener('click', function (ev) {
        var t = ev.target; if (!t) return;
        if (t.matches && t.matches('[data-bs-target="#tabEdit"]')) { setTimeout(sc_refresh, 200); }
      });
    }

