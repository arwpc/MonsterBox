        </div>
        <script>
          // Bulk-select toolbar handlers
          document.addEventListener('DOMContentLoaded', function () {
            const selectAllParts = document.getElementById('selectAllParts');
            const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');
            if (selectAllParts) {
              selectAllParts.addEventListener('change', function () {
                const vis = (window.visiblePartIds || []).map(String);
                if (this.checked) vis.forEach(id => window.selectedIdsMulti && window.selectedIdsMulti.add(String(id)));
                else vis.forEach(id => window.selectedIdsMulti && window.selectedIdsMulti.delete(String(id)));
                document.querySelectorAll('.part-select').forEach(cb => {
                  const pid = String(cb.getAttribute('data-pid'));
                  if (vis.includes(pid)) cb.checked = selectAllParts.checked;
                });
                if (window.updateBulkUI) window.updateBulkUI();
              });
            }
            if (deleteSelectedBtn) {
              deleteSelectedBtn.addEventListener('click', async function () {
                try {
                  const setRef = window.selectedIdsMulti instanceof Set ? window.selectedIdsMulti : new Set();
                  const ids = Array.from(setRef);
                  if (!ids.length) { if (window.showToast) window.showToast('No parts selected', 'error'); return; }
                  const names = ids.map(id => {
                    const p = (window.allParts || []).find(pp => String(pp.id) === String(id));
                    return p ? p.name : id;
                  });
                  const confirmMessage = `Are you sure you want to delete ${ids.length} selected part(s)?\n\nThis will permanently remove the parts and all associated records including:\n• Calibration data\n• Saved positions\n• Markers\n• Configuration settings\n\nParts:\n- ${names.join('\n- ')}\n\nThis action cannot be undone.`;
                  if (!confirm(confirmMessage)) return;
                  let successCount = 0, failCount = 0;
                  for (const id of ids) {
                    try {
                      const resp = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(id)}`, { method: 'DELETE' });
                      if (resp.ok) successCount++; else failCount++;
                    } catch (e) { failCount++; }
                  }
                  if (window.showToast) window.showToast(`Deleted ${successCount} part(s)` + (failCount ? `, ${failCount} failed` : ''), failCount ? 'warning' : 'success');
                  // Clear current selection if deleted
                  if (window.selected && ids.includes(String(window.selected.id))) {
                    window.selected = null;
                    if (window.renderControls) window.renderControls(null);
                    if (window.renderMarkers) window.renderMarkers([]);
                    if (window.renderBottomRail) window.renderBottomRail([]);
                  }
                  // Reset selection set and reload
                  if (window.selectedIdsMulti) window.selectedIdsMulti.clear();
                  if (window.loadParts) await window.loadParts();
                  if (window.updateBulkUI) window.updateBulkUI();
                } catch (err) {
                  console.error('Bulk delete error:', err);
                  if (window.showToast) window.showToast('Error deleting selected parts', 'error');
                }
              });
            }
          });
        </script>
