              <div class="mb-3">
                <label for="addModelSelect" class="form-label">Model</label>
                <select class="form-select" id="addModelSelect" data-bs-toggle="tooltip" data-bs-placement="top" title="Optionally assign a hardware model to pre-fill default settings (pulse widths, speed limits, etc.)">
                  <option value="">Select Model (optional)</option>
                </select>
              </div>
            </div>
            <div class="col-md-4 d-flex align-items-end">
              <button type="button" class="btn btn-outline-secondary w-100" id="addModelBtn"
                onclick="window.open('/setup/models', '_blank')">
                <i class="bi bi-plus-circle"></i> Add Model
              </button>
            </div>
          </div>

          <!-- Dynamic configuration area -->
          <div id="addPartConfigArea"></div>

          <!-- Description -->
          <div class="row">
            <div class="col-12">
              <div class="mb-3">
                <label for="addPartDescription" class="form-label">Description</label>
                <input type="text" class="form-control" id="addPartDescription" name="description" data-bs-toggle="tooltip" data-bs-placement="top" title="Optional description of this part's purpose or location on the character">
              </div>
            </div>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" title="Close without creating a part">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="createPartFromCalibration()" data-bs-toggle="tooltip" data-bs-placement="top" title="Create the new hardware part and add it to the current character">Add Part</button>
      </div>
    </div>
  </div>
</div>