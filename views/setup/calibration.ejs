    // Part creation function
    window.createPartFromCalibration = function () {
      const form = document.getElementById('addPartForm');
      const formData = new FormData(form);

      const type = formData.get('type');
      if (!type) {
        alert('Please select a part type');
        return;
      }

      const payload = {
        name: formData.get('name'),
        type: type,
        description: formData.get('description') || ''
      };

      // Handle type-specific configurations
      const partType = partTypes[type];
      let config = {};

      // Add model if selected
      const modelSelect = document.getElementById('addModelSelect');
      if (modelSelect && modelSelect.value) {
        config.modelId = modelSelect.value;
      }

      // Handle pin-based parts
      if (partType.requiresPin) {
        const pin = formData.get('pin');
        if (pin) payload.pin = parseInt(pin, 10);
      }

      // Type-specific handling
      switch (type) {
        case 'servo':
          const servoType = document.getElementById('addServoType').value || 'standard';
          const controllerType = document.getElementById('addControllerType').value || 'gpio';
          config.servoType = servoType;
          config.controllerType = controllerType;

          if (controllerType === 'pca9685') {
            const channel = document.getElementById('addPca9685Channel').value;
            const address = document.getElementById('addPca9685Address').value || '0x40';
            const frequency = document.getElementById('addPca9685Frequency').value;

            config.channel = channel ? parseInt(channel, 10) : 0;
            config.address = address.startsWith('0x') ? parseInt(address, 16) : parseInt(address, 10) || 0x40;
            if (frequency) config.pca9685Frequency = parseInt(frequency, 10);
          }
          break;

        case 'motor':
        case 'linear_actuator':
          // Control board detection for both motor and linear_actuator
          var controlBoardEl = document.getElementById('addControlBoard');
          var controlBoard = controlBoardEl ? controlBoardEl.value : null;
          if (controlBoard) {
            payload.controlBoard = controlBoard;
          }

          if (controlBoard === 'BTS7960') {
            var rpwmPin = formData.get('rpwmPin');
            var lpwmPin = formData.get('lpwmPin');
            var renPin = formData.get('renPin');
            var lenPin = formData.get('lenPin');
            if (rpwmPin) payload.rpwmPin = parseInt(rpwmPin, 10);
            if (lpwmPin) payload.lpwmPin = parseInt(lpwmPin, 10);
            if (renPin) payload.renPin = parseInt(renPin, 10);
            if (lenPin) payload.lenPin = parseInt(lenPin, 10);
          } else {
            const directionPin = formData.get('directionPin');
            const pwmPin = formData.get('pwmPin');
            if (directionPin) payload.directionPin = parseInt(directionPin, 10);
            if (pwmPin) payload.pwmPin = parseInt(pwmPin, 10);
          }

          if (type === 'linear_actuator') {
            const maxExtension = formData.get('maxExtension');
            const maxRetraction = formData.get('maxRetraction');
            if (maxExtension) payload.maxExtension = parseInt(maxExtension, 10);
            if (maxRetraction) payload.maxRetraction = parseInt(maxRetraction, 10);
          } else if (type === 'motor') {
            payload.maxDuration = 10000; // 10 second safety limit for motors
          }
          break;

        case 'stepper':
          const stepPin = formData.get('stepPin');
          const dirPin = formData.get('dirPin');
          const enablePin = formData.get('enablePin');
          if (stepPin) payload.stepPin = parseInt(stepPin, 10);
          if (dirPin) payload.dirPin = parseInt(dirPin, 10);
          if (enablePin) payload.enablePin = parseInt(enablePin, 10);
          const micro = document.getElementById('addMicrostepping')?.value;
          if (micro) { config.microstepping = parseInt(micro, 10); }
          const spr = document.getElementById('addStepsPerRev')?.value;
          if (spr) { config.stepsPerRevolution = parseInt(spr, 10); }
          break;

        case 'webcam':
          const webcamDevice = document.getElementById('addWebcamDevice');
          if (webcamDevice && webcamDevice.value) {
            config.devicePath = webcamDevice.value;
            const deviceId = webcamDevice.value.match(/\/dev\/video(\d+)/);
            if (deviceId) config.deviceId = parseInt(deviceId[1], 10);
          }
          break;

        case 'microphone':
          const audioInput = document.getElementById('addAudioInput');
          if (audioInput && audioInput.value) {
            config.deviceId = audioInput.value;
          }
          break;

        case 'speaker':
          const audioOutput = document.getElementById('addAudioOutput');
          if (audioOutput && audioOutput.value) {
            config.audioDeviceId = audioOutput.value;
          }

          const volume = document.getElementById('addSpeakerVolume').value;
          const bass = document.getElementById('addSpeakerBass').value;
          const treble = document.getElementById('addSpeakerTreble').value;

          if (volume !== '') config.volume = Math.max(0, Math.min(100, parseInt(volume, 10)));
          if (bass !== '') config.bass = Math.max(-10, Math.min(10, parseInt(bass, 10)));
          if (treble !== '') config.treble = Math.max(-10, Math.min(10, parseInt(treble, 10)));
          break;
      }

      if (Object.keys(config).length) payload.config = config;

      // Create the part
      fetch('/setup/calibration/api/parts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(r => r.json())
        .then(data => {
          if (data.success) {
            // Close modal and reset form (robust: get or create instance before hide)
            (function () {
              var el = document.getElementById('addPartModal');
              var modal = (window.bootstrap && bootstrap.Modal && (bootstrap.Modal.getInstance(el) || bootstrap.Modal.getOrCreateInstance && bootstrap.Modal.getOrCreateInstance(el))) || null;
              try {
                const el = document.getElementById('addPartModal');
                if (window.bootstrap && bootstrap.Modal && el) {
                  const modal = bootstrap.Modal.getOrCreateInstance(el);
                  if (modal && modal.hide) modal.hide();
                }
              } catch (e) { /* no-op */ }
              // Force cleanup of any stale backdrops to avoid intercepting clicks in CI
              try {
                document.body.classList.remove('modal-open');
                document.querySelectorAll('.modal-backdrop').forEach(b => b.remove());
              } catch (_) { /* ignore */ }
            })();
            var f = document.getElementById('addPartForm'); if (f && f.reset) f.reset();
            var cfgArea = document.getElementById('addPartConfigArea'); if (cfgArea) cfgArea.innerHTML = '';
            var modelGroup = document.getElementById('addModelGroup'); if (modelGroup) modelGroup.style.display = 'none';

            // Reload parts list
            loadParts();

            // Show success message
            alert(`${data.message || 'Part created successfully'} `);
          } else {
            alert(`Failed to create part: ${data.error || 'Unknown error'} `);
          }
        })
        .catch(error => {
          console.error('Error creating part:', error);
          alert('Error creating part');
        });
    };

