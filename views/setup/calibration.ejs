          if (status) { status.textContent = 'Monitoring Off'; status.className = 'fs-5 fw-bold text-muted mb-1'; }
          if (details) details.textContent = sensorDetectionCount > 0 ? sensorDetectionCount + ' total detection' + (sensorDetectionCount !== 1 ? 's' : '') : 'GPIO ' + part.pin;
          toggleBtn.className = 'btn btn-success btn-lg';
