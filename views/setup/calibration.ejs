<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Setup Calibration - MonsterBox 4.0</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/monsterbox4.css" rel="stylesheet">
  <style>
    .safety-bar {
      position: sticky;
      top: 56px;
      z-index: 1030;
      background: #121212;
      border-bottom: 1px solid #333;
    }

    .device-list {
      max-height: calc(100vh - 200px);
      overflow: auto;
    }

    .marker-chip {
      cursor: pointer;
    }

    .ghost-tick {
      position: absolute;
      height: 6px;
      width: 2px;
      background: #8a2be2;
      top: -2px;
    }
  </style>
</head>

<body>
  <%- include('../components/unified-navigation', { page: 'setup-calibration' }) %>

    <!-- Global Safety Bar -->
    <div class="safety-bar py-2 border-bottom">
      <div class="container-fluid d-flex align-items-center gap-2">
        <button id="btnEstop" class="btn btn-danger"><i class="bi bi-x-octagon"></i> E-STOP</button>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" id="powerEnable">
          <label class="form-check-label" for="powerEnable">Power Enable</label>
        </div>
        <div class="ms-auto d-flex gap-2 align-items-center">
          <span class="badge text-bg-success">Comms</span>
          <span class="badge text-bg-success">12V</span>
          <span class="badge text-bg-secondary">Temp</span>
          <span class="badge text-bg-secondary">Current</span>
          <span class="badge text-bg-secondary">Fault</span>
          <div class="d-flex align-items-center">
            <span class="me-2 small">Global Speed Cap</span>
            <input id="globalSpeedCap" type="range" min="10" max="100" value="75" class="form-range"
              style="width:160px">
            <span class="ms-2" id="globalSpeedCapVal">75%</span>
          </div>
        </div>
      </div>
    </div>

    <main class="container-fluid py-3">
      <!-- Mode Toggle and Add Part Button -->
      <div class="mb-3 d-flex justify-content-between align-items-center">
        <div class="btn-group" role="group">
          <input type="radio" class="btn-check" name="mode" id="modeCal" autocomplete="off" checked>
          <label class="btn btn-outline-warning" for="modeCal">CALIBRATE</label>
          <input type="radio" class="btn-check" name="mode" id="modeOperate" autocomplete="off">
          <label class="btn btn-outline-info" for="modeOperate">OPERATE</label>
        </div>
        <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#addPartModal">
          <i class="bi bi-plus-circle"></i> Add Part
        </button>
      </div>

      <!-- Quick Model assignment (always visible) -->
      <div class="mb-3">
        <label class="form-label">Model</label>
        <div class="input-group">
          <select id="modelSelect" class="form-select">
            <option value="">Select model</option>
          </select>
          <button id="assignModelBtn" class="btn btn-primary"><i class="bi bi-link"></i> Assign</button>
        </div>
        <div class="form-text">Models are shared across all characters. Overrides remain part-specific.</div>
      </div>


      <div class="row g-3">
        <!-- Left Sidebar: Devices -->
        <div class="col-12 col-xl-3">
          <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
              <span>Devices</span>
              <div class="input-group input-group-sm" style="width: 200px;">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input id="searchDevices" type="text" class="form-control" placeholder="Search">
              </div>
            </div>
            <div class="card-body p-0">
              <div class="list-group list-group-flush device-list" id="deviceList"></div>
            </div>
          </div>
        </div>

        <!-- Center Panel: Device Card -->
        <div class="col-12 col-xl-6">
          <div class="card h-100" id="deviceCard" data-empty="1">
            <div class="card-header d-flex justify-content-between align-items-center">
              <div>
                <div class="h5 mb-0" id="devName">Select a device</div>
                <small class="text-muted" id="devMeta"></small>
              </div>
              <div class="text-end">
                <span class="badge text-bg-dark" id="modelBadge">Model: —</span>
                <div class="form-check form-switch ms-2 d-inline-block">
                  <input class="form-check-input" type="checkbox" id="invertDir">
                  <label class="form-check-label" for="invertDir">Invert</label>
                </div>
              </div>
            </div>
            <div class="card-body">

              <ul class="nav nav-tabs" id="devTabs" role="tablist">
                <li class="nav-item" role="presentation"><button class="nav-link active" data-bs-toggle="tab"
                    data-bs-target="#tabControls" type="button">Controls</button></li>
                <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab"
                    data-bs-target="#tabEdit" type="button">Edit</button></li>
                <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab"
                    data-bs-target="#tabModel" type="button">Model/Overrides</button></li>
                <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab"
                    data-bs-target="#tabSafety" type="button">Safety</button></li>
                <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab"
                    data-bs-target="#tabAdvanced" type="button">Advanced</button></li>
              </ul>
              <div class="tab-content pt-3">
                <!-- Controls -->
                <div class="tab-pane fade show active" id="tabControls">
                  <div id="controlsArea" class="text-muted">Select a device to show controls.</div>
                </div>
                <!-- Edit (comprehensive part settings) -->
                <div class="tab-pane fade" id="tabEdit">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label">Name</label>
                      <input id="editName" class="form-control" placeholder="Part name">
                    </div>
                    <div class="col-md-3">
                      <label class="form-label">Type</label>
                      <input id="editType" class="form-control" readonly>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                      <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="editEnabled">
                        <label class="form-check-label" for="editEnabled">Enabled</label>
                      </div>
                    </div>

                    <!-- Dynamic configuration area for type-specific settings -->
                    <div class="col-12" id="editConfigArea">
                      <!-- Type-specific configuration fields will be rendered here -->
                    </div>

                    <div class="col-12">
                      <label class="form-label">Description</label>
                      <input id="editDescription" class="form-control" placeholder="Describe this part">
                    </div>

                    <!-- Advanced JSON Config (collapsible) -->
                    <div class="col-12">
                      <div class="card">
                        <div class="card-header">
                          <button class="btn btn-link p-0 text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#advancedConfigCollapse">
                            <i class="bi bi-chevron-down"></i> Advanced Configuration (JSON)
                          </button>
                        </div>
                        <div class="collapse" id="advancedConfigCollapse">
                          <div class="card-body">
                            <textarea id="editConfig" class="form-control" rows="6" placeholder="{}"></textarea>
                            <div class="form-text">Direct JSON configuration - use with caution</div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class="col-12 d-flex justify-content-between">
                      <button id="deletePartBtn" class="btn btn-danger"><i class="bi bi-trash"></i> Delete Part</button>
                      <div>
                        <button id="applyMjpgBtn" class="btn btn-outline-info me-2" style="display:none;" onclick="applyWebcamToMjpg()">
                          <i class="bi bi-camera-video"></i> Apply to mjpg-streamer
                        </button>
                        <button id="saveEditBtn" class="btn btn-success"><i class="bi bi-save"></i> Save Changes</button>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- Model/Overrides -->
                <div class="tab-pane fade" id="tabModel">
                  <div class="row g-3">
                    <div class="col-12">
                      <div class="alert alert-secondary py-2">Use the Model selector above to assign or change the
                        model. Defaults can be overridden below.</div>
                    </div>
                    <div class="col-12">
                      <label class="form-label">Overrides (JSON)</label>
                      <textarea id="overridesEditor" class="form-control" rows="6"
                        placeholder="{\n  &quot;minPulse&quot;: 500,\n  &quot;maxPulse&quot;: 2500\n}"></textarea>
                      <div class="d-flex justify-content-end mt-2 gap-2">
                        <button id="saveOverridesBtn" class="btn btn-success btn-sm"><i class="bi bi-save"></i> Save
                          Overrides</button>
                        <button id="revertOverridesBtn" class="btn btn-outline-warning btn-sm"><i
                            class="bi bi-arrow-counterclockwise"></i> Revert to Model</button>
                      </div>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Model Defaults</label>
                      <pre id="modelDefaultsJson" class="bg-dark text-light p-2 small" style="min-height:120px">{}</pre>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Effective</label>
                      <pre id="effectiveJson" class="bg-dark text-light p-2 small" style="min-height:120px">{}</pre>
                    </div>

                  </div>
                </div>
                <!-- Safety -->
                <div class="tab-pane fade" id="tabSafety">
                  <div class="row g-2">
                    <div class="col-6">
                      <label class="form-label">Current limit (A)</label>
                      <input id="safetyCurrent" type="number" class="form-control" placeholder="e.g., 8">
                    </div>
                    <div class="col-6">
                      <label class="form-label">Timeout (ms)</label>
                      <input id="safetyTimeout" type="number" class="form-control" placeholder="e.g., 1500">
                    </div>
                  </div>
                </div>
                <!-- Advanced -->
                <div class="tab-pane fade" id="tabAdvanced">
                  <div class="alert alert-secondary mb-0">Advanced settings per device will appear here.</div>
                </div>
              </div>
            </div>
            <div class="card-footer d-flex justify-content-between">
              <div class="text-muted small" id="devNotes">Notes: —</div>
              <div class="d-flex gap-2">
                <button class="btn btn-outline-info btn-sm" id="btnTestSweep"><i class="bi bi-arrows"></i> Sweep
                  Test</button>
                <button class="btn btn-outline-danger btn-sm" id="btnRemove" disabled><i class="bi bi-trash"></i>
                  Remove</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Panel: Markers -->
        <div class="col-12 col-xl-3">
          <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
              <span>Markers</span>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="lockMinMax">
                <label class="form-check-label" for="lockMinMax">Lock Min/Max</label>
              </div>
            </div>
            <div class="card-body">
              <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <strong>Min</strong>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-secondary" id="setMinBtn">Set from current</button>
                    <button class="btn btn-outline-primary" id="goMinBtn">Go To</button>
                  </div>
                </div>
                <input id="minValue" class="form-control form-control-sm" placeholder="deg / mm / counts / preset">
              </div>
              <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <strong>Mid</strong>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-secondary" id="setMidBtn">Set from current</button>
                    <button class="btn btn-outline-primary" id="goMidBtn">Go To</button>
                  </div>
                </div>
                <input id="midValue" class="form-control form-control-sm" placeholder="deg / mm / counts / preset">
              </div>
              <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <strong>Max</strong>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-secondary" id="setMaxBtn">Set from current</button>
                    <button class="btn btn-outline-primary" id="goMaxBtn">Go To</button>
                  </div>
                </div>
                <input id="maxValue" class="form-control form-control-sm" placeholder="deg / mm / counts / preset">
              </div>
              <hr>
              <div id="customMarkers" class="d-flex flex-wrap gap-2"></div>
              <div class="input-group input-group-sm mt-2">
                <input id="newMarkerName" class="form-control" placeholder="New marker name">
                <button id="addMarkerBtn" class="btn btn-outline-success"><i class="bi bi-plus"></i> Add</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Rail: Cross-Device Locations -->
      <div class="mt-3">
        <div id="bottomRail" class="d-flex flex-wrap gap-2"></div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/character-menu.js"></script>
    <script>
      (function () {
        const elList = document.getElementById('deviceList');
        const searchEl = document.getElementById('searchDevices');
        const modelSelect = document.getElementById('modelSelect');
        const modelBadge = document.getElementById('modelBadge');
        const overridesEditor = document.getElementById('overridesEditor');
        const devName = document.getElementById('devName');
        const devMeta = document.getElementById('devMeta');
        const bottomRail = document.getElementById('bottomRail');
        const globalSpeedCap = document.getElementById('globalSpeedCap');
        const globalSpeedCapVal = document.getElementById('globalSpeedCapVal');

        let parts = [];
        let selected = null;
        let modelsCache = {}; // by type

        globalSpeedCap.addEventListener('input', () => globalSpeedCapVal.textContent = globalSpeedCap.value + '%');

        async function loadParts() {
          // Get current character first
          let characterId = null;
          try {
            const currentRes = await fetch('/setup/characters/api/current');
            const currentData = await currentRes.json();
            characterId = currentData.selectedCharacter;
          } catch (e) {
            console.warn('Could not get current character:', e);
          }

          const url = characterId ? `/setup/calibration/api/parts?characterId=${characterId}` : '/setup/calibration/api/parts';
          const res = await fetch(url);
          const j = await res.json();
          if (!j.success) throw new Error('Failed to load parts');
          parts = j.parts || [];
          renderList(parts);
          renderBottomRail(parts);
        }

        function renderList(items) {
          const q = (searchEl.value || '').toLowerCase();
          elList.innerHTML = '';
          items.filter(p => !q || p.name.toLowerCase().includes(q) || p.type.includes(q)).forEach(p => {
            const a = document.createElement('a');
            a.href = 'javascript:void(0)';
            a.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
            a.setAttribute('data-pid', p.id);
            var badges = '';
            if (p.needsModel) badges += '<span class="badge text-bg-warning me-1">Needs Model</span>';
            if (p.needsCalibration) badges += '<span class="badge text-bg-info me-1">Needs Cal</span>';
            if (p.gpioConflict) badges += '<span class="badge text-bg-danger">GPIO</span>';
            a.innerHTML = `<div><div class="fw-semibold">${p.name}</div><small class="text-muted">${p.type}</small></div>` +
              `<div>${badges}</div>`;
            a.addEventListener('click', () => selectPart(p.id));
            elList.appendChild(a);
          });
        }
        searchEl.addEventListener('input', () => renderList(parts));

        async function selectPart(id) {
          selected = parts.find(function (p) { return String(p.id) === String(id); });
          if (!selected) return;
          devName.textContent = selected.name;
          devMeta.textContent = 'ID: ' + selected.id + ' | Type: ' + selected.type;
          modelBadge.textContent = 'Model: ' + (selected.modelId || '—');
          overridesEditor.value = JSON.stringify(selected.config || {}, null, 2);
          await ensureModelsLoaded(selected.type);
          populateModelSelect(selected.type, selected.modelId);
          var ctrlTabBtn = document.querySelector('button[data-bs-target="#tabControls"]');
          if (ctrlTabBtn) ctrlTabBtn.click();
          renderControls(selected);
          renderEdit(selected);
          refreshEffective(selected.id);
        }

        async function ensureModelsLoaded(type) {
          if (modelsCache[type]) return;
          const res = await fetch(`/setup/models/api/${encodeURIComponent(type)}`);
          const j = await res.json();
          modelsCache[type] = j.models || [];
        }

        function populateModelSelect(type, current) {
          const list = modelsCache[type] || [];
          modelSelect.innerHTML = '<option value="">Select model…</option>' + list.map(m => `<option value="${m.id}" ${String(current || '') === String(m.id) ? 'selected' : ''}>${m.name}</option>`).join('');
        }

        async function refreshEffective(partId) {
          try {
            const r = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(partId)}/effective`);
            const d = await r.json();
            if (!d || !d.success) return;
            const md = document.getElementById('modelDefaultsJson');
            const ef = document.getElementById('effectiveJson');
            if (md) md.textContent = JSON.stringify(d.modelDefaults || {}, null, 2);
            if (ef) ef.textContent = JSON.stringify(d.effective || {}, null, 2);
            if (d.part && d.part.modelId) { modelBadge.textContent = 'Model: ' + d.part.modelId; }
            if (selected && String(selected.id) === String(partId)) {
              selected.modelId = d.part.modelId || selected.modelId;
              selected.config = d.overrides || selected.config;
            }
          } catch (e) { /* ignore */ }
        }


        document.getElementById('assignModelBtn').addEventListener('click', async () => {
          if (!selected) return;
          const val = modelSelect.value;
          if (!val) { alert('Select a model'); return; }
          const resp = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/model`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ modelId: val })
          });
          const j = await resp.json();
          if (j.success) {
            selected.modelId = val;
            modelBadge.textContent = 'Model: ' + val;
            // reflect badge in list
            loadParts();
            var ctrlTabBtn = document.querySelector('button[data-bs-target="#tabControls"]');
            if (ctrlTabBtn) ctrlTabBtn.click();
          } else alert(j.error || 'Failed to assign model');
        });

        document.getElementById('saveOverridesBtn').addEventListener('click', async () => {
          if (!selected) return;
          let obj;
          try { obj = JSON.parse(overridesEditor.value || '{}'); }
          catch (e) { alert('Invalid JSON'); return; }
          const resp = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/overrides`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ overrides: obj })
          });
          const j = await resp.json();
          if (j.success) { selected.config = j.config; alert('Overrides saved'); refreshEffective(selected.id); }
          else alert(j.error || 'Failed to save overrides');
        });

        document.getElementById('revertOverridesBtn').addEventListener('click', async () => {
          if (!selected) return;
          overridesEditor.value = '{}';
          const resp = await fetch(`/setup/calibration/api/parts/${encodeURIComponent(selected.id)}/overrides`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ overrides: {} })
          });
          const j = await resp.json();
          if (j.success) { selected.config = j.config; refreshEffective(selected.id); }
        });

        function renderControls(part) {
          const el = document.getElementById('controlsArea');
          if (part.type === 'servo') {
            const isCont = String(part.config?.servoType || 'standard') === 'continuous';
            if (isCont) {
              el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
                '<button class="btn btn-primary btn-lg" data-dir="ccw"><i class="bi bi-arrow-counterclockwise"></i> CCW</button>' +
                '<button class="btn btn-danger btn-lg" data-dir="stop"><i class="bi bi-stop-circle"></i> Stop</button>' +
                '<button class="btn btn-primary btn-lg" data-dir="cw">CW <i class="bi bi-arrow-clockwise"></i></button>' +
                '<input type="number" id="spd" class="form-control form-control-lg" value="35" style="width:110px">% ' +
                '<input type="number" id="dur" class="form-control form-control-lg" value="300" style="width:140px"> ms' +
                '</div>' +
                '<div id="ctrlStatus" class="mt-2 small text-info"></div>';
              el.querySelectorAll('button[data-dir]').forEach(b => b.addEventListener('click', async () => {
                const dir = b.getAttribute('data-dir');
                const speed = parseInt(document.getElementById('spd').value || '35', 10);
                const duration = parseInt(document.getElementById('dur').value || '300', 10);
                const st = document.getElementById('ctrlStatus');
                if (st) st.textContent = 'Executing…';
                try {
                  await fetch(`/setup/calibration/api/continuous_servo/${encodeURIComponent(part.id)}/jog`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ direction: dir, speed, duration }) });
                  if (st) st.textContent = 'Done';
                  setTimeout(() => { if (st) st.textContent = ''; }, 800);
                } catch (e) { if (st) st.textContent = 'Failed'; }
              }));
            } else {
              el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
                '<input id="ang" type="range" min="0" max="180" value="90" class="form-range" style="width:320px">' +
                '<input id="angNum" type="number" class="form-control form-control-lg" value="90" style="width:110px">° ' +
                '<button id="goAng" class="btn btn-success btn-lg"><i class="bi bi-cursor"></i> Move</button>' +
                '</div>' +
                '<div id="ctrlStatus" class="mt-2 small text-info"></div>';
              const s = el.querySelector('#ang');
              const n = el.querySelector('#angNum');
              s.addEventListener('input', () => n.value = s.value);
              n.addEventListener('input', () => s.value = n.value);
              el.querySelector('#goAng').addEventListener('click', async () => {
                const angle = parseInt(n.value || '90', 10);
                const st = document.getElementById('ctrlStatus');
                if (st) st.textContent = 'Moving…';
                try {
                  await fetch(`/setup/calibration/api/standard_servo/${encodeURIComponent(part.id)}/move`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ angle }) });
                  if (st) st.textContent = 'Done';
                  setTimeout(() => { if (st) st.textContent = ''; }, 800);
                } catch (e) { if (st) st.textContent = 'Failed'; }

              });
            }
          } else if (part.type === 'linear_actuator') {
            el.innerHTML = '<div class="d-flex align-items-center flex-wrap gap-2">' +
              '<button class="btn btn-primary btn-lg" id="extendBtn"><i class="bi bi-caret-up-fill"></i> Extend</button>' +
              '<button class="btn btn-danger btn-lg" id="stopBtn"><i class="bi bi-stop-circle"></i> Stop</button>' +
              '<button class="btn btn-primary btn-lg" id="retractBtn"><i class="bi bi-caret-down-fill"></i> Retract</button>' +
              '<input type="number" id="laSpd" class="form-control form-control-lg" value="50" style="width:110px">%' +
              '<input type="number" id="laDur" class="form-control form-control-lg" value="500" style="width:140px"> ms' +
              '</div>' +
              '<div id="ctrlStatus" class="mt-2 small text-info"></div>';
            const spd = () => parseInt(document.getElementById('laSpd').value || '50', 10);
            const dur = () => parseInt(document.getElementById('laDur').value || '500', 10);
