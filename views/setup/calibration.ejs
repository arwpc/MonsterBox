        return `
          <div class="card mb-3">
            <div class="card-header"><i class="bi bi-lightbulb"></i> ${type === 'led' ? 'LED' : 'Light'} Configuration</div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">GPIO Pin</label>
                  <input type="number" class="form-control" id="editLightPin" min="1" max="40">
                  <div class="form-text">GPIO pin for control</div>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Brightness (%)</label>
                  <input type="number" class="form-control" id="editBrightness" min="0" max="100" value="100">
                  <div class="form-text">Default brightness level</div>
                </div>
              </div>
            </div>
          </div>
        `;
      }

      function generateEditSensorConfig(part, config, type) {
        const isMotion = type === 'motion_sensor';
        return `
          <div class="card mb-3">
            <div class="card-header"><i class="bi bi-radar"></i> ${isMotion ? 'Motion Sensor' : 'Sensor'} Configuration</div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label">GPIO Pin</label>
                  <input type="number" class="form-control" id="editSensorPin" min="1" max="40">
                  <div class="form-text">GPIO pin for sensor input</div>
                </div>
                ${isMotion ? `
                <div class="col-md-4">
                  <label class="form-label">Sensitivity</label>
                  <input type="number" class="form-control" id="editSensitivity" min="1" max="10" value="5">
                  <div class="form-text">Detection sensitivity (1-10)</div>

                </div>
                <div class="col-md-4">
                  <label class="form-label">Window (ms)</label>
                  <input type="number" class="form-control" id="editWindowMs" min="50" max="1000" value="100">
                  <div class="form-text">Detection window</div>
                </div>
                ` : ''}
              </div>
            </div>
          </div>
        `;
      }

      function generateEditWebcamConfig(part, config) {
        return `
          <div class="card mb-3">
            <div class="card-header"><i class="bi bi-camera-video"></i> Webcam Configuration</div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-3">
                  <label class="form-label">Device Path</label>
                  <input type="text" class="form-control" id="editDevicePath" placeholder="/dev/video0">
                  <div class="form-text">Video device path</div>
                </div>
                <div class="col-md-3">
                  <label class="form-label">Device ID</label>
                  <input type="number" class="form-control" id="editDeviceId" min="0" max="10" value="0">
                  <div class="form-text">Camera device number</div>
                </div>
                <div class="col-md-2">
                  <label class="form-label">Width</label>
                  <input type="number" class="form-control" id="editWidth" value="1280">
                </div>
                <div class="col-md-2">
                  <label class="form-label">Height</label>
                  <input type="number" class="form-control" id="editHeight" value="720">
                </div>
                <div class="col-md-2">
                  <label class="form-label">FPS</label>
                  <input type="number" class="form-control" id="editFps" min="1" max="60" value="30">
                </div>
              </div>
            </div>
          </div>
        `;
      }

      function generateEditMicrophoneConfig(part, config) {
        return `
          <div class="card mb-3">
            <div class="card-header"><i class="bi bi-mic"></i> Microphone Configuration</div>
            <div class="card-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">Device Name</label>
                  <input type="text" class="form-control" id="editMicDevice" placeholder="default">
                  <div class="form-text">Audio input device</div>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Sample Rate</label>
                  <input type="number" class="form-control" id="editSampleRate" value="44100">
                  <div class="form-text">Audio sample rate (Hz)</div>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Gain</label>
                  <input type="number" class="form-control" id="editGain" min="0" max="100" value="50">
                  <div class="form-text">Input gain (%)</div>
                </div>
              </div>
            </div>
          </div>
        `;
      }

      function generateEditSpeakerConfig(part, config) {
        return `
          <div class="card mb-3">
            <div class="card-header"><i class="bi bi-speaker"></i> Speaker Configuration</div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-3">
                  <label class="form-label">Device Name</label>
                  <input type="text" class="form-control" id="editSpeakerDevice" placeholder="default">
                  <div class="form-text">Audio output device</div>
                </div>
                <div class="col-md-3">
                  <label class="form-label">Volume (%)</label>
                  <input type="number" class="form-control" id="editVolume" min="0" max="100" value="80">
                  <div class="form-text">Default volume level</div>
                </div>
                <div class="col-md-3">
                  <label class="form-label">Bass</label>
                  <input type="number" class="form-control" id="editBass" min="-10" max="10" value="0">
                  <div class="form-text">Bass adjustment</div>
                </div>
                <div class="col-md-3">
                  <label class="form-label">Treble</label>
                  <input type="number" class="form-control" id="editTreble" min="-10" max="10" value="0">
                  <div class="form-text">Treble adjustment</div>
                </div>
              </div>
            </div>
          </div>
        `;
      }

      function loadEditConfigValues(part, config, type) {
        // Load values based on part type
        switch (type) {
          case 'servo':
            loadEditServoValues(part, config);
            break;
          case 'motor':
            loadEditMotorValues(part, config);
            break;
          case 'linear_actuator':
            loadEditLinearActuatorValues(part, config);
            break;
          case 'stepper':
            loadEditStepperValues(part, config);
            break;
          case 'light':
          case 'led':
            loadEditLightValues(part, config);
            break;
          case 'sensor':
          case 'motion_sensor':
            loadEditSensorValues(part, config, type);
            break;
          case 'webcam':
            loadEditWebcamValues(part, config);
            break;
          case 'microphone':
            loadEditMicrophoneValues(part, config);
            break;
          case 'speaker':
            loadEditSpeakerValues(part, config);
            break;
        }
      }

      function loadEditServoValues(part, config) {
        const pin = part.pin || config.pin;
        const servoType = config.servoType || 'standard';



        const controllerType = config.controllerType || 'gpio';
        const invertDirection = config.invertDirection || false;
        const modelId = part.modelId || config.modelId;
        const address = config.address || config.pca9685Address || 64;
        const frequency = config.frequency || config.pca9685Frequency || 50;
        const channel = config.channel || config.pca9685Channel || 0;

        // Set basic values
        const pinEl = document.getElementById('editServoPin');
        if (pinEl && pin != null) pinEl.value = pin;

        const typeEl = document.getElementById('editServoType');
        if (typeEl) typeEl.value = servoType;

        const controllerEl = document.getElementById('editControllerType');
        if (controllerEl) controllerEl.value = controllerType;

        const invertEl = document.getElementById('editInvertDirection');
        if (invertEl) invertEl.value = String(invertDirection);

        const modelEl = document.getElementById('editServoModel');
        if (modelEl && modelId) modelEl.value = modelId;

        // PCA9685 configuration
        const addressEl = document.getElementById('editPca9685Address');
        if (addressEl) addressEl.value = '0x' + address.toString(16).toUpperCase();

        const frequencyEl = document.getElementById('editPca9685Frequency');
        if (frequencyEl) frequencyEl.value = frequency;

        const channelEl = document.getElementById('editPca9685Channel');
        if (channelEl) channelEl.value = channel;

        // Show/hide PCA9685 config
        const pca9685Config = document.getElementById('editPca9685Config');
        if (pca9685Config) {
          pca9685Config.style.display = controllerType === 'pca9685' ? 'block' : 'none';
        }

        // Set up event listeners
        if (controllerEl && !controllerEl._listenerAdded) {
          controllerEl._listenerAdded = true;
          controllerEl.addEventListener('change', function () {
            const pca9685Config = document.getElementById('editPca9685Config');
            if (pca9685Config) {
              pca9685Config.style.display = this.value === 'pca9685' ? 'block' : 'none';
            }
          });
        }

        // Set up channel grid
        const channelButtons = document.querySelectorAll('#editChannelGrid .channel-btn');
        channelButtons.forEach(btn => {
          btn.classList.remove('btn-primary');
          btn.classList.add('btn-outline-secondary');
          if (parseInt(btn.dataset.channel) === channel) {
            btn.classList.remove('btn-outline-secondary');
            btn.classList.add('btn-primary');
          }

          if (!btn._listenerAdded) {
            btn._listenerAdded = true;
            btn.addEventListener('click', function () {
              channelButtons.forEach(b => {
                b.classList.remove('btn-primary');
                b.classList.add('btn-outline-secondary');
              });
              this.classList.remove('btn-outline-secondary');
              this.classList.add('btn-primary');
              if (channelEl) channelEl.value = this.dataset.channel;
            });
          }
        });
      } // End loadEditServoValues - Fixed: Removed extra blank line that caused syntax error on some browsers

      function loadEditMotorValues(part, config) {
        const directionPin = part.directionPin || config.directionPin;
        const pwmPin = part.pwmPin || config.pwmPin;
        const maxDuration = config.maxDuration || 5000;

        const dirEl = document.getElementById('editDirectionPin');
        if (dirEl && directionPin != null) dirEl.value = directionPin;

        const pwmEl = document.getElementById('editPwmPin');
        if (pwmEl && pwmPin != null) pwmEl.value = pwmPin;

        const maxDurEl = document.getElementById('editMaxDuration');
        if (maxDurEl) maxDurEl.value = maxDuration;
      }

      function loadEditStepperValues(part, config) {
        const s = part.stepPin ?? config.stepPin;
        const d = part.dirPin ?? config.dirPin;
        const e = part.enablePin ?? config.enablePin;
        const micro = (config && config.microstepping != null) ? config.microstepping : 16;
        const spr = (config && config.stepsPerRevolution != null) ? config.stepsPerRevolution : 200;

        const sEl = document.getElementById('editStepPin'); if (sEl && s != null) sEl.value = s;
        const dEl = document.getElementById('editDirPin'); if (dEl && d != null) dEl.value = d;
        const eEl = document.getElementById('editEnablePin'); if (eEl && e != null) eEl.value = e;
        const mEl = document.getElementById('editMicrostepping'); if (mEl) mEl.value = String(micro);
        const sprEl = document.getElementById('editStepsPerRev'); if (sprEl) sprEl.value = spr;
      }

      function loadEditLinearActuatorValues(part, config) {
        // Decide control board
        var controlBoard = part.controlBoard || config.controlBoard;
        if (!controlBoard) {
          controlBoard = (part.rpwmPin != null || part.lpwmPin != null) ? 'BTS7960' : 'MDD10A';
        }
        var cbEl = document.getElementById('editControlBoard');
        if (cbEl) {
          cbEl.value = controlBoard;
          cbEl.addEventListener('change', function () {
            var v = this.value;
            document.getElementById('editMddGroup').style.display = (v === 'MDD10A') ? 'block' : 'none';
            document.getElementById('editBtsGroup').style.display = (v === 'BTS7960') ? 'block' : 'none';
          });
        }
        // Toggle groups initially
        if (document.getElementById('editMddGroup') && document.getElementById('editBtsGroup')) {
          document.getElementById('editMddGroup').style.display = (controlBoard === 'MDD10A') ? 'block' : 'none';
          document.getElementById('editBtsGroup').style.display = (controlBoard === 'BTS7960') ? 'block' : 'none';
        }

        // Populate pins
        const directionPin = part.directionPin || config.directionPin;
        const pwmPin = part.pwmPin || config.pwmPin;
        const rpwmPin = (part.rpwmPin != null ? part.rpwmPin : config.rpwmPin);
        const lpwmPin = (part.lpwmPin != null ? part.lpwmPin : config.lpwmPin);
        const renPin = (part.renPin != null ? part.renPin : config.renPin);
        const lenPin = (part.lenPin != null ? part.lenPin : config.lenPin);
        const maxExtension = config.maxExtension || part.maxExtension || 15000;
        const maxRetraction = config.maxRetraction || part.maxRetraction || 15000;

        var dirEl = document.getElementById('editDirectionPin'); if (dirEl && directionPin != null) dirEl.value = directionPin;
        var pwmEl = document.getElementById('editPwmPin'); if (pwmEl && pwmPin != null) pwmEl.value = pwmPin;
        var rpEl = document.getElementById('editRpwmPin'); if (rpEl && rpwmPin != null) rpEl.value = rpwmPin;
        var lpEl = document.getElementById('editLpwmPin'); if (lpEl && lpwmPin != null) lpEl.value = lpwmPin;
        var reEl = document.getElementById('editRenPin'); if (reEl && renPin != null) reEl.value = renPin;
        var leEl = document.getElementById('editLenPin'); if (leEl && lenPin != null) leEl.value = lenPin;

        var maxExtEl = document.getElementById('editMaxExtension'); if (maxExtEl) maxExtEl.value = maxExtension;
        var maxRetEl = document.getElementById('editMaxRetraction'); if (maxRetEl) maxRetEl.value = maxRetraction;
      }

      function loadEditLightValues(part, config) {
        const pin = part.pin || config.pin;
        const brightness = config.brightness || 100;

        const pinEl = document.getElementById('editLightPin');
        if (pinEl && pin != null) pinEl.value = pin;

        const brightnessEl = document.getElementById('editBrightness');
        if (brightnessEl) brightnessEl.value = brightness;
      }

      function loadEditSensorValues(part, config, type) {
        const pin = part.pin || config.pin;
        const sensitivity = config.sensitivity || 5;
        const windowMs = config.windowMs || 100;

        const pinEl = document.getElementById('editSensorPin');
        if (pinEl && pin != null) pinEl.value = pin;

        if (type === 'motion_sensor') {
          const sensEl = document.getElementById('editSensitivity');
          if (sensEl) sensEl.value = sensitivity;

          const windowEl = document.getElementById('editWindowMs');
          if (windowEl) windowEl.value = windowMs;
        }
      }

      function loadEditWebcamValues(part, config) {
        const devicePath = config.devicePath || '/dev/video0';
        const deviceId = config.deviceId || 0;
        const width = config.width || 1280;
        const height = config.height || 720;
        const fps = config.fps || 30;

        const pathEl = document.getElementById('editDevicePath');
        if (pathEl) pathEl.value = devicePath;

        const idEl = document.getElementById('editDeviceId');
        if (idEl) idEl.value = deviceId;

        const widthEl = document.getElementById('editWidth');
        if (widthEl) widthEl.value = width;

        const heightEl = document.getElementById('editHeight');
        if (heightEl) heightEl.value = height;

        const fpsEl = document.getElementById('editFps');
        if (fpsEl) fpsEl.value = fps;
      }

      function loadEditMicrophoneValues(part, config) {
        const device = config.device || 'default';
        const sampleRate = config.sampleRate || 44100;
        const gain = config.gain || 50;

        const deviceEl = document.getElementById('editMicDevice');
        if (deviceEl) deviceEl.value = device;

        const rateEl = document.getElementById('editSampleRate');
        if (rateEl) rateEl.value = sampleRate;

        const gainEl = document.getElementById('editGain');
        if (gainEl) gainEl.value = gain;
      }

      function loadEditSpeakerValues(part, config) {
        const device = config.device || 'default';
        const volume = config.volume || 80;
        const bass = config.bass || 0;
        const treble = config.treble || 0;

        const deviceEl = document.getElementById('editSpeakerDevice');
        if (deviceEl) deviceEl.value = device;

        const volumeEl = document.getElementById('editVolume');
        if (volumeEl) volumeEl.value = volume;

        const bassEl = document.getElementById('editBass');
        if (bassEl) bassEl.value = bass;

        const trebleEl = document.getElementById('editTreble');
        if (trebleEl) trebleEl.value = treble;
      }

      function generateEditStepperConfig(part, config) {
        return `
          <div class="card mb-3">
            <div class="card-header"><i class="bi bi-compass"></i> Stepper Motor Configuration</div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-3">
                  <label class="form-label">Step Pin</label>
                  <input type="number" class="form-control" id="editStepPin" min="1" max="40">
                </div>
                <div class="col-md-3">
                  <label class="form-label">Dir Pin</label>
                  <input type="number" class="form-control" id="editDirPin" min="1" max="40">
                </div>
                <div class="col-md-3">
                  <label class="form-label">Enable Pin (optional)</label>
                  <input type="number" class="form-control" id="editEnablePin" min="1" max="40">
                </div>
                <div class="col-md-3">
                  <label class="form-label">Microstepping</label>
                  <select class="form-select" id="editMicrostepping">
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="4">4</option>
                    <option value="8">8</option>
                    <option value="16">16</option>
                  </select>
                </div>
              </div>
              <div class="row g-3 mt-1">
                <div class="col-md-3">
                  <label class="form-label">Steps/Rev</label>
                  <input type="number" class="form-control" id="editStepsPerRev" min="1" max="2000" value="200">
                </div>
              </div>
            </div>
          </div>
        `;
      }

    </script>

    <!-- Add Part Modal -->
    <div class="modal fade" id="addPartModal" tabindex="-1">
      <div class="modal-dialog modal-xl">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Add Hardware Part</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <form id="addPartForm">
              <div class="row">
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="addPartName" class="form-label">Part Name</label>
                    <input type="text" class="form-control" id="addPartName" name="name" required>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="addPartType" class="form-label">Part Type</label>
                    <select class="form-select" id="addPartType" name="type" onchange="onAddPartTypeChange()" required>
                      <option value="">Select Part Type</option>
                    </select>
                  </div>
                </div>
              </div>

              <!-- Model Selection -->
              <div class="row" id="addModelGroup" style="display:none;">
                <div class="col-md-8">
                  <div class="mb-3">
                    <label for="addModelSelect" class="form-label">Model</label>
                    <select class="form-select" id="addModelSelect">
                      <option value="">Select Model (optional)</option>
                    </select>
                  </div>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                  <button type="button" class="btn btn-outline-secondary w-100" id="addModelBtn"
                    onclick="window.open('/setup/models', '_blank')">
                    <i class="bi bi-plus-circle"></i> Add Model
                  </button>
                </div>
              </div>

              <!-- Dynamic configuration area -->
              <div id="addPartConfigArea"></div>

              <!-- Description -->
              <div class="row">
                <div class="col-12">
                  <div class="mb-3">
                    <label for="addPartDescription" class="form-label">Description</label>
                    <input type="text" class="form-control" id="addPartDescription" name="description">
                  </div>
                </div>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-primary" onclick="createPartFromCalibration()">Add Part</button>
          </div>
        </div>
      </div>
    </div>
</body>

</html>