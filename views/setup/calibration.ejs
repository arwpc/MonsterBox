            try {
              // Map direction to nudge delta
              let delta = 0;
              if (dir === 'cw') delta = 0.1;
              else if (dir === 'ccw') delta = -0.1;

              const response = await fetch(`/api/calibration/${encodeURIComponent(part.id)}/nudge`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ delta, speedPct: speed, durationMs: duration })
              });
              const data = await response.json();
              if (response.ok && data.success) {
                if (st) st.textContent = `${part.name} ${dir} complete`;
                console.log(`Successfully jogged continuous servo ${part.name} ${dir}`);
