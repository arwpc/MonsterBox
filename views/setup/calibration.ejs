    // Sweep test: move from min to max 3 times at 100% speed.
    // For open-loop parts (linear actuators, continuous servos), homes to
    // a physical endstop before starting and between each cycle to prevent
    // accumulated positional drift.
    async function runSweepTest() {
      var partId = window.selectedPartId;
      if (!partId) { alert('No part selected'); return; }
      if (!currentCalProfile || !currentCalProfile.bounds) {
        alert('Set Min and Max bounds first before running sweep test.');
        return;
      }
      var bounds = currentCalProfile.bounds;
      var capKind = currentCalProfile.capability && currentCalProfile.capability.kind;
      var isServo = (capKind === 'absolute-servo');
      var needsHoming = (capKind === 'openloop-linear' || capKind === 'continuous-servo');

      // Use angle for absolute servos, normalized p for others
      var sweepMin, sweepMax;
      if (isServo) {
        sweepMin = bounds.minAngle;
        sweepMax = bounds.maxAngle;
        if (sweepMin == null || sweepMax == null) {
          alert('Both Min and Max angle bounds must be set for sweep test.');
          return;
        }
      } else {
        sweepMin = bounds.minP;
        sweepMax = bounds.maxP;
        if (sweepMin == null || sweepMax == null) {
          alert('Both Min and Max bounds must be set for sweep test.');
          return;
        }
      }
      if (sweepMin >= sweepMax) {
        alert('Min must be less than Max to sweep.');
        return;
      }

      var btn = document.getElementById('btnTestSweep');
      if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Sweeping...';
      }

      var SWEEPS = 3;
      var SPEED = 100;

      // Build goto payload based on part type
      function gotoPayload(val) {
        if (isServo) return { angle: val, speedPct: SPEED };
        return { p: val, speedPct: SPEED };
      }

      try {
        for (var i = 0; i < SWEEPS; i++) {
          // For open-loop parts, home to retract endstop before each cycle
          if (needsHoming) {
            if (btn) btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Homing...';
            var homeRes = await fetch('/api/calibration/' + encodeURIComponent(partId) + '/home', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ direction: 'retract', speedPct: SPEED })
            });
            var homeData = await homeRes.json();
            updateCurrentPositionDisplay(homeData.currentP, homeData.currentAngle);
          }
          if (btn) btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Sweep ' + (i + 1) + '/' + SWEEPS + '...';

          // Go to min
          var res1 = await fetch('/api/calibration/' + encodeURIComponent(partId) + '/goto', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(gotoPayload(sweepMin))
          });
          var d1 = await res1.json();
          updateCurrentPositionDisplay(d1.targetP, d1.targetAngle);

          // Go to max
          var res2 = await fetch('/api/calibration/' + encodeURIComponent(partId) + '/goto', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(gotoPayload(sweepMax))
          });
          var d2 = await res2.json();
          updateCurrentPositionDisplay(d2.targetP, d2.targetAngle);
        }

        // Return to midpoint after sweep
        var mid = (sweepMin + sweepMax) / 2;
        if (isServo) mid = Math.round(mid);
        var res3 = await fetch('/api/calibration/' + encodeURIComponent(partId) + '/goto', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(gotoPayload(mid))
        });
        var d3 = await res3.json();
        updateCurrentPositionDisplay(d3.targetP, d3.targetAngle);
      } catch (err) {
        console.error('Sweep test error:', err);
        alert('Sweep test failed: ' + err.message);
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.innerHTML = '<i class="bi bi-arrows"></i> Sweep Test';
        }
      }
    }
    window.runSweepTest = runSweepTest;

    // Preset management
    function renderPresetsUI(presets) {
