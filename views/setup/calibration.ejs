      var badge = document.getElementById('calConfidenceBadge');
      if (!badge) return;
      // Only show for open-loop parts
      if (currentPartIsAbsoluteServo) {
        badge.style.display = 'none';
        return;
      }
      badge.style.display = 'inline-block';
      if (confidence === 'homed') {
        badge.className = 'badge bg-success';
        badge.textContent = 'Homed';
      } else if (confidence === 'tracked' && positionKnown !== false) {
        badge.className = 'badge bg-warning text-dark';
        badge.textContent = 'Tracked';
      } else {
        badge.className = 'badge bg-danger';
        badge.textContent = 'Unknown - Home Required';
      }
    }

