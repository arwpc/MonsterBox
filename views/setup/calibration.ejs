            var html = '';
            function field(id, label, type, placeholder) {
              return '<div class="col-md-3"><label class="form-label">' + label + '</label>' +
                '<input id="' + id + '" class="form-control" ' + (type === 'number' ? 'type="number"' : '') + ' placeholder="' + (placeholder || '') + '"></div>';
            }
            if (part.type === 'motor' || part.type === 'linear_actuator') {
              html += '<div class="row g-3">';
              html += field('editPin', 'PWM Pin', 'number', 'GPIO');
              html += field('editDirectionPin', 'Direction Pin', 'number', 'GPIO');
              html += '</div>';
            } else if (part.type === 'servo' || part.type === 'led' || part.type === 'light' || part.type === 'sensor' || part.type === 'motion_sensor') {
              html += '<div class="row g-3">' + field('editPin', 'Pin', 'number', 'GPIO') + '</div>';
            } else {
              html = '<div class="text-muted">No pin fields for this part type.</div>';
            }
            container.innerHTML = html;
            // Populate current values if present
            var cfg = part || {};
            var pin = (cfg.pin != null ? cfg.pin : (cfg.config && cfg.config.pin));
            var pwm = (cfg.pwmPin != null ? cfg.pwmPin : (cfg.config && cfg.config.pwmPin));
            var dir = (cfg.directionPin != null ? cfg.directionPin : (cfg.config && cfg.config.directionPin));
            var el;
            el = document.getElementById('editPin'); if (el && pin != null) el.value = pin;
            el = document.getElementById('editDirectionPin'); if (el && dir != null) el.value = dir;
            el = document.getElementById('editPwmPin'); if (el && pwm != null) el.value = pwm;
          }

          function renderEdit(part) {
            // Populate basic fields
            var n = document.getElementById('editName'); if (n) n.value = part.name || '';
            var t = document.getElementById('editType'); if (t) t.value = part.type || '';
            var en = document.getElementById('editEnabled'); if (en) en.checked = !!part.enabled;
            var d = document.getElementById('editDescription'); if (d) d.value = part.description || '';
            var c = document.getElementById('editConfig'); if (c) c.value = JSON.stringify(part.config || {}, null, 2);

            // Render type-specific configuration
            renderEditConfigArea(part);

            // Bind save button (only once)
            var save = document.getElementById('saveEditBtn');
            if (save && !save._bound) {
              save._bound = true;
              save.addEventListener('click', function () {
                savePartChanges();
              });
            }

            // Bind delete button (only once)
            var deleteBtn = document.getElementById('deletePartBtn');
            if (deleteBtn && !deleteBtn._bound) {
              deleteBtn._bound = true;
              deleteBtn.addEventListener('click', function () {
                deleteSelectedPart();
              });
            }

            // Show/hide mjpg button for webcam parts
            var mjpgBtn = document.getElementById('applyMjpgBtn');
            if (mjpgBtn) {
              mjpgBtn.style.display = (part.type === 'webcam') ? 'inline-block' : 'none';
            }
          }

          function renderEditConfigArea(part) {
            const container = document.getElementById('editConfigArea');
            if (!container) return;

            const type = part.type;
            const config = part.config || {};
            let html = '';



            // Generate type-specific configuration fields
            switch (type) {
              case 'servo':
                html = generateEditServoConfig(part, config);
                break;
              case 'motor':
              case 'linear_actuator':
                html = generateEditMotorConfig(part, config, type);
                break;
              case 'light':
              case 'led':
                html = generateEditLightConfig(part, config, type);
                break;
              case 'sensor':
              case 'motion_sensor':
                html = generateEditSensorConfig(part, config, type);
                break;
              case 'webcam':
                html = generateEditWebcamConfig(part, config);
                break;
              case 'microphone':
                html = generateEditMicrophoneConfig(part, config);
                break;
              case 'speaker':
                html = generateEditSpeakerConfig(part, config);
                break;
              default:
                html = '<div class="text-muted">No specific configuration for this part type.</div>';
            }

            container.innerHTML = html;

            // Populate values after rendering
            populateEditConfigValues(part, config);

            // Populate servo model dropdown if it's a servo
            if (type === 'servo') {
              populateEditServoModels();
            }
          }

