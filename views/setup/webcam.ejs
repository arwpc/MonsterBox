<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Setup Webcam - MonsterBox 5.3</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
  <!-- Unified Navigation - Same on ALL pages -->
  <%- include('../components/unified-navigation', { page: 'setup-webcam' }) %>

    <main class="container-fluid py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-camera-video"></i> Setup Webcam</h1>
        <span class="badge bg-success">Live Stream</span>
      </div>

      <div class="row g-4">
        <div class="col-md-4">

          <div class="card">
            <div class="card-header"><i class="bi bi-hdd-network"></i> Select Webcam Part</div>
            <div class="card-body">
              <div class="mb-2">
                <label class="form-label">Webcam Part</label>
                <select id="webcamPart" class="form-select"></select>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="autoDetect" checked>
                <label class="form-check-label" for="autoDetect">Autodetect camera</label>
              </div>
              <div class="d-grid gap-2">
                <button id="startStream" class="btn btn-primary">Start Stream</button>
              </div>
              <div id="deviceResults" class="small text-muted mt-2"></div>
            </div>
          </div>

          <!-- Motion Tracking Card -->
          <div class="card mt-3">
            <div class="card-header"><i class="bi bi-eye"></i> Motion Tracking</div>
            <div class="card-body">
              <div class="mb-3">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="enableMotionTracking">
                  <label class="form-check-label" for="enableMotionTracking">
                    <strong>Enable Motion Tracking</strong>
                  </label>
                </div>
                <small class="text-muted">Track the largest moving object in the field of view</small>
              </div>

              <!-- OpenCV Parameters -->
              <div id="motionTrackingParams" style="display: none;">
                <div class="mb-2">
                  <label for="motionThreshold" class="form-label">Motion Threshold</label>
                  <input type="range" class="form-range" id="motionThreshold" min="10" max="100" value="25">
                  <small class="text-muted">Sensitivity: <span id="motionThresholdValue">25</span></small>
                </div>

                <div class="mb-2">
                  <label for="minContourArea" class="form-label">Min Object Size</label>
                  <input type="range" class="form-range" id="minContourArea" min="100" max="2000" value="500"
                    step="100">
                  <small class="text-muted">Pixels: <span id="minContourAreaValue">500</span></small>
                </div>

                <div class="mb-2">
                  <label for="trackingSmoothing" class="form-label">Tracking Smoothing</label>
                  <input type="range" class="form-range" id="trackingSmoothing" min="0.1" max="0.9" value="0.3"
                    step="0.1">
                  <small class="text-muted">Factor: <span id="trackingSmoothingValue">0.3</span></small>
                </div>

                <div class="mb-2">
                  <label for="trackingDeadzone" class="form-label">Deadzone</label>
                  <input type="range" class="form-range" id="trackingDeadzone" min="1" max="20" value="5">
                  <small class="text-muted">Percent: <span id="trackingDeadzoneValue">5</span>%</small>
                </div>
              </div>

              <!-- Head Tracking Super Power -->
              <div class="mt-3 pt-3 border-top">
                <div class="mb-2">
                  <label for="panServoSelect" class="form-label">Pan Servo (Head Movement)</label>
                  <select id="panServoSelect" class="form-select form-select-sm">
                    <option value="">Select servo for head tracking...</option>
                  </select>
                </div>

                <div class="row mb-2">
                  <div class="col-6">
                    <label for="headTrackingRange" class="form-label">Range (degrees)</label>
                    <input type="range" class="form-range" id="headTrackingRange" min="30" max="120" value="60">
                    <small class="text-muted">±<span id="headTrackingRangeValue">60</span>°</small>
                  </div>
                  <div class="col-6">
                    <label for="headTrackingSmoothing" class="form-label">Smoothing</label>
                    <input type="range" class="form-range" id="headTrackingSmoothing" min="0.1" max="0.8" value="0.35"
                      step="0.05">
                    <small class="text-muted"><span id="headTrackingSmoothingValue">0.35</span></small>
                  </div>
                </div>

                <button id="enableHeadTracking" class="btn btn-outline-warning w-100" disabled>
                  <i class="bi bi-magic"></i> Enable Head Tracking Super Power
                </button>
                <small class="text-muted d-block mt-1">Select a servo above to enable head tracking</small>

                <!-- Emergency Stop Button -->
                <button id="emergencyStopBtn" class="btn btn-danger w-100 mt-2" onclick="emergencyStopAllServos()">
                  <i class="bi bi-stop-circle-fill"></i> 🛑 EMERGENCY STOP ALL SERVOS
                </button>
                <small class="text-muted d-block mt-1">Immediately stops all servo movement</small>
              </div>

              <!-- Status Display -->
              <div id="motionTrackingStatus" class="mt-3" style="display: none;">
                <div class="alert alert-info mb-0">
                  <small>
                    <strong>Status:</strong> <span id="trackingStatusText">Initializing...</span><br>
                    <strong>Target:</strong> <span id="targetPosition">None detected</span>
                  </small>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-8">
          <div class="card mb-3">
            <div class="card-header"><i class="bi bi-broadcast"></i> MJPEG Stream</div>
            <div class="card-body text-center" style="background:#000; position: relative;">
              <img id="webcamStream" alt="Webcam Stream" style="max-width:100%; display:none;" />
              <canvas id="motionOverlay"
                style="position: absolute; top: 0; left: 0; pointer-events: none; display: none;"></canvas>
              <div id="noStream" class="text-secondary">Select a webcam and click Start Stream</div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <script>
      (function () {
        // Shared DOM references
        var webcamSelectEl = document.getElementById('webcamPart');
        var headTrackingBtn = document.getElementById('enableHeadTracking');


        function loadWebcams() {
          console.log('🔄 Loading webcam parts...');
          fetch('/setup/calibration/api/parts')
            .then(function (r) { return r.json(); })
            .then(function (j) {
              console.log('📦 Parts data received:', j);
              var sel = document.getElementById('webcamPart');
              sel.innerHTML = '';
              var webcams = (j.parts || []).filter(function (p) { return p.type === 'webcam'; });
              console.log('📹 Found webcam parts:', webcams);
              if (webcams.length === 0) {
                var opt = document.createElement('option'); opt.value = ''; opt.textContent = 'No webcam parts found'; sel.appendChild(opt);
                console.log('❌ No webcam parts found');
              } else {
                webcams.forEach(function (p) {
                  var opt = document.createElement('option');
                  opt.value = p.id;
                  opt.textContent = p.name || ('Webcam #' + p.id);
                  sel.appendChild(opt);
                  console.log('✅ Added webcam option:', p.name, 'ID:', p.id);
                });
              }

              // Also load servo parts for head tracking
              loadServoPartsForHeadTracking(j.parts || []);
            }).catch(function (err) {
              console.error('❌ Error loading webcam parts:', err);
            });
        }

        function loadServoPartsForHeadTracking(allParts) {
          var servoSelect = document.getElementById('panServoSelect');
          servoSelect.innerHTML = '<option value="">Select servo for head tracking...</option>';

          var servos = allParts.filter(function (p) { return p.type === 'servo'; });
          servos.forEach(function (servo) {
            var opt = document.createElement('option');
            opt.value = servo.id;
            opt.textContent = servo.name || ('Servo #' + servo.id);
            servoSelect.appendChild(opt);
          });

          // Enable/disable head tracking button based on servo selection
          servoSelect.addEventListener('change', function () {
            var btn = document.getElementById('enableHeadTracking');
            btn.disabled = !this.value;
          });
        }
        function start() {
          console.log('🎬 Start Stream button clicked');
          var id = document.getElementById('webcamPart').value;
          console.log('📹 Selected webcam ID:', id);
          if (!id) {
            console.log('❌ No webcam selected');
            alert('Please select a webcam part first');
            return;
          }
          var img = document.getElementById('webcamStream');
          var no = document.getElementById('noStream');
          var auto = document.getElementById('autoDetect').checked;
          var qs = (auto ? '?auto=1&_ts=' : '?_ts=') + Date.now();
          var streamUrl = '/setup/webcam/api/parts/' + id + '/stream' + qs;
          console.log('🔗 Stream URL:', streamUrl);
          img.src = streamUrl;
          img.style.display = 'block';
          no.style.display = 'none';

          // Setup motion overlay canvas
          setupMotionOverlay();
          console.log('✅ Stream started');
        }
        document.getElementById('startStream').addEventListener('click', start);

        // Motion Tracking functionality
        function initMotionTracking() {
          var enableCheckbox = document.getElementById('enableMotionTracking');
          var paramsDiv = document.getElementById('motionTrackingParams');
          var statusDiv = document.getElementById('motionTrackingStatus');

          // Toggle parameters visibility
          enableCheckbox.addEventListener('change', function () {
            if (this.checked) {
              paramsDiv.style.display = 'block';
              statusDiv.style.display = 'block';
              startMotionTracking();
              checkHeadTrackingAvailability();
            } else {
              paramsDiv.style.display = 'none';
              statusDiv.style.display = 'none';
              stopMotionTracking();
              setHeadTrackingUI(false);
            }
          });

          // Update parameter value displays
          var params = ['motionThreshold', 'minContourArea', 'trackingSmoothing', 'trackingDeadzone'];
          params.forEach(function (param) {
            var slider = document.getElementById(param);
            var display = document.getElementById(param + 'Value');
            if (slider && display) {
              slider.addEventListener('input', function () {
                display.textContent = this.value;
                updateMotionTrackingParams();
              });
            }
          });

          // Update head tracking parameter displays
          var headParams = ['headTrackingRange', 'headTrackingSmoothing'];
          headParams.forEach(function (param) {
            var slider = document.getElementById(param);
            var display = document.getElementById(param + 'Value');
            if (slider && display) {
              slider.addEventListener('input', function () {
                display.textContent = this.value;
              });
            }
          });

          // Head Tracking Super Power toggle
          headTrackingBtn.addEventListener('click', function () {
            toggleHeadTracking();
          });
        }

        function startMotionTracking() {
          var webcamId = document.getElementById('webcamPart').value;
          if (!webcamId) {
            document.getElementById('trackingStatusText').textContent = 'No webcam selected';
            return;
          }

          document.getElementById('trackingStatusText').textContent = 'Starting motion tracking...';

          // Start motion tracking via API
          fetch('/setup/webcam/api/motion-tracking/start', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              webcamId: webcamId,
              params: getMotionTrackingParams()
            })
          })
            .then(function (r) { return r.json(); })
            .then(function (result) {
              if (result.success) {
                document.getElementById('trackingStatusText').textContent = 'Motion tracking active';
                startTrackingStatusUpdates();
              } else {
                document.getElementById('trackingStatusText').textContent = 'Failed to start: ' + (result.error || 'Unknown error');
              }
            })
            .catch(function (err) {
              document.getElementById('trackingStatusText').textContent = 'Error: ' + err.message;
            });
        }

        function stopMotionTracking() {
          var webcamId = document.getElementById('webcamPart').value;
          if (!webcamId) {
            document.getElementById('trackingStatusText').textContent = 'No webcam selected';
            return;
          }

          document.getElementById('trackingStatusText').textContent = 'Stopping motion tracking...';

          fetch('/setup/webcam/api/motion-tracking/stop', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ webcamId: webcamId })
          })
            .then(function (r) { return r.json(); })
            .then(function (result) {
              document.getElementById('trackingStatusText').textContent = 'Motion tracking stopped';
              document.getElementById('targetPosition').textContent = 'None detected';
            })
            .catch(function (err) {
              document.getElementById('trackingStatusText').textContent = 'Stop error: ' + err.message;
            });
        }

        function getMotionTrackingParams() {
          return {
            motionThreshold: parseInt(document.getElementById('motionThreshold').value),
            minContourArea: parseInt(document.getElementById('minContourArea').value),
            trackingSmoothing: parseFloat(document.getElementById('trackingSmoothing').value),
            trackingDeadzone: parseFloat(document.getElementById('trackingDeadzone').value)
          };
        }

        function updateMotionTrackingParams() {
          var webcamId = document.getElementById('webcamPart').value;
          if (!webcamId || !document.getElementById('enableMotionTracking').checked) return;

          fetch('/setup/webcam/api/motion-tracking/params', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              webcamId: webcamId,
              params: getMotionTrackingParams()
            })
          })
            .catch(function (err) {
              console.warn('Failed to update motion tracking params:', err);
            });
        }

        function startTrackingStatusUpdates() {
          // Poll for tracking status updates every 50ms for ultra-responsive overlay
          setInterval(function () {
            if (!document.getElementById('enableMotionTracking').checked) return;

            var webcamId = document.getElementById('webcamPart').value;
            if (!webcamId) return;

            fetch('/setup/webcam/api/motion-tracking/status?webcamId=' + encodeURIComponent(webcamId))
              .then(function (r) { return r.json(); })
              .then(function (result) {
                if (result.success && result.status) {
                  var status = result.status;
                  if (status.target_detected) {
                    var pos = status.target_position;
                    document.getElementById('targetPosition').textContent =
                      'X: ' + pos[0].toFixed(1) + '%, Y: ' + pos[1].toFixed(1) + '%';

                    // Draw bounding box overlay if bbox data is available
                    if (status.bbox) {
                      drawMotionOverlay(status.bbox);
                    }
                  } else {
                    document.getElementById('targetPosition').textContent = 'None detected';
                    clearMotionOverlay();
                  }
                }
              })
              .catch(function () {
                // Ignore polling errors
              });
          }, 50);
        }

        // Canvas overlay functions for motion tracking visualization
        function setupMotionOverlay() {
          var img = document.getElementById('webcamStream');
          var canvas = document.getElementById('motionOverlay');

          // Update canvas size when image loads or resizes
          function updateCanvasSize() {
            if (img.naturalWidth > 0 && img.naturalHeight > 0) {
              var rect = img.getBoundingClientRect();
              canvas.width = rect.width;
              canvas.height = rect.height;
              canvas.style.width = rect.width + 'px';
              canvas.style.height = rect.height + 'px';

              // Position canvas over the image
              var imgRect = img.getBoundingClientRect();
              var containerRect = img.parentElement.getBoundingClientRect();
              canvas.style.left = (imgRect.left - containerRect.left) + 'px';
              canvas.style.top = (imgRect.top - containerRect.top) + 'px';
            }
          }

          img.addEventListener('load', updateCanvasSize);
          window.addEventListener('resize', updateCanvasSize);

          // Initial setup
          setTimeout(updateCanvasSize, 100);
        }

        function drawMotionOverlay(bbox) {
          var canvas = document.getElementById('motionOverlay');
          var ctx = canvas.getContext('2d');

          if (!canvas.width || !canvas.height) return;

          // Clear previous drawings
          ctx.clearRect(0, 0, canvas.width, canvas.height);

          // Convert percentage coordinates to canvas pixels
          var x = (bbox.x / 100) * canvas.width;
          var y = (bbox.y / 100) * canvas.height;
          var w = (bbox.w / 100) * canvas.width;
          var h = (bbox.h / 100) * canvas.height;

          // Draw green bounding box
          ctx.strokeStyle = '#00ff00';
          ctx.lineWidth = 2;
          ctx.strokeRect(x, y, w, h);

          // Draw center crosshair
          var centerX = x + w / 2;
          var centerY = y + h / 2;
          var crossSize = 10;

          ctx.beginPath();
          ctx.moveTo(centerX - crossSize, centerY);
          ctx.lineTo(centerX + crossSize, centerY);
          ctx.moveTo(centerX, centerY - crossSize);
          ctx.lineTo(centerX, centerY + crossSize);
          ctx.stroke();

          // Show canvas
          canvas.style.display = 'block';
        }

        function clearMotionOverlay() {
          var canvas = document.getElementById('motionOverlay');
          var ctx = canvas.getContext('2d');
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          canvas.style.display = 'none';
        }

        // Head tracking helpers (ES5)
        var headTrackingEnabled = false;

        function setHeadTrackingUI(enabled) {
          headTrackingEnabled = !!enabled;
          headTrackingBtn.classList.toggle('btn-success', !headTrackingEnabled);
          headTrackingBtn.classList.toggle('btn-danger', headTrackingEnabled);
          headTrackingBtn.textContent = headTrackingEnabled ? 'Disable Head Tracking Super Power' : 'Enable Head Tracking Super Power';
          headTrackingBtn.disabled = false;
        }

        function checkHeadTrackingAvailability() {
          var webcamId = webcamSelectEl.value;
          if (!webcamId) return;

          // Check if a servo is selected
          var selectedServo = document.getElementById('panServoSelect').value;
          headTrackingBtn.disabled = !selectedServo;
        }

        function toggleHeadTracking() {
          var webcamId = webcamSelectEl.value;
          if (!webcamId) return;

          if (!headTrackingEnabled) {
            var panId = document.getElementById('panServoSelect').value;
            if (!panId) {
              alert('Please select a servo for head tracking');
              return;
            }

            var rangeDeg = parseInt(document.getElementById('headTrackingRange').value);
            var smoothing = parseFloat(document.getElementById('headTrackingSmoothing').value);

            fetch('/setup/webcam/api/motion-tracking/head-tracking/enable', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                webcamId: webcamId,
                panServoId: panId,
                params: {
                  rangeDeg: rangeDeg,
                  centerDeg: 0,
                  smoothing: smoothing,
                  deadzone: 6
                }
              })
            }).then(function (r) { return r.json(); })
              .then(function (data) {
                if (data && data.success) {
                  setHeadTrackingUI(true);
                  console.log('Head tracking enabled with servo', panId);
                } else {
                  alert('Failed to enable head tracking: ' + (data.error || 'Unknown error'));
                }
              })
              .catch(function (err) {
                alert('Error enabling head tracking: ' + err.message);
              });
          } else {
            fetch('/setup/webcam/api/motion-tracking/head-tracking/disable', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ webcamId: webcamId })
            }).then(function (r) { return r.json(); })
              .then(function (data) {
                if (data && data.success) {
                  setHeadTrackingUI(false);
                  console.log('Head tracking disabled');
                }
              })
              .catch(function () { /* ignore */ });
          }
        }

        // On load, check availability
        checkHeadTrackingAvailability();


        // Emergency stop function
        function emergencyStopAllServos() {
          fetch('/setup/calibration/api/parts')
            .then(function (r) { return r.json(); })
            .then(function (data) {
              var parts = (data.parts || []);
              var stops = [];

              // Stop continuous servos
              parts.filter(function (p) { return p.type === 'servo' && String((p.config && p.config.servoType) || 'standard') === 'continuous'; })
                .forEach(function (servo) {
                  stops.push(fetch('/setup/calibration/api/continuous_servo/' + encodeURIComponent(servo.id) + '/jog', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ direction: 'stop', speed: 0, duration: 0 })
                  }));
                });

              // Stop linear actuators
              parts.filter(function (p) { return p.type === 'linear_actuator'; })
                .forEach(function (act) {
                  stops.push(fetch('/setup/calibration/api/linear_actuator/' + encodeURIComponent(act.id) + '/stop', { method: 'POST' }));
                });

              return Promise.all(stops);
            })
            .then(function () {
              alert('🛑 Emergency stop executed.');
            })
            .catch(function (e) {
              alert('❌ Emergency stop failed: ' + e.message);
              console.error('Emergency stop failed:', e);
            });
        }

        initMotionTracking();
        loadWebcams();
      })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>