<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Setup Webcam - MonsterBox 4.0</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/"><i class="bi bi-robot"></i> MonsterBox 4.0</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> Dashboard</a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle active" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-gear"></i> Setup
            </a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/setup/parts"><i class="bi bi-cpu"></i> Parts</a></li>
              <li><a class="dropdown-item" href="/setup/poses"><i class="bi bi-person-arms-up"></i> Poses</a></li>
              <li><a class="dropdown-item" href="/setup/characters"><i class="bi bi-people"></i> Characters</a></li>
              <li><a class="dropdown-item" href="/setup/audio"><i class="bi bi-volume-up"></i> Audio</a></li>
              <li><a class="dropdown-item active" href="/setup/webcam"><i class="bi bi-camera-video"></i> Webcam</a>
              </li>
            </ul>
          </li>
          <li class="nav-item"><a class="nav-link" href="/live"><i class="bi bi-play-circle"></i> Live Mode</a></li>
          <li class="nav-item"><a class="nav-link" href="/scenes"><i class="bi bi-film"></i> Scenes</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1><i class="bi bi-camera-video"></i> Setup Webcam</h1>
      <span class="badge bg-success">Live Stream</span>
    </div>

    <div class="row g-4">
      <div class="col-md-4">
        <div class="card">
          <div class="card-header"><i class="bi bi-hdd-network"></i> Select Webcam Part</div>
          <div class="card-body">
            <div class="mb-2">
              <label class="form-label">Webcam Part</label>
              <select id="webcamPart" class="form-select"></select>
            </div>
            <div class="form-check mb-2">
              <input class="form-check-input" type="checkbox" id="autoDetect" checked>
              <label class="form-check-label" for="autoDetect">Autodetect camera</label>
            </div>
            <div class="d-grid gap-2">
              <button id="startStream" class="btn btn-primary">Start Stream</button>
              <button id="scanDevices" class="btn btn-outline-secondary" type="button">Scan Devices</button>
            </div>
            <div id="deviceResults" class="small text-muted mt-2"></div>
          </div>
        </div>
      </div>
      <div class="col-md-8">
        <div class="card mb-3">
          <div class="card-header"><i class="bi bi-broadcast"></i> MJPEG Stream</div>
          <div class="card-body text-center" style="background:#000">
            <img id="webcamStream" alt="Webcam Stream" style="max-width:100%; display:none;" />
            <div id="noStream" class="text-secondary">Select a webcam and click Start Stream</div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    (function () {
      function loadWebcams() {
        fetch('/setup/parts/api/parts')
          .then(function (r) { return r.json(); })
          .then(function (j) {
            var sel = document.getElementById('webcamPart');
            sel.innerHTML = '';
            var webcams = (j.parts || []).filter(function (p) { return p.type === 'webcam'; });
            if (webcams.length === 0) {
              var opt = document.createElement('option'); opt.value = ''; opt.textContent = 'No webcam parts found'; sel.appendChild(opt);
            } else {
              webcams.forEach(function (p) { var opt = document.createElement('option'); opt.value = p.id; opt.textContent = p.name || ('Webcam #' + p.id); sel.appendChild(opt); });
            }
          }).catch(function () { /* ignore */ });
      }
      function start() {
        var id = document.getElementById('webcamPart').value;
        if (!id) { return; }
        var img = document.getElementById('webcamStream');
        var no = document.getElementById('noStream');
        var auto = document.getElementById('autoDetect').checked;
        var qs = (auto ? '?auto=1&_ts=' : '?_ts=') + Date.now();
        img.src = '/setup/webcam/api/parts/' + id + '/stream' + qs;
        img.style.display = 'block';
        no.style.display = 'none';
      }
      function scan() {
        var box = document.getElementById('deviceResults');
        box.textContent = 'Scanning...';
        fetch('/setup/webcam/api/devices/probe')
          .then(function (r) { return r.json(); })
          .then(function (j) {
            if (!j || !j.results) { box.textContent = 'No devices found'; return; }
            var lines = j.results.map(function (it) { return (it.ok ? '✅ ' : '❌ ') + (it.name || it.path) + ' [' + it.path + ']' + (it.info ? ' - ' + it.info : ''); });
            box.textContent = lines.join('\n');
          })
          .catch(function () { box.textContent = 'Error scanning devices'; });
      }
      document.getElementById('startStream').addEventListener('click', start);
      document.getElementById('scanDevices').addEventListener('click', scan);
      loadWebcams();
    })();
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>