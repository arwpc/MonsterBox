<div class="d-flex justify-content-end mb-2">
  <a class="btn btn-outline-secondary btn-sm" href="/setup/calibration" title="Back to Calibration">
    <i class="bi bi-arrow-left"></i> Back to Calibration
  </a>
</div>

  <div class="row g-3">
    <!-- Left Panel: Type + Editor -->
    <div class="col-lg-4">
      <!-- Type Selector -->
      <div class="card mb-3">
        <div class="card-header"><i class="bi bi-funnel"></i> Part Type</div>
        <div class="card-body">
          <select id="typeSelect" class="form-select" title="Select part type">
            <option value="servo">Servo</option>
            <option value="linear_actuator">Linear Actuator</option>
            <option value="motor">Motor (DC)</option>
            <option value="stepper">Stepper Motor</option>
            <option value="led">LED</option>
            <option value="light">Light</option>
            <option value="sensor">Sensor</option>
            <option value="motion_sensor">Motion Sensor</option>
            <option value="microphone">Microphone</option>
            <option value="speaker">Speaker</option>
            <option value="webcam">WebCam</option>
            <option value="head_tracking">Head Tracking</option>
          </select>
        </div>
      </div>

      <!-- Model Editor -->
      <div class="card">
        <div class="card-header" id="editorHeader">
          <i class="bi bi-pencil-square"></i> <span id="editorTitle">Create New Model</span>
        </div>
        <div class="card-body">
          <input type="hidden" id="modelId" />
          <div class="mb-2">
            <label class="form-label">Name <span class="text-danger">*</span></label>
            <input id="modelName" class="form-control" placeholder="e.g., MG90S Micro Servo" title="Model name" />
          </div>
          <div class="mb-2">
            <label class="form-label">Description</label>
            <input id="modelDesc" class="form-control" placeholder="Optional description" title="Model description" />
          </div>

          <hr />
          <h6 class="text-muted"><i class="bi bi-sliders"></i> Default Settings</h6>
          <div id="defaultsFieldsArea" class="row g-2 mb-3">
            <!-- Dynamic fields rendered by JS -->
          </div>

          <div class="mb-2">
            <a class="small text-decoration-none" data-bs-toggle="collapse" href="#rawDefaultsCollapse" role="button" title="Toggle raw JSON editor">
              <i class="bi bi-code-slash"></i> Raw JSON (advanced)
            </a>
            <div class="collapse" id="rawDefaultsCollapse">
              <textarea id="modelDefaults" rows="5" class="form-control font-monospace mt-1"
                placeholder='{"key": "value"}' title="Raw JSON defaults"></textarea>
            </div>
          </div>

          <div class="d-grid gap-2 mt-3">
            <button class="btn btn-success" id="btnSaveModel" title="Save model"><i class="bi bi-save"></i> Save Model</button>
            <div class="d-flex gap-2">
              <button class="btn btn-outline-secondary flex-fill" id="btnNewModel" title="Create new model"><i class="bi bi-plus"></i> New</button>
              <button class="btn btn-danger flex-fill" id="btnDeleteModel" disabled title="Delete model"><i class="bi bi-trash"></i> Delete</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Panel: Models List -->
    <div class="col-lg-8">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span><i class="bi bi-list-ul"></i> <span id="listTitle">Servo</span> Models</span>
          <div>
            <button class="btn btn-sm btn-danger me-2" id="btnDeleteSelected" style="display:none;" title="Delete selected models">
              <i class="bi bi-trash"></i> Delete Selected (<span id="selectedCount">0</span>)
            </button>
            <button class="btn btn-sm btn-outline-secondary" id="btnRefresh" title="Refresh models list">
              <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0" id="modelsTable">
              <thead>
                <tr>
                  <th style="width:30px"><input type="checkbox" id="selectAll" title="Select All"></th>
                  <th>Name</th>
                  <th>Description</th>
                  <th>Key Settings</th>
                  <th style="width:80px">Actions</th>
                </tr>
              </thead>
              <tbody>
                <tr><td colspan="5" class="text-center text-muted py-3">Loading...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Apply Model to Parts -->
      <div class="card mt-3">
        <div class="card-header"><i class="bi bi-link-45deg"></i> Apply Model to Parts</div>
        <div class="card-body">
          <div class="row g-2 align-items-end">
            <div class="col-md-5">
              <label class="form-label">Parts of this type</label>
              <select multiple id="partsSelect" class="form-select" size="5" title="Select parts to apply model"></select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Selected Model</label>
              <input id="applyModelId" class="form-control" placeholder="Click a model row" readonly title="Selected model to apply" />
            </div>
            <div class="col-md-3 d-grid gap-2">
              <button id="btnApplyModel" class="btn btn-primary" title="Assign model to selected parts"><i class="bi bi-link"></i> Assign Model</button>
              <button id="btnPushDefaults" class="btn btn-outline-primary"
                title="Merge model defaults into each part's config"><i class="bi bi-box-arrow-in-down"></i> Push Defaults</button>
            </div>
          </div>
          <div id="applyStatus" class="mt-2 small text-muted"></div>
        </div>
      </div>
    </div>
  </div>

<script>
(function () {
  // ─── Field schemas per model type ────────────────────────────────────
  const MODEL_FIELDS = {
    servo: [
      { key: 'minPulse', label: 'Min Pulse (µs)', type: 'number', placeholder: '500' },
      { key: 'maxPulse', label: 'Max Pulse (µs)', type: 'number', placeholder: '2500' },
      { key: 'neutralPulse', label: 'Neutral Pulse (µs)', type: 'number', placeholder: '1500' },
      { key: 'rotationRangeDeg', label: 'Rotation Range (°)', type: 'number', placeholder: '180' },
      { key: 'servoType', label: 'Servo Type', type: 'select', options: ['standard', 'continuous', 'feedback'] },
    ],
    linear_actuator: [
      { key: 'speedMaxPct', label: 'Max Speed (%)', type: 'number', placeholder: '100' },
      { key: 'strokeMs', label: 'Stroke Time (ms)', type: 'number', placeholder: '2000' },
      { key: 'maxExtension', label: 'Max Extension (ms)', type: 'number', placeholder: '15000' },
      { key: 'maxRetraction', label: 'Max Retraction (ms)', type: 'number', placeholder: '15000' },
      { key: 'controlBoard', label: 'Control Board', type: 'select', options: ['MDD10A', 'BTS7960', 'L298N'] },
    ],
    motor: [
      { key: 'motorType', label: 'Motor Type', type: 'select', options: ['dc'] },
      { key: 'voltage', label: 'Voltage (V)', type: 'number', placeholder: '12' },
      { key: 'maxDutyPct', label: 'Max Duty (%)', type: 'number', placeholder: '100' },
      { key: 'recommendedDriver', label: 'Recommended Drivers', type: 'text', placeholder: 'MDD10A, BTS7960' },
    ],
    stepper: [
      { key: 'motorType', label: 'Motor Type', type: 'select', options: ['stepper'] },
      { key: 'stepsPerRevolution', label: 'Steps/Rev', type: 'number', placeholder: '200' },
      { key: 'stepAngleDeg', label: 'Step Angle (°)', type: 'number', placeholder: '1.8', step: 0.1 },
      { key: 'ratedCurrentA', label: 'Rated Current (A)', type: 'number', placeholder: '2', step: 0.1 },
      { key: 'holdingTorqueNcm', label: 'Holding Torque (Ncm)', type: 'number', placeholder: '59' },
      { key: 'phaseResistanceOhm', label: 'Phase Resistance (Ω)', type: 'number', placeholder: '1.4', step: 0.1 },
      { key: 'phaseInductancemH', label: 'Phase Inductance (mH)', type: 'number', placeholder: '3', step: 0.1 },
    ],
    led: [
      { key: 'brightness', label: 'Brightness (%)', type: 'number', placeholder: '50' },
      { key: 'pwmFrequency', label: 'PWM Frequency (Hz)', type: 'number', placeholder: '1000' },
      { key: 'maxCurrentMa', label: 'Max Current (mA)', type: 'number', placeholder: '20' },
      { key: 'forwardVoltageV', label: 'Forward Voltage (V)', type: 'number', placeholder: '2', step: 0.1 },
    ],
    light: [
      { key: 'brightness', label: 'Brightness (%)', type: 'number', placeholder: '100' },
    ],
    sensor: [
      { key: 'sensitivity', label: 'Sensitivity (%)', type: 'number', placeholder: '50' },
      { key: 'retriggerMs', label: 'Retrigger Delay (ms)', type: 'number', placeholder: '5000' },
    ],
    motion_sensor: [
      { key: 'sensitivity', label: 'Sensitivity (%)', type: 'number', placeholder: '50' },
      { key: 'retriggerMs', label: 'Retrigger Delay (ms)', type: 'number', placeholder: '5000' },
    ],
    microphone: [
      { key: 'sampleRate', label: 'Sample Rate (Hz)', type: 'number', placeholder: '16000' },
      { key: 'channels', label: 'Channels', type: 'number', placeholder: '1' },
      { key: 'format', label: 'Format', type: 'text', placeholder: 's16le' },
    ],
    speaker: [
      { key: 'outputDevice', label: 'Output Device', type: 'text', placeholder: 'default' },
      { key: 'volume', label: 'Volume (%)', type: 'number', placeholder: '80' },
      { key: 'format', label: 'Audio Format', type: 'select', options: ['mp3', 'wav', 'ogg'] },
    ],
    webcam: [
      { key: 'resolution', label: 'Resolution', type: 'select', options: ['320x240', '640x480', '1280x720', '1920x1080'] },
      { key: 'fps', label: 'FPS', type: 'number', placeholder: '30' },
      { key: 'quality', label: 'Quality (%)', type: 'number', placeholder: '85' },
    ],
    head_tracking: [
      { key: 'trackingMode', label: 'Tracking Mode', type: 'select', options: ['face', 'motion', 'color'] },
      { key: 'smoothing', label: 'Smoothing (0-1)', type: 'number', placeholder: '0.5', step: 0.1 },
    ],
  };

  // ─── Type display names ──────────────────────────────────────────────
  const TYPE_LABELS = {
    servo: 'Servo', linear_actuator: 'Linear Actuator', motor: 'Motor (DC)',
    stepper: 'Stepper Motor', led: 'LED', light: 'Light', sensor: 'Sensor',
    motion_sensor: 'Motion Sensor', microphone: 'Microphone', speaker: 'Speaker',
    webcam: 'WebCam', head_tracking: 'Head Tracking'
  };

  // ─── DOM refs ────────────────────────────────────────────────────────
  var typeSelect = document.getElementById('typeSelect');
  var listTitle = document.getElementById('listTitle');
  var editorTitle = document.getElementById('editorTitle');
  var btnDeleteSelected = document.getElementById('btnDeleteSelected');
  var selectAllCheckbox = document.getElementById('selectAll');
  var selectedCountSpan = document.getElementById('selectedCount');
  var tableBody = document.querySelector('#modelsTable tbody');
  var partsSelect = document.getElementById('partsSelect');
  var applyModelId = document.getElementById('applyModelId');
  var selectedModels = new Set();
  var defaultsFieldsArea = document.getElementById('defaultsFieldsArea');

  // ─── Render default fields for current type ──────────────────────────
  function renderDefaultFields(type, values) {
    var fields = MODEL_FIELDS[type] || [];
    var vals = values || {};
    var html = '';
    fields.forEach(function (f) {
      var val = vals[f.key] !== undefined ? vals[f.key] : '';
      // Handle arrays (like recommendedDriver)
      if (Array.isArray(val)) val = val.join(', ');
      if (f.type === 'select') {
        html += '<div class="col-md-6"><label class="form-label small">' + f.label + '</label>' +
          '<select title="Select the default value for this field" class="form-select form-select-sm defaults-field" data-key="' + f.key + '">' +
          '<option value="">—</option>';
        (f.options || []).forEach(function (o) {
          html += '<option value="' + o + '"' + (String(val) === o ? ' selected' : '') + '>' + o + '</option>';
        });
        html += '</select></div>';
      } else if (f.type === 'number') {
        html += '<div class="col-md-6"><label class="form-label small">' + f.label + '</label>' +
          '<input type="number" class="form-control form-control-sm defaults-field" data-key="' + f.key + '"' +
          ' value="' + val + '" placeholder="' + (f.placeholder || '') + '"' +
          (f.step ? ' step="' + f.step + '"' : '') + '></div>';
      } else {
        html += '<div class="col-md-6"><label class="form-label small">' + f.label + '</label>' +
          '<input type="text" class="form-control form-control-sm defaults-field" data-key="' + f.key + '"' +
          ' value="' + val + '" placeholder="' + (f.placeholder || '') + '"></div>';
      }
    });
    if (!html) html = '<div class="text-muted small col-12">No configurable defaults for this type.</div>';
    defaultsFieldsArea.innerHTML = html;
  }

  function collectDefaultFields() {
    var obj = {};
    document.querySelectorAll('.defaults-field').forEach(function (el) {
      var key = el.dataset.key;
      var val = el.value;
      if (val === '' || val === undefined) return;
      if (el.type === 'number' && val !== '') val = parseFloat(val);
      // Handle comma-separated text as arrays for known array fields
      if (el.type === 'text' && val.indexOf(',') > -1) {
        val = val.split(',').map(function (s) { return s.trim(); }).filter(Boolean);
      }
      obj[key] = val;
    });
    return obj;
  }

  // ─── Summary of key settings for table display ──────────────────────
  function summarizeDefaults(type, defaults) {
    if (!defaults || Object.keys(defaults).length === 0) return '<span class="text-muted">—</span>';
    var fields = MODEL_FIELDS[type] || [];
    var parts = [];
    fields.slice(0, 3).forEach(function (f) {
      if (defaults[f.key] !== undefined) {
        var v = defaults[f.key];
        if (Array.isArray(v)) v = v.join(', ');
        parts.push('<span class="badge bg-secondary me-1">' + f.label.split('(')[0].trim() + ': ' + v + '</span>');
      }
    });
    return parts.join('') || '<span class="text-muted">—</span>';
  }

  // ─── Selection management ────────────────────────────────────────────
  function updateSelectedCount() {
    selectedCountSpan.textContent = selectedModels.size;
    btnDeleteSelected.style.display = selectedModels.size > 0 ? 'inline-block' : 'none';
  }

  function updateSelectAllState() {
    var checkboxes = document.querySelectorAll('.model-checkbox');
    if (checkboxes.length === 0) {
      selectAllCheckbox.checked = false;
      selectAllCheckbox.indeterminate = false;
    } else if (selectedModels.size === checkboxes.length) {
      selectAllCheckbox.checked = true;
      selectAllCheckbox.indeterminate = false;
    } else if (selectedModels.size > 0) {
      selectAllCheckbox.checked = false;
      selectAllCheckbox.indeterminate = true;
    } else {
      selectAllCheckbox.checked = false;
      selectAllCheckbox.indeterminate = false;
    }
  }

  selectAllCheckbox.onchange = function () {
    var checkboxes = document.querySelectorAll('.model-checkbox');
    if (selectAllCheckbox.checked) {
      checkboxes.forEach(function (cb) { cb.checked = true; selectedModels.add(cb.getAttribute('data-model-id')); });
    } else {
      checkboxes.forEach(function (cb) { cb.checked = false; }); selectedModels.clear();
    }
    updateSelectedCount();
  };

  // ─── Load models ─────────────────────────────────────────────────────
  function loadModels() {
    var type = typeSelect.value;
    listTitle.textContent = TYPE_LABELS[type] || type;
    selectedModels.clear();
    updateSelectedCount();
    renderDefaultFields(type, {});
    clearForm();

    fetch('/setup/models/api/' + encodeURIComponent(type))
      .then(function (r) { return r.json(); })
      .then(function (d) {
        var models = (d && d.models) || [];
        var html = '';
        if (models.length === 0) {
          html = '<tr><td colspan="5" class="text-center text-muted py-3">No models for this type</td></tr>';
        } else {
          models.forEach(function (m) {
            html += '<tr class="model-row" data-model-id="' + m.id + '" style="cursor:pointer">' +
              '<td><input title="Select this model" type="checkbox" class="model-checkbox" data-model-id="' + m.id + '" onclick="event.stopPropagation()"></td>' +
              '<td class="fw-semibold">' + (m.name || '') + '</td>' +
              '<td class="small text-muted">' + (m.description || '') + '</td>' +
              '<td>' + summarizeDefaults(type, m.defaults) + '</td>' +
              '<td><button title="Apply this model" class="btn btn-sm btn-outline-primary" data-choose-apply="' + m.id + '" onclick="event.stopPropagation()">' +
              '<i class="bi bi-link"></i></button></td>' +
              '</tr>';
          });
        }
        tableBody.innerHTML = html;
        wireModelRowHandlers();
        loadPartsOfType();
      })
      .catch(function () { tableBody.innerHTML = '<tr><td colspan="5" class="text-danger py-3">Failed to load</td></tr>'; });
  }

  function wireModelRowHandlers() {
    // Row click = edit
    document.querySelectorAll('.model-row').forEach(function (row) {
      row.addEventListener('click', function () { fillFormFromId(row.getAttribute('data-model-id')); });
    });
    // Choose button = set for apply
    document.querySelectorAll('[data-choose-apply]').forEach(function (btn) {
      btn.onclick = function () { applyModelId.value = btn.getAttribute('data-choose-apply'); };
    });
    // Checkboxes
    document.querySelectorAll('.model-checkbox').forEach(function (cb) {
      cb.onchange = function () {
        var mid = cb.getAttribute('data-model-id');
        if (cb.checked) selectedModels.add(mid); else selectedModels.delete(mid);
        updateSelectedCount();
        updateSelectAllState();
      };
    });
  }

  // ─── Form operations ─────────────────────────────────────────────────
  function clearForm() {
    document.getElementById('modelId').value = '';
    document.getElementById('modelName').value = '';
    document.getElementById('modelDesc').value = '';
    document.getElementById('modelDefaults').value = '';
    document.getElementById('btnDeleteModel').disabled = true;
    editorTitle.textContent = 'Create New Model';
    renderDefaultFields(typeSelect.value, {});
  }

  function fillFormFromId(id) {
    var type = typeSelect.value;
    fetch('/setup/models/api/' + encodeURIComponent(type) + '/' + encodeURIComponent(id))
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (!d || !d.success || !d.model) return;
        document.getElementById('modelId').value = d.model.id;
        document.getElementById('modelName').value = d.model.name || '';
        document.getElementById('modelDesc').value = d.model.description || '';
        document.getElementById('modelDefaults').value = JSON.stringify(d.model.defaults || {}, null, 2);
        document.getElementById('btnDeleteModel').disabled = false;
        editorTitle.textContent = 'Edit: ' + (d.model.name || d.model.id);
        renderDefaultFields(type, d.model.defaults || {});
        // Highlight row
        document.querySelectorAll('.model-row').forEach(function (r) { r.classList.remove('table-active'); });
        var row = document.querySelector('.model-row[data-model-id="' + id + '"]');
        if (row) row.classList.add('table-active');
      });
  }

  function loadPartsOfType() {
    var type = typeSelect.value;
    partsSelect.innerHTML = '';
    fetch('/api/parts')
      .then(function (r) { return r.json(); })
      .then(function (d) {
        var parts = (d && d.parts) || [];
        parts.filter(function (p) { return ((p.type || '').replace(/\-/g, '_') === type); })
          .forEach(function (p) {
            var opt = document.createElement('option');
            opt.value = p.id;
            opt.textContent = '#' + p.id + ' — ' + (p.name || '') + (p.modelId ? ' [' + p.modelId + ']' : '');
            partsSelect.appendChild(opt);
          });
      });
  }

  // ─── Save ─────────────────────────────────────────────────────────────
  document.getElementById('btnSaveModel').onclick = function () {
    var type = typeSelect.value;
    var id = document.getElementById('modelId').value.trim();
    var name = document.getElementById('modelName').value.trim();
    var description = document.getElementById('modelDesc').value.trim();
    if (!name) { alert('Name is required'); return; }

    // Collect from form fields, then merge any raw JSON overrides
    var defaults = collectDefaultFields();
    var rawCollapse = document.getElementById('rawDefaultsCollapse');
    if (rawCollapse && rawCollapse.classList.contains('show')) {
      var rawText = document.getElementById('modelDefaults').value.trim();
      if (rawText) {
        try {
          var rawObj = JSON.parse(rawText);
          defaults = Object.assign({}, defaults, rawObj);
        } catch (e) { alert('Invalid JSON in raw defaults: ' + e.message); return; }
      }
    }

    var payload = { name: name, description: description, defaults: defaults };
    var url = '/setup/models/api/' + encodeURIComponent(type) + (id ? '/' + encodeURIComponent(id) : '');
    var method = id ? 'PUT' : 'POST';
    fetch(url, { method: method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
      .then(function (r) { return r.json(); })
      .then(function (resp) {
        if (resp && resp.success) {
          loadModels();
          if (!id) clearForm();
        } else {
          alert('Error: ' + (resp.error || 'Unknown'));
        }
      });
  };

  // ─── Delete ───────────────────────────────────────────────────────────
  document.getElementById('btnDeleteModel').onclick = function () {
    var type = typeSelect.value;
    var id = document.getElementById('modelId').value.trim();
    if (!id) { alert('No model selected'); return; }
    if (!confirm('Delete this model?')) return;
    fetch('/setup/models/api/' + encodeURIComponent(type) + '/' + encodeURIComponent(id), { method: 'DELETE' })
      .then(function (r) { return r.json(); })
      .then(function () { clearForm(); loadModels(); });
  };

  document.getElementById('btnNewModel').onclick = clearForm;

  // ─── Bulk delete ──────────────────────────────────────────────────────
  btnDeleteSelected.onclick = function () {
    if (selectedModels.size === 0) return;
    if (!confirm('Delete ' + selectedModels.size + ' selected model(s)?')) return;
    var type = typeSelect.value;
    fetch('/setup/models/api/' + encodeURIComponent(type) + '/bulk-delete', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids: Array.from(selectedModels) })
    })
      .then(function (r) { return r.json(); })
      .then(function (resp) {
        if (resp && resp.success) alert('Deleted ' + resp.deletedCount + ' model(s)');
        selectedModels.clear();
        loadModels();
      })
      .catch(function (err) { alert('Error: ' + err.message); loadModels(); });
  };

  // ─── Apply model to parts ────────────────────────────────────────────
  document.getElementById('btnApplyModel').onclick = function () {
    var id = applyModelId.value.trim();
    if (!id) { alert('Click the link icon on a model row first'); return; }
    var selected = Array.from(partsSelect.selectedOptions).map(function (o) { return o.value; });
    if (selected.length === 0) { alert('Select one or more parts'); return; }
    var status = document.getElementById('applyStatus');
    status.textContent = 'Applying model ' + id + '...';
    var ok = 0, fail = 0;
    Promise.all(selected.map(function (pid) {
      return fetch('/api/parts/' + encodeURIComponent(pid), {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ config: { modelId: id } })
      }).then(function (r) { return r.json(); })
        .then(function (r) { if (r && r.success) ok++; else fail++; })
        .catch(function () { fail++; });
    })).then(function () {
      status.textContent = 'Done. Applied to ' + ok + ' part(s), failed: ' + fail;
      loadPartsOfType();
    });
  };

  document.getElementById('btnPushDefaults').onclick = function () {
    var id = applyModelId.value.trim();
    if (!id) { alert('Click the link icon on a model row first'); return; }
    var selected = Array.from(partsSelect.selectedOptions).map(function (o) { return o.value; });
    if (selected.length === 0) { alert('Select one or more parts'); return; }
    var status = document.getElementById('applyStatus');
    var type = typeSelect.value;
    status.textContent = 'Pushing defaults...';
    fetch('/setup/models/api/' + encodeURIComponent(type) + '/' + encodeURIComponent(id))
      .then(function (r) { return r.json(); })
      .then(function (md) {
        if (!md || !md.success || !md.model) throw new Error('Model not found');
        var defaults = md.model.defaults || {};
        return Promise.all(selected.map(function (pid) {
          return fetch('/api/parts/' + encodeURIComponent(pid))
            .then(function (r) { return r.json(); })
            .then(function (pd) {
              if (!pd || !pd.success || !pd.part) throw new Error('Part not found');
              var cfg = pd.part.config || {};
              var merged = {};
              Object.keys(defaults).forEach(function (k) { merged[k] = defaults[k]; });
              Object.keys(cfg).forEach(function (k) { merged[k] = cfg[k]; });
              merged.modelId = id;
              return fetch('/api/parts/' + encodeURIComponent(pid), {
                method: 'PUT', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ config: merged })
              }).then(function (r) { return r.json(); });
            });
        }));
      })
      .then(function (results) {
        var ok = 0, fail = 0;
        (results || []).forEach(function (r) { if (r && r.success) ok++; else fail++; });
        status.textContent = 'Done. Pushed to ' + ok + ' part(s), failed: ' + fail;
        loadPartsOfType();
      })
      .catch(function (err) { status.textContent = 'Failed: ' + err.message; });
  };

  // ─── Auto-load on type change ─────────────────────────────────────────
  typeSelect.addEventListener('change', function () {
    loadModels();
  });

  document.getElementById('btnRefresh').onclick = loadModels;

  // Initial load
  loadModels();
})();
</script>
