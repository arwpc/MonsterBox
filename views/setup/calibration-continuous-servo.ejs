<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Custom CSS -->
    <style>
        body {
            background-color: #0d1117;
            color: #c9d1d9;
        }

        .saved-position-badge {
            cursor: pointer;
        }

        .card {
            background-color: #161b22;
            border: 1px solid #30363d;
        }

        .card-header {
            background-color: #21262d;
            border-bottom: 1px solid #30363d;
        }

        .btn-outline-primary:hover {
            background-color: #1f6feb;
            border-color: #1f6feb;
        }

        .btn-outline-success:hover {
            background-color: #238636;
            border-color: #238636;
        }

        .btn-outline-warning:hover {
            background-color: #d29922;
            border-color: #d29922;
        }

        .btn-outline-danger:hover {
            background-color: #da3633;
            border-color: #da3633;
        }

        .form-control,
        .form-select {
            background-color: #0d1117;
            border: 1px solid #30363d;
            color: #c9d1d9;
        }

        .form-control:focus,
        .form-select:focus {
            background-color: #0d1117;
            border-color: #1f6feb;
            color: #c9d1d9;
            box-shadow: 0 0 0 0.25rem rgba(31, 111, 235, 0.25);
        }

        .text-success {
            color: #3fb950 !important;
        }

        .text-warning {
            color: #d29922 !important;
        }

        .text-danger {
            color: #f85149 !important;
        }

        .pulse-display {
            font-family: 'Courier New', monospace;
            font-size: 1.1em;
            font-weight: bold;
        }
    </style>
</head>

<body>
    <!-- Navigation -->
        <!-- Unified Navigation - Same on ALL pages -->
    <%- include('../components/unified-navigation', { page: 'setup-calibration' }) %>

    <main class="container-fluid py-4">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1><i class="bi bi-sliders"></i> Calibrate Continuous Servo</h1>
                        <p class="text-muted mb-0">
                            <i class="bi bi-arrow-left"></i>
                            <a href="/setup/parts" class="text-decoration-none">Back to Parts</a>
                        </p>
                    </div>
                    <div class="text-end">
                        <h4 class="mb-0">🎛️ <%= part.name %>
                        </h4>
                        <small class="text-muted">ID: <%= part.id %> | Channel: <%= part.config.channel %> | Type: <%=
                                        part.config.servoType %></small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Messages -->
        <div class="row mb-3">
            <div class="col-12">
                <div id="statusMessage" class="alert alert-info d-none" role="alert">
                    <i class="bi bi-info-circle"></i> <span id="statusText">Ready to calibrate</span>
                </div>
            </div>
        </div>

        <!-- Phase 1: Pulse Calibration -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-1-circle"></i> Phase 1: Pulse Calibration
                            <span class="badge bg-secondary ms-2">Find Stop, CW, and CCW Pulses</span>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <!-- Jog Controls -->
                            <div class="col-lg-6">
                                <h6><i class="bi bi-joystick"></i> Jog Controls</h6>

                                <!-- Speed and Duration Controls -->
                                <div class="row mb-3">
                                    <div class="col-6">
                                        <label for="jogSpeed" class="form-label">Speed (%)</label>
                                        <input type="range" class="form-range" id="jogSpeed" min="10" max="100"
                                            value="50">
                                        <div class="text-center">
                                            <small class="text-muted"><span id="speedValue">50</span>%</small>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <label for="jogDuration" class="form-label">Duration (ms)</label>
                                        <input type="range" class="form-range" id="jogDuration" min="100" max="2000"
                                            value="500" step="100">
                                        <div class="text-center">
                                            <small class="text-muted"><span id="durationValue">500</span>ms</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Jog Buttons -->
                                <div class="d-grid gap-2">
                                    <div class="row g-2">
                                        <div class="col-4">
                                            <button id="jogCwBtn" class="btn btn-outline-primary w-100" type="button">
                                                <i class="bi bi-arrow-clockwise"></i> CW
                                            </button>
                                        </div>
                                        <div class="col-4">
                                            <button id="stopBtn" class="btn btn-outline-danger w-100" type="button">
                                                <i class="bi bi-stop-fill"></i> STOP
                                            </button>
                                        </div>
                                        <div class="col-4">
                                            <button id="jogCcwBtn" class="btn btn-outline-primary w-100" type="button">
                                                <i class="bi bi-arrow-counterclockwise"></i> CCW
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Pulse Calibration -->
                            <div class="col-lg-6">
                                <h6><i class="bi bi-broadcast"></i> Pulse Calibration</h6>

                                <!-- Current Pulses Display -->
                                <div class="mb-3">
                                    <div class="row g-2 text-center">
                                        <div class="col-4">
                                            <div class="card bg-dark">
                                                <div class="card-body py-2">
                                                    <small class="text-muted">STOP</small>
                                                    <div class="pulse-display text-warning" id="stopPulseDisplay">
                                                        <%= calibrationStatus.pulses?.stop || 1500 %>µs
                                                    </div>
                                                    <i id="stopPulseIcon"
                                                        class="bi <%= calibrationStatus.stopPulseCalibrated ? 'bi-check-circle-fill text-success' : 'bi-circle text-muted' %>"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="card bg-dark">
                                                <div class="card-body py-2">
                                                    <small class="text-muted">CW</small>
                                                    <div class="pulse-display text-primary" id="cwPulseDisplay">
                                                        <%= calibrationStatus.pulses?.cw || 1200 %>µs
                                                    </div>
                                                    <i id="cwPulseIcon"
                                                        class="bi <%= calibrationStatus.cwPulseCalibrated ? 'bi-check-circle-fill text-success' : 'bi-circle text-muted' %>"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="card bg-dark">
                                                <div class="card-body py-2">
                                                    <small class="text-muted">CCW</small>
                                                    <div class="pulse-display text-info" id="ccwPulseDisplay">
                                                        <%= calibrationStatus.pulses?.ccw || 1800 %>µs
                                                    </div>
                                                    <i id="ccwPulseIcon"
                                                        class="bi <%= calibrationStatus.ccwPulseCalibrated ? 'bi-check-circle-fill text-success' : 'bi-circle text-muted' %>"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Pulse Input and Save -->
                                <div class="row g-2">
                                    <div class="col-6">
                                        <select id="pulseType" class="form-select">
                                            <option value="stop">STOP Pulse</option>
                                            <option value="cw">CW Pulse</option>
                                            <option value="ccw">CCW Pulse</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <div class="input-group">
                                            <input type="number" id="pulseInput" class="form-control" min="500"
                                                max="2500" value="1500" placeholder="1500">
                                            <span class="input-group-text">µs</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-grid mt-2">
                                    <button id="savePulseBtn" class="btn btn-outline-success" type="button">
                                        <i class="bi bi-save"></i> Save Pulse
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Phase 2: Position Calibration -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-2-circle"></i> Phase 2: Position Calibration
                            <span class="badge bg-secondary ms-2">Save Named Positions</span>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <!-- Suggested Positions -->
                            <div class="col-lg-6">
                                <h6><i class="bi bi-bookmark"></i> Suggested Positions</h6>
                                <div id="suggestedPositions">
                                    <% suggestedPositions.forEach(function(pos) { %>
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div>
                                                <strong>
                                                    <%= pos.name %>
                                                </strong>
                                                <br><small class="text-muted">
                                                    <%= pos.description %>
                                                </small>
                                            </div>
                                            <button class="btn btn-outline-success btn-sm save-position-btn"
                                                data-position="<%= pos.name %>"
                                                data-description="<%= pos.description %>">
                                                <i class="bi bi-save"></i> Save
                                            </button>
                                        </div>
                                        <% }); %>
                                </div>
                            </div>

                            <!-- Custom Position -->
                            <div class="col-lg-6">
                                <h6><i class="bi bi-plus-circle"></i> Custom Position</h6>
                                <div class="mb-3">
                                    <label for="customPositionName" class="form-label">Position Name</label>
                                    <input type="text" id="customPositionName" class="form-control"
                                        placeholder="e.g., custom_position">
                                </div>
                                <div class="mb-3">
                                    <label for="customPositionDesc" class="form-label">Description</label>
                                    <input type="text" id="customPositionDesc" class="form-control"
                                        placeholder="e.g., Custom position description">
                                </div>
                                <div class="d-grid">
                                    <button id="saveCustomPositionBtn" class="btn btn-outline-success" type="button">
                                        <i class="bi bi-save"></i> Save Custom Position
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Saved Positions Status -->
                        <div class="mt-4">
                            <h6><i class="bi bi-list-check"></i> Saved Positions</h6>
                            <div id="savedPositions" class="row g-2">
                                <% if (calibrationStatus.calibratedPositions &&
                                    calibrationStatus.calibratedPositions.length> 0) { %>
                                    <% calibrationStatus.calibratedPositions.forEach(function(posName) { %>
                                        <div class="col-auto">
                                            <% var posObj=(calibrationStatus.positions &&
                                                calibrationStatus.positions[posName]) || {}; %>
                                                <span class="badge bg-success saved-position-badge"
                                                    data-position-name="<%= posName %>"
                                                    data-direction="<%= (posObj.motion && posObj.motion.direction) ? posObj.motion.direction : '' %>"
                                                    data-speed="<%= (posObj.motion && posObj.motion.speed != null) ? posObj.motion.speed : '' %>"
                                                    data-duration="<%= (posObj.motion && posObj.motion.duration != null) ? posObj.motion.duration : '' %>"
                                                    title="Click to move">
                                                    <i class="bi bi-check-circle"></i>
                                                    <%= posName %>
                                                </span>
                                        </div>
                                        <% }); %>
                                            <% } else { %>
                                                <div class="col-12">
                                                    <p class="text-muted mb-0">No positions saved yet</p>
                                                </div>
                                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-tools"></i> Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex gap-2">
                            <button id="resetCalibrationBtn" class="btn btn-outline-warning">
                                <i class="bi bi-arrow-clockwise"></i> Reset Calibration
                            </button>
                            <a href="/setup/parts" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Back to Parts
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Calibration JavaScript -->
    <script>
        const partId = '<%= part.id %>';

        // Update range displays
        document.getElementById('jogSpeed').addEventListener('input', function () {
            document.getElementById('speedValue').textContent = this.value;
        });
        // Track last jog settings for quick replay
        var lastJogDirection = 'stop';
        var lastJogSpeed = parseInt(document.getElementById('jogSpeed').value || '50', 10);
        var lastJogDuration = parseInt(document.getElementById('jogDuration').value || '500', 10);

        // Lightweight heading estimator (client-side)
        var msPerDegree = null; // milliseconds per degree at calibratedSpeed
        var calibratedSpeed = null; // % speed used when calibrating msPerDegree
        var currentAngleEstimate = null; // degrees; null if unknown


        document.getElementById('jogDuration').addEventListener('input', function () {
            document.getElementById('durationValue').textContent = this.value;
        });

        // Show status message
        function showStatus(message, type = 'info') {
            const statusDiv = document.getElementById('statusMessage');
            const statusText = document.getElementById('statusText');

            statusDiv.className = `alert alert-${type}`;
            statusText.textContent = message;
            statusDiv.classList.remove('d-none');

            // Auto-hide after 3 seconds for success messages
            if (type === 'success') {
                setTimeout(() => {
                    statusDiv.classList.add('d-none');
                }, 3000);
            }
        }

        // Disable/enable controls during operations
        function setControlsEnabled(enabled) {
            const buttons = ['jogCwBtn', 'jogCcwBtn', 'stopBtn', 'savePulseBtn', 'saveCustomPositionBtn', 'resetCalibrationBtn'];
            buttons.forEach(id => {
                const btn = document.getElementById(id);
                if (btn) {
                    btn.disabled = !enabled;
                }
            });

            document.querySelectorAll('.save-position-btn').forEach(btn => {
                btn.disabled = !enabled;
            });
        }

        // Jog servo
        async function jogServo(direction) {
            const speed = document.getElementById('jogSpeed').value;
            const duration = document.getElementById('jogDuration').value;

            // Remember last jog settings
            lastJogDirection = direction;
            lastJogSpeed = parseInt(speed, 10);
            lastJogDuration = parseInt(duration, 10);

            // Any manual jog invalidates our angle estimate (we no longer know absolute heading)
            try { if (direction !== 'stop') { currentAngleEstimate = null; } } catch (e) { /* ignore */ }


            try {
                setControlsEnabled(false);
                showStatus(`${direction.toUpperCase()} rotation at ${speed}% for ${duration}ms...`, 'info');

                const response = await fetch(`/setup/calibration/api/continuous_servo/${partId}/jog`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        direction: direction,
                        speed: parseInt(speed),
                        duration: parseInt(duration)
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showStatus(result.message, 'success');
                } else {
                    showStatus(result.message || 'Jog operation failed', 'danger');
                }

            } catch (error) {
                console.error('Error jogging servo:', error);
                showStatus('Failed to jog servo: ' + error.message, 'danger');
            } finally {
                setControlsEnabled(true);
            }
        }

        // Save pulse calibration
        async function savePulse() {
            const pulseType = document.getElementById('pulseType').value;
            const pulseUs = document.getElementById('pulseInput').value;

            if (!pulseUs || pulseUs < 500 || pulseUs > 2500) {
                showStatus('Pulse width must be between 500 and 2500 microseconds', 'danger');
                return;
            }

            try {
                setControlsEnabled(false);
                showStatus(`Saving ${pulseType.toUpperCase()} pulse (${pulseUs}µs)...`, 'info');

                const response = await fetch(`/setup/calibration/api/continuous_servo/${partId}/save-pulse`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        pulseType: pulseType,
                        pulseUs: parseInt(pulseUs)
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showStatus(result.message, 'success');
                    updatePulseDisplay(pulseType, pulseUs);
                } else {
                    showStatus(result.message || 'Failed to save pulse', 'danger');
                }

            } catch (error) {
                console.error('Error saving pulse:', error);
                showStatus('Failed to save pulse: ' + error.message, 'danger');
            } finally {
                setControlsEnabled(true);
            }
        }

        // Update pulse display
        function updatePulseDisplay(pulseType, pulseUs) {
            const displayId = pulseType + 'PulseDisplay';
            const iconId = pulseType + 'PulseIcon';

            const display = document.getElementById(displayId);
            const icon = document.getElementById(iconId);

            if (display) {
                display.textContent = pulseUs + 'µs';
            }

            if (icon) {
                icon.className = 'bi bi-check-circle-fill text-success';
            }
        }

        // Save position
        async function savePosition(positionName, description) {
            if (!positionName || !positionName.trim()) {
                showStatus('Position name is required', 'danger');
                return;
            }

            try {
                setControlsEnabled(false);
                showStatus(`Saving position "${positionName}"...`, 'info');

                const response = await fetch(`/setup/calibration/api/continuous_servo/${partId}/save-position`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        positionName: positionName.trim(),
                        description: description || `${positionName} position`,
                        direction: lastJogDirection,
                        speed: lastJogSpeed,
                        duration: lastJogDuration
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showStatus(result.message, 'success');
                    addSavedPositionBadge(positionName, { direction: lastJogDirection, speed: lastJogSpeed, duration: lastJogDuration });
                } else {
                    showStatus(result.message || 'Failed to save position', 'danger');
                }

            } catch (error) {
                console.error('Error saving position:', error);
                showStatus('Failed to save position: ' + error.message, 'danger');
            } finally {
                setControlsEnabled(true);
            }
        }

        // Add saved position badge
        function addSavedPositionBadge(positionName, motion) {
            const savedPositions = document.getElementById('savedPositions');

            // Remove "No positions saved yet" message if it exists
            const noPositionsMsg = savedPositions.querySelector('.text-muted');
            if (noPositionsMsg) {
                noPositionsMsg.parentElement.remove();
            }

            // Check if badge already exists
            const existingBadge = Array.from(savedPositions.querySelectorAll('.badge')).find(badge =>
                badge.textContent.includes(positionName)
            );

            if (!existingBadge) {
                const badgeDiv = document.createElement('div');
                badgeDiv.className = 'col-auto';
                var dir = motion && motion.direction ? motion.direction : '';
                var spd = (motion && motion.speed != null) ? motion.speed : '';
                var dur = (motion && motion.duration != null) ? motion.duration : '';
                badgeDiv.innerHTML = `
                    <span class="badge bg-success saved-position-badge" data-position-name="${positionName}"
                        data-direction="${dir}" data-speed="${spd}" data-duration="${dur}" title="Click to move">
                        <i class="bi bi-check-circle"></i> ${positionName}
                    </span>
                `;
                savedPositions.appendChild(badgeDiv);
                try { bindSavedPositionClicks && bindSavedPositionClicks(); } catch (e) { /* ignore */ }

            }
        }
        // Click-to-move: saved positions
        function directionFromPositionName(name) {
            try {
                var n = String(name || '').toLowerCase();
                if (n.indexOf('stop') >= 0 || n.indexOf('neutral') >= 0 || n.indexOf('center') >= 0 || n.indexOf('centre') >= 0 || n.indexOf('forward') >= 0) return 'stop';
                if (n.indexOf('left') >= 0 || n.indexOf('ccw') >= 0) return 'ccw';
                if (n.indexOf('right') >= 0 || n.indexOf('cw') >= 0) return 'cw';
                if (n.indexOf('back') >= 0) return 'cw';
                return 'stop';
            } catch (e) { return 'stop'; }
        }
        async function applySavedMotion(dir, spd, dur) {
            try {
                setControlsEnabled(false);
                showStatus(`${(dir || 'stop').toUpperCase()} (saved) at ${spd || 0}% for ${dur || 0}ms...`, 'info');
                const response = await fetch(`/setup/calibration/api/continuous_servo/${partId}/jog`, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ direction: dir || 'stop', speed: parseInt(spd || 0), duration: parseInt(dur || 0) })
                });
                const result = await response.json();
                if (result.success) { showStatus(result.message, 'success'); }
                else { showStatus(result.message || 'Failed to apply saved motion', 'danger'); }
            } catch (e) {
                showStatus('Failed to apply saved motion: ' + e.message, 'danger');
            } finally { setControlsEnabled(true); }
        }
        function bindSavedPositionClicks() {
            try {
                document.querySelectorAll('.saved-position-badge').forEach(function (el) {
                    if (el.dataset._bound) return; // avoid double-binding
                    el.dataset._bound = '1';
                    el.addEventListener('click', function () {
                        var name = this.getAttribute('data-position-name') || this.textContent.trim();
                        function angleFromName(name) {
                            try {
                                var n = String(name || '').toLowerCase().trim();
                                if (n.indexOf('forward') >= 0 || n.indexOf('center') >= 0 || n.indexOf('centre') >= 0 || n.indexOf('neutral') >= 0) return 0;
                                if (n.indexOf('backward') >= 0 || n === 'back' || n.indexOf('back') >= 0) return 180;
                                var m = n.match(/right[ _-]?(\d+)/i); if (m) return parseInt(m[1], 10);
                                m = n.match(/left[ _-]?(\d+)/i); if (m) return -parseInt(m[1], 10);
                                return null;
                            } catch (e) { return null; }
                        }
                        function ensureTimingCalibration() {
                            if (msPerDegree != null) return;
                            try {
                                var best = null; // {angle: number, duration: number, speed: number}
                                document.querySelectorAll('.saved-position-badge').forEach(function (el) {
                                    var name = el.getAttribute('data-position-name') || el.textContent.trim();
                                    var ang = angleFromName(name);
                                    var dur = parseInt(el.getAttribute('data-duration') || '', 10);
                                    var spd = parseInt(el.getAttribute('data-speed') || '', 10);
                                    if (ang != null && !isNaN(dur) && Math.abs(ang) > 0) {
                                        if (!best || Math.abs(ang) > Math.abs(best.angle)) {
                                            best = { angle: ang, duration: dur, speed: (!isNaN(spd) ? spd : null) };
                                        }
                                    }
                                });
                                if (best) {
                                    msPerDegree = Math.max(1, Math.round(best.duration / Math.abs(best.angle)));
                                    calibratedSpeed = (best.speed != null ? best.speed : (lastJogSpeed || 50));
                                }
                            } catch (e) { /* ignore */ }
                        }

                        var d = this.getAttribute('data-direction') || '';
                        var s = this.getAttribute('data-speed');
                        var t = this.getAttribute('data-duration');
                        var targetAngle = angleFromName(name);

                        // Prefer angle-aware goto when we can estimate timing and current heading
                        ensureTimingCalibration();
                        if (targetAngle != null) {
                            if (msPerDegree != null && currentAngleEstimate != null) {
                                var delta = targetAngle - currentAngleEstimate;
                                if (Math.abs(delta) < 1) { jogServo('stop'); currentAngleEstimate = targetAngle; return; }
                                var dir2 = (delta > 0 ? 'cw' : 'ccw');
                                var dur2 = Math.max(1, Math.round(Math.abs(delta) * msPerDegree));
                                var spd2 = (calibratedSpeed != null ? calibratedSpeed : (parseInt(s || '', 10) || lastJogSpeed || 50));
                                applySavedMotion(dir2, spd2, dur2);
                                currentAngleEstimate = targetAngle;
                                return;
                            }
                            // If no timing yet but this badge has a known angle and saved motion, calibrate from it
                            var tNum = parseInt(t || '', 10);
                            var sNum = parseInt(s || '', 10);
                            if (d && !isNaN(tNum) && Math.abs(targetAngle) > 0) {
                                if (msPerDegree == null) { msPerDegree = Math.max(1, Math.round(tNum / Math.abs(targetAngle))); }
                                if (calibratedSpeed == null && !isNaN(sNum)) { calibratedSpeed = sNum; }
                                applySavedMotion(d, s, t);
                                currentAngleEstimate = targetAngle;
                                return;
                            }
                        }

                        // Fallbacks
                        if (d) { applySavedMotion(d, s, t); return; }
                        var dir = directionFromPositionName(name);
                        if (dir === 'stop') { jogServo('stop'); } else { jogServo(dir); }
                    });
                });
            } catch (e) { /* ignore */ }
        }


        // Reset calibration
        async function resetCalibration() {
            if (!confirm('Are you sure you want to reset all calibration data? This cannot be undone.')) {
                return;
            }

            try {
                setControlsEnabled(false);
                showStatus('Resetting calibration...', 'info');

                const response = await fetch(`/setup/calibration/api/continuous_servo/${partId}/reset`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({})
                });

                const result = await response.json();

                if (result.success) {
                    showStatus(result.message, 'success');
                    // Ensure newly added badge is clickable
                    try { bindSavedPositionClicks && bindSavedPositionClicks(); } catch (e) { /* ignore */ }

                    // Reload page to reset UI
                    setTimeout(() => {
                        window.location.reload();
                    }, 1500);
                } else {
                    showStatus(result.message || 'Failed to reset calibration', 'danger');
                }

            } catch (error) {
                console.error('Error resetting calibration:', error);
                showStatus('Failed to reset calibration: ' + error.message, 'danger');
            } finally {
                setControlsEnabled(true);
            }
        }

        // Event listeners
        document.getElementById('jogCwBtn').addEventListener('click', () => jogServo('cw'));
        document.getElementById('jogCcwBtn').addEventListener('click', () => jogServo('ccw'));

        // Enable click-to-move on any existing saved position badges
        try { bindSavedPositionClicks(); } catch (e) { /* ignore */ }

        document.getElementById('stopBtn').addEventListener('click', () => jogServo('stop'));
        document.getElementById('savePulseBtn').addEventListener('click', savePulse);
        document.getElementById('resetCalibrationBtn').addEventListener('click', resetCalibration);

        // Suggested position buttons
        document.querySelectorAll('.save-position-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const positionName = this.getAttribute('data-position');
                const description = this.getAttribute('data-description');
                savePosition(positionName, description);
            });
        });

        // Custom position button
        document.getElementById('saveCustomPositionBtn').addEventListener('click', function () {
            const positionName = document.getElementById('customPositionName').value;
            const description = document.getElementById('customPositionDesc').value;

            if (positionName.trim()) {
                savePosition(positionName, description);
                // Clear inputs after saving
                document.getElementById('customPositionName').value = '';
                document.getElementById('customPositionDesc').value = '';
            } else {
                showStatus('Please enter a position name', 'danger');
            }
        });
    </script>