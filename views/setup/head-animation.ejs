<style>
  .head-page { max-height: calc(100vh - 56px); overflow: hidden; }
  .head-section { background: rgba(13,13,13,0.6); border-left: 3px solid var(--bs-primary, #0d6efd); padding: 0.75rem; margin-bottom: 0.5rem; border-radius: 4px; }
  .head-section.opencv-section { border-left-color: var(--bs-success, #198754); }
  .head-section.servo-section { border-left-color: var(--bs-warning, #ffc107); }
  .compact-label { font-size: 0.85rem; margin-bottom: 0.25rem; }
  .form-range { height: 1.2rem; }
  .webcam-container { position: relative; background: #000; border-radius: 6px; overflow: hidden; min-height: 240px; }
  .webcam-stream { width: 100%; display: block; border-radius: 6px; }
  .tracking-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
  .tracking-status-panel { background: rgba(13,13,13,0.6); border: 1px solid var(--bs-border-color, #444); border-radius: 6px; padding: 0.75rem; }
  .servo-test-panel { background: rgba(13,13,13,0.6); border: 1px solid var(--bs-border-color, #444); border-radius: 6px; padding: 0.75rem; }
  .status-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 4px; }
  .status-dot.active { background: var(--mb-success, #198754); animation: statusPulse 1s ease-in-out infinite; }
  .status-dot.inactive { background: var(--mb-secondary, #6c757d); }
  .status-dot.detecting { background: var(--mb-warning, #ffc107); animation: statusPulse 0.5s ease-in-out infinite; }
  @keyframes statusPulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
  .fps-badge { font-variant-numeric: tabular-nums; min-width: 2.5em; }
  .servo-bounds-info { font-size: 0.8rem; color: var(--bs-info, #0dcaf0); margin-top: 0.25rem; }
  .toggle-disabled-hint { font-size: 0.75rem; color: var(--bs-secondary, #6c757d); margin-left: 0.5rem; }
  .left-scroll { max-height: calc(100vh - 70px); overflow-y: auto; overflow-x: hidden; padding-right: 0.25rem; }
</style>

<div class="head-page">
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-warning alert-dismissible py-2 mb-2" role="alert">
    <i class="bi bi-exclamation-triangle"></i> <%= error %>
    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
  </div>
  <% } %>

  <% if (currentCharacter) { %>
  <div class="row g-2">
    <!-- LEFT COLUMN: Configuration (scrollable) -->
    <div class="col-lg-5 left-scroll">
      <!-- OpenCV Detection Toggle & Webcam -->
      <div class="head-section opencv-section">
        <div class="form-check form-switch mb-2">
          <input class="form-check-input" type="checkbox" role="switch" id="ocvEnabled">
          <label class="form-check-label" for="ocvEnabled" title="Starts the camera motion detection process" data-bs-toggle="tooltip"><strong><i class="bi bi-eye-fill text-success"></i> OpenCV Detection</strong></label>
        </div>

        <div class="mb-0">
          <label for="webcamSelect" class="compact-label" title="Which camera to use for tracking" data-bs-toggle="tooltip"><i class="bi bi-webcam"></i> Webcam</label>
          <select class="form-select form-select-sm" id="webcamSelect">
            <option value="">Select a webcam...</option>
          </select>
        </div>
      </div>

      <!-- Presets -->
      <div class="head-section opencv-section">
        <h6 class="text-success mb-2" style="font-size:0.9rem;"><i class="bi bi-lightning"></i> Presets</h6>
        <div id="presetsContainer" class="d-flex gap-1 flex-wrap mb-2">
          <button type="button" class="btn btn-outline-success btn-sm" id="presetPerson">
            <i class="bi bi-person-walking"></i> Person Tracking
          </button>
          <button type="button" class="btn btn-outline-info btn-sm" id="presetNoisy">
            <i class="bi bi-tv"></i> Noisy Environment
          </button>
          <button type="button" class="btn btn-outline-warning btn-sm" id="presetSensitive">
            <i class="bi bi-bullseye"></i> High Sensitivity
          </button>
        </div>
        <div class="d-flex gap-1">
          <button type="button" class="btn btn-outline-primary btn-sm" id="savePresetBtn">
            <i class="bi bi-floppy"></i> Save Current as Preset
          </button>
        </div>
      </div>

      <!-- Detection Mode -->
      <div class="head-section opencv-section">
        <h6 class="text-success mb-2" style="font-size:0.9rem;"><i class="bi bi-search"></i> Detection Mode</h6>
        <select class="form-select form-select-sm" id="detectionMode">
          <option value="motion">Motion (Background Subtraction)</option>
          <option value="face">Face Detection (Haar Cascade)</option>
          <option value="face+hands">Face + Hands</option>
          <option value="all">All (Face + Motion + Hands)</option>
        </select>
        <small class="text-muted">Select what the tracker should detect</small>
      </div>

      <!-- OpenCV Parameters -->
      <div class="head-section opencv-section">
        <h6 class="text-success mb-2" style="font-size:0.9rem;"><i class="bi bi-eye"></i> OpenCV Parameters</h6>

        <div class="mb-2">
          <label for="motionThresholdRange" class="compact-label" title="How much a pixel must change to count as motion. Higher = less sensitive, ignores small changes. Lower = catches subtle movement but more noise." data-bs-toggle="tooltip">
            Motion Threshold <span class="badge bg-secondary ms-1" id="motionThresholdValue">25</span>
          </label>
          <input type="range" class="form-range" id="motionThresholdRange" min="5" max="100" step="1" value="25">
        </div>

        <div class="row g-2 mb-2">
          <div class="col-6">
            <label for="minContourArea" class="compact-label" title="Minimum size of motion blob in pixels. Increase to ignore small movements (pets, shadows). A person at mid-range is ~5000-15000." data-bs-toggle="tooltip">Min Contour</label>
            <input type="number" class="form-control form-control-sm" id="minContourArea" min="100" max="50000" step="100" value="3000">
          </div>
          <div class="col-6">
            <label for="maxContourArea" class="compact-label" title="Maximum motion blob size. Decrease to ignore full-frame changes (lighting shifts, camera bumps)." data-bs-toggle="tooltip">Max Contour</label>
            <input type="number" class="form-control form-control-sm" id="maxContourArea" min="1000" max="300000" step="1000" value="100000">
          </div>
        </div>

        <div class="mb-2">
          <label for="bgLearningRateRange" class="compact-label" title="How fast the background model adapts to changes. Lower = more stable background (better for static cameras). Higher = adapts quickly (handles lighting changes)." data-bs-toggle="tooltip">
            BG Learning Rate <span class="badge bg-secondary ms-1" id="bgLearningRateValue">0.005</span>
          </label>
          <input type="range" class="form-range" id="bgLearningRateRange" min="0.001" max="0.1" step="0.001" value="0.005">
        </div>

        <div class="mb-2">
          <label for="noiseKernelRange" class="compact-label" title="Morphological filter size to remove speckle noise. Higher = more aggressive noise removal but may lose small targets." data-bs-toggle="tooltip">
            Noise Kernel <span class="badge bg-secondary ms-1" id="noiseKernelValue">5</span>
          </label>
          <input type="range" class="form-range" id="noiseKernelRange" min="1" max="11" step="2" value="5">
        </div>

        <div class="mb-2">
          <label for="blurSizeRange" class="compact-label" title="Gaussian blur before detection. Higher = smoother image, fewer false detections, but less precise target edges." data-bs-toggle="tooltip">
            Blur Size <span class="badge bg-secondary ms-1" id="blurSizeValue">5</span>
          </label>
          <input type="range" class="form-range" id="blurSizeRange" min="1" max="15" step="2" value="5">
        </div>

        <div class="mb-2">
          <label for="dilateSizeRange" class="compact-label" title="Merges nearby motion blobs into one target. Higher = treats spread-out motion (walking person) as one target." data-bs-toggle="tooltip">
            Dilate/Merge Size <span class="badge bg-secondary ms-1" id="dilateSizeValue">9</span>
          </label>
          <input type="range" class="form-range" id="dilateSizeRange" min="1" max="21" step="2" value="9">
        </div>

        <div class="mb-2">
          <label for="varThresholdRange" class="compact-label" title="Background model sensitivity. Higher = ignores more variation (good for noisy environments). Lower = detects subtle changes." data-bs-toggle="tooltip">
            MOG2 Var Threshold <span class="badge bg-secondary ms-1" id="varThresholdValue">25</span>
          </label>
          <input type="range" class="form-range" id="varThresholdRange" min="5" max="80" step="1" value="25">
        </div>

        <div class="mb-2">
          <label for="targetLockRange" class="compact-label" title="How strongly to stick with the current target. Higher = won't jump to new motion. Lower = switches targets more readily." data-bs-toggle="tooltip">
            Target Lock <span class="badge bg-secondary ms-1" id="targetLockValue">5</span>
          </label>
          <input type="range" class="form-range" id="targetLockRange" min="1" max="10" step="1" value="5">
        </div>

        <div class="mb-2">
          <label for="confirmFramesRange" class="compact-label" title="Frames a new motion must persist before tracking it. Higher = ignores brief flickers (TVs, screens). Lower = faster target acquisition." data-bs-toggle="tooltip">
            Confirm Frames <span class="badge bg-secondary ms-1" id="confirmFramesValue">3</span>
          </label>
          <input type="range" class="form-range" id="confirmFramesRange" min="1" max="10" step="1" value="3">
        </div>
      </div>

      <!-- Head Tracking Toggle & Servo -->
      <div class="head-section servo-section">
        <div class="form-check form-switch mb-2">
          <input class="form-check-input" type="checkbox" role="switch" id="htEnabled">
          <label class="form-check-label" for="htEnabled" title="Enables servo movement to follow detected motion. Requires OpenCV to be running." data-bs-toggle="tooltip"><strong><i class="bi bi-robot text-warning"></i> Head Tracking (Servo)</strong></label>
          <span class="toggle-disabled-hint" id="htDisabledHint" style="display:none;">Requires OpenCV</span>
        </div>

        <div class="mb-0">
          <label for="panServoSelect" class="compact-label"><i class="bi bi-robot"></i> Pan Servo</label>
          <select class="form-select form-select-sm" id="panServoSelect">
            <option value="">Select a servo...</option>
          </select>
          <div class="servo-bounds-info" id="servoBoundsInfo" style="display:none;"></div>
        </div>
      </div>

      <!-- Tracking Tuning -->
      <div class="head-section servo-section">
        <h6 class="text-warning mb-2" style="font-size:0.9rem;"><i class="bi bi-sliders"></i> Servo Tuning</h6>

        <div class="mb-2">
          <label for="smoothingRange" class="compact-label" title="How gradually the servo follows the target. Higher = smoother but slower response. Lower = faster but may jitter." data-bs-toggle="tooltip">
            Smoothing <span class="badge bg-secondary ms-1" id="smoothingValue">0.25</span>
          </label>
          <input type="range" class="form-range" id="smoothingRange" min="0.05" max="0.95" step="0.05" value="0.25">
        </div>

        <div class="mb-2">
          <label for="deadzoneRange" class="compact-label" title="Center region (% of frame) where no servo movement occurs. Prevents jitter when target is near center." data-bs-toggle="tooltip">
            Deadzone <span class="badge bg-secondary ms-1" id="deadzoneValue">5</span>
          </label>
          <input type="range" class="form-range" id="deadzoneRange" min="1" max="25" step="1" value="5">
        </div>

        <div class="row g-2 mb-2">
          <div class="col-6">
            <label for="centerDeg" class="compact-label" title="Servo angle for the 'looking straight ahead' position." data-bs-toggle="tooltip">Center (&deg;)</label>
            <input type="number" class="form-control form-control-sm" id="centerDeg" value="0">
          </div>
          <div class="col-6">
            <label for="rangeDeg" class="compact-label" title="Total degrees the servo can sweep. Larger = wider tracking range." data-bs-toggle="tooltip">Range (&deg;)</label>
            <input type="number" class="form-control form-control-sm" id="rangeDeg" min="1" max="180" value="60">
          </div>
        </div>

        <div class="form-check form-switch mb-2">
          <input class="form-check-input" type="checkbox" role="switch" id="invertPan">
          <label class="form-check-label compact-label" for="invertPan" title="Reverse the pan direction if servo moves opposite to target." data-bs-toggle="tooltip">Invert Pan Direction</label>
        </div>
      </div>

      <!-- Save Button -->
      <div class="d-flex gap-2 mb-2">
        <button type="button" class="btn btn-primary btn-sm flex-grow-1" id="saveConfigBtn">
          <i class="bi bi-save"></i> Save Config
        </button>
      </div>
    </div>

    <!-- RIGHT COLUMN: Webcam Preview & Controls -->
    <div class="col-lg-7">
      <!-- Webcam Preview with Overlay -->
      <div class="webcam-container mb-2" id="webcamContainer">
        <img id="webcamStream" class="webcam-stream" alt="Webcam stream" style="display:none;">
        <canvas id="trackingOverlay" class="tracking-overlay"></canvas>
        <div class="d-flex justify-content-center align-items-center h-100 text-muted" id="webcamPlaceholder" style="min-height:240px;">
          <div class="text-center">
            <i class="bi bi-webcam" style="font-size:2rem;"></i>
            <p class="mb-0 mt-1">Select a webcam to preview</p>
          </div>
        </div>
      </div>

      <!-- Tracking Status Panel -->
      <div class="tracking-status-panel mb-2">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div>
            <span class="status-dot inactive" id="trackingDot"></span>
            <span class="fw-bold" id="trackingStatusText">Stopped</span>
          </div>
          <div>
            <span class="badge bg-secondary fps-badge" id="fpsDisplay">0 FPS</span>
          </div>
        </div>

        <div class="row g-2">
          <div class="col-4">
            <small class="text-muted">Target</small>
            <div class="fw-bold" id="targetStatus">No target</div>
          </div>
          <div class="col-4">
            <small class="text-muted">Position</small>
            <div class="fw-bold" id="targetPosition">--</div>
          </div>
          <div class="col-4">
            <small class="text-muted">Head Tracking</small>
            <div class="fw-bold" id="headTrackingStatus">Off</div>
          </div>
        </div>
      </div>

      <!-- Servo Test Panel -->
      <div class="servo-test-panel">
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-outline-warning btn-sm flex-grow-1" id="testSweepBtn">
            <i class="bi bi-arrow-left-right"></i> Test Sweep
          </button>
          <button type="button" class="btn btn-outline-danger btn-sm" id="emergencyStopBtn">
            <i class="bi bi-exclamation-triangle"></i> E-Stop
          </button>
        </div>
      </div>
    </div>
  </div>
  <% } else { %>
  <div class="alert alert-info py-2" role="alert">
    <i class="bi bi-info-circle"></i> No character selected. Please select a character from the navigation menu.
  </div>
  <% } %>
</div>

<script src="/js/head-animation.js?v=<%= Date.now() %>"></script>
