<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Setup Characters - MonsterBox 4.0</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
  <!-- Unified Navigation - Same on ALL pages -->
  <%- include('../components/unified-navigation', { page: 'setup-characters' }) %>

    <main class="container-fluid py-4">
      <div class="row">
        <div class="col-12">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="bi bi-people"></i> Setup Characters</h1>
            <button id="createCharBtn" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create</button>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-body">
          <div id="alertBox" class="alert alert-warning d-none" role="alert"></div>

          <div id="charactersContainer" class="table-responsive">
            <div class="text-center text-muted py-4">
              <div class="spinner-border spinner-border-sm" role="status"><span
                  class="visually-hidden">Loading...</span>
              </div>
              <p class="mt-2">Loading characters...</p>
            </div>
          </div>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      (function () {
        var state = { characters: [], selected: null };

        function esc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

        function getInitials(name) {
          if (!name) return '?';
          var words = name.trim().split(/\s+/);
          if (words.length === 1) return words[0].substring(0, 2).toUpperCase();
          return (words[0][0] + words[words.length - 1][0]).toUpperCase();
        }

        function createAvatar(c, size) {
          size = size || 40;
          var initials = getInitials(c.name || 'Character ' + c.id);
          var imageUrl = c.activeImage ? '/api/characters/' + c.id + '/images/' + c.activeImage : '';
          var avatarHtml = '<div class="character-avatar rounded-circle overflow-hidden d-inline-flex align-items-center justify-content-center" ' +
            'style="width:' + size + 'px;height:' + size + 'px;min-width:' + size + 'px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;font-weight:bold;font-size:' + Math.floor(size * 0.4) + 'px;border:2px solid rgba(255,255,255,0.2);vertical-align:middle;">';
          if (imageUrl) {
            avatarHtml += '<img src="' + esc(imageUrl) + '" alt="' + esc(c.name || '') + '" class="w-100 h-100" style="object-fit:cover;" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\';">';
            avatarHtml += '<div class="w-100 h-100 d-none align-items-center justify-content-center" style="display:none!important;">' + initials + '</div>';
          } else {
            avatarHtml += initials;
          }
          avatarHtml += '</div>';
          return avatarHtml;
        }

        function render() {
          var characters = state.characters;
          var selected = state.selected;
          var html = '';
          if (!characters || !characters.length) {
            html = '<div class="text-center text-muted py-4">No characters yet</div>';
          } else {
            html = '<table class="table table-dark table-striped"><thead><tr><th>Avatar</th><th>ID</th><th>Name</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody>';
            for (var i = 0; i < characters.length; i++) {
              var c = characters[i];
              var isSel = (selected === c.id);
              html += '<tr>' +
                '<td>' + createAvatar(c, 40) + '</td>' +
                '<td>' + c.id + '</td>' +
                '<td>' + esc(c.name || '') + '</td>' +
                '<td>' + (isSel ? '<span class="badge bg-success">Current</span>' : '') + '</td>' +
                '<td class="text-end">' +
                '<button class="btn btn-sm btn-outline-secondary me-1" onclick="__chars.select(' + c.id + ')"><i class="bi bi-check2-circle"></i></button>' +
                '<button class="btn btn-sm btn-outline-warning me-1" onclick="__chars.edit(' + c.id + ')"><i class="bi bi-pencil"></i></button>' + '<a class="btn btn-sm btn-outline-info me-1" href="/setup/characters/images?charId=' + c.id + '"><i class="bi bi-image"></i></a>' +
                '<button class="btn btn-sm btn-outline-danger" onclick="__chars.remove(' + c.id + ')"><i class="bi bi-trash"></i></button>' +
                '</td>' +
                '</tr>';
            }
            html += '</tbody></table>';
          }
          document.getElementById('charactersContainer').innerHTML = html;
        }

        function load() {
          var p1 = fetch('/setup/characters/api/current').then(function (r) { return r.json(); }).catch(function () { return { selectedCharacter: null }; });
          var p2 = fetch('/setup/characters/api/characters').then(function (r) { return r.json(); }).catch(function () { return { success: false, characters: [] }; });
          Promise.all([p1, p2]).then(function (arr) {
            var current = arr[0];
            var list = arr[1];
            state.selected = current && typeof current.selectedCharacter !== 'undefined' ? current.selectedCharacter : null;
            state.characters = list && list.success ? list.characters : [];
            render();
          });
        }

        function showAlert(msg, type) {
          var el = document.getElementById('alertBox');
          if (!el) return;
          el.className = 'alert alert-' + (type || 'warning');
          el.textContent = String(msg || '');
          el.classList.remove('d-none');
        }

        function clearAlert() {
          var el = document.getElementById('alertBox');
          if (!el) return;
          el.classList.add('d-none');
          el.textContent = '';
        }

        function create() {
          var name = window.prompt('Character name:');
          if (name === null) return;
          name = String(name).trim();
          if (!name) { showAlert('Name is required', 'warning'); return; }
          clearAlert();
          fetch('/setup/characters/api/characters', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name }) })
            .then(function (r) { if (!r.ok) { showAlert('Failed to create character', 'danger'); } return r; })
            .then(function () { load(); });
        }

        function edit(id) {
          var c = null;
          for (var i = 0; i < state.characters.length; i++) { if (state.characters[i].id === id) { c = state.characters[i]; break; } }
          if (!c) return;
          var name = window.prompt('Edit name:', c.name || '');
          if (name === null) return;
          name = String(name).trim();
          if (!name) { showAlert('Name cannot be empty', 'warning'); return; }
          clearAlert();
          fetch('/setup/characters/api/characters/' + id, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name }) })
            .then(function (r) { if (!r.ok) { showAlert('Failed to update character', 'danger'); } return r; })
            .then(function () { load(); });
        }


        function remove(id) {
          if (!window.confirm('Delete character #' + id + '?')) return;
          fetch('/setup/characters/api/characters/' + id, { method: 'DELETE' })
            .then(function () { load(); });
        }

        function select(id) {
          fetch('/setup/characters/api/select', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body:
              JSON.stringify({ id: id })
          })
            .then(function (r) { return r.json(); })
            .then(function (data) { if (data && data.success) { state.selected = data.selectedCharacter; render(); } });
        }

        window.__chars = { create: create, edit: edit, remove: remove, select: select };

        document.getElementById('createCharBtn').addEventListener('click', create);
        document.addEventListener('DOMContentLoaded', function () { load(); });
      })();
    </script>
    <script src="/js/character-menu.js"></script>

</body>

</html>