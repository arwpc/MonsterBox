<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setup Poses - MonsterBox 4.0</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
    <!-- Navigation (copied from layout for stability) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="bi bi-robot"></i> MonsterBox 4.0</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> Dashboard</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle active" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-gear"></i> Setup
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/setup/parts"><i class="bi bi-cpu"></i> Parts</a></li>
                            <li><a class="dropdown-item" href="/setup/calibration"><i class="bi bi-sliders"></i>
                                    Calibration</a></li>
                            <li><a class="dropdown-item active" href="/setup/poses"><i class="bi bi-person-arms-up"></i>
                                    Poses</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/audio"><i class="bi bi-volume-up"></i> Audio</a>
                            </li>
                            <li><a class="dropdown-item" href="/setup/webcam"><i class="bi bi-camera-video"></i>
                                    Webcam</a></li>
                            <li><a class="dropdown-item" href="/setup/super-powers"><i class="bi bi-lightning"></i>
                                    Super Powers</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/system"><i class="bi bi-pc-display"></i>
                                    System</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/live"><i class="bi bi-play-circle"></i> Live
                            Mode</a></li>
                    <li class="nav-item"><a class="nav-link" href="/scenes"><i class="bi bi-film"></i> Scenes</a></li>
                </ul>
                <%- include('../partials/characterMenu') %>
            </div>
        </div>
    </nav>

    <main class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1><i class="bi bi-person-arms-up"></i> Setup Poses</h1>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createPoseModal">
                        <i class="bi bi-plus-circle"></i> Create Pose
                    </button>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Poses List -->
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-list"></i> Existing Poses
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="poses-list">
                            <div class="text-center">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2">Loading poses...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Templates -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-template"></i> Quick Templates
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="templates-list">
                            <div class="text-center">
                                <div class="spinner-border spinner-border-sm" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2">Loading templates...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Create Pose Modal -->
        <div class="modal fade" id="createPoseModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Create New Pose</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <ul class="nav nav-tabs" id="createPoseTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="template-tab" data-bs-toggle="tab"
                                    data-bs-target="#template-pane" type="button" role="tab">
                                    From Template
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="custom-tab" data-bs-toggle="tab"
                                    data-bs-target="#custom-pane" type="button" role="tab">
                                    Custom Pose
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content mt-3" id="createPoseTabContent">
                            <!-- Template Tab -->
                            <div class="tab-pane fade show active" id="template-pane" role="tabpanel">
                                <form id="templatePoseForm">
                                    <div class="mb-3">
                                        <label for="templateName" class="form-label">Template</label>
                                        <select class="form-select" id="templateName" required>
                                            <option value="">Select a template...</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label for="templateOption" class="form-label">Option</label>
                                        <select class="form-select" id="templateOption" required>
                                            <option value="">Select template first...</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label for="templatePartId" class="form-label">Part</label>
                                        <select class="form-select" id="templatePartId" required>
                                            <option value="">Select a part...</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label for="templateCustomName" class="form-label">Custom Name
                                            (optional)</label>
                                        <input type="text" class="form-control" id="templateCustomName"
                                            placeholder="Leave blank to use default name">
                                    </div>
                                </form>
                            </div>

                            <!-- Custom Tab -->
                            <div class="tab-pane fade" id="custom-pane" role="tabpanel">
                                <form id="customPoseForm">
                                    <div class="mb-3">
                                        <label for="customName" class="form-label">Pose Name</label>
                                        <input type="text" class="form-control" id="customName" required>
                                    </div>
                                    <div class="mb-3">
                                        <label for="customDescription" class="form-label">Description</label>
                                        <textarea class="form-control" id="customDescription" rows="2"></textarea>
                                    </div>
                                    <div class="mb-3">
                                        <label for="customCategory" class="form-label">Category</label>
                                        <input type="text" class="form-control" id="customCategory"
                                            placeholder="e.g., head, elbow, arm">
                                    </div>
                                    <div class="alert alert-info">
                                        <i class="bi bi-info-circle"></i>
                                        Custom pose creation requires advanced configuration. Use templates for quick
                                        setup.
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" id="createPoseBtn">Create Pose</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Test Pose Modal -->
        <div class="modal fade" id="testPoseModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Test Pose</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to test this pose?</p>
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i>
                            Make sure the animatronic is in a safe position before testing.
                        </div>
                        <div id="testPoseInfo"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-warning" id="confirmTestBtn">Test Pose</button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/monsterbox4.js"></script>
    <script src="/js/poses-setup.js"></script>
    <script src="/js/character-menu.js"></script>
</body>

</html>