<div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1><i class="bi bi-person-arms-up"></i> Setup Poses</h1>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createPoseModal" title="Create a new pose">
                            <i class="bi bi-plus-circle"></i> Create Pose
                        </button>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- Poses List -->
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-list"></i> Existing Poses
                            </h5>
                        </div>
                        <div class="card-body">
                            <div id="poses-list">
                                <div class="text-center">
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <p class="mt-2">Loading poses...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Templates -->
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-template"></i> Quick Templates
                            </h5>
                        </div>
                        <div class="card-body">
                            <div id="templates-list">
                                <div class="text-center">
                                    <div class="spinner-border spinner-border-sm" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <p class="mt-2">Loading templates...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Create Pose Modal -->
            <div class="modal fade" id="createPoseModal" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Create New Pose</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" title="Close this dialog"></button>
                        </div>
                        <div class="modal-body">
                            <ul class="nav nav-tabs" id="createPoseTabs" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" id="template-tab" data-bs-toggle="tab"
                                        data-bs-target="#template-pane" type="button" role="tab" title="Create pose from a template">
                                        From Template
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="custom-tab" data-bs-toggle="tab"
                                        data-bs-target="#custom-pane" type="button" role="tab" title="Create a custom pose">
                                        Custom Pose
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content mt-3" id="createPoseTabContent">
                                <!-- Template Tab -->
                                <div class="tab-pane fade show active" id="template-pane" role="tabpanel">
                                    <form id="templatePoseForm">
                                        <div class="mb-3">
                                            <label for="templateName" class="form-label">Template</label>
                                            <select class="form-select" id="templateName" required title="Select a pose template">
                                                <option value="">Select a template...</option>
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label for="templateOption" class="form-label">Option</label>
                                            <select class="form-select" id="templateOption" required title="Select a template option">
                                                <option value="">Select template first...</option>
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label for="templatePartId" class="form-label">Part</label>
                                            <select class="form-select" id="templatePartId" required title="Select a hardware part">
                                                <option value="">Select a part...</option>
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label for="templateCustomName" class="form-label">Custom Name
                                                (optional)</label>
                                            <input type="text" class="form-control" id="templateCustomName"
                                                placeholder="Leave blank to use default name" title="Optional custom name for the pose">
                                        </div>
                                    </form>
                                </div>

                                <!-- Custom Tab -->
                                <div class="tab-pane fade" id="custom-pane" role="tabpanel">
                                    <form id="customPoseForm">
                                        <div class="mb-3">
                                            <label for="customName" class="form-label">Pose Name</label>
                                            <input type="text" class="form-control" id="customName" required title="Name of the pose">
                                        </div>
                                        <div class="mb-3">
                                            <label for="customDescription" class="form-label">Description</label>
                                            <textarea class="form-control" id="customDescription" rows="2" title="Description of the pose"></textarea>
                                        </div>
                                        <div class="mb-3">
                                            <label for="customCategory" class="form-label">Category</label>
                                            <input type="text" class="form-control" id="customCategory"
                                                placeholder="e.g., head, elbow, arm" title="Category for the pose">
                                        </div>
                                        <div class="alert alert-info">
                                            <i class="bi bi-info-circle"></i>
                                            Custom pose creation requires advanced configuration. Use templates for
                                            quick
                                            setup.
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" title="Cancel and close">Cancel</button>
                            <button type="button" class="btn btn-primary" id="createPoseBtn" title="Create the pose">Create Pose</button>
                        </div>
                    </div>
                </div>
    </div>