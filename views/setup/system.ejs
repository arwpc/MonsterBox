  $('#btnDeployKey').addEventListener('click', function () {
    var keyName = $('#deployKeySelect').value;
    var host = $('#deployHost').value;
    if (!keyName || !host) {
      showAlert('sshDeployMessage', 'warning', 'Select a key and enter a host');
      return;
    }
    apiPost('/api/system/ssh/keys/deploy', { keyName: keyName, host: host }, function (err, data) {
      if (err || !data || !data.success) {
        showAlert('sshDeployMessage', 'danger', 'Failed: ' + ((data && data.error) || 'Unknown error'));
      } else {
        showAlert('sshDeployMessage', 'success', 'Key deployed to ' + host);
      }
    });
