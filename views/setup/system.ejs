  function saveTemplate() {
    var name = $('#tplName').value;
    var desc = ($('#tplDesc') && $('#tplDesc').value) || '';
    if (!name) { showAlert('tplMessage', 'warning', 'Name required'); return; }
    apiPost('/api/system/templates', { name: name, description: desc }, function (err, data) {
      if (err || !data || !data.success) {
        showAlert('tplMessage', 'danger', 'Failed: ' + ((data && data.error) || 'Unknown error'));
      } else {
        showAlert('tplMessage', 'success', 'Template saved');
        $('#tplName').value = '';
        $('#tplDesc').value = '';
        loadTemplates();
      }
    });
