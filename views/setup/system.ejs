          '<td>' +
          '<button class="btn btn-sm btn-outline-primary tpl-apply-btn me-1" data-id="' + t.id + '" title="Apply"><i class="bi bi-play-circle"></i></button>' +
          '<button class="btn btn-sm btn-outline-danger tpl-delete-btn" data-id="' + t.id + '" title="Delete"><i class="bi bi-trash"></i></button>' +
          '</td></tr>';
