          apiPost('/api/system/templates/' + id + '/apply', {}, function (err2, res) {
            if (err2 || !res || !res.success) {
              showAlert('systemAlerts', 'danger', 'Failed to apply template');
            } else {
              showAlert('systemAlerts', 'success', 'Template applied');
              loadSettings();
            }
          });
