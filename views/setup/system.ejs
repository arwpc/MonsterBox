<div class="d-flex justify-content-end mb-2 gap-2">
  <button class="btn btn-outline-danger btn-sm" id="btnReboot" title="Reboot System">
    <i class="bi bi-arrow-clockwise"></i> Reboot
  </button>
  <button class="btn btn-outline-danger btn-sm" id="btnShutdown" title="Shutdown System">
    <i class="bi bi-power"></i> Shutdown
  </button>
</div>

<!-- Tab Navigation -->
<ul class="nav nav-tabs mb-3" id="systemTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab">
      <i class="bi bi-speedometer2"></i> Overview
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="performance-tab" data-bs-toggle="tab" data-bs-target="#performance" type="button" role="tab">
      <i class="bi bi-graph-up"></i> Performance
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="logs-tab" data-bs-toggle="tab" data-bs-target="#logs" type="button" role="tab">
      <i class="bi bi-journal-text"></i> Logs
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab">
      <i class="bi bi-gear"></i> Settings
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="ssh-tab" data-bs-toggle="tab" data-bs-target="#ssh" type="button" role="tab">
      <i class="bi bi-key"></i> SSH Keys
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="templates-tab" data-bs-toggle="tab" data-bs-target="#templates" type="button" role="tab">
      <i class="bi bi-clipboard-data"></i> Templates
    </button>
  </li>
</ul>

<!-- Tab Content -->
<div class="tab-content" id="systemTabContent">

  <!-- ══════════════════ Tab 1: Overview ══════════════════ -->
  <div class="tab-pane fade show active" id="overview" role="tabpanel">
    <div class="row g-3">
      <!-- System Info Card -->
      <div class="col-lg-6">
        <div class="card h-100">
          <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-info-circle"></i> System Information</h5></div>
          <div class="card-body">
            <dl class="row mb-0">
              <dt class="col-sm-5">MonsterBox Version</dt>
              <dd class="col-sm-7"><span class="badge bg-primary" id="infoVersion"><%= typeof appVersion !== 'undefined' ? appVersion : 'loading...' %></span></dd>
              <dt class="col-sm-5">Hostname</dt>
              <dd class="col-sm-7" id="infoHostname">Loading...</dd>
              <dt class="col-sm-5">Node.js</dt>
              <dd class="col-sm-7" id="infoNode">Loading...</dd>
              <dt class="col-sm-5">Platform</dt>
              <dd class="col-sm-7" id="infoPlatform">Loading...</dd>
              <dt class="col-sm-5">System Uptime</dt>
              <dd class="col-sm-7" id="infoUptime">Loading...</dd>
              <dt class="col-sm-5">CPU Model</dt>
              <dd class="col-sm-7" id="infoCpuModel">Loading...</dd>
              <dt class="col-sm-5">CPU Cores</dt>
              <dd class="col-sm-7" id="infoCpuCount">Loading...</dd>
            </dl>
          </div>
        </div>
      </div>

      <!-- Theme Gallery -->
      <div class="col-12">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0"><i class="bi bi-palette"></i> Theme Settings</h5>
            <div>
              <span class="badge bg-secondary me-2" id="themePreviewLabel">Previewing: --</span>
              <button type="button" class="btn btn-sm btn-outline-secondary me-1" id="btnResetPreview">
                <i class="bi bi-arrow-counterclockwise"></i> Reset
              </button>
              <button type="button" class="btn btn-sm btn-primary" id="btnApplyTheme">
                <i class="bi bi-check-circle"></i> Apply Theme
              </button>
            </div>
          </div>
          <div class="card-body">
            <div id="themeMessage" class="mb-3"></div>
            <div class="row g-3" id="themeGallery"></div>
          </div>
        </div>
      </div>

      <!-- Live Gauges -->
      <div class="col-12">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0"><i class="bi bi-speedometer"></i> Live Performance</h5>
            <small class="text-muted" id="gaugeTimestamp">--</small>
          </div>
          <div class="card-body">
            <div class="row text-center g-3">
              <div class="col-6 col-md-3">
                <h6>CPU</h6>
                <div class="position-relative d-inline-block" style="width:100px;height:100px;">
                  <canvas id="gaugeCpu" width="100" height="100"></canvas>
                  <span class="position-absolute top-50 start-50 translate-middle fw-bold" id="gaugeCpuText">--%</span>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <h6>Memory</h6>
                <div class="position-relative d-inline-block" style="width:100px;height:100px;">
                  <canvas id="gaugeMem" width="100" height="100"></canvas>
                  <span class="position-absolute top-50 start-50 translate-middle fw-bold" id="gaugeMemText">--%</span>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <h6>Temperature</h6>
                <div class="position-relative d-inline-block" style="width:100px;height:100px;">
                  <canvas id="gaugeTemp" width="100" height="100"></canvas>
                  <span class="position-absolute top-50 start-50 translate-middle fw-bold" id="gaugeTempText">--&deg;C</span>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <h6>Disk</h6>
                <div class="position-relative d-inline-block" style="width:100px;height:100px;">
                  <canvas id="gaugeDisk" width="100" height="100"></canvas>
                  <span class="position-absolute top-50 start-50 translate-middle fw-bold" id="gaugeDiskText">--%</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════ Tab 2: Performance ══════════════════ -->
  <div class="tab-pane fade" id="performance" role="tabpanel">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0"><i class="bi bi-graph-up"></i> Performance History</h5>
        <div class="btn-group btn-group-sm">
          <button class="btn btn-outline-secondary active" data-period="24h">24 Hours</button>
          <button class="btn btn-outline-secondary" data-period="1w">1 Week</button>
          <button class="btn btn-outline-secondary" data-period="1m">1 Month</button>
        </div>
      </div>
      <div class="card-body">
        <div class="mb-3">
          <canvas id="perfChart" height="280" style="width:100%;"></canvas>
        </div>
        <div class="row text-center" id="perfSummary">
          <div class="col-4"><strong>Avg CPU:</strong> <span id="perfAvgCpu">--</span>%</div>
          <div class="col-4"><strong>Avg Memory:</strong> <span id="perfAvgMem">--</span>%</div>
          <div class="col-4"><strong>Avg Temp:</strong> <span id="perfAvgTemp">--</span>&deg;C</div>
        </div>
