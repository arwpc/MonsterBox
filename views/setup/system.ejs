              <option value="mjpg-streamer">mjpg-streamer</option>
              <option value="pigpiod">pigpiod</option>
              <option value="pipewire">pipewire</option>
            </select>
          </div>
          <div class="col-auto">
            <select class="form-select form-select-sm" id="logLines">
              <option value="50">50 lines</option>
              <option value="100" selected>100 lines</option>
              <option value="200">200 lines</option>
              <option value="500">500 lines</option>
            </select>
          </div>
          <div class="col-auto">
            <button class="btn btn-sm btn-primary" id="btnRefreshLogs"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
