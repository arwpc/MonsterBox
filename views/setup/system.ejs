<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><i class="bi bi-pc-display"></i> Setup System</h1>
</div>

<div class="row g-4">
  <!-- Theme Settings Card -->
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-palette"></i> Theme Settings</h5>
      </div>
      <div class="card-body">
        <div class="mb-3">
          <label for="themeSelect" class="form-label">Bootstrap Theme</label>
          <select class="form-select" id="themeSelect">
            <option value="dark" <%=(config?.theme==='dark' || !config?.theme) ? 'selected' : '' %>>Dark Theme</option>
            <option value="light" <%=(config?.theme==='light' ) ? 'selected' : '' %>>Light Theme</option>
          </select>
          <div class="form-text">Select the Bootstrap color scheme for the entire application</div>
        </div>
        <button type="button" class="btn btn-primary" id="saveThemeBtn">
          <i class="bi bi-check-circle"></i> Save Theme
        </button>
        <div id="themeMessage" class="mt-3"></div>
      </div>
    </div>
  </div>

  <!-- System Information Card -->
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-info-circle"></i> System Information</h5>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">MonsterBox Version</dt>
          <dd class="col-sm-8">5.3</dd>

          <dt class="col-sm-4">Node.js Version</dt>
          <dd class="col-sm-8" id="nodeVersion">Loading...</dd>

          <dt class="col-sm-4">Platform</dt>
          <dd class="col-sm-8" id="platform">Loading...</dd>
        </dl>
      </div>
    </div>
  </div>

  <!-- System Control Card -->
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0"><i class="bi bi-power"></i> System Control</h5>
      </div>
      <div class="card-body">
        <div class="alert alert-warning" role="alert">
          <i class="bi bi-exclamation-triangle"></i> <strong>Warning:</strong> Rebooting will temporarily interrupt all
          animatronic operations.
        </div>
        <button type="button" class="btn btn-danger" id="rebootBtn">
          <i class="bi bi-arrow-clockwise"></i> Reboot Animatronic
        </button>
        <div id="rebootMessage" class="mt-3"></div>
      </div>
    </div>
  </div>
</div>

<script>
  // Theme management
  document.getElementById('saveThemeBtn').addEventListener('click', async function () {
    const theme = document.getElementById('themeSelect').value;
    const messageEl = document.getElementById('themeMessage');

    try {
      const response = await fetch('/api/config/theme', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ theme })
      });

      const data = await response.json();

      if (data.success) {
        messageEl.innerHTML = '<div class="alert alert-success"><i class="bi bi-check-circle"></i> Theme saved! Reloading page...</div>';

        // Apply theme immediately
        document.documentElement.setAttribute('data-bs-theme', theme);

        // Reload page after short delay to apply theme across all components
        setTimeout(() => {
          window.location.reload();
        }, 1000);
      } else {
        messageEl.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> Failed to save theme: ' + (data.error || 'Unknown error') + '</div>';
      }
    } catch (error) {
      messageEl.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> Error: ' + error.message + '</div>';
    }
  });

  // Reboot system
  document.getElementById('rebootBtn').addEventListener('click', async function () {
    const messageEl = document.getElementById('rebootMessage');

    if (!confirm('Are you sure you want to reboot this animatronic? This will interrupt all operations.')) {
      return;
    }

    try {
      messageEl.innerHTML = '<div class="alert alert-info"><i class="bi bi-arrow-clockwise"></i> Rebooting system... Please wait 30-60 seconds.</div>';
      this.disabled = true;

      const response = await fetch('/api/system/reboot', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });

      const data = await response.json();

      if (data.success) {
        messageEl.innerHTML = '<div class="alert alert-success"><i class="bi bi-check-circle"></i> Reboot initiated. The system will be unavailable for about a minute.</div>';
      } else {
        messageEl.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> Failed to reboot: ' + (data.error || 'Unknown error') + '</div>';
        this.disabled = false;
      }
    } catch (error) {
      messageEl.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> Error: ' + error.message + '</div>';
      this.disabled = false;
    }
  });

  // Load system information
  async function loadSystemInfo() {
    try {
      const response = await fetch('/api/system/info');
      const data = await response.json();

      if (data.success) {
        document.getElementById('nodeVersion').textContent = data.nodeVersion || 'Unknown';
        document.getElementById('platform').textContent = data.platform || 'Unknown';
      }
    } catch (error) {
      console.error('Failed to load system info:', error);
    }
  }

  loadSystemInfo();
</script>