      var delBtns = $$('.tpl-delete-btn');
      for (var dd = 0; dd < delBtns.length; dd++) {
        delBtns[dd].addEventListener('click', function () {
          var id = this.getAttribute('data-id');
          if (!confirm('Delete this template?')) return;
          apiDelete('/api/system/templates/' + id, function (err2, res) {
            if (err2 || !res || !res.success) {
              showAlert('systemAlerts', 'danger', 'Failed to delete template');
            } else {
              loadTemplates();
            }
          });
        });
      }
    });
