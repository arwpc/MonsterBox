        <div class="row align-items-center g-2">
          <div class="col-auto">
            <select class="form-select form-select-sm" id="logSource">
              <option value="journal" selected>Journal (systemd)</option>
              <option value="console">Console Output (stdout)</option>
              <option value="errors">Error Output (stderr)</option>
