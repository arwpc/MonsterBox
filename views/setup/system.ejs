  $('#btnGenerateKey').addEventListener('click', function () {
    var type = $('#sshKeyType').value;
    var comment = $('#sshKeyComment').value;
    apiPost('/api/system/ssh/keys/generate', { type: type, comment: comment }, function (err, data) {
      if (err || !data || !data.success) {
        showAlert('sshGenMessage', 'danger', 'Failed: ' + ((data && data.error) || 'Unknown error'));
      } else {
        showAlert('sshGenMessage', 'success', 'Key generated: ' + data.name);
        loadSSHKeys();
      }
    });
