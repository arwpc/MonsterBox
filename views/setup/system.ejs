<div id="systemAlerts" class="mt-3"></div>

<script>
(function () {
  'use strict';
  /* ─── Helpers ──────────────────────────────────────────────────────────────── */
  var $ = function (sel) { return document.querySelector(sel); };
  var $$ = function (sel) { return document.querySelectorAll(sel); };

  function showAlert(containerId, type, msg) {
    var el = document.getElementById(containerId);
    if (!el) return;
    el.innerHTML = '<div class="alert alert-' + type + ' alert-dismissible fade show py-2">' + msg +
      '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
  }

  function formatUptime(seconds) {
    var d = Math.floor(seconds / 86400);
    var h = Math.floor((seconds % 86400) / 3600);
    var m = Math.floor((seconds % 3600) / 60);
    if (d > 0) return d + 'd ' + h + 'h ' + m + 'm';
    if (h > 0) return h + 'h ' + m + 'm';
    return m + 'm';
  }

  function apiGet(url, cb) {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', url);
    xhr.setRequestHeader('Accept', 'application/json');
    xhr.onload = function () {
      try { cb(null, JSON.parse(xhr.responseText)); } catch (e) { cb(e); }
    };
    xhr.onerror = function () { cb(new Error('Network error')); };
    xhr.send();
  }

  function apiPost(url, body, cb) {
    var xhr = new XMLHttpRequest();
    xhr.open('POST', url);
    xhr.setRequestHeader('Content-Type', 'application/json');
    xhr.setRequestHeader('Accept', 'application/json');
    xhr.onload = function () {
      try { cb(null, JSON.parse(xhr.responseText)); } catch (e) { cb(e); }
    };
    xhr.onerror = function () { cb(new Error('Network error')); };
    xhr.send(JSON.stringify(body || {}));
  }

  function apiPut(url, body, cb) {
    var xhr = new XMLHttpRequest();
    xhr.open('PUT', url);
    xhr.setRequestHeader('Content-Type', 'application/json');
    xhr.setRequestHeader('Accept', 'application/json');
    xhr.onload = function () {
      try { cb(null, JSON.parse(xhr.responseText)); } catch (e) { cb(e); }
    };
    xhr.onerror = function () { cb(new Error('Network error')); };
    xhr.send(JSON.stringify(body || {}));
  }

  function apiDelete(url, cb) {
    var xhr = new XMLHttpRequest();
    xhr.open('DELETE', url);
    xhr.setRequestHeader('Accept', 'application/json');
    xhr.onload = function () {
      try { cb(null, JSON.parse(xhr.responseText)); } catch (e) { cb(e); }
    };
    xhr.onerror = function () { cb(new Error('Network error')); };
    xhr.send();
  }

  /* ─── Gauge Drawing ────────────────────────────────────────────────────────── */
  function drawGauge(canvasId, percent, color) {
    var canvas = document.getElementById(canvasId);
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var w = canvas.width, h = canvas.height;
    var cx = w / 2, cy = h / 2, r = (Math.min(w, h) / 2) - 8;
    var startAngle = 0.75 * Math.PI;
    var endAngle = 2.25 * Math.PI;
    var pct = Math.max(0, Math.min(100, percent || 0));
    var sweepAngle = startAngle + (pct / 100) * (endAngle - startAngle);

    ctx.clearRect(0, 0, w, h);

    // Background arc
    ctx.beginPath();
    ctx.arc(cx, cy, r, startAngle, endAngle);
    var cs = getComputedStyle(document.documentElement);
    ctx.strokeStyle = cs.getPropertyValue('--bs-border-color').trim() || '#333';
    ctx.lineWidth = 8;
    ctx.lineCap = 'round';
    ctx.stroke();

    // Value arc
    if (pct > 0) {
      ctx.beginPath();
      ctx.arc(cx, cy, r, startAngle, sweepAngle);
      ctx.strokeStyle = color || (cs.getPropertyValue('--bs-primary').trim() || '#0d6efd');
      ctx.lineWidth = 8;
      ctx.lineCap = 'round';
      ctx.stroke();
    }
  }

  function gaugeColor(pct) {
    var cs = getComputedStyle(document.documentElement);
    if (pct >= 90) return cs.getPropertyValue('--bs-danger').trim() || '#dc3545';
    if (pct >= 70) return cs.getPropertyValue('--bs-warning').trim() || '#ffc107';
    return cs.getPropertyValue('--bs-success').trim() || '#198754';
  }

  function tempColor(temp) {
    var cs = getComputedStyle(document.documentElement);
    var t = parseFloat(temp);
    if (t >= 80) return cs.getPropertyValue('--bs-danger').trim() || '#dc3545';
    if (t >= 65) return cs.getPropertyValue('--bs-warning').trim() || '#ffc107';
    return cs.getPropertyValue('--bs-success').trim() || '#198754';
  }

  /* ─── Tab 1: Overview ──────────────────────────────────────────────────────── */
  function loadSystemInfo() {
    apiGet('/api/system/info', function (err, data) {
      if (err || !data || !data.success) return;
      if (data.version) $('#infoVersion').textContent = 'v' + data.version;
      $('#infoHostname').textContent = data.hostname || 'Unknown';
      $('#infoNode').textContent = data.nodeVersion || 'Unknown';
      $('#infoPlatform').textContent = data.platform || 'Unknown';
      $('#infoUptime').textContent = data.systemUptime ? formatUptime(data.systemUptime) : 'Unknown';
      $('#infoCpuModel').textContent = data.cpuModel || 'Unknown';
      $('#infoCpuCount').textContent = data.cpuCount || 'Unknown';
    });
  }

  function refreshGauges() {
    apiGet('/api/system/performance', function (err, data) {
      if (err || !data || !data.success) return;
      var p = data.performance;

      drawGauge('gaugeCpu', p.cpu, gaugeColor(p.cpu));
      $('#gaugeCpuText').textContent = p.cpu + '%';

      drawGauge('gaugeMem', p.memory, gaugeColor(p.memory));
      $('#gaugeMemText').textContent = p.memory + '%';

      var temp = p.temperature ? parseFloat(p.temperature) : 0;
      var tempPct = Math.min(100, (temp / 85) * 100);
      drawGauge('gaugeTemp', tempPct, tempColor(temp));
      $('#gaugeTempText').innerHTML = (p.temperature || '--') + '&deg;C';

      var disk = p.disk || 0;
      drawGauge('gaugeDisk', disk, gaugeColor(disk));
      $('#gaugeDiskText').textContent = disk + '%';

      var now = new Date();
      $('#gaugeTimestamp').textContent = 'Updated: ' + now.toLocaleTimeString();
    });
  }

  var gaugeInterval = null;
  function startGaugeRefresh() {
    refreshGauges();
    gaugeInterval = setInterval(refreshGauges, 5000);
  }
  function stopGaugeRefresh() {
    if (gaugeInterval) { clearInterval(gaugeInterval); gaugeInterval = null; }
  }

  /* ─── Tab 2: Performance History ───────────────────────────────────────────── */
  var currentPeriod = '24h';

  function drawPerfChart(data) {
    var canvas = document.getElementById('perfChart');
    if (!canvas || !data || data.length === 0) {
      if (canvas) {
        var ctx2 = canvas.getContext('2d');
        ctx2.clearRect(0, 0, canvas.width, canvas.height);
        ctx2.fillStyle = '#666';
        ctx2.font = '14px sans-serif';
        ctx2.textAlign = 'center';
        ctx2.fillText('No performance data available for this period.', canvas.width / 2, canvas.height / 2);
      }
      return;
    }

    var ctx = canvas.getContext('2d');
    var W = canvas.width = canvas.offsetWidth;
    var H = canvas.height = 280;
    var pad = { top: 20, right: 20, bottom: 30, left: 40 };
    var chartW = W - pad.left - pad.right;
    var chartH = H - pad.top - pad.bottom;

    ctx.clearRect(0, 0, W, H);

    // Read theme colors
    var cs = getComputedStyle(document.documentElement);
    var gridColor = cs.getPropertyValue('--bs-border-color').trim() || '#333';
    var textColor = cs.getPropertyValue('--bs-secondary-color').trim() || '#999';
    var primaryC = cs.getPropertyValue('--bs-primary').trim() || '#0d6efd';
    var successC = cs.getPropertyValue('--bs-success').trim() || '#198754';
    var dangerC = cs.getPropertyValue('--bs-danger').trim() || '#dc3545';

    // Grid
    ctx.strokeStyle = gridColor;
    ctx.lineWidth = 0.5;
    for (var g = 0; g <= 4; g++) {
      var gy = pad.top + (chartH / 4) * g;
      ctx.beginPath();
      ctx.moveTo(pad.left, gy);
      ctx.lineTo(W - pad.right, gy);
      ctx.stroke();
      ctx.fillStyle = textColor;
      ctx.font = '10px sans-serif';
      ctx.textAlign = 'right';
      ctx.fillText((100 - g * 25) + '%', pad.left - 5, gy + 4);
    }

    function drawLine(arr, color) {
      if (!arr || arr.length < 2) return;
      ctx.beginPath();
      ctx.strokeStyle = color;
      ctx.lineWidth = 2;
      for (var i = 0; i < arr.length; i++) {
        var x = pad.left + (i / (arr.length - 1)) * chartW;
        var y = pad.top + (1 - arr[i] / 100) * chartH;
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      }
      ctx.stroke();
    }

    var cpuArr = [], memArr = [], tempArr = [];
    for (var j = 0; j < data.length; j++) {
      cpuArr.push(data[j].cpu || 0);
      memArr.push(data[j].memory || 0);
      var t = data[j].temperature ? (parseFloat(data[j].temperature) / 85) * 100 : 0;
      tempArr.push(Math.min(100, t));
    }

    drawLine(cpuArr, primaryC);
    drawLine(memArr, successC);
    drawLine(tempArr, dangerC);

    // Legend
    var legendItems = [
      { color: primaryC, label: 'CPU' },
      { color: successC, label: 'Memory' },
      { color: dangerC, label: 'Temperature' }
    ];
    var lx = pad.left + 10;
    for (var li = 0; li < legendItems.length; li++) {
      ctx.fillStyle = legendItems[li].color;
      ctx.fillRect(lx, pad.top + 5, 12, 3);
      ctx.fillStyle = textColor;
      ctx.font = '11px sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText(legendItems[li].label, lx + 16, pad.top + 10);
      lx += 80;
    }

    // Summary
    var sumCpu = 0, sumMem = 0, sumTemp = 0, tempCount = 0;
    for (var s = 0; s < data.length; s++) {
      sumCpu += data[s].cpu || 0;
      sumMem += data[s].memory || 0;
      if (data[s].temperature) { sumTemp += parseFloat(data[s].temperature); tempCount++; }
    }
    $('#perfAvgCpu').textContent = data.length ? (sumCpu / data.length).toFixed(1) : '--';
    $('#perfAvgMem').textContent = data.length ? (sumMem / data.length).toFixed(1) : '--';
    $('#perfAvgTemp').textContent = tempCount ? (sumTemp / tempCount).toFixed(1) : '--';
  }

  function loadPerfHistory(period) {
    currentPeriod = period || currentPeriod;
    apiGet('/api/system/performance/history?period=' + currentPeriod, function (err, data) {
      if (err || !data || !data.success) { drawPerfChart([]); return; }
      drawPerfChart(data.data || []);
    });
  }

  // Period buttons
  var periodBtns = $$('#performance .btn-group .btn');
  for (var pi = 0; pi < periodBtns.length; pi++) {
    periodBtns[pi].addEventListener('click', function () {
      for (var b = 0; b < periodBtns.length; b++) periodBtns[b].classList.remove('active');
      this.classList.add('active');
      loadPerfHistory(this.getAttribute('data-period'));
    });
  }

  /* ─── Tab 3: Logs ──────────────────────────────────────────────────────────── */
  var logAutoTimer = null;

  function loadLogs() {
    var source = $('#logSource').value;
    var lines = $('#logLines').value;

    if (source === 'console' || source === 'errors') {
      var src = (source === 'errors') ? 'stderr' : 'stdout';
      $('#logService').disabled = true;
      apiGet('/api/system/console?lines=' + lines + '&source=' + src, function (err, data) {
        if (err || !data) { $('#logOutput').textContent = 'Error loading console output'; return; }
        $('#logOutput').textContent = data.output || 'No output available';
        var el = $('#logOutput');
        el.scrollTop = el.scrollHeight;
      });
    } else {
      $('#logService').disabled = false;
      var service = $('#logService').value;
      apiGet('/api/system/logs?service=' + encodeURIComponent(service) + '&lines=' + lines, function (err, data) {
        if (err || !data) { $('#logOutput').textContent = 'Error loading logs'; return; }
        $('#logOutput').textContent = data.logs || 'No logs available';
        var el = $('#logOutput');
        el.scrollTop = el.scrollHeight;
      });
    }
  }

  $('#btnRefreshLogs').addEventListener('click', loadLogs);
  $('#logSource').addEventListener('change', loadLogs);
  $('#logService').addEventListener('change', loadLogs);
  $('#logLines').addEventListener('change', loadLogs);
  $('#logAutoRefresh').addEventListener('change', function () {
    if (this.checked) {
      loadLogs();
      logAutoTimer = setInterval(loadLogs, 5000);
    } else {
      if (logAutoTimer) { clearInterval(logAutoTimer); logAutoTimer = null; }
    }
  });

  /* ─── Tab 4: Settings ──────────────────────────────────────────────────────── */
  function loadSettings() {
    apiGet('/api/system/settings', function (err, data) {
      if (err || !data || !data.success) return;
      var s = data.settings;

      // CPU Governor
      var govSelect = $('#cpuGovernor');
      govSelect.innerHTML = '';
      var avail = (s.cpu && s.cpu.availableGovernors) || [];
      for (var i = 0; i < avail.length; i++) {
        var opt = document.createElement('option');
        opt.value = avail[i];
        opt.textContent = avail[i];
        if (s.cpu && avail[i] === s.cpu.governor) opt.selected = true;
        govSelect.appendChild(opt);
      }
      if (avail.length === 0) {
        govSelect.innerHTML = '<option>N/A</option>';
      }
      $('#cpuGovernorCurrent').value = (s.cpu && s.cpu.governor) || 'unknown';

      // GPU
      $('#gpuMemory').textContent = (s.gpu && s.gpu.memory) || 'N/A';

      // Swap
      $('#swapTotal').textContent = (s.memory && s.memory.swapTotalMB) ? s.memory.swapTotalMB + ' MB' : 'N/A';
      $('#swapUsed').textContent = (s.memory && s.memory.swapUsedMB != null) ? s.memory.swapUsedMB + ' MB' : 'N/A';
    });

    // Startup tasks
    apiGet('/api/system/settings/startup', function (err, data) {
      if (err || !data || !data.success) return;
      var tasks = data.tasks || [];
      var html = '';
      for (var i = 0; i < tasks.length; i++) {
        html += '<div class="form-check form-switch mb-2">' +
          '<input class="form-check-input startup-toggle" type="checkbox" data-service="' + tasks[i].service + '"' +
          (tasks[i].enabled ? ' checked' : '') + '>' +
          '<label class="form-check-label">' + tasks[i].service + '</label></div>';
      }
      $('#startupTasksList').innerHTML = html || '<p class="text-muted">No startup tasks found</p>';

      // Bind toggle handlers
      var toggles = $$('.startup-toggle');
      for (var t = 0; t < toggles.length; t++) {
        toggles[t].addEventListener('change', function () {
          var svc = this.getAttribute('data-service');
          var en = this.checked;
          apiPut('/api/system/settings/startup', { service: svc, enabled: en }, function (err2, res) {
            if (err2 || !res || !res.success) {
              showAlert('systemAlerts', 'danger', 'Failed to update startup task');
            }
          });
        });
      }
    });
  }

  $('#btnSaveCpuGovernor').addEventListener('click', function () {
    var gov = $('#cpuGovernor').value;
    apiPut('/api/system/settings', { category: 'cpu', key: 'governor', value: gov }, function (err, data) {
      if (err || !data || !data.success) {
        showAlert('cpuMessage', 'danger', 'Failed: ' + ((data && data.error) || 'Unknown error'));
      } else {
        showAlert('cpuMessage', 'success', 'CPU governor set to ' + gov);
        $('#cpuGovernorCurrent').value = gov;
      }
    });
  });

  /* ─── Performance Presets ──────────────────────────────────────────────────── */
  function loadPresets() {
    apiGet('/api/system/presets', function (err, data) {
      if (err || !data || !data.success) return;
      var presets = data.presets || {};
      var html = '';
      var keys = Object.keys(presets);
      for (var i = 0; i < keys.length; i++) {
        var id = keys[i];
        var p = presets[id];
        var s = p.settings || {};
        html += '<div class="col-md-6 col-lg-4">' +
          '<div class="card h-100">' +
          '<div class="card-body p-2">' +
          '<h6 class="card-title mb-1">' + p.label + '</h6>' +
          '<p class="card-text small text-muted mb-2">' + p.description + '</p>' +
          '<ul class="list-unstyled small mb-2">' +
          '<li>Governor: <strong>' + s.governor + '</strong></li>' +
          '<li>GPU Mem: <strong>' + s.gpu_mem + ' MB</strong></li>' +
          '<li>ARM Freq: <strong>' + s.arm_freq + ' MHz</strong></li>' +
          '<li>I2C: <strong>' + (s.i2c_baudrate / 1000) + ' kHz</strong></li>' +
          '</ul>' +
          '<button class="btn btn-sm btn-outline-primary w-100 preset-apply-btn" data-preset="' + id + '">Apply</button>' +
          '</div></div></div>';
      }
      $('#presetsList').innerHTML = html || '<p class="text-muted">No presets available</p>';

      var btns = $$('.preset-apply-btn');
      for (var b = 0; b < btns.length; b++) {
        btns[b].addEventListener('click', function () {
          var presetId = this.getAttribute('data-preset');
          var btn = this;
          btn.disabled = true;
          btn.textContent = 'Applying...';
          apiPost('/api/system/presets/apply', { presetId: presetId }, function (err2, res) {
            btn.disabled = false;
            btn.textContent = 'Apply';
            if (err2 || !res || !res.success) {
              showAlert('presetMessage', 'danger', 'Failed: ' + ((res && res.error) || 'Unknown error'));
              return;
            }
            var msgs = [];
            var results = res.results || [];
            for (var r = 0; r < results.length; r++) {
              if (results[r].key === 'governor' && results[r].success) {
                msgs.push('CPU governor set to <strong>' + results[r].value + '</strong>');
              } else if (results[r].key === 'boot_config') {
                msgs.push('<span class="text-warning">' + results[r].message + '</span>');
              } else if (!results[r].success) {
                msgs.push('<span class="text-danger">' + results[r].key + ': ' + results[r].error + '</span>');
              }
            }
            showAlert('presetMessage', 'info', 'Preset <strong>' + (res.label || presetId) + '</strong> applied.<br>' + msgs.join('<br>'));
            loadSettings();
          });
        });
      }
    });
  }

  /* ─── Tab 5: SSH Keys ──────────────────────────────────────────────────────── */
  function loadSSHKeys() {
    apiGet('/api/system/ssh/keys', function (err, data) {
      if (err || !data || !data.success) return;
      var keys = data.keys || [];
      var tbody = $('#sshKeysBody');
      var deploySelect = $('#deployKeySelect');

      if (keys.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="text-muted">No SSH keys found</td></tr>';
        deploySelect.innerHTML = '<option>-- no keys --</option>';
        return;
      }

      var html = '';
      var dhtml = '<option value="">-- select key --</option>';
      for (var i = 0; i < keys.length; i++) {
        var k = keys[i];
        var created = k.created ? new Date(k.created).toLocaleDateString() : '--';
        html += '<tr><td>' + k.name + '</td><td><code class="small">' +
          (k.fingerprint || '--').substring(0, 47) + '</code></td><td>' + created + '</td>' +
          '<td><button class="btn btn-sm btn-outline-danger ssh-delete-btn" data-name="' + k.name + '"><i class="bi bi-trash"></i></button></td></tr>';
        dhtml += '<option value="' + k.name + '">' + k.name + '</option>';
      }
      tbody.innerHTML = html;
      deploySelect.innerHTML = dhtml;

      // Bind delete buttons
      var delBtns = $$('.ssh-delete-btn');
      for (var d = 0; d < delBtns.length; d++) {
        delBtns[d].addEventListener('click', function () {
          var name = this.getAttribute('data-name');
          if (!confirm('Delete SSH key "' + name + '"?')) return;
          apiDelete('/api/system/ssh/keys/' + encodeURIComponent(name), function (err2, res) {
            if (err2 || !res || !res.success) {
              showAlert('systemAlerts', 'danger', 'Failed to delete key');
            } else {
              loadSSHKeys();
            }
          });
        });
      }
    });
