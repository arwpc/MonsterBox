<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setup Parts - MonsterBox 4.0</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/monsterbox4.css" rel="stylesheet">

</head>

<body>
    <!-- Navigation (standalone, same structure as other pages) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="bi bi-robot"></i> MonsterBox 4.0</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> Dashboard</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle active" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-gear"></i> Setup
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item active" href="/setup/parts"><i class="bi bi-cpu"></i> Parts</a>
                            </li>
                            <li><a class="dropdown-item" href="/setup/calibration"><i class="bi bi-sliders"></i>
                                    Calibration</a></li>
                            <li><a class="dropdown-item" href="/setup/poses"><i class="bi bi-person-arms-up"></i>
                                    Poses</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/audio"><i class="bi bi-volume-up"></i> Audio</a>
                            </li>
                            <li><a class="dropdown-item" href="/setup/webcam"><i class="bi bi-camera-video"></i>
                                    Webcam</a></li>
                            <li><a class="dropdown-item" href="/setup/super-powers"><i class="bi bi-lightning"></i>
                                    Super Powers</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/system"><i class="bi bi-pc-display"></i>
                                    System</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/live"><i class="bi bi-play-circle"></i> Live
                            Mode</a></li>
                    <li class="nav-item"><a class="nav-link" href="/scenes"><i class="bi bi-film"></i> Scenes</a></li>
                </ul>
                <%- include('../partials/characterMenu') %>
            </div>
        </div>
    </nav>

    <main class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1><i class="bi bi-cpu"></i> Setup Parts</h1>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createPartModal">
                        <i class="bi bi-plus-circle"></i> Add Part
                    </button>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Parts List -->
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-list"></i> Hardware Parts
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="parts-list">
                            <div class="text-center">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2">Loading parts...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Part Types -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-gear"></i> Part Types
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-arrow-repeat"></i> Servo</span>
                                <span class="badge bg-primary rounded-pill" id="servo-count">0</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-gear-wide"></i> Motor</span>
                                <span class="badge bg-primary rounded-pill" id="motor-count">0</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-lightbulb"></i> Light</span>
                                <span class="badge bg-primary rounded-pill" id="light-count">0</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-mic"></i> Microphone</span>
                                <span class="badge bg-primary rounded-pill" id="microphone-count">0</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-speaker"></i> Speaker</span>
                                <span class="badge bg-primary rounded-pill" id="speaker-count">0</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-camera-video"></i> Webcam</span>
                                <span class="badge bg-primary rounded-pill" id="webcam-count">0</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Create Part Modal -->
        <div class="modal fade" id="createPartModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Add Hardware Part</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <form id="createPartForm">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="partName" class="form-label">Part Name</label>
                                        <input type="text" class="form-control" id="partName" name="name" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="partType" class="form-label">Part Type</label>
                                        <select class="form-select" id="partType" name="type"
                                            onchange="onPartTypeChange()" required>
                                            <!-- Options populated by JavaScript -->
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6" id="modelGroup" style="display:none;">
                                    <div class="mb-3">
                                        <label for="modelSelect" class="form-label">Model</label>
                                        <select class="form-select" id="modelSelect">
                                            <option value="">Select Model (optional)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Webcam device assignment (shown for Webcam type) -->
                            <div class="row" id="webcamGroup" style="display:none;">
                                <div class="col-md-8">
                                    <div class="mb-3">
                                        <label for="webcamDeviceSelect" class="form-label">Webcam Device</label>
                                        <select class="form-select" id="webcamDeviceSelect">
                                            <option value="">Select a detected webcam...</option>
                                        </select>
                                        <div class="form-text">Assign a /dev/video device to this Webcam part.</div>
                                    </div>
                                </div>
                                <div class="col-md-4 d-flex align-items-end">
                                    <button type="button" class="btn btn-outline-secondary w-100" id="scanWebcamsBtn"
                                        onclick="scanWebcamsInto('webcamDeviceSelect','webcamScanResults')">Scan
                                        Devices</button>
                                </div>
                                <div class="col-12">
                                    <div id="webcamScanResults" class="small text-muted"></div>
                                </div>
                            </div>

                            <!-- Speaker config (shown for Speaker type) -->
                            <!-- Microphone config (shown for Microphone type) -->
                            <div class="row" id="microphoneGroup" style="display:none;">
                                <div class="col-md-8">
                                    <div class="mb-3">
                                        <label for="audioInputSelect" class="form-label">Audio Input</label>
                                        <select class="form-select" id="audioInputSelect">
                                            <option value="">Select an audio input...</option>
                                        </select>
                                        <div class="form-text">Select an ALSA input device for this Microphone.</div>
                                    </div>
                                </div>
                                <div class="col-md-4 d-flex align-items-end">
                                    <button type="button" class="btn btn-outline-secondary w-100"
                                        id="scanAudioInputsBtn"
                                        onclick="(function(){var sel=document.getElementById('audioInputSelect');var out=document.getElementById('audioInputScanResults'); if(out) out.textContent='Scanning inputs...'; fetch('/setup/audio/api/inputs').then(function(r){return r.json();}).then(function(j){ if(!sel) return; sel.innerHTML='<option value=\"
                                        \">Select an audio input...</option>'; var list=(j&&j.inputs)||[];
                                        list.forEach(function(it){ var opt=document.createElement('option');
                                        opt.value=it.id||''; opt.textContent=it.description||it.name||it.id;
                                        sel.appendChild(opt); }); if(out) out.textContent = !list.length ? 'No inputs
                                        found' : list.map(function(it){return '\ud83c\udfa4
                                        '+(it.description||(it.name+' ('+it.id+')'));}).join('\\n');
                                        }).catch(function(){ if(out) out.textContent='Error scanning inputs'; });
                                        })()">Scan
                                        Inputs</button>
                                    <script>
                                        (function () {
                                            // Define scanner early so other handlers can call it
                                            if (typeof window.scanAudioInputsInto !== 'function') {
                                                window.scanAudioInputsInto = function (selectId, resultsId) {
                                                    var sel = document.getElementById(selectId);
                                                    var out = document.getElementById(resultsId);
                                                    if (out) out.textContent = 'Scanning inputs...';
                                                    fetch('/setup/audio/api/inputs')
                                                        .then(function (r) { return r.json(); })
                                                        .then(function (j) {
                                                            if (!sel) return;
                                                            sel.innerHTML = '<option value="">Select an audio input...</option>';
                                                            var list = (j && j.inputs) || [];
                                                            list.forEach(function (it) {
                                                                var opt = document.createElement('option');
                                                                opt.value = it.id || '';
                                                                opt.textContent = it.description || it.name || it.id;
                                                                sel.appendChild(opt);
                                                            });
                                                            if (out) out.textContent = !list.length ? 'No inputs found' : list.map(function (it) { return '🎤 ' + (it.description || (it.name + ' (' + it.id + ')')); }).join('\n');
                                                        })
                                                        .catch(function () { if (out) out.textContent = 'Error scanning inputs'; });
                                                };
                                            }
                                            var btn = document.getElementById('scanAudioInputsBtn');
                                            if (btn) {
                                                try { btn.removeAttribute('onclick'); } catch (e) { }
                                                btn.onclick = function () { scanAudioInputsInto('audioInputSelect', 'audioInputScanResults'); };
                                            }
                                        })();
                                    </script>
                                </div>
                                <div class="col-12">
                                    <div id="audioInputScanResults" class="small text-muted"></div>
                                </div>
                                <div class="col-12">
                                    <button type="button" class="btn btn-sm btn-info"
                                        onclick="(function(){var sel=document.getElementById('audioInputSelect'); if(!sel||!sel.value){alert('Select an input first');return;} var out=document.getElementById('audioInputScanResults'); if(out) out.textContent='Measuring level...'; fetch('/setup/audio/api/input-level?device='+encodeURIComponent(sel.value)).then(function(r){return r.json();}).then(function(j){ if(out) out.textContent = j && j.success ? ('Level: '+ (j.level!=null?j.level.toFixed?j.level.toFixed(4):j.level:j.level)) : ('Error: '+ (j && j.error)); }).catch(function(){ if(out) out.textContent='Error measuring level'; }); })()">Quick
                                        Level Test</button>
                                </div>
                            </div>

                            <div class="row" id="speakerGroup" style="display:none;">
                                <div class="col-md-8">
                                    <div class="mb-3">
                                        <label for="audioDeviceSelect" class="form-label">Audio Output</label>
                                        <select class="form-select" id="audioDeviceSelect">
                                            <option value="">Select an audio output...</option>
                                        </select>
                                        <div class="form-text">Route this Speaker to a specific ALSA output.</div>
                                    </div>
                                </div>
                                <div class="col-md-4 d-flex align-items-end">
                                    <button type="button" class="btn btn-outline-secondary w-100" id="scanAudioBtn"
                                        onclick="scanAudioOutputsInto('audioDeviceSelect','audioScanResults')">Scan
                                        Outputs</button>
                                </div>
                                <div class="col-12">
                                    <div id="audioScanResults" class="small text-muted"></div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label for="speakerVolume" class="form-label">Volume (0-100)</label>
                                        <input type="number" class="form-control" id="speakerVolume" min="0" max="100"
                                            value="50">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label for="speakerBass" class="form-label">Bass (dB)</label>
                                        <input type="number" class="form-control" id="speakerBass" min="-10" max="10"
                                            value="0">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label for="speakerTreble" class="form-label">Treble (dB)</label>
                                        <input type="number" class="form-control" id="speakerTreble" min="-10" max="10"
                                            value="0">
                                    </div>
                                </div>
                            </div>


                            <!-- GPIO Pin (shown for parts that require pins) -->
                            <div class="row" id="pinGroup" style="display: none;">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="gpioPin" class="form-label">GPIO Pin</label>
                                        <input type="number" class="form-control" id="gpioPin" name="pin" min="1"
                                            max="40">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="partDescription" class="form-label">Description</label>
                                        <input type="text" class="form-control" id="partDescription" name="description">
                                    </div>
                                </div>
                            </div>

                            <!-- Linear Actuator specific pins -->
                            <div class="row" id="actuatorPinGroup" style="display: none;">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="directionPin" class="form-label">Direction Pin</label>
                                        <input type="number" class="form-control" id="directionPin" name="directionPin"
                                            min="1" max="40" value="18">
                                        <div class="form-text">GPIO pin for direction control</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="pwmPin" class="form-label">PWM Pin</label>
                                        <input type="number" class="form-control" id="pwmPin" name="pwmPin" min="1"
                                            max="40" value="13">
                                        <div class="form-text">GPIO pin for PWM speed control (12,13,18,19 recommended)
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Linear Actuator safety limits -->
                            <div class="row" id="actuatorLimitsGroup" style="display: none;">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="maxExtension" class="form-label">Max Extension (ms)</label>
                                        <input type="number" class="form-control" id="maxExtension" name="maxExtension"
                                            min="1000" max="30000" value="15000">
                                        <div class="form-text">Maximum extension time to prevent damage</div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="maxRetraction" class="form-label">Max Retraction (ms)</label>
                                        <input type="number" class="form-control" id="maxRetraction"
                                            name="maxRetraction" min="1000" max="30000" value="15000">
                                        <div class="form-text">Maximum retraction time to prevent damage</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Servo-specific options -->
                            <div id="servoGroup" style="display: none;">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="servoType" class="form-label">Servo Type</label>
                                            <select class="form-select" id="servoType" name="servoType">
                                                <!-- Options populated by JavaScript -->
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="controllerType" class="form-label">Controller Type</label>
                                            <select class="form-select" id="controllerType" name="controllerType"
                                                onchange="onControllerTypeChange()">
                                                <option value="gpio">Direct GPIO PWM</option>
                                                <option value="pca9685">PCA9685 PWM Driver</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- PCA9685 Configuration -->
                            <div id="pca9685Group" style="display: none;">
                                <div class="card border-primary mb-3">
                                    <div class="card-header bg-primary text-white">
                                        <i class="bi bi-cpu"></i> PCA9685 Configuration
                                    </div>
                                    <div class="card-body">
                                        <div class="row mb-3">
                                            <div class="col-md-6">
                                                <label for="pca9685Address" class="form-label">I2C Address</label>
                                                <input type="text" class="form-control" id="pca9685Address"
                                                    name="pca9685Address" value="0x40" pattern="0x[0-9A-Fa-f]{2}">
                                                <div class="form-text">Default: 0x40</div>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="pca9685Frequency" class="form-label">PWM Frequency
                                                    (Hz)</label>
                                                <input type="number" class="form-control" id="pca9685Frequency"
                                                    name="pca9685Frequency" value="50" min="40" max="1000">
                                                <div class="form-text">Servo standard: 50Hz</div>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Select PCA9685 Channel</label>
                                            <div id="pca9685Channels">
                                                <!-- PCA9685 channel layout populated by JavaScript -->
                                            </div>
                                            <input type="hidden" id="pca9685Channel" name="pca9685Channel">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Description for non-pin parts -->
                            <div class="row" id="descriptionGroup">
                                <div class="col-12">
                                    <div class="mb-3">
                                        <label for="partDescriptionAlt" class="form-label">Description</label>
                                        <input type="text" class="form-control" id="partDescriptionAlt"
                                            name="description">
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" onclick="createPart()">Add Part</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- Edit Part Modal -->
        <div class="modal fade" id="editPartModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Hardware Part</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="editPartId" />
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editPartName" class="form-label">Part Name</label>
                                    <input type="text" class="form-control" id="editPartName" required>
                                </div>
                                <!-- Edit Microphone config -->
                                <div class="row" id="editMicrophoneGroup" style="display:none;">
                                    <div class="col-md-8">
                                        <div class="mb-3">
                                            <label for="editAudioInputSelect" class="form-label">Audio Input</label>
                                            <select class="form-select" id="editAudioInputSelect">
                                                <option value="">Select an audio input...</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4 d-flex align-items-end">
                                        <button type="button" class="btn btn-outline-secondary w-100"
                                            id="editScanAudioInputsBtn"
                                            onclick="scanAudioInputsInto('editAudioInputSelect','editAudioInputScanResults')">Scan
                                            Inputs</button>
                                    </div>
                                    <div class="col-12">
                                        <div id="editAudioInputScanResults" class="small text-muted"></div>
                                    </div>
                                </div>

                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">

                                    <!-- Edit Speaker config -->
                                    <div class="row" id="editSpeakerGroup" style="display:none;">
                                        <div class="col-md-8">
                                            <div class="mb-3">
                                                <label for="editAudioDeviceSelect" class="form-label">Audio
                                                    Output</label>
                                                <select class="form-select" id="editAudioDeviceSelect">
                                                    <option value="">Select an audio output...</option>
                                                </select>
                                                <div class="form-text">Route this Speaker to a specific ALSA output.
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4 d-flex align-items-end">
                                            <button type="button" class="btn btn-outline-secondary w-100"
                                                id="editScanAudioBtn"
                                                onclick="scanAudioOutputsInto('editAudioDeviceSelect','editAudioScanResults')">Scan
                                                Outputs</button>
                                        </div>
                                        <div class="col-12">
                                            <div id="editAudioScanResults" class="small text-muted"></div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label for="editSpeakerVolume" class="form-label">Volume (0-100)</label>
                                                <input type="number" class="form-control" id="editSpeakerVolume" min="0"
                                                    max="100" value="50">
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label for="editSpeakerBass" class="form-label">Bass (dB)</label>
                                                <input type="number" class="form-control" id="editSpeakerBass" min="-10"
                                                    max="10" value="0">
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label for="editSpeakerTreble" class="form-label">Treble (dB)</label>
                                                <input type="number" class="form-control" id="editSpeakerTreble"
                                                    min="-10" max="10" value="0">
                                            </div>
                                        </div>
                                    </div>

                                    <label for="editPartType" class="form-label">Part Type</label>
                                    <select class="form-select" id="editPartType" disabled>
                                        <option value="">Select…</option>

                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row" id="editPinGroup" style="display: none;">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editGpioPin" class="form-label">GPIO Pin</label>
                                    <input type="number" class="form-control" id="editGpioPin" min="1" max="40">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editPartDescription" class="form-label">Description</label>
                                    <input type="text" class="form-control" id="editPartDescription">
                                </div>
                            </div>
                        </div>
                        <!-- Edit Webcam device assignment -->
                        <div class="row" id="editWebcamGroup" style="display:none;">
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label for="editWebcamDeviceSelect" class="form-label">Webcam Device</label>
                                    <select class="form-select" id="editWebcamDeviceSelect">
                                        <option value="">Select a detected webcam...</option>
                                    </select>
                                    <div class="form-text">Assign a /dev/video device to this Webcam part.</div>
                                </div>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <button type="button" class="btn btn-outline-secondary w-100" id="editScanWebcamsBtn"
                                    onclick="scanWebcamsInto('editWebcamDeviceSelect','editWebcamScanResults')">Scan
                                    Devices</button>
                            </div>
                            <div class="col-12">
                                <div id="editWebcamScanResults" class="small text-muted"></div>
                            </div>
                        </div>


                        <!-- Edit Servo-specific options -->
                        <div id="editServoGroup" style="display: none;">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="editServoType" class="form-label">Servo Type</label>
                                        <select class="form-select" id="editServoType">
                                            <!-- Options populated by JavaScript -->
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="editControllerType" class="form-label">Controller Type</label>
                                        <select class="form-select" id="editControllerType"
                                            onchange="onEditControllerTypeChange()">
                                            <option value="gpio">Direct GPIO PWM</option>
                                            <option value="pca9685">PCA9685 PWM Driver</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <!-- Invert Direction toggle for servos -->
                            <div class="row">
                                <div class="col-12">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" id="editInvertDirection">
                                        <label class="form-check-label" for="editInvertDirection">
                                            Invert Direction (swap CW/CCW)
                                        </label>
                                    </div>
                                </div>
                            </div>


                            <!-- Edit Model Selection -->
                            <div id="editModelGroup" style="display: none;">
                                <div class="row">
                                    <div class="col-12">
                                        <div class="mb-3">
                                            <label for="editModelSelect" class="form-label">Model</label>
                                            <select class="form-select" id="editModelSelect">
                                                <option value="">Select Model...</option>
                                                <!-- Options populated by JavaScript -->
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Edit PCA9685 Configuration -->
                        <div id="editPca9685Group" style="display: none;">
                            <div class="card border-primary mb-3">
                                <div class="card-header bg-primary text-white">
                                    <i class="bi bi-cpu"></i> PCA9685 Configuration
                                </div>
                                <div class="card-body">
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label for="editPca9685Address" class="form-label">I2C Address</label>
                                            <input type="text" class="form-control" id="editPca9685Address" value="0x40"
                                                pattern="0x[0-9A-Fa-f]{2}">
                                            <div class="form-text">Default: 0x40</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label for="editPca9685Frequency" class="form-label">PWM Frequency
                                                (Hz)</label>
                                            <input type="number" class="form-control" id="editPca9685Frequency"
                                                value="50" min="40" max="1000">
                                            <div class="form-text">Servo standard: 50Hz</div>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Select PCA9685 Channel</label>
                                        <div id="editPca9685Channels">
                                            <!-- Channels populated by JavaScript -->
                                        </div>
                                        <input type="hidden" id="editPca9685Channel">
                                    </div>
                                </div>
                            </div>
                        </div>


                        <!-- Edit Linear Actuator specific pins -->
                        <div class="row" id="editActuatorPinGroup" style="display: none;">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editDirectionPin" class="form-label">Direction Pin</label>
                                    <input type="number" class="form-control" id="editDirectionPin" min="1" max="40">
                                    <div class="form-text">GPIO pin for direction control</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editPwmPin" class="form-label">PWM Pin</label>
                                    <input type="number" class="form-control" id="editPwmPin" min="1" max="40">
                                    <div class="form-text">GPIO pin for PWM speed control</div>
                                </div>
                            </div>
                        </div>

                        <!-- Edit Linear Actuator safety limits -->
                        <div class="row" id="editActuatorLimitsGroup" style="display: none;">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editMaxExtension" class="form-label">Max Extension (ms)</label>
                                    <input type="number" class="form-control" id="editMaxExtension" min="1000"
                                        max="30000">
                                    <div class="form-text">Maximum extension time to prevent damage</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editMaxRetraction" class="form-label">Max Retraction (ms)</label>
                                    <input type="number" class="form-control" id="editMaxRetraction" min="1000"
                                        max="30000">
                                    <div class="form-text">Maximum retraction time to prevent damage</div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="editConfigJson" class="form-label">Config (JSON)</label>
                            <textarea id="editConfigJson" class="form-control" rows="6" spellcheck="false"></textarea>
                            <div class="form-text">Edit advanced settings here (e.g., servoType, PCA9685 options).
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <div id="editTestBtns" class="btn-group" role="group" style="display:none;">
                            <button type="button" class="btn btn-outline-secondary"
                                onclick="testStopFromEdit()">Stop</button>
                            <button type="button" class="btn btn-outline-success"
                                onclick="testMoveAngleFromEdit(0)">0°</button>
                            <button type="button" class="btn btn-outline-success"
                                onclick="testMoveAngleFromEdit(90)">90°</button>
                            <button type="button" class="btn btn-outline-success"
                                onclick="testMoveAngleFromEdit(180)">180°</button>
                        </div>
                        <button type="button" class="btn btn-outline-info" id="applyMjpgBtn" style="display:none;"
                            onclick="applyWebcamToMjpg()">
                            <i class="bi bi-camera-video"></i> Apply to mjpg-streamer
                        </button>

                        <button type="button" class="btn btn-primary" onclick="saveEditedPart()">Save
                            Changes</button>
                    </div>
                </div>
            </div>
        </div>

        </div>

        <script>
            // Parts management functionality
            var parts = [];
            var partTypes = {};
            var servoTypes = {};

            function initPartsManager() {
                loadParts();
            }

            function loadParts() {
                fetch('/setup/parts/api/parts')
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (data.success) {
                            parts = data.parts;
                            partTypes = data.partTypes;
                            servoTypes = data.servoTypes;
                            renderPartsList();
                            updatePartCounts();
                            populatePartTypeSelect();
                        } else {
                            console.error('Failed to load parts:', data.error);
                            document.getElementById('parts-list').innerHTML =
                                '<div class="alert alert-danger">Failed to load parts: ' + data.error + '</div>';
                            var modelCapableTypes = { servo: true, led: true, linear_actuator: true, webcam: true };

                            function loadModelsIntoSelect(type, selectId, selectedId) {
                                var sel = document.getElementById(selectId);
                                if (!sel) return;
                                sel.innerHTML = '<option value="">Select Model (optional)</option>';
                                if (!modelCapableTypes[type]) return;
                                fetch('/setup/models/api/' + encodeURIComponent(type))
                                    .then(function (r) { return r.json(); })
                                    .then(function (d) {
                                        if (d && d.success && Array.isArray(d.models)) {
                                            d.models.forEach(function (m) {
                                                var opt = document.createElement('option');
                                                opt.value = m.id;
                                                opt.textContent = m.name || ('Model ' + m.id);
                                                if (selectedId && String(selectedId) === String(m.id)) opt.selected = true;
                                                sel.appendChild(opt);
                                            });
                                        }
                                    })
                                    .catch(function () { /* ignore */ });
                            }

                        }
                    })
                    .catch(function (error) {
                        console.error('Error loading parts:', error);
                        var modelCapableTypes = { servo: true, led: true, linear_actuator: true, webcam: true };

                        function loadModelsIntoSelect(type, selectId, selectedId) {
                            var sel = document.getElementById(selectId);
                            if (!sel) return;
                            sel.innerHTML = '<option value="">Select Model (optional)</option>';
                            if (!modelCapableTypes[type]) return;
                            fetch('/setup/models/api/' + encodeURIComponent(type))
                                .then(function (r) { return r.json(); })
                                .then(function (d) {
                                    if (d && d.success && Array.isArray(d.models)) {
                                        d.models.forEach(function (m) {
                                            var opt = document.createElement('option');
                                            opt.value = m.id;
                                            opt.textContent = m.name || ('Model ' + m.id);
                                            if (selectedId && String(selectedId) === String(m.id)) opt.selected = true;
                                            sel.appendChild(opt);
                                        });
                                    }
                                })
                                .catch(function () { /* ignore */ });
                        }


                        document.getElementById('parts-list').innerHTML =
                            '<div class="alert alert-danger">Error loading parts</div>';
                    });
            }

            function renderPartsList() {
                var container = document.getElementById('parts-list');
                if (parts.length === 0) {
                    container.innerHTML = '<div class="text-center text-muted py-4"><i class="bi bi-cpu fs-1"></i><p class="mt-2">No parts configured yet</p><button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createPartModal"><i class="bi bi-plus-circle"></i> Add Your First Part</button></div>';
                    return;
                }

                var html = parts.map(function (part) {
                    var partType = partTypes[part.type] || { icon: '❓', description: 'Unknown type' };
                    var badges = '<span class="badge bg-secondary">' + part.type.replace('_', ' ').toUpperCase() + '</span>';

                    if (part.pin) {
                        badges += ' <span class="badge bg-info">Pin ' + part.pin + '</span>';
                    }
                    if (part.config && part.config.channel !== undefined) {
                        badges += ' <span class="badge bg-warning">Ch ' + part.config.channel + '</span>';
                    }
                    if (part.config && part.config.controllerType === 'pca9685') {
                        badges += ' <span class="badge bg-success">PCA9685</span>';
                    }
                    if (part.config && part.config.modelId) {
                        badges += ' <span class="badge bg-secondary">Model <span data-model-type="' + part.type + '" data-model-id="' + part.config.modelId + '">' + part.config.modelId + '</span></span>';
                    }


                    var modelCapableTypes = { servo: true, led: true, linear_actuator: true, webcam: true };

                    function loadModelsIntoSelect(type, selectId, selectedId) {
                        var sel = document.getElementById(selectId);
                        if (!sel) return;
                        sel.innerHTML = '<option value="">Select Model (optional)</option>';
                        if (!modelCapableTypes[type]) return;
                        fetch('/setup/models/api/' + encodeURIComponent(type))
                            .then(function (r) { return r.json(); })
                            .then(function (d) {
                                if (d && d.success && Array.isArray(d.models)) {
                                    d.models.forEach(function (m) {
                                        var opt = document.createElement('option');
                                        opt.value = m.id;
                                        opt.textContent = m.name || ('Model ' + m.id);
                                        if (selectedId && String(selectedId) === String(m.id)) opt.selected = true;
                                        sel.appendChild(opt);
                                    });
                                }
                            })
                            .catch(function () { /* ignore */ });
                    }

                    return '<div class="card mb-2" data-testid="part-card" data-part-id="' + part.id + '">' +
                        '<div class="card-body">' +
                        '<div class="d-flex justify-content-between align-items-start">' +
                        '<div class="flex-grow-1">' +
                        '<div class="d-flex align-items-center mb-1">' +
                        '<span class="fs-5 me-2">' + partType.icon + '</span>' +
                        '<h6 class="card-title mb-0">' + part.name + '</h6>' +
                        '</div>' +
                        '<div class="mb-2">' + badges + '</div>' +
                        (part.description ? '<p class="card-text text-muted small mb-0">' + part.description + '</p>' : '') +
                        '</div>' +
                        '<div class="btn-group btn-group-sm ms-2">' +
                        '<button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editPartModal" onclick="populateEditModal(\'' + part.id + '\')" title="Edit">' +
                        '<i class="bi bi-pencil"></i>' +
                        '</button>' +
                        (part.type === 'linear_actuator' ?
                            '<button class="btn btn-outline-warning" onclick="window.location.href=\'/setup/calibration/linear_actuator/' + part.id + '\'" title="Calibrate">' +
                            '<i class="bi bi-sliders"></i>' +
                            '</button>' : '') +
                        (part.type === 'servo' && part.config && part.config.servoType === 'continuous' ?
                            '<button class="btn btn-outline-warning" onclick="window.location.href=\'/setup/calibration/continuous_servo/' + part.id + '\'" title="Calibrate">' +
                            '<i class="bi bi-sliders"></i>' +
                            '</button>' : '') +
                        (part.type === 'servo' && (!part.config || part.config.servoType === 'standard' || typeof part.config.servoType === 'undefined') ?
                            '<button class="btn btn-outline-warning" onclick="window.location.href=\'/setup/calibration/standard_servo/' + part.id + '\'" title="Calibrate">' +
                            '<i class="bi bi-sliders"></i>' +
                            '</button>' : '') +
                        '<button class="btn btn-outline-success" onclick="toggleTestDrawer(\'' + part.id + '\')" title="Test" data-testid="open-test-btn" data-part-id="' + part.id + '">' +
                        '<i class="bi bi-play"></i>' +
                        '</button>' +
                        '<button class="btn btn-outline-danger" onclick="deletePart(\'' + part.id + '\')" title="Delete">' +
                        '<i class="bi bi-trash"></i>' +
                        '</button>' +
                        '</div>' +
                        '</div>' +
                        // Test drawer area
                        '<div id="test-drawer-' + part.id + '" class="mt-3 border rounded p-2" style="display:none;" data-testid="test-drawer">' +
                        '<div class="d-flex justify-content-between align-items-center mb-2">' +
                        '<strong>Test Controls</strong>' +
                        '<button class="btn btn-sm btn-outline-secondary" onclick="testPart(\'' + part.id + '\')" title="Quick Test" data-testid="quick-test-btn">' +
                        '<i class="bi bi-lightning"></i> Quick Test' +
                        '</button>' +
                        '</div>' +
                        '<div id="test-controls-' + part.id + '"></div>' +
                        '<div id="test-result-' + part.id + '" class="small text-muted mt-2"></div>' +
                        '</div>' +
                        '</div>' +
                        '</div>';
                }).join('');

                container.innerHTML = html;
            }
            // After rendering, resolve model badges to names
            (function resolveModelBadges() {
                var neededTypes = { servo: true, led: true, linear_actuator: true, webcam: true };
                var maps = {};
                var promises = Object.keys(neededTypes).map(function (t) {
                    return fetch('/setup/models/api/' + t)
                        .then(function (r) { return r.json(); })
                        .then(function (d) {
                            maps[t] = {};
                            (d.models || []).forEach(function (m) { maps[t][String(m.id)] = m.name || ('Model ' + m.id); });
                        })
                        .catch(function () { maps[t] = {}; });
                });
                Promise.all(promises).then(function () {
                    document.querySelectorAll('[data-model-type][data-model-id]').forEach(function (el) {
                        var t = (el.getAttribute('data-model-type') || '').replace(/\-/g, '_');
                        var id = el.getAttribute('data-model-id');
                        var name = (maps[t] && maps[t][String(id)]) || ('Model ' + id);
                        el.textContent = name;
                    });
                });
            })();


            function updatePartCounts() {
                var counts = {};
                parts.forEach(function (part) {
                    counts[part.type] = (counts[part.type] || 0) + 1;
                });

                // Update count badges
                Object.keys(counts).forEach(function (type) {
                    var element = document.getElementById(type + '-count');
                    if (element) {
                        element.textContent = counts[type];
                    }
                });
            }

            function populatePartTypeSelect() {
                var select = document.getElementById('partType');
                if (!select) return;

                select.innerHTML = '<option value="">Select Part Type</option>';

                Object.keys(partTypes).forEach(function (type) {
                    var partType = partTypes[type];
                    var option = document.createElement('option');
                    option.value = type;
                    option.textContent = partType.icon + ' ' + type.replace('_', ' ').toUpperCase() + ' - ' + partType.description;
                    select.appendChild(option);
                });

                // Also populate the edit modal dropdown
                var editSelect = document.getElementById('editPartType');
                if (editSelect) {
                    editSelect.innerHTML = '<option value="">Select…</option>';
                    Object.keys(partTypes).forEach(function (type) {
                        var partType = partTypes[type];
                        var option = document.createElement('option');
                        option.value = type;
                        option.textContent = partType.icon + ' ' + type.replace('_', ' ').toUpperCase() + ' - ' + partType.description;
                        editSelect.appendChild(option);
                    });
                }
            }

            function onPartTypeChange() {
                var partType = document.getElementById('partType').value;
                var pinGroup = document.getElementById('pinGroup');
                var servoGroup = document.getElementById('servoGroup');
                var pca9685Group = document.getElementById('pca9685Group');
                var descriptionGroup = document.getElementById('descriptionGroup');
                var actuatorPinGroup = document.getElementById('actuatorPinGroup');
                var actuatorLimitsGroup = document.getElementById('actuatorLimitsGroup');

                // Microphone assignment group
                var micGrp = document.getElementById('microphoneGroup');
                if (micGrp) {
                    if (partType === 'microphone') {
                        micGrp.style.display = 'block';
                        if (typeof window.scanAudioInputsInto === 'function') {
                            scanAudioInputsInto('audioInputSelect', 'audioInputScanResults');
                        }
                    } else {
                        micGrp.style.display = 'none';
                    }
                }

                // Show/hide pin field based on part type
                if (partTypes[partType] && partTypes[partType].requiresPin && partType !== 'linear_actuator') {
                    pinGroup.style.display = 'block';
                    descriptionGroup.style.display = 'none';
                } else {
                    pinGroup.style.display = 'none';
                    descriptionGroup.style.display = 'block';
                }

                // Show servo-specific options
                if (partType === 'servo') {
                    servoGroup.style.display = 'block';
                    populateServoTypeSelect();
                } else {
                    servoGroup.style.display = 'none';
                    pca9685Group.style.display = 'none';
                }

                // Show linear actuator specific options
                if (partType === 'linear_actuator') {
                    actuatorPinGroup.style.display = 'block';
                    actuatorLimitsGroup.style.display = 'block';
                    descriptionGroup.style.display = 'none';
                } else {
                    actuatorPinGroup.style.display = 'none';
                    actuatorLimitsGroup.style.display = 'none';
                }
                // Webcam device assignment group
                var wcGrp = document.getElementById('webcamGroup');
                if (wcGrp) {
                    if (partType === 'webcam') {
                        wcGrp.style.display = 'block';
                        // Auto-scan to populate list on type selection
                        scanWebcamsInto('webcamDeviceSelect', 'webcamScanResults');
                    } else {
                        wcGrp.style.display = 'none';
                    }
                }

                // Speaker assignment group
                var spGrp = document.getElementById('speakerGroup');
                if (spGrp) {
                    if (partType === 'speaker') {
                        spGrp.style.display = 'block';
                        // Populate outputs on show
                        scanAudioOutputsInto('audioDeviceSelect', 'audioScanResults');
                    } else {
                        spGrp.style.display = 'none';
                    }
                }


                // Model selector for supported types
                var modelGroup = document.getElementById('modelGroup');
                var supported = ['servo', 'led', 'linear_actuator', 'webcam'];

                function onEditControllerTypeChange() {
                    var ct = document.getElementById('editControllerType').value;
                    var grp = document.getElementById('editPca9685Group');
                    if (ct === 'pca9685') {
                        grp.style.display = 'block';
                        renderEditPCA9685Channels();
                    } else {
                        grp.style.display = 'none';
                    }
                }

                function renderEditPCA9685Channels() {
                    var container = document.getElementById('editPca9685Channels');
                    if (!container) return;
                    var html = '<div class="pca9685-board-layout">';
                    html += '<div class="text-center mb-2"><strong>PCA9685 16-Channel PWM Driver</strong></div>';
                    html += '<div class="text-center mb-2 text-muted small">Click a channel to select it</div>';
                    html += '<div class="row g-1">';
                    for (var i = 0; i < 16; i++) {
                        if (i % 4 === 0) html += '<div class="col-3">';
                        html += '<button type="button" class="btn btn-outline-secondary btn-sm w-100 mb-1 edit-pca9685-channel" ' +
                            'onclick="selectEditPCA9685Channel(' + i + ')" id="edit-channel-' + i + '">Ch ' + i + '</button>';
                        if ((i + 1) % 4 === 0) html += '</div>';
                    }
                    html += '</div></div>';
                    container.innerHTML = html;
                }

                function selectEditPCA9685Channel(ch) {
                    document.querySelectorAll('.edit-pca9685-channel').forEach(function (btn) {
                        btn.classList.remove('btn-primary');
                        btn.classList.add('btn-outline-secondary');
                    });
                    var btn = document.getElementById('edit-channel-' + ch);
                    if (btn) {
                        btn.classList.remove('btn-outline-secondary');
                        btn.classList.add('btn-primary');
                    }
                    var hidden = document.getElementById('editPca9685Channel');
                    if (hidden) hidden.value = ch;
                }

                if (supported.indexOf(partType) >= 0) {
                    modelGroup.style.display = 'block';
                    var sel = document.getElementById('modelSelect');
                    if (sel) {
                        sel.innerHTML = '<option value="">Select Model (optional)</option>';
                        fetch('/setup/models/api/' + encodeURIComponent(partType))
                            .then(function (r) { return r.json(); })
                            .then(function (d) {
                                if (d && d.success && Array.isArray(d.models)) {
                                    d.models.forEach(function (m) {
                                        var opt = document.createElement('option');
                                        opt.value = m.id;
                                        opt.textContent = m.name || ('Model ' + m.id);
                                        sel.appendChild(opt);
                                    });
                                }
                            })
                            .catch(function () { /* ignore */ });
                    }
                } else {
                    modelGroup.style.display = 'none';
                }

            }

            function populateServoTypeSelect() {
                var select = document.getElementById('servoType');
                if (!select) return;

                select.innerHTML = '<option value="">Select Servo Type</option>';

                Object.keys(servoTypes).forEach(function (type) {
                    var servoType = servoTypes[type];
                    var option = document.createElement('option');
                    option.value = type;
                    option.textContent = type.toUpperCase() + ' - ' + servoType.description;
                    select.appendChild(option);
                });
            }

            function onControllerTypeChange() {
                var controllerType = document.getElementById('controllerType').value;
                var pca9685Group = document.getElementById('pca9685Group');

                if (controllerType === 'pca9685') {
                    pca9685Group.style.display = 'block';
                    renderPCA9685Channels();
                } else {
                    pca9685Group.style.display = 'none';
                }
            }

            function renderPCA9685Channels() {
                var container = document.getElementById('pca9685Channels');
                if (!container) return;

                var html = '<div class="pca9685-board-layout">';
                html += '<div class="text-center mb-2"><strong>PCA9685 16-Channel PWM Driver</strong></div>';
                html += '<div class="text-center mb-2 text-muted small">Click a channel to select it</div>';
                html += '<div class="row g-1">';

                // Render channels 0-15 in a 4x4 grid layout like the physical board

                for (var i = 0; i < 16; i++) {
                    if (i % 4 === 0) {
                        html += '<div class="col-3">';
                    }

                    html += '<button type="button" class="btn btn-outline-secondary btn-sm w-100 mb-1 pca9685-channel" ';
                    html += 'onclick="selectPCA9685Channel(' + i + ')" id="channel-' + i + '">';
                    html += 'Ch ' + i;
                    html += '</button>';

                    if ((i + 1) % 4 === 0) {
                        html += '</div>';
                    }
                }
                html += '</div></div>';

                container.innerHTML = html;
            }

            function selectPCA9685Channel(channel) {
                // Clear previous selection
                document.querySelectorAll('.pca9685-channel').forEach(function (btn) {
                    btn.classList.remove('btn-primary');
                    btn.classList.add('btn-outline-secondary');
                });

                // Select new channel
                var channelBtn = document.getElementById('channel-' + channel);
                if (channelBtn) {
                    channelBtn.classList.remove('btn-outline-secondary');
                    channelBtn.classList.add('btn-primary');
                }

                // Set hidden input
                var hiddenInput = document.getElementById('pca9685Channel');
                if (hiddenInput) {
                    hiddenInput.value = channel;
                }
            }

            // Global functions
            function createPart() {
                var form = document.getElementById('createPartForm');
                var formData = new FormData(form);

                var type = formData.get('type');
                var payload = {
                    name: formData.get('name'),
                    type: type,
                    description: formData.get('description') || ''
                };

                // Handle linear actuator specific fields
                if (type === 'linear_actuator') {
                    var directionPin = formData.get('directionPin');
                    var pwmPin = formData.get('pwmPin');
                    var maxExtension = formData.get('maxExtension');
                    var maxRetraction = formData.get('maxRetraction');

                    if (directionPin) payload.directionPin = parseInt(directionPin, 10);
                    if (pwmPin) payload.pwmPin = parseInt(pwmPin, 10);
                    if (maxExtension) payload.maxExtension = parseInt(maxExtension, 10);
                    if (maxRetraction) payload.maxRetraction = parseInt(maxRetraction, 10);
                } else {
                    // Handle regular pin for other part types
                    var pin = formData.get('pin');
                    if (pin) payload.pin = parseInt(pin, 10);
                }

                // Attach selected model if any
                var modelSel = document.getElementById('modelSelect');
                var cfg = {};
                if (modelSel && modelSel.value) {
                    cfg.modelId = modelSel.value;
                }

                // Servo-specific config
                if (type === 'servo') {
                    var servoType = document.getElementById('servoType').value || 'standard';
                    var controllerType = document.getElementById('controllerType').value || 'gpio';
                    cfg.servoType = servoType;
                    cfg.controllerType = controllerType;
                    if (controllerType === 'pca9685') {
                        var ch = document.getElementById('pca9685Channel').value;
                        var addrStr = document.getElementById('pca9685Address').value || '0x40';
                        var freq = document.getElementById('pca9685Frequency').value;
                        cfg.channel = ch ? parseInt(ch, 10) : 0;
                        cfg.address = (addrStr && /^0x/i.test(addrStr)) ? parseInt(addrStr, 16) : (parseInt(addrStr, 10) || 0x40);
                        if (freq) cfg.pca9685Frequency = parseInt(freq, 10);
                    }
                }
                // Webcam-specific config
                if (type === 'webcam') {
                    var devSel = document.getElementById('webcamDeviceSelect');
                    var dv = devSel ? devSel.value : '';
                    if (!cfg) cfg = {};
                    if (dv) {
                        cfg.devicePath = dv;
                        var idn = parseVideoIdFromPath(dv);
                        if (idn != null) cfg.deviceId = idn;
                    }
                }

                // Microphone-specific config
                if (type === 'microphone') {
                    var inSel = document.getElementById('audioInputSelect');
                    var inId = inSel ? inSel.value : '';
                    if (!inId) { showAlert('warning', 'Please scan and select an Audio Input for this Microphone'); return; }
                    if (!cfg) cfg = {};
                    cfg.deviceId = inId;
                }

                // Speaker-specific config
                if (type === 'speaker') {
                    var devSel2 = document.getElementById('audioDeviceSelect');
                    var devId2 = devSel2 ? devSel2.value : '';
                    if (!devId2) {
                        showAlert('warning', 'Please scan and select an Audio Output for this Speaker');
                        return;
                    }
                    if (!cfg) cfg = {};
                    cfg.audioDeviceId = devId2;
                    var vol2 = document.getElementById('speakerVolume').value;
                    var bass2 = document.getElementById('speakerBass').value;
                    var treble2 = document.getElementById('speakerTreble').value;
                    if (vol2 !== '') cfg.volume = Math.max(0, Math.min(100, parseInt(vol2, 10)));
                    if (bass2 !== '') cfg.bass = Math.max(-10, Math.min(10, parseInt(bass2, 10)));
                    if (treble2 !== '') cfg.treble = Math.max(-10, Math.min(10, parseInt(treble2, 10)));
                }



                if (Object.keys(cfg).length) payload.config = cfg;

                fetch('/setup/parts/api/parts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                })
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (data.success) {
                            bootstrap.Modal.getInstance(document.getElementById('createPartModal')).hide();
                            document.getElementById('createPartForm').reset();
                            loadParts(); // Reload parts list
                            showAlert('success', data.message);
                        } else {
                            showAlert('danger', 'Failed to create part: ' + data.error);
                        }

                    })
                    .catch(function (error) {
                        console.error('Error creating part:', error);
                        showAlert('danger', 'Error creating part');
                    });
            }
            // Webcam helpers
            function parseVideoIdFromPath(p) {
                var m = String(p || '').match(/\/dev\/video(\d+)/);
                return m ? parseInt(m[1], 10) : null;
            }
            function scanWebcamsInto(selectId, resultsId) {
                var sel = document.getElementById(selectId);
                var out = document.getElementById(resultsId);
                if (out) out.textContent = 'Scanning...';
                fetch('/setup/webcam/api/devices/probe')
                    .then(function (r) { return r.json(); })
                    .then(function (j) {
                        if (!sel) return;
                        sel.innerHTML = '<option value="">Select a detected webcam...</option>';
                        var list = (j && j.results) || [];
                        list.forEach(function (it) {
                            var opt = document.createElement('option');
                            opt.value = it.path || '';
                            opt.textContent = (it.name || it.path || '') + (it.info ? (' - ' + it.info) : '');
                            sel.appendChild(opt);
                        });
                        if (out) {
                            if (!list.length) out.textContent = 'No devices found';
                            else out.textContent = list.map(function (it) { return (it.ok ? '✅ ' : '❌ ') + (it.name || it.path) + ' [' + it.path + ']'; }).join('\n');
                        }
                    })
                    .catch(function () { if (out) out.textContent = 'Error scanning devices'; });
            }
            function scanAudioOutputsInto(selectId, resultsId) {
                var sel = document.getElementById(selectId);
                var out = document.getElementById(resultsId);
                if (out) out.textContent = 'Scanning outputs...';
                fetch('/setup/audio/api/outputs')
                    .then(function (r) { return r.json(); })
                    .then(function (j) {
                        if (!sel) return;
                        sel.innerHTML = '<option value="">Select an audio output...</option>';
                        var list = (j && j.outputs) || [];
                        list.forEach(function (it) {
                            var opt = document.createElement('option');
                            opt.value = it.id || '';
                            opt.textContent = it.description || it.name || it.id;
                            sel.appendChild(opt);
                        });
                        if (out) {
                            if (!list.length) out.textContent = 'No outputs found';
                            else out.textContent = list.map(function (it) { return '🎧 ' + (it.description || (it.name + ' (' + it.id + ')')); }).join('\n');
                        }
                    })
                    .catch(function () { if (out) out.textContent = 'Error scanning outputs'; });
            }
            function applyWebcamToMjpg() {
                try {
                    var id = document.getElementById('editPartId').value;
                    var sel = document.getElementById('editWebcamDeviceSelect');
                    if (!id) { showAlert('danger', 'No part selected'); return; }
                    if (!sel || !sel.value) { showAlert('danger', 'Select a Webcam Device first, then Save'); return; }
                    fetch('/setup/webcam/api/parts/' + id + '/apply-device', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({})
                    })
                        .then(function (r) { return r.json(); })
                        .then(function (d) {
                            if (d && d.success) {
                                showAlert('success', 'Applied to mjpg-streamer: ' + (d.devicePath || ''));
                            } else {
                                var msg = (d && (d.error || d.message)) || 'Failed to apply to mjpg-streamer';

                                if (d && d.needsSudo) msg += ' (needs sudo)';
