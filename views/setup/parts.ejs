            function sendPartAction(partId, action, params, resultId, silent) {
                var payload = { action: action, params: params || {} };
                var resultEl = document.getElementById(resultId);
                fetch('/setup/parts/api/parts/' + partId + '/test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (resultEl) {
                            var txt = (data && data.message) ? data.message : JSON.stringify(data);
                            resultEl.textContent = txt;
                        }
                        if (!silent) {
                            if (data && data.success) showAlert('success', data.message || 'Action succeeded');
                            else showAlert('danger', (data && (data.error || data.message)) || 'Action failed');
                        }
                    })
                    .catch(function (err) {
                        if (resultEl) resultEl.textContent = 'Error: ' + err.message;
                        if (!silent) showAlert('danger', 'Error: ' + err.message);
                    });
            }

            function startLivePoll(partId, action, resultId) {
                var total = 5000, interval = 1000, elapsed = 0;
                var handle = setInterval(function () {
                    sendPartAction(partId, action, {}, resultId, true);


                    elapsed += interval;
                    if (elapsed >= total) clearInterval(handle);
                }, interval);
            }


            function populateEditModal(partId) {
                var part = parts.find(function (p) { return p.id === partId; });
                if (!part) return;
                // populate modal fields
                document.getElementById('editPartId').value = part.id;
                document.getElementById('editPartName').value = part.name || '';
                document.getElementById('editPartType').value = part.type || '';
                document.getElementById('editPartType').disabled = true;
                var pinGroup = document.getElementById('editPinGroup');
                var editActuatorPinGroup = document.getElementById('editActuatorPinGroup');
                var editActuatorLimitsGroup = document.getElementById('editActuatorLimitsGroup');
                var testBtns = document.getElementById('editTestBtns');
                if (testBtns) testBtns.style.display = (part.type === 'servo') ? '' : 'none';

                if (part.type === 'linear_actuator') {
                    // Show linear actuator specific fields
                    pinGroup.style.display = 'none';
                    editActuatorPinGroup.style.display = '';
                    editActuatorLimitsGroup.style.display = '';
                    document.getElementById('editDirectionPin').value = part.directionPin != null ? part.directionPin : '';
                    document.getElementById('editPwmPin').value = part.pwmPin != null ? part.pwmPin : '';
                    document.getElementById('editMaxExtension').value = part.maxExtension != null ? part.maxExtension : 15000;
                    document.getElementById('editMaxRetraction').value = part.maxRetraction != null ? part.maxRetraction : 15000;


                } else if (partTypes[part.type] && partTypes[part.type].requiresPin) {
                    // Show regular pin field for other parts
                    pinGroup.style.display = '';
                    // Toggle Apply-to-mjpg button visibility for webcam
                    var applyBtn = document.getElementById('applyMjpgBtn');
                    if (applyBtn) { applyBtn.style.display = (part.type === 'webcam') ? '' : 'none'; }

                    editActuatorPinGroup.style.display = 'none';
                    editActuatorLimitsGroup.style.display = 'none';
                    document.getElementById('editGpioPin').value = part.pin != null ? part.pin : '';
                } else {
                    // Hide all pin fields
                    pinGroup.style.display = 'none';
                    editActuatorPinGroup.style.display = 'none';
                    editActuatorLimitsGroup.style.display = 'none';
                    document.getElementById('editGpioPin').value = '';
                }
                // Webcam edit group handling
                (function () {
                    var grp = document.getElementById('editWebcamGroup');
                    if (!grp) return;
                    if (part.type === 'webcam') {
                        grp.style.display = '';
                        scanWebcamsInto('editWebcamDeviceSelect', 'editWebcamScanResults');
                        // Select current if present
                        setTimeout(function () {
                            var sel = document.getElementById('editWebcamDeviceSelect');
                            var cfg = part.config || {};
                            if (sel && cfg.devicePath) sel.value = cfg.devicePath;
                        }, 250);
                        // Show Apply-to-mjpg button for webcam type
                        var _applyBtn = document.getElementById('applyMjpgBtn');
                        if (_applyBtn) _applyBtn.style.display = '';
                        // Microphone edit group handling
                        (function () {
                            var grp = document.getElementById('editMicrophoneGroup');
                            if (!grp) return;
                            if (part.type === 'microphone') {
                                grp.style.display = '';
                                scanAudioInputsInto('editAudioInputSelect', 'editAudioInputScanResults');
                                var cfg = part.config || {};
                                setTimeout(function () {
                                    try {
                                        var sel = document.getElementById('editAudioInputSelect');
                                        if (sel && cfg.deviceId) sel.value = cfg.deviceId;
                                    } catch (e) { /* ignore */ }
                                }, 250);
                            } else { grp.style.display = 'none'; }
                        })()


                    } else {
                        // Hide Apply-to-mjpg button when not webcam
                        var __applyBtn = document.getElementById('applyMjpgBtn');
                        if (__applyBtn) __applyBtn.style.display = 'none';

                        grp.style.display = 'none';
                    }
                })();


                // Servo-specific edit fields
                (function () {
                    var editServoGroup = document.getElementById('editServoGroup');
                    var editPcaGrp = document.getElementById('editPca9685Group');
                    if (part.type === 'servo') {
                        editServoGroup.style.display = '';
                        // Populate servo type options once
                        var editServoTypeSel = document.getElementById('editServoType');
                        if (editServoTypeSel && !editServoTypeSel.dataset.filled) {
                            editServoTypeSel.innerHTML = '';
                            Object.keys(servoTypes).forEach(function (k) {
                                var opt = document.createElement('option');
                                opt.value = k;
                                opt.textContent = servoTypes[k].label || k;
                                editServoTypeSel.appendChild(opt);
                            });
                            editServoTypeSel.dataset.filled = '1';

                        }
                        var cfg = part.config || {};
                        document.getElementById('editServoType').value = cfg.servoType || 'standard';

                        // Set invert direction toggle
                        (function () {
                            var invEl = document.getElementById('editInvertDirection');
                            if (invEl) { invEl.checked = !!(cfg && cfg.invertDirection); }
                        })();

                        document.getElementById('editControllerType').value = cfg.controllerType || 'gpio';
                        if ((cfg.controllerType || 'gpio') === 'pca9685') {
                            editPcaGrp.style.display = '';
                            renderEditPCA9685Channels();
                            var addr = (typeof cfg.address === 'number') ? '0x' + cfg.address.toString(16) : (cfg.address || '0x40');
                            document.getElementById('editPca9685Address').value = addr;
                            document.getElementById('editPca9685Frequency').value = (cfg.pca9685Frequency != null ? cfg.pca9685Frequency : 50);
                            var ch = (typeof cfg.channel === 'number') ? cfg.channel : 0;
                            selectEditPCA9685Channel(ch);
                        } else {
                            editPcaGrp.style.display = 'none';
                        }
                    } else {
                        editServoGroup.style.display = 'none';
                        editPcaGrp.style.display = 'none';
                    }
                })();

                document.getElementById('editPartDescription').value = part.description || '';
                document.getElementById('editConfigJson').value = JSON.stringify(part.config || {}, null, 2);
                // Populate model selector if supported
                var editModelGroup = document.getElementById('editModelGroup');
                var supported = ['servo', 'led', 'linear_actuator', 'webcam'];
                if (supported.indexOf(part.type) >= 0) {
                    editModelGroup.style.display = '';
                    var sel = document.getElementById('editModelSelect');
                    if (sel) {
                        sel.innerHTML = '<option value=\"\">Select Model (optional)</option>';
                        fetch('/setup/models/api/' + encodeURIComponent(part.type))
                            .then(function (r) { return r.json(); })
                            .then(function (d) {
                                if (d && d.success && Array.isArray(d.models)) {
                                    d.models.forEach(function (m) {
                                        var opt = document.createElement('option');
                                        opt.value = m.id;
                                        opt.textContent = m.name || ('Model ' + m.id);
                                        sel.appendChild(opt);
                                    });
                                    var curModelId = (part.config && part.config.modelId) ? String(part.config.modelId) : '';
                                    if (curModelId) sel.value = curModelId;
                                }

                                // Speaker edit group handling
                                (function () {
                                    var grp = document.getElementById('editSpeakerGroup');
                                    if (!grp) return;
                                    if (part.type === 'speaker') {
                                        grp.style.display = '';
                                        scanAudioOutputsInto('editAudioDeviceSelect', 'editAudioScanResults');
                                        var cfg = part.config || {};
                                        setTimeout(function () {
                                            try {
                                                var sel = document.getElementById('editAudioDeviceSelect');
                                                if (sel && cfg.audioDeviceId) sel.value = cfg.audioDeviceId;
                                            } catch (e) { /* ignore */ }
                                        }, 250);
                                        try {
                                            var v = document.getElementById('editSpeakerVolume'); if (v) v.value = (cfg.volume != null ? cfg.volume : 50);
                                            var b = document.getElementById('editSpeakerBass'); if (b) b.value = (cfg.bass != null ? cfg.bass : 0);
                                            var t = document.getElementById('editSpeakerTreble'); if (t) t.value = (cfg.treble != null ? cfg.treble : 0);
                                        } catch (e) { /* ignore */ }
                                    } else {
                                        grp.style.display = 'none';
                                    }
                                })();

                            })
                            .catch(function () { /* ignore */ });

                        // When model selection changes, merge model defaults into config preview
                        (function () {
                            var sel = document.getElementById('editModelSelect');
                            if (!sel) return;
                            sel.onchange = function () {
                                var modelId = sel.value;
                                if (!modelId) return; // no selection
                                var type = (part.type || '').replace(/\-/g, '_');
                                fetch('/setup/models/api/' + encodeURIComponent(type) + '/' + encodeURIComponent(modelId))
                                    .then(function (r) { return r.json(); })
                                    .then(function (d) {
                                        if (!d || !d.success || !d.model) return;
                                        var defaults = d.model.defaults || {};
                                        var txt = document.getElementById('editConfigJson').value || '{}';
                                        var cfg; try { cfg = JSON.parse(txt); } catch (e) { cfg = {}; }
                                        Object.keys(defaults).forEach(function (k) { if (typeof cfg[k] === 'undefined') cfg[k] = defaults[k]; });
                                        cfg.modelId = modelId;
                                        document.getElementById('editConfigJson').value = JSON.stringify(cfg, null, 2);
                                    })
                                    .catch(function () { /* ignore */ });
                            };
                        })();
                    }
                } else {
                    editModelGroup.style.display = 'none';
                }

                // Bootstrap will handle showing the modal via data-bs-toggle
            }

            function testMoveFromEdit() {
                try {
                    var partId = document.getElementById('editPartId').value;
                    if (!partId) return;
                    var part = parts.find(function (p) { return p.id === partId; });
                    if (!part) return;
                    var stSel = document.getElementById('editServoType');
                    var st = stSel && stSel.value ? stSel.value : ((part.config && part.config.servoType) || 'standard');
                    st = String(st || '').toLowerCase();
                    if (part.type !== 'servo') {
                        showAlert('warning', 'Test Move is only available for servo parts');
                        return;
                    }
                    if (st === 'continuous') {
                        // Short gentle CW spin then auto-stop by hardware logic
                        sendPartAction(partId, 'rotateContinuous', { direction: 'cw', speed: 25, duration: 800 }, null);
                    } else {
                        // Positional or standard: move to 90 deg
                        sendPartAction(partId, 'moveToAngle', { angleDeg: 90 }, null);


                    }
                } catch (e) {
                    // Microphone-specific edit selection merges into config
                    if (type === 'microphone') {
                        try {
                            var mSel = document.getElementById('editAudioInputSelect');
                            var mid = mSel ? mSel.value : '';
                            if (mid) config.deviceId = mid;
                        } catch (e) { /* ignore */ }
                    }

                    console.error('testMoveFromEdit error:', e);
                    showAlert('danger', 'Error issuing test move: ' + e.message);
                }
            }
            function testMoveAngleFromEdit(angle) {
                try {
                    var partId = document.getElementById('editPartId').value;
                    if (!partId) return;
                    var part = parts.find(function (p) { return p.id === partId; });
                    if (!part) return;
                    if (part.type !== 'servo') { showAlert('warning', 'Servo-only test'); return; }
                    var stSel = document.getElementById('editServoType');
                    var st = stSel && stSel.value ? stSel.value : ((part.config && part.config.servoType) || 'standard');
                    st = String(st || '').toLowerCase();
                    if (st === 'continuous') {
                        if (angle === 0) { sendPartAction(partId, 'stop', {}, null); }
                        else if (angle === 90) { sendPartAction(partId, 'rotateContinuous', { direction: 'cw', speed: 35, duration: 800 }, null); }
                        else if (angle === 180) { sendPartAction(partId, 'rotateContinuous', { direction: 'ccw', speed: 35, duration: 800 }, null); }
                        else { sendPartAction(partId, 'stop', {}, null); }
                    } else {
                        sendPartAction(partId, 'moveToAngle', { angleDeg: angle }, null);
                    }
                } catch (e) {
                    console.error('testMoveAngleFromEdit error:', e);
                }
            }

            function testStopFromEdit() {
                try {
                    var partId = document.getElementById('editPartId').value;
                    if (!partId) return;
                    var part = parts.find(function (p) { return p.id === partId; });
                    if (!part) return;
                    sendPartAction(partId, 'stop', {}, null);
                } catch (e) {
                    console.error('testStopFromEdit error:', e);
                }
            }


            function saveEditedPart() {
                var id = document.getElementById('editPartId').value;
                var name = document.getElementById('editPartName').value.trim();
                var type = document.getElementById('editPartType').value;
                var pin = document.getElementById('editGpioPin').value;
                var description = document.getElementById('editPartDescription').value;
                var configText = document.getElementById('editConfigJson').value;
                var requiresPin = partTypes[type] && partTypes[type].requiresPin;

                if (!name) { showAlert('danger', 'Name is required'); return; }

                // Handle linear actuator validation
                if (type === 'linear_actuator') {
                    var directionPin = document.getElementById('editDirectionPin').value;
                    var pwmPin = document.getElementById('editPwmPin').value;
                    if (!directionPin || !pwmPin) {
                        showAlert('danger', 'Direction pin and PWM pin are required for linear actuator');
                        return;
                    }
                } else if (requiresPin && !pin) {
                    // Allow servo without GPIO pin when using PCA9685
                    var editCT = (type === 'servo') ? document.getElementById('editControllerType').value : null;
                    if (!(type === 'servo' && editCT === 'pca9685')) {
                        showAlert('danger', 'Pin is required for ' + type);
                        return;
                    }

                }

                var config;
                try { config = configText ? JSON.parse(configText) : {}; }
                catch (e) { showAlert('danger', 'Config JSON invalid: ' + e.message); return; }
                // Merge selected model into config
                var editModelSel = document.getElementById('editModelSelect');


                if (editModelSel && editModelSel.value) { config.modelId = editModelSel.value; }

                // Merge servo-specific fields from edit controls
                if (type === 'servo') {
                    try {
                        var st = document.getElementById('editServoType').value || 'standard';
                        var ct = document.getElementById('editControllerType').value || 'gpio';
                        config.servoType = st;  // Always use the form value
                        config.controllerType = ct;

                        // Persist invert direction from UI toggle
                        (function () {
                            var invEl = document.getElementById('editInvertDirection');
                            if (invEl) { config.invertDirection = !!invEl.checked; }
                        })();

                        if (ct === 'pca9685') {
                            var addrStr = document.getElementById('editPca9685Address').value || '0x40';
                            var chVal = document.getElementById('editPca9685Channel').value;
                            var freqVal = document.getElementById('editPca9685Frequency').value;
                            config.address = (/^0x/i.test(addrStr)) ? parseInt(addrStr, 16) : (parseInt(addrStr, 10) || 0x40);
                            config.channel = chVal ? parseInt(chVal, 10) : (typeof config.channel === 'number' ? config.channel : 0);

                            if (freqVal) config.pca9685Frequency = parseInt(freqVal, 10);
                        }
                    } catch (e) { /* ignore */ }
                }

                // Webcam-specific edit selection merges into config
                if (type === 'webcam') {
                    try {
                        var devSel = document.getElementById('editWebcamDeviceSelect');
                        var dv = devSel ? devSel.value : '';
                        if (dv) {
                            config.devicePath = dv;
                            var idn = parseVideoIdFromPath(dv);
                            if (idn != null) config.deviceId = idn;
                        }
                    } catch (e) { /* ignore */ }
                }

                // Microphone-specific edit selection merges into config
                if (type === 'microphone') {
                    try {
                        var mSel = document.getElementById('editAudioInputSelect');
                        var mid = mSel ? mSel.value : '';
                        if (mid) config.deviceId = mid;
                    } catch (e) { /* ignore */ }
                }

                // Speaker-specific edit selection merges into config
                if (type === 'speaker') {
                    try {
                        var sSel = document.getElementById('editAudioDeviceSelect');
                        var sid = sSel ? sSel.value : '';
                        if (sid) config.audioDeviceId = sid;
                        var v = document.getElementById('editSpeakerVolume'); if (v && v.value !== '') config.volume = Math.max(0, Math.min(100, parseInt(v.value, 10)));
                        var b = document.getElementById('editSpeakerBass'); if (b && b.value !== '') config.bass = Math.max(-10, Math.min(10, parseInt(b.value, 10)));
                        var t = document.getElementById('editSpeakerTreble'); if (t && t.value !== '') config.treble = Math.max(-10, Math.min(10, parseInt(t.value, 10)));
                    } catch (e) { /* ignore */ }
                }


                var payload = { name: name, description: description, config: config };

                // Add linear actuator specific fields
                if (type === 'linear_actuator') {
                    payload.directionPin = parseInt(document.getElementById('editDirectionPin').value, 10);
                    payload.pwmPin = parseInt(document.getElementById('editPwmPin').value, 10);
                    payload.maxExtension = parseInt(document.getElementById('editMaxExtension').value, 10) || 15000;
                    payload.maxRetraction = parseInt(document.getElementById('editMaxRetraction').value, 10) || 15000;
                } else if (requiresPin) {
                    payload.pin = parseInt(pin, 10);
                }

                fetch('/setup/parts/api/parts/' + id, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                })
                    .then(function (resp) { return resp.json(); })
                    .then(function (data) {
                        if (data && data.success) {
                            bootstrap.Modal.getInstance(document.getElementById('editPartModal')).hide();
                            loadParts();
                            showAlert('success', data.message || 'Part updated');
                        } else {
                            showAlert('danger', 'Failed to update: ' + (data && (data.error || data.message) || 'Unknown error'));
                        }
                    })
                    .catch(function (err) { showAlert('danger', 'Update error: ' + err.message); });
            }

            function deletePart(partId) {
                var part = parts.find(function (p) { return p.id === partId; });
                if (!part) return;

                if (confirm('Are you sure you want to delete "' + part.name + '"?')) {
                    fetch('/setup/parts/api/parts/' + partId, {
                        method: 'DELETE'
                    })
                        .then(function (response) { return response.json(); })
                        .then(function (data) {
                            if (data.success) {
                                loadParts(); // Reload parts list
                                showAlert('success', data.message);
                            } else {
                                showAlert('danger', 'Failed to delete part: ' + data.error);
                            }
                        })
                        .catch(function (error) {
                            console.error('Error deleting part:', error);
                            showAlert('danger', 'Error deleting part');
                        });
                }
            }

            function showAlert(type, message) {
                // Create alerts container if it doesn't exist
                var alertsContainer = document.getElementById('alertsContainer');
                if (!alertsContainer) {
                    alertsContainer = document.createElement('div');
                    alertsContainer.id = 'alertsContainer';
                    alertsContainer.className = 'position-fixed top-0 end-0 p-3';
                    alertsContainer.style.zIndex = '1055';
                    document.body.appendChild(alertsContainer);
                }

                var alertHtml = '<div class="alert alert-' + type + ' alert-dismissible fade show" role="alert">';
                alertHtml += message;
                alertHtml += '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
                alertHtml += '</div>';
                alertsContainer.innerHTML = alertHtml;

                // Auto-dismiss after 5 seconds
                setTimeout(function () {
                    var alert = alertsContainer.querySelector('.alert');
                    if (alert) {
                        var bsAlert = bootstrap.Alert.getInstance(alert);
                        if (bsAlert) bsAlert.close();
                    }
                }, 5000);
            }


            // Webcam controls helpers
            function listWebcamControls(partId) {
                var outEl = document.getElementById('wc-ctrls-out-' + partId);
                if (outEl) outEl.textContent = 'Loading...';
                fetch('/setup/webcam/api/parts/' + partId + '/controls/list')
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        if (d && d.success) {
                            if (outEl) outEl.textContent = d.rawOutput || JSON.stringify(d.controls || [], null, 2);
                            showAlert('success', d.message || 'Controls loaded');
                        } else {
                            var msg = (d && (d.error || d.message)) || 'Failed to list controls';
                            if (outEl) outEl.textContent = msg;
                            showAlert('danger', msg);
                        }
                    })
                    .catch(function (err) {
                        if (outEl) outEl.textContent = 'Error: ' + err.message;
                        showAlert('danger', 'Error: ' + err.message);
                    });
            }

            function applyWebcamControls(partId) {
                var inputEl = document.getElementById('wc-ctrls-' + partId);
                var persistEl = document.getElementById('wc-persist-' + partId);
                var str = inputEl ? (inputEl.value || '').trim() : '';
                var persist = !!(persistEl && persistEl.checked);
                var obj = {};
                if (str) {
                    str.split(',').forEach(function (pair) {
                        var kv = pair.split('=');
                        if (kv.length >= 2) {
                            var k = (kv[0] || '').trim();
                            var v = kv.slice(1).join('=');
                            v = (v || '').trim();
                            if (/^-?\d+$/.test(v)) v = parseInt(v, 10);
                            else if (v === 'true' || v === 'false') v = (v === 'true');
                            obj[k] = v;
                        }
                        // Ensure global microphone scanner is available
                        window.scanAudioInputsInto = function (selectId, resultsId) {
                            var sel = document.getElementById(selectId);
                            var out = document.getElementById(resultsId);
                            if (out) out.textContent = 'Scanning inputs...';
                            fetch('/setup/audio/api/inputs')
                                .then(function (r) { return r.json(); })
                                .then(function (j) {
                                    if (!sel) return;
                                    sel.innerHTML = '<option value="">Select an audio input...</option>';
                                    var list = (j && j.inputs) || [];
                                    list.forEach(function (it) {
                                        var opt = document.createElement('option');
                                        opt.value = it.id || '';
                                        opt.textContent = it.description || it.name || it.id;
                                        sel.appendChild(opt);
                                    });
                                    if (out) out.textContent = !list.length ? 'No inputs found' : list.map(function (it) {
                                        return '🎤 ' + (it.description || (it.name + ' (' + it.id + ')'));
                                    }).join('\n');
                                })
                                .catch(function () {
                                    if (out) out.textContent = 'Error scanning inputs';
                                });
                        };
                    });
                }
                fetch('/setup/webcam/api/parts/' + partId + '/controls/set', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ controls: obj, persist: persist })
                })
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        if (d && d.success) {
                            showAlert('success', d.message || 'Controls applied');
                        } else {
                            showAlert('danger', (d && (d.error || d.message)) || 'Failed to apply controls');
                        }
                    })
                    .catch(function (err) { showAlert('danger', 'Error: ' + err.message); });
            }


            // Hoisted to global scope so Edit modal can use these handlers
            function onEditControllerTypeChange() {
                var ct = document.getElementById('editControllerType').value;
                var grp = document.getElementById('editPca9685Group');
                if (ct === 'pca9685') {
                    if (grp) grp.style.display = 'block';
                    renderEditPCA9685Channels();
                } else {
                    if (grp) grp.style.display = 'none';
                }
            }

            function renderEditPCA9685Channels() {
                var container = document.getElementById('editPca9685Channels');
                if (!container) return;
                var html = '<div class="pca9685-board-layout">';
                html += '<div class="text-center mb-2"><strong>PCA9685 16-Channel PWM Driver</strong></div>';
                html += '<div class="text-center mb-2 text-muted small">Click a channel to select it</div>';
                html += '<div class="row g-1">';
                for (var i = 0; i < 16; i++) {
                    if (i % 4 === 0) html += '<div class="col-3">'; html
                        += '<button type="button" class="btn btn-outline-secondary btn-sm w-100 mb-1 edit-pca9685-channel" '
                        + 'onclick="selectEditPCA9685Channel(' + i + ')" id="edit-channel-' + i + '">Ch ' + i + '</button>'
                        ; if ((i + 1) % 4 === 0) html += '</div>';
                } html += '</div></div>'; container.innerHTML = html;
            }
            function selectEditPCA9685Channel(ch) {
                var btns = document.querySelectorAll('.edit-pca9685-channel');
                if (btns && btns.forEach) {
                    btns.forEach(function (btn) {
                        btn.classList.remove('btn-primary');
                        btn.classList.add('btn-outline-secondary');
                    });
                }
                var btn = document.getElementById('edit-channel-' + ch);
                if (btn) {
                    btn.classList.remove('btn-outline-secondary');
                    btn.classList.add('btn-primary');
                }
                var hidden = document.getElementById('editPca9685Channel');
                if (hidden) hidden.value = ch;
            }
        </script>
