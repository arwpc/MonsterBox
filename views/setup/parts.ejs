            }

            function selectPCA9685Channel(channel) {
                // Clear previous selection
                document.querySelectorAll('.pca9685-channel').forEach(function (btn) {
                    btn.classList.remove('btn-primary');
                    btn.classList.add('btn-outline-secondary');
                });

                // Select new channel
                var channelBtn = document.getElementById('channel-' + channel);
                if (channelBtn) {
                    channelBtn.classList.remove('btn-outline-secondary');
                    channelBtn.classList.add('btn-primary');
                }

                // Set hidden input
                var hiddenInput = document.getElementById('pca9685Channel');
                if (hiddenInput) {
                    hiddenInput.value = channel;
                }
            }

            // Global functions
            function createPart() {
                var form = document.getElementById('createPartForm');
                var formData = new FormData(form);
                var type = formData.get('type');
                var payload = {
                    name: formData.get('name'),
                    type: type,
                    description: formData.get('description') || ''
                };

                // Handle linear actuator specific fields
                if (type === 'linear_actuator') {
                    var directionPin = formData.get('directionPin');
                    var pwmPin = formData.get('pwmPin');
                    var maxExtension = formData.get('maxExtension');
                    var maxRetraction = formData.get('maxRetraction');

                    if (directionPin) payload.directionPin = parseInt(directionPin, 10);
                    if (pwmPin) payload.pwmPin = parseInt(pwmPin, 10);
                    if (maxExtension) payload.maxExtension = parseInt(maxExtension, 10);
                    if (maxRetraction) payload.maxRetraction = parseInt(maxRetraction, 10);
                } else {
                    // Handle regular pin for other part types
                    var pin = formData.get('pin');
                    if (pin) payload.pin = parseInt(pin, 10);
                }

                // Attach selected model if any
                var modelSel = document.getElementById('modelSelect');
                var cfg = {};
                if (modelSel && modelSel.value) {
                    cfg.modelId = modelSel.value;
                }

                // Servo-specific config
                if (type === 'servo') {
                    var servoType = document.getElementById('servoType').value || 'standard';
                    var controllerType = document.getElementById('controllerType').value || 'gpio';
                    cfg.servoType = servoType;
                    cfg.controllerType = controllerType;
                    if (controllerType === 'pca9685') {
                        var ch = document.getElementById('pca9685Channel').value;
                        var addrStr = document.getElementById('pca9685Address').value || '0x40';
                        cfg.channel = ch ? parseInt(ch, 10) : 0;
                        cfg.address = (addrStr && /^0x/i.test(addrStr)) ? parseInt(addrStr, 16) : (parseInt(addrStr, 10) || 0x40);
                    }
                }

                if (Object.keys(cfg).length) payload.config = cfg;

                fetch('/setup/parts/api/parts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                })
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (data.success) {
                            bootstrap.Modal.getInstance(document.getElementById('createPartModal')).hide();
                            document.getElementById('createPartForm').reset();
                            loadParts(); // Reload parts list
                            showAlert('success', data.message);
                        } else {
                            showAlert('danger', 'Failed to create part: ' + data.error);
                        }
                    })
                    .catch(function (error) {
                        console.error('Error creating part:', error);
                        showAlert('danger', 'Error creating part');
                    });
            }

            function testPart(partId) {
                var part = parts.find(function (p) { return p.id === partId; });
                if (!part) return;

                var payload = getDefaultActionPayload(part);

                fetch('/setup/parts/api/parts/' + partId + '/test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                })
                    .then(function (response) { return response.json(); })
                    .then(function (data) {
                        if (data && data.success) {
                            showAlert('success', data.message || 'Test succeeded');
                        } else {
                            var msg = (data && (data.error || data.message)) || 'Test failed';
                            showAlert('danger', msg);
                        }
                    })
                    .catch(function (error) {
                        console.error('Error testing part:', error);
                        showAlert('danger', 'Error testing part');
                    });
            }

            function getDefaultActionPayload(part) {
                var type = (part.type || '').replace(/\-/g, '_');
                switch (type) {
                    case 'servo':
                        var st = part && part.config && part.config.servoType;
                        if (st === 'continuous') {
                            return { action: 'rotateContinuous', params: { direction: 'cw', speed: 50, duration: 1000 } };
                        }
                        return { action: 'moveToAngle', params: { angleDeg: 15 } };
                    case 'motor':
                        return { action: 'control', params: { direction: 'cw', speed: 50, duration: 1000 } };
                    case 'linear_actuator':
                        return { action: 'extend', params: { speed: 50, distance: 50 } };
                    case 'light':
                        return { action: 'toggle', params: {} };
                    case 'led':
                        return { action: 'setBrightness', params: { brightness: 50 } };
                    case 'sensor':
                        return { action: 'read', params: {} };
                    case 'motion_sensor':
                        return { action: 'read', params: {} };
                    case 'microphone':
                        return { action: 'getLevel', params: {} };
                    case 'speaker':
                        return { action: 'stop', params: {} };
                    case 'webcam':
                        return { action: 'capture', params: { resolution: '640x480' } };
                    case 'head_tracking':
                        return { action: 'getPosition', params: {} };
                    default:
                        return { action: '', params: {} };
                }
            }

            // Per-type Test Drawer logic
            function toggleTestDrawer(partId) {
                var drawer = document.getElementById('test-drawer-' + partId);
                if (!drawer) return;
                var part = parts.find(function (p) { return p.id === partId; });
                if (!part) return;
                if (drawer.style.display === 'none') {
                    drawer.style.display = 'block';
                    renderTestControls(part);
                } else {
                    drawer.style.display = 'none';
                }
            }

            function renderTestControls(part) {
                var container = document.getElementById('test-controls-' + part.id);
                var resultId = 'test-result-' + part.id;
                if (!container) return;
                var html = '';
                var t = (part.type || '').replace(/\-/g, '_');
