                        html += '<div class="col-auto"><input id="servo-angle-' + part.id + '" type="number" class="form-control form-control-sm" style="width:80px" value="15"/></div>';
                        html += '<div class="col-auto"><button class="btn btn-sm btn-primary" onclick="sendPartAction(\'' + part.id + '\',\'moveToAngle\',{ angleDeg: parseInt(document.getElementById(\'servo-angle-' + part.id + '\').value,10)||0 },\'' + resultId + '\')">Move</button></div>';
                        html += '<div class="col-auto"><button class="btn btn-sm btn-outline-secondary" onclick="sendPartAction(\'' + part.id + '\',\'rotateContinuous\',{ direction: \'cw\', speed: 50 },\'' + resultId + '\')">CW</button></div>';
                        html += '<div class="col-auto"><button class="btn btn-sm btn-outline-secondary" onclick="sendPartAction(\'' + part.id + '\',\'rotateContinuous\',{ direction: \'ccw\', speed: 50 },\'' + resultId + '\')">CCW</button></div>';
                        html += '<div class="col-auto"><button class="btn btn-sm btn-outline-danger" onclick="sendPartAction(\'' + part.id + '\',\'stop\',{},\'' + resultId + '\')">Stop</button></div>';
