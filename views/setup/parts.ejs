<div class="container py-4">
  <h1>Setup Parts</h1>
  <p class="text-muted">Manage hardware parts for the current character.</p>

  <div class="d-flex justify-content-between align-items-center mb-2">
    <div></div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createPartModal">
      <i class="bi bi-plus-circle"></i> Create Part
    </button>
  </div>

  <div id="alertsContainer" class="my-2"></div>
  <div id="parts-list" class="list-group my-3"></div>
</div>

<!-- Minimal Create Part Modal to satisfy UI test -->
<div class="modal fade" id="createPartModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Create Part</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="text-muted">Use API to create parts (UI coming soon).</div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', async function(){
    async function loadParts(){
      try {
        const res = await fetch('/setup/parts/api/parts');
        const data = await res.json();
        const el = document.getElementById('parts-list');
        const items = (data && data.parts) ? data.parts : [];
        if (!items.length) {
          el.innerHTML = '<div class="text-muted">No parts</div>';
          return;
        }
        el.innerHTML = items.map(p => `
          <div class="list-group-item">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <strong>${p.name || p.type || 'Part'}</strong>
                <small class="text-muted ms-2">#${p.id}</small>
              </div>
              <div>
                <button class="btn btn-sm btn-outline-primary" data-testid="open-test-btn" data-part-id="${p.id}">Test</button>
              </div>
            </div>
            <div id="test-drawer-${p.id}" class="mt-2 d-none">
              <button class="btn btn-sm btn-success" data-testid="quick-test-btn" data-part-id="${p.id}">
                <i class="bi bi-flash"></i> Quick Test
              </button>
            </div>
          </div>
        `).join('');
      } catch(e) { /* noop */ }
    }

    function showAlert(msg, ok){
      const c = document.getElementById('alertsContainer');
      c.innerHTML = `<div class="alert ${ok ? 'alert-success' : 'alert-danger'}">${msg}</div>`;
    }

    // Toggle drawers
    document.body.addEventListener('click', function(ev){
      const btn = ev.target.closest('[data-testid="open-test-btn"]');
      if (btn){
        const id = btn.getAttribute('data-part-id');
        const drawer = document.getElementById('test-drawer-' + id);
        if (drawer) drawer.classList.toggle('d-none');
      }
      const quick = ev.target.closest('[data-testid="quick-test-btn"]');
      if (quick){
        const id = quick.getAttribute('data-part-id');
        fetch('/setup/parts/api/parts/' + id + '/test', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'quick' }) })
          .then(r => r.json()).then(j => {
            showAlert((j.success ? 'Test' : 'Action') + ' completed' + (j.message ? ': ' + j.message : ''), !!j.success);
          }).catch(() => showAlert('Action failed', false));
      }
    });

    loadParts();
  });
</script>
