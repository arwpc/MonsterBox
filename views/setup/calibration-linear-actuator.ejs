<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<main class="container-fluid py-4">
            <!-- Header -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h1><i class="bi bi-sliders"></i> Calibrate Linear Actuator</h1>
                            <p class="text-muted mb-0">
                                <i class="bi bi-arrow-left"></i>
                                <a href="/setup/parts" class="text-decoration-none">Back to Parts</a>
                            </p>
                        </div>
                        <div class="text-end">
                            <h4 class="mb-0">🦴 <%= part.name %>
                            </h4>
                            <small class="text-muted">ID: <%= part.id %> | Dir Pin: <%= part.directionPin %> | PWM Pin:
                                        <%= part.pwmPin %></small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- Control Panel -->
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0"><i class="bi bi-joystick"></i> Jog Controls</h5>
                        </div>
                        <div class="card-body">
                            <!-- Speed Control -->
                            <div class="mb-3">
                                <label for="jogSpeed" class="form-label">Jog Speed (%)</label>
                                <div class="row g-2 align-items-center">
                                    <div class="col">
                                        <input type="range" class="form-range" id="jogSpeed" min="10" max="100"
                                            value="50">
                                    </div>
                                    <div class="col-auto">
                                        <input type="number" class="form-control form-control-sm" id="jogSpeedValue"
                                            min="10" max="100" value="50" style="width: 70px;">
                                    </div>
                                </div>
                            </div>

                            <!-- Duration Control -->
                            <div class="mb-4">
                                <label for="jogDuration" class="form-label">Jog Duration (ms)</label>
                                <div class="row g-2 align-items-center">
                                    <div class="col">
                                        <input type="range" class="form-range" id="jogDuration" min="100" max="2000"
                                            value="500">
                                    </div>
                                    <div class="col-auto">
                                        <input type="number" class="form-control form-control-sm" id="jogDurationValue"
                                            min="100" max="2000" value="500" style="width: 80px;">
                                    </div>
                                </div>
                            </div>

                            <!-- Jog Buttons -->
                            <div class="d-grid gap-2">
                                <button class="btn btn-primary btn-lg" id="extendBtn" onclick="jogActuator('extend')">
                                    <i class="bi bi-arrow-up"></i> Extend
                                </button>
                                <button class="btn btn-secondary btn-lg" id="retractBtn"
                                    onclick="jogActuator('retract')">
                                    <i class="bi bi-arrow-down"></i> Retract
                                </button>
                                <button class="btn btn-danger" id="stopBtn" onclick="stopActuator()">
                                    <i class="bi bi-stop-fill"></i> STOP
                                </button>
                            </div>

                            <!-- Status Display -->
                            <div class="mt-3">
                                <div id="jogStatus" class="alert alert-info" style="display: none;"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Calibration Panel -->
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0"><i class="bi bi-bookmark"></i> Save Positions</h5>
                        </div>
                        <div class="card-body">
                            <!-- Calibration Status -->
                            <div class="mb-4">
                                <h6>Calibration Status</h6>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <div class="d-flex align-items-center">
                                            <i id="minStatusIcon"
                                                class="bi <%= calibrationStatus.minCalibrated ? 'bi-check-circle-fill text-success' : 'bi-circle text-muted' %> me-2"></i>
                                            <span>Min Position</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="d-flex align-items-center">
                                            <i id="maxStatusIcon"
                                                class="bi <%= calibrationStatus.maxCalibrated ? 'bi-check-circle-fill text-success' : 'bi-circle text-muted' %> me-2"></i>
                                            <span>Max Position</span>
                                        </div>
                                    </div>
                                </div>
                                <% if (calibrationStatus.calibratedDate) { %>
                                    <small class="text-muted">Last calibrated: <%= new
                                            Date(calibrationStatus.calibratedDate).toLocaleString() %></small>
                                    <% } %>
                            </div>

                            <!-- Position Save Buttons -->
                            <div class="d-grid gap-2 mb-3">
                                <button class="btn btn-success" onclick="savePosition('min')">
                                    <i class="bi bi-bookmark-plus"></i> Save Min Position (Fully Retracted)
                                </button>
                                <button class="btn btn-warning" onclick="savePosition('max')">
                                    <i class="bi bi-bookmark-plus"></i> Save Max Position (Fully Extended)
                                </button>
                            </div>

                            <!-- Reset Button -->
                            <div class="d-grid">
                                <button class="btn btn-outline-danger" onclick="resetCalibration()">
                                    <i class="bi bi-arrow-clockwise"></i> Reset Calibration
                                </button>
                            </div>

                            <!-- Save Status -->
                            <div class="mt-3">
                                <div id="saveStatus" class="alert" style="display: none;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Instructions -->
            <div class="row mt-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0"><i class="bi bi-info-circle"></i> Calibration Instructions</h5>
                        </div>
                        <div class="card-body">
                            <ol>
                                <li><strong>Set Speed & Duration:</strong> Adjust the jog speed and duration for safe
                                    movement.</li>
                                <li><strong>Find Min Position:</strong> Use the "Retract" button to move the actuator to
                                    its
                                    fully retracted position.</li>
                                <li><strong>Save Min:</strong> Click "Save Min Position" when the actuator is fully
                                    retracted.</li>
                                <li><strong>Find Max Position:</strong> Use the "Extend" button to move the actuator to
                                    its
                                    fully extended position.</li>
                                <li><strong>Save Max:</strong> Click "Save Max Position" when the actuator is fully
                                    extended.</li>
                                <li><strong>Test:</strong> Use the jog controls to verify the actuator moves within the
                                    calibrated range.</li>
                            </ol>
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle"></i>
                                <strong>Safety:</strong> Always use the STOP button if the actuator moves unexpectedly.
                                Start with low speeds and short durations until you're familiar with the movement.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <script src="/js/monsterbox4.js"></script>
        <script>
            const partId = '<%= part.id %>';

            // Sync range sliders with number inputs
            document.getElementById('jogSpeed').addEventListener('input', function () {
                document.getElementById('jogSpeedValue').value = this.value;
            });

            document.getElementById('jogSpeedValue').addEventListener('input', function () {
                document.getElementById('jogSpeed').value = this.value;
            });

            document.getElementById('jogDuration').addEventListener('input', function () {
                document.getElementById('jogDurationValue').value = this.value;
            });

            document.getElementById('jogDurationValue').addEventListener('input', function () {
                document.getElementById('jogDuration').value = this.value;
            });

            // Show status message
            function showStatus(elementId, message, type = 'info') {
                const element = document.getElementById(elementId);
                element.className = `alert alert-${type}`;
                element.textContent = message;
                element.style.display = 'block';

                // Auto-hide after 3 seconds for success messages
                if (type === 'success') {
                    setTimeout(function () {
                        element.style.display = 'none';
                    }, 3000);
                }
            }

            // Jog actuator
            async function jogActuator(direction) {
                const speed = parseInt(document.getElementById('jogSpeedValue').value);
                const duration = parseInt(document.getElementById('jogDurationValue').value);

                // Disable buttons during movement
                setButtonsEnabled(false);
                showStatus('jogStatus', `${direction === 'extend' ? 'Extending' : 'Retracting'} actuator...`, 'info');

                try {
                    const response = await fetch(`/setup/calibration/api/linear_actuator/${partId}/jog`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            direction: direction,
                            speed: speed,
                            duration: duration
                        })
                    });

                    const result = await response.json();

                    if (result.success) {
                        showStatus('jogStatus', result.message, 'success');
                    } else {
                        showStatus('jogStatus', result.error || 'Jog command failed', 'danger');
                    }
                } catch (error) {
                    console.error('Error jogging actuator:', error);
                    showStatus('jogStatus', 'Network error: ' + error.message, 'danger');
                } finally {
                    // Re-enable buttons after movement duration + buffer
                    setTimeout(function () {
                        setButtonsEnabled(true);
                    }, duration + 200);
                }
            }

            // Stop actuator
            async function stopActuator() {
                showStatus('jogStatus', 'Stopping actuator...', 'warning');

                try {
                    const response = await fetch(`/setup/calibration/api/linear_actuator/${partId}/stop`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    const result = await response.json();

                    if (result.success) {
                        showStatus('jogStatus', result.message, 'success');
                        setButtonsEnabled(true);
                    } else {
                        showStatus('jogStatus', result.error || 'Stop command failed', 'danger');
                    }
                } catch (error) {
                    console.error('Error stopping actuator:', error);
                    showStatus('jogStatus', 'Network error: ' + error.message, 'danger');
                }
            }

            // Save calibration position
            async function savePosition(position) {
                const description = position === 'min' ? 'Fully retracted position' : 'Fully extended position';

                showStatus('saveStatus', `Saving ${position} position...`, 'info');

                try {
                    const response = await fetch(`/setup/calibration/api/linear_actuator/${partId}/save-position`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            position: position,
                            description: description
                        })
                    });

                    const result = await response.json();

                    if (result.success) {
                        showStatus('saveStatus', result.message, 'success');
                        updateCalibrationStatus(position, true);
                    } else {
                        showStatus('saveStatus', result.error || 'Save failed', 'danger');
                    }
                } catch (error) {
                    console.error('Error saving position:', error);
                    showStatus('saveStatus', 'Network error: ' + error.message, 'danger');
                }
            }

            // Reset calibration
            async function resetCalibration() {
                if (!confirm('Are you sure you want to reset the calibration? This will remove all saved positions.')) {
                    return;
                }

                showStatus('saveStatus', 'Resetting calibration...', 'warning');

                try {
                    const response = await fetch(`/setup/calibration/api/linear_actuator/${partId}/reset`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    const result = await response.json();

                    if (result.success) {
                        showStatus('saveStatus', result.message, 'success');
                        updateCalibrationStatus('min', false);
                        updateCalibrationStatus('max', false);
                    } else {
                        showStatus('saveStatus', result.error || 'Reset failed', 'danger');
                    }
                } catch (error) {
                    console.error('Error resetting calibration:', error);
                    showStatus('saveStatus', 'Network error: ' + error.message, 'danger');
                }
            }

            // Update calibration status icons
            function updateCalibrationStatus(position, calibrated) {
                const icon = document.getElementById(position + 'StatusIcon');
                if (calibrated) {
                    icon.className = 'bi bi-check-circle-fill text-success me-2';
                } else {
                    icon.className = 'bi bi-circle text-muted me-2';
                }
            }

            // Enable/disable control buttons
            function setButtonsEnabled(enabled) {
                document.getElementById('extendBtn').disabled = !enabled;
                document.getElementById('retractBtn').disabled = !enabled;
            }
        </script>
