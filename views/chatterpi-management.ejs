<!DOCTYPE html>
<html lang="en" data-theme="monsterbox">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'ChatterPi Management' %></title>
    
    <!-- Preload critical fonts -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&family=Creepster&display=swap" as="style">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&family=Creepster&display=swap">
    
    <!-- MonsterBox CSS -->
    <link rel="stylesheet" href="/css/main.css?v=<%= Date.now() %>">
    
    <!-- Favicon and meta tags -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <meta name="description" content="ChatterPi - Character Management">
    <meta name="theme-color" content="#00ff00">
</head>

<body class="min-h-screen bg-base-100 text-base-content font-terminal">
    <!-- Skip to main content for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 button z-50">
        Skip to main content
    </a>

    <!-- Navigation -->
    <nav class="navbar bg-base-200 border-b border-primary shadow-lg sticky top-0 z-40">
        <div class="container mx-auto px-4">
            <div class="navbar-start">
                <!-- Logo -->
                <a href="/" class="button ghost text-xl font-creepster text-primary hover:text-green-600">
                    🎭 MonsterBox™
                </a>
            </div>
            
            <!-- Navigation Links -->
            <div class="navbar-center hidden lg:flex">
                <ul class="menu menu-horizontal px-1">
                    <li><a href="/characters" class="button ghost">🎭 Characters</a></li>
                    <li><a href="/ai-management" class="button ghost">🤖 AI Management</a></li>
                    <li><a href="/configuration" class="button ghost">⚙️ Configuration</a></li>
                </ul>
            </div>
            
            <!-- User actions -->
            <div class="navbar-end">
                <a href="/" class="button ghost" aria-label="Home">
                    🏠 Home
                </a>
            </div>
        </div>
    </nav>

    <!-- Main content -->
    <main id="main-content" class="flex-1 container mx-auto px-4 py-8">
        <!-- Breadcrumbs -->
        <% if (typeof breadcrumbs !== 'undefined' && breadcrumbs.length > 0) { %>
        <%- include('components/button-components', {
            component: 'breadcrumb',
            items: breadcrumbs
        }) %>
        <% } %>

        <!-- Page title -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-primary font-creepster mb-2 glow-text">
                🎭 <%= pageTitle %>
            </h1>
            <% if (typeof pageDescription !== 'undefined') { %>
            <p class="text-base-content/70 text-lg">
                <%= pageDescription %>
            </p>
            <% } %>
        </div>

        <!-- Connection Status -->
        <div class="alert mb-6" id="connection-status">
            <div class="flex items-center">
                <div class="loading loading-spinner loading-sm mr-2" id="status-spinner"></div>
                <span id="status-text">Checking connection...</span>
            </div>
        </div>

        <!-- Main Control Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6 mb-8">
            
            <!-- Character Selection -->
            <div class="card bg-base-200 shadow-xl border border-primary">
                <div class="card-header bg-base-300 border-b border-primary">
                    <h3 class="text-xl font-bold text-primary flex items-center">
                        🎭 Character Selection
                    </h3>
                </div>
                <div class="card-body">
                    <div class="form-control w-full">
                        <label class="label">
                            <span class="label-text text-base-content">Active Character:</span>
                        </label>
                        <select id="character-selector" class="select select-bordered select-primary w-full">
                            <% if (typeof characters !== 'undefined') { %>
                                <% characters.forEach(function(character) { %>
                                    <option value="<%= character.id %>" <%= defaultCharacter && defaultCharacter.id === character.id ? 'selected' : '' %>>
                                        <%= character.name %> (ID: <%= character.id %>)
                                    </option>
                                <% }); %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="mt-4">
                        <button class="button primary w-full" onclick="loadCharacterConfig()">
                            📥 Load Character Settings
                        </button>
                    </div>
                </div>
            </div>


        </div>







        <!-- Real-time Feedback Overlay -->
        <div id="feedbackOverlay" class="fixed bottom-4 left-4 z-40 space-y-2" style="display: none;">
            <div class="alert alert-info shadow-lg max-w-sm">
                <div>
                    <span id="feedbackText">Configuration applied successfully</span>
                </div>
            </div>
        </div>

        <!-- Messages -->
        <div id="messageContainer" class="fixed top-4 right-4 z-50 space-y-2"></div>
    </main>

    <!-- Footer -->
    <footer class="footer footer-center p-6 bg-base-200 text-base-content border-t border-primary">
        <div>
            <p class="font-bold text-primary font-creepster">ChatterPi™ Character Management</p>
            <p>AI-powered character interaction and voice configuration</p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="/js/chatterpi-management.js"></script>
</body>
</html>
