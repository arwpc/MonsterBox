<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Agent Management - MonsterBox 4.0</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
    <!-- Navigation (consistent with MonsterBox 4.0 design) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="bi bi-robot"></i> MonsterBox 4.0</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> Dashboard</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-gear"></i> Setup
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/setup/parts"><i class="bi bi-cpu"></i> Parts</a></li>
                            <li><a class="dropdown-item" href="/setup/calibration"><i class="bi bi-sliders"></i>
                                    Calibration</a></li>
                            <li><a class="dropdown-item" href="/setup/poses"><i class="bi bi-person-arms-up"></i>
                                    Poses</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/audio"><i class="bi bi-volume-up"></i> Audio</a>
                            </li>
                            <li><a class="dropdown-item" href="/setup/webcam"><i class="bi bi-camera-video"></i>
                                    Webcam</a></li>
                            <li><a class="dropdown-item" href="/setup/super-powers"><i class="bi bi-lightning"></i>
                                    Super Powers</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/system"><i class="bi bi-pc-display"></i>
                                    System</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/live"><i class="bi bi-play-circle"></i> Live
                            Mode</a></li>
                    <li class="nav-item"><a class="nav-link" href="/scenes"><i class="bi bi-film"></i> Scenes</a></li>
                </ul>
                <%- include('../partials/characterMenu') %>
            </div>
        </div>
    </nav>

    <main class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1><i class="bi bi-robot"></i> AI Agent Management</h1>
                    <div>
                        <a href="/ai-settings" class="btn btn-outline-secondary me-2">
                            <i class="bi bi-arrow-left"></i> Back to AI Settings
                        </a>
                        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createAgentModal">
                            <i class="bi bi-plus-circle"></i> Create Agent
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Agents List -->
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-list"></i> Your AI Agents
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="agentsList">
                            <div class="text-center">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2">Loading agents...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Available Models -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-cpu"></i> Available LLM Models
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="availableModels">
                            <div class="text-center">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2">Loading models...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Create Agent Modal -->
    <div class="modal fade" id="createAgentModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-plus-circle"></i> Create New Agent
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="createAgentForm">
                        <!-- Basic Information -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="agentName" class="form-label">Agent Name *</label>
                                    <input type="text" class="form-control" id="agentName" name="name" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="agentLanguage" class="form-label">Language</label>
                                    <select class="form-select" id="agentLanguage" name="language">
                                        <option value="en">English</option>
                                        <option value="es">Spanish</option>
                                        <option value="fr">French</option>
                                        <option value="de">German</option>
                                        <option value="it">Italian</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Model and Voice -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="agentModel" class="form-label">LLM Model *</label>
                                    <select class="form-select" id="agentModel" name="model" required>
                                        <option value="">Select model...</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="agentVoice" class="form-label">Voice *</label>
                                    <select class="form-select" id="agentVoice" name="voice_id" required>
                                        <option value="">Select voice...</option>
                                    </select>
                                    <button type="button" class="btn btn-sm btn-outline-primary mt-1" id="previewVoice">
                                        <i class="bi bi-play"></i> Preview Voice
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Configuration -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="maxDuration" class="form-label">Max Duration (seconds)</label>
                                    <input type="number" class="form-control" id="maxDuration" name="max_duration"
                                        min="30" max="600" value="300">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="agentTemplate" class="form-label">Character Template</label>
                                    <select class="form-select" id="agentTemplate">
                                        <option value="">Custom</option>
                                        <option value="Orlok">Orlok (Vampire)</option>
                                        <option value="Witch">Witch</option>
                                        <option value="Ghost">Ghost</option>
                                        <option value="Pirate">Pirate</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Prompt -->
                        <div class="mb-3">
                            <label for="agentPrompt" class="form-label">System Prompt *</label>
                            <textarea class="form-control" id="agentPrompt" name="prompt" rows="4" required
                                placeholder="Define your agent's personality, behavior, and response style..."></textarea>
                            <div class="form-text">
                                This prompt defines how your agent will behave and respond to trick-or-treaters.
                            </div>
                        </div>

                        <!-- First Message -->
                        <div class="mb-3">
                            <label for="firstMessage" class="form-label">First Message</label>
                            <textarea class="form-control" id="firstMessage" name="first_message" rows="2"
                                placeholder="The first thing your agent will say when someone approaches..."></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-info" id="testAgent">
                        <i class="bi bi-play"></i> Test Agent
                    </button>
                    <button type="button" class="btn btn-success" id="saveAgent">
                        <i class="bi bi-check-circle"></i> Create Agent
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Agent Modal -->
    <div class="modal fade" id="editAgentModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-pencil"></i> Edit Agent
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="editAgentForm">
                        <input type="hidden" id="editAgentId" name="agentId">
                        <!-- Same form fields as create modal -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editAgentName" class="form-label">Agent Name *</label>
                                    <input type="text" class="form-control" id="editAgentName" name="name" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editAgentLanguage" class="form-label">Language</label>
                                    <select class="form-select" id="editAgentLanguage" name="language">
                                        <option value="en">English</option>
                                        <option value="es">Spanish</option>
                                        <option value="fr">French</option>
                                        <option value="de">German</option>
                                        <option value="it">Italian</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editAgentModel" class="form-label">LLM Model *</label>
                                    <select class="form-select" id="editAgentModel" name="model">
                                        <option value="">Select model...</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="editAgentVoice" class="form-label">Voice *</label>
                                    <select class="form-select" id="editAgentVoice" name="voice_id">
                                        <option value="">Select voice...</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="editAgentPrompt" class="form-label">System Prompt *</label>
                            <textarea class="form-control" id="editAgentPrompt" name="prompt" rows="4"
                                required></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="editAgentFirstMessage" class="form-label">First Message</label>
                            <textarea class="form-control" id="editAgentFirstMessage" name="first_message"
                                rows="2"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success" id="updateAgent">
                        <i class="bi bi-check-circle"></i> Update Agent
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Agent Chat Modal (standalone; not nested in other modals) -->
    <div class="modal fade" id="agentChatModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-chat-dots"></i> <span id="chatAgentTitle">Chat</span></h5>
                    <span id="wsConnectionStatus" class="badge bg-secondary me-2">Connecting...</span>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="chatLog" class="border rounded p-2 mb-3"
                        style="height: 300px; overflow:auto; background:#111;">
                        <div class="text-muted">Type a message to start chatting with the agent…</div>
                    </div>
                    <div class="input-group">
                        <input type="text" id="chatInput" class="form-control" placeholder="Say something spooky…"
                            onkeypress="if(event.key==='Enter' && window.agentsManager) window.agentsManager.sendChatMessage()">
                        <button class="btn btn-primary" type="button"
                            onclick="window.agentsManager && window.agentsManager.sendChatMessage()">
                            <i class="bi bi-send"></i> Send
                        </button>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="d-flex w-100 align-items-center justify-content-between">
                        <!-- Mic Source -->
                        <div class="btn-group" role="group" aria-label="Microphone Source Toggle">
                            <input type="radio" class="btn-check" name="micSource" id="micServer" autocomplete="off"
                                checked onchange="window.agentsManager && window.agentsManager.setMicSource('server')">
                            <label class="btn btn-outline-warning" for="micServer">
                                <i class="bi bi-mic"></i> Server Mic
                            </label>

                            <input type="radio" class="btn-check" name="micSource" id="micBrowser" autocomplete="off"
                                onchange="window.agentsManager && window.agentsManager.setMicSource('browser')">
                            <label class="btn btn-outline-info" for="micBrowser" title="Requires HTTPS (or localhost)">
                                <i class="bi bi-mic-fill"></i> Browser Mic
                            </label>
                        </div>

                        <!-- Audio Output -->
                        <div class="btn-group" role="group" aria-label="Audio Output Toggle">
                            <input type="radio" class="btn-check" name="audioOutput" id="audioLocal" autocomplete="off"
                                checked onchange="window.agentsManager && window.agentsManager.setAudioOutput('local')">
                            <label class="btn btn-outline-primary" for="audioLocal">
                                <i class="bi bi-headphones"></i> Local
                            </label>

                            <input type="radio" class="btn-check" name="audioOutput" id="audioSpeaker"
                                autocomplete="off"
                                onchange="window.agentsManager && window.agentsManager.setAudioOutput('speaker')">
                            <label class="btn btn-outline-success" for="audioSpeaker">
                                <i class="bi bi-speaker"></i> Speaker
                            </label>

                            <!-- VU Meter -->
                            <div class="flex-grow-1 mx-3" style="max-width:300px;">
                                <div class="small text-muted mb-1"><i class="bi bi-activity"></i> Mic Level</div>
                                <div class="progress" style="height:10px; background:#222;">
                                    <div id="chatVUMeterBar" class="progress-bar bg-warning" role="progressbar"
                                        style="width:0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <div class="small text-muted mt-2" id="chatStatusLine">
                                    <span>Character: <span id="chatStatusCharacter">-</span></span>
                                    &nbsp;&middot;&nbsp;
                                    <span>Server Mic: <span id="chatStatusDevice">-</span></span>
                                    &nbsp;&middot;&nbsp;
                                    <span>STT: <span id="chatStatusSTT">-</span></span>
                                </div>
                            </div>

                        </div>

                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/websocket-chat.js"></script>
    <script src="/js/ai-settings-agents.js"></script>
    <script src="/js/character-menu.js"></script>
</body>

</html>