<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Settings - MonsterBox 4.0</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
    <!-- Navigation (consistent with MonsterBox 4.0 design) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="bi bi-robot"></i> MonsterBox 4.0</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> Dashboard</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-gear"></i> Setup
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/setup/parts"><i class="bi bi-cpu"></i> Parts</a></li>
                            <li><a class="dropdown-item" href="/setup/calibration"><i class="bi bi-sliders"></i>
                                    Calibration</a></li>
                            <li><a class="dropdown-item" href="/setup/poses"><i class="bi bi-person-arms-up"></i>
                                    Poses</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/audio"><i class="bi bi-volume-up"></i> Audio</a>
                            </li>
                            <li><a class="dropdown-item" href="/setup/webcam"><i class="bi bi-camera-video"></i>
                                    Webcam</a></li>
                            <li><a class="dropdown-item" href="/ai-settings"><i class="bi bi-brain"></i> AI Settings</a>
                            </li>
                            <li><a class="dropdown-item" href="/setup/super-powers"><i class="bi bi-lightning"></i>
                                    Super Powers</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/system"><i class="bi bi-pc-display"></i>
                                    System</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link active" href="/ai-settings"><i class="bi bi-brain"></i> AI
                            Settings</a></li>
                    <li class="nav-item"><a class="nav-link" href="/live"><i class="bi bi-play-circle"></i> Live
                            Mode</a></li>
                    <li class="nav-item"><a class="nav-link" href="/scenes"><i class="bi bi-film"></i> Scenes</a></li>
                </ul>
                <%- include('../partials/characterMenu') %>
            </div>
        </div>
    </nav>

    <main class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1><i class="bi bi-brain"></i> AI Settings</h1>
                    <button class="btn btn-primary" id="testConnection">
                        <i class="bi bi-plug"></i> Test Connection
                    </button>
                </div>
            </div>
        </div>

        <!-- Configuration Status -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-info-circle"></i> ElevenLabs Configuration Status
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">API Key Status</label>
                                    <div id="apiKeyStatus" class="d-flex align-items-center">
                                        <div class="spinner-border spinner-border-sm me-2" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <span>Checking configuration...</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Connection Status</label>
                                    <div id="connectionStatus" class="d-flex align-items-center">
                                        <div class="spinner-border spinner-border-sm me-2" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <span>Testing connection...</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- AI Settings Dashboard -->
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-mic display-4 text-primary mb-3"></i>
                        <h5 class="card-title">Speech-to-Text</h5>
                        <p class="card-text">Configure STT models and audio processing for voice input.</p>
                        <a href="/ai-settings/stt" class="btn btn-primary">
                            <i class="bi bi-arrow-right"></i> Configure STT
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-robot display-4 text-success mb-3"></i>
                        <h5 class="card-title">AI Agents</h5>
                        <p class="card-text">Create and manage conversational AI agents for characters.</p>
                        <a href="/ai-settings/agents" class="btn btn-success">
                            <i class="bi bi-arrow-right"></i> Manage Agents
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-volume-up display-4 text-warning mb-3"></i>
                        <h5 class="card-title">Text-to-Speech</h5>
                        <p class="card-text">Configure voices and TTS settings for audio output.</p>
                        <a href="/ai-settings/tts" class="btn btn-warning">
                            <i class="bi bi-arrow-right"></i> Configure TTS
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-person-check display-4 text-info mb-3"></i>
                        <h5 class="card-title">Character Assignment</h5>
                        <p class="card-text">Assign AI agents to animatronic characters.</p>
                        <a href="/ai-settings/character-assignment" class="btn btn-info">
                            <i class="bi bi-arrow-right"></i> Assign Characters
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="row g-4 mt-4">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-graph-up"></i> AI Integration Status
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="text-center">
                                    <div class="display-6 text-primary" id="agentCount">-</div>
                                    <small class="text-muted">AI Agents</small>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-center">
                                    <div class="display-6 text-success" id="voiceCount">-</div>
                                    <small class="text-muted">Available Voices</small>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-center">
                                    <div class="display-6 text-warning" id="characterCount">-</div>
                                    <small class="text-muted">Characters</small>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-center">
                                    <div class="display-6 text-info" id="assignmentCount">-</div>
                                    <small class="text-muted">Assignments</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-tools"></i> Quick Actions
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-primary" id="createAgent">
                                <i class="bi bi-plus-circle"></i> Create New Agent
                            </button>
                            <button class="btn btn-outline-success" id="testConversation">
                                <i class="bi bi-chat-dots"></i> Test Conversation
                            </button>
                            <button class="btn btn-outline-info" id="viewLogs">
                                <i class="bi bi-journal-text"></i> View AI Logs
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/ai-settings.js"></script>
</body>

</html>