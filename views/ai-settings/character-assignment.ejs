<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Character Assignment - MonsterBox 4.0</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
    <!-- Navigation (consistent with MonsterBox 4.0 design) -->
    <!-- Unified Navigation - Same on ALL pages -->
    <%- include('../components/unified-navigation', { page: 'ai-settings-assignment' }) %>

        <main class="container-fluid py-4">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1><i class="bi bi-person-check"></i> Character Assignment</h1>
                        <div>
                            <a href="/ai-settings" class="btn btn-outline-secondary me-2">
                                <i class="bi bi-arrow-left"></i> Back to AI Settings
                            </a>
                            <button class="btn btn-success" id="saveAllAssignments">
                                <i class="bi bi-check-circle"></i> Save All Assignments
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Current Character Selection -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-person"></i> Current Character
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label for="currentCharacter" class="form-label">Selected Character</label>
                                        <select class="form-select" id="currentCharacter">
                                            <option value="">Loading characters...</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label for="currentAgent" class="form-label">Assigned Agent</label>
                                        <select class="form-select" id="currentAgent">
                                            <option value="">No agent assigned</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label class="form-label">Actions</label>
                                        <div class="d-grid">
                                            <button type="button" class="btn btn-primary" id="testCurrentAssignment">
                                                <i class="bi bi-play-circle"></i> Test Assignment
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- All Character Assignments -->
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-list"></i> All Character Assignments
                            </h5>
                        </div>
                        <div class="card-body">
                            <div id="characterAssignments">
                                <div class="text-center">
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <p class="mt-2">Loading character assignments...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Assignment Tools -->
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-tools"></i> Quick Assignment Tools
                            </h5>
                        </div>
                        <div class="card-body">
                            <h6>Auto-Create Agents</h6>
                            <p class="small text-muted">Automatically create agents for characters without assignments
                            </p>
                            <div class="mb-3">
                                <label for="defaultVoice" class="form-label">Default Voice</label>
                                <select class="form-select" id="defaultVoice">
                                    <option value="">Select default voice...</option>
                                </select>
                            </div>
                            <div class="d-grid gap-2 mb-4">
                                <button type="button" class="btn btn-primary" id="autoCreateAgents">
                                    <i class="bi bi-magic"></i> Auto-Create Missing Agents
                                </button>
                            </div>

                            <h6>Bulk Operations</h6>
                            <p class="small text-muted">Perform operations on multiple assignments</p>
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-outline-info" id="testAllAssignments">
                                    <i class="bi bi-play-circle"></i> Test All Assignments
                                </button>
                                <button type="button" class="btn btn-outline-warning" id="clearAllAssignments">
                                    <i class="bi bi-x-circle"></i> Clear All Assignments
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Assignment Statistics -->
                    <div class="card mt-4">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-graph-up"></i> Assignment Statistics
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-6">
                                    <div class="display-6 text-success" id="assignedCount">-</div>
                                    <small class="text-muted">Assigned</small>
                                </div>
                                <div class="col-6">
                                    <div class="display-6 text-warning" id="unassignedCount">-</div>
                                    <small class="text-muted">Unassigned</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <!-- Assignment Test Modal -->
        <div class="modal fade" id="assignmentTestModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-play-circle"></i> Test Character-Agent Assignment
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <strong>Character:</strong> <span id="testCharacterName">-</span><br>
                            <strong>Agent:</strong> <span id="testAgentName">-</span>
                        </div>
                        <div class="mb-3">
                            <label for="testConversationMessage" class="form-label">Test Message</label>
                            <input type="text" class="form-control" id="testConversationMessage"
                                value="Hello! I'm trick-or-treating tonight!">
                        </div>
                        <div id="conversationTestResults" class="mt-4" style="display: none;">
                            <h6>Conversation Test Results:</h6>
                            <div class="card bg-dark border-secondary">
                                <div class="card-body">
                                    <div class="mb-2">
                                        <strong>Agent Response:</strong>
                                        <div id="agentResponseText"></div>
                                    </div>
                                    <div class="mb-2">
                                        <strong>Audio Generated:</strong>
                                        <span id="audioStatus" class="badge bg-secondary">-</span>
                                    </div>
                                    <div>
                                        <audio id="testAudio" controls class="w-100" style="display: none;">
                                            Your browser does not support the audio element.
                                        </audio>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="button" class="btn btn-primary" id="runConversationTest">
                            <i class="bi bi-play-circle"></i> Run Test
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Create Agent for Character Modal -->
        <div class="modal fade" id="createAgentForCharacterModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-plus-circle"></i> Create Agent for Character
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <form id="createAgentForCharacterForm">
                            <input type="hidden" id="targetCharacterId" name="characterId">
                            <div class="mb-3">
                                <label class="form-label">Character</label>
                                <input type="text" class="form-control" id="targetCharacterName" readonly>
                            </div>
                            <div class="mb-3">
                                <label for="newAgentName" class="form-label">Agent Name</label>
                                <input type="text" class="form-control" id="newAgentName" name="name" required>
                            </div>
                            <div class="mb-3">
                                <label for="newAgentVoice" class="form-label">Voice</label>
                                <select class="form-select" id="newAgentVoice" name="voice_id" required>
                                    <option value="">Select voice...</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="newAgentTemplate" class="form-label">Character Template</label>
                                <select class="form-select" id="newAgentTemplate">
                                    <option value="">Custom</option>
                                    <option value="Orlok">Orlok (Vampire)</option>
                                    <option value="Witch">Witch</option>
                                    <option value="Ghost">Ghost</option>
                                    <option value="Pirate">Pirate</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="newAgentPrompt" class="form-label">System Prompt</label>
                                <textarea class="form-control" id="newAgentPrompt" name="prompt" rows="3"
                                    required></textarea>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-success" id="createAndAssignAgent">
                            <i class="bi bi-check-circle"></i> Create & Assign Agent
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="/js/character-menu.js"></script>
        <script src="/js/ai-settings-character-assignment.js"></script>
</body>

</html>