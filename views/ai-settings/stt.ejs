<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="bi bi-mic"></i> Speech-to-Text Settings</h1>
                <div>
                    <a href="/ai-settings" class="btn btn-outline-secondary me-2">
                        <i class="bi bi-arrow-left"></i> Back to AI Settings
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Character Banner -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="alert alert-info d-flex align-items-center mb-0" id="sttCharacterBanner">
                <i class="bi bi-person-badge me-2"></i>
                <strong>Currently tuning: </strong>
                <span id="sttCharacterName" class="ms-1">Loading...</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column: STT Configuration -->
        <div class="col-lg-8">

    <!-- Real-time Transcription - THE MOST IMPORTANT FEATURE -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-mic-fill"></i> Real-time Transcription
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-center mb-3">
                        <div class="col-auto">
                            <button type="button" class="btn btn-success btn-lg" id="startListening">
                                <i class="bi bi-record-circle"></i> Start Listening
                            </button>
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-danger btn-lg" id="stopListening"
                                style="opacity: 0.5; cursor: not-allowed;">
                                <i class="bi bi-stop-circle"></i> Stop Listening
                            </button>
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-outline-info" id="sttTwoSecTest">
                                <i class="bi bi-mic-fill"></i> 2s Test
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- STT Configuration -->
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-gear"></i> STT Configuration
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Filter Presets -->
                    <div class="alert alert-info mb-4">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-magic me-2"></i>
                            <strong>Quick Presets</strong>
                        </div>
                        <div class="row g-2" id="filterPresets">
                            <div class="col-12 text-muted small">Loading presets...</div>
                        </div>
                    </div>

                    <form id="sttConfigForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="sttModel" class="form-label">STT Model</label>
                                    <select class="form-select" id="sttModel" name="model">
                                        <option value="">Loading models...</option>
                                    </select>
                                    <small class="text-muted">
                                        <i class="bi bi-info-circle"></i> <strong>Scribe v2</strong> is recommended for
                                        best accuracy and multilingual support
                                    </small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="sttLanguage" class="form-label">Language</label>
                                    <select class="form-select" id="sttLanguage" name="language">
                                        <option value="en">English (Recommended)</option>
                                        <option value="es">Spanish</option>
                                        <option value="fr">French</option>
                                        <option value="de">German</option>
                                        <option value="it">Italian</option>
                                        <option value="pt">Portuguese</option>
                                        <option value="auto">Auto-detect (May transcribe in other languages)</option>
                                    </select>
                                    <small class="text-muted">
                                        <i class="bi bi-exclamation-triangle"></i> Auto-detect may transcribe background
                                        noise as foreign languages
                                    </small>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="sampleRate" class="form-label">Sample Rate</label>
                                    <select class="form-select" id="sampleRate" name="sampleRate">
                                        <option value="8000">8 kHz</option>
                                        <option value="16000" selected>16 kHz</option>
                                        <option value="22050">22.05 kHz</option>
                                        <option value="44100">44.1 kHz</option>
                                        <option value="48000">48 kHz</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Voice Activity Detection (VAD)</label>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="vadEnabled"
                                            name="vadEnabled" checked>
                                        <label class="form-check-label" for="vadEnabled">
                                            Enable VAD
                                        </label>
                                    </div>
                                    <small class="text-muted">Automatically detect when speech
                                        starts/stops</small>
                                </div>
                            </div>
                        </div>

                        <!-- Microphone Hardware Section -->
                        <hr class="my-4">
                        <h6 class="mb-3"><i class="bi bi-mic"></i> Microphone Hardware</h6>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="microphonePart" class="form-label">Microphone Part</label>
                                    <select class="form-select" id="microphonePart">
                                        <option value="">Loading microphone parts...</option>
                                    </select>
                                    <small class="text-muted">Select the microphone hardware for this character</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Input Gain <span id="inputGainLabel"
                                            class="text-muted">100%</span></label>
                                    <input type="range" class="form-range" id="inputGain" min="0" max="200" step="1"
                                        value="100">
                                    <small class="text-muted">Adjusted via PipeWire/PulseAudio (applies
                                        immediately)</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <button type="button" class="btn btn-info w-100 mt-4"
                                        id="testMicrophoneIntegration">
                                        <i class="bi bi-arrow-repeat"></i> Test Microphone → STT
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- VAD Tuning Section -->
                        <hr class="my-4">
                        <h6 class="mb-3"><i class="bi bi-activity"></i> Voice Activity Detection (VAD) Tuning</h6>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="vadThreshold" class="form-label">
                                        VAD Threshold:
                                        <span id="vadThresholdValue">0.40</span>
                                        <span id="vadThresholdLabel" class="ms-2 text-muted"
                                            style="display:none">40%</span>
                                    </label>
                                    <input type="range" class="form-range" id="vadThreshold" name="vadThreshold"
                                        min="0.05" max="0.95" step="0.05" value="0.40">
                                    <small class="text-muted">Lower = more sensitive (may pick up noise). Tune while
                                        watching VU meter.</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="vadSilenceDuration" class="form-label">
                                        Silence Duration: <span id="vadSilenceDurationValue">500</span>ms
                                    </label>
                                    <input type="range" class="form-range" id="vadSilenceDuration"
                                        name="vadSilenceDuration" min="100" max="2000" step="100" value="500">
                                    <small class="text-muted">How long to wait before ending speech</small>
                                </div>
                            </div>
                        </div>

                        <!-- Buffer Timing Section -->
                        <hr class="my-4">
                        <h6 class="mb-3"><i class="bi bi-clock-history"></i> Buffer Timing & Capture Settings</h6>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="captureChunkDuration" class="form-label">
                                        Capture Chunk Duration: <span id="captureChunkDurationValue">0.5</span>s
                                    </label>
                                    <input type="range" class="form-range" id="captureChunkDuration"
                                        name="captureChunkDuration" min="0.25" max="1.0" step="0.25" value="0.5">
                                    <small class="text-muted">Duration of each audio capture chunk (0.5s
                                        recommended)</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="sttThrottleInterval" class="form-label">
                                        STT Throttle Interval: <span id="sttThrottleIntervalValue">2500</span>ms
                                    </label>
                                    <input type="range" class="form-range" id="sttThrottleInterval"
                                        name="sttThrottleInterval" min="1000" max="5000" step="500" value="2500">
                                    <small class="text-muted">How often to send audio to STT service</small>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="minBufferDuration" class="form-label">
                                        Minimum Buffer Duration: <span id="minBufferDurationValue">2.5</span>s
                                    </label>
                                    <input type="range" class="form-range" id="minBufferDuration"
                                        name="minBufferDuration" min="1.0" max="5.0" step="0.5" value="2.5">
                                    <small class="text-muted">Minimum audio duration before transcription (2.5s captures
                                        full sentences)</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="maxBufferDuration" class="form-label">
                                        Maximum Buffer Duration: <span id="maxBufferDurationValue">6.0</span>s
                                    </label>
                                    <input type="range" class="form-range" id="maxBufferDuration"
                                        name="maxBufferDuration" min="3.0" max="10.0" step="1.0" value="6.0">
                                    <small class="text-muted">Maximum audio buffer size (6s allows long phrases)</small>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="microphoneInputGain" class="form-label">
                                        Microphone Input Gain: <span id="microphoneInputGainValue">70</span>%
                                    </label>
                                    <input type="range" class="form-range" id="microphoneInputGain"
                                        name="microphoneInputGain" min="25" max="100" step="5" value="70">
                                    <small class="text-muted">System microphone volume (70% prevents clipping)</small>
                                </div>
                            </div>
                        </div>

                        <!-- Audio Filtering Section -->
                        <hr class="my-4">
                        <h6 class="mb-3"><i class="bi bi-soundwave"></i> Audio Filtering</h6>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Audio Preprocessing</label>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="audioFilterEnabled"
                                            name="audioFilterEnabled" checked>
                                        <label class="form-check-label" for="audioFilterEnabled">
                                            Enable Bandpass & Denoise Filters
                                        </label>
                                    </div>
                                    <small class="text-muted">Removes background noise and non-speech
                                        frequencies</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="highpassFreq" class="form-label">
                                        Highpass Filter: <span id="highpassFreqValue">180</span>Hz
                                    </label>
                                    <input type="range" class="form-range" id="highpassFreq" name="highpassFreq"
                                        min="50" max="500" step="50" value="180">
                                    <small class="text-muted">Remove low-frequency rumble</small>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="lowpassFreq" class="form-label">
                                        Lowpass Filter: <span id="lowpassFreqValue">4200</span>Hz
                                    </label>
                                    <input type="range" class="form-range" id="lowpassFreq" name="lowpassFreq"
                                        min="2000" max="8000" step="200" value="4200">
                                    <small class="text-muted">Remove high-frequency hiss</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="denoiseLevel" class="form-label">
                                        Denoise Level: <span id="denoiseLevelValue">-22</span>dB
                                    </label>
                                    <input type="range" class="form-range" id="denoiseLevel" name="denoiseLevel"
                                        min="-50" max="-10" step="5" value="-22">
                                    <small class="text-muted">Noise reduction strength</small>
                                </div>
                            </div>
                        </div>

                        <!-- Text Filtering Section -->
                        <hr class="my-4">
                        <h6 class="mb-3"><i class="bi bi-filter"></i> Text Filtering</h6>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Sound Effects Filtering</label>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="filterSfx" name="filterSfx"
                                            checked>
                                        <label class="form-check-label" for="filterSfx">
                                            Filter Bracketed Sound Effects
                                        </label>
                                    </div>
                                    <small class="text-muted">Remove transcriptions like "(beep)", "(music)",
                                        etc.</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Language Validation</label>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="validateEnglish"
                                            name="validateEnglish" checked>
                                        <label class="form-check-label" for="validateEnglish">
                                            Validate English Text
                                        </label>
                                    </div>
                                    <small class="text-muted">Reject non-English or gibberish
                                        transcriptions</small>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="minLetterRatio" class="form-label">
                                        Min Letter Ratio: <span id="minLetterRatioValue">55</span>%
                                    </label>
                                    <input type="range" class="form-range" id="minLetterRatio" name="minLetterRatio"
                                        min="30" max="90" step="5" value="55">
                                    <small class="text-muted">Minimum percentage of letters in text</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Require Vowels</label>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="requireVowels"
                                            name="requireVowels" checked>
                                        <label class="form-check-label" for="requireVowels">
                                            Require At Least One Vowel
                                        </label>
                                    </div>
                                    <small class="text-muted">Reject consonant-only gibberish</small>
                                </div>
                            </div>
                        </div>
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Save Configuration
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

        </div><!-- end col-lg-8 -->

        <!-- Right Column: Sticky Transcript + VU Meter -->
        <div class="col-lg-4">
            <div style="position: sticky; top: 70px;">
                <div class="card border-primary mb-3">
                    <div class="card-header bg-primary text-white">
                        <h6 class="card-title mb-0">
                            <i class="bi bi-activity"></i> Live Transcript
                        </h6>
                    </div>
                    <div class="card-body p-2">
                        <div class="d-flex align-items-center mb-2">
                            <small class="text-muted me-2"
                                title="Amplified 10x for visibility. Speak to see levels spike.">
                                <i class="bi bi-activity"></i> Audio Input:
                            </small>
                            <div class="progress flex-grow-1" style="height: 20px;">
                                <div id="micVUMeter" class="progress-bar bg-success" role="progressbar"
                                    style="width: 0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <span id="micVULabel" class="ms-2 badge bg-secondary">0%</span>
                        </div>
                        <div id="liveTranscript" class="form-control bg-dark text-light font-monospace"
                            style="height: 150px; overflow-y: auto; font-size: 0.9rem;"></div>
                    </div>
                </div>
            </div>
        </div><!-- end col-lg-4 -->

    </div><!-- end row -->
</div>

<!-- STT page logic -->
<script src="/js/ai-settings-stt.js"></script>