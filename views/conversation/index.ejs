<script>
  try { if (navigator.webdriver) window.MB_TEST_MODE = true; } catch (e) { }
</script>

<link rel="stylesheet" href="/css/body-map.css">
<link rel="stylesheet" href="/css/lurk-mode.css">
<link rel="stylesheet" href="/css/dashboard.css">

<div class="container-fluid px-0 px-md-2">

  <!-- ════════════════════════════════════════════════════════════════════
       OPERATOR COMMAND BAR  (Phase 3 redesign, 2026-04)
       Sticky top bar; character · Lurk master · live status · scene
       transport · PANIC. Every element from the old Lurk bar keeps its
       ID so the lurk FSM script (line ~571) binds unchanged.
       ════════════════════════════════════════════════════════════════════ -->
  <div id="lurkBar" class="mb-opbar" role="toolbar" aria-label="Operator command bar">

    <!-- Character identity -->
    <div class="mb-opbar-character">
      <a href="/setup/characters" class="mb-opbar-avatar" id="opbarAvatar"
         data-bs-toggle="tooltip" data-bs-placement="bottom" title="Manage characters">
        <i class="bi bi-person-bounding-box"></i>
      </a>
      <div class="mb-opbar-id">
        <span class="mb-opbar-id-label">Character</span>
        <span class="mb-opbar-id-name" id="charName">—</span>
      </div>
    </div>

    <!-- Lurk master + live status indicators -->
    <div class="mb-opbar-lurk-group">
      <label class="mb-switch mb-opbar-lurk" data-bs-toggle="tooltip" data-bs-placement="bottom"
             title="Bring the character to life — enables AI, jaw, head, idle, motion sensor together.">
        <input type="checkbox" id="lurkToggle" class="lurk-toggle-input">
        <span class="mb-switch-track"><span class="mb-switch-thumb"></span></span>
        <span class="mb-opbar-lurk-label"><i class="bi bi-lightning-charge-fill"></i> Lurk</span>
      </label>
      <div id="lurkStatusIndicators" class="mb-opbar-status">
        <span class="mb-badge mb-badge-ai lurk-badge" id="lurkBadgeAI"
              data-bs-toggle="tooltip" data-bs-placement="bottom" title="AI Conversation"><i class="bi bi-chat-dots"></i> AI</span>
        <span class="mb-badge mb-badge-primary lurk-badge" id="lurkBadgeJaw"
              data-bs-toggle="tooltip" data-bs-placement="bottom" title="Jaw Animation"><i class="bi bi-soundwave"></i> Jaw</span>
        <span class="mb-badge mb-badge-info lurk-badge" id="lurkBadgeHead"
              data-bs-toggle="tooltip" data-bs-placement="bottom" title="Head Tracking"><i class="bi bi-eye"></i> Head</span>
        <span class="mb-badge mb-badge-warning lurk-badge" id="lurkBadgeIdle"
              data-bs-toggle="tooltip" data-bs-placement="bottom" title="Idle Movement"><i class="bi bi-person-walking"></i> Idle</span>
        <span class="mb-badge mb-badge-danger lurk-badge" id="lurkBadgeMotion"
              data-bs-toggle="tooltip" data-bs-placement="bottom" title="Motion Sensor"><i class="bi bi-radar"></i> Motion</span>
      </div>
      <span id="lurkStatus" class="mb-text-muted mb-mono mb-text-sm" aria-live="polite">Off</span>
    </div>

    <!-- Transport + PANIC -->
    <div class="mb-opbar-transport">
      <button id="opbarLoopAll" class="mb-btn mb-btn-secondary mb-btn-sm" type="button"
              data-bs-toggle="tooltip" data-bs-placement="bottom" title="Loop through every scene">
        <i class="bi bi-arrow-repeat"></i> <span>Loop</span>
      </button>
      <button id="opbarStopLoop" class="mb-btn mb-btn-secondary mb-btn-sm" type="button" style="display:none;"
              data-bs-toggle="tooltip" data-bs-placement="bottom" title="Stop the scene loop">
        <i class="bi bi-stop-fill"></i> <span>Stop Loop</span>
      </button>
      <button id="mbPanicBtn" class="mb-btn mb-btn-panic mb-opbar-panic" type="button"
              data-bs-toggle="tooltip" data-bs-placement="bottom"
              title="Stop everything — scenes, audio, Lurk, idle, head, jaw, AI. Shortcut: Esc Esc">
        <i class="bi bi-exclamation-octagon-fill"></i>
        <span class="mb-opbar-panic-label">Stop Everything</span>
      </button>
    </div>
  </div>

  <div class="px-2 px-md-3">

  <!-- ════════════════════════════════════════════════════════════════════
       HERO SECTION — Webcam + AI Chat side-by-side
       ════════════════════════════════════════════════════════════════════ -->
  <section class="mb-hero">
    <!-- Webcam — Primary View -->
    <div class="mb-panel mb-panel-accent" data-panel-id="webcam">
      <div class="mb-panel-header">
        <h2 class="mb-panel-title"><i class="bi bi-camera-video"></i> Live View</h2>
        <div class="mb-row-sm" style="align-items:center;">
          <span id="headTrackStatusBadge" class="mb-badge mb-badge-info" style="display:none;">Off</span>
          <small class="mb-text-muted mb-mono mb-text-xs" id="webcamHint"></small>
        </div>
      </div>
      <div class="mb-panel-body">
        <div class="mb-webcam-frame">
          <img id="webcamImg" src="" alt="Webcam Stream">
          <span id="clickTrackCountdown" class="mb-badge mb-badge-info mb-webcam-overlay" style="display:none;"></span>
        </div>
        <div id="webcamStatus" class="mb-webcam-status">Finding webcam…</div>
      </div>
    </div>

    <!-- Chat Panel — AI Conversation Portal -->
    <div class="mb-panel mb-panel-accent-ai" data-panel-id="chat">
      <div class="mb-panel-header">
        <h2 class="mb-panel-title">
          <i class="bi bi-chat-dots"></i>
          <span id="chatCharacterName">Loading…</span>
        </h2>
        <div class="mb-row-sm" style="align-items:center;">
          <select id="chatSpeakerSelect" class="mb-select" style="max-width: 130px; min-height: 28px; padding: 2px 8px; font-size: var(--mb-text-xs);"
                  data-bs-toggle="tooltip" data-bs-placement="bottom" title="Select output speaker device">
            <option value="">Auto</option>
          </select>
          <label class="mb-switch" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Connect to ElevenLabs conversational AI agent">
            <input type="checkbox" id="chatAiOnToggle">
            <span class="mb-switch-track"><span class="mb-switch-thumb"></span></span>
            <span class="mb-text-sm">AI</span>
          </label>
        </div>
      </div>
      <div class="mb-panel-body">
        <div id="chatLog" class="mb-chat-log">
          <div class="mb-text-muted mb-text-sm" style="text-align:center;">Chat will appear here…</div>
        </div>
        <div class="mb-chat-meter">
          <small class="mb-text-muted"><i class="bi bi-activity"></i></small>
          <div class="mb-meter" style="flex:1;">
            <div id="chatVUMeter" class="mb-meter-fill" style="width:0%;"></div>
          </div>
          <span id="chatVULabel" class="mb-badge">0%</span>
        </div>
        <div class="mb-chat-controls">
          <label class="mb-switch" data-bs-toggle="tooltip" data-bs-placement="top" title="Play AI speech through your browser speaker">
            <input type="checkbox" id="chatBrowserSpeaker">
            <span class="mb-switch-track"><span class="mb-switch-thumb"></span></span>
            <span class="mb-text-sm"><i class="bi bi-broadcast"></i> Browser Spk</span>
          </label>
          <label class="mb-switch" data-bs-toggle="tooltip" data-bs-placement="top" title="Send your browser microphone to the AI agent">
            <input type="checkbox" id="chatBrowserMic">
            <span class="mb-switch-track"><span class="mb-switch-thumb"></span></span>
            <span class="mb-text-sm"><i class="bi bi-mic"></i> Browser Mic</span>
          </label>
          <small id="chatAudioStatus" class="mb-text-info mb-text-xs"></small>
        </div>
        <div class="mb-chat-input">
          <div class="mb-input-group">
            <button class="mb-btn mb-btn-secondary mb-btn-sm" type="button" id="chatModeToggle"
                    data-bs-toggle="tooltip" data-bs-placement="top"
                    title="Switch between asking the AI and making the character say exact text"
                    style="min-width: 92px;">
              <i class="bi bi-chat-dots"></i> Ask AI
            </button>
            <input type="text" class="mb-input" id="chatInput" placeholder="Ask the character something…" autocomplete="off">
            <button class="mb-btn mb-btn-primary" type="button" id="chatSendBtn" aria-label="Send">
              <i class="bi bi-send"></i>
            </button>
          </div>
          <div id="sayStatus" class="mb-text-xs mb-text-muted" style="margin-top:4px;"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       SUPERPOWERS STRIP — Compact horizontal toggles
       ════════════════════════════════════════════════════════════════════ -->
  <section class="mb-superpowers" data-panel-id="monster-features" aria-label="Character superpowers">
    <label class="mb-switch" data-bs-toggle="tooltip" data-bs-placement="top" title="Sync jaw servo movement with audio playback">
      <input type="checkbox" id="jawToggle">
      <span class="mb-switch-track"><span class="mb-switch-thumb"></span></span>
      <span class="mb-text-sm"><i class="bi bi-soundwave"></i> Jaw</span>
    </label>
    <label class="mb-switch" data-bs-toggle="tooltip" data-bs-placement="top" title="Track visitors via webcam and move head servo to follow">
      <input type="checkbox" id="headTrackToggle">
      <span class="mb-switch-track"><span class="mb-switch-thumb"></span></span>
      <span class="mb-text-sm"><i class="bi bi-eye"></i> Head Track</span>
    </label>
    <label class="mb-switch" data-bs-toggle="tooltip" data-bs-placement="top" title="Listen to speech and repeat through character speaker">
      <input type="checkbox" id="parrotToggle">
      <span class="mb-switch-track"><span class="mb-switch-thumb"></span></span>
      <span class="mb-text-sm"><i class="bi bi-megaphone"></i> Parrot</span>
    </label>
    <label class="mb-switch" data-bs-toggle="tooltip" data-bs-placement="top" title="Enable idle movement loop with character personality">
      <input type="checkbox" id="idleToggle">
      <span class="mb-switch-track"><span class="mb-switch-thumb"></span></span>
      <span class="mb-text-sm"><i class="bi bi-person-walking"></i> Idle</span>
    </label>
    <label class="mb-switch" data-bs-toggle="tooltip" data-bs-placement="top" title="Monitor PIR motion sensor — detects nearby visitors and keeps animatronic awake">
      <input type="checkbox" id="motionSensorToggle">
      <span class="mb-switch-track"><span class="mb-switch-thumb"></span></span>
      <span class="mb-text-sm"><i class="bi bi-radar"></i> Motion</span>
    </label>
    <label class="mb-switch" data-bs-toggle="tooltip" data-bs-placement="top" title="Mute all audio output from character speaker">
      <input type="checkbox" id="speakerMuteToggle">
      <span class="mb-switch-track"><span class="mb-switch-thumb"></span></span>
      <span class="mb-text-sm"><i class="bi bi-volume-mute"></i> Mute</span>
    </label>
    <span class="mb-superpowers-spacer"></span>
    <button id="stopAllAudioBtn" class="mb-btn mb-btn-secondary mb-btn-sm"
            data-bs-toggle="tooltip" data-bs-placement="top" title="Stop all audio playback and loops">
      <i class="bi bi-stop-circle"></i> Stop Audio
    </button>
  </section>

  <!-- ════════════════════════════════════════════════════════════════════
       EXPANDABLE PANELS — Accordion for Scenes, Poses, Controls, etc.
       ════════════════════════════════════════════════════════════════════ -->
  <div class="accordion mb-2" id="dashboardAccordion">

    <!-- Scenes -->
    <div class="accordion-item" data-panel-id="scenes">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#collapseScenes">
          <i class="bi bi-grip-vertical me-1 panel-drag-handle" style="cursor:grab;opacity:0.5;" title="Drag to reorder"></i>
          <i class="bi bi-film me-2"></i> Scenes
          <span id="scenesQueueStatus" class="badge bg-secondary small ms-2" style="display:none;"></span>
        </button>
      </h2>
      <div id="collapseScenes" class="accordion-collapse collapse" data-bs-parent="#dashboardAccordion">
        <div class="accordion-body py-2">
          <div class="d-flex gap-1 mb-2">
            <button id="btnLoopAll" class="btn btn-sm btn-outline-success" title="Loop all scenes"><i class="bi bi-arrow-repeat"></i> Loop All</button>
            <button id="btnStopLoop" class="btn btn-sm btn-outline-danger" title="Stop loop" style="display:none;"><i class="bi bi-stop-fill"></i> Stop</button>
            <a href="/scenes" class="btn btn-sm btn-outline-secondary ms-auto" title="Animation Studio"><i class="bi bi-gear"></i> Studio</a>
          </div>
          <div id="scenesContainer" style="max-height: 350px; overflow-y: auto;">
            <div class="text-center text-muted py-3">
              <div class="spinner-border spinner-border-sm"></div>
              <p class="mt-2 mb-0 small">Loading scenes...</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Poses -->
    <div class="accordion-item" data-panel-id="poses">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#collapsePoses">
          <i class="bi bi-grip-vertical me-1 panel-drag-handle" style="cursor:grab;opacity:0.5;" title="Drag to reorder"></i>
          <i class="bi bi-person-arms-up me-2"></i> Poses
        </button>
      </h2>
      <div id="collapsePoses" class="accordion-collapse collapse" data-bs-parent="#dashboardAccordion">
        <div class="accordion-body py-2">
          <div class="d-flex mb-2">
            <a href="/poses/editor" class="btn btn-sm btn-outline-secondary ms-auto"><i class="bi bi-pencil"></i> Pose Editor</a>
          </div>
          <div id="posesContainer" style="max-height: 300px; overflow-y: auto;">
            <div class="text-center text-muted py-3">
              <div class="spinner-border spinner-border-sm"></div>
              <p class="mt-2 mb-0 small">Loading poses...</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Manual Controls -->
    <div class="accordion-item" data-panel-id="manual-controls">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#collapseManual">
          <i class="bi bi-grip-vertical me-1 panel-drag-handle" style="cursor:grab;opacity:0.5;" title="Drag to reorder"></i>
          <i class="bi bi-joystick me-2"></i> Manual Controls
          <span class="badge bg-secondary small ms-2" id="mcItemCount">0 items</span>
        </button>
      </h2>
      <div id="collapseManual" class="accordion-collapse collapse" data-bs-parent="#dashboardAccordion">
        <div class="accordion-body py-2" id="manual-controls-card">
          <div id="mcBodyMapWrap">
            <!-- Left: SVG body silhouette + peripherals -->
            <div id="mcBodyMapCol">
              <svg id="mcBodyMap" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 340" style="width:200px;height:auto;"></svg>
              <div id="mcPeripherals"></div>
            </div>
            <!-- Right: control panel + quick actions -->
            <div id="mcControlCol">
              <div id="mcControlPanel"></div>
              <div id="mcQuickActions"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Live Console -->
    <div class="accordion-item" data-panel-id="console">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#collapseConsole">
          <i class="bi bi-grip-vertical me-1 panel-drag-handle" style="cursor:grab;opacity:0.5;" title="Drag to reorder"></i>
          <i class="bi bi-terminal me-2"></i> Live Console
        </button>
      </h2>
      <div id="collapseConsole" class="accordion-collapse collapse" data-bs-parent="#dashboardAccordion">
        <div class="accordion-body py-2">
          <div class="d-flex gap-1 align-items-center mb-2">
            <select id="consoleLines" class="form-select form-select-sm" style="width: auto; font-size: 0.75rem;">
              <option value="50">50</option>
              <option value="100" selected>100</option>
              <option value="200">200</option>
              <option value="500">500</option>
            </select>
            <div class="form-check form-switch mb-0 ms-1">
              <input class="form-check-input" type="checkbox" id="consoleLive" checked>
              <label class="form-check-label small" for="consoleLive">Live</label>
            </div>
            <button class="btn btn-sm btn-outline-secondary" id="btnConsoleRefresh" title="Refresh"><i class="bi bi-arrow-clockwise"></i></button>
          </div>
          <pre id="consoleOutput" class="mb-0 p-2" style="height: 250px; overflow-y: auto; font-size: 0.75rem; white-space: pre-wrap; word-break: break-all; background: var(--mb-terminal-bg, #0a0a0a); color: var(--mb-terminal-text, #0f0); margin: 0; resize: vertical;">Loading console...</pre>
        </div>
      </div>
    </div>

    <!-- Browser Audio Bridge -->
    <div class="accordion-item" data-panel-id="audio-bridge">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAudioBridge">
          <i class="bi bi-grip-vertical me-1 panel-drag-handle" style="cursor:grab;opacity:0.5;" title="Drag to reorder"></i>
          <i class="bi bi-headset me-2"></i> Browser Audio Bridge
        </button>
      </h2>
      <div id="collapseAudioBridge" class="accordion-collapse collapse" data-bs-parent="#dashboardAccordion">
        <div class="accordion-body py-2">
          <div class="row">
            <!-- Listen In: Browser Speaker -->
            <div class="col-md-6 mb-2 mb-md-0">
              <div class="card bg-dark border-info">
                <div class="card-header bg-dark text-info border-info py-1">
                  <small class="fw-bold"><i class="bi bi-headphones"></i> Listen In</small>
                </div>
                <div class="card-body py-2">
                  <div class="mb-1">
                    <select id="bridge-listenin-source" class="form-select form-select-sm" style="font-size: 0.75rem;">
                      <option value="default">System Default Input</option>
                    </select>
                  </div>
                  <div class="mb-1">
                    <div class="d-flex align-items-center gap-1">
                      <small class="text-muted" style="min-width: 28px;">Vol</small>
                      <input type="range" id="bridge-listenin-volume" class="form-range form-range-sm" min="0" max="100" value="75" step="5" style="height: 16px;">
                    </div>
                  </div>
                  <div class="d-flex align-items-center gap-2 mb-1">
                    <div class="progress flex-grow-1" style="height: 8px;">
                      <div id="bridge-listenin-vu" class="progress-bar bg-success" style="width: 0%"></div>
                    </div>
                    <span id="bridge-listenin-vu-label" class="badge bg-secondary" style="font-size: 0.6rem; min-width: 28px;">0%</span>
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <button id="btn-bridge-listenin" class="btn btn-info btn-sm" type="button" style="font-size: 0.7rem;">
                      <i class="bi bi-headphones"></i> <span id="bridge-listenin-text">Start</span>
                    </button>
                    <span id="bridge-listenin-status" class="badge bg-secondary" style="font-size: 0.6rem;">Off</span>
                  </div>
                </div>
              </div>
            </div>
            <!-- Talk Through: Browser Mic -->
            <div class="col-md-6">
              <div class="card bg-dark border-warning">
                <div class="card-header bg-dark text-warning border-warning py-1">
                  <small class="fw-bold"><i class="bi bi-mic-fill"></i> Talk Through</small>
                </div>
                <div class="card-body py-2">
                  <div class="mb-1">
                    <select id="bridge-talkthrough-sink" class="form-select form-select-sm" style="font-size: 0.75rem;">
                      <option value="default">System Default Output</option>
                    </select>
                  </div>
                  <div class="d-flex align-items-center gap-2 mb-1">
                    <div class="progress flex-grow-1" style="height: 8px;">
                      <div id="bridge-talkthrough-vu" class="progress-bar bg-success" style="width: 0%"></div>
                    </div>
                    <span id="bridge-talkthrough-vu-label" class="badge bg-secondary" style="font-size: 0.6rem; min-width: 28px;">0%</span>
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <button id="btn-bridge-talkthrough" class="btn btn-warning btn-sm" type="button" style="font-size: 0.7rem;">
                      <i class="bi bi-mic-fill"></i> <span id="bridge-talkthrough-text">Start</span>
                    </button>
                    <span id="bridge-talkthrough-status" class="badge bg-secondary" style="font-size: 0.6rem;">Off</span>
                  </div>
                  <div id="bridge-talkthrough-https-warn" class="alert alert-warning small mt-1 mb-0 py-1 d-none" style="font-size: 0.7rem;">
                    <i class="bi bi-shield-lock"></i> Requires HTTPS or localhost.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /accordion -->

  </div><!-- /px-2 px-md-3 wrapper -->
</div><!-- /container-fluid -->

<script src="/js/manual-controls.js"></script>

<!-- Dashboard client logic (extracted v8.1.1 — see /public/js/dashboard.js). -->
<script src="/js/dashboard.js" defer></script>
