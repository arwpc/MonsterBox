          <div class="form-check form-switch lurk-switch mb-0">
            <input class="form-check-input lurk-toggle-input" type="checkbox" id="lurkToggle">
            <label class="form-check-label fw-bold lurk-label" for="lurkToggle">
              <i class="bi bi-lightning-charge-fill"></i> Lurk Mode
            </label>
          </div>
        </div>
        <div id="lurkStatusIndicators" class="d-flex gap-2 align-items-center">
          <span class="badge lurk-badge" id="lurkBadgeAI" title="AI Conversation"><i class="bi bi-chat-dots"></i> AI</span>
          <span class="badge lurk-badge" id="lurkBadgeJaw" title="Jaw Animation"><i class="bi bi-soundwave"></i> Jaw</span>
          <span class="badge lurk-badge" id="lurkBadgeHead" title="Head Tracking"><i class="bi bi-eye"></i> Head</span>
          <span class="badge lurk-badge" id="lurkBadgeIdle" title="Idle Movement"><i class="bi bi-person-walking"></i> Idle</span>
        </div>
