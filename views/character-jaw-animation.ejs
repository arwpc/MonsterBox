<!-- Character Jaw Animation Configuration Page -->
<div class="container-monsterbox">
    <!-- Status Messages -->
    <div id="status" class="mb-4"></div>

    <!-- Character Info Section -->
    <div class="card-monsterbox mb-6">
        <div class="card-body">
            <div class="flex items-center gap-4">
                <% if (character.image) { %>
                    <img src="/images/characters/<%= character.image %>" alt="<%= character.char_name %>" class="w-16 h-16 object-cover rounded-lg">
                <% } else { %>
                    <div class="w-16 h-16 bg-base-200 rounded-lg flex items-center justify-center text-base-content/50">🎭</div>
                <% } %>
                <div>
                    <h2 class="text-2xl font-bold text-primary">🦴 Jaw Animation Configuration</h2>
                    <p class="text-base-content/70">Character: <span class="font-semibold"><%= character.char_name %></span></p>
                    <p class="text-sm text-base-content/60"><%= character.char_description %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation Buttons -->
    <%- include('components/button-components', {
        component: 'buttonGroup',
        alignment: 'start',
        buttons: [
            { text: 'Back to Character', icon: '🎭', href: '/characters/' + character.id + '/edit', class: 'btn-secondary-monsterbox' },
            { text: 'Character Parts', icon: '🔧', href: '/characters/' + character.id + '/parts', class: 'btn-secondary-monsterbox' },
            { text: 'AI Instances', icon: '🧠', href: '/characters/' + character.id + '/ai', class: 'btn-secondary-monsterbox' }
        ]
    }) %>

    <!-- Main Configuration Form -->
    <form id="jawAnimationForm" class="space-y-6">
        <!-- Enable/Disable Jaw Animation -->
        <div class="card-monsterbox">
            <div class="card-body">
                <h3 class="text-xl font-bold text-primary mb-4">🔧 Basic Configuration</h3>
                <div class="form-control">
                    <label class="label cursor-pointer">
                        <span class="label-text">Enable Jaw Animation</span>
                        <input type="checkbox" id="enableJawAnimation" name="enabled"
                               class="checkbox checkbox-primary"
                               <%= jawAnimationConfig.enabled ? 'checked' : '' %>>
                    </label>
                </div>
                <div class="text-sm text-base-content/60 mt-2">
                    Enable real-time jaw animation synchronized with audio playback and speech
                </div>
            </div>
        </div>

        <!-- Servo Configuration -->
        <div class="card-monsterbox" id="servoConfigSection">
            <div class="card-body">
                <h3 class="text-xl font-bold text-primary mb-4">🎛️ Servo Configuration</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Servo Selection -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Jaw Servo</span>
                        </label>
                        <select id="servoSelect" name="servo.id" class="select select-bordered">
                            <option value="">Select Servo...</option>
                            <% availableServos.forEach(function(servo) { %>
                                <option value="<%= servo.id %>"
                                        <%= (jawAnimationConfig.servo && jawAnimationConfig.servo.id == servo.id) ? 'selected' : '' %>>
                                    <%= servo.name %> (Pin: <%= servo.pin %>, Channel: <%= servo.channel %>)
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <!-- GPIO Pin -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">GPIO Pin</span>
                        </label>
                        <input type="number" id="servoPin" name="servo.pin"
                               class="input input-bordered"
                               value="<%= jawAnimationConfig.servo ? jawAnimationConfig.servo.pin : 18 %>"
                               min="0" max="40">
                    </div>

                    <!-- Closed Angle -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Closed Angle (°)</span>
                        </label>
                        <input type="number" id="closedAngle" name="servo.closedAngle"
                               class="input input-bordered"
                               value="<%= jawAnimationConfig.servo ? jawAnimationConfig.servo.closedAngle : 50 %>"
                               min="0" max="180">
                    </div>

                    <!-- Open Angle -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Open Angle (°)</span>
                        </label>
                        <input type="number" id="openAngle" name="servo.openAngle"
                               class="input input-bordered"
                               value="<%= jawAnimationConfig.servo ? jawAnimationConfig.servo.openAngle : 30 %>"
                               min="0" max="180">
                    </div>
                </div>

                <!-- Servo Test Controls -->
                <div class="divider">Test Controls</div>
                <div class="flex flex-wrap gap-2">
                    <button type="button" id="testClosedBtn" class="btn btn-sm btn-secondary">
                        Test Closed Position
                    </button>
                    <button type="button" id="testOpenBtn" class="btn btn-sm btn-secondary">
                        Test Open Position
                    </button>
                    <button type="button" id="testMovementBtn" class="btn btn-sm btn-primary">
                        Test Movement Sequence
                    </button>
                </div>
            </div>
        </div>

        <!-- Manual Servo Control -->
        <div class="card-monsterbox" id="manualControlSection">
            <div class="card-body">
                <h3 class="text-xl font-bold text-primary mb-4">🎮 Manual Control</h3>

                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Servo Angle: <span id="angleValue">90°</span></span>
                    </label>
                    <input type="range" id="angleSlider" class="range range-primary"
                           min="0" max="180" value="90" step="1">
                    <div class="w-full flex justify-between text-xs px-2">
                        <span>0°</span>
                        <span>90°</span>
                        <span>180°</span>
                    </div>
                </div>

                <div class="flex gap-2 mt-4">
                    <button type="button" id="moveToAngleBtn" class="btn btn-primary">
                        Move to Angle
                    </button>
                    <button type="button" id="setClosedBtn" class="btn btn-secondary">
                        Set as Closed
                    </button>
                    <button type="button" id="setOpenBtn" class="btn btn-secondary">
                        Set as Open
                    </button>
                </div>
            </div>
        </div>

        <!-- Audio Analysis Configuration -->
        <div class="card-monsterbox" id="audioConfigSection">
            <div class="card-body">
                <h3 class="text-xl font-bold text-primary mb-4">🎵 Audio Analysis</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Volume Threshold -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Volume Threshold</span>
                        </label>
                        <input type="number" id="volumeThreshold" name="audioAnalysis.volumeThreshold"
                               class="input input-bordered"
                               value="<%= jawAnimationConfig.audioAnalysis ? jawAnimationConfig.audioAnalysis.volumeThreshold : 0.01 %>"
                               step="0.001" min="0" max="1">
                        <div class="label">
                            <span class="label-text-alt">Minimum audio level to trigger jaw movement</span>
                        </div>
                    </div>

                    <!-- Smoothing Factor -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Smoothing Factor</span>
                        </label>
                        <input type="number" id="smoothingFactor" name="audioAnalysis.smoothingFactor"
                               class="input input-bordered"
                               value="<%= jawAnimationConfig.audioAnalysis ? jawAnimationConfig.audioAnalysis.smoothingFactor : 0.8 %>"
                               step="0.1" min="0" max="1">
                        <div class="label">
                            <span class="label-text-alt">Higher values = smoother movement</span>
                        </div>
                    </div>

                    <!-- Sensitivity -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Sensitivity</span>
                        </label>
                        <input type="number" id="sensitivity" name="audioAnalysis.sensitivity"
                               class="input input-bordered"
                               value="<%= jawAnimationConfig.audioAnalysis ? jawAnimationConfig.audioAnalysis.sensitivity : 1.0 %>"
                               step="0.1" min="0.1" max="5.0">
                        <div class="label">
                            <span class="label-text-alt">Audio response sensitivity multiplier</span>
                        </div>
                    </div>

                    <!-- Response Curve -->
                    <div class="form-control">
                        <label class="label">
                            <span class="label-text">Response Curve</span>
                        </label>
                        <select id="responseCurve" name="audioAnalysis.responseCurve" class="select select-bordered">
                            <option value="linear" <%= (jawAnimationConfig.audioAnalysis && jawAnimationConfig.audioAnalysis.responseCurve === 'linear') ? 'selected' : '' %>>Linear</option>
                            <option value="exponential" <%= (jawAnimationConfig.audioAnalysis && jawAnimationConfig.audioAnalysis.responseCurve === 'exponential') ? 'selected' : '' %>>Exponential</option>
                            <option value="logarithmic" <%= (jawAnimationConfig.audioAnalysis && jawAnimationConfig.audioAnalysis.responseCurve === 'logarithmic') ? 'selected' : '' %>>Logarithmic</option>
                        </select>
                        <div class="label">
                            <span class="label-text-alt">How audio levels map to jaw movement</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Preset Configuration -->
        <div class="card-monsterbox" id="presetSection">
            <div class="card-body">
                <h3 class="text-xl font-bold text-primary mb-4">🎯 Presets</h3>
                <p class="text-base-content/70 mb-4">Quick configuration presets for different character types</p>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                    <button type="button" class="btn btn-outline preset-btn" data-preset="skeleton">
                        💀 Skeleton
                    </button>
                    <button type="button" class="btn btn-outline preset-btn" data-preset="bear">
                        🐻 Bear
                    </button>
                    <button type="button" class="btn btn-outline preset-btn" data-preset="fish">
                        🐟 Fish
                    </button>
                    <button type="button" class="btn btn-outline preset-btn" data-preset="demon">
                        👹 Demon
                    </button>
                </div>
            </div>
        </div>

        <!-- Audio Testing -->
        <div class="card-monsterbox" id="audioTestSection">
            <div class="card-body">
                <h3 class="text-xl font-bold text-primary mb-4">🔊 Audio Testing</h3>

                <div class="form-control mb-4">
                    <label class="label">
                        <span class="label-text">Test Audio</span>
                    </label>
                    <select id="soundSelect" class="select select-bordered">
                        <option value="">Select test audio...</option>
                        <% sounds.forEach(function(sound) { %>
                            <option value="<%= sound.filename %>" data-id="<%= sound.id %>">
                                <%= sound.name %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="flex gap-2">
                    <button type="button" id="playAudioBtn" class="btn btn-primary">
                        ▶️ Play Audio
                    </button>
                    <button type="button" id="startAnimationBtn" class="btn btn-success">
                        🦴 Start Animation
                    </button>
                    <button type="button" id="stopAnimationBtn" class="btn btn-error">
                        ⏹️ Stop Animation
                    </button>
                </div>
            </div>
        </div>

        <!-- Save Configuration -->
        <div class="card-monsterbox">
            <div class="card-body">
                <div class="flex justify-between items-center">
                    <div>
                        <h3 class="text-lg font-bold">Save Configuration</h3>
                        <p class="text-sm text-base-content/60">Save your jaw animation settings</p>
                    </div>
                    <div class="flex gap-2">
                        <button type="button" id="resetBtn" class="btn btn-outline">
                            Reset to Defaults
                        </button>
                        <button type="submit" class="btn btn-primary">
                            💾 Save Configuration
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Real-time Monitoring Section -->
<div class="container-monsterbox" id="monitoringSection" style="display: none;">
    <div class="card-monsterbox">
        <div class="card-body">
            <h3 class="text-xl font-bold text-primary mb-4">📊 Real-time Monitoring</h3>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <!-- Audio Volume -->
                <div class="stat bg-base-200 rounded-lg">
                    <div class="stat-title">Audio Volume</div>
                    <div class="stat-value text-primary" id="audioVolume">0.00</div>
                    <div class="stat-desc">
                        Raw: <span id="audioRaw">0.00</span> |
                        Smoothed: <span id="audioSmoothed">0.00</span>
                    </div>
                </div>

                <!-- Servo Position -->
                <div class="stat bg-base-200 rounded-lg">
                    <div class="stat-title">Servo Position</div>
                    <div class="stat-value text-secondary" id="servoPosition">90°</div>
                    <div class="stat-desc">Current angle</div>
                </div>

                <!-- Performance -->
                <div class="stat bg-base-200 rounded-lg">
                    <div class="stat-title">Performance</div>
                    <div class="stat-value text-sm">
                        <div>Updates/sec: <span id="updateRate">0</span></div>
                        <div>Latency: <span id="latency">0ms</span></div>
                    </div>
                </div>

                <!-- System Status -->
                <div class="stat bg-base-200 rounded-lg">
                    <div class="stat-title">System Status</div>
                    <div class="stat-value text-sm">
                        <div>Memory: <span id="memory">0MB</span></div>
                        <div>Clients: <span id="clients">0</span></div>
                    </div>
                </div>
            </div>

            <!-- System Log -->
            <div class="mt-4">
                <h4 class="font-bold mb-2">System Log</h4>
                <div id="systemLog" class="bg-base-300 px-4 py-6 rounded-lg h-32 overflow-y-auto text-sm font-mono">
                    System ready...
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Configuration variables
    let currentCharacterId = <%= character.id %>;
    let animationActive = false;
    let jawAnimationConfig = <%- JSON.stringify(jawAnimationConfig) %>;
    let monitoringInterval = null;

    // Initialize page
    document.addEventListener('DOMContentLoaded', function() {
        initializeForm();
        setupEventListeners();

        // Show monitoring section if animation is enabled
        if (jawAnimationConfig.enabled) {
            document.getElementById('monitoringSection').style.display = 'block';
            startMonitoring();
        }
    });

    function initializeForm() {
        // Update angle display when slider changes
        const angleSlider = document.getElementById('angleSlider');
        const angleValue = document.getElementById('angleValue');

        angleSlider.addEventListener('input', function() {
            angleValue.textContent = this.value + '°';
        });

        // Enable/disable sections based on jaw animation enabled state
        const enableCheckbox = document.getElementById('enableJawAnimation');
        enableCheckbox.addEventListener('change', function() {
            toggleSections(this.checked);
        });

        // Initial state
        toggleSections(enableCheckbox.checked);
    }

    function setupEventListeners() {
        // Servo test buttons
        document.getElementById('testClosedBtn').addEventListener('click', () => testServoPosition('closed'));
        document.getElementById('testOpenBtn').addEventListener('click', () => testServoPosition('open'));
        document.getElementById('testMovementBtn').addEventListener('click', testMovementSequence);

        // Manual control buttons
        document.getElementById('moveToAngleBtn').addEventListener('click', moveToAngle);
        document.getElementById('setClosedBtn').addEventListener('click', () => setAngleAs('closed'));
        document.getElementById('setOpenBtn').addEventListener('click', () => setAngleAs('open'));

        // Preset buttons
        document.querySelectorAll('.preset-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const preset = this.dataset.preset;
                applyPreset(preset);
            });
        });

        // Audio test buttons
        document.getElementById('playAudioBtn').addEventListener('click', playSelectedSound);
        document.getElementById('startAnimationBtn').addEventListener('click', startAnimation);
        document.getElementById('stopAnimationBtn').addEventListener('click', stopAnimation);

        // Form submission
        document.getElementById('jawAnimationForm').addEventListener('submit', saveConfiguration);

        // Reset button
        document.getElementById('resetBtn').addEventListener('click', resetToDefaults);
    }

    function toggleSections(enabled) {
        const sections = ['servoConfigSection', 'manualControlSection', 'audioConfigSection', 'audioTestSection'];
        sections.forEach(sectionId => {
            const section = document.getElementById(sectionId);
            if (section) {
                section.style.opacity = enabled ? '1' : '0.5';
                const inputs = section.querySelectorAll('input, select, button');
                inputs.forEach(input => {
                    input.disabled = !enabled;
                });
            }
        });

        // Show/hide monitoring section
        const monitoringSection = document.getElementById('monitoringSection');
        if (enabled) {
            monitoringSection.style.display = 'block';
            startMonitoring();
        } else {
            monitoringSection.style.display = 'none';
            stopMonitoring();
        }
    }

    function showStatus(message, type = 'info') {
        const statusDiv = document.getElementById('status');
        const alertClass = type === 'error' ? 'alert-error' :
                          type === 'success' ? 'alert-success' :
                          type === 'warning' ? 'alert-warning' : 'alert-info';

        statusDiv.innerHTML = `
            <div class="alert ${alertClass}">
                <span>${message}</span>
            </div>
        `;

        // Auto-hide after 5 seconds
        setTimeout(() => {
            statusDiv.innerHTML = '';
        }, 5000);
    }

    async function testServoPosition(position) {
        try {
            const angle = position === 'closed' ?
                parseInt(document.getElementById('closedAngle').value) :
                parseInt(document.getElementById('openAngle').value);

            showStatus(`Testing ${position} position (${angle}°)...`, 'info');

            const response = await fetch(`/jaw-animation/api/servo/${currentCharacterId}/test`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ angle: angle })
            });

            const data = await response.json();

            if (data.success) {
                showStatus(`Servo moved to ${position} position (${angle}°)`, 'success');
                document.getElementById('servoPosition').textContent = angle + '°';
                addLogEntry(`Servo moved to ${position} position: ${angle}°`);
            } else {
                showStatus(data.message || `Failed to test ${position} position`, 'error');
            }

        } catch (error) {
            showStatus(`Error testing ${position} position: ${error.message}`, 'error');
            addLogEntry(`Error: ${error.message}`);
        }
    }

    async function testMovementSequence() {
        try {
            showStatus('Running movement sequence test...', 'info');

            const closedAngle = parseInt(document.getElementById('closedAngle').value);
            const openAngle = parseInt(document.getElementById('openAngle').value);

            // Open/close 3 times
            for (let i = 0; i < 3; i++) {
                await moveServoTo(openAngle, 0.3);
                await new Promise(resolve => setTimeout(resolve, 300));
                await moveServoTo(closedAngle, 0.3);
                await new Promise(resolve => setTimeout(resolve, 300));
            }

            // 3-second transition
            await moveServoTo(openAngle, 1.0);
            await new Promise(resolve => setTimeout(resolve, 1000));
            await moveServoTo(closedAngle, 2.0);

            showStatus('Movement sequence completed', 'success');
            addLogEntry('Movement sequence test completed');

        } catch (error) {
            showStatus(`Error in movement sequence: ${error.message}`, 'error');
            addLogEntry(`Movement sequence error: ${error.message}`);
        }
    }

    async function moveServoTo(angle, duration = 1.0) {
        const response = await fetch(`/jaw-animation/api/servo/${currentCharacterId}/test`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ angle: angle, duration: duration })
        });

        if (!response.ok) {
            throw new Error(`Failed to move servo to ${angle}°`);
        }

        document.getElementById('servoPosition').textContent = angle + '°';
        return response.json();
    }

    function addLogEntry(message) {
        const log = document.getElementById('systemLog');
        const timestamp = new Date().toLocaleTimeString();
        log.innerHTML += `<br>${timestamp}: ${message}`;
        log.scrollTop = log.scrollHeight;
    }

    function startMonitoring() {
        if (monitoringInterval) return;

        monitoringInterval = setInterval(() => {
            if (animationActive) {
                // Simulate real-time updates (in production, this would come from WebSocket)
                const audioLevel = Math.random() * 0.5;
                document.getElementById('audioRaw').textContent = audioLevel.toFixed(2);
                document.getElementById('audioSmoothed').textContent = (audioLevel * 0.8).toFixed(2);
                document.getElementById('audioVolume').textContent = audioLevel.toFixed(2);

                // Simulate servo movement based on audio
                const servoAngle = Math.floor(audioLevel * 180);
                document.getElementById('servoPosition').textContent = servoAngle + '°';

                // Update performance metrics
                document.getElementById('updateRate').textContent = '60';
                document.getElementById('latency').textContent = Math.floor(Math.random() * 10) + 'ms';
                document.getElementById('memory').textContent = (Math.random() * 50 + 20).toFixed(1);
                document.getElementById('clients').textContent = '1';
            }
        }, 100);
    }

    function stopMonitoring() {
        if (monitoringInterval) {
            clearInterval(monitoringInterval);
            monitoringInterval = null;
        }
    }

    async function moveToAngle() {
        const angle = parseInt(document.getElementById('angleSlider').value);
        try {
            await moveServoTo(angle);
            showStatus(`Moved servo to ${angle}°`, 'success');
            addLogEntry(`Manual move to ${angle}°`);
        } catch (error) {
            showStatus(`Error moving servo: ${error.message}`, 'error');
        }
    }

    function setAngleAs(position) {
        const angle = parseInt(document.getElementById('angleSlider').value);
        const inputId = position === 'closed' ? 'closedAngle' : 'openAngle';
        document.getElementById(inputId).value = angle;
        showStatus(`Set ${position} position to ${angle}°`, 'success');
        addLogEntry(`Set ${position} position: ${angle}°`);
    }

    async function applyPreset(presetName) {
        try {
            showStatus(`Applying ${presetName} preset...`, 'info');

            const response = await fetch(`/characters/${currentCharacterId}/jaw-animation/preset/${presetName}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            const data = await response.json();

            if (data.success) {
                // Update form fields with preset values
                const config = data.config;
                if (config.servo) {
                    if (config.servo.minPosition !== undefined) {
                        // Update UI elements if they exist
                        const minPosInput = document.querySelector('[name="servo.minPosition"]');
                        if (minPosInput) minPosInput.value = config.servo.minPosition;
                    }
                    if (config.servo.maxPosition !== undefined) {
                        const maxPosInput = document.querySelector('[name="servo.maxPosition"]');
                        if (maxPosInput) maxPosInput.value = config.servo.maxPosition;
                    }
                }
                if (config.audioAnalysis) {
                    if (config.audioAnalysis.sensitivity !== undefined) {
                        document.getElementById('sensitivity').value = config.audioAnalysis.sensitivity;
                    }
                    if (config.audioAnalysis.volumeThreshold !== undefined) {
                        document.getElementById('volumeThreshold').value = config.audioAnalysis.volumeThreshold;
                    }
                    if (config.audioAnalysis.responseCurve !== undefined) {
                        document.getElementById('responseCurve').value = config.audioAnalysis.responseCurve;
                    }
                }

                showStatus(`${presetName} preset applied successfully`, 'success');
                addLogEntry(`Applied ${presetName} preset`);
            } else {
                showStatus(data.message || `Failed to apply ${presetName} preset`, 'error');
            }

        } catch (error) {
            showStatus(`Error applying preset: ${error.message}`, 'error');
            addLogEntry(`Preset error: ${error.message}`);
        }
    }

    async function playSelectedSound() {
        const select = document.getElementById('soundSelect');
        const selectedSound = select.value;

        if (!selectedSound) {
            showStatus('Please select a sound first', 'warning');
            return;
        }

        try {
            showStatus(`Playing sound: ${selectedSound}...`, 'info');

            // Create audio element and play
            const audio = new Audio(`/sounds/${selectedSound}`);
            audio.volume = 0.7;

            audio.onloadstart = () => addLogEntry(`Loading audio: ${selectedSound}`);
            audio.oncanplay = () => addLogEntry(`Audio ready to play`);
            audio.onplay = () => addLogEntry(`Audio playback started`);
            audio.onended = () => {
                addLogEntry(`Audio playback finished`);
                showStatus('Audio playback completed', 'success');
            };
            audio.onerror = (e) => {
                addLogEntry(`Audio error: ${e.message || 'Unknown error'}`);
                showStatus('Audio playback failed', 'error');
            };

            await audio.play();
            showStatus('Audio playing...', 'info');

        } catch (error) {
            showStatus('Error playing sound: ' + error.message, 'error');
            addLogEntry(`Audio play error: ${error.message}`);
        }
    }

    async function startAnimation() {
        try {
            showStatus('Starting jaw animation...', 'info');
            const response = await fetch(`/jaw-animation/api/animation/${currentCharacterId}/start`, {
                method: 'POST'
            });

            const data = await response.json();

            if (data.success) {
                animationActive = true;
                showStatus('Jaw animation started', 'success');
                addLogEntry('Animation started');

                // Update button states
                document.getElementById('startAnimationBtn').disabled = true;
                document.getElementById('stopAnimationBtn').disabled = false;
            } else {
                showStatus(data.message || 'Failed to start animation', 'error');
            }

        } catch (error) {
            showStatus('Error starting animation: ' + error.message, 'error');
            addLogEntry(`Animation start error: ${error.message}`);
        }
    }

    async function stopAnimation() {
        try {
            showStatus('Stopping jaw animation...', 'info');
            const response = await fetch(`/jaw-animation/api/animation/${currentCharacterId}/stop`, {
                method: 'POST'
            });

            const data = await response.json();

            if (data.success) {
                animationActive = false;
                showStatus('Jaw animation stopped', 'success');
                addLogEntry('Animation stopped');

                // Update button states
                document.getElementById('startAnimationBtn').disabled = false;
                document.getElementById('stopAnimationBtn').disabled = true;
            } else {
                showStatus(data.message || 'Failed to stop animation', 'error');
            }

        } catch (error) {
            showStatus('Error stopping animation: ' + error.message, 'error');
            addLogEntry(`Animation stop error: ${error.message}`);
        }
    }

    async function saveConfiguration(event) {
        event.preventDefault();

        try {
            showStatus('Saving configuration...', 'info');

            // Collect form data
            const formData = new FormData(document.getElementById('jawAnimationForm'));
            const config = {};

            // Convert FormData to nested object structure
            for (let [key, value] of formData.entries()) {
                const keys = key.split('.');
                let current = config;

                for (let i = 0; i < keys.length - 1; i++) {
                    if (!current[keys[i]]) {
                        current[keys[i]] = {};
                    }
                    current = current[keys[i]];
                }

                // Convert numeric values
                if (value === 'on') {
                    current[keys[keys.length - 1]] = true;
                } else if (!isNaN(value) && value !== '') {
                    current[keys[keys.length - 1]] = parseFloat(value);
                } else {
                    current[keys[keys.length - 1]] = value;
                }
            }

            // Handle checkbox for enabled state
            config.enabled = document.getElementById('enableJawAnimation').checked;

            const response = await fetch(`/characters/${currentCharacterId}/jaw-animation`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(config)
            });

            const data = await response.json();

            if (data.success) {
                showStatus('Configuration saved successfully', 'success');
                addLogEntry('Configuration saved');
                jawAnimationConfig = config; // Update local config
            } else {
                showStatus(data.message || 'Failed to save configuration', 'error');
            }

        } catch (error) {
            showStatus('Error saving configuration: ' + error.message, 'error');
            addLogEntry(`Save error: ${error.message}`);
        }
    }

    function resetToDefaults() {
        if (confirm('Are you sure you want to reset all settings to defaults? This will lose your current configuration.')) {
            // Reset form to default values
            document.getElementById('enableJawAnimation').checked = false;
            document.getElementById('servoPin').value = 18;
            document.getElementById('closedAngle').value = 50;
            document.getElementById('openAngle').value = 30;
            document.getElementById('volumeThreshold').value = 0.01;
            document.getElementById('smoothingFactor').value = 0.8;
            document.getElementById('sensitivity').value = 1.0;
            document.getElementById('responseCurve').value = 'linear';
            document.getElementById('angleSlider').value = 90;
            document.getElementById('angleValue').textContent = '90°';

            toggleSections(false);
            showStatus('Settings reset to defaults', 'info');
            addLogEntry('Settings reset to defaults');
        }
    }
</script>
