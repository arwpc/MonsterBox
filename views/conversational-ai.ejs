<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Voice Chat - ElevenLabs Conversational AI' %></title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .breadcrumb-vertical {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 20px;
            font-size: 1.1em;
        }

        .breadcrumb-item {
            color: #00ffff;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .breadcrumb-item:hover {
            color: #ffffff;
            text-shadow: 0 0 5px #00ffff;
        }

        .breadcrumb-item.active {
            color: #00ff00;
            font-weight: bold;
        }

        .breadcrumb-item:not(.active):after {
            content: ' → ';
            color: #666666;
            margin-left: 8px;
        }

        .mb-6 {
            margin-bottom: 24px;
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>

    <div class="container">
        <!-- Breadcrumb Navigation -->
        <nav class="breadcrumb-vertical mb-6">
            <a href="/" class="breadcrumb-item">🏠 Home</a>
            <a href="/ai-management" class="breadcrumb-item">🤖 AI Management</a>
            <span class="breadcrumb-item active">🎤 Voice Chat</span>
        </nav>

        <h1 style="text-align: center; color: #00ff00; margin-bottom: 30px; text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);">
            🎤 ElevenLabs Voice Chat
        </h1>

        <!-- Service Status -->
        <div class="config-section">
            <div class="config-header">
                <i class="fas fa-signal config-icon"></i>
                <h2>📡 Service Status</h2>
            </div>
            <div class="status-grid">
                <div class="status-item">
                    <span>ElevenLabs Service</span>
                    <div style="display: flex; align-items: center;">
                        <% if (serviceStatus && serviceStatus.isRunning) { %>
                            <span style="color: #00ff00;">✅ Running</span>
                        <% } else { %>
                            <span style="color: #ff6666;">❌ Offline</span>
                        <% } %>
                    </div>
                </div>
                <div class="status-item">
                    <span>Available Agents</span>
                    <div style="display: flex; align-items: center;">
                        <span style="color: #00ff88;"><%= serviceStatus ? serviceStatus.availableAgents : 0 %></span>
                    </div>
                </div>
                <div class="status-item">
                    <span>Active Connections</span>
                    <div style="display: flex; align-items: center;">
                        <span style="color: #00ff88;"><%= serviceStatus ? serviceStatus.activeConnections : 0 %></span>
                    </div>
                </div>
                <div class="status-item">
                    <span>WebSocket Port</span>
                    <div style="display: flex; align-items: center;">
                        <span style="color: #00ff88;"><%= serviceStatus ? serviceStatus.port : 'N/A' %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Character Selection -->
        <div class="config-section">
            <div class="config-header">
                <i class="fas fa-theater-masks config-icon"></i>
                <h2>🎭 Select Character</h2>
            </div>
            <div class="character-grid" id="character-selection">
                <% characters.forEach(character => { %>
                    <div class="character-card cursor-pointer"
                         data-character-id="<%= character.id %>"
                         data-character-name="<%= character.char_name %>"
                         onclick="selectCharacter(<%= character.id %>, '<%= character.char_name %>')">
                        <div class="character-header">
                            <div class="character-avatar">
                                <%= character.char_name.charAt(0).toUpperCase() %>
                            </div>
                            <div class="character-info">
                                <h4><%= character.char_name %></h4>
                                <p><%= character.char_description %></p>
                            </div>
                        </div>
                        <div class="character-status" id="status-<%= character.id %>">
                            <span class="status-indicator">⏳</span>
                            <span>Checking...</span>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>

        <!-- Conversation Interface -->
        <div class="config-section" id="conversation-interface" style="display: none;">
            <div class="config-header">
                <i class="fas fa-comments config-icon"></i>
                <h2>💬 Conversation with <span id="current-character-name">Character</span></h2>
                <div class="config-actions">
                    <button class="button secondary-btn" id="disconnect-btn">
                        🔌 Disconnect
                    </button>
                    <button class="button primary-btn" id="settings-btn">
                        ⚙️ Settings
                    </button>
                </div>
            </div>

            <!-- Connection Status -->
            <div class="status-message" id="connection-status">
                <span class="status-indicator">⏳</span>
                <span id="connection-message">Connecting to ElevenLabs...</span>
            </div>

            <!-- Conversation Starters -->
            <div class="conversation-starters" id="conversation-starters" style="display: none;">
                <h3>💡 Conversation Starters:</h3>
                <div class="starters-grid" id="starters-container">
                    <!-- Starters will be populated by JavaScript -->
                </div>
            </div>

            <!-- Chat Messages -->
            <div class="chat-container" id="chat-messages">
                <div class="chat-placeholder">
                    Select a character and start a conversation...
                </div>
            </div>

            <!-- Voice Controls -->
            <div class="voice-controls">
                <button class="button primary-btn voice-btn" id="voice-btn" disabled>
                    🎤 Hold to Talk
                </button>
                <button class="button secondary-btn" id="mute-btn">
                    🔊 Mute
                </button>
            </div>

            <!-- Text Input -->
            <div class="text-input-container">
                <input type="text"
                       class="text-input"
                       id="text-input"
                       placeholder="Type a message or use voice..."
                       disabled>
                <button class="button primary-btn" id="send-btn" disabled>
                    📤 Send
                </button>
            </div>
        </div>

        <!-- Advanced Settings -->
        <div class="card bg-base-200 shadow-xl" id="advanced-settings" style="display: none;">
            <div class="card-body">
                <h2 class="card-title text-primary mb-4">
                    ⚙️ Advanced Settings
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Audio Settings -->
                    <div>
                        <h3 class="text-lg font-semibold mb-3">🔊 Audio Settings</h3>
                        <div class="space-y-4">
                            <div class="form-control">
                                <label class="label">
                                    <span class="label-text">Voice Activity Detection</span>
                                </label>
                                <input type="range" min="0.1" max="1.0" step="0.1" value="0.5" 
                                       class="range range-primary" id="vad-threshold">
                                <div class="w-full flex justify-between text-xs px-2">
                                    <span>Sensitive</span>
                                    <span>Balanced</span>
                                    <span>Conservative</span>
                                </div>
                            </div>
                            <div class="form-control">
                                <label class="label">
                                    <span class="label-text">Audio Quality</span>
                                </label>
                                <select class="select select-bordered" id="audio-quality">
                                    <option value="high">High Quality</option>
                                    <option value="medium" selected>Medium Quality</option>
                                    <option value="low">Low Quality (Faster)</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- ElevenLabs Voice Settings -->
                    <div>
                        <h3 class="text-lg font-semibold mb-3">🎤 Voice Settings</h3>
                        <div class="space-y-4">
                            <div class="form-control">
                                <label class="cursor-pointer label">
                                    <span class="label-text">Enable Voice Activity Detection</span>
                                    <input type="checkbox" class="toggle toggle-primary" id="vad-enabled" checked>
                                </label>
                            </div>
                            <div class="form-control">
                                <label class="label">
                                    <span class="label-text">Voice Sensitivity</span>
                                </label>
                                <input type="range" min="0.1" max="1.0" step="0.1" value="0.5"
                                       class="range range-primary" id="voice-sensitivity">
                            </div>
                            <div class="form-control">
                                <label class="label">
                                    <span class="label-text">Response Speed</span>
                                </label>
                                <input type="range" min="100" max="1000" step="50" value="300"
                                       class="range range-primary" id="response-speed">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-actions justify-end mt-6">
                    <button class="button button-outline" id="reset-settings-btn">
                        🔄 Reset to Defaults
                    </button>
                    <button class="button button-primary" id="save-settings-btn">
                        💾 Save Settings
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer footer-center p-4 bg-base-200 text-base-content mt-8">
        <div>
            <p class="font-terminal">
                🎭 MonsterBox™ ChatterPi • Powered by ElevenLabs Conversational AI
            </p>
        </div>
    </footer>

    <style>
        .character-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .character-card {
            background: #001100;
            border: 2px solid #003300;
            border-radius: 8px;
            padding: 20px;
            transition: all 0.3s ease;
        }

        .character-card:hover {
            border-color: #00ff00;
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.3);
        }

        .character-card.selected {
            border-color: #00ff00;
            background: #002200;
            box-shadow: 0 0 30px rgba(0, 255, 0, 0.5);
        }

        .character-status {
            margin-top: 15px;
            padding: 8px 12px;
            background: #000800;
            border-radius: 4px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .chat-container {
            background: #000800;
            border: 1px solid #003300;
            border-radius: 8px;
            height: 300px;
            overflow-y: auto;
            padding: 20px;
            margin: 20px 0;
        }

        .chat-placeholder {
            text-align: center;
            color: #666;
            font-style: italic;
        }

        .voice-controls {
            display: flex;
            gap: 15px;
            margin: 20px 0;
        }

        .voice-btn {
            flex: 1;
        }

        .text-input-container {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }

        .text-input {
            flex: 1;
            background: #000800;
            border: 1px solid #003300;
            border-radius: 4px;
            padding: 12px;
            color: #00ff00;
            font-family: 'Courier New', monospace;
        }

        .text-input:focus {
            border-color: #00ff00;
            outline: none;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
        }

        .conversation-starters {
            margin: 20px 0;
        }

        .starters-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }

        .starter-btn {
            background: #001100;
            border: 1px solid #003300;
            color: #00ff88;
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .starter-btn:hover {
            border-color: #00ff00;
            background: #002200;
        }

        .status-message {
            background: #001100;
            border: 1px solid #003300;
            border-radius: 4px;
            padding: 15px;
            margin: 20px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
    </style>

    <!-- JavaScript -->
    <script>
        // Pass server data to JavaScript
        window.ConversationalAIConfig = {
            characters: <%- JSON.stringify(characters) %>,
            serviceStatus: <%- JSON.stringify(serviceStatus) %>,
            currentCharacterId: <%= currentCharacterId %>
        };

        // Character selection function
        function selectCharacter(characterId, characterName) {
            // Remove previous selection
            document.querySelectorAll('.character-card').forEach(card => {
                card.classList.remove('selected');
            });

            // Add selection to clicked card
            const selectedCard = document.querySelector(`[data-character-id="${characterId}"]`);
            if (selectedCard) {
                selectedCard.classList.add('selected');
            }

            // Update current character
            window.currentCharacterId = characterId;
            window.currentCharacterName = characterName;

            // Update UI
            document.getElementById('current-character-name').textContent = characterName;
            document.getElementById('conversation-interface').style.display = 'block';

            // Update status
            document.getElementById('connection-status').innerHTML = `
                <span class="status-indicator">✅</span>
                <span>Connected to ${characterName}</span>
            `;

            console.log(`Selected character: ${characterName} (ID: ${characterId})`);
        }
    </script>
    <script src="/js/conversational-ai.js?v=<%= Date.now() %>"></script>
</body>
</html>
