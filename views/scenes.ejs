<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>

<body>
    <%- include('components/universal-header') %>

    <main>
        <div class="button-group">
            <a href="/scenes/new?characterId=<%= character ? character.id : '' %>" class="button primary-btn">Add New
                Scene</a>
            <button onclick="showTemplateModal()" class="button">Create from Template</button>
            <button onclick="exportScenes()" class="button">Export Scenes</button>
            <button onclick="showImportModal()" class="button">Import Scenes</button>
            <button onclick="stopAllScenes()" class="button danger-btn">Stop All Scenes</button>
            <a href="/?characterId=<%= character ? character.id : '' %>" class="button secondary-btn">Back to Main
                Menu</a>
        </div>

        <% if (scenes.length===0) { %>
            <p>No scenes found for this character.</p>
            <% } else { %>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Scene Name</th>
                                <th>Steps</th>
                                <th>Actions</th>
                                <th>Operations</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% scenes.forEach(function(scene) { %>
                                <tr>
                                    <td>
                                        <%= scene.scene_name || 'Untitled Scene' %> (ID: <%= scene.id %>)
                                    </td>
                                    <td>
                                        <%= scene.steps ? scene.steps.length : 0 %>
                                    </td>
                                    <td>
                                        <% if (scene.steps && scene.steps.length> 0) { %>
                                            <ul class="info-list">
                                                <% scene.steps.forEach(function(step) { %>
                                                    <li>
                                                        <%= step.name || 'Unnamed Step' %>
                                                    </li>
                                                    <% }); %>
                                            </ul>
                                            <% } else { %>
                                                <p>No steps</p>
                                                <% } %>
                                    </td>
                                    <td>
                                        <div class="button-group">
                                            <a href="/scenes/<%= scene.id %>/edit?characterId=<%= character ? character.id : '' %>"
                                                class="button edit-scene" data-id="<%= scene.id %>">Edit</a>
                                            <button onclick="duplicateScene('<%= scene.id %>')"
                                                class="button">Duplicate</button>
                                            <button onclick="deleteScene('<%= scene.id %>')"
                                                class="button">Delete</button>
                                            <a href="/scenes/<%= scene.id %>?characterId=<%= character ? character.id : '' %>"
                                                class="button play-scene" data-id="<%= scene.id %>">Run</a>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } %>
    </main>

    <script>
        const characterId = '<%= character ? character.id : "" %>';

        function deleteScene(id) {
            if (confirm('Are you sure you want to delete this scene?')) {
                axios.delete('/scenes/' + id + '?characterId=' + characterId)
                    .then(function (result) {
                        location.reload();
                    })
                    .catch(function (error) {
                        alert('Error deleting scene: ' + error.message);
                    });
            }
        }

        function duplicateScene(id) {
            const newName = prompt('Enter name for duplicated scene:');
            if (newName) {
                axios.post('/scenes/' + id + '/duplicate?characterId=' + characterId, { newName: newName })
                    .then(function (result) {
                        location.reload();
                    })
                    .catch(function (error) {
                        alert('Error duplicating scene: ' + error.message);
                    });
            }
        }

        function exportScenes() {
            window.location.href = '/scenes/export?characterId=' + characterId;
        }

        function stopAllScenes() {
            if (confirm('Are you sure you want to stop all running scenes?')) {
                axios.post('/scenes/stop-all?characterId=' + characterId)
                    .then(function (result) {
                        alert('All scenes stopped successfully');
                    })
                    .catch(function (error) {
                        alert('Error stopping scenes: ' + error.message);
                    });
            }
        }

        function showTemplateModal() {
            // Load templates and show modal
            axios.get('/scenes/templates')
                .then(function (response) {
                    const templates = response.data;
                    showTemplateSelectionModal(templates);
                })
                .catch(function (error) {
                    alert('Error loading templates: ' + error.message);
                });
        }

        function showTemplateSelectionModal(templates) {
            let modalHtml = '<div id="templateModal" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000;">';
            modalHtml += '<div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 20px; border-radius: 5px; max-width: 500px; width: 90%;">';
            modalHtml += '<h3>Select Scene Template</h3>';
            modalHtml += '<select id="templateSelect" style="width: 100%; margin: 10px 0;">';
            modalHtml += '<option value="">Choose a template...</option>';

            templates.forEach(template => {
                modalHtml += `<option value="${template.id}">${template.name} - ${template.description}</option>`;
            });

            modalHtml += '</select>';
            modalHtml += '<input type="text" id="sceneNameInput" placeholder="Scene name (optional)" style="width: 100%; margin: 10px 0; padding: 5px;">';
            modalHtml += '<div style="text-align: right; margin-top: 15px;">';
            modalHtml += '<button onclick="closeTemplateModal()" style="margin-right: 10px;">Cancel</button>';
            modalHtml += '<button onclick="createFromTemplate()">Create Scene</button>';
            modalHtml += '</div></div></div>';

            document.body.insertAdjacentHTML('beforeend', modalHtml);
        }

        function createFromTemplate() {
            const templateId = document.getElementById('templateSelect').value;
            const sceneName = document.getElementById('sceneNameInput').value;

            if (!templateId) {
                alert('Please select a template');
                return;
            }

            axios.post('/scenes/from-template?characterId=' + characterId, {
                templateId: templateId,
                scene_name: sceneName,
                character_id: characterId
            })
                .then(function (result) {
                    closeTemplateModal();
                    location.reload();
                })
                .catch(function (error) {
                    alert('Error creating scene from template: ' + error.message);
                });
        }

        function closeTemplateModal() {
            const modal = document.getElementById('templateModal');
            if (modal) {
                modal.remove();
            }
        }

        function showImportModal() {
            let modalHtml = '<div id="importModal" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000;">';
            modalHtml += '<div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 20px; border-radius: 5px; max-width: 500px; width: 90%;">';
            modalHtml += '<h3>Import Scenes</h3>';
            modalHtml += '<input type="file" id="importFile" accept=".json" style="width: 100%; margin: 10px 0;">';
            modalHtml += '<label><input type="checkbox" id="overwriteCheck"> Overwrite existing scenes</label>';
            modalHtml += '<div style="text-align: right; margin-top: 15px;">';
            modalHtml += '<button onclick="closeImportModal()" style="margin-right: 10px;">Cancel</button>';
            modalHtml += '<button onclick="importScenes()">Import</button>';
            modalHtml += '</div></div></div>';

            document.body.insertAdjacentHTML('beforeend', modalHtml);
        }

        function importScenes() {
            const fileInput = document.getElementById('importFile');
            const overwrite = document.getElementById('overwriteCheck').checked;

            if (!fileInput.files[0]) {
                alert('Please select a file to import');
                return;
            }

            const reader = new FileReader();
            reader.onload = function (e) {
                try {
                    const importData = JSON.parse(e.target.result);

                    axios.post('/scenes/import?characterId=' + characterId, {
                        ...importData,
                        overwrite: overwrite,
                        targetCharacterId: characterId
                    })
                        .then(function (result) {
                            closeImportModal();
                            alert(result.data.message);
                            location.reload();
                        })
                        .catch(function (error) {
                            alert('Error importing scenes: ' + error.message);
                        });
                } catch (error) {
                    alert('Invalid JSON file');
                }
            };
            reader.readAsText(fileInput.files[0]);
        }

        function closeImportModal() {
            const modal = document.getElementById('importModal');
            if (modal) {
                modal.remove();
            }
        }

        $(document).ready(function () {
            $('.edit-scene').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('id');
                var url = '/scenes/' + id + '/edit?characterId=' + characterId;
                window.location.href = url;
            });

            $('.play-scene').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('id');
                var url = '/scenes/' + id + '?characterId=' + characterId;
                window.location.href = url;
            });
        });
    </script>
</body>

</html>