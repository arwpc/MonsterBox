<%# MonsterBox UI Component Library - Table Components %>

<%# Data Table Component %>
<% if (typeof component !== 'undefined' && component === 'dataTable') { %>
<div class="overflow-x-auto">
  <table class="table table-zebra w-full">
    <% if (typeof headers !== 'undefined' && Array.isArray(headers)) { %>
    <thead>
      <tr class="bg-base-200">
        <% headers.forEach(function(header) { %>
        <th class="text-primary font-bold">
          <% if (typeof header === 'object' && header.sortable) { %>
          <button class="btn btn-ghost btn-sm p-0 hover:text-primary-focus" onclick="sortTable('<%= header.key %>')">
            <%= header.label || header.text %>
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path>
            </svg>
          </button>
          <% } else { %>
          <%= typeof header === 'object' ? (header.label || header.text) : header %>
          <% } %>
        </th>
        <% }); %>
        <% if (actions) { %>
        <th class="text-primary font-bold">Actions</th>
        <% } %>
      </tr>
    </thead>
    <% } %>
    <tbody>
      <% if (typeof rows !== 'undefined' && Array.isArray(rows)) { %>
        <% rows.forEach(function(row, rowIndex) { %>
        <tr class="hover:bg-base-200/50">
          <% if (Array.isArray(row)) { %>
            <% row.forEach(function(cell) { %>
            <td class="text-base-content"><%- cell %></td>
            <% }); %>
          <% } else if (typeof row === 'object') { %>
            <% headers.forEach(function(header) { %>
              <% const key = typeof header === 'object' ? header.key : header; %>
            <td class="text-base-content"><%- row[key] || '' %></td>
            <% }); %>
          <% } %>
          <% if (actions && typeof actionButtons !== 'undefined') { %>
          <td>
            <div class="flex gap-1">
              <% actionButtons.forEach(function(action) { %>
              <button 
                class="btn btn-sm <%= action.class || 'btn-primary' %>" 
                onclick="<%= action.onclick.replace('{id}', row.id || rowIndex) %>"
                <%= action.disabled ? 'disabled' : '' %>
              >
                <%= action.icon || '' %> <%= action.text || '' %>
              </button>
              <% }); %>
            </div>
          </td>
          <% } %>
        </tr>
        <% }); %>
      <% } else { %>
        <tr>
          <td colspan="<%= (headers ? headers.length : 1) + (actions ? 1 : 0) %>" class="text-center text-base-content/70 py-8">
            No data available
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
<% } %>

<%# Simple Table Component %>
<% if (typeof component !== 'undefined' && component === 'simpleTable') { %>
<div class="overflow-x-auto">
  <table class="table w-full">
    <tbody>
      <% if (typeof data !== 'undefined' && Array.isArray(data)) { %>
        <% data.forEach(function(item) { %>
        <tr class="hover:bg-base-200/50">
          <td class="font-medium text-base-content/70 w-1/3"><%= item.key || item.label %></td>
          <td class="text-primary font-mono"><%- item.value %></td>
        </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>
</div>
<% } %>

<%# Status Table Component %>
<% if (typeof component !== 'undefined' && component === 'statusTable') { %>
<div class="overflow-x-auto">
  <table class="table table-zebra w-full">
    <thead>
      <tr class="bg-base-200">
        <th class="text-primary font-bold">Service</th>
        <th class="text-primary font-bold">Status</th>
        <th class="text-primary font-bold">Details</th>
        <th class="text-primary font-bold">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (typeof items !== 'undefined' && Array.isArray(items)) { %>
        <% items.forEach(function(item) { %>
        <tr class="hover:bg-base-200/50">
          <td class="text-base-content font-medium">
            <%= item.icon || '🔧' %> <%= item.name %>
          </td>
          <td>
            <div class="badge <%= item.status === 'online' ? 'badge-success' : item.status === 'offline' ? 'badge-error' : 'badge-warning' %>">
              <%= item.status === 'online' ? '🟢 Online' : item.status === 'offline' ? '🔴 Offline' : '⚪ Unknown' %>
            </div>
          </td>
          <td class="text-base-content/70 text-sm">
            <%= item.details || 'No details available' %>
          </td>
          <td>
            <div class="flex gap-1">
              <% if (item.testable) { %>
              <button class="btn btn-sm btn-primary" onclick="testService('<%= item.id %>')">
                🧪 Test
              </button>
              <% } %>
              <% if (item.configurable) { %>
              <button class="btn btn-sm btn-secondary" onclick="configureService('<%= item.id %>')">
                ⚙️ Config
              </button>
              <% } %>
            </div>
          </td>
        </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>
</div>
<% } %>

<%# Responsive Card Table (for mobile) %>
<% if (typeof component !== 'undefined' && component === 'cardTable') { %>
<div class="grid grid-cols-1 gap-4 lg:hidden">
  <% if (typeof items !== 'undefined' && Array.isArray(items)) { %>
    <% items.forEach(function(item) { %>
    <div class="card-monsterbox">
      <div class="card-body">
        <h3 class="card-title text-primary">
          <%= item.icon || '🔧' %> <%= item.name || item.title %>
        </h3>
        <% if (item.description) { %>
        <p class="text-base-content/70 text-sm"><%= item.description %></p>
        <% } %>
        <div class="grid grid-cols-2 gap-2 text-sm mt-2">
          <% Object.keys(item).forEach(function(key) { %>
            <% if (!['name', 'title', 'icon', 'description', 'actions'].includes(key)) { %>
            <div class="flex justify-between">
              <span class="text-base-content/70"><%= key %>:</span>
              <span class="text-primary font-mono"><%- item[key] %></span>
            </div>
            <% } %>
          <% }); %>
        </div>
        <% if (item.actions && Array.isArray(item.actions)) { %>
        <div class="card-actions justify-end mt-4">
          <% item.actions.forEach(function(action) { %>
          <button 
            class="btn btn-sm <%= action.class || 'btn-primary' %>" 
            onclick="<%= action.onclick %>"
            <%= action.disabled ? 'disabled' : '' %>
          >
            <%= action.icon || '' %> <%= action.text || '' %>
          </button>
          <% }); %>
        </div>
        <% } %>
      </div>
    </div>
    <% }); %>
  <% } %>
</div>
<% } %>

<%# Pagination Component %>
<% if (typeof component !== 'undefined' && component === 'pagination') { %>
<% if (totalPages > 1) { %>
<div class="flex justify-center mt-6">
  <div class="btn-group">
    <% if (currentPage > 1) { %>
    <a href="<%= baseUrl %>?page=<%= currentPage - 1 %>" class="btn btn-outline">«</a>
    <% } %>
    
    <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
      <% if (i === currentPage) { %>
      <button class="btn btn-active"><%= i %></button>
      <% } else { %>
      <a href="<%= baseUrl %>?page=<%= i %>" class="btn btn-outline"><%= i %></a>
      <% } %>
    <% } %>
    
    <% if (currentPage < totalPages) { %>
    <a href="<%= baseUrl %>?page=<%= currentPage + 1 %>" class="btn btn-outline">»</a>
    <% } %>
  </div>
</div>
<% } %>
<% } %>

<%# Filter Bar Component %>
<% if (typeof component !== 'undefined' && component === 'filterBar') { %>
<div class="card-monsterbox mb-6">
  <div class="card-body">
    <div class="flex flex-wrap gap-4 items-end">
      <% if (typeof filters !== 'undefined' && Array.isArray(filters)) { %>
        <% filters.forEach(function(filter) { %>
        <div class="form-control">
          <label class="label">
            <span class="label-text text-base-content"><%= filter.label %></span>
          </label>
          <% if (filter.type === 'select') { %>
          <select class="select select-bordered select-sm" onchange="<%= filter.onchange || 'filterTable()' %>">
            <option value="">All <%= filter.label %></option>
            <% filter.options.forEach(function(option) { %>
            <option value="<%= option.value %>"><%= option.text %></option>
            <% }); %>
          </select>
          <% } else { %>
          <input 
            type="<%= filter.type || 'text' %>" 
            class="input input-bordered input-sm" 
            placeholder="<%= filter.placeholder || 'Filter...' %>"
            onchange="<%= filter.onchange || 'filterTable()' %>"
          >
          <% } %>
        </div>
        <% }); %>
      <% } %>
      <div class="form-control">
        <button class="btn btn-primary btn-sm" onclick="applyFilters()">
          🔍 Apply Filters
        </button>
      </div>
      <div class="form-control">
        <button class="btn btn-outline btn-sm" onclick="clearFilters()">
          🗑️ Clear
        </button>
      </div>
    </div>
  </div>
</div>
<% } %>
