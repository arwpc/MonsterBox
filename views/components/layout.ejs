<!DOCTYPE html>
<html lang="en" data-bs-theme="<%= config.theme || 'dark' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-robot"></i>
                MonsterBox 4.0
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'dashboard' ? 'active' : '' %>" href="/">
                            <i class="bi bi-house"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle <%= page?.startsWith('setup') ? 'active' : '' %>" href="#"
                            role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-gear"></i> Setup
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/setup/parts">
                                    <i class="bi bi-cpu"></i> Parts
                                </a></li>
                            <li><a class="dropdown-item" href="/setup/calibration">
                                    <i class="bi bi-sliders"></i> Calibration
                                </a></li>
                            <li><a class="dropdown-item" href="/setup/poses">
                                    <i class="bi bi-person-arms-up"></i> Poses
                                </a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/audio">
                                    <i class="bi bi-volume-up"></i> Audio
                                </a></li>
                            <li><a class="dropdown-item" href="/setup/webcam">
                                    <i class="bi bi-camera-video"></i> Webcam
                                </a></li>
                            <li><a class="dropdown-item" href="/setup/super-powers">
                                    <i class="bi bi-lightning"></i> Super Powers
                                </a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/system">
                                    <i class="bi bi-pc-display"></i> System
                                </a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'live-dashboard' ? 'active' : '' %>" href="/live">
                            <i class="bi bi-play-circle"></i> Live Mode
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'scenes' ? 'active' : '' %>" href="/scenes">
                            <i class="bi bi-film"></i> Scenes
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i>
                            <span id="charLabel">
                                <% if (currentCharacter) { %>Character <%= currentCharacter %>
                                        <% } else { %>No Character<% } %>
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" id="charMenu">
                            <li>
                                <h6 class="dropdown-header">Character Selection</h6>
                            </li>
                            <li class="px-3 py-2 text-muted" id="charLoading">Loading...</li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/characters"><i class="bi bi-people"></i> Manage
                                    Characters</a></li>
                            <li><a class="dropdown-item" href="/setup/system"><i class="bi bi-gear"></i> Settings</a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container-fluid py-4">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-light py-3 mt-5">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-6">
                    <small>&copy; 2025 MonsterBox 4.0 - Single Node Animatronic Control</small>
                </div>
                <div class="col-md-6 text-end">
                    <small>
                        <i class="bi bi-cpu"></i> Hardware:
                        <span class="badge bg-success">Connected</span>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="/js/monsterbox4.js"></script>

    <script>
        (function () {
            function esc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
            function setLabel(name) {
                var el = document.getElementById('charLabel');
                if (el) { el.textContent = name ? ('Character ' + name) : 'No Character'; }
            }
            function populateMenu(chars, selectedId) {
                var ul = document.getElementById('charMenu');
                var loading = document.getElementById('charLoading');
                if (loading) { loading.parentNode.removeChild(loading); }
                if (!ul) return;
                // Insert characters before the divider (first hr)
                var itemsHtml = '';
                for (var i = 0; i < chars.length; i++) {
                    var c = chars[i];
                    var badge = (selectedId === c.id) ? ' <span class=\'badge bg-success ms-2\'>Current</span>' : '';
                    itemsHtml += '<li><button class="dropdown-item d-flex align-items-center" data-char-id="' + c.id + '">' + esc(c.name || ('Character ' + c.id)) + badge + '</button></li>';
                }
                var hrIndex = -1; for (var j = 0; j < ul.children.length; j++) { if (ul.children[j].tagName === 'HR' || ul.children[j].querySelector('hr')) { hrIndex = j; break; } }
                var tmp = document.createElement('div'); tmp.innerHTML = itemsHtml; var nodes = Array.prototype.slice.call(tmp.children);
                if (hrIndex >= 0) { for (var k = nodes.length - 1; k >= 0; k--) { ul.insertBefore(nodes[k], ul.children[hrIndex]); } }
                else { for (var k2 = 0; k2 < nodes.length; k2++) { ul.appendChild(nodes[k2]); } }
                // Attach handlers
                ul.addEventListener('click', function (e) {
                    var btn = e.target.closest ? e.target.closest('button.dropdown-item') : e.target;
                    if (!btn || !btn.getAttribute) return;
                    var id = parseInt(btn.getAttribute('data-char-id'), 10);
                    if (!id) return;
                    fetch('/setup/characters/api/select', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: id }) })
                        .then(function (r) { return r.json(); })
                        .then(function (d) {
                            if (d && d.success) {
                                // Update label then reload to ensure pages use new selection
                                var nm = null; for (var m = 0; m < chars.length; m++) { if (chars[m].id === id) { nm = chars[m].name; break; } }
                                setLabel(nm || String(id)); location.reload();
                            }
                        });
                });
            }
            function init() {
                var p1 = fetch('/setup/characters/api/current').then(function (r) { return r.json(); }).catch(function () { return { selectedCharacter: null } });
                var p2 = fetch('/setup/characters/api/characters').then(function (r) { return r.json(); }).catch(function () { return { success: false, characters: [] } });
                Promise.all([p1, p2]).then(function (arr) {
                    var cur = arr[0]; var list = arr[1];
                    var selectedId = cur && typeof cur.selectedCharacter !== 'undefined' ? cur.selectedCharacter : null;
                    var chars = list && list.success ? list.characters : [];
                    var nm = null; for (var i = 0; i < chars.length; i++) { if (chars[i].id === selectedId) { nm = chars[i].name; break; } }
                    setLabel(nm);
                    populateMenu(chars, selectedId);
                });
            }
            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init); else init();
        })();
    </script>

    <!-- Page-specific scripts -->
    <% if (typeof scripts !=='undefined' ) { %>
        <% scripts.forEach(function(script){ %>
            <script src="<%= script %>"></script>
            <% }); %>
                <% } %>
</body>

</html>