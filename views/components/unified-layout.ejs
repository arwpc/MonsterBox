<!DOCTYPE html>
<html lang="en" data-bs-theme="<%= config?.theme || 'dark' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link href="/css/monsterbox4.css" rel="stylesheet">

    <!-- Page-specific CSS -->
    <% if (typeof styles !=='undefined' ) { %>
        <% styles.forEach(function(style){ %>
            <link href="<%= style %>" rel="stylesheet">
            <% }); %>
                <% } %>
</head>

<body>
    <!-- Unified Navigation - Used on ALL pages -->
    <%- include('unified-navigation', { page: 'dashboard' }) %>

        <!-- Main Content -->
        <main class="container-fluid py-4">
            <%- body %>
        </main>

        <!-- Footer -->
        <footer class="bg-dark text-light py-3 mt-5">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-6">
                        <small>&copy; 2025 MonsterBox 5.3 - Single Node Animatronic Control</small>
                    </div>
                    <div class="col-md-6 text-end">
                        <small>
                            <i class="bi bi-cpu"></i> Hardware:
                            <span class="badge bg-success">Connected</span>
                        </small>
                    </div>
                </div>
            </div>
        </footer>

        <!-- Bootstrap 5 JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

        <!-- Custom JS -->
        <script src="/js/monsterbox4.js"></script>

        <!-- Page-specific scripts -->
        <% if (typeof scripts !=='undefined' ) { %>
            <% scripts.forEach(function(script){ %>
                <script src="<%= script %>"></script>
                <% }); %>
                    <% } %>
</body>

</html>