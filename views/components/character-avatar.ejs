<%
/**
 * Character Avatar Component
 * 
 * Displays a circular character avatar with fallback to initials or skull icon
 * 
 * Parameters:
 * - character: Character object with { id, name, activeImage }
 * - size: Size in pixels (default: 40)
 * - showName: Whether to show character name next to avatar (default: false)
 * - className: Additional CSS classes (default: '')
 */

const char = locals.character || {};
const charId = char.id || '';
const charName = char.name || 'Unknown';
const activeImage = char.activeImage || '';
const size = locals.size || 40;
const showName = locals.showName !== undefined ? locals.showName : false;
const className = locals.className || '';

// Generate initials from character name
function getInitials(name) {
  if (!name) return '?';
  const words = name.trim().split(/\s+/);
  if (words.length === 1) return words[0].substring(0, 2).toUpperCase();
  return (words[0][0] + words[words.length - 1][0]).toUpperCase();
}

const initials = getInitials(charName);
const imageUrl = activeImage ? `/api/characters/${charId}/images/${activeImage}` : '';
%>

<div class="character-avatar-wrapper d-inline-flex align-items-center <%= className %>" data-character-id="<%= charId %>">
  <div class="character-avatar rounded-circle overflow-hidden d-flex align-items-center justify-content-center" 
       style="width: <%= size %>px; height: <%= size %>px; min-width: <%= size %>px; background: linear-gradient(135deg, var(--mb-primary) 0%, var(--mb-primary-dark, #5a359a) 100%); color: white; font-weight: bold; font-size: <%= Math.floor(size * 0.4) %>px;"
       title="<%= charName %>">
    <% if (imageUrl) { %>
      <img src="<%= imageUrl %>" 
           alt="<%= charName %>" 
           class="w-100 h-100 object-fit-cover"
           onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
      <div class="w-100 h-100 d-none align-items-center justify-content-center" style="display: none !important;">
        <%= initials %>
      </div>
    <% } else { %>
      <%= initials %>
    <% } %>
  </div>
  <% if (showName) { %>
    <span class="ms-2 character-name"><%= charName %></span>
  <% } %>
</div>

