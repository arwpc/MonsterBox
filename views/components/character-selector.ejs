<!-- Character Selection Component -->
<div class="card-monsterbox mb-8">
    <div class="card-header-monsterbox">
        <h3 class="text-2xl font-bold text-primary flex items-center">
            🎭 Character Selection
        </h3>
    </div>
    
    <div class="card-body">
        <% if (characters && characters.length > 0) { %>
            <div class="form-control w-full max-w-xs">
                <label class="label">
                    <span class="label-text text-base-content">Choose a character to control:</span>
                </label>
                <select id="character-select" class="select select-bordered select-primary w-full max-w-xs" onchange="updateCharacter(this.value)">
                    <option value="" disabled selected>Select a character</option>
                    <% characters.forEach(function(character) { %>
                        <option value="<%= character.id %>">
                            <%= character.char_name %>
                        </option>
                    <% }); %>
                </select>
                <label class="label">
                    <span class="label-text-alt text-base-content/70">This will update all navigation links with the selected character context.</span>
                </label>
            </div>
            
            <!-- Character Info Display -->
            <div id="character-info" class="mt-6 hidden">
                <div class="alert alert-info">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div>
                        <h4 class="font-bold">Character Selected</h4>
                        <p id="character-name">Character information will appear here</p>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="alert alert-warning">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                </svg>
                <div>
                    <h4 class="font-bold">No Characters Available</h4>
                    <p>Please create a character first to get started.</p>
                    <div class="mt-4">
                        <a href="/characters" class="btn btn-primary btn-sm">
                            Create Character
                        </a>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</div>

<script>
    // Enhanced character selection with info display
    function updateCharacterInfo(characterId) {
        const characters = <%- JSON.stringify(characters || []) %>;
        const character = characters.find(c => c.id === characterId);
        const infoDiv = document.getElementById('character-info');
        const nameSpan = document.getElementById('character-name');
        
        if (character && infoDiv && nameSpan) {
            nameSpan.textContent = `${character.char_name} is now selected for control operations.`;
            infoDiv.classList.remove('hidden');
        } else if (infoDiv) {
            infoDiv.classList.add('hidden');
        }
    }

    // Override the global updateCharacter function to include info display
    const originalUpdateCharacter = window.updateCharacter;
    window.updateCharacter = function(characterId) {
        if (originalUpdateCharacter) {
            originalUpdateCharacter(characterId);
        }
        updateCharacterInfo(characterId);
    };
</script>
