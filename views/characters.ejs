<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Creepster&display=swap">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>
<body>
    <header>
        <h1 class="landing-title">🎭 <%= title %></h1>
    </header>

    <main>
        <div class="info-section">
            <h3>🎭 Character Management</h3>
            <p>Manage animatronic characters and their configurations. Assign hardware parts and AI instances to create complete character experiences.</p>
        </div>

        <div class="button-group">
            <a href="/characters/new" class="button primary-btn">🎭 Add New Character</a>
            <a href="/ai-instances" class="button">🧠 Manage AI Instances</a>
            <a href="/parts" class="button">🔧 Manage Hardware Parts</a>
            <a href="/" class="button secondary-btn">Back to Main Menu</a>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Hardware Parts</th>
                        <th>AI Instances</th>
                        <th>Sounds</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(let character of characters) { %>
                        <tr>
                            <td>
                                <% if (character.image) { %>
                                    <img src="/images/characters/<%= character.image %>" alt="<%= character.char_name %>" style="max-width: 100px;">
                                <% } else { %>
                                    No Image
                                <% } %>
                            </td>
                            <td><%= character.char_name %></td>
                            <td><%= character.char_description %></td>
                            <td>
                                <div class="parts-assignment">
                                    <%
                                    let displayParts = [];
                                    // Check parts with characterId
                                    parts.forEach(function(part) {
                                        if (part.characterId === character.id) {
                                            displayParts.push(part);
                                        }
                                    });
                                    // Check character's parts array
                                    if (character.parts && character.parts.length > 0) {
                                        parts.forEach(function(part) {
                                            if (character.parts.includes(part.id) && !displayParts.find(p => p.id === part.id)) {
                                                displayParts.push(part);
                                            }
                                        });
                                    }
                                    if (displayParts.length > 0) {
                                        displayParts.forEach(function(part) {
                                    %>
                                        <span class="part-tag"><%= part.name %></span>
                                    <% });
                                    } else { %>
                                        <small style="color: #888;">No parts assigned</small>
                                    <% } %>
                                    <br>
                                    <a href="/characters/<%= character.id %>/parts" class="button small-btn">🔧 Manage Parts</a>
                                </div>
                            </td>
                            <td>
                                <div class="ai-assignment">
                                    <% if (character.chatterpi_config && character.chatterpi_config.ai_characters && character.chatterpi_config.ai_characters.length > 0) { %>
                                        <% character.chatterpi_config.ai_characters.forEach(function(aiId) { %>
                                            <span class="ai-tag">
                                                <%= aiId === 'orlok' ? 'Count Orlok' :
                                                    aiId === 'robochat' ? 'RoboChat' :
                                                    aiId === 'blackbeard' ? 'Blackbeard' :
                                                    aiId.charAt(0).toUpperCase() + aiId.slice(1) %>
                                            </span>
                                        <% }); %>
                                        <br>
                                        <small>Default: <%=
                                            character.chatterpi_config.default_character === 'orlok' ? 'Count Orlok' :
                                            character.chatterpi_config.default_character === 'robochat' ? 'RoboChat' :
                                            character.chatterpi_config.default_character === 'blackbeard' ? 'Blackbeard' :
                                            character.chatterpi_config.default_character || 'None'
                                        %></small>
                                        <br>
                                        <a href="/characters/<%= character.id %>/ai" class="button small-btn">🔄 Change AI</a>
                                        <button onclick="removeAI(<%= character.id %>)" class="button small-btn danger-btn">❌ Remove AI</button>
                                    <% } else { %>
                                        <small style="color: #888;">No AI Assigned</small>
                                        <br>
                                        <a href="/characters/<%= character.id %>/ai" class="button small-btn">🧠 Assign AI</a>
                                    <% } %>
                                </div>
                            </td>
                            <td>
                                <div class="sounds-assignment">
                                    <%
                                    let displaySounds = [];
                                    // Check sounds with characterIds array
                                    sounds.forEach(function(sound) {
                                        if (sound.characterIds && sound.characterIds.includes(character.id)) {
                                            displaySounds.push(sound);
                                        }
                                    });
                                    // Check character's sounds array
                                    if (character.sounds && character.sounds.length > 0) {
                                        sounds.forEach(function(sound) {
                                            if (character.sounds.includes(sound.id) && !displaySounds.find(s => s.id === sound.id)) {
                                                displaySounds.push(sound);
                                            }
                                        });
                                    }
                                    if (displaySounds.length > 0) {
                                        displaySounds.forEach(function(sound) {
                                    %>
                                        <span class="sound-tag"><%= sound.name %></span>
                                    <% });
                                    } else { %>
                                        <small style="color: #888;">No sounds assigned</small>
                                    <% } %>
                                </div>
                            </td>
                            <td>
                                <div class="button-group">
                                    <a href="/characters/<%= character.id %>/edit" class="button">✏️ Edit</a>
                                    <button onclick="deleteCharacter(<%= character.id %>)" class="button danger-btn">🗑️ Delete</button>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <!-- Modal for displaying results -->
    <div id="resultModal" class="modal" style="display: none;">
        <div class="modal-content">
            <span class="close" onclick="closeModal()">&times;</span>
            <h2 id="modalTitle">Result</h2>
            <div id="modalBody"></div>
        </div>
    </div>

    <style>
        .modal {
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.8);
        }

        .modal-content {
            background-color: #000;
            border: 2px solid #00ff00;
            margin: 5% auto;
            padding: 20px;
            width: 80%;
            max-width: 800px;
            border-radius: 5px;
            color: #00ff00;
            max-height: 80vh;
            overflow-y: auto;
        }

        .close {
            color: #ff0000;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

        .close:hover {
            color: #ff6666;
        }

        .small-btn {
            padding: 2px 6px;
            font-size: 12px;
            margin: 1px;
            min-width: 25px;
        }

        .small-btn.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            background-color: #333;
            color: #666;
        }

        .animatronic-status {
            font-size: 12px;
        }

        .animatronic-controls {
            display: flex;
            gap: 2px;
            flex-wrap: wrap;
        }

        .test-result {
            margin: 10px 0;
            padding: 10px;
            border: 1px solid #333;
            border-radius: 3px;
        }

        .test-passed {
            border-color: #00ff00;
            background-color: rgba(0, 255, 0, 0.1);
        }

        .test-failed {
            border-color: #ff0000;
            background-color: rgba(255, 0, 0, 0.1);
        }

        .log-section {
            margin: 10px 0;
            padding: 10px;
            border: 1px solid #333;
            border-radius: 3px;
            background-color: rgba(0, 0, 0, 0.3);
        }

        .log-content {
            font-family: monospace;
            font-size: 11px;
            white-space: pre-wrap;
            max-height: 200px;
            overflow-y: auto;
            background-color: #111;
            padding: 5px;
            border: 1px solid #333;
        }

        .info-section {
            background: rgba(0, 255, 0, 0.1);
            border: 1px solid #00ff00;
            border-radius: 5px;
            padding: 15px;
            margin: 20px 0;
        }

        .info-section h3 {
            color: #00ff00;
            margin-bottom: 10px;
        }

        .parts-assignment, .ai-assignment, .sounds-assignment {
            font-size: 12px;
        }

        .part-tag, .ai-tag, .sound-tag {
            display: inline-block;
            padding: 2px 6px;
            margin: 1px;
            border-radius: 8px;
            font-size: 10px;
            font-weight: bold;
        }

        .part-tag {
            background: rgba(76, 175, 80, 0.2);
            color: #4CAF50;
            border: 1px solid #4CAF50;
        }

        .ai-tag {
            background: rgba(33, 150, 243, 0.2);
            color: #2196F3;
            border: 1px solid #2196F3;
        }

        .sound-tag {
            background: rgba(255, 152, 0, 0.2);
            color: #ff9800;
            border: 1px solid #ff9800;
        }
    </style>

    <script>


        function removeAI(characterId) {
            // Get character name for confirmation
            const button = document.querySelector(`button[onclick="removeAI(${characterId})"]`);
            const characterRow = button.closest('tr');
            const characterName = characterRow.querySelector('td:nth-child(2)').textContent.trim();

            if (confirm(`Are you sure you want to remove all AI assignments from "${characterName}"?`)) {
                showModal('Removing AI...', '<p>Please wait while AI assignments are being removed...</p>');

                fetch(`/characters/${characterId}/ai/remove-all`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showModal('AI Removed', `<p style="color: #00ff00;">✅ All AI assignments have been removed from "${characterName}".</p>`);
                        setTimeout(() => {
                            location.reload();
                        }, 2000);
                    } else {
                        showModal('Remove AI Failed', `<p style="color: #ff0000;">❌ Failed to remove AI from "${characterName}": ${data.error}</p>`);
                    }
                })
                .catch(error => {
                    console.error('Error details:', error);
                    showModal('Remove AI Failed', `<p style="color: #ff0000;">❌ Failed to remove AI from "${characterName}": ${error.message}</p>`);
                });
            }
        }

        function deleteCharacter(id) {
            // Get character name for confirmation
            const button = document.querySelector(`button[onclick="deleteCharacter(${id})"]`);
            const characterRow = button.closest('tr');
            const characterName = characterRow.querySelector('td:nth-child(2)').textContent.trim();

            if (confirm(`Are you sure you want to delete "${characterName}"? This action cannot be undone.`)) {
                // Show loading state
                showModal('Deleting Character...', '<p>Please wait while the character is being deleted...</p>');

                fetch('/characters/' + id + '/delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success !== false) {
                        showModal('Character Deleted', `<p style="color: #00ff00;">✅ "${characterName}" has been successfully deleted.</p>`);
                        setTimeout(() => {
                            location.reload();
                        }, 2000);
                    } else {
                        showModal('Delete Failed', `<p style="color: #ff0000;">❌ Failed to delete "${characterName}": ${data.error}</p>`);
                    }
                })
                .catch(error => {
                    console.error('Error details:', error);
                    showModal('Delete Failed', `<p style="color: #ff0000;">❌ Failed to delete "${characterName}": ${error.message}</p>`);
                });
            }
        }

        function closeModal() {
            document.getElementById('resultModal').style.display = 'none';
        }

        function showModal(title, content) {
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalBody').innerHTML = content;
            document.getElementById('resultModal').style.display = 'block';
        }



        // Close modal when clicking outside of it
        window.onclick = function(event) {
            const modal = document.getElementById('resultModal');
            if (event.target == modal) {
                closeModal();
            }
        }
    </script>
</body>
</html>
