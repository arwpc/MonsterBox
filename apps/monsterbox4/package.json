{
  "name": "monsterbox4",
  "version": "4.0.0",
  "description": "MonsterBox 4.0 - Single Node Animatronic Control System with Poses",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha tests/**/*.test.js --timeout 10000",
    "test:unit": "mocha tests/basic.test.js tests/hardware/**/*.test.js --timeout 10000",
    "test:ui": "playwright test",
    "test:ui-headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run test:ui"
  },
  "keywords": [
    "animatronic",
    "raspberry-pi",
    "servo",
    "poses",
    "hardware-control"
  ],
  "author": "MonsterBox Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ejs": "^3.1.9",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "mocha": "^10.2.0",
    "chai": "^4.3.10",
    "playwright": "^1.40.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}