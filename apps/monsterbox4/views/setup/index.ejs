<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setup - MonsterBox 4.0</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/monsterbox4.css" rel="stylesheet">
</head>

<body>
    <!-- Navigation (copied from layout for stability) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="bi bi-robot"></i> MonsterBox 4.0</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> Dashboard</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle active" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-gear"></i> Setup
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/setup/parts"><i class="bi bi-cpu"></i> Parts</a></li>
                            <li><a class="dropdown-item" href="/setup/calibration"><i class="bi bi-sliders"></i>
                                    Calibration</a></li>
                            <li><a class="dropdown-item" href="/setup/poses"><i class="bi bi-person-arms-up"></i>
                                    Poses</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/audio"><i class="bi bi-volume-up"></i> Audio</a>
                            </li>
                            <li><a class="dropdown-item" href="/setup/webcam"><i class="bi bi-camera-video"></i>
                                    Webcam</a></li>
                            <li><a class="dropdown-item" href="/setup/super-powers"><i class="bi bi-lightning"></i>
                                    Super Powers</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" href="/setup/system"><i class="bi bi-pc-display"></i>
                                    System</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/live"><i class="bi bi-play-circle"></i> Live
                            Mode</a></li>
                    <li class="nav-item"><a class="nav-link" href="/scenes"><i class="bi bi-film"></i> Scenes</a></li>
                </ul>
                <%- include('../partials/characterMenu') %>
            </div>
        </div>
    </nav>

    <main class="container-fluid py-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1><i class="bi bi-gear"></i> Setup</h1>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-cpu display-4 text-primary mb-3"></i>
                        <h5 class="card-title">Parts</h5>
                        <p class="card-text">Configure animatronic parts, servos, and hardware components.</p>
                        <a href="/setup/parts" class="btn btn-primary">
                            <i class="bi bi-arrow-right"></i> Configure Parts
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-person-arms-up display-4 text-success mb-3"></i>
                        <h5 class="card-title">Poses</h5>
                        <p class="card-text">Create and manage poses for your animatronic character.</p>
                        <a href="/setup/poses" class="btn btn-success">
                            <i class="bi bi-arrow-right"></i> Manage Poses
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-sliders display-4 text-warning mb-3"></i>
                        <h5 class="card-title">Calibration</h5>
                        <p class="card-text">Calibrate servo positions and movement ranges.</p>
                        <a href="/setup/calibration" class="btn btn-warning">
                            <i class="bi bi-arrow-right"></i> Calibrate
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-volume-up display-4 text-info mb-3"></i>
                        <h5 class="card-title">Audio</h5>
                        <p class="card-text">Configure audio settings and sound effects.</p>
                        <a href="/setup/audio" class="btn btn-info">
                            <i class="bi bi-arrow-right"></i> Audio Settings
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-camera-video display-4 text-secondary mb-3"></i>
                        <h5 class="card-title">Webcam</h5>
                        <p class="card-text">Configure webcam and vision settings.</p>
                        <a href="/setup/webcam" class="btn btn-secondary">
                            <i class="bi bi-arrow-right"></i> Webcam Setup
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-pc-display display-4 text-dark mb-3"></i>
                        <h5 class="card-title">System</h5>
                        <p class="card-text">System preferences and advanced settings.</p>
                        <a href="/setup/system" class="btn btn-dark">
                            <i class="bi bi-arrow-right"></i> System Settings
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/monsterbox4.js"></script>
    <script src="/js/character-menu.js"></script>
</body>

</html>