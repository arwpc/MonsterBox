<!DOCTYPE html>
<html lang="en" data-bs-theme="<%= config.theme || 'dark' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link href="/css/monsterbox4.css" rel="stylesheet">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-robot"></i>
                MonsterBox 4.0
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'dashboard' ? 'active' : '' %>" href="/">
                            <i class="bi bi-house"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle <%= page?.startsWith('setup') ? 'active' : '' %>" 
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-gear"></i> Setup
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/setup/parts">
                                <i class="bi bi-cpu"></i> Parts
                            </a></li>
                            <li><a class="dropdown-item" href="/setup/calibration">
                                <i class="bi bi-sliders"></i> Calibration
                            </a></li>
                            <li><a class="dropdown-item" href="/setup/poses">
                                <i class="bi bi-person-arms-up"></i> Poses
                            </a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/setup/audio">
                                <i class="bi bi-volume-up"></i> Audio
                            </a></li>
                            <li><a class="dropdown-item" href="/setup/webcam">
                                <i class="bi bi-camera-video"></i> Webcam
                            </a></li>
                            <li><a class="dropdown-item" href="/setup/super-powers">
                                <i class="bi bi-lightning"></i> Super Powers
                            </a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/setup/system">
                                <i class="bi bi-pc-display"></i> System
                            </a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'live-dashboard' ? 'active' : '' %>" href="/live">
                            <i class="bi bi-play-circle"></i> Live Mode
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'scenes' ? 'active' : '' %>" href="/scenes">
                            <i class="bi bi-film"></i> Scenes
                        </a>
                    </li>
                </ul>
                
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i>
                            <% if (currentCharacter) { %>
                                Character <%= currentCharacter %>
                            <% } else { %>
                                No Character
                            <% } %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">Character Selection</h6></li>
                            <li><a class="dropdown-item" href="?characterId=1">Orlok</a></li>
                            <li><a class="dropdown-item" href="?characterId=4">Skulltalker</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/setup/system">
                                <i class="bi bi-gear"></i> Settings
                            </a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container-fluid py-4">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-light py-3 mt-5">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-6">
                    <small>&copy; 2025 MonsterBox 4.0 - Single Node Animatronic Control</small>
                </div>
                <div class="col-md-6 text-end">
                    <small>
                        <i class="bi bi-cpu"></i> Hardware: 
                        <span class="badge bg-success">Connected</span>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script src="/js/monsterbox4.js"></script>
    
    <!-- Page-specific scripts -->
    <% if (typeof scripts !== 'undefined') { %>
        <% scripts.forEach(script => { %>
            <script src="<%= script %>"></script>
        <% }); %>
    <% } %>
</body>
</html>
